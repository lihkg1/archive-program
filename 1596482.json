aces/lm2/point1.gif\" class=\"hkgmoji\" /><br />\npush"},{"pid":"308a58165d3a6a09556d9f14ed0185949860c599","tid":1596482,"uid":193233,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T14:21:06.000Z","msg":"但有班人話廢左，英美冇藉口介入呢？<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"1a4991e6d5240b4fd878801256acc1b450de95fc","tid":1596482,"uid":224479,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T14:21:26.000Z","msg":"<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />"},{"pid":"9fc251c492a9e933ce0d71218511ea90cccdfe52","tid":1596482,"uid":98141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T14:26:23.000Z","msg":"push"},{"pid":"986f941b364c225bfdd89a788c5bd108937ee44b","tid":1596482,"uid":108757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T14:28:18.000Z","msg":"提出廢除嘅建議，主要係逼英國同中國反枱，真正推上國際，變成香港主權問題，唔係內部政治問題。<br />\n<br />\n如果主流民意係廢除，香港就變成中立，唔歸於任何國家。<span style=\"color: red;\">中國強行出兵，就會變咗侵略，真正變成CHINAZI</span>！咁WW3就有可能發生！"},{"pid":"88af2e9576ddbf0559b1d3629fae786e7d177937","tid":1596482,"uid":108757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T14:35:00.000Z","msg":"中國係侵略香港<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"}]}