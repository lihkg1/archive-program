src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"1bbab182db7c9363a2eb4a851ee2f73245e7f525","tid":1949170,"uid":125026,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-29T16:52:05.000Z","msg":"推"},{"pid":"17d83a5a3c2d3fbc39316f8f59db518a5e4168eb","tid":1949170,"uid":269686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-29T17:03:36.000Z","msg":"<img src=\"/assets/faces/big/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/kiss.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"aaa91d99ae030ba7aca5959f44d6fd05e458a6ec","tid":1949170,"uid":156767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-29T17:52:59.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"acd9021293e1cb723f89b2c7584b94e216ac7cf2","tid":1949170,"uid":61604,"like":0,"dislike":0,"score":0,"quote":{"pid":"82bca4612ac1ce14122c6cce373aebfed4df273d","tid":1949170,"uid":267969,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-29T12:47:21.000Z","msg":"<span style=\"font-size: x-large;\"><strong>【<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />週日特別任務<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />29 Mar 2020】</strong></span><br />\n<img src=\"https://na.cx/i/bBhHGC8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbBhHGC8.jpg&h=6a585233&s={SIZE}\" /><br />\n<br />\n⚔️【行動概要】<br />\n仲喺TVB落廣告嘅品牌，一定唔care香港人嘅感愛，或者藍底紅底🔹🇨🇳<br />\n藍絲最驚係乜？驚死囉☠️～所以我哋要做下好心，將品牌真實嘅產品問題spread俾藍絲，等佢哋都加入抵制大軍🤪<br />\n<br />\n⚔️【行動詳情】<br />\n<strong><span style=\"color: orange;\">Step 1️⃣ 去Discuss, Uwants, Babycondom推post</span></strong><br />\n⚠️注意事項：<br />\n💢俾少少心機回覆，如果只係回覆&quot;推&quot;、表情灌水，嚴重者可能被封鎖帳戶<br />\n💢Template：&quot;真係好恐怖&quot;, &quot;日本牌子都唔係安全&quot;<br />\n💢隔幾日再回覆，推足一星期<br />\n<br />\n👉🏻Discuss<br />\n<a href=\"https://ladies.discuss.com.hk/viewthread.php?tid=28959731\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fladies.discuss.com.hk%2Fviewthread.php%3Ftid%3D28959731&d=UCtUugLpQcFJMmY1nWpYq8g1Od0Dt6CGL4wHSLmh2%2Bg%3D&h=28a42e85\" data-auto-link target=\"_blank\">https://ladies.discuss.com.hk/viewthread.php?tid=28959731</a><br />\n👉🏻Uwants<br />\n<a href=\"https://www.uwants.com/viewthread.php?tid=20124906\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.uwants.com%2Fviewthread.php%3Ftid%3D20124906&d=UCtUugLpQcFJMmY1nWpYq8g1Od0Dt6CGL4wHSLmh2%2Bg%3D&h=55743094\" data-auto-link target=\"_blank\">https://www.uwants.com/viewthread.php?tid=20124906</a><br />\n👉🏻親子王國<br />\n<a href=\"https://www.baby-kingdom.com/forum.php?mod=viewthread&amp;tid=23147877\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.baby-kingdom.com%2Fforum.php%3Fmod%3Dviewthread%26tid%3D23147877&d=UCtUugLpQcFJMmY1nWpYq8g1Od0Dt6CGL4wHSLmh2%2Bg%3D&h=a7fe9365\" data-auto-link target=\"_blank\">https://www.baby-kingdom.com/forum.php?mod=viewthread&amp;tid=23147877</a><br />\n<br />\n<br />\n<strong><span style=\"color: orange;\">Step 2️⃣ Whatsapp</span></strong><br />\n將雪印醜聞傳spread去Whatsapp長者group、媽媽group，請喺留言搵圖及文字<br />\n<br />\n<strong><span style=\"color: orange;\">Step 3️⃣ 進階 - 開post：</span></strong><br />\n喺唔同討論區相關分台自行開post，但如果見到手足已開post，推post就得（請注意相關版規）<br />\n<br />\n<br />\nP.S. Discuss嗰班TVB柒fans好期待我哋入去影視台踩場，我哋偏偏唔入去，歡迎佢哋幫手推post<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-29T18:29:51.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"9b3534913db5ffa8db2980272395da7c141ebe23","tid":1949170,"uid":3149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-29T18:48:4