0,"score":1,"citedBy":0,"replyTime":"2018-07-06T12:35:20.000Z","msg":"rm -rf /"},{"pid":"dc43ea7b1493c18788af0e577fd0791daa2b8762","tid":731660,"uid":7311,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-06T12:36:37.000Z","msg":"會唔會又出現爆玻璃 同埋 入錯油"}]}