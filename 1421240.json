aces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"c8ae45849483694e5408a2f6e8237daf9060bc54","tid":1421240,"uid":158270,"like":1,"dislike":2,"score":-1,"citedBy":3,"replyTime":"2019-08-06T07:39:14.000Z","msg":"如果係真，絕對係失控。<br />\n如果係假，你一定係鬼。"},{"pid":"ed123e9d11fd5ec65b20ffc4dd875ab8505f45db","tid":1421240,"uid":285424,"like":2,"dislike":0,"score":2,"quote":{"pid":"091b5a38900e4a6f429ce942600c4461e4467998","tid":1421240,"uid":189157,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-06T07:36:42.000Z","msg":"證據?<br />\n有冇其他手足係現場出黎講下?"},"citedBy":0,"replyTime":"2019-08-06T07:40:28.000Z","msg":"我無喇，嗰刻點會諗住要留證據出post<img src=\"/assets/faces/lomoji/39.png\" class=\"hkgmoji\" /><br />\n睇下有無手足都同場吧"},{"pid":"432e593c581d88a9c4e2fd60243780d61e68d00e","tid":1421240,"uid":285424,"like":1,"dislike":1,"score":0,"quote":{"pid":"c8ae45849483694e5408a2f6e8237daf9060bc54","tid":1421240,"uid":158270,"like":1,"dislike":2,"score":-1,"citedBy":3,"replyTime":"2019-08-06T07:39:14.000Z","msg":"如果係真，絕對係失控。<br />\n如果係假，你一定係鬼。"},"citedBy":0,"replyTime":"2019-08-06T07:43:44.000Z","msg":"我無諗咁多喇，出post係想大家睇住件事，需要時幫下d路人帶下口罩，引下路之類，後排手足同時做呢d都好過齋企吖"},{"pid":"181b285a696148a9ea6a045c5630e13cbe100295","tid":1421240,"uid":93311,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-08-06T07:43:56.000Z","msg":"又帶風向話示威者好暴力<br />\n太多風向post救命"},{"pid":"aef84c7a44bfe2a892d86446e196d62c8e261956","tid":1421240,"uid":280648,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T07:45:04.000Z","msg":"推"},{"pid":"b6a004b442e8fc34cdf24befef8d5f39338f4367","tid":1421240,"uid":32221,"like":2,"dislike":1,"score":1,"quote":{"pid":"c8ae45849483694e5408a2f6e8237daf9060bc54","tid":1421240,"uid":158270,"like":1,"dislike":2,"score":-1,"citedBy":3,"replyTime":"2019-08-06T07:39:14.000Z","msg":"如果係真，絕對係失控。<br />\n如果係假，你一定係鬼。"},"citedBy":0,"replyTime":"2019-08-06T07:46:57.000Z","msg":"真假唔重要<br />\n過左就係過左<br />\n重要既係未來<br />\n前線太惡，對打卡太敏感唔係第一日既事<br />\n都係果句<br />\n做人唔帶關公出街好易屎都冇得食"},{"pid":"e77abae6949c153088980f0955c5d953b48a8aa0","tid":1421240,"uid":285424,"like":1,"dislike":0,"score":1,"quote":{"pid":"181b285a696148a9ea6a045c5630e13cbe100295","tid":1421240,"uid":93311,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-08-06T07:43:56.000Z","msg":"又帶風向話示威者好暴力<br />\n太多風向post救命"},"citedBy":0,"replyTime":"2019-08-06T07:49:56.000Z","msg":"P牌乜7都唔識<img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />係咪應該揀個好d嘅timing出呢d post？<br />\n無心distract架，見好多人有出呢類，但今次自己見到實例真係感受到有d野要睇反住個目標，自己要清晰我地每個人都係運動嘅一部分，自己決定做咩位，可以幫到d咩，而唔係要人地湊住我地，就可以不負責任"},{"pid":"e8f83193aa0c0afd7f4986292a6df9b62fcc86a5","tid":1421240,"uid":260740,"like":2,"dislike":0,"score":2,"quote":{"pid":"3e5e135b0352db88c0f5f5cbe4a6478221f14561","tid":1421240,"uid":2215,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-06T07:36:29.000Z","msg":"我發夢時都做錯左, 影衰左手足 希望求原諒"},"citedBy":0,"replyTime":"2019-08-06T08:11:41.000Z","msg":"唔好再做就得<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n同埋阻止身邊嘅人再犯錯<br />\n因為形象一衰咗就好難補救<br />\n啲警察就係活生生嘅例子"},{"pid":"c3ba38a7bb1cb714811656b54c28acd2f49e26b0","tid":1421240,"uid":260740,"like":0,"dislike":0,"score":0,"quote":{"pid":"a25d295c04f02df48265c7a82486b8caeb523076","tid":1421240,"uid":285424,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-06T07:30:35.000Z","msg":"P牌忍唔住第一次出post！<br />\n<br />\n琴日發夢11點幾喺太子<br />\nd狗射左幾粒催淚後<br />\n大家退到去朗豪位置<br />\n<br />\n我親眼望住<br />\n有個路人女人拎住電話影現場(利申 唔知佢影乜)<br />\n<span style=\"font-size: large;\"><span style=\"color: gold;\">有個手足企喺佢身後<br />\n無喇喇將佢部電話拍9咗落地！仲要係勁L大力！<br />\n之後就行開咗<br />\n好明顯純發洩！</span></span><br />\n屌你開聲叫佢唔好影都唔做？<br />\n直接攻擊？<br />\n咁同d狗有乜L野分別？<br />\n<br />\n個女人即刻鬧，<span style=\"font-size: large;\">話原來我地先係暴徒！</span><br />\n我同幾個手足行過去道歉<br />\n我唔敢望佢部電話，好怕真係壞我地都無錢賠，但因為係自己人做錯，又好想承擔呢個責任，但當時都真係做唔到d咩<br />\n個女人情緒有d激動，一路鬧我地，我地唯有勸佢離開<br />\n因為同時又有好多唔知咩事嘅手足加入鬧個女人<br />\n(呢個位真係好無奈，屌<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />)<br />\n我同一兩個見到件事嘅朋友只能夠同大家講無事無事咁<br />\n嗱據我觀察，個女人只係普通師奶<br />\n莫講話師奶，就算佢真係個內地記者之類<br />\n都唔係下下郁手喇！？<br />\n唔好當係自己地頭就打橫行先得架！<br />\n要打要發洩留反喺d狗身上！<br />\n<br />\n好後悔當時我無勇氣大聲講反件事出黎<img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" /><br />\n一黎d狗仲攻緊仲係危險，怕side track<br />\n亦好可能因為怕無人信我，怕另生事端<br />\n只能夠反到黎出post<br />\n我地成日話不分化，除咗自己人<br />\n盡可能都唔好再樹立敵人<br />\n我都唔係和理非，但呢d情形<br />\n見到真係好心疼<br />\n<br />\n心疼個政府迫到我地變成點<br />\n心疼快要失去焦點<br />\n亦只係被引導到去用一種仇恨既情緒去發夢<br />\n<br />\n求求大家，睇住你身邊d朋友，適當嘅時候㩒㩒佢地，情緒好濃烈嘅就陪佢屌下笑下，齊上齊落！<br />\n<br />\n千祈唔好變成你心中痛恨嘅嗰種人！<img src=\"/assets/faces/big/angry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-06T08:14:46.000Z","msg":"建議下次遇到類似嘅事<br />\n以和平嘅口吻勸一下太過激動嘅手足<br />\n我相信喺前線亦都有唔少同你持有相同諗法嘅人<br />\n唔好鬧交但一定要勸"},{"pid":"ff366f3a8b04b9d5ea6985047b5b58e2619a2dcb","tid":1421240,"uid":258825,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:16:53.000Z","msg":"推"},{"pid":"4e3a7bcaf243806e11c5126e1ff1adaba3984999","tid":1421240,"uid":260325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:22:37.000Z","msg":"推"},{"pid":"b77c9308f109ce2dcdfa9b2f37160e31041f8e9b","tid":1421240,"uid":149728,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:22:43.000Z","msg":"推"},{"pid":"03ab6e0ff4c38980d12d7048dfc858e87c309ce1","tid":1421240,"uid":285424,"like":1,"dislike":0,"score":1,"quote":{"pid":"c3ba38a7bb1cb714811656b54c28acd2f49e26b0","tid":1421240,"uid":260740,"like":0,"dislike":0,"score":0,"quote":{"pid":"a25d295c04f02df48265c7a82486b8caeb523076","tid":1421240,"uid":285424,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-06T07:30:35.000Z","msg":"P牌忍唔住第一次出post！<br />\n<br />\n琴日發夢11點幾喺太子<br />\nd狗射左幾粒催淚後<br />\n大家退到去朗豪位置<br />\n<br />\n我親眼望住<br />\n有個路人女人拎住電話影現場(利申 唔知佢影乜)<br />\n<span style=\"font-size: large;\"><span style=\"color: gold;\">有個手足企喺佢身後<br />\n無喇喇將佢部電話拍9咗落地！仲要係勁L大力！<br />\n之後就行開咗<br />\n好明顯純發洩！</span></span><br />\n屌你開聲叫佢唔好影都唔做？<br />\n直接攻擊？<br />\n咁同d狗有乜L野分別？<br />\n<br />\n個女人即刻鬧，<span style=\"font-