f7cf9740ccbabf123aac6d3","tid":1835430,"uid":28114,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-23T01:05:43.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"9f25344524783ab4e49406ae65bedc5b772a213b","tid":1835430,"uid":123738,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-01-23T01:09:51.000Z","msg":"呢班支那狗都係等拉鳩哂<br />\n又有實名，實知你班仆街去左邊<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n準備為黨捐軀啦"},{"pid":"79c52fcc20f7566e3c8a93bb308bce95154a685b","tid":1835430,"uid":305016,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-01-23T01:11:03.000Z","msg":"冇事禾，武漢咁大，邊樹有事。我地落離香港都係想幫下香港經濟，港豬要感謝我就真<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a0a780f26888074b6e1a8bedbdd36b634cf3471a","tid":1835430,"uid":28114,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-23T01:21:40.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"abf7ebbf0c29289a9ce462dcd72d6e768c72723d","tid":1835430,"uid":173326,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-01-23T01:22:59.000Z","msg":"點解封城要預告，而唔係即刻執行？<br />\n係咪領導家屬先走？"},{"pid":"fe74203d0699167f0b60b52acc1fe4dbfce7d3ff","tid":1835430,"uid":9542,"like":2,"dislike":0,"score":2,"quote":{"pid":"abf7ebbf0c29289a9ce462dcd72d6e768c72723d","tid":1835430,"uid":173326,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-01-23T01:22:59.000Z","msg":"點解封城要預告，而唔係即刻執行？<br />\n係咪領導家屬先走？"},"citedBy":0,"replyTime":"2020-01-23T01:25:43.000Z","msg":"一早走晒啦"},{"pid":"1caa019522f2da87c49fc0f46651b71a668f4f2c","tid":1835430,"uid":244332,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-23T01:29:31.000Z","msg":"衝哂過來香港<im