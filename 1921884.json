CAsd5me42-Al2LPXUkzbIx1eQ93ORvO5cSrzuXEo%3Fv%3Dw1440&h=8db7b796&s={SIZE}\" /><br />\n涉案男警在停職期間，與一名14歲女童到蘭桂坊消遣，其後在沙田公屋梯間強姦該名女童。"},"citedBy":0,"replyTime":"2020-03-12T13:28:28.000Z","msg":"我敢肯定由於服務多年減刑。<br />\n紀律部隊知法犯法，所有刑罰一定要係最高，唔係就一個接一個黎。<br />\n香港法律，正一垃圾，有罪嘅紀律部隊都輕判，屌。"},{"pid":"92e4e3d2a8f0c76e20bc86a100992a437313c380","tid":1921884,"uid":266755,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T13:28:37.000Z","msg":"dklm, 禽獸"},{"pid":"e017dd9a51f5c20ef949ed8e11fadb5734a1b9c7","tid":1921884,"uid":125079,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T13:29:50.000Z","msg":"警狗咪就係依啲畜牲囉"},{"pid":"3aa837ff09b5e3b7c6d9480c9f464e71c6f05365","tid":1921884,"uid":125079,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T13:30:14.000Z","msg":"警狗壓力大<br />\n<br />\n要搵妹妹仔發洩呀"},{"pid":"caffcaca03a425ca3f5c8e1fff26ead70cd00e31","tid":1921884,"uid":148599,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T13:31:42.000Z","msg":"包容下，電光火石間衝動左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"6d6d2f0da0525562203e8647cfc2adfddb77f449","tid":1921884,"uid":236878,"like":0,"dislike":0,"score":0,"quote":{"pid":"e7cd3de621ec7f1fbc276ceaa92557b815971be8","tid":1921884,"uid":24730,"like":0,"dislike":0,"score":0,"quote":{"pid":"1fac8352f9c4e93c4a73f5b43fe862d664dfc391","tid":1921884,"uid":175732,"like":8,"dislike":22,"score":-14,"citedBy":3,"replyTime":"2020-03-12T08:47:04.000Z","msg":"雖然係2018年既野"},"citedBy":2,"replyTime":"2020-03-12T12:10:04.000Z","msg":"而家黑警做呢啲嘢唔會拉㗎，朱經緯如果今日周街扑人都冇事啦"},"citedBy":0,"replyTime":"2020-03-12T13:32:00.000Z","msg":"行得太前"},{"pid":"194647d81a7a228fdb7afed053f3622482805c9e","tid":1921884,"uid":263878,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T13:33:53.000Z","msg":"壓力過大要包容，加埋已訓責，冇事了<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f4f4d3a25894279948315252021750a82371a373","tid":1921884,"uid":171192,"like":0,"dislike":0,"score":0,"cit