 src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-16T07:29:12.000Z","msg":"佢驚條鐵啦<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"b70650482776cf4b19f7362df750d1270dac0765","tid":1477423,"uid":291279,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T07:33:54.000Z","msg":"推啊"},{"pid":"b70e0c39839181249d4739c7bd1de598e2582c20","tid":1477423,"uid":291279,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T08:49:46.000Z","msg":"推"}]}