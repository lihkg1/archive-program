assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e12f2dd68129ba730096a6af0474ba60d0eb5dd6","tid":656983,"uid":183090,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-07T23:06:48.000Z","msg":"HR 負責對資料，真正問你問題會係相關嘅  deparment 老細。<br />\nbtw，你係 HA 做開咩先"},{"pid":"d477457e8493ab91b15a5ac942044a587c300ca3","tid":656983,"uid":180905,"like":0,"dislike":0,"score":0,"quote":{"pid":"e12f2dd68129ba730096a6af0474ba60d0eb5dd6","tid":656983,"uid":183090,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-07T23:06:48.000Z","msg":"HR 負責對資料，真正問你問題會係相關嘅  deparment 老細。<br />\nbtw，你係 HA 做開咩先"},"citedBy":0,"replyTime":"2018-05-08T04:29:37.000Z","msg":"Allied health ge 前線底層囉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a75ee5c17a86c2dcb01731342709d76a411ebd9b","tid":656983,"uid":180905,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-02T05:57:03.000Z","msg":"分享番<br />\n成件事完佐了<br />\n近呢幾日啱啱簽佐約<br />\n<br />\n其實真係見department in charge先有意思<br />\n個HR manager都真係當傾下計<br />\n問下d普通野<br />\n有題好鳩<br />\n問我，你覺得其他HA ge 人會點睇我地醫院<br />\n話佢地近排想洗底洗甩個「貴價醫院」個名<br />\n心諗，邊會洗得甩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n我做佐個大概4分鐘英文self intro<br />\n其實佢都冇聽，只係係到揭我d資料<br />\n我諗佢純粹想聽下我d英文而已<br />\n根本冇諗過要係當中聽到d乜野資料<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n（我話佢冇聽，因為佢事後有問佐我幾題問題都係self intro mentioned）"},{"pid":"2103094842ccfe3dfd4d6d91deeadcfb526ab5e8","tid":656983,"uid":85564,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-02T07:32:11.000Z","msg":"唔好覺得自己低人一等<br />\n<br />\n成個對話你當同陌生人閒談"}]}