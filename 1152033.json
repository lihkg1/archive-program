AE%89%E8%BE%AD%E8%81%B7?signed=true</a>"},"citedBy":0,"replyTime":"2019-05-12T18:29:39.000Z","msg":"老老實實 有乜撚用 外國勢力？<br />\n係就出街啦 鍵盤戰士佢又睇唔到<br />\n<br />\n雖然出街佢又報細數 又有藉口"},{"pid":"79a417a885927e486a768c5861058190708eee35","tid":1152033,"uid":173002,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-12T18:34:35.000Z","msg":"其實係宜家嘅連1.5制都無嘅形勢，陳太講嘅都係廢話，<br />\n因為777只聽命於強國黨，無考慮要講道理，只想用專橫手法強推惡法，根本無將香港人嘅福祉放在眼內，真面目仲醜惡過689。"},{"pid":"3070977c66386bdbc3b0dae4bf69efabe409112c","tid":1152033,"uid":224066,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-12T18:52:33.000Z","msg":"只要信,不要問<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8ecdcfff19d72661d14f8ba60a7a2251a0ec3247","tid":1152033,"uid":76216,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-05-12T18:57:21.000Z","msg":"燒到自己就出聲<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />平時就係咁奶係咁奶<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},{"pid":"abfb8b0784d82c2c419cfab5d43da0e02321d1ea","tid":1152033,"uid":149026,"like":0,"dislike":0,"score":0,"quote":{"pid":"63d42e91a7ccb9d83a70e05fb80685c047c19d01","tid":1152033,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-05-12T18:27:04.000Z","msg":"要求香港立法會秘書長陳維安辭職<br />\n<a href=\"https://www.change.org/p/%E9%99%B3%E7%B6%AD%E5%AE%89-%E8%A6%81%E6%B1%82%E9%A6%99%E6%B8%AF%E7%AB%8B%E6%B3%95%E6%9C%83%E7%A7%98%E6%9B%B8%E9%95%B7%E9%99%B3%E7%B6%AD%E5%AE%89%E8%BE%AD%E8%81%B7?signed=true\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.change.org%2Fp%2F%25E9%2599%25B3%25E7%25B6%25AD%25E5%25AE%2589-%25E8%25A6%2581%25E6%25B1%2582%25E9%25A6%2599%25E6%25B8%25AF%25E7%25AB%258B%25E6%25B3%2595%25E6%259C%2583%25E7%25A7%2598%25E6%259B%25B8%25E9%2595%25B7%25E9%2599%25B3%25E7%25B6%25AD%25E5%25AE%2589%25E8%25BE%25AD%25E8%2581%25B7%3Fsigned%3Dtrue&d=JinSrGH%2FoctmVpTuEhnihKGvShGfzVnrv2JJWMS0YvQ%3D&h=ebabac9f\" data-auto-link target=\"_blank\">https://www.change.org/p/%E9%99%B3%E7%B6%A