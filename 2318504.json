/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-09T11:30:28.000Z","msg":"<img src=\"/assets/faces/mouse/yea.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/yea.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/yea.gif\" class=\"hkgmoji\" />"},{"pid":"9ed1510e148ffa42449d07183bb75eebebbf8bc1","tid":2318504,"uid":359522,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-09T11:32:00.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"1386841c8cde2ec71a9461130d9472715613f423","tid":2318504,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-09T11:32:04.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c70190ea54c0c4b85e4bf3d0efb49a63540533f7","tid":2318504,"uid":196227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-09T11:32:30.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"1c36d2f237e8564673a558912f1ee9ddcc7434aa","tid":2318504,"uid":230594,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-12-09T11:33:40.000Z","msg":"入地盤又唔一定要工人註冊證<br />\n個官有冇留意過建築界㗎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n唔俾人啱搞返新證"},{"pid":"3c3fc2e748954b2e597a27cc9cf69fdc86650ca6","tid":2318504,"uid":230594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-09T11:34:10.000Z","msg":"推返 唔小心用咗不推文<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"3f3bab44ef329f7a602389d7a1e2c2c2fe2c7d45","tid":2318504,"uid":51752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-09T11:36:08.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ebd7