1,"uid":60434,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-05-02T10:17:21.000Z","msg":"藍定黃"},{"pid":"eac29f381a25ea7d4d7589a99c1449e292ab40c9","tid":1998241,"uid":1550,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-02T10:18:40.000Z","msg":"醫生有冇話之後點做？"},{"pid":"bc6d4c48e3de644f34cf3d0b2946c95ef80dd858","tid":1998241,"uid":130128,"like":0,"dislike":0,"score":0,"quote":{"pid":"36cec35e299330efde42ef2f9a2fd40dd0cbee6b","tid":1998241,"uid":355966,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-02T08:54:31.000Z","msg":"仲要擴散到去肝<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-02T10:22:44.000Z","msg":"希望樓主同家人加油，多啲陪下呀爸，珍惜呢段時光"},{"pid":"4075884e6d394424b85669be48c7bfcc9036eb4e","tid":1998241,"uid":237487,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-05-02T10:25:34.000Z","msg":"樓主<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 要正面啲！ <br />\n<br />\n雖然聽到癌症大家就好驚<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n之後因為情緒影響病情亦聽唔少<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n老豆又擔心你又擔心自己又擔心呢樣嗰樣<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n不如大家一齊樂觀啲面對，反而更加有希望<br />\n<br />\n大家趁呢段時間一齊做啲想做嘅嘢，<br />\n例如一齊唔工作，執乾淨間屋，如果冇肺炎就去旅行，<br />\n多啲共同人生經驗，<br />\n當然自我網上學習有關呢個病係好重要<br />\n一齊跑步做運動行山游水等<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n<br />\n好好珍惜<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"5d9f74c9618111d3ae313e985172264be62eae2e","tid":1998241,"uid":237487,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-05-02T10:28:55.000Z","msg":"因為每個人個身體基因都唔同，有個朋友廿幾歲，突然有癌，眨吓眼就去咗⋯ <br />\n<br />\n有啲人一有癌，就去深山， 又研究唔好食酸性嘢要飲咩水咩食物咩罐頭，完全自然療法⋯ 最後以為好成功但都係死咗<br />\n<br />\n最緊要聽醫生講， 做好化療， 保持心理， 家人好重要， 唔好喊<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 唔好憂愁<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 總有方便解決嘅"},{"pid":"035bac2922b07f972521c9c1cefcd73233de8741","tid":1998241,"uid":237487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-02T10:31:50.000Z","msg":"Btw 最好驗多一兩個醫生<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />聽多一兩個醫生意見"},{"pid":"4504be0e8ba8c60fbadaf71eef2252a93ec33e77","tid":1998241,"uid":313418,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-02T10:41:52.000Z","msg":"樓主加油<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"000ecc3200796c5dac532a538b9c6af8c45e9add","tid":1998241,"uid":355966,"like":0,"dislike":0,"score":0,"quote":{"pid":"08c2220b719ff0355dd544bf8e691cd8585e2ef7","tid":1998241,"uid":60434,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-05-02T10:17:21.000Z","msg":"藍定黃"},"citedBy":1,"replyTime":"2020-05-02T10:44:39.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"d8f5d18f49e7cc6f4f01bc68ad9a343b6f1f4926","tid":1998241,"uid":355966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-02T10:47:55.000Z","msg":"呀爸而家直情住埋院<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"}]}