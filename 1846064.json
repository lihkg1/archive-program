\"https://www.3armystore.com/products/pyramex-capstone-dual-lens\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.3armystore.com%2Fproducts%2Fpyramex-capstone-dual-lens&d=gjA94EiKSJsk9JMrtOnM5otKjO%2FIGoH7AJS0Ocrd4mI%3D&h=5f1c48d4\" data-auto-link target=\"_blank\">https://www.3armystore.com/products/pyramex-capstone-dual-lens</a><br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<a href=\"https://shop.outletexpress.com.hk/index.php?route=product/product&amp;product_id=4252\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fshop.outletexpress.com.hk%2Findex.php%3Froute%3Dproduct%2Fproduct%26product_id%3D4252&d=gjA94EiKSJsk9JMrtOnM5otKjO%2FIGoH7AJS0Ocrd4mI%3D&h=14a1852a\" data-auto-link target=\"_blank\">https://shop.outletexpress.com.hk/index.php?route=product/product&amp;product_id=4252</a><br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<a href=\"https://www.autoworld.hk/chinese/pygg504t.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.autoworld.hk%2Fchinese%2Fpygg504t.html&d=gjA94EiKSJsk9JMrtOnM5otKjO%2FIGoH7AJS0Ocrd4mI%3D&h=e0266e75\" data-auto-link target=\"_blank\">https://www.autoworld.hk/chinese/pygg504t.html</a><br />\n<br />\n<br />\n#屠龍 #藍絲 #藍屍 #黃色經濟圈 #黃店 #裝備 #口罩 #武漢肺炎 #武漢 #P95 #文宣 #N95 #肺炎 #沙士 #香港 #支那人 #高鐵 #眼罩 #tg #lihkg #連登 #高登 #d100 #黑警"},"citedBy":1,"replyTime":"2020-01-27T13:06:27.000Z","msg":"Push!"},"citedBy":0,"replyTime":"2020-01-27T13:37:59.000Z","msg":"Push"},{"pid":"4bda0655b3754fc50aa514de90fc9bd52b0500fb","tid":1846064,"uid":26708,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T13:48:03.000Z","msg":"<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},{"pid":"ed7cdc2df7f1deefa1a0541a1d33ce59dfc7fcc9","tid":1846064,"uid":136457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T13:50:50.000Z","msg":"<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />以後唔出尖沙咀"},{"pid":"f2294b32727b426051e70b53c1412e61ca851a05","tid":1846064,"uid":1025,"l