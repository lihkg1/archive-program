/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"39526dcb63b270be3291463c69aa165755333e35","tid":2391531,"uid":46388,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-02T10:10:20.000Z","msg":"拿臨守佢屋搵到把菜刀咪可以話佢頭號通緝犯"},{"pid":"6ef4f793eec5f324c1131b0dac927b00f54bc558","tid":2391531,"uid":12991,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-02T10:16:10.000Z","msg":"你會唔會聽被制裁頭目講既野 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"154e811a52e2eeb3b0b86fa25066fbd0e37a4dc8","tid":2391531,"uid":39872,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-02T10:20:10.000Z","msg":"即係黑警死都唔肯認錯喇<br />\n死黑警死黑警死黑警"},{"pid":"ed162c9e0358088971dea2125cd39c0c0390f497","tid":2391531,"uid":280593,"like":0,"dislike":0,"score":0,"quote":{"pid":"39b9d4f908b08ee172ee18b6dc83bca0b42627de","tid":2391531,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-02T09:35:19.000Z","msg":"警務處處長鄧炳強表示，警方要做實事，挽回公眾信心，包括安排軍裝警員高姿態巡邏等，並盡快澄清假消息。<br />\n<br />\n鄧炳強在立法會保安事務委員會視像會議中表示，上個財政年度，警隊招聘人數一度下跌3成，但最近已改善，其中28歲以上投考警隊的人士升近15%，投考輔警人數更增加5成，警隊會加強向有實際工作經驗的市民招聘。<br />\n<br />\n委員會主席、民建聯議員陳克勤就關注，警方會否將各區專責處理虐待動物案件的專隊，正名為「動物警察」。鄧炳強說，會考慮檢視，希望用更好名稱，令市民清楚知道專隊的定位。<br />\n<br />\n熱血公民議員鄭松泰就提到，警方早前截查一名孕婦時，以4名警員將孕婦壓倒，質疑警方行使權力沒有約束。鄧炳強表示，對涉案女子表示慰問，但不同意警方使用不必要武力。他說警方已經接獲相關投訴，會全面調查，亦會有獨立證人。他說警員因應當時情況採取行動，使用最低武力，相信調查結果會還大家清白。<br />\n<br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1573665-20210202.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1573665-20210202.htm&d=y7rvae0RAf6wlyT0SQBX%2BLXqul57XbQM8lVYa5HUNM4%3D&h=68a22700\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1573665-20210202.htm&h=60f8ad16\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1573665-20210202.htm</a>"},"citedBy":0,"replyTime":"2021-02-02T10:22:03.000Z","msg":"自己查自己一定清白<br />\n邊個冇信心就拉邊個"},{"pid":"4b51648a7b383fd3cb797