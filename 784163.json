e45f4f140446b6e6c6878340420414514","tid":784163,"uid":29702,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-18T07:36:56.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2018-08-18T07:38:10.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-18T07:42:54.000Z","msg":"3日無薪"},"citedBy":0,"replyTime":"2018-08-18T08:51:19.000Z","msg":"呢位手足係咪係街頭乞緊錢<br />\n<br />\n<blockquote>收爹啦你，唔通陪你喺腥港做支共奴隸？<br />\n<br />\n去得人道做二等公民又點？起碼人哋自由過腥港，社會風氣同制度冇腥港咁仆街，你咁怕人睇你唔起，你咪繼續喺腥港做支匪人一等奴隸囉！</blockquote>"},{"pid":"5bd41b97da199c1717933c4721da3541f8826e4c","tid":784163,"uid":20449,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-18T08:53:34.000Z","msg":"此回覆已被刪除"},{"pid":"10d2b17d09187d0e378b58bb0990f377962becfe","tid":784163,"uid":27664,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-18T08:59:43.000Z","msg":"又唔係揸坐支槍迫佢工作<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"9e5144c736fda2ff7733daa077bacecb5288220e","tid":784163,"uid":27664,"like":0,"dislike":0,"score":0,"quote":{"pid":"10d2b17d09187d0e378b58bb0990f377962becfe","tid":784163,"uid":27664,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-18T08:59:43.000Z","msg":"又唔係揸坐支槍迫佢工作<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-18T08:59:56.000Z","msg":"住"},{"pid":"071ba063dace06a32239935683365af71f8b7d77","tid":784163,"uid":68728,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-18T09:01:19.000Z","msg":"北歐國際都咁多仆街野？"}]}