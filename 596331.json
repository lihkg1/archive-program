二月初一，習帝登基，奉天命，承氣運。頃刻，天降瑞雪，全民大悅，臣民自瀆，喜曰：此乃中華復興之兆也。"},{"pid":"0b9687e4ccf5fea8f31baa97d00a640ba02f8c94","tid":596331,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-18T03:40:31.000Z","msg":"刁大大<img src=\"/assets/faces/big/dead.gif\" class=\"hkgmoji\" />"},{"pid":"0d38e218de00692e1058660bb85920490d0c11e3","tid":596331,"uid":143582,"like":0,"dislike":0,"score":0,"quote":{"pid":"e1893e0c4e21f4f48f3b734cd6e808029ce3bd83","tid":596331,"uid":143499,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-03-18T03:26:36.000Z","msg":"六月飛霜就好笑<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-18T03:41:10.000Z","msg":"好似年年都會<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"b17e243a76b5a67aabdb1df444bcbcb2c8b3de87","tid":596331,"uid":48222,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-18T03:41:56.000Z","msg":"趙匡胤黃袍加身，呢啲招中國人用足咁多年都唔厭<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"}]}