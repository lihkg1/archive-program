b8c990c3f0f4783cc67f967e0948","tid":1264353,"uid":85524,"like":27,"dislike":1,"score":26,"citedBy":5,"replyTime":"2019-06-28T16:24:43.000Z","msg":"你地係分人定被分?我down左好多日<br />\n頭先真係想打去生命熱線。<br />\n<br />\n當你諗到自己真心 人地係玩玩下 到最後絕情<br />\n真係好難頂 眼淚完全控制唔到 返工集中唔到"},"citedBy":1,"replyTime":"2019-06-28T23:42:01.000Z","msg":"我分人試過，被分都試過吓，不過即刻補救咗，一齊返，依家開始心淡，可能遲吓又分<br />\n<br />\n離離合合好正常，只要你喺過程盡咗力就得，你總會遇到下一個，如果已經無可挽回，咁不如將心思留俾下一個<br />\n<br />\n死，其實一啲都唔難，但有生命而選擇唔要，咁先令人覺得可惜<br />\n<br />\n死，可能有十幾個理由支持你<br />\n但唔死，你就唔止有十幾個可能性俾你繼續走落去"},{"pid":"d98983518bc957e2db3eeb7e174d63c27f64fd5c","tid":1264353,"uid":225730,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-29T01:18:32.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"e787e95c39dd6bce0c01424800d5cdd00469a60d","tid":1264353,"uid":192587,"like":1,"dislike":0,"score":1,"quote":{"pid":"7515914bb1c126f36435c25b3da1ba7536073f69","tid":1264353,"uid":146433,"like":1,"dislike":0,"score":1,"quote":{"pid":"1551424bcba5b8c990c3f0f4783cc67f967e0948","tid":1264353,"uid":85524,"like":27,"dislike":1,"score":26,"citedBy":5,"replyTime":"2019-06-28T16:24:43.000Z","msg":"你地係分人定被分?我down左好多日<br />\n頭先真係想打去生命熱線。<br />\n<br />\n當你諗到自己真心 人地係玩玩下 到最後絕情<br />\n真係好難頂 眼淚完全控制唔到 返工集中唔到"},"citedBy":2,"replyTime":"2019-06-28T22:48:58.000Z","msg":"最近被分<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />個心好痛 痛到想死 除咗佢咩都諗唔到 點解佢要咁絕情 話唔愛就唔愛"},"citedBy":1,"replyTime":"2019-06-29T01:23:15.000Z","msg":"老實講...未聽過主動分會傷心過一星期，我兩年了<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 但冇諗過放低"},{"pid":"bcd41c6ad6a973d1d319ff43426e19c42f86663e","tid":1264353,"uid":173902,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-06-29T01:35:15.000Z","msg":"一個月前被分，間唔中會痛，但係對方只係痛一晚就完全冇事，依家係咁同自己講唔值得為佢痛"},{"pid":"2bc93666be319f5dccf7a68c15e104224a405480","tid":1264353,"uid":122513,"like":0,"dislike":0,"score":0,"quote":{"pid":"1551424bcba5b8c990c3f0f4783cc67f967e0948","tid":1264353,"uid":85524,"like":27,"dislike":1,"score":26,"citedBy":5,"replyTime":"2019-06-28T16:24:43.000Z","msg":"你地係分人定被分?我down左好多日<br />\n頭先真係想打去生命熱線。<br />\n<br />\n當你諗到自己真心 人地係玩玩下 到最後絕情<br />\n真係好難頂 眼淚完全控制唔到 返工集中唔到"},"citedBy":1,"replyTime":"2019-06-29T04:09:33.000Z","msg":"或許我不能完全了解你內心的痛苦，但我也曾置身於無助和絕望之中，明白身處痛苦是怎樣一回事。無論你的是否想放棄自己，也希望你不要將困擾藏在心裡，因鬱結和壓力積存得太多太久，到情緒爆發時可能已超出你所能控制的程度。<br />\n<br />\n你不如停一停，<a href=\"http://到我們的網站www.help4suicide.com.hk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2F%E5%88%B0%E6%88%91%E5%80%91%E7%9A%84%E7%B6%B2%E7%AB%99www.help4suicide.com.hk&d=Ns8Dgi7AEu9liZcLsKty6vkum5iQZutveDYoRIbm5C0%3D&h=9addc14e\" data-auto-link target=\"_blank\">到我們的網站www.help4suicide.com.hk</a>。 那裡有一些勵志故事、有趣短片，也有與自殺有關的人與事，你可以隨心看看。您更可以進入網站內的『Chat窿』（星期一至五：上午六時至凌晨一時；星期六、日及公眾假期：下午８時至凌晨１時），即時與我們的義工在網上交談，或致電我們24小時電話熱線2389-2222，與我們的義工傾訴。<br />\n<br />\n我們願意聆聽你的心聲，伴你一起走過這段艱難的時候！只因『晴天雨天要樂天，難關難過總會過』！<br />\n<br />\n《自殺．自療．互助舍》"},{"pid":"d90c14b827911241cfc055c1e7f72910473a8fb5","tid":1264353,"uid":154908,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-29T04:17:20.000Z","msg":"<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"558f49e0d6fcd398713c950170ec606656d889ab","tid":1264353,"uid":85524,"like":7,"dislike":0,"score":7,"citedBy":2,"replyTime":"2019-06-29T18:24:15.000Z","msg":"多謝各巴打絲打關愛<br />\n哩3日係假期可以比我抖下<br />\n我搵朋友傾先可以暫時忘記佢<br />\n但朋友一走左 一返到屋企好又會再諗起佢<br />\n我真係好痛 眼淚完全止不住 好想走出哩個困局<br />\n但只要一諗起當初同佢由好關愛到到佢厭惡自己<br />\n想我永遠消失，永遠不要再見<br />\n腦海會不斷重複哩d句子 就會好辛苦<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"1fee38ba9c31fcf1fb737ffd464957a3634b11ca","tid":1264353,"uid":85524,"like":0,"dislike":0,"score":0,"quote":{"pid":"4fe4f9134528c93f343e0b1f80d19593ab66e295","tid":1264353,"uid":258447,"like":0,"dislike":0,"score":0,"quote":{"pid":"1551424bcba5b8c990c3f0f4783cc67f967e0948","tid":1264353,"uid":85524,"like":27,"dislike":1,"score":26,"citedBy":5,"replyTime":"2019-06-28T16:24:43.000Z","msg":"你地係分人定被分?我down左好多日<br />\n頭先真係想打去生命熱線。<br />\n<br />\n當你諗