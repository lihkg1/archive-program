k\">https://lih.kg/sddHNcX</a>"},{"pid":"9e5ecb60ff143598c0162d397042bb0ce11991f3","tid":2458484,"uid":256957,"like":1,"dislike":0,"score":1,"quote":{"pid":"56a5baa674f6b62bc011c486952547bc54516539","tid":2458484,"uid":72795,"like":0,"dislike":0,"score":0,"quote":{"pid":"59c6a456fcd0c68d976cedd0ba9d9a22d806a476","tid":2458484,"uid":362377,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-24T04:12:44.000Z","msg":"其實無 睇落好fancy其實無乜公司真係有用."},"citedBy":1,"replyTime":"2021-03-24T12:10:07.000Z","msg":"咩原因唔多公司用？"},"citedBy":1,"replyTime":"2021-03-24T13:40:05.000Z","msg":"對於普通web development嚟講<br />\n玩threejs而且仲要係玩到去production level有好多故慮<br />\n第一 公司點都要特登拎第二筆錢出嚟請人<br />\n正常frontend team係唔會有人識寫glsl, 3d modeling同3d animation<br />\n第二 就係依加仲未有requirement要寫到個web變3D<br />\n自己屎忽痕玩threejs又唔會多咗錢入袋<br />\n第三 就係行threejs嘅performance<br />\n唔一定每個end user嘅device都勁 廢機load threejs好影響ux<br />\n所以你會見到除左啲興趣撚組成嘅team之外<br />\n無咩公司會自發性玩threejs<br />\n<br />\n如果係普通game development<br />\n直接用unity寫咪得<br />\n開個webgl project就可以deploy上web<br />\n根本唔洗用到threejs<br />\n除非個requirement係唔比你用市場上任何game engine<br />\n一定要你要自己砌個出嚟"},{"pid":"f971977b3c9a4f64a664845d5234282d578c25b5","tid":2458484,"uid":72795,"like":0,"dislike":0,"score":0,"quote":{"pid":"9e5ecb60ff143598c0162d397042bb0ce11991f3","tid":2458484,"uid":256957,"like":1,"dislike":0,"score":1,"quote":{"pid":"56a5baa674f6b62bc011c486952547bc54516539","tid":2458484,"uid":72795,"like":0,"dislike":0,"score":0,"quote":{"pid":"59c6a456fcd0c68d976cedd0ba9d9a22d806a476","tid":2458484,"uid":362377,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-24T04:12:44.000Z","msg":"其實無 睇落好fancy其實無乜公司真係有用."},"citedBy":1,"replyTime":"2021-03-24T12:10:07.000Z","msg":"咩原因唔多公司用？"},"citedBy":1,"replyTime":"2021-03-24T13:40:05.000Z","msg":"對於普通web development嚟講<br />\n玩threejs而且仲要係玩到去production level有好多故慮<br />\n第一 公司點都要特登拎第二筆錢出嚟請人<br />\n正常frontend team係唔會有人識寫glsl, 3d modeling同3d animation<br />\n第二 就係依加仲未有requirement要寫到個web變3D<br />\n自己屎忽痕玩threejs又唔會多咗錢入袋<br />\n第三 就係行threejs嘅performance<br />\n唔一定每個end user嘅device都勁 廢機load threejs好影響ux<br />\n所以你會見到除左啲興趣撚組成嘅team之外<br />\n無咩公司會自發性玩threejs<br />\n<br />\n如果係普通game development<br />\n直接用unity寫咪得<br />\n開個webgl project就可以deploy上web<br />\n根本唔洗用到threejs<br />\n除非個requirement係唔比你用市場上任何game engine<br />\n一定要你要自己砌個出嚟"},"citedBy":0,"replyTime":"2021-03-24T13:46:39.000Z","msg":"好詳細 唔該巴打<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><br />\n如果想係front end發展，未來5-10年你預計會有咩趨勢？"},{"pid":"db123e2e3f7466fec6a0ef4ac9e2b7209cf767ad","tid":2458484,"uid":249170,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-03-24T13:56:23.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /><br />\n有冇人用過babylonjs 或 playcanvas 寫game"},{"pid":"585ae4b8a3579838a78c9513f1955633b1edb9bb","tid":2458484,"uid":72795,"like":0,"dislike":0,"score":0,"quote":{"pid":"db123e2e3f7466fec6a0ef4ac9e2b7209cf767ad","tid":2458484,"uid":249170,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-03-24T13:56:23.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /><br />\n有冇人用過babylonjs 或 playcanvas 寫game"},"citedBy":0,"replyTime":"2021-03-24T15:10:58.000Z","msg":"Lm"},{"pid":"c380de1d49aae45103dce11d601fb223df65516f","tid":2458484,"uid":257658,"like":0,"dislike":0,"score":0,"quote":{"pid":"db123e2e3f7466fec6a0ef4ac9e2b7209cf767ad","tid":2458484,"uid":249170,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-03-24T13:56:23.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /><br />\n有冇人用過babylonjs 或 playcanvas 寫game"},"citedBy":1,"replyTime":"2021-03-24T15:25:20.000Z","msg":"玩過playcanvas, unity, unreal."},{"pid":"ad02a3736a61b4a4353ba9f7d3a57772106e2904","tid":2458484,"uid":249170,"like":0,"dislike":0,"score":0,"quote":{"pid":"c380de1d49aae45103dce11d601fb223df65516f","tid":2458484,"uid":257658,"like":0,"dislike":0,"score":0,"quote":{"pid":"db123e2e3f7466fec6a0ef4ac9e2b7209cf767ad","tid":245848