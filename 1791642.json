1642,"uid":158270,"like":0,"dislike":0,"score":0,"quote":{"pid":"f4544044a4f1a1f78d1a634644045d775aee8daa","tid":1791642,"uid":338743,"like":1,"dislike":0,"score":1,"quote":{"pid":"24d03dae164c2dd1358e3c6c74eaf23a7ef3599b","tid":1791642,"uid":158270,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-25T07:57:38.000Z","msg":"Push"},"citedBy":1,"replyTime":"2019-12-25T08:17:04.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-12-25T08:26:50.000Z","msg":"其實唔緊要。從來power都係來自有武力嘅人，忽視武力只係自欺欺人。喺依一點，林鄭攬警察聰明過想同前線割嘅泛民，所以泛民五年前抵輸。"},{"pid":"9ca3c118e04afd2cea99ab438e125817a67d02c8","tid":1791642,"uid":338743,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-25T08:39:02.000Z","msg":"此回覆已被刪除"},{"pid":"0164207f3d57618550698be3b286507a0b6c85b9","tid":1791642,"uid":158270,"like":0,"dislike":0,"score":0,"quote":{"pid":"9ca3c118e04afd2cea99ab438e125817a67d02c8","tid":1791642,"uid":338743,"like":0,"dislike":0,"score":0,"quote":{"pid":"6670fde23655717b724b6f00ff1254f0b577642e","tid":1791642,"uid":158270,"like":0,"dislike":0,"score":0,"quote":{"pid":"f4544044a4f1a1f78d1a634644045d775aee8daa","tid":1791642,"uid":338743,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-12-25T08:17:04.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-12-25T08:26:50.000Z","msg":"其實唔緊要。從來power都係來自有武力嘅人，忽視武力只係自欺欺人。喺依一點，林鄭攬警察聰明過想同前線割嘅泛民，所以泛民五年前抵輸。"},"citedBy":1,"replyTime":"2019-12-25T08:39:02.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-12-25T08:43:29.000Z","msg":"1.紥根社區<br />\n大家係時係建立社區抗爭組織，唔係為做政治show，而係為咗整合依場運動嘅資源，實現民主自治！<br />\n<a href=\"https://lih.kg/1617406\" data-auto-link target=\"_blank\">https://lih.kg/1617406</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n2.組織私人保安公司填補警察唔做嘢嘅漏洞，係商機嚟。"},{"pid":"b6c366bd546243405ce5293c827ecd2bef0ad823","tid":1791642,"uid":338743,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-25T08:49:06.000Z","msg":"此回覆已被刪除"},{"pid":"6247b8d8c167971c12766e534da1e42bd236d7ab","tid":1791642,"uid":158270,"like":0,"dislike":0,"s