ji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"af8163a0fd8cf9aa47201a9b1135b2fe66e37603","tid":749520,"uid":29080,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-20T06:34:57.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"480240379b9269714ce270cdc5314bfc02e96be0","tid":749520,"uid":133824,"like":1,"dislike":1,"score":0,"quote":{"pid":"5aca20088499f6f6d9b3b1d36979844c1fe22a76","tid":749520,"uid":43557,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-20T06:33:42.000Z","msg":"我都好驚果日<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T07:43:53.000Z","msg":"無得驚<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 我果日都好突然，明明朝早仲好似平時咁送我出門口番工，收工番緊去就收到電話<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"fa65bfdb5e64c1111f202b4d71cd15cab84acae1","tid":749520,"uid":133824,"like":0,"dislike":1,"score":-1,"quote":{"pid":"67be27ee6cc069defad8f9c2aee8fc3b979d7904","tid":749520,"uid":4780,"like":1,"dislike":1,"score":0,"quote":{"pid":"9cd4af47962a708be59b316acf0cdd330e454f6e","tid":749520,"uid":133824,"like":1,"dislike":1,"score":0,"quote":{"pid":"ecf0749600cb27ceb0d00c98f1be8d69567f02b1","tid":749520,"uid":4780,"like":20,"dislike":1,"score":19,"citedBy":1,"replyTime":"2018-07-20T06:06:50.000Z","msg":"巴打唔好傷心，佢去到彩虹橋日日跑黎跑去好開心嫁啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T06:17:50.000Z","msg":"希望係"},"citedBy":1,"replyTime":"2018-07-20T06:33:59.000Z","msg":"我隻衰女都9歲了， 唔敢想像呢一日<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-20T07:44:37.000Z","msg":"唯有盡量陪多啲佢<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"93c9a25a34c54c10b93b40835676f4fda740b1ee","tid":749520,"uid":133824,"like":0,"dislike":1,"score":-1,"quote":{"pid":"f0389f467f4d8bc699da48190a459fc09e16d3e3","tid":749520,"uid":181697,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-20T06:15:44.000Z","msg":"最驚分別果刻<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n睇來你有排傷心<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n有冇養緊第二隻"},"citedBy":1,"replyTime":"2018-07-20T07:45:05.000Z","msg":"唔會再養啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8d7220ed771c593496690e8896686a614720389f","tid":749520,"uid":181697,"like":0,"dislike":1,"score":-1,"quote":{"pid":"93c9a25a34c54c10b93b40835676f4fda740b1ee","tid":749520,"uid":133824,"like":0,"dislike":1,"score":-1,"quote":{"pid":"f0389f467f4d8bc699da48190a459fc09e16d3e3","tid":749520,"uid":181697,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-20T06:15:44.000Z","msg":"最驚分別果刻<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n睇來你有排傷心<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n有冇養緊第二隻"},"citedBy":1,"replyTime":"2018-07-20T07:45:05.000Z","msg":"唔會再養啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-20T08:01:52.000Z","msg":"咁退休再養啦<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 老人與狗<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n起碼唔洗每十年經歷一次分別<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> (touchwood<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"62262f749044d61c9efd1f5ae8bf3bb7476f10d1","tid":749520,"uid":17189,"like":22,"dislike":1,"score":21,"citedBy":1,"replyTime":"2018-07-20T08:02:50.000Z","msg":"我嗰隻大狗今年都就黎九歲<br />\n長期食藥同睇醫生<br />\n其實全家都有曬心理準備<br />\n但每次夜晚瞓唔著一諗起<br />\n就會喊到痴左線<br />\n其實我唔係好高要求<br />\n只求佢睇到我同我女朋友結婚一刻<br />\n起教堂著婚紗影番張相留念<br />\n已經唔敢奢求話見到我有小朋友一刻<br />\n由中學開始陪到我宜家<br />\n當佢係我個仔咁<br />\n真係好唔捨得<br />\n打到哩度我又忍唔住喊啦<br />\n巴打你都唔好傷心啦<br />\n佢起彩虹橋一定好開心玩緊<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" /> <br />\n佢都唔想再見到你為佢而傷心架<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},{"pid":"8aaf4e1bb4c430fd73d8ff4c87f1be8f790cb232","tid":749520,"uid":78349,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-07-20T08:06:42.000Z","msg":"一路睇 諗返起我家14歲的呀女<br />\n我都好唔捨得 但聚散有時<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 希望佢而家開心 我就滿足了"},{"pid":"c761b3fced4d3193d2aca9aa3e2c167ee1a011dd","tid":749520,"uid":32279,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-07-20T08:07:49.000Z","msg":"我隻狗前兩日走左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 真係好傷心<br />\n最後24小時接左佢番屋企陪住佢行最後一程<br />\n一直都無諗過佢會因為病而離開<br />\n仲要最後24小時咁痛 痛到係咁吠<br />\n呢兩日不停諗自己究竟有無做錯<br />\n如果有啲野再早啲知道 或者易啲醫 或者轉醫生會唔會有第二個結果<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n不過佢都19歲 雖然只收養左4年半<br />\n但真係好唔捨得好傷心<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"1f6485276d9a88be0d0f0e94f30c3b8e5fc4ebfc","tid":749520,"uid":82398,"like":3,"dislike":2,"score":1,"citedBy":2,"replyTime":"2018-07-20T08:07:56.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/07/20/160540_c6f54456e373a514d770dbd0b38a7533.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F20%2F160540_c6f54456e373a514d770dbd0b38a7533.png&h=4d417106&s={SIZE}\" />早幾個月我隻狗狗都好安詳去左 終年十六歲<br />\n前一晚仲抱完錫完黎 仲r我啲西瓜食<br />\n第二朝起身返工前仲有望下佢 晏就呀媽就打電話黎話佢走左了"},{"pid":"d15e5ebac7e708af872bc31d5cff37c20041e0be","tid":749520,"uid":133824,"like":1,"dislike":1,"score":0,"quote":{"pid":"62262f749044d61c9efd1f5ae8bf3bb7476f10d1","tid":749520,"uid":17189,"like":22,"dislike":1,"score":21,"citedBy":1,"replyTime":"2018-07-20T08:02:50.000Z","msg":"我嗰隻大狗今年都就黎九歲<br />\n長期食藥同睇醫生<br />\n其實全家都有曬心理準備<br />\n但每次夜晚瞓唔著一諗起<br />\n就會喊到痴左線<br />\n其實我唔係好高要求<br />\n只求佢睇到我同我女朋友結婚一刻<br />\n起教堂著婚紗影番張相留念<br />\n已經唔敢奢求話見到我有小朋友一刻<br />\n由中學開始陪到我宜家<br />\n當佢係我個仔咁<br />\n真係好唔捨得<br />\n打到哩度我又忍唔住喊啦<br />\n巴打你都唔好傷心啦<br />\n佢起彩虹橋一定好開心玩緊<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" /> <br />\n佢都唔想再見到你為佢而傷心架<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T08:52:00.000Z","msg":"我隻仔仔都有長期病，仲有一隻眼白內障睇唔到<br />\n原本諗住做手術，但醫生話佢本身身體差，做完手術未必醒得番，所以最後都無做<br />\n佢都慢慢慣左，果時屋企唔會亂擺野怕佢撞到<br />\n但到佢走左果時都有諗，其實佢走左唔使再打針食藥，隻眼又睇得番野，可能對佢對我地都係一種解脫<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1b742ffd92c4bee5dc7ea79edd3425b36cec66eb","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"quote":{"pid":"8aaf4e1bb4c430fd73d8ff4c87f1be8f790cb232","tid":749520,"uid":78349,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-07-20T08:06:42.000Z","msg":"一路睇 諗返起我家14歲的呀女<br />\n我都好唔捨得 但聚散有時<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 希望佢而家開心 我就滿足了"},"citedBy":0,"replyTime":"2018-07-20T08:52:47.000Z","msg":"都係既，希望佢今世覺得幸福同滿足我就好開心"},{"pid":"fa24db18c043fff1cba5b01680bd51dff8333964","tid":749520,"uid":99960,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-20T08:53:40.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"8dbf158e12588a91906d3dcff0b9b19ce6109693","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"quote":{"pid":"c761b3fced4d3193d2aca9aa3e2c167ee1a011dd","tid":749520,"uid":32279,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-07-20T08:07:49.000Z","msg":"我隻狗前兩日走左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 真係好傷心<br />\n最後24小時接左佢番屋企陪住佢行最後一程<br />\n一直都無諗過佢會因為病而離開<br />\n仲要最後24小時咁痛 痛到係咁吠<br />\n呢兩日不停諗自己究竟有無做錯<br />\n如果有啲野再早啲知道 或者易啲醫 或者轉醫生會唔會有第二個結果<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n不過佢都19歲 雖然只收養左4年半<br />\n但真係好唔捨得好傷心<