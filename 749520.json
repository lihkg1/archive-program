e":1,"score":-1,"quote":{"pid":"480240379b9269714ce270cdc5314bfc02e96be0","tid":749520,"uid":133824,"like":1,"dislike":1,"score":0,"quote":{"pid":"5aca20088499f6f6d9b3b1d36979844c1fe22a76","tid":749520,"uid":43557,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-20T06:33:42.000Z","msg":"我都好驚果日<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T07:43:53.000Z","msg":"無得驚<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 我果日都好突然，明明朝早仲好似平時咁送我出門口番工，收工番緊去就收到電話<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T09:13:47.000Z","msg":"佢之前有無病，定係好健康的？"},{"pid":"441f299dcabd8058749dc1aa5b1936290f96cf17","tid":749520,"uid":32279,"like":0,"dislike":0,"score":0,"quote":{"pid":"5158e422268d3dcc6a890eac9e7ee1d896172865","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"quote":{"pid":"8dbf158e12588a91906d3dcff0b9b19ce6109693","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"quote":{"pid":"c761b3fced4d3193d2aca9aa3e2c167ee1a011dd","tid":749520,"uid":32279,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-07-20T08:07:49.000Z","msg":"我隻狗前兩日走左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 真係好傷心<br />\n最後24小時接左佢番屋企陪住佢行最後一程<br />\n一直都無諗過佢會因為病而離開<br />\n仲要最後24小時咁痛 痛到係咁吠<br />\n呢兩日不停諗自己究竟有無做錯<br />\n如果有啲野再早啲知道 或者易啲醫 或者轉醫生會唔會有第二個結果<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n不過佢都19歲 雖然只收養左4年半<br />\n但真係好唔捨得好傷心<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T08:53:49.000Z","msg":"佢最尾呢段時間希你咁錫佢照顧佢到尾，都好幸福架啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T08:54:41.000Z","msg":"佢最尾呢段時間<span style=\"color: red;\">有</span>你咁錫佢照顧佢到尾，都好幸福架啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T09:19:02.000Z","msg":"見到佢住左幾日醫院 番到黎又痛<br />\n平時佢唔會吠 但有到係咁吠<br />\n我地全家無訓輪住陪佢<br />\n最後幾個鐘全部喺廳陪住佢<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n佢本身周身病痛食十種藥咁濟<br />\n臨走前斷左軔帶行唔到<br />\n我都知佢離開反而係解脫<br />\n但真係好掛住佢<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"cbf7774ec8725bb33de947f4c0fb68cd43c78210","tid":749520,"uid":58140,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-20T09:20:28.000Z","msg":"tebby<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"7389bcc2abae3cd461196466cec049e880ace5a2","tid":749520,"uid":44607,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-20T09:26:50.000Z","msg":"養緊貓既路過<br />\n<br />\n見到上面有幾位巴打都講番左工屋企人打黎就話寵物走左, 個人認為寵物咁樣走好過睇住佢病, 辛苦, 瘦慢慢俾病折磨"},{"pid":"df3cd0731b756d25386b1c912d91b7de3401b47a","tid":749520,"uid":13596,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-07-20T09:28:27.000Z","msg":"那時候 只有你陪我一起往前衝<br />\n有時候 受了傷反而覺得更快活<br />\n我們破風飛行 奔馳海闊天空<br />\n不在乎 把世界拋到腦後<br />\n對人生 我有太多困惑<br />\n但確定 我有個永遠的 朋友<br />\n<br />\n往前走 一個人走上人生的鋼索<br />\n回過頭 怎麼會失去了你的線索<br />\n來不及說再見 從此各自漂流<br />\n為什麼 把過去丟向黑洞<br />\n常想著 你現在的生活<br />\n是不是 已經和你要的 相同<br />\n<br />\n我夢見你也夢見我<br />\n告訴我思念的寂寞<br />\n就在多年以後 那泛淚的笑容<br />\n讓回憶裡的你 再復活<br />\n<br />\n我夢見你也夢見我<br />\n當你也覺得很失落<br />\n就在夢醒以後 謝謝你來過<br />\n留給我生命中最美的 感動<br />\n<br />\n往前走 一個人走上人生的鋼索<br />\n回過頭 怎麼會失去了你的線索<br />\n來不及說再見 從此各自漂流<br />\n為什麼 把過去丟向黑洞<br />\n常想著 你現在的生活<br />\n是不是 和你要的 相同<br />\n<br />\n我夢見你也夢見我<br />\n告訴我思念的寂寞<br />\n就在多年以後 那泛淚的笑容<br />\n讓回憶裡的你 再復活<br />\n<br />\n我夢見你也夢見我<br />\n當你也覺得很失落<br />\n就在夢醒以後 謝謝你來過<br />\n提醒我別忘了那時候 的我"},{"pid":"a69544a169d6d0f27c8465d5bcb4fde58d5b1680","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"quote":{"pid":"9bd4e200ecf675d5f01a12202bff259ebaed017a","tid":749520,"uid":17189,"like":0,"dislike":1,"score":-1,"quote":{"pid":"d15e5ebac7e708af872bc31d5cff37c20041e0be","tid":749520,"uid":133824,"like":1,"dislike":1,"score":0,"quote":{"pid":"62262f749044d61c9efd1f5ae8bf3bb7476f10d1","tid":749520,"uid":17189,"like":22,"dislike":1,"score":21,"citedBy":1,"replyTime":"2018-07-20T08:02:50.000Z","msg":"我嗰隻大狗今年都就黎九歲<br />\n長期食藥同睇醫生<br />\n其實全家都有曬心理準備<br />\n但每次夜晚瞓唔著一諗起<br />\n就會喊到痴左線<br />\n其實我唔係好高要求<br />\n只求佢睇到我同我女朋友結婚一刻<br />\n起教堂著婚紗影番張相留念<br />\n已經唔敢奢求話見到我有小朋友一刻<br />\n由中學開始陪到我宜家<br />\n當佢係我個仔咁<br />\n真係好唔捨得<br />\n打到哩度我又忍唔住喊啦<br />\n巴打你都唔好傷心啦<br />\n佢起彩虹橋一定好開心玩緊<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" /> <br />\n佢都唔想再見到你為佢而傷心架<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T08:52:00.000Z","msg":"我隻仔仔都有長期病，仲有一隻眼白內障睇唔到<br />\n原本諗住做手術，但醫生話佢本身身體差，做完手術未必醒得番，所以最後都無做<br />\n佢都慢慢慣左，果時屋企唔會亂擺野怕佢撞到<br />\n但到佢走左果時都有諗，其實佢走左唔使再打針食藥，隻眼又睇得番野，可能對佢對我地都係一種解脫<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T08:58:22.000Z","msg":"係呀<br />\n所以佢起彩虹橋宜家應該玩得好開心<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-20T09:37:56.000Z","msg":"都係既，又可以跑跑跳跳<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"a27f7fc184fdc29c8ad84f764efa0b8da7da4e6d","tid":749520,"uid":133824,"like":1,"dislike":1,"score":0,"quote":{"pid":"9db583d0d6e4d68de842a3d9b8f3cc009e5a332a","tid":749520,"uid":94454,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-20T08:59:08.000Z","msg":"一睇到個post即刻想攬下隻狗<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T09:39:09.000Z","msg":"多啲陪佢，就算唔係成日出街行，坐係佢隔離陪住佢已經好好<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b398fe8f57eb628057ace7beacbb0b53b5d17592","tid":749520,"uid":133824,"like":0,"dislike":1,"score":-1,"quote":{"pid":"adb040904e73754b8d22350bde0b6a5e1f0fe4f3","tid":749520,"uid":75256,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-20T09:12:31.000Z","msg":"你果隻同我果隻好似樣，但你果隻d 毛白d。<br />\n<br />\n我果隻今年都11歲，有d 白內障，但好精神。每次抱佢，都叫佢陪埋我地廿幾三十年先好走呀。雖然明知無可能，但都希望佢留耐d<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-20T09:41:13.000Z","msg":"摩天使黎<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n我隻仔都有隻眼有白內障，但身體差唔做得手術<br />\n就算佢睇唔清楚你，但佢一聞就知係你仲會跑過黎<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"8b3631ca90a6e7504afcab9a4a96c7ca7bd41004","tid":749520,"uid":133824,"like":0,"dislike":1,"score":-1,"quote":{"pid":"7e4bea87f6f9c24cf91ae1bf248889703a468777","tid":749520,"uid":75256,"like":0,"dislike":1,"score":-1,"quote":{"pid":"480240379b9269714ce270cdc5314bfc02e96be0","tid":749520,"uid":133824,"like":1,"dislike":1,"score":0,"quote":{"pid":"5aca20088499f6f6d9b3b1d36979844c1fe22a76","tid":749520,"uid":43557,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-20T06:33:42.000Z","msg":"我都好驚果日<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T07:43:53.000Z","msg":"無得驚<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 我果日都好突然，明明朝早仲好似平時咁送我出門口番工，收工番緊去就收到電話<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T09:13:47.000Z","msg":"佢之前有無病，定係好健康的？"},"citedBy":0,"replyTime":"2018-07-20T09:43:02.000Z","msg":"個肝長期唔得要食藥同控制飲食，我娘親真係當佢孫咁湊咁錫先可以有11歲，7-8歲果年個醫生都話可能得番半年命<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"7c0472e77e69e2f79523117ad7546ee3dccc9c5a","tid":749520,"uid":104533,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-20T09:43:41.000Z","msg":"做獸醫診所姑娘，見得太多依啲場面<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> <br />\n所以做哂心理準備，自己啲寵物有絕症一定唔會勉強佢，寧願佢可以係我身邊走得舒服啲"},{"pid":"5245f729014b06b9d941576374af29840ed3974a","tid":749520,"uid":13850,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-20T09:45:40.000Z","msg":"我都好怕佢走⋯所以一直睇好多狗狗保健既資料，希望佢健健康康<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"49f8928757e6b13187cd61bf4a8b352a08acb4c6","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"quote":{"pid":"441f299dcabd8058749dc1aa5b1936290f96cf17","tid":749520,"uid":32279,"like":0,"dislike":0,"score":0,"quote":{"pid":"5158e422268d3dcc6a890eac9e7ee1d896172865","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"quote":{"pid":"8dbf158e12588a91906d3dcff0b9b19ce6109693","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-20T08:53:49.000Z","msg":"佢最尾呢段時間希你咁錫佢照顧佢到尾，都好幸福架啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T08:54:41.000Z","msg":"佢最尾呢段時間<span style=\"color: red;\">有</span>你咁錫佢照顧佢到尾，都好幸福架啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T09:19:02.000Z","msg":"見到佢住左幾日醫院 番到黎又痛<br />\n平時佢唔會吠 但有到係咁吠<br />\n我地全家無訓輪住陪佢<br />\n最後幾個鐘全部喺廳陪住佢<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n佢本身周身病痛食十種藥咁濟<br />\n臨走前斷左軔帶行唔到<br />\n我都知佢離開反而係解脫<br />\n但真係好掛住佢<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-20T09:47:01.000Z","msg":"遲啲可能會番黎搵你做你真正既仔/女呢<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"97be05b5fed601d1e44260345a23ccad60e69cfd","tid":749520,"uid":33004,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-07-20T09:48:13.000Z","msg":"對唔住都想講句<br />\n你分享無問題<br />\n做乜鳩要post相<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n生前既相都話<br />\n死左嗰張<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"c8d2d00b045bd54a8d5d4337806d081d71756787","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"quote":{"pid":"7c0472e77e69e2f79523117ad7546ee3dccc9c5a","tid":749520,"uid":104533,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-20T09:43:41.000Z","msg":"做獸醫診所姑娘，見得太多依啲場面<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> <br />\n所以做哂心理準備，自己啲寵物有絕症一定唔會勉強佢，寧願佢可以係我身邊走得舒服啲"},"citedBy":0,"replyTime":"2018-07-20T09:49:28.000Z","msg":"自己知道佢有長期病一路都賺緊做左心理準備，收到電話果時都無太激動<br />\n但到真係面對果時始終都會好傷心"},{"pid":"bc38161056e1c0720c074f919590178300f62999","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"quote":{"pid":"5245f729014b06b9d941576374af29840ed3974a","tid":749520,"uid":13850,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-20T09:45:40.000Z","msg":"我都好怕佢走⋯所以一直睇好多狗狗保健既資料，希望佢健健康康<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T09:49:54.000Z","msg":"有責任心既主人<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"2dafa2fc9c724637425ff733c95d9081d9ffb385","tid":749520,"uid":13850,"like":0,"dislike":2,"score":-2,"quote":{"pid":"bc38161056e1c0720c074f919590178300f62999","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"quote":{"pid":"5245f729014b06b9d941576374af29840ed3974a","tid":749520,"uid":13850,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-20T09:45:40.000Z","msg":"我都好怕佢走⋯所以一直睇好多狗狗保健既資料，希望佢健健康康<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T09:49:54.000Z","msg":"有責任心既主人<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T09:52:04.000Z","msg":"我自己都冇咁緊張自己身體<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n一黎唔捨得佢地有病<br />\n二黎睇獸醫真係好撚貴<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3149b8fc671204847562b26e33413fda0efb43a9","tid":749520,"uid":162485,"like":0,"dislike":2,"score":-2,"quote":{"pid":"5e0a893d35a98f9744e1c7506b8d71f48c8d8842","tid":749520,"uid":133824,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-07-20T05:50:19.000Z","msg":"上年既琴日佢走左，成家都好傷心同一個親人走左無分別<br />\n琴日係相簿同fb睇番佢既相同片，之後呆左半個鐘諗番佢點跑跑跳跳，嗲我地扭抱<br />\n呢11年除左我，連我阿爹阿娘都當佢孫咁錫，希望養緊寵物既你好好咁陪下佢地，因為佢地既世界真係得你地<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/07/20/134553_55408a73762a9638a303c2e06874c6b1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F20%2F134553_55408a73762a9638a303c2e06874c6b1.png&h=c4d53fc2&s={SIZE}\" /><br />\n<br />\n送佢走果時好似訓左咁，真係有一刻以為佢會突然間起番身又嗲我<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/07/20/134820_b8eb7f33c8d558caff907f8f1236d7eb.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F20%2F134820_b8eb7f33c8d558caff907f8f1236d7eb.png&h=14c0a892&s={SIZE}\" /><br />\n<br />\n<span style=\"color: red;\"> 請所有養緊寵物既你唔好話棄養就棄養！</span>"},"citedBy":0,"replyTime":"2018-07-20T09:55:08.000Z","msg":"隻狗係咪叫老納<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/35.png\" class=\"hkgmoji\" />"},{"pid":"87c8c6e70181eebff807df45599dcbab46d80af5","tid":749520,"uid":94454,"like":0,"dislike":0,"score":0,"quote":{"pid":"a27f7fc184fdc29c8ad84f764efa0b8da7da4e6d","tid":749520,"uid":133824,"like":1,"dislike":1,"score":0,"quote":{"pid":"9db583d0d6e4d68de842a3d9b8f3cc009e5a332a","tid":749520,"uid":94454,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-20T08:59:08.000Z","msg":"一睇到個post即刻想攬下隻狗<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-20T09:39:09.000Z","msg":"多啲陪佢，就算唔係成日出街行，坐係佢隔離陪住佢已