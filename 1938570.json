":0,"score":0,"quote":{"pid":"d8417207505a61a03f4a624a7321a2f0f3484d2c","tid":1938570,"uid":223428,"like":1,"dislike":0,"score":1,"quote":{"pid":"398b3a8e213a28413da8f691155a65bbfe421eaf","tid":1938570,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-22T17:41:50.000Z","msg":"咁耐都未寫完<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><br />\n咁幾時有得睇呀<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-22T17:53:02.000Z","msg":"寫到第43章，上少d連登會快d寫完。後來脈絡亂左少少。<br />\n想50章止。"},"citedBy":1,"replyTime":"2020-04-27T21:17:12.000Z","msg":"有得睇未<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-28T01:23:28.000Z","msg":"未<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"e59beee69d4eddc9725d79d1330f77fd7b61e5dd","tid":1938570,"uid":246289,"like":0,"dislike":0,"score":0,"quote":{"pid":"09114a07d82182e22f98cf2c17dba41d5a5a1bef","tid":1938570,"uid":223428,"like":0,"dislike":0,"score":0,"quote":{"pid":"81f9fcfa11d52c1a03e533580ef1b16071f9921a","tid":1938570,"uid":246289,"like":0,"dislike":0,"score":0,"quote":{"pid":"d8417207505a61a03f4a624a7321a2f0f3484d2c","tid":1938570,"uid":223428,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-03-22T17:53:02.000Z","msg":"寫到第43章，上少d連登會快d寫完。後來脈絡亂左少少。<br />\n想50章止。"},"citedBy":1,"replyTime":"2020-04-27T21:17:12.000Z","msg":"有得睇未<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-28T01:23:28.000Z","msg":"未<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-28T20:17:20.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n加油 會等你<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"a99a0e609fe43ea10ee8b44657d5f189437edf4f","tid":1938570,"uid":277236,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-08T18:12:26.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"}]}