aces/pigxm/snowhat.gif\" class=\"hkgmoji\" />"},{"pid":"0ad3bb8b9093cf00f9a63778d4ce75d8467fbed6","tid":1800044,"uid":207195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-27T13:56:33.000Z","msg":"笑撚死<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />幫我地呢邊嫌好多人升級得唔夠嘅時候，對面連和理非都話係滅絕人性<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dc197072941e6c9bb82b66bd9328e8ffb3fa4298","tid":1800044,"uid":23085,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-12-27T13:56:51.000Z","msg":"連黑警都有得屌票"},{"pid":"3082ec4b8fdc8a4c80c7eb3e491b33971c55f51a","tid":1800044,"uid":32473,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-12-27T14:00:25.000Z","msg":"玩左幾個月分化搞唔掂<br />\n時間證明原來自己係個傻鳩<br />\n然後發爛渣<br />\n開地圖砲屌全世界<br />\n唔好話我鳩up<br />\n真係是但搵件蒲開cc台既巴打都可以秒作d垃圾論點<br />\n員佐真係員佐<br />\n智力既上限唔過60"},{"pid":"efb8ea6963c284a74afecb42fd12d8ed8038b36c","tid":1800044,"uid":41292,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-27T14:04:26.000Z","msg":"林總統你好"},{"pid":"a1672e12f8383b7c90d558b3a4cd8de17476c8ea","tid":1800044,"uid":221265,"like":1,"dislike":0,"score":1,"quote":{"pid":"747189db433520c51ee7ab6af71217562cff743e","tid":1800044,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-12-27T12:14:33.000Z","msg":"警察隊員佐級協會主席林志偉向會員發信，表示黑衣暴徒處心積慮連日在各大商場、公共地方、交通樞紐搗亂滋事，包括破壞銀行商店食肆、毀壞公眾設施、毆打異見市民等，形容是「無惡不作，為所欲為」，令香港市民再度與佳節無緣。<br />\n<br />\n林志偉又指，除了親手參與暴行的狂徒，一眾自稱和平、理性、非暴力的追隨者亦難辭其咎，他們的「惡行」包括以身體、雨傘或其他物件掩護暴徒施暴及破壞、在暴徒施暴及破壞過程中吶喊助威、協助暴徒逃避警察追捕、在網上平台或以其他方法鼓動他人參與違法行為等。<br />\n<br />\n協會懇請各大傳媒及市民停止以「和理非」稱呼他們，認為他們的行逕「滅絕人性，冷血程度不下於施暴狂徒，配不上和平、理性等歌頌人類美德的詞語，是赤裸裸的幫凶。」<br />\n<a href=\"https://www.am730.com.hk/news/新聞/員佐級協會轟「和理非」是「幫凶」-201695\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.am730.com.hk%2Fnews%2F%E6%96%B0%E8%81%9E%2F%E5%93%A1%E4%BD%90%E7%B4%9A%E5%8D%94%E6%9C%