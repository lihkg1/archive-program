faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f9d9c4562c3fe2b023d5bc44e3b7c0c29a1328ed","tid":1375772,"uid":63370,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:48:19.000Z","msg":"推"},{"pid":"8267e688f9904e4b393128f20e64a0431ad957d2","tid":1375772,"uid":63370,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T08:25:33.000Z","msg":"推"},{"pid":"54a8676f55b8632389e7cc86847358fce5b176e3","tid":1375772,"uid":279006,"like":0,"dislike":0,"score":0,"quote":{"pid":"a00c82dbd6da15773ee22749803bce84a8d48006","tid":1375772,"uid":63370,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-28T06:47:49.000Z","msg":"昨晚大約十一點，我朋友喺波斯富街連濃牆被打(另有一名白衫中年男子被打至仍然留醫)。<br />\n<br />\n當時聽到有人係連濃牆破壞同搞事，我朋友就上前拍片，點知就比兩個人圍毆。擾攘一番後報警到醫院驗傷，點知竟然反過黎被警察拘留扣押，但警察未能講清楚到底而家係拘捕定係協助週查。落口供後被要求留低衣物作證，最後交保釋金後就返咗屋企(唔清楚要交保釋金係唔係=被拘捕)<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n如果而家呢度有人當時在場，或者手頭上有相關片段，可唔可以幫幫手share出黎作證？因為而家手頭上得一條片，而條片影唔到啲咩實質證據<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n<a href=\"https://m.facebook.com/story.php?story_fbid=10156727117709737&amp;id=2228262587450481&amp;sfnsn=xwwa&amp;funlid=gLRDLKwDYU03yXBw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2Fstory.php%3Fstory_fbid%3D10156727117709737%26id%3D2228262587450481%26sfnsn%3Dxwwa%26funlid%3DgLRDLKwDYU03yXBw&d=GsYKB4iL2zhb3369BxXbpyHJFIlRN37b%2BuZTNWj4Tkw%3D&h=ea32f1a6\" data-auto-link target=\"_blank\">https://m.facebook.com/story.php?story_fbid=10156727117709737&amp;id=2228262587450481&amp;sfnsn=xwwa&amp;funlid=gLRDLKwDYU03yXBw</a><br />\n(片段中坐係地下黑衫係我朋友，比兩人圍打完，而中間白衫係當時同佢一齊同行嘅朋友）"},"citedBy":1,"replyTime":"2019-07-28T10:59:41.000Z","msg":"我朋友係現場有片，"},{"pid":"d8afa0a2515afefff4e0047f887d6c5a49dcb