。<br />\n<br />\n<a href=\"https://tw.news.yahoo.com/%E5%B9%B4%E5%BA%A6%E5%8D%81%E5%A4%A7%E7%A7%91%E5%AD%B8%E4%BA%BA%E7%89%A9-%E6%A6%9C%E9%A6%96%E7%AB%9F%E6%98%AF%E8%AD%9A%E5%BE%B7%E5%A1%9E-134305720.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.news.yahoo.com%2F%25E5%25B9%25B4%25E5%25BA%25A6%25E5%258D%2581%25E5%25A4%25A7%25E7%25A7%2591%25E5%25AD%25B8%25E4%25BA%25BA%25E7%2589%25A9-%25E6%25A6%259C%25E9%25A6%2596%25E7%25AB%259F%25E6%2598%25AF%25E8%25AD%259A%25E5%25BE%25B7%25E5%25A1%259E-134305720.html&d=PGKZrCzpIeFm7bz4D1EKrYCLuBk19a2msHWYQfvuVO4%3D&h=ec17731e\" target=\"_blank\">https://tw.news.yahoo.com/%E5%B9%B4%E5%BA%A6%E5%8D%81%E5%A4%A7%E7%A7%91%E5%AD%B8%E4%BA%BA%E7%89%A9-%E6%A6%9C%E9%A6%96%E7%AB%9F%E6%98%AF%E8%AD%9A%E5%BE%B7%E5%A1%9E-134305720.html</a>"},"citedBy":1,"replyTime":"2020-12-18T07:39:37.000Z","msg":"真係無撚野好講，完"},"citedBy":2,"replyTime":"2020-12-18T08:21:40.000Z","msg":"仲on9過黑鬼總統一上任就拎和平獎<br />\n疫情一開頭 呢隻黑鬼做咗啲咩嗰班左9可以完全唔理<br />\n顛倒是非黑白同共產黨無分別"},{"pid":"8afbcf21c3047ca004bfb63b3800ba41da755c16","tid":2330634,"uid":19617,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2020-12-18T08:22:14.000Z","msg":"<img src=\"https://na.cx/i/413YBB0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F413YBB0.png&h=cf14ebf7&s={SIZE}\" />"},{"pid":"23880550e4bc475e79d3dd33f30818285c54ac32","tid":2330634,"uid":199957,"like":2,"dislike":0,"score":2,"quote":{"pid":"156ded9ec356d7197fcb90ba0d248470bf9b726a","tid":2330634,"uid":60120,"like":12,"dislike":1,"score":11,"citedBy":1,"replyTime":"2020-12-18T07:42:23.000Z","msg":"原來科學係咁解<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-18T08:22:21.000Z","msg":"倒退返去幾百年之前"},{"pid":"04b93ae61b5ef5e82acdc2b342d84ea19dfa54bc","tid":2330634,"uid":186,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-18T08:22:59.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"2c8777eccf612ce988d0d6d65cc