en20Shot202018-11-0220at204.44.3520PM_7ymkt_1200x0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2FScreen20Shot202018-11-0220at204.44.3520PM_7ymkt_1200x0.png&h=f886481c&s={SIZE}\" /><br />\n<br />\n<img src=\"https://cdn.thestandnews.com/media/photos/cache/Screen20Shot202018-11-0220at204.44.3020PM_JLHJc_1200x0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2FScreen20Shot202018-11-0220at204.44.3020PM_JLHJc_1200x0.png&h=c27382e0&s={SIZE}\" /><br />\n<br />\n<img src=\"https://cdn.thestandnews.com/media/photos/cache/Screen20Shot202018-11-0220at204.44.2520PM_KyaJ1_1200x0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2FScreen20Shot202018-11-0220at204.44.2520PM_KyaJ1_1200x0.png&h=52af1891&s={SIZE}\" /><br />\n<br />\n<img src=\"https://cdn.thestandnews.com/media/photos/cache/Screen20Shot202018-11-0220at204.44.4020PM_f6kW5_1200x0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2FScreen20Shot202018-11-0220at204.44.4020PM_f6kW5_1200x0.png&h=3927eb0b&s={SIZE}\" /><br />\n<br />\n<a href=\"https://thestandnews.com/politics/異見漫畫家巴丟草香港作品展突取消-主辦單位稱收中國當局威脅/#.W9wcsGGALx8.facebook\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%E7%95%B0%E8%A6%8B%E6%BC%AB%E7%95%AB%E5%AE%B6%E5%B7%B4%E4%B8%9F%E8%8D%89%E9%A6%99%E6%B8%AF%E4%BD%9C%E5%93%81%E5%B1%95%E7%AA%81%E5%8F%96%E6%B6%88-%E4%B8%BB%E8%BE%A6%E5%96%AE%E4%BD%8D%E7%A8%B1%E6%94%B6%E4%B8%AD%E5%9C%8B%E7%95%B6%E5%B1%80%E5%A8%81%E8%84%85%2F%23.W9wcsGGALx8.facebook&d=XjQgjJGG3Jmbsj%2FlSM8MSDA5unq%2FSd9ZKvr75NUD1%2F0%3D&h=b0829bde\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%E7%95%B0%E8%A6%8B%E6%BC%AB%E7%95%AB%E5%AE%B6%E5%B7%B4%E4%B8%9F%E8%8D%89%E9%A6%99%E6%B8%AF%E4%BD%9C%E5%93%81%E5%B1%95%E