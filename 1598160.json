src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"460e04c44e425bd0a42b9ef884e88d407e21c533","tid":1598160,"uid":86828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T11:52:50.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"1ffff96738404920c529f16b964ab2823d662f5b","tid":1598160,"uid":303110,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T11:54:19.000Z","msg":"Push"},{"pid":"dd16cb9696f3b658fe26ec037d6df4b03b92b081","tid":1598160,"uid":242734,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T11:54:27.000Z","msg":"推"},{"pid":"1725368292bd56d456096ec1f279ed860af3829f","tid":1598160,"uid":319568,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T11:54:42.000Z","msg":"國旗及國徽條例<br />\n<br />\n《國旗及國徽條例》規定須保護國旗、國徽，列明任何人公開及故意以焚燒、毀損、塗劃、玷污、踐踏等方式侮辱國旗或國徽，即屬犯罪，一經定罪，可處第5級罰款及監禁3年。"},{"pid":"66ccd881d4e2f0b000e02ce0a154902186c1d3e8","tid":1598160,"uid":319568,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T11:56:51.000Z","msg":"公安條例<br />\n<br />\n<a href=\"https://zh.wikipedia.org/wiki/%E5%85%AC%E5%AE%89%E6%A2%9D%E4%BE%8B_(%E9%A6%99%E6%B8%AF)\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E5%2585%25AC%25E5%25AE%2589%25E6%25A2%259D%25E4%25BE%258B_%28%25E9%25A6%2599%25E6%25B8%25AF%29&d=MLRnjlmMEh1el5UvTt2rHWAbrlwo3OpfDsLQU8t9Jac%3D&h=e7454ed8\" target=\"_blank\">https://zh.wikipedia.org/wiki/%E5%85%AC%E5%AE%89%E6%A2%9D%E4%BE%8B_(%E9%A6%99%E6%B8%AF)</a>"},{"pid":"f708b03b7c6479aaec0f4198b93785b49abc6a1d","tid":1598160,"uid":319568,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T11:58:40.000Z","msg":"社團條例<br />\n<br />\n<br />\n第151章《社團條例》 本條例旨在就社團的註冊、禁止某些社團的運作，以及與此有關的事宜，訂定條文。 在該社團或該分支機構的決策過程中，外國政治性組織或台灣政治性組織直接或間接作出指示、主使、控制或參與<br />\n<br />\n<br />\n之前用呢個取締民族黨"},{"pid":"6e4e79b5e1da133581601296d1b05f826bcf53a5","tid":1598160,"uid":182197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T12:01:59.000Z","msg":"TUI"},{"pid":"08a3efab9ce559d1da6ade1b004aa9f29d230be0","tid":1598160,"uid":86828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T12:09:18.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"}]}