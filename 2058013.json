?v=1Q012EzAXR8&amp;list=PLWhTf0pND8pcPyCj41vWS4nXWSBLcTWUj&amp;index=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D1Q012EzAXR8%26list%3DPLWhTf0pND8pcPyCj41vWS4nXWSBLcTWUj%26index%3D1&d=TNVh%2FXBsTmD9bRjMILuVa9VSC25YwgVwXuaRRXYDXIw%3D&h=38a6d0c8\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=1Q012EzAXR8&amp;list=PLWhTf0pND8pcPyCj41vWS4nXWSBLcTWUj&amp;index=1</a><br />\n<br />\n之前整片時拍落既無音樂版gameplay，<br />\n睇住先，支持下幫手推下post<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"f4488640caf562fc4ca095379e1e527f7bf61d3e","tid":2058013,"uid":223002,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-10T19:38:54.000Z","msg":"G持本土遊戲工業<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b1890cd2202564008449be0da6d34b4e9f86c39e","tid":2058013,"uid":9640,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-10T19:40:56.000Z","msg":"呢排好多港產遊戲出世<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"121989daebe5be15f24206a8b38f294c39bf0317","tid":2058013,"uid":9640,"like":0,"dislike":0,"score":0,"quote":{"pid":"aafb7107c2ff66af5d311cf3894ebb49cdacb41b","tid":2058013,"uid":104804,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-06-10T03:52:26.000Z","msg":"近日咁多香港STEAM彈起"},"citedBy":0,"replyTime":"2020-06-10T19:47:55.000Z","msg":"軟實力 好事黎<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"e5ec57b3f74af11c5084395b9192d5d39ea2fad7","tid":2058013,"uid":45498,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-10T20:56:44.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\