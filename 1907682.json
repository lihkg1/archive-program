82,"uid":188035,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-02T23:55:04.000Z","msg":"Push"},{"pid":"1319243ef3bc31a5332529048da9c5efcda2d3d9","tid":1907682,"uid":158613,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T01:35:22.000Z","msg":"push"},{"pid":"3253da289d1efaf364d09fe4f964114d18fa3b66","tid":1907682,"uid":237300,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T02:05:17.000Z","msg":"好有心"},{"pid":"3e0d893aab6738f47693fb41aaa34b26837745e7","tid":1907682,"uid":210495,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T02:33:02.000Z","msg":"黃店手足入入嚟 登記完飲食界個人票 仲差一步！<br />\n<a href=\"https://lih.kg/1904542\" data-auto-link target=\"_blank\">https://lih.kg/1904542</a><br />\n<br />\n[[尚欠三千]] 工程同建測規園界，差3000手足趕走盧偉國同謝偉銓<br />\n<a href=\"https://lih.kg/1903176\" data-auto-link target=\"_blank\">https://lih.kg/1903176</a><br />\n<br />\n做緊老細嘅你入一入黎 我比張進出口界嘅選票你<br />\n<a href=\"https://lih.kg/1903067\" data-auto-link target=\"_blank\">https://lih.kg/1903067</a><br />\n<br />\n做網店嘅入一入嚟 登記做功能組民選民 即時有票踢走黃定光<br />\n<a href=\"https://lih.kg/fdzxwS\" data-auto-link target=\"_blank\">https://lih.kg/fdzxwS</a>"},{"pid":"cdedc78545ce66b07b6a46e61ca76fb99a1ba2b3","tid":1907682,"uid":141286,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T03:16:41.000Z","msg":"推呢個<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<pre><code data-type=\"\">18歲生日快樂 即刻登記做選民\n\n只要在2020年7月25日或以前年滿18歲，今年5月2日前可登記做選民</code></pre><br />\n選民登記填表機<br />\n<a href=\"https://hk2020.vote\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk2020.vote&d=FoM%2FNT%2BxDvRLDdkWKwCN%2BOSCO5RJLUOM1IbOSdmZk8c%3D&h=9c301e04\" data-auto-link target=\"_blank\">https://hk2020.vote</a><br />\n地方選區選民新登記申請表：<br />\n<a href=\"https://www.reo.gov.hk/pdf/form/REO-1(C\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.reo.gov.hk%2Fpdf%2Fform%2FREO-1%28C&d=FoM%2FNT%2BxDvRLDdkWKwCN%2BOSCO5RJLUOM1IbOSdmZk8c%3D&h=893e2c86\" data-auto-link target=\"_blank\">https://www.reo.gov.hk/pdf/form/REO-1(C</a>).pdf<br />\n選民資料網上查閱系統<br />\n<a href=\"https://www2.voterinfo.gov.hk/bd_reovi/OVIES/jsp/web/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww2.voterinfo.gov.hk%2Fbd_reovi%2FOVIES%2Fjsp%2Fweb%2F&d=FoM%2FNT%2BxDvRLDdkWKwCN%2BOSCO5RJLUOM1IbOSdmZk8c%3D&h=9302e3ac\" data-auto-link target=\"_blank\">https://www2.voterinfo.gov.hk/bd_reovi/OVIES/jsp/web/</a><br />\n<img src=\"https://i.lih.kg/540/https://na.cx/i/M8STBFS.jpg\" /><br />\n<img src=\"https://i.lih.kg/540/https://na.cx/i/a8T7y6C.jpg\" />"},{"pid":"e8ddec7ce94f8c39f90437464bd23014627bbda4","tid":1907682,"uid":41355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T03:17:40.000Z","msg":"push"},{"pid":"984a8f73be25d1595f0c58f7a76e7f82ce9eac18","tid":1907682,"uid":200665,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T03:18:51.000Z","msg":"推"},{"pid":"30d738529910bfafbac8c92bde8a3b2175c49fcc","tid":1907682,"uid":209390,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T03:18:56.000Z","msg":"Pm下啲fb網店 好多係黃"},{"pid":"1a12ce432fb4a18f690fc9185402b0d67756bfb0","tid":1907682,"uid":70063,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T03:57:30.000Z","msg":"lm"},{"pid":"1a826b5dec8f2a8464c3226bba0d82ef5afc3448","tid":1907682,"uid":33868,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-03T03:59:54.000Z","msg":"我想問Online Business用屋企擺野點申請進出口牌？<br />\n我見佢好似要交Stamped租單同埋舖頭個樣"},{"pid":"8b17ac6485c2936941703f63956094ccd8157c4a","tid":1907682,"uid":142242,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T10:10:45.000Z","msg":"推"},{"pid":"70bd0b2ed920b6dd6de774680259895b89d267b1","tid":1907682,"uid":210495,"like":0,"dislike":0,"score":0,"quote":{"pid":"1a826b5dec8f2a8464c3226bba0d82ef5afc3448","tid":1907682,"uid":33868,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-03T03:59:54.000Z","msg":"我想問Online Business用屋企擺野點申請進