日裁減部份香港員工。<br />\n<br />\n香港康樂體育專業人員總會會長李粵閩指，暫未見健身業界出現大規模裁員，但認為部份健身中心分店持續欠租，屬經營警號，望政府放寬健身教練採取適當的社交距離下，在戶外場地授課，及加快審批防疫抗疫基金下的健身中心資助計劃。<br />\n<br />\n<a href=\"https://www.hk01.com/01%E5%81%B5%E6%9F%A5/577423/%E8%88%92%E9%81%A9%E5%A0%A1-goji%E5%81%A5%E8%BA%AB%E5%AE%A4%E6%95%B8%E5%BA%97%E9%81%AD%E5%85%A5%E7%A6%80%E8%BF%BD%E7%A7%9F-pure%E8%A3%81%E5%93%A1-300%E4%B8%AD%E5%B0%8F%E5%BA%97%E5%B7%B2%E7%B5%90%E6%A5%AD\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F01%25E5%2581%25B5%25E6%259F%25A5%2F577423%2F%25E8%2588%2592%25E9%2581%25A9%25E5%25A0%25A1-goji%25E5%2581%25A5%25E8%25BA%25AB%25E5%25AE%25A4%25E6%2595%25B8%25E5%25BA%2597%25E9%2581%25AD%25E5%2585%25A5%25E7%25A6%2580%25E8%25BF%25BD%25E7%25A7%259F-pure%25E8%25A3%2581%25E5%2593%25A1-300%25E4%25B8%25AD%25E5%25B0%258F%25E5%25BA%2597%25E5%25B7%25B2%25E7%25B5%2590%25E6%25A5%25AD&d=TIKlq4bXcOIiQck3m%2BQSv%2FzvTpW%2BvScgizIMFshFG5Q%3D&h=d357bbbb\" data-auto-link target=\"_blank\">https://www.hk01.com/01%E5%81%B5%E6%9F%A5/577423/%E8%88%92%E9%81%A9%E5%A0%A1-goji%E5%81%A5%E8%BA%AB%E5%AE%A4%E6%95%B8%E5%BA%97%E9%81%AD%E5%85%A5%E7%A6%80%E8%BF%BD%E7%A7%9F-pure%E8%A3%81%E5%93%A1-300%E4%B8%AD%E5%B0%8F%E5%BA%97%E5%B7%B2%E7%B5%90%E6%A5%AD</a>"},"citedBy":0,"replyTime":"2021-01-27T06:25:34.000Z","msg":"粵閩粵傷心"},{"pid":"c1be9e8f773233c67a2d5453f50ea928b429c36a","tid":2381313,"uid":5199,"like":4,"dislike":0,"score":4,"quote":{"pid":"6828e793aa95c120d047374a0e17e382c8ba69ec","tid":2381313,"uid":313692,"like":46,"dislike":11,"score":35,"citedBy":5,"replyTime":"2021-01-26T13:07:57.000Z","msg":"香港連鎖gym room 要pure 247 go24 呢啲就夠<br />\n其他一律希望快啲執柒咗佢"},"citedBy":4,"replyTime":"2021-01-27T06:26:19.000Z","msg":"P記可以隔走啲怪人"},{"pid":"947fafa200c4f956e38851a37f5819fff65c4dd5","tid":2381313,"uid":193969,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-27T06:27:35.000Z","msg":"尖撚未日"},{"pid":"8c340bb1446c07bffca85cd19626200b2b3668a1","tid":2381313,"uid":52122,"like":0,"dislike":0,"score":0,"quote":{"pid":"c60492baf5627