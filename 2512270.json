"bd1ddd3c45a54057d5dbb880944bdb6b73f4b6fa","tid":2512270,"uid":321977,"like":0,"dislike":0,"score":0,"quote":{"pid":"ebd6066d7fe1b330aa86e48b22d7c63bbd3f5d5b","tid":2512270,"uid":199893,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-05-01T14:18:25.000Z","msg":"啲狗咁蠢 唔呃狗呃邊個<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-05-02T01:18:07.000Z","msg":"真<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />係醒就唔會做狗啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9c1186cb4fb1691d596e614f1b2ced1ab0ac8d6f","tid":2512270,"uid":142097,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-02T01:23:41.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"a315d3f5f01c2a201a8a71babc1fac10b4e26d1e","tid":2512270,"uid":44209,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-02T05:27:24.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}