s/faces/normal/surprise.gif\" class=\"hkgmoji\" /> <br />\n</blockquote><br />\n<br />\n唔係囉<br />\n唔好誤會連登仔針對生得平凡既女仔<br />\n連登仔唔會咁<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<span style=\"color: pink;\"><span style=\"font-size: x-small;\">係所有女人都係雞呀</span><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /></span>"},{"pid":"11ecf0d3b5d3429cb55ec84a9969cf0e75b0d587","tid":439323,"uid":127705,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-18T05:26:12.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"b6d7f0f4a12ee373d48bdf88fc73f886c1234928","tid":439323,"uid":28614,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-22T13:51:56.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"7e97d2bad4b972e0c996029becf2fa4c5473c7f2","tid":439323,"uid":79353,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-22T13:54:10.000Z","msg":"<img src=\"/assets/faces/lomoji/39.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/39.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/39.png\" class=\"hkgmoji\" />"},{"pid":"f30fc762c8976bfefd3b0f4ab1a3662f2b9fc543","tid":439323,"uid":55552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-28T06:16:52.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}