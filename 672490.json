/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-21T05:38:41.000Z","msg":"Eason唱法就係「走」唱腔，用最真實嘅聲線來唱，唔似90年或之前個堆天皇，腔調重，但偏偏Eason呢種唱法就係最吸引人、最耐聽，所以文字其實唔係好描述到"},{"pid":"7bdb024eaa09a51ae80366d91b5df3d5bf3c167a","tid":672490,"uid":40867,"like":13,"dislike":1,"score":12,"citedBy":1,"replyTime":"2018-05-21T05:38:57.000Z","msg":"Eason 之所以係神<br />\n係duo爛到極致 心知技巧都難以搭救<br />\n只好更加用心 更加賣力去演唱 <br />\n<br />\n天不負Eason <br />\n<br />\n最後造就一場獨一無二 最好聽嘅爛聲演唱會"},{"pid":"0b16d405fc41b33e67dd4e19ce45759ee96775ac","tid":672490,"uid":30478,"like":1,"dislike":0,"score":1,"quote":{"pid":"3c7923188207395346a93e40ada780b2e5e25c10","tid":672490,"uid":68632,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-05-21T05:37:50.000Z","msg":"早幾年無限演唱會<br />\n點都會勞損 <br />\n再加上四張野都黎緊<br />\n算幾好架喇<br />\n<br />\n利申 好鐘意佢"},"citedBy":0,"replyTime":"2018-05-21T05:42:21.000Z","msg":"其實過左40好耐了<br />\n今年44<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"27e0c8548668e88bc8079f730ecd9c879e08e840","tid":672490,"uid":172297,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-05-21T05:49:47.000Z","msg":"其實eason life演唱會個陣把聲已經返哂黎, 雖然冇得同moving on stage 比<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> 但係duo爛聲我都覺得正, 尤其是浮誇同與我常在, 重有陀飛輪唱得好有感情, 太多不能盡錄"},{"pid":"32ea8985e4cff626195c3b1b097dc46708acf617","tid":672490,"uid":187617,"like":0,"dislike":0,"score":0,"quote":{"pid":"7bdb024eaa09a51ae80366d91b5df3d5bf3c167a","tid":672490,"uid":40867,"like":13,"dislike":1,"score":12,"citedBy":1,"replyTime":"2018-05-21T05:38:57.000Z","msg":"Eason 之所以係神<br />\n係duo爛到極致 心知技巧都難以搭救<br />\n只好更加用心 更加賣力去演唱 <br />\n<br />\n天不負Eason <br />\n<br />\n最後造就一場獨一無二 最好聽嘅爛聲演唱會"},"citedBy":0,"replyTime":"2018-05-21T05:57:55.000Z","msg":"Duo真係聽過最好聽嘅爛聲演唱會，果種痴線賣力好似唱完罷就，有今生冇來世咁<img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" />"},{"pid":"e8bab94e4303c8e8f082930c2ddabe0180a37501","tid":672490,"uid":19660,"like":0,"dislike":10,"score":-10,"citedBy":0,"replyTime":"2018