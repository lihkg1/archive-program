ass=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-22T00:06:09.000Z","msg":"<img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" />"},{"pid":"cdeb55b78e227ca5c08c8e7d014756127b3525c2","tid":788754,"uid":4575,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-22T00:28:06.000Z","msg":"美國：你！過黎同我傾，我就黎頂唔住了"},{"pid":"e8c5008d60449202d98c37aea43b1c49c856664a","tid":788754,"uid":56819,"like":1,"dislike":2,"score":-1,"quote":{"pid":"bd9f5e8f4ce854738802334638bfb1f810f55502","tid":788754,"uid":51656,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-08-21T20:58:39.000Z","msg":"快跌倒120對港紙100<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-22T00:34:16.000Z","msg":"人民幣都升返啦，想一兌一都難<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"81b19678a66ee26aa5b7fd947fed60b839428581","tid":788754,"uid":511,"like":1,"dislike":0,"score":1,"quote":{"pid":"e8c5008d60449202d98c37aea43b1c49c856664a","tid":788754,"uid":56819,"like":1,"dislike":2,"score":-1,"quote":{"pid":"bd9f5e8f4ce854738802334638bfb1f810f55502","tid":788754,"uid":51656,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-08-21T20:58:39.000Z","msg":"快跌倒120對港紙100<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-22T00:34:16.000Z","msg":"人民幣都升返啦，想一兌一都難<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-22T00:49:50.000Z","msg":"Yes 快all in<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a35b6124c9064ca99f17238752129985952388b3","tid":788754,"uid":62950,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-22T01:05:21.000Z","msg":"成篇野都content farm咁既格式<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n講埋啲野 你阿媽係女人咁<br />\n當 八月先發現新大陸<br />\n美國係想阻止你支國掘起咁<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n<br />\nbtw 中國邏輯<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n中國定位：中國是世界第二大經濟體，但仍是發展中國家。"}]}