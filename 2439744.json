src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e434cd51f350e33b6172d7e25d7b6bd06ee7095d","tid":2439744,"uid":350584,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-09T13:22:59.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5be600a4ca3014a8891553f4fbaf96bb91e0dbc5","tid":2439744,"uid":37528,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-09T13:27:08.000Z","msg":"其實呢條撚樣打左未<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9416799dbf428e74d75a5dd10fb30be2b18a4315","tid":2439744,"uid":12267,"like":0,"dislike":0,"score":0,"quote":{"pid":"5be600a4ca3014a8891553f4fbaf96bb91e0dbc5","tid":2439744,"uid":37528,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-09T13:27:08.000Z","msg":"其實呢條撚樣打左未<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-09T13:33:27.000Z","msg":"打左，不過Biontech<br />\n科興要留番比愛國者打"},{"pid":"281184e45ec00dc4685681c6a5d8d7866570639e","tid":2439744,"uid":36157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-09T13:36:41.000Z","msg":"有人在打疫苗後死亡，是不出奇。<br />\n有人在打飛滋後死亡，是不出奇。<br />\n有人在打飛機後死亡，是不出奇。<br />\n有人在打市民後死亡，是不出奇。<br />\n刃近平在打疫苗後死亡，是不出奇。"},{"pid":"67a644dd4e417bc953cddc669fcc60eb3605988e","tid":2439744,"uid":270506,"like":1,"dislike":0,"score":1,"quote":{"pid":"daf61000da280e9b5e592dafd0d55ca615b30664","tid":2439744,"uid":350584,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2021-03-09T12:47:06.000Z","msg":"孔繁毅認為目前毋須叫停接種計劃，指打疫苗仍然安全。 <br />\n<br />\n孔繁毅重申，本港每日平均有10人死於冠心病和缺血性中風等，加上在大型接種計劃中，接種者包括長期病患者，因此有人在打疫苗後死亡，是不出奇。"},"citedBy":0,"replyTime":"2021-03-09T13:45:38.000Z","msg":"本港每日平均有10人死於冠心病和缺血性中風等，加上在大型接種計劃中，接種者包括長期病患者，因此有人打疫苗後死亡並不出奇<br />\n<br />\n本港每日平均有少於1人死於China Virus, 加上確診個案包括長期病患者，因此有人中China Virus後死亡並不出奇<br />\n<br />\n如果咁嘅邏