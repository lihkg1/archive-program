":1924372,"uid":40521,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-14T18:31:59.000Z","msg":"<img src=\"https://i.lih.kg/540/https://na.cx/i/OGJOBMw.png\" />"},{"pid":"fc4b7adc7fb6d3b7f0785b982158be586d7dbb23","tid":1924372,"uid":40521,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-14T21:34:22.000Z","msg":"<img src=\"https://i.lih.kg/540/https://na.cx/i/OGJOBMw.png\" />"},{"pid":"ab11889c17d68e34c633065942cb3add06b4f09e","tid":1924372,"uid":283494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-14T23:28:51.000Z","msg":"TVB (上市編號 0511:hk) 之事實<br />\n<br />\n市值過去五年蒸發了一百七十億元港幣<br />\n<br />\n股價五年間一共下挫八成<br />\n<br />\n以2019年上半年表現計, 只要廣告收入少一成, 就會入不敷支, 所以目前明顯是虧蝕狀態<br />\n<br />\n但之前幾十年賺咗好多,所以可以陰蝕好多年"},{"pid":"e361d0355f0b271de1de46a525e4c468397f5591","tid":1924372,"uid":40521,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-15T01:12:30.000Z","msg":"<img src=\"https://i.lih.kg/540/https://na.cx/i/OGJOBMw.png\" />"}]}