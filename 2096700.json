d":2096700,"uid":19126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-06T11:45:03.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"de93da9dcf4aa5fa29860ef83d368f4e28de3975","tid":2096700,"uid":8257,"like":0,"dislike":0,"score":0,"quote":{"pid":"75f2d243c373d8a0d39f4aac506772bda6db9dd3","tid":2096700,"uid":15605,"like":9,"dislike":1,"score":8,"citedBy":2,"replyTime":"2020-07-06T09:50:39.000Z","msg":"他則駕駛Uber維生，月入8,000美元（約6.1萬港元）<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-06T11:47:38.000Z","msg":"NYC 8000蚊係一般人工咋喎<br />\n<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"}]}