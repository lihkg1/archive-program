vi/HqbDM2MnD3s/hqdefault.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.ytimg.com%2Fvi%2FHqbDM2MnD3s%2Fhqdefault.jpg&h=796ba694&s={SIZE}\" />"},{"pid":"438b16b6824b9acbc142b2cfd709ed84ae7a0ed1","tid":2240283,"uid":168478,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-10-12T15:05:23.000Z","msg":"cls<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />做咩成日將心底果句講出嚟"},{"pid":"d0a535404d3a301411252d67c0221b0fa1b7bfee","tid":2240283,"uid":45660,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-12T15:05:29.000Z","msg":"美國陳克勤<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fedc30b3a9a6fb64795dd65262cb5060dc08dfe1","tid":2240283,"uid":177724,"like":1,"dislike":0,"score":1,"quote":{"pid":"159b9c0b9fe77d24a140345732078eb2cbd78008","tid":2240283,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-12T14:17:55.000Z","msg":"美國總統大選即將到來，各黨卯足全力替自己拉選票，民主黨候選人拜登（Joe Biden）於美國時間10日到賓夕法尼亞州拜票時，卻疑似說錯話，提到「試試自己的乳房，但感覺永遠不夠」，讓網友紛紛傻眼，狂轟他演說時、腦袋到底裝些什麼？<br />\n<br />\n<img src=\"https://s.yimg.com/ny/api/res/1.2/kfh8zC86CIzqEVFoEDdmtA--/YXBwaWQ9aGlnaGxhbmRlcjt3PTY0MDtoPTM1NC4xMzMzMzMzMzMzMzMz/https://s.yimg.com/uu/api/res/1.2/0B2rrVJAbT06M4h3Yn8Lbw--~B/aD00MTU7dz03NTA7c209MTthcHBpZD15dGFjaHlvbg--/https://media.zenfs.com/zh-tw/setn.com.tw/8fefbe81a0581b33d473aeb4a23c5447\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs.yimg.com%2Fny%2Fapi%2Fres%2F1.2%2Fkfh8zC86CIzqEVFoEDdmtA--%2FYXBwaWQ9aGlnaGxhbmRlcjt3PTY0MDtoPTM1NC4xMzMzMzMzMzMzMzMz%2Fhttps%3A%2F%2Fs.yimg.com%2Fuu%2Fapi%2Fres%2F1.2%2F0B2rrVJAbT06M4h3Yn8Lbw--~B%2FaD00MTU7dz03NTA7c209MTthcHBpZD15dGFjaHlvbg--%2Fhttps%3A%2F%2Fmedia.zenfs.com%2Fzh-tw%2Fsetn.com.tw%2F8fefbe81a0581b33d473aeb4a23c5447&h=6fb83077&s={SIZE}\" /><br />\n（圖／翻攝自Joe Biden臉書）<br />\n<br />\n拜登在拜票時，先是提及川普2016年承諾的基礎設施計劃沒做到，接著就表示如果他當選了，會改善勞工階級的生活，沒想到下一秒他拋出的一段話，瞬間震驚全場，「每個地方都有同樣故事，你正試試自己的乳房（You are trying your breast），但感覺永遠不夠，你不是在尋求救贖，只是在尋找公平機會」。<br />\n<br />\n拜登口誤的影片曝光後，立刻流傳於網路，雖然大家認為拜登應該是要說「你正努力做到最好（Trying your best）」，仍有不少網友砲轟，留言表示，「是不是要去治療痴呆症了」、「我想知道為甚麼他在過去47年沒有試過胸部」、「拜登是不是在觀眾席裡看到豐滿女子，才會腦子和嘴巴不同步」、「很顯然，拜登在精神上沒有能力擔任總統」。<br />\n<br />\n面對沸沸揚揚的討論，拜登至今沒正面回應，不過今日仍在自己臉書發文，「當川普被告知每天有1000名美國人死於新冠狀病毒時，他聳肩地說『就是這樣』，但真的是這樣嗎？這個總統根本不關心他發誓要服務的美國人，這真的很可恥！」<br />\n<br />\n<a href=\"https://tw.news.yahoo.com/嗆川普承諾跳票-拜登竟說試試胸部-133055104.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.news.yahoo.com%2F%E5%97%86%E5%B7%9D%E6%99%AE%E6%89%BF%E8%AB%BE%E8%B7%B3%E7%A5%A8-%E6%8B%9C%E7%99%BB%E7%AB%9F%E8%AA%AA%E8%A9%A6%E8%A9%A6%E8%83%B8%E9%83%A8-133055104.html&d=W9k3bdIekjUozLnTtmc2V4c%2FDYnbIFO1z8NzTSvCTwQ%3D&h=bf9160f1\" target=\"_blank\">https://tw.news.yahoo.com/嗆川普承諾跳票-拜登竟說試試胸部-133055104.html</a>"},"citedBy":0,"replyTime":"2020-10-12T15:05:35.000Z","msg":"拜登原來係陳克勤議扮架！唔怪得之咁𦧺共啦！"},{"pid":"e231be27afd68e09c856132b95df6ee0a33b81d3","tid":2240283,"uid":54373,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-12T15:05:45.000Z","msg":"驚金主真係比人滅？<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"5cf1ab179768961694931e4ee97a97053138cfef","tid":2240283,"uid":11291,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-12T15:06:51.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2e645693c36dace6c4a510de6a06e8938e81bb42","tid":2240283,"uid":289900,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-10-12T15:06:56.000Z","msg":"得罪講句<br />\n就算投票之前佢中風癱左都贏<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n拜登必勝<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\