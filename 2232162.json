id":"4f4a013edda7b1427a76058eb873ec48b79afbaf","tid":2232162,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-06T12:30:09.000Z","msg":"10月1日當天，內地訪港遊客僅93人次。"},{"pid":"e2397df70ffa9a3a7cd7ecb400dc34e1d8f72ee4","tid":2232162,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-06T15:15:18.000Z","msg":"<img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"6ce008edec94495237ec471dc6bd5a55eda20dcc","tid":2232162,"uid":297045,"like":1,"dislike":0,"score":1,"quote":{"pid":"1f1540e584c04cfbe21b6f89c7e42015e8d39ed7","tid":2232162,"uid":2054,"like":30,"dislike":0,"score":30,"citedBy":1,"replyTime":"2020-10-06T08:08:58.000Z","msg":"原來無左自由行 太照常升起<br />\n股樓繼續暢旺 以後取消左佢啦<img src=\"/assets/faces/pig/dance3.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance3.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-07T00:40:17.000Z","msg":"香港本地零售額上半年跌左 33.3%<br />\n7月跌左23%<br />\n8月跌左13.1%<br />\n可見跌幅少左<br />\n<br />\n而本地香港人私人消費開支第二季跌14.5%<br />\n<br />\n換言之, 依家香港人去唔到海外消費, 跌左九成, <br />\n變左大部份人留港消費"},{"pid":"36480ea564f2ee9bd721b22f327badaddb769449","tid":2232162,"uid":76261,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-07T00:57:57.000Z","msg":"屌仲有成1000人黎播毒<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"15699a6ada9dc505b70d7d00f448cec93a14582f","tid":2232162,"uid":339384,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-07T01:10:51.000Z","msg":"<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},{"pid":"3d0f3fefb2709e80dfb745996cd79e200ebb3613","tid":2232162,"uid":80108,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-07T01:12:57.000Z","msg":"<img src=\"https://na.cx/i/x0Djksg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fx0Djksg.jpg&h=30e81f82&s={SIZE}\" />"},{"pid