2e797d7fcccf6f8577fb4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F20%2F111647_68488cf94be2e797d7fcccf6f8577fb4.jpg&h=e673b2fb&s={SIZE}\" /><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/20/111647_e411b3c3664716442b3cd0f41f194636.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F20%2F111647_e411b3c3664716442b3cd0f41f194636.jpg&h=58368373&s={SIZE}\" /><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/20/111647_50485c8a37c6d5555fe27d0cc409c775.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F20%2F111647_50485c8a37c6d5555fe27d0cc409c775.jpg&h=972ba0cc&s={SIZE}\" /><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/20/111648_800a52c06d2a35b5913852f510ad590b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F20%2F111648_800a52c06d2a35b5913852f510ad590b.jpg&h=162ceb3e&s={SIZE}\" /><br />\n<br />\n有人問我呢度有咩睇？梗係睇塊玻璃反光，睇裙底啦。<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/20/111648_6c1847d454d471914747709a8002495f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F20%2F111648_6c1847d454d471914747709a8002495f.jpg&h=dfdf2dca&s={SIZE}\" />"},{"pid":"a758de29c1598ad79557cf001c6b8b3e5d908f28","tid":707132,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-20T03:31:31.000Z","msg":"上面我又話無諗着去景點，咁又點解嚟青沙浦？<br />\n<br />\n其實係為咗食燒貝殼類海產，之前喺濟州燒過兩次，正到仆街，所以呢次專登過嚟試。<br />\n<br />\n職員識國語，知我係香港人又同我講國語。<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/20/112539_a640dc43ca3d00c02e84ca6e5f712ba9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F20%2F112539_a640dc43ca3d00c02e84ca6e5f712ba9.jpg&h=daeeebe9&s={SIZE}\" /><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/20/112538_aabd7e3c4c191a920247549efa85c79d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F20%2F112538_aabd7e3c4c191a920247549efa85c79d.jpg&h=057679c0&s={SIZE}\" /><br />\n<br />\n呢盤嘢收 30000won<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/20/112538_546a7768df9fb8459df3c10f6d33d38a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F20%2F112538_546a7768df9fb8459df3c10f6d33d38a.jpg&h=c60b88f4&s={SIZE}\" /><br />\n<br />\n講真，真係麻撚麻，我喺濟州食係原隻，隻隻郁，又新鮮又正。<br />\n呢邊隻扇貝係開邊。<br />\n<br />\n佢仲要用嚿疑似煤球燒，好鬼臭。<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/20/112538_785dc0050c2fb4d624f1828fd4d6c6cc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F20%2F112538_785dc0050c2fb4d624f1828fd4d6c6cc.jpg&h=26bcc9b9&s={SIZE}\" /><br />\n<br />\n店鋪內望出去<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/20/112539_b0e29bfef361ceb33f646ad9b21e93dc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F20%2F112539_b0e29bfef361ceb33f646ad9b21e93dc.jpg&h=4a56aeeb&s={SIZE}\" />"}]}