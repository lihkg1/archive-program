ss=\"hkgmoji\" />"},{"pid":"daf8298cfa28f41a9bfdb236eeec2a8014fa5cd2","tid":794653,"uid":185126,"like":5,"dislike":1,"score":4,"citedBy":2,"replyTime":"2018-08-26T14:53:05.000Z","msg":"香港都有人塞春卷乒乓球啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 有幾閒"},{"pid":"ef668975d2e9120da4741d209596dc52d92e0cac","tid":794653,"uid":143241,"like":4,"dislike":3,"score":1,"citedBy":1,"replyTime":"2018-08-26T14:59:18.000Z","msg":"<img src=\"http://imgs.nmplus.hk/wp-content/uploads/2016/02/514.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimgs.nmplus.hk%2Fwp-content%2Fuploads%2F2016%2F02%2F514.jpg&h=98eb7425&s={SIZE}\" />"},{"pid":"03a5fa244bdc56c028cb5e44764671289eac8892","tid":794653,"uid":109462,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-08-26T15:02:24.000Z","msg":"點解塞啲烚蛋入去會腸穿肚爛？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cb161f6999e14997af742065321cecd6b3cb7f53","tid":794653,"uid":37666,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-26T15:03:53.000Z","msg":"基登<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8a2c3bf14922fc3ebdbba0ed433d0d23efc432c4","tid":794653,"uid":109462,"like":41,"dislike":0,"score":41,"quote":{"pid":"7b7fb30362de082f0151ea07f3a1a8442fdce57c","tid":794653,"uid":55384,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-26T14:51:27.000Z","msg":"似想自殺多D<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-08-26T15:04:17.000Z","msg":"翠玉瓜塞肛大出血 老翁稱「古法自殺」<br />\n(明報)2010年3月21日 星期日 05:10 <br />\n<br />\n【明報專訊】青衣長安村昨晚發生一宗聞所未聞的「翠玉瓜插肛」企圖自殺案。一名六旬老翁疑因病厭世，把一整條翠玉瓜由肛門塞進直腸，以致肛門受傷大量出血，幸家人及時發現，報警將他送院搶救，救回一命。<br />\n<br />\n疑因病厭世<br />\n<br />\n尋死老翁姓林，62歲，肛門撕裂受傷，失血近1000毫升，翠玉瓜整條留在直腸內，由救護車送瑪嘉烈醫院動手術搶救，暫未有生命危險。現場消息指出，救護員到場時得悉林翁把翠玉瓜塞入肛門，即問他所為何事，他解釋是「想死」，又說這是「古法自殺」。<br />\n<br />\n整條塞入臥床等死<br />\n<br />\n據悉，林翁與家人同住青衣長安村，疑因病厭世而萌死念。昨晚林翁想出以翠玉瓜從肛門插入身體內自殘的手法尋死，把整條翠玉瓜完全插入肛門，肛門遭撕裂不斷出血，林翁瞞著家人忍痛躺在睡床上「等死」。<br />\n<br />\n及至晚上約10時40分，家人見林翁長時間未有步出房間，思疑下進房查看，赫然發現林翁躺臥在染滿鮮血的床，查問下得悉他竟以翠玉瓜自插肛門尋死，大驚報警。事後警員到場調查，相信事件並無可疑，列作企圖自殺案處理。﻿"},{"pid":"9bae2ea74fd6300e30f6a8d79cff7828d16b9028","tid":794653,"uid":55384,"like":1,"dislike":1,"score":0,"quote":{"pid":"8a2c3bf14922fc3ebdbba0ed433d0d23efc432c4","tid":794653,"uid":109462,"like":41,"dislike":0,"score":41,"quote":{"pid":"7b7fb30362de082f0151ea07f3a1a8442fdce57c","tid":794653,"uid":55384,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-26T14:51:27.000Z","msg":"似想自殺多D<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-08-26T15:04:17.000Z","msg":"翠玉瓜塞肛大出血 老翁稱「古法自殺」<br />\n(明報)2010年3月21日 星期日 05:10 <br />\n<br />\n【明報專訊】青衣長安村昨晚發生一宗聞所未聞的「翠玉瓜插肛」企圖自殺案。一名六旬老翁疑因病厭世，把一整條翠玉瓜由肛門塞進直腸，以致肛門受傷大量出血，幸家人及時發現，報警將他送院搶救，救回一命。<br />\n<br />\n疑因病厭世<br />\n<br />\n尋死老翁姓林，62歲，肛門撕裂受傷，失血近1000毫升，翠玉瓜整條留在直腸內，由救護車送瑪嘉烈醫院動手術搶救，暫未有生命危險。現場消息指出，救護員到場時得悉林翁把翠玉瓜塞入肛門，即問他所為何事，他解釋是「想死」，又說這是「古法自殺」。<br />\n<br />\n整條塞入臥床等死<br />\n<br />\n據悉，林翁與家人同住青衣長安村，疑因病厭世而萌死念。昨晚林翁想出以翠玉瓜從肛門插入身體內自殘的手法尋死，把整條翠玉瓜完全插入肛門，肛門遭撕裂不斷出血，林翁瞞著家人忍痛躺在睡床上「等死」。<br />\n<br />\n及至晚上約10時40分，家人見林翁長時間未有步出房間，思疑下進房查看，赫然發現林翁躺臥在染滿鮮血的床，查問下得悉他竟以翠玉瓜自插肛門尋死，大驚報警。事後警員到場調查，相信事件並無可疑，列作企圖自殺案處理。﻿"},"citedBy":0,"replyTime":"2018-08-26T15:04:57.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"de6fdcf8f91d48ecc54575f87b6e480bbbe3fee0","tid":794653,"uid":186,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-26T15:21:01.000Z","msg":"Hehe"},{"pid":"43e324e5f0980379b22c5720e4584644b4331c9e","tid":794653,"uid":2419,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-26T15:21:51.000Z","msg":"點解要咁做<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2e6f8b7d87e53c733d8a0cb8bc583714a1209701","tid":794653,"uid":51436,"like":24,"dislike":0,"score":24,"citedBy":0,"replyTime":"2018-08-26T15:37:39.000Z","msg":"阿寬，仲有隻雞脾呀，塞埋入去啦"},{"pid":"182