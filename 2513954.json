 src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"d3b5fabba77b5e8b6dd600c6427a80c39520c1b4","tid":2513954,"uid":101481,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-03T03:19:38.000Z","msg":"直接燒左條漁村<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"97f1e5e4373db17315248c121f5c345a68a50af1","tid":2513954,"uid":82938,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-03T03:20:21.000Z","msg":"誰燒了我的村莊"},{"pid":"e8402fd880608fa75ae34f16f3834a6a31fb3da6","tid":2513954,"uid":31215,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2021-05-03T03:20:29.000Z","msg":"人地政府人民授權，啲政策係民主方式制定，咁啲人咪服囉on9"},{"pid":"91b7e9c815a1c83df5c9df433d2d22f8a37299c0","tid":2513954,"uid":21249,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-05-03T03:22:45.000Z","msg":"聖誕快樂 <img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" />"},{"pid":"bfa77c8a46e4a1fbce4dbec39788b14c378ce17a","tid":2513954,"uid":340088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-03T03:27:07.000Z","msg":"燒咗印度佢？<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"9b5e2410aeb9742aef5d226e87b98df93fedaa11","tid":2513954,"uid":51271,"like":4,"dislike":0,"score":4,"quote":{"pid":"0e9f85952243d206c6f5afacc720f8f43e79b55c","tid":2513954,"uid":183649,"like":154,"dislike":0,"score":154,"citedBy":3,"replyTime":"2021-05-03T03:02:42.000Z","msg":"當日點解唔燒左武漢"},"citedBy":0,"replyTime":"2021-05-03T03:27:55.000Z","msg":"燒咗啦，菊花斷市"},{"pid":"f3eb790f4f661a0f24f2d738fee27b1845475e35","tid":2513954,"uid":358035,"like":2,"dislike":0,"score":2,"quote":{"pid":"3407c855eb6c70e87ba6969f15716358084bd7bc","tid":2513954,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2021-05-03T02:49:52.000Z","msg":"有人認為，打不打疫苗應留給個人自行選擇。若政府用行政手段強制人民接種，可視作侵犯人權，港人應齊心合力加以反對。<br />\n<br />\n這種說法，只講理念，不講現實；只能維持政治正確，卻沒法解決現實世界的問題。政府會否強制人民打疫苗，很視乎疫情的嚴重程度與人民對打疫苗的自覺程度。<br />\n<br />\n如果疫情會像SARS那樣自行消失，或人民都能自覺地盡快接種疫苗，那政府自然沒有必要自己出手。但如果疫情發展到像印度那麼嚴重，而人民又不願意主動去接種疫苗的話，那政府就只好強制人民接種，再也顧不到那麼多的個人選擇。<br />\n<br />\n現實是類似的事情早有發生，年前我去南美洲旅行的時候，就被逼要打黃熱病疫苗，否則會申請不到當地的入境許可。沒有人指責當地政府的要求違反人權。<br />\n<br />\n其實，政府的其中一項功能，就是要制訂出一套大家都得遵守的規矩，以便社會上的人可以一齊生活。這些規矩都會在一定的程度上限制了個人的活動空間。為了交通安全，行人不可能不顧交通燈而自己亂過馬路。由此可見，政府是有權按社會的整體需要，而對人民的自由作一定規限的。<br />\n<br />\n以強制隔離為例，難道這沒有損害個人自由？一個人可能自己並無犯錯，只是鄰居受到感染；為安全計，政府只好把所有可能受感染的人一併隔離，在確認他們沒有受感染之後，才放他們自由活動。從人權的角度而言，這樣很難說得過，但很多自由國家，現時都在這樣做。<br />\n<br />\n黑死病肆虐的時候，人們曾恐懼到把受感染的村落封鎖，不許裏面的人出來。有時甚至會出現放火燒村的悲劇。我曾看過一齣荷李活電影，講美國受到一種源自非洲猴子的病毒入侵。這種病毒傳染性極強，死亡率極高，而美國政府卻一時未找到克制辦法，唯有出動軍隊把懷疑受感染的地區封鎖，甚至打算把區內的人，不管是否已受感染都一併殺掉。電影雖是虛構，但亦可反映，人為了對抗疫情，採取的方法可以去到多麼極端。<br />\n<br />\n香港的疫情未算嚴重，但世界仍有很多地方疫情仍未受控。香港是一個沒法自給自足的地方，無法完全與外界隔絕，因此總會反覆受外邊的疫情拖累。如果沿用現有的方法來對付一再在香港出現的疫情，社會的代價會很大。一年兩年還可以「頂硬上」，但長期拖下去，香港就會變成死港，大家都沒有好日過。<br />\n<br />\n如果出現了這樣的情況，而香港仍有相當一部分人不肯接種疫苗的話，不排除政府會立法，強制所有身體狀況適宜打疫苗的人都要接種疫苗，以助香港早日出現群體免疫的效果。我相信，其他自由國家，若果出現類似的情況，亦一樣會這樣做。<br />\n<br />\n<pre><code data-type=\"\">https://www.am730.com .hk/column/新聞/政府會強制人民接種疫苗嗎？- 266245</code></pre>"},"citedBy":0,"replyTime":"2021-05-03T03:33:18.000Z","msg":"條友08年叫人唔好買樓,話樓市會有冰河時期wor"},{"pid":"491bd0fc0f123a0407d16ff3b1b7c932ccc9f5ab","tid":2513954,"uid":156108,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-05-03T03:34:46.000Z","msg":"不如順便燒埋聖誕卡畀你<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"69039124b5edeacfcb3628c7ba1748756ac602ba","tid":2513954,"uid":346701,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-05-03T03:35:08.000Z","msg":"施永青支持於2020年2月核平武漢"},{"pid":"4d2a7a19b80feb67d284e9fc6b19196abc21f409","tid":2513954,"uid":319512,"like":0,"dislike":0,"score":0,"quote":{"pid":"3407c855eb6c70e87ba6969f15716358084bd7bc","tid":2513954,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2021-05-03T02:49:52.000Z","msg":"有人認為，打不打疫苗應留給個人自行選擇。若政府用行政手段強制人民接種，可視作侵犯人權，港人應齊心合力加以反對。<br />\n<br />\n這種說法，只講理念，不講現實；只能維持政治正確，卻沒法解決現實世界的問題。政府會否強制人民打疫苗，很視乎疫情的嚴重程度與人民對打疫苗的自覺程度。<br />\n<br />\n如果疫情會像SARS那樣自行消失，或人民都能自覺地盡快接種疫苗，那政府自然沒有必要自己出手。但如果疫情發展到像印度那麼嚴重，而人民又不願意主動去接種疫苗的話，那政府就只好強制人民接種，再也顧不到那麼多的個人選擇。<br />\n<br />\n現實是類似的事情早有發生，年前我去南美洲旅行的時候，就被逼要打黃熱病疫苗，否則會申請不到當地的入境許可。沒有人指責當地政府的要求違反人權。<br />\n<br />\n其實，政府的其中一項功能，就是要制訂出一套大家都得遵守的規矩，以便社會上的人可以一齊生活。這些規矩都會在一定的程度上限制了個人的活動空間。為了交通安全，行人不可能不顧交通燈而自己亂過馬路。由此可見，政府是有權按社會的整體需要，而對人民的自由作一定規限的。<br />\n<br />\n以強制隔離為例，難道這沒有損害個人自由？一個人可能自己並無犯錯，只是鄰居受到感染；為安全計，政府只好把所有可能受感染的人一併隔離，在確認他們沒有受感染之後，才放他們自由活動。從人權的角度而言，這樣很難說得過，但很多自由國家，現時都在這樣做。<br />\n<br />\n黑死病肆虐的時候，人們曾恐懼到把受感染的村落封鎖，不許裏面的人出來。有時甚至會出現放火燒村的悲劇。我曾看過一齣荷李活電影，講美國受到一種源自非洲猴子的病毒入侵。這種病毒傳染性極強，死亡率極高，而美國政府卻一時未找到克制辦法，唯有出動軍隊把懷疑受感染的地區封鎖，甚至打算把區內的人，不管是否已受感染都一併殺掉。電影雖是虛構，但亦可反映，人為了對抗疫情，採取的方法可以去到多麼極端。<br />\n<br />\n香港的疫情未算嚴重，但世界仍有很多地方疫情仍未受控。香港是一個沒法自給自足的地方，無法完全與外界隔絕，因此總會反覆受外邊的疫情拖累。如果沿用現有的方法來對付一再在香港出現的疫情，社會的代價會很大。一年兩年還可以「頂硬上」，但長期拖下去，香港就會變成死港，大家都沒有好日過。<br />\n<br />\n如果出現了這樣的情況，而香港仍有相當一部分人不肯接種疫苗的話，不排除政府會立法，強制所有身體狀況適宜打疫苗的人都要接種疫苗，以助香港早日出現群體免疫的效果。我相信，其他自由國家，若果出現類似的情況，亦一樣會這樣做。<br />\n<br />\n<pre><code data-type=\"\">https://www.am730.com .hk/column/新聞/政府會強制人民接種疫苗嗎？- 266245</code></pre>"},"citedBy":0,"replyTime":"2021-05-03T03:36:21.000Z","msg":"點解香港會變死港？ <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"d3988a4ae35829179746471b3f15d1d984813175","tid":2513954,"uid":346701,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-05-03T03:38:30.000Z","msg":"施永青是否支持為咗全世界70億人口、全中國14億人口、人類發展偉大復興，武漢一千一百萬人係少數，應當於2020年2月全面封鎖並且用空中投擲凝固汽油彈進行全面消毒？"},{"pid":"43c679646bcdad7045aee15d0ad8e878ff2a20da","tid":2513954,"uid":293943,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-03T03:38:58.000Z","msg":"係咪想玩返鬥地主 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4344facf10f367b9f8c3c7dfd6bd054a5dde3edc","tid":2513954,"uid":364443,"like":6,"dislike":0,"score":6,"quote":{"pid":"f6fa0838d004186e837683bbe1624704c73c380b","tid":2513954,"uid":93784,"like":23,"dislike":0,"score":23,"citedBy":1,"replyTime":"2021-05-03T03:05:34.000Z","msg":"問題係個政府廢呀嘛 又無公信力<br />\n早10幾年前爆武肺既話 我諗大家都會好合作 依家不了<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-05-03T03:39:10.000Z","msg":"exactly 講到尾根本係信任問題<br />\n唔止黃營 連好多所謂中立同藍營都唔信政府"},{"pid":"e6b2e8e1c74c7aabafe28f68143a2555817e41bf","tid":2513954,"uid":256246,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-05-03T03:39:56.000Z","msg":"係咪即係怨當初無一把火燒咗成個武漢？<img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"7e672d339acfa64b4d4628e1e7749cfee6b3e690","tid":2513954,"uid":37196,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-03T03:40:09.000Z","msg":"聖誕快樂施永青"},{"pid":"b901dbc05918b25a69a38d436d6d7f06697571bd","tid":2513954,"uid":278380,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-03T03:40:17.000Z","msg":"咁武漢咪收皮？"},{"pid":"2a8db09f15cc6619be1de25526bc401649b823d9","tid":2513954,"uid":265338,"like":0,"dislike":0,"score":0,"quote":{"pid":"3407c855eb6c70e87ba6969f15716358084bd7bc","tid":2513954,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2021-05-03T02:49:52.000Z","msg":"有人認為，打不打疫苗應留給個人自行選擇。若政府用行政手段強制人民接種，可視作侵犯人權，港人應齊心合力加以反對。<br />\n<br />\n這種說法，只講理念，不講現實；只能維持政治正確，卻沒法解決現實世界的問題。政府會否強制人民打疫苗，很視乎疫情的嚴重程度與人民對打疫苗的自覺程度。<br />\n<br />\n如果疫情會像SARS那樣自行消失，或人民都能自覺地盡快接種疫苗，那政府自然沒有必要自己出手。但如果疫情發展到像印度那麼嚴重，而人民又不願意主動去接種疫苗的話，那政府就只好強制人民接種，再也顧不到那麼多的個人選擇。<br />\n<br />\n現實是類似的事情早有發生，年前我去南美洲旅行的時候，就被逼要打黃熱病疫苗，否則會申請不到當地的入境許可。沒有人指責當地政府的要求違反人權。<br />\n<br />\n其實，政府的其中一項功能，就是要制訂出一套大家都得遵守的規矩，以便社會上的人可以一齊生活。這些規矩都會在一定的程度上限制了個人的活動空間。為了交通安全，行人