{"tid":418410,"cid":5,"subCid":0,"title":"康文署宣佈取消10.1煙花匯演","createTime":"2017-09-29T14:01:21.000Z","updateTime":"2017-10-01T12:25:48.000Z","uid":28366,"like":935,"dislike":56,"uniUserReply":111,"replies":[{"pid":"f2488c0c54f9c493642ce09dd1e5eff3f6622fa4","tid":418410,"uid":28366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-29T14:01:21.000Z","msg":"<img src=\"https://holland.pk/g6al9dit\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fg6al9dit&h=fa59dc1b&s={SIZE}\" /><br />\n【16時36分消息】政府宣佈，10月1日的國慶煙花匯演取消舉行。當局解釋，有鑑於當前的情況，前往各熱點觀賞煙花匯演的交通要道或會持續受到嚴重的影響，基於公共交通安排及市民安全的考慮，故取消原定當日晚上8時在維多利亞港舉行的國慶煙花匯演。&nbsp;"},{"pid":"fc9da27af3e9b10096f8ca90eaebd89396c930cc","tid":418410,"uid":2471,"like":1,"dislike":4,"score":-3,"citedBy":0,"replyTime":"2017-09-29T14:02:12.000Z","msg":"👌🏻"},{"pid":"e37b4ba528ab948a0cc4d8f257679f8a0058f073","tid":418410,"uid":76148,"like":19,"dislike":141,"score":-122,"citedBy":0,"replyTime":"2017-09-29T14:02:15.000Z","msg":"Show Blocked User - 唔震乳"},{"pid":"3a729cab1c3bdb0427f42673099a451af1d7d152","tid":418410,"uid":104256,"like":1,"dislike":6,"score":-5,"citedBy":0,"replyTime":"2017-09-29T14:02:21.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"8370d70bb957b8d2da0c85262162b0f1f793beb1","tid":418410,"uid":38539,"like":4,"dislike":3,"score":1,"citedBy":0,"replyTime":"2017-09-29T14:02:36.000Z","msg":"不安"},{"pid":"dfb1ce979337f4eebda3f742c74d3c67c675fbef","tid":418410,"uid":101945,"like":15,"dislike":2,"score":13,"citedBy":0,"replyTime":"2017-09-29T14:03:09.000Z","msg":"報驚<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"200cb4eafffc82c58b0d16222ec9e15f5fa7caf1","tid":418410,"uid":130247,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-29T14:08:56.000Z","msg":"ok"},{"pid":"f3cd746aaeaca47271e8bb60e00f83a70ca2e1d8","tid":418410,"uid":2203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-29T14:09:59.000Z","msg":"嘩"},{"pid"