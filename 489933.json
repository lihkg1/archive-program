8b9ea5e04c890326b5c1f471f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F05%2F175639_9eb9cd58b9ea5e04c890326b5c1f471f.png&h=1c2c519e&s={SIZE}\" /></blockquote><br />\n所以falcon啱打support做任務多d<br />\nCa3做cap左右手好撚正<br />\n成班一齊出mission<br />\n反而wm火力夠自己其實可以自己打</blockquote><br />\n<br />\n咁又未必，佢唔夠靈活，上到前線如果對住d強小小又有返d頭腦的對手，都未必夠，你睇下佢隊長都唔中被佢拆支棒，佢其實似高達入面的雷射大炮<br />\n<br />\n其實二個都係支援型，一個係擾敵同拎情報，一個係高火力支援</blockquote><br />\n隊長嗰下好撚型<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <br />\n一早睇穿對手想點用體術技剷佢落地<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n同cap近身戰無好下場<br />\n應該離遠飛個飛彈或者開音波攻擊</blockquote><br />\n<br />\n<br />\nWm等於識飛的坦克，根本要有人係前面打，你係唔岩上前<br />\n<br />\nFalcon係有戰鬥力的偵察機"},{"pid":"af964e3af0ba3b24a6d69891df0bb1030a7b489b","tid":489933,"uid":23993,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-05T10:19:08.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><blockquote><blockquote><br />\n<br />\n你咁講wm個心口無左夠收皮啦<br />\n睇下ca3咪證明左囉，降落傘都無</blockquote><br />\n收皮易難度問題</blockquote><br />\nca3唔小心打中 擋都冇得擋</blockquote><br />\n<br />\n但一中到你就玩完<br />\n另一邊好似ca2咁，無左對翼都仲打得，加上ca3加左紅翼同多d槍幫手<br />\n你唔會覺得wm就咁一個人出黎有得同人打呀<br />\n<br />\n所以只可以講各有長短</blockquote><br />\n仲可以射下飛彈<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2017/12/05/175639_9eb9cd58b9ea5e04c890326b5c1f471f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F05%2F175639_9eb9cd58b9ea5e04c890326b5c1f471f.png&h=1c2c519e&s={SIZE}\" /></blockquote><br />\n所以falcon啱打support做任務多d<br />\nCa3做cap左右手好撚正<br />\n成班一齊出mission<br />\n反而wm火力夠自己其實可以自己打</blockquote><br />\nWM要裝返個降落傘先<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n最應該係裝backup battery或者收埋個arc reactor<br />\n佢同im都係arc reactor一爛成副甲就完全變廢鐵<img src=\"/assets/faces/normal/sosad.gif\" 