 src=\"https://fs.mingpao.com/pns/20210325/s00046/f6b34ae2e62aaf639ae88d723603c674.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffs.mingpao.com%2Fpns%2F20210325%2Fs00046%2Ff6b34ae2e62aaf639ae88d723603c674.jpg&h=6782448c&s={SIZE}\" />"},"citedBy":1,"replyTime":"2021-03-26T08:18:36.000Z","msg":"真係好想喺佢哋身上試哂呢堆嘢"},"citedBy":0,"replyTime":"2021-03-26T08:24:06.000Z","msg":"個繼母憎對小朋友我都仲諗到點解<br />\n但係個老豆對自己仔女好似殺父仇人咁真係諗唔明<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"5ab63c10c7473aa89327d81bf72c1f1d35399a03","tid":2462731,"uid":380132,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-26T08:24:21.000Z","msg":"入硬謀殺啦<br />\n完全有預謀同埋長達幾個月既虐待行為<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"21b045b3247318b388d17ec6de17a3a47ac1b0c7","tid":2462731,"uid":24044,"like":0,"dislike":0,"score":0,"quote":{"pid":"de403f42019564ffc085970b756eefa538c631bb","tid":2462731,"uid":155095,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2021-03-26T08:13:12.000Z","msg":"<img src=\"https://fs.mingpao.com/pns/20210325/s00046/f6b34ae2e62aaf639ae88d723603c674.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffs.mingpao.com%2Fpns%2F20210325%2Fs00046%2Ff6b34ae2e62aaf639ae88d723603c674.jpg&h=6782448c&s={SIZE}\" />"},"citedBy":0,"replyTime":"2021-03-26T08:24:37.000Z","msg":"讀得書少唔係藉口，根本係無當佢地係人，另外唔好忘記個<strong><span class=\"red\">老師</span></strong>都係間接既幫兇！"},{"pid":"7eba0142032866a4ea5b35714f55582840a083f6","tid":2462731,"uid":8014,"like":0,"dislike":0,"score":0,"quote":{"pid":"de403f42019564ffc085970b756eefa538c631bb","tid":2462731,"uid":155095,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2021-03-26T08:13:12.000Z","msg":"<img src=\"https://fs.mingpao.com/pns/20210325/s00046/f6b34ae2e62aaf639ae88d723603c674.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffs.mingpao.com%2Fpns%2F20210325%2Fs00046%2Ff6b34ae2e62aaf639ae88d723603c674.jpg&h=6782448c&s={SIZE}\" />"},"cit