O6rLs.png&h=c60efa8d&s={SIZE}\" /><br />\n教完大家咩係足球之後就無贏過了"},{"pid":"b31805c9284b0769fd193f8755848cf1c1e7bb50","tid":1617594,"uid":31314,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T02:49:51.000Z","msg":"11場不勝先係紀錄"},{"pid":"89c1a10c8c1c6fdc792c961c89f0fe162ec79296","tid":1617594,"uid":89037,"like":0,"dislike":0,"score":0,"quote":{"pid":"c83585f3ed494763ea3202d35ccb0d89ba728c4f","tid":1617594,"uid":11254,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2019-10-04T02:48:03.000Z","msg":"<img src=\"https://na.cx/i/pbO6rLs.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpbO6rLs.png&h=c60efa8d&s={SIZE}\" /><br />\n教完大家咩係足球之後就無贏過了"},"citedBy":0,"replyTime":"2019-10-04T02:50:00.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n熱血<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"25d0412a8957a6d83d4131ce30932dbc53be60ed","tid":1617594,"uid":173952,"like":0,"dislike":0,"score":0,"quote":{"pid":"c83585f3ed494763ea3202d35ccb0d89ba728c4f","tid":1617594,"uid":11254,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2019-10-04T02:48:03.000Z","msg":"<img src=\"https://na.cx/i/pbO6rLs.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpbO6rLs.png&h=c60efa8d&s={SIZE}\" /><br />\n教完大家咩係足球之後就無贏過了"},"citedBy":0,"replyTime":"2019-10-04T03:20:24.000Z","msg":"無窮人了"},{"pid":"816440cb615ea946f1d1015dc4dabd15b0233173","tid":1617594,"uid":173952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T03:24:21.000Z","msg":"4.1996年來首次英超客場三連敗。<br />\n<br />\n 5.隊史第五次英超淨輸4球，5年來第一次被6強外打進4球。<br />\n<br />\n 6.38年來首次各條戰線客場5連敗。<br />\n<br />\n 7.各項賽事連續15場未能零封對手，新紀錄？<br />\n<br />\n 8.曼聯隊史首次歐冠淘汰賽兩回合輸4球。<br />\n<br />\n 9.首次聯賽主場出現0：2失績。<br />\n<br />\n 10.9場比賽輸了7場，創58年來最差紀錄。<br />\n<br />\n 11.58年來卡迪夫城第一次在曼聯主場贏球。<br />\n<br />\n 12. 創歷史，英超時代聯賽首負水晶宮。<br />\n<br />\n 13. 4輪5分，曼聯遭1992-93賽季以來最差開局。<br />\n<br />\n 14.30年來首次，曼聯聯賽前7輪積分不上雙。<br />\n<br />\n 15.10場客場不勝！ 曼聯創30年來最差客場戰績 。<br />\n<br />\n 16.尷尬！ 曼聯面對AZ的比賽為隊史歐聯首次 0射正。"},{"pid":"f64ebe8830af6eff84f0824439381e8338ae8497","tid":1617594,"uid":173952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T03:25:27.000Z","msg":"<img src=\"https://i3.hoopchina.com.cn/hupuapp/bbs/951/50722951/thread_50722951_20191004025915_s_2079631_w_375_h_250_21283.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi3.hoopchina.com.cn%2Fhupuapp%2Fbbs%2F951%2F50722951%2Fthread_50722951_20191004025915_s_2079631_w_375_h_250_21283.gif&h=f40ce078&s={SIZE}\" />"},{"pid":"39011b157aafcfe35addb6746121f3ab0193e2e4","tid":1617594,"uid":173952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T03:33:34.000Z","msg":"<img src=\"https://na.cx/i/68crr0H.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F68crr0H.png&h=f93a9463&s={SIZE}\" /><br />\n全場禁區掂過7次波<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"dbe9aef57d296eb5db766593eb29d3fab3be6838","tid":1617594,"uid":173952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T03:46:16.000Z","msg":"曼聯黑衫，欣賞下佢地防守力保不失<br />\n<img src=\"https://n.sinaimg.cn/sports/transform/110/w653h257/20191004/84d8-ifmectm0198861.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fn.sinaimg.cn%2Fsports%2Ftransform%2F110%2Fw653h257%2F20191004%2F84d8-ifmectm0198861.gif&h=bd5c9515&s={SIZE}\" /><br />\n<img src=\"https://n.sinaimg.cn/sports/transform/700/w439h261/20191004/a70b-ifmectm0199390.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fn.sinaimg.cn%2Fsports%2Ftransform%2F700%2Fw439h261%2F20191004%2Fa70b-ifmectm0199390.gif&h=62d7343f&s={SIZE}\" />"},{"pid":"b13e771efe028a8daa74d39b830d5524338ab06c","tid":1617594,"uid":173952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T03:51:21.000Z","msg":"在談到比賽結果時，蘇帥認為一分也可以接受：「我們面對的一支是在作客3-0戰勝飛燕諾的球隊，他們很有實力。而且場地的條件很糟糕，對方更熟悉在人工草皮上踢球，這對我們很不利。<span style=\"color: red;\">但面對這樣一個強敵，我們踢了一場不錯的比賽，拿到一分也是可以接受的。</span>但我們本應該獲勝，因為我們被漏判了一粒12碼。如果我們在主場取勝的話，作客拿1分的結果也不能算太糟。」"},{"pid":"cd32817bedc8bb7378b338f2b072633101a0c7f6","tid":1617594,"uid":173952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T03:57:10.000Z","msg":"蘇帥上任後執教了28場英超，曼聯拿到49個積分，摩連奴在曼聯下台前的28場英超，拿到了51個積分，蘇帥戰績比摩連奴下台時還要糟糕"},{"pid":"d26a4137115d50c548461b8739ac7c2631735bd6","tid":1617594,"uid":173952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T03:59:11.000Z","msg":"15-16賽季，雲高爾的曼聯和如今的蘇帥曼聯狀況很類似，當時紅魔整個賽季只失了35球，這可是那賽季英超最好的防守。然而那支曼聯卻有致命缺陷&mdash;&mdash;進攻奇差，場面極度無聊，最終紅魔無緣英超前四，雲高爾也慘遭解僱。而蘇帥如今的情況遠比雲高爾下台時糟糕，他有何資格繼續執掌曼聯？有意思的是，雲高爾這場歐霸盃比賽親臨現場，看到這樣一支曼聯後，雲高爾足以在蘇斯克查面前昂首挺胸了。"}]}