kg.com/link?u=https%3A%2F%2Fwww.konami.com%2Fwepes%2Fmobile%2Fen%2F&d=W4F44tB2NhBwWjndCc5Bw0wFe44qEnauMGuWilFD6Zg%3D&h=447f44db\" target=\"_blank\">https://www.konami.com/wepes/mobile/en/</a><br />\n● Download Link<br />\nIOS: <a href=\"https://itunes.apple.com/hk/app/pes-2018-pro-evolution-soccer/id1117270703?mt=8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fitunes.apple.com%2Fhk%2Fapp%2Fpes-2018-pro-evolution-soccer%2Fid1117270703%3Fmt%3D8&d=W4F44tB2NhBwWjndCc5Bw0wFe44qEnauMGuWilFD6Zg%3D&h=9e5b91d5\" target=\"_blank\">https://itunes.apple.com/hk/app/pes-2018-pro-evolution-soccer/id1117270703?mt=8</a><br />\nAndroid: <a href=\"https://play.google.com/store/apps/details?id=jp.konami.pesam\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fplay.google.com%2Fstore%2Fapps%2Fdetails%3Fid%3Djp.konami.pesam&d=W4F44tB2NhBwWjndCc5Bw0wFe44qEnauMGuWilFD6Zg%3D&h=dc79849c\" target=\"_blank\">https://play.google.com/store/apps/details?id=jp.konami.pesam</a><br />\n<br />\n● 新手開波Q&amp;A?<br />\n<br />\n1. 洗唔洗刷首抽?<br />\n新手開波既時候會有好多抽，盡量黑波起手，coins留黎抽Fp(精選球員)，唔滿意既可以繼續刷到自己想要既球員為止。<br />\n<br />\n3. 點樣改Email或者密碼?<br />\n<a href=\"https://my.konami.net/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmy.konami.net%2F&d=W4F44tB2NhBwWjndCc5Bw0wFe44qEnauMGuWilFD6Zg%3D&h=57db6d2b\" target=\"_blank\">https://my.konami.net/</a><br />\n<br />\n4. 操控方法<br />\n操控類型有 Advanced 同 Classic 揀<br />\n推薦 Classic 佢類似手制咁樣同埋易上手啲<br />\n<br />\n● 球員資料<br />\nPES DATABASE<br />\n<a href=\"http://pesdb.net/pes2020/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fpesdb.net%2Fpes2020%2F&d=W4F44tB2NhBwWjndCc5Bw0wFe44qEnauMGuWilFD6Zg%3D&h=4649a8be\" target=\"_blank\">http://pesdb.net/pes2020/</a><br />\n要注意由於可能有球員更新，所以DATABASE 入面既100%抽球員可能有誤。<br />\n<br />\n只需要直接search球員名，你就可以搵到該球員特性同數值。<br />\n而想搵一堆某類球員，可以憑Search Conditions自行set Filters 搵出黎。<br />\n<br />\n●畫面調整<br />\n新手入game 第一件事畫質轉60fps<br />\n<img src=\"https://na.cx/i/h38hp4m.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fh38hp4m.jpg&h=66c1328d&s={SIZE}\" /><br />\n但30fps low quality 比較慳電<br />\n<br />\n教練，球員，沒有最強只有更強<br />\n因該每次更新，Konami 都會暗改教練球員走位，唔會通知，要靠老手用過先知<br />\n<br />\n●實時系統<br />\n每周四維護6小時（10am-4pm)後，會按照現實球員表現而調整球員狀態；<br />\n另有巴打 隨時更新球員實際操作表現（暗改），詳情要留意留言<br />\n<br />\n●教練更新<br />\n即日起，可簽入不同版本的同名教練。每日更新3次，已擁有的教練不能再簽下<br />\n<br />\n●拍賣<br />\n根本球員條件（國籍，球會，年歲，能力）買球探組合球員<br />\n詳情：PES DATABASE<br />\n[url]<a href=\"http://pesdb.net/pes2020/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fpesdb.net%2Fpes2020%2F&d=W4F44tB2NhBwWjndCc5Bw0wFe44qEnauMGuWilFD6Zg%3D&h=4649a8be\" target=\"_blank\">http://pesdb.net/pes2020/</a><br />\n<br />\n●遊戲玩法<br />\n<br />\nTour &amp;Tour Sim<br />\n用fp球員既%會高d (分數較高)<br />\n<br />\n最少打2500 points 賺導師(幫球員升lv)<br />\n<br />\ncampaign sim <br />\n<br />\n刷gp 用狀態A/B 銀波+白波bench(升班有23000gp~24000gp)<br />\n<br />\n<br />\n●Matchday<br />\n<br />\nPreset  team<br />\n有coins既matchday 就打夠5500分<br />\n想刷gp可以繼續打 前300名可以參加比賽(抽籤)<br />\n無coins既matchday 打1500分就得 記得觀戰賺gp<br />\n<br />\n<br />\n<br />\n自已球員代表球會出戰<br />\n<br />\n活動分數累積超過4萬分可獲1500coins<br />\n<br />\n<img src=\"https://na.cx/i/BJ0BbT8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBJ0BbT8.jpg&h=44326adc&s={SIZE}\" /><br />\n<br />\n係度search自已個名 查到所代表球會及你打既積分<br />\n<br />\n<a href=\"https://efootballpro.konami.net/open/rankings/season-program/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fefootballpro.konami.net%2Fopen%2Frankings%2Fseason-program%2F&d=W4F44tB2NhBwWjndCc5Bw0wFe44qEnauMGuWilFD6Zg%3D&h=368dccc4\" target=\"_blank\">https://efootballpro.konami.net/open/rankings/season-program/</a><br />\n<br />\n例子<br />\n<img src=\"https://na.cx/i/TtL5PHa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTtL5PHa.jpg&h=bd1f7c11&s={SIZE}\" />"},{"pid":"e39ab5d5c44d6bcd5240c3479bc1f80e754a096e","tid":1915401,"uid":105814,"like":0,"dislike":0,"score":0,"quote":{"pid":"b0858f44fe0a4740ac