1b969669af7dfd2c47e55d66d14e41.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F01%2F23%2F235820_291b969669af7dfd2c47e55d66d14e41.png&h=df059a49&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2019/01/23/235821_51cf6317f7a40935d38758ec0ed12af8.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F01%2F23%2F235821_51cf6317f7a40935d38758ec0ed12af8.png&h=9be81a21&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2019/01/23/235822_a5ad4ff0a1a55a57688073cb105ba690.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F01%2F23%2F235822_a5ad4ff0a1a55a57688073cb105ba690.png&h=0a5e3bd5&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2019/01/23/235822_e6df4a9dfadddaeee616f1ba23460bec.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F01%2F23%2F235822_e6df4a9dfadddaeee616f1ba23460bec.png&h=255e82e5&s={SIZE}\" />"},{"pid":"eeecabc4b4805b1f83ac21aa944c4718bad5c596","tid":992893,"uid":56716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-23T16:00:16.000Z","msg":"黃子菲在2012年1月20日下嫁大律師黃添偉，當時黃子菲19歲，丈夫比她年長約10年。在2016年，黃子菲於個人instagram上承認已和黃添偉離婚，並表示雙方已於2014年分開。"},{"pid":"513ca74075d3d29927fbf8349992391509e7e5a7","tid":992893,"uid":208722,"like":0,"dislike":0,"score":0,"quote":{"pid":"124730e2ac844248ac168396a0df6a926c9a1956","tid":992893,"uid":141782,"like":2,"dislike":0,"score":2,"quote":{"pid":"f5e2e64344485b7715628bb0e8cd362865a43423","tid":992893,"uid":208722,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-23T14:05:28.000Z","msg":"間嘢好普通<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n但枕崎留一晚都唔錯<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-23T15:32:25.000Z","msg":"I have bad news for you<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-23T16:23:02.000Z","msg":"Wait wot"},{"pid":"647422b670d8d68ca52d9255a60148b2960cdb8c","tid":992893,"uid":12254,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-23T16:24:49.000Z","msg":"有冇人可以回一回帶"},{"pid":"26d97eb1a8e27f1c2a600bc4f52de97934933609","tid":992893,"uid":3189,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-23T17:38:12.000Z","msg":"完全唔知佢係邊個<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"a92ef45727fdfcfc458826a51619f0a86e4ef1a6","tid":992893,"uid":93043,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-22T11:21:46.000Z","msg":"此回覆已被刪除"}]}