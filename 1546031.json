est effort，你呢？<br />\nVersion 2019.09.06"},{"pid":"d96f8a002559bbfaf1ef54016f24b0e49fa811f5","tid":1546031,"uid":226959,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:43:57.000Z","msg":"冰島撚留名<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ebdcc2bbc700efee758e053698d6717f2604f7b4","tid":1546031,"uid":50361,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-06T10:46:07.000Z","msg":"I love Mike Pence <img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"b4c70d824c1d99db85188677c37c885794621a0c","tid":1546031,"uid":47169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:47:09.000Z","msg":"你都就落黃泉路啦支那<br />\n仲搞搞震"},{"pid":"0adb2729da50caf9a32d9f66a1aa586c1daefc07","tid":1546031,"uid":265839,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:48:02.000Z","msg":"彭斯<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"afeb5d529634e26bbf2423e8ab6541aca6e1538b","tid":1546031,"uid":44569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:56:01.000Z","msg":"<img src=\"https://i.imgur.com/UrGopnx.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FUrGopnx.png&h=0410e2a3&s={SIZE}\" />"},{"pid":"f65527faebbd4ac4244a01c8c22ebd2bbdfab0eb","tid":1546031,"uid":38982,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:56:28.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" />覺唔覺彭斯好似自護基連"},{"pid":"3f438cde7f9413b44ddef6822a26f5fd1e0d3e36","tid":1546031,"uid":131122,"like":0,"dislike":0,"score":0,"quote":{"pid":"82266e4acd136359a36d22e68abd01cbfffeb05a","tid":1546031,"uid":222834,"like":3,"dislike":0,"score":3,"quote":{"pid":"cab92b1ce5917ec97b2dd6bbf8bf205aee690515","tid":1546031,"uid":9846,"like":28,"dislike":0,"score":28,"quote":{"pid":"cb1652113132cfcfa03113e623aa9afd3b10d88d","tid":1546031,"uid":171450,"like":76,"dislike":0,"score":76,"citedBy":2,"reply