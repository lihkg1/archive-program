90280,"uid":202895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T16:06:06.000Z","msg":"點解推唔到上去<img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"4ef8e207530aa535b24796e51345e6e713b63690","tid":1590280,"uid":202895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T16:08:25.000Z","msg":"[文宣必入]Sharon Hom比左一個極重要抗爭方向大家!!<br />\n<a href=\"https://lih.kg/1588879\" data-auto-link target=\"_blank\">https://lih.kg/1588879</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n入面講到話要寫D<strong><span style=\"color: red;\">有希望嘅故事</span></strong>，或者大家可以從呢個方向發展"},{"pid":"ca7468bcfb83ef71229cf9b8d3ebdb7d36dd7cc0","tid":1590280,"uid":202895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T16:10:57.000Z","msg":"單機mode<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />"},{"pid":"0fc0a51691667686449b9e1755817d9407682557","tid":1590280,"uid":202895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T16:13:53.000Z","msg":"單機mode<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />"},{"pid":"d9ce9729dcd37d317f076c0f34c189cc3a5eb5b9","tid":1590280,"uid":202895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T17:01:54.000Z","msg":"推<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"}]}