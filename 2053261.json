s/lm2/support.gif\" class=\"hkgmoji\" />"},{"pid":"236f3b360e2702caa46439e2da525dc62aa47e51","tid":2053261,"uid":113074,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2020-06-06T06:39:01.000Z","msg":"司徒華叫大家散水<br />\n旺角有300武漢"},{"pid":"388240daf35520c2810de77a2e7c020bb30865e9","tid":2053261,"uid":221035,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-06T06:39:14.000Z","msg":"調酒師工會代表宣讀聲明：<br />\n<br />\n國安法剝奪港人自由，引發撤資和大規模失業<br />\n22工會發動聯合公投，並爲罷工作準備"},{"pid":"bd9d8514e582ca60b6dc72c552bc11815b5f5742","tid":2053261,"uid":63543,"like":7,"dislike":1,"score":6,"citedBy":2,"replyTime":"2020-06-06T06:41:24.000Z","msg":"睇錯做工聯會<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"141cb56f08cc59342da7c3583f411352ca0e7c9b","tid":2053261,"uid":221035,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-06T06:45:08.000Z","msg":"酒店工會代表交代公投計劃：<br />\n<br />\n以公投表達真確民意，工會屬法定組織，比「簽名」更具可信度，透過下以上的民主方式授權罷工行動，建立民意基礎；打破「狼來了」困局，發動真公投、真罷工，呼籲打工仔加入工會參與公投；抵制警方打壓，公投屬工會活動；「仲有方法可以表達」，向國際社會表達香港人訴求<br />\n<br />\n條件1:6萬人參與公投，6成人支持罷工行動<br />\n條件2:各工會自定人數門檻，8成工會達標<br />\n同時達成2個條件，就會啓動聯合罷工計劃<br />\n<br />\n打破「假日抗爭」思維，平日亦是抗爭一部分<br />\n團結打工仔，對抗資方以及政權，實行「全民皆兵」"},{"pid":"f2253e3c9fd4c7e346d322134ef38df8639a252a","tid":2053261,"uid":6562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T06:45:54.000Z","msg":"推"},{"pid":"611e122407adb80ecee150bcec4a4975379792c0","tid":2053261,"uid":119897,"like":2,"dislike":0,"score":2,"quote":{"pid":"141cb56f08cc59342da7c3583f411352ca0e7c9b","tid":2053261,"uid":221035,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-06T06:45:08.000Z","msg":"酒店工會代表交代公投計劃：<br />\n<br />\n以公投表達真確民意，工會屬法定組織，比「簽名」更具可信度，透過下以上的民主方式授權罷工行動，建立民意基礎；打破「狼來了」困局，發動真公投、真罷工，呼籲打工仔加入工會參與公投；抵制警方打壓，公投屬工會活動；「仲有方法可以表達」，向國際社會表達香港人訴求<br />\n<br />\n條件1:6萬人參與公投，6成人支持罷工行動<br />\n條件2:各工會自定人數門檻，8成工會達標<br />\n同時達成2個條件，就會啓動聯合罷工計劃<br />\n<br />\n打破「假日抗爭」思維，平日亦是抗爭一部分<br />\n團結打工仔，對抗資方以及政權，實行「全民皆兵」"},"citedBy":0,"replyTime":"2020-06-06T06:47:16.000Z","msg":"都無工返 緊無罷啦"},{"pid":"5c17151c33b66a3acfee893997611cf1138f1907","tid":2053261,"uid":316329,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-06-06T06:48:22.000Z","msg":"罷還罷<br />\n唔好影響到我就得<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"302b39a0da9680b261e41ec403b039d3f05c3cef","tid":2053261,"uid":105976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T06:48:24.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"dcf7c13cf7b28557e2d48c7b7b7a4a2dfff61da3","tid":2053261,"uid":53003,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-06-06T06:48:37.000Z","msg":"睇錯工聯會罷工<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cb74651160097fdf6361d8a78a9e5c9895d43923","tid":2053261,"uid":221035,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T06:50:02.000Z","msg":"IT工會代表：<br />\n<br />\n6月14日進行公投，時間地點稍後公佈<br />\n第一階段：3日警示式罷工<br />\n第二階段：真。罷工<br />\n截至今早，23工會參與計劃，呼籲理念相同工會可以一同參與<br />\n政治罷工不受法例保障，海量人數就是保護同路人的最大保障<br />\n罷工是團結一致對抗政權的機會"},{"pid":"ff6bdf8a3fc05fe5e5cf4b640be3d5e1177b6707","tid":2053261,"uid":307203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T06:50:05.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"8c952e56b4dc9e7687e6733e62fdffa18b04e8c6","tid":2053261,"uid":222907,"like":3,"dislike":2,"score":1,"citedBy":1,"replyTime":"2020-06-06T06:51:46.000Z","msg":"柒夠未架<br />\n仲搞罷工<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"d0aca1568fe7c0c959f0bd3cad4419bb79dc34c4","tid":2053261,"uid":77628,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T06:52:21.000Z","msg":"<a href=\"https://www.facebook.com/loy.diary/videos/242037457090899/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Floy.diary%2Fvideos%2F242037457090899%2F&d=bCxsXTpKmrqj5N4FYztdxz%2BdFj26OgxneTHruUJDv9o%3D&h=77b6e56f\" data-auto-link target=\"_blank\">https://www.facebook.com/loy.diary/videos/242037457090899/</a>"},{"pid":"05e689660268a496f8fc6c01b3d95274b74c3826","tid":2053261,"uid":15984,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T06:53:40.000Z","msg":"<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"bfa5ea00e782bcc281ba8b0e97cf616126a33e49","tid":2053261,"uid":160373,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T06:55:34.000Z","msg":"TUI"},{"pid":"2cfac6f56170e5e31ae40c2bd45c3371ecd7f2a5","tid":2053261,"uid":268519,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T06:57:51.000Z","msg":"推"},{"pid":"627671ee79c716a69eafca765dfcfe207d858398","tid":2053261,"uid":221035,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-06T07:04:13.000Z","msg":"職工盟總幹事吳敏兒：<br />\n<br />\n職工盟支持公投，希望更多工會加入<br />\n香港進入全民反抗，國安法陰霾已經揮之不去<br />\n香港人「唔係淨係識返工放工」，「我哋唔會被代表」，透過真工會發聲<br />\n各界打工仔應團結加入工會並參與公投，退縮才是令香港玩完<br />\n中學生組織響應行動，會發起罷課公投"},{"pid":"9a6eecc11bae8e0f30b27b31766e87a238ce627f","tid":2053261,"uid":221035,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T07:04:32.000Z","msg":"&mdash;&mdash;&mdash;&mdash;Q&amp;A&mdash;&mdash;&mdash;&mdash;<br />\n問：現時工會人數幾多？6萬人死線係幾時？<br />\n答：23工會人數近1萬，死線是公投當日。第一階段屬警示式罷工，可用各種方式自行參與，第二階段才是真罷工"},{"pid":"a4c4b8f2229ae9b976a9b3842f368e423de3fca5","tid":2053261,"uid":221035,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T07:04:43.000Z","msg":"問：會員只有1萬，但目標係6萬，有無信心？門檻點定？罷工有無保障？<br />\n答：要全民團結參與，6成贊成有認受性，各行業門檻由各工會自行釐定。強調政治罷工法例無保障，人數越多保障越大。所謂「法律保障」值得思考，極權只是用各種方式打壓抗爭者，支持政府的人做咩都無事，真正的保障係團結和共同參與"},{"pid":"5fbfcf52a5c03cab959bee1ed03e69e1aaad8d12","tid":2053261,"uid":232077,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c952e56b4dc9e7687e6733e62fdffa18b04e8c6","tid":2053261,"uid":222907,"like":3,"dislike":2,"score":1,"citedBy":1,"replyTime":"2020-06-06T06:51:46.000Z","msg":"柒夠未架<br />\n仲搞罷工<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-06T07:05:51.000Z","msg":"醫護搞罷工都係一個禮拜就收左皮<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"f54c4f573a18eb4000d43d6e9c4dd325ed1275f8","tid":2053261,"uid":78470,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T07:05:54.000Z","msg":"說服到班訴求就係返工既港豬先啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5768ac6132654cc4b6560dd08c9f515ce8210665","tid":2053261,"uid":95138,"like":0,"dislike":0,"score":0,"quote":{"pid":"c123a4d9e86f34886df452916aa8feaf41f7a07e","tid":2053261,"uid":8014,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-06-06T06:32:47.000Z","msg":"個tg 好似十萬人都無<br />\n<br />\n點200萬人三罷"},"citedBy":0,"replyTime":"2020-06-06T07:06:59.000Z","msg":"用把口罷"},{"pid":"e3f11456beeac2867f673e02f04da78331ad9c37","tid":2053261,"uid":20558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T07:08:08.000Z","msg":"推"},{"pid":"7e5b2efc901da6d4cc21ea4c267537beb19afa38","tid":2053261,"uid":268519,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T07:08:58.000Z","msg":"要兩邊睇 同17區撞到正一正"},{"pid":"94b1455349a5dfb631accdcade1fc67de65e02ed","tid":2053261,"uid":34410,"like":0