faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 加埋成百幾歲<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"64f618522f8987d60f87b7a55b4868e2f463ffb5","tid":1158273,"uid":211579,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-17T03:31:46.000Z","msg":"住得老人院都同是天涯淪落人啦，仲嘈乜春呀廢老"},{"pid":"0d9fa9926766ae30dd901d736406cdc878282783","tid":1158273,"uid":130901,"like":0,"dislike":0,"score":0,"quote":{"pid":"64f618522f8987d60f87b7a55b4868e2f463ffb5","tid":1158273,"uid":211579,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-17T03:31:46.000Z","msg":"住得老人院都同是天涯淪落人啦，仲嘈乜春呀廢老"},"citedBy":0,"replyTime":"2019-05-17T03:38:26.000Z","msg":"有d廢老好鬼固執"},{"pid":"9c3309f13e210947f3ec98b5b2803ec952d70483","tid":1158273,"uid":59283,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-17T03:47:18.000Z","msg":"建制派-1票"},{"pid":"4337fb1a9162cc3d7d8f3d822ae6f85283281d03","tid":1158273,"uid":3090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-17T07:52:07.000Z","msg":"【13:38】警方今日暫控該名89歲老婦一項誤殺罪。案件將於明日（18日）在觀塘裁判法院提堂。<br />\n【11:37】有相信是社署職員到老人院調查。<br />\n【17/5 09:26】有院友形容，涉用拖鞋打死者的婆婆出名「惡死」，與其他院友關係亦欠佳，當時曾見有人用拖鞋拍打死者頭部。院舍女職員則表示負責人未返，着傳媒「你哋問警察啦！」"}]}