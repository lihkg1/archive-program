 />\nFC唔係唔做 但唔係靠依到推post就做到<br />\n我地仲有好多好多更重要既野要做"},{"pid":"c893ceb5ce29b9b75e6d3b678767100b9b962652","tid":1529702,"uid":43322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T19:57:59.000Z","msg":"全港三罷<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"5b99dadc3776aa5a1a735e240092ae74eb871193","tid":1529702,"uid":43322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T19:59:21.000Z","msg":"全港三罷<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"80a8cfa6c46ab7c3c057beb4fbb651d53723d862","tid":1529702,"uid":43322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T20:00:26.000Z","msg":"全港三罷<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"802a66e868a10da913b91eff3a35f74b10b0e1fe","tid":1529702,"uid":43322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T20:01:46.000Z","msg":"全港三罷<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"4185f6e8d33cbff59b1414cd15b6a95225669848","tid":1529702,"uid":43322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T20:03:55.000Z","msg":"全港三罷<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"98897ef9c5aecb6a717a6f0b3822470310122a3d","tid":1529702,"uid":127929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T20:04:30.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"cfb272950d4340464a7b5aca8d4bf9ef7518d688","tid":1529702,"uid":147345,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T20:05:13.000Z","msg":"推"},{"pid":"d959696c5293b6ed74b285e48d67fdb1eba9715c","tid":1529702,"uid":127929,"like":0,"dislike":0,"score":0,"quote":{"pid":"4b3e51e6c0131aa1690703ded6029176c59885ba","tid":1529702,"uid":43322,"like":0,"dislike":0,"score":0,"quote":{"pid":"e3dede15ac1b7d9e59ae90a9dc710b62e8ce9f34","tid":1529702,"uid":127929,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-01T19: