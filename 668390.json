e":{"pid":"3b374a425a2ab5458d5d2d90c08c9945587e4d36","tid":668390,"uid":83582,"like":17,"dislike":1,"score":16,"citedBy":1,"replyTime":"2018-05-17T16:22:47.000Z","msg":"<img src=\"http://usingapple.com/wp-content/uploads/2011/06/Organizational-Chart-for-Apple-Amazon-Facebook-Google-Microsoft-and-Oracle.jpg?189db0\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fusingapple.com%2Fwp-content%2Fuploads%2F2011%2F06%2FOrganizational-Chart-for-Apple-Amazon-Facebook-Google-Microsoft-and-Oracle.jpg%3F189db0&h=a60ea4fa&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-05-17T18:03:17.000Z","msg":"入黎就係為左睇呢幅圖<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"326e66fc15d13efdae45fb348a2cf445568db659","tid":668390,"uid":100943,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-17T19:26:32.000Z","msg":"Oracle license 好難計<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"937374c82c715b556654807772e3b65999ebdca8","tid":668390,"uid":105366,"like":1,"dislike":0,"score":1,"quote":{"pid":"6c038a77cf84353e1af3ec2f2552f2ee39743fcc","tid":668390,"uid":67500,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-17T15:41:51.000Z","msg":"期望wp 翻身"},"citedBy":0,"replyTime":"2018-05-17T19:34:49.000Z","msg":"難過期望香港翻身"},{"pid":"feae23c766df7d5316efe6e2c0a65aaba766225c","tid":668390,"uid":75193,"like":2,"dislike":2,"score":0,"citedBy":0,"replyTime":"2018-05-17T20:50:40.000Z","msg":"係咪location history 果d.<br />\n呢樣真係抵告 仆街又食電又食data<br />\n仲廿四小時畀人跟蹤咁<br />\n<br />\n雖然可以自己熄 但google成日鬼鬼祟崇引你開"}]}