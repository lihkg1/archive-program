\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"0ff482d402d86dc1b8fe9f8ed66fd2c89e97dd88","tid":828450,"uid":92690,"like":2,"dislike":0,"score":2,"quote":{"pid":"db4df6a59dbbc68455f9821b7377cd1aa75f6558","tid":828450,"uid":181685,"like":0,"dislike":8,"score":-8,"quote":{"pid":"700616c95ad346074a244b96df837419f0b24973","tid":828450,"uid":92690,"like":2,"dislike":4,"score":-2,"citedBy":2,"replyTime":"2018-09-19T16:41:41.000Z","msg":"要用松節水"},"citedBy":1,"replyTime":"2018-09-19T16:49:48.000Z","msg":"松節水都比你諗到<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 睇黎小弟學藝未精"},"citedBy":0,"replyTime":"2018-09-19T22:18:50.000Z","msg":"你直頭唔入流<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"6cd1b3c62382cfc9ebc1eee0cf60b83a16468b4f","tid":828450,"uid":64318,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-19T22:20:33.000Z","msg":"乜鳩都痴"},{"pid":"335b8349838e8a888a9edee45e16db7001239f0a","tid":828450,"uid":186177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-19T22:23:30.000Z","msg":"白電油/綠色蓋果罐啦"},{"pid":"e417b4016968aa866097c3894c5ce9755b32d596","tid":828450,"uid":152612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T01:25:03.000Z","msg":"用擦膠～"},{"pid":"2d113e03ee19cc0cdc073f2284b8d347d08786bf","tid":828450,"uid":52148,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T02:40:08.000Z","msg":"下次用皺紋膠紙啦,打完風兩日內好撕啦"},{"pid":"77f384b0d898a9938406dd7c0c37a1f5d51a64d4","tid":828450,"uid":60299,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-20T05:54:16.000Z","msg":"此回覆已被刪除"},{"pid":"28eac013022c02b37034fb52b8135c09ab193db2","tid":828450,"uid":43678,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-09-20T05:58:14.000Z","msg":"噴完Wd40攤十分鐘先清<br />\n易好多<br />\n想問下用完wd40，用酒精再擦，再過幾次水，<br />\n塊玻璃都好似好油，可以點解決"},{"pid":"d5b54148143ec7174eb269e5c59695bcab225e13","tid":828450,"uid":63154,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T06:14:27.000Z","msg":"呢隻最難清<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a278458a1e13502c604d6c35c8599489ffa3835c","tid":828450,"uid":49215,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T06:41:33.000Z","msg":"用開火水清 浸十零秒一抺就甩"},{"pid":"988e1f7f6f4c9834fe1eb9620af303dbbc00e30f","tid":828450,"uid":26487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T09:44:07.000Z","msg":"搵電油抹一抹就甩 <br />\n<br />\n利申：做木工"},{"pid":"751727259c49a8d7847c59cf2ca7fe3e9dda5a04","tid":828450,"uid":67500,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-20T09:48:25.000Z","msg":"咁快搣做乜，留返下年打風"},{"pid":"b87eec068afebc5712c0406132de07109c2bda85","tid":828450,"uid":58863,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T11:12:25.000Z","msg":"WD-40 點去漬??"},{"pid":"3f9fda113ee18c0c738cbc79909218ed9d93ac69","tid":828450,"uid":52215,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T11:17:37.000Z","msg":"WD40 用過，堅得"},{"pid":"02d68f7b68fc6ef639eb679dc1b3f8f5d90be65a","tid":828450,"uid":141359,"like":0,"dislike":0,"score":0,"quote":{"pid":"7836e83d6abb54a00289a1f35adbeadddd8bf717","tid":828450,"uid":82183,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-09-19T16:33:35.000Z","msg":"上網揾過，主要有幾個方法:<br />\n1) 黏膠去除劑(eg: 3M /  保賜利（Botny）)<br />\n2) WD40<br />\n3) 松節水<br />\n4) 風筒加熱<br />\n5) 75%/95% 酒精<br />\n<br />\n<br />\n我個人試過風筒同埋75%酒精，唔多得，聽日會試黏膠去除劑，<br />\n有冇人有經驗可以推介下邊個牌子?<br />\n<br />\n<br />\nPS: 提提未撕膠紙嘅巴絲，愈遲撕就愈難清，避免陽光直射玻璃窗上令膠紙受熱而膠質溶解"},"citedBy":0,"replyTime":"2018-09-20T11:47:26.000Z","msg":"試下用 橙皮<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"dd06e89faef2d4acee0a5cb576b7b81b8edca9d0","tid":828450,"uid":9838,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T11:57:11.000Z","msg":"天拿水啦<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"15c760fd81835a1d839cc13e7f6118b89899e5a6","tid":828450,"uid":9838,"like":0,"dislike":0,"score":0,"quote":{"pid":"28eac013022c02b37034fb52b8135c09ab193db2","tid":828450,"uid":43678,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-09-20T05:58:14.000Z","msg":"噴完Wd40攤十分鐘先清<br />\n易好多<br />\n想問下用完wd40，用酒精再擦，再過幾次水，<br />\n塊玻璃都好似好油，可以點解決"},"citedBy":0,"replyTime":"2018-09-20T11:59:54.000Z","msg":"由佢"},{"pid":"4088185e0a552350c40a4034be246baef7f77ce2","tid":828450,"uid":28361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T12:00:31.000Z","msg":"認真答你<br />\n用牛皮膠紙癡返出嚟就得"},{"pid":"d8160910c79ceda449c2c105d2ee7385c456c84f","tid":828450,"uid":294,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T12:00:33.000Z","msg":"日本城咪有"},{"pid":"2802aeb039a5b3e6a0b3ded11939329173e27aa6","tid":828450,"uid":62837,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T12:01:39.000Z","msg":"Wd40 百潔布"},{"pid":"7a299d58707ed2f49a2b34f7e3efb05f97f565ee","tid":828450,"uid":106,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T12:03:54.000Z","msg":"橙皮水輕鬆搞掂"},{"pid":"ea11bfbf12fc0c3db36de56850bf1d9ba5a1fd9e","tid":828450,"uid":98232,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T13:01:16.000Z","msg":"你地全部收皮<br />\n亞斯通 一滴已經可以溶穿20mm厚發泡膠<br />\n去膠漬一流"},{"pid":"69246ac26b22ca8c8c05a651bf49a8c331b17180","tid":828450,"uid":4917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T13:10:59.000Z","msg":"尋日終於搣完<br />\n原來牛皮膠紙好多層，你噴嘢上去，佢表面嗰層濕，膠水位都係乾嘅，要響個邊一路手搣一路噴先得<br />\n<br />\n3M嗰隻唔知點解痴立立，隻手整到，掂乜都痴"},{"pid":"e4a53da3187af6429f2c96a1a9d942b4eca22815","tid":828450,"uid":82183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T15:50:09.000Z","msg":"今日用WD 40，噴完用百潔布卒幾卒就溶哂<br />\n<br />\n之後因為WD 40係油性溶劑，屋企一定有嘅洗潔精就已經可以清咗WD 40果種油到仆街嘅感覺<br />\n過兩次洗潔精，再過水/直接用tissue就得<br />\n<br />\n有其他去油嘅強力清潔劑都得，睇你屋企有邊D"},{"pid":"1a2200ab5756a6efe28c115befb898ac6230771e","tid":828450,"uid":82183,"like":0,"dislike":0,"score":0,"quote":{"pid":"28eac013022c02b37034fb52b8135c09ab193db2","tid":828450,"uid":43678,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-09-20T05:58:14.000Z","msg":"噴完Wd40攤十分鐘先清<br />\n易好多<br />\n想問下用完wd40，用酒精再擦，再過幾次水，<br />\n塊玻璃都好似好油，可以點解決"},"citedBy":0,"replyTime":"2018-09-20T16:09:45.000Z","msg":"可以睇我上一個回覆<br />\n<br />\n係度再講多少少，因為酒精同WD40嘅主要成分Stoddard solvent 極性唔同，所以酒精對WD40黎講係無咩清潔作用<br />\n<br />\n要清WD40，最易有嘅就係普通洗潔精，<br />\n但最好用就係丙酮 Acetone，因為用佢洗完玻璃之後，佢會因為超高揮發性而自行消失，水都唔洗過"},{"pid":"a600dc20b847898bb88198fb26e36f28354cde90","tid":828450,"uid":82183,"like":0,"dislike":0,"score":0,"quote":{"pid":"77f384b0d898a9938406dd7c0c37a1f5d51a64d4","tid":828450,"uid":60299,"like":1,"dislike":0,"score":1,"quote":{"pid":"0fb2afe8460222b065e2227fd97951407917b796","tid":828450,"uid":50801,"like":0,"dislike":0,"score":0,"quote":{"pid":"aafaf6b35baa7a828f1b4c014e9c05420b9be995","tid":828450,"uid":82183,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-19T18:12:47.000Z","msg":"我打算2種一齊用，反正刀片都唔貴<br />\n就係驚會整花D玻璃窗<br />\n<br />\n以巴打嘅經驗黎講，會唔會好易整花?"},"citedBy":1,"replyTime":"2018-09-19T18:18:50.000Z","msg":"落得刀就有機會整花，怕花就用溶劑算啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-20T05:54:16.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-09-20T16:17:41.000Z","msg":"今日成功咗，就係用刀鋒鏟起小小，之後用手撕<br />\n唔知係唔係噴咗少少WD40嘅關係，好易撕<br />\n雖然都有少少膠漬，不過再用WD40-&gt;洗潔精-&gt;水 就清完<br />\n多謝你"},{"pid":"dff44907326e9eda6603d85197a044940d68508d","tid":828450,"uid":82183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-20T16:25:26.000Z","msg":"最後結論: 雖然WD40 好成功O禁去哂D膠漬，不過如果有下次，我會用白電油/松節油黎試<br />\n<br />\n因為WD40 其實好油，用完之後嘅事後清理有D麻煩<br />\n<br />\n白電油/松節油嘅揮發性好D，應該易D清理<br />\n<br />\nANYWAY，多謝所有巴絲嘅意見同埋幫助"},{"pid":"d9de57bf8d125ef85566837b5197f54f00133564","tid":828450,"uid":27568,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-21T00:40:29.000Z","msg":"仆街我仲未搣..."},{"pid":"7deda0ebf23c995592231f7eb152f0092eefe3a1","tid":828450,"uid":165012,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-21T01:01:17.000Z","msg":"擦膠"},{"pid":"2cf01bea02e5f3fe3e166b2541dc423281cb46f8","tid":828450,"uid":177736,"like":0,"dislike":0,"score":0,"quote":{"pid":"700616c95ad346074a244b96df837419f0b24973","tid":828450,"uid":92690,"like":2,"dislike":4,"score":-2,"citedBy":2,"replyTime":"2018-09-19T16:41:41.000Z","msg":"要用松節水"},"citedBy":1,"replyTime":"2018-09-21T01:12:23.000Z","msg":"好撚大陣味<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"fca2eb50851b1229b7ead422ce709d902dbc938d","tid":828450,"uid":177736,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-21T01:13:21.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/09/21/091317_8e1e79fb7cb9f8c11f00a1c95038512b.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F21%2F091317_8e1e79fb7cb9f8c11f00a1c95038512b.png&h=4c7b6f30&s={SIZE}\" />"},{"pid":"628ab21c28caba185ef2e9efbeaee51eac2eeeaa","tid":828450,"uid":99607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-21T01:21:49.000Z","msg":"留返下次用"},{"pid":"43e079db7a1f8661f302f81d2eb05b045bd3ce0d","tid":828450,"uid":22692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-21T01:22:18.000Z","msg":"白電油"},{"pid":"efa5c6689ebeaa5955082a1b4a81d67cb5f09bb6","tid":828450,"uid":9230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-21T01:22:56.000Z","msg":"火機用白電油"},{"pid":"6f6f543818498a49e941ab8e32ecd77001194491","tid":828450,"uid":92690,"like":0,"dislike":0,"score":0,"quote":{"pid":"2cf01bea02e5f3fe3e166b2541dc423281cb46f8","tid":828450,"uid":177736,"like":0,"dislike":0,"score":0,"quote":{"pid":"700616c95ad346074a244b96df837419f0b24973","tid":828450,"uid":92690,"like":2,"dislike":4,"score":-2,"citedBy":2,"replyTime":"2018-09-19T16:41:41.000Z","msg":"要用松節水"},"citedBy":1,"replyTime":"2018-09-21T01:12:23.000Z","msg":"好撚大陣味<img src=\"/assets/faces/normal/dead.gif\" class=