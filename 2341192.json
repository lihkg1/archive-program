pid":"f0aef296d1423e0a48e30f17a1ac09a44bf5d95c","tid":2341192,"uid":33730,"like":1,"dislike":0,"score":1,"quote":{"pid":"1cf7ced259c3b65e6e97487e33d82fe15cdcde50","tid":2341192,"uid":33730,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-27T18:24:24.000Z","msg":"前面幾隊都係一兩場波距離, 仲有啲補賽未踢"},"citedBy":1,"replyTime":"2020-12-27T18:24:50.000Z","msg":"回錯, SOR<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-28T00:05:45.000Z","msg":"推"},{"pid":"636bf4b3ca70818b63304c2188bf65d6c4874675","tid":2341192,"uid":49316,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-01-14T03:14:05.000Z","msg":"仲有下文<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n中國游族網絡創辦人林奇遭毒死 逾百億遺產爆私生子爭奪戰<br />\n<br />\n〔即時新聞／綜合報導〕中國遊戲巨頭游族網絡創辦人林奇在去年12月疑遭中慢性毒死亡，遺留約30億人民幣（下同，約126億元台幣）財產，由其3名未成年子女繼承，本月11日公司公告，公司實控人變更為孩子的母親許芬芬，但是，12日即引爆一場「爭產風暴」登場，微博上流傳林奇「私生子」姨媽在po出其出生證明，宣告已請律師起草訴狀，將爭取孩子的合法繼承權<br />\n<br />\n<a href=\"https://ec.ltn.com.tw/article/breakingnews/3410440\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fec.ltn.com.tw%2Farticle%2Fbreakingnews%2F3410440&d=gNEzxY0d91fOO8mfTbt%2FUiukga04qSQtFIF%2FU0RrEoA%3D&h=060ac55e\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fec.ltn.com.tw%2Farticle%2Fbreakingnews%2F3410440&h=41f7d326\" data-auto-link target=\"_blank\">https://ec.ltn.com.tw/article/breakingnews/3410440</a>"},{"pid":"b2318ae0997ab277cba5be9c24ec52db4adc303b","tid":2341192,"uid":136311,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-14T03:15:35.000Z","msg":"宮鬥劇情<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7906e78f95d22c75cac3d7e312d7a0cf6b3acc8d","tid":2341192,"uid":7903,"like":0,"dislike":0,"score":0,"quote":{"pid":"636bf4b3ca70818b63304c2188bf65d6c4874675","tid":2341192,"uid":49316,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-01-14T03:14:05.000Z","msg":"仲有下文<img src=\"/assets/faces/normal/sosad.gif\" cla