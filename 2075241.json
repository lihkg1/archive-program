":"f567754658b36e836817140719552b88d77c40f6","tid":2075241,"uid":67116,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-23T03:10:37.000Z","msg":"叫兩聲支持國安法 沒事 沒事兒"},{"pid":"fb07d6b068ea01b885fca05e5418637aae4b22ad","tid":2075241,"uid":71323,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-23T03:59:52.000Z","msg":"呢間學校就係之前個副校長喺自己fb鬧過黑警跟住俾人炒咗<br />\n<br />\n孔聖堂中學：終止其副校長一職<br />\n<a href=\"https://lih.kg/1898485\" data-auto-link target=\"_blank\">https://lih.kg/1898485</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"5076bd05b76d49e8b2435c2775631cd70c023b3a","tid":2075241,"uid":78304,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-23T04:32:33.000Z","msg":"快啲登報支持国安法<br />\n犯過咩罪都可以赦免"}]}