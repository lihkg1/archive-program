/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dd6e3e513f787aba70764b2de44e07e4374f2e46","tid":2207123,"uid":21545,"like":0,"dislike":0,"score":0,"quote":{"pid":"47106517e570fcc4b515b662d6b8dba307ddab17","tid":2207123,"uid":53498,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-09-18T03:27:05.000Z","msg":"想超越蘇文隆郭偉健"},"citedBy":0,"replyTime":"2020-09-18T03:28:15.000Z","msg":"鄭紀航隻腳膠先係<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"61b769bf1218a1d26e60401e5ee545264ebe3232","tid":2207123,"uid":82938,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T03:29:01.000Z","msg":"錦化咪算係咁<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"aa0b44e69a77f681e21bd0e9ed1c09da4e58557c","tid":2207123,"uid":150610,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T03:31:14.000Z","msg":"<img src=\"/assets/faces/cat/unwell.gif\" class=\"hkgmoji\" />"},{"pid":"4dc9654773b994d355ec82992865515cd0014cee","tid":2207123,"uid":268153,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T03:37:37.000Z","msg":"<img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" />"},{"pid":"3dfff8bc56c353d091b20c4816af8b32c903e7b1","tid":2207123,"uid":325011,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T03:38:49.000Z","msg":"香港真系玩L完<img src=\"/assets/faces/cat/sneeze.gif\" class=\"hkgmoji\" />"},{"pid":"5b93c302d2b9af8bdd9626444205af6e02f27a80","tid":2207123,"uid":49329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T03:40:39.000Z","msg":"希望有日佢俾毅進仔打"},{"pid":"cd30a59f3100037211265e4fed27f07d20cb6630","tid":2207123,"uid":14941,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-09-18T03:41:42.000Z","msg":"以後鬧警察一野<br />\n可以俾打到殘廢了"},{"pid":"b3142cf06baff1a391e8eda40223d4d672543063","tid":2207123,"uid":335967,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T03:42:27.000Z","msg":"紅官<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"4df4582983a24109213fc40b93e5864c36ae628c","tid":2207123,"uid":54516,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T03:45:11.000Z","msg":"呢個係國安法指定法官"},{"pid":"12268f6abd6d5039fdebf4a94143e3002342efbc","tid":2207123,"uid":331590,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T03:47:14.000Z","msg":"佢係2018年後變藍??????<br />\n星島日報2018年5月18日 下午5:32<br />\n【星島日報報道】長沙灣鄰舍輔導會怡菁山莊一名年輕男職員於去年11月虐打智障院友，拳打腳踢其頭部、箍頸、將院友推向牆、地面和椅子並困於「玩具隧道」等。院方調查漏水事件而查看閉路電視片段意外揭發此案並報警處理。被告早前承認一項襲擊致造成身體傷害罪，稱因多年累積的工作壓力大而失控犯案，現已深感懊悔，更曾有輕生的念頭。案件今於西九龍裁判法院被判80小時社會服務令，<span class=\"red\">嚴舜儀署理主任裁判官用心說教地稱「做人一定遇到好多唔同問題，唔好隨便話要輕生，要好好規劃人生，唔好辜負自己屋企人嘅期望」。</span>"},{"pid":"101ad37a7c35ec083fba3ce248568ea01622c5b8","tid":2207123,"uid":331590,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T03:53:28.000Z","msg":"(China Daily HK Edition)<br />\nUpdated: 2006-12-25 09:41<br />\nThe District Court yesterday sentenced a new mainland immigrant to 21 months in prison for biting and breaking a thumb of a fellow bus passenger.<br />\n<br />\nHanding down the sentence, <span class=\"red\">deputy judge Ada Yim Shun-yee said the 35-year-old Wu Peng, a master's degree holder in economics, hadn't shown any remorse and still thought that biting the person's thumb was his only option.</span><br />\n<br />\n佢之前D JUDE好正常"},{"pid":"019f4ce22ca7e7f7c6aabae82492776dabd0c0ed","tid":2207123,"uid":99695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T05:07:31.000Z","msg":"狗官"},{"pid":"444c5d7b18b0cb6be3c258d0755d354c9d580abc","tid":2207123,"uid":43062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T05:09:06.000Z","msg":"狗官成日推測到人地點犯罪，點解推測唔到警察打人？"},{"pid":"547bbc1cc03dcba4f186492dbbc5b31a6e32c596","tid":2207123,"uid":124410,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-18T05:10:06.000Z","msg":"成班藍官真係無人性<br />\n但港共就係鍾意呢班官"}]}