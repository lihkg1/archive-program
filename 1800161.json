"dfde2a299a75f85ab11717a39e40f5b3ac2c8dc3","tid":1800161,"uid":31151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-27T14:18:57.000Z","msg":"郭榮鏗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"3e7ab1ab8ad1187490b8f7c1796b4ed10e6b36a0","tid":1800161,"uid":27764,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-27T14:21:14.000Z","msg":"屌隔離個po仲有人推緊<img src=\"/assets/faces/pigxm/arrested.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/arrested.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/arrested.gif\" class=\"hkgmoji\" />"},{"pid":"437be2fd607d9f3dcad359f5d9907f292e36cf83","tid":1800161,"uid":27764,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-27T14:23:00.000Z","msg":"推"},{"pid":"ead7b6f7d53c721282260b426eccd7382b16690d","tid":1800161,"uid":27764,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-27T14:25:36.000Z","msg":"推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"8f007deb91b1f1f812b9df454778214adbdd5a46","tid":1800161,"uid":11013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-27T14:26:19.000Z","msg":"幫推 <br />\n<br />\n唔好意思 謝一謝位<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n和理非 手足 家長 學生都請入黎 <br />\n<br />\ntg 支足channel<br />\n<a href=\"https://t.me/materials201920\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fmaterials201920&d=CRZj9ITMXIzKHLmvffUzPAPtErjweJPees2C482IDEo%3D&h=d86b157d\" data-auto-link target=\"_blank\">https://t.me/materials201920</a>"},{"pid":"ee94024414b6d3d4e0ec8835dcfd30392a36