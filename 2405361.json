hkgmoji\" />"},{"pid":"7f9758b710c31158297a99e479c4c887d9781675","tid":2405361,"uid":246909,"like":13,"dislike":0,"score":13,"citedBy":0,"replyTime":"2021-02-12T10:14:26.000Z","msg":"是咁的 <br />\n<br />\n我表哥佢今年考dse，琴日放榜 <br />\n佢考得唔係太好，又怕呀媽擔心 <br />\n呀媽一生人既夢想佢佢個仔入大學 <br />\n因為佢d親戚街坊都無仔女入到U <br />\n<br />\n今日一早番左屋企時，呀媽係咁問佢成績點，夠唔夠分, 可以入邊間U <br />\n表哥心情唔好，是撚但但同呀媽佢佢去讀藥劑， <br />\n之後請入房訓較(尋晚通左頂) <br />\n<br />\n表哥起左身，屙完屎之後出黎 <br />\n發現成家人都好開心，呀爸呀媽叫撚晒佢d親戚姑嫂話今晚出黎食飯 <br />\n同個仔慶祝入到HKU讀藥劑 <br />\n<br />\n依個時候先知大撚獲 <br />\n表哥其實係去報IVE讀藥劑 <br />\n唔撚知邊個親戚街坊話係香港既大學，只有HKU有藥劑讀 <br />\n所以呀媽以為佢夠分入左HKU <br />\n<br />\n屌你 <br />\n我表哥頭先打電話比我 <br />\n問我點做好......... <br />\n<br />\n點算好"},{"pid":"c1897cc0ccb67bf7cfbf7cfd4182f29ad4e0a92e","tid":2405361,"uid":309553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-12T10:24:22.000Z","msg":"拜年話自己讀hku, d親戚以為我讀hku space<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"009f22ee464779f7e283acee75663aff02091233","tid":2405361,"uid":191926,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-12T10:27:24.000Z","msg":"你同親戚解釋<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<br />\nHKU = ARKK<br />\nHKU Space (太空科技) = ARKG"},{"pid":"049291605b0e279c7176c4672340c86cd961373d","tid":2405361,"uid":62032,"like":0,"dislike":0,"score":0,"quote":{"pid":"009f22ee464779f7e283acee75663aff02091233","tid":2405361,"uid":191926,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-12T10:27:24.000Z","msg":"你同親戚解釋<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<br />\nHKU = ARKK<br />\nHKU Space (太空科技) = ARKG"},"citedBy":0,"replyTime":"2021-02-12T10:49:38.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dc24043f90c7194d224ff9d2df16ace6416f699b","tid":2405361,"uid":304008,"like":0,"dislike":0,"score":0,"c