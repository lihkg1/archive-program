ets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"745917e76afb4945eefe5a41e43b74bc09baeb88","tid":303694,"uid":89064,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2017-06-30T11:19:15.000Z","msg":"話時話, 做過餐飲都知, 如果上級無同自己講要快手D, 又或者本身個人冇危機壓迫感, 就算好多人排隊, 收銀果個都唔會FEEL到有咩壓力, 結果就就好似大家所見到既KFC濕鳩員工做野咁慢。<br />\n<br />\n我屌!!!!!<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"6b2151c4050f6bb33311290fe4adeefa6a85873d","tid":303694,"uid":76804,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2017-06-30T11:19:50.000Z","msg":"另類既飢餓營銷方法<br />\n實際上係生意愈黎愈差 要搞到好似好多人幫襯咁<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"8e399b88d741536fb9bc868be2c7d227f92b4ea4","tid":303694,"uid":33787,"like":0,"dislike":6,"score":-6,"citedBy":0,"replyTime":"2017-06-30T11:19:55.000Z","msg":"此回覆已被刪除"},{"pid":"7f343389c5ca670e9471438cf82322187ef68439","tid":303694,"uid":85819,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2017-06-30T11:21:06.000Z","msg":"此回覆已被刪除"},{"pid":"e928540602de16036e2f2f0cc6cb5c1ab683506a","tid":303694,"uid":89064,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2017-06-30T11:22:20.000Z","msg":"<blockquote><blockquote>佢出餐設計白痴<br />\n收銀同執餐同一個人</blockquote><br />\n其實而家老麥買飛再等，分分鐘慢過kfc</blockquote><br />\nM記呢個問題之前討論過, M記而家用first order first service 呢個濕鳩系統, 前面果個如果一次買左3個餐, 後面等拎野食既人就食撚屎<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"2791c6c0279705fa8573c79b00cb27f6fab49fd6","tid":303694,"uid":33787,"like":12,"dislike":0,"score":12,"citedBy":0,"replyTime":"2017-06-30T11:23:01.000Z","msg":"此回覆已被刪除"},{"pid":"9a16be0bca13083468df9d63ddd5556f353f1109","tid":303694,"uid":85819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T11:23:36.000Z","msg":"此回覆已被刪除"},{"pid":"7fd00e125b224df440481eab66790056f4c3d3ba","tid":303694,"uid":78971,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-06-30T11:23:48.000Z","msg":"完全同意<br />\n唔撚係快餐店嚟<br />\n都唔撚入流嘅！"},{"pid":"39d13a9057569b057ed44dd3badf1ae724dea711","tid":303694,"uid":123825,"like":44,"dislike":0,"score":44,"citedBy":0,"replyTime":"2017-06-30T11:25:58.000Z","msg":"因為kfc係負責感嘅企業 請好多智障人士<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n無錯 睇佢表面似正常人 實際都係智障的<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n如果唔係執個濕尻餐洗撚咁柒耐咩<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"2af02299ddad8071d8d51e4fc78bce3b7b0688a6","tid":303694,"uid":89064,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T11:26:26.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>佢出餐設計白痴<br />\n收銀同執餐同一個人</blockquote><br />\n其實而家老麥買飛再等，分分鐘慢過kfc</blockquote><br />\nM記呢個問題之前討論過, M記而家用first order first service 呢個濕鳩系統, 前面果個如果一次買左3個餐, 後面等拎野食既人就食撚屎<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /></blockquote><br />\n所以咪有自助機<br />\n2條唔同隊來</blockquote><br />\n我唔知道, 自助幾同係櫃檯叫野食既次序唔會互相有影響?<br />\n咁如果前一個人用自助機買左3個餐, 後面用自助機買野既人又係等到訓教<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"200f0cf5bdf8c644068bec6358b3bb22ad33c46a","tid":303694,"uid":89064,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-06-30T11:27:45.000Z","msg":"<blockquote>因為kfc係負責感嘅企業 請好多智障人士<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n無錯 睇佢表面似正常人 實際都係智障的<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n如果唔係執個濕尻餐洗撚咁柒耐咩<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n唔怪撚得之見親果度D收銀, 個態度都不溫不火咁, 慢條斯理啦"},{"pid":"773d15fb01e71d1ab92e9b9c2d2d72a9bfe3e5bb","tid":303694,"uid":56127,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T11:29:15.000Z","msg":"M記我起馬睇住啲人拎餐走<br />\nKfc真係郁都唔郁"},{"pid":"6a83910c1471a378fdabfb44b5f61f5754c8a048","tid":303694,"uid":89064,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T11:29:18.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>佢出餐設計白痴<br />\n收銀同執餐同一個人</blockquote><br />\n其實而家老麥買飛再等，分分鐘慢過kfc</blockquote><br />\nM記呢個問題之前討論過, M記而家用first order first service 呢個濕鳩系統, 前面果個如果一次買左3個餐, 後面等拎野食既人就食撚屎<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /></blockquote><br />\n根本就係on9<br />\n仲有班廢物完全唔識multi task<br />\n例如前面有餐未出，後面有個新地筒，班友竟然係等前面個餐出完先去整新地筒</blockquote><br />\n我覺得應該係高層落order比所有分店, 一定要做晒先前既order先可以做下一個order"},{"pid":"a1e0f4cbefc382ec3420d630b826a8b411cb4a5f","tid":303694,"uid":54574,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T11:30:26.000Z","msg":"<blockquote><blockquote><blockquote>佢出餐設計白痴<br />\n收銀同執餐同一個人</blockquote><br />\n其實而家老麥買飛再等，分分鐘慢過kfc</blockquote><br />\nM記呢個問題之前討論過, M記而家用first order first service 呢個濕鳩系統, 前面果個如果一次買左3個餐, 後面等拎野食既人就食撚屎<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /></blockquote><br />\n應該有快慢線架喎，買得多係會後少少"},{"pid":"08dd79dbc8b74cb232d5f20ab66753adf8783a88","tid":303694,"uid":89064,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T11:31:13.000Z","msg":"<blockquote>M記我起馬睇住啲人拎餐走<br />\nKfc真係郁都唔郁</blockquote><br />\nM記以前收銀同汽水機/薯條機/唔同包既通道係好撚近, 而家做到好似開放式咁, 個距離遠撚左好多"},{"pid":"950f802e40cc79a6afffa7abad7d9eda16fb6742","tid":303694,"uid":89064,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T11:32:04.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>佢出餐設計白痴<br />\n收銀同執餐同一個人</blockquote><br />\n其實而家老麥買飛再等，分分鐘慢過kfc</blockquote><br />\nM記呢個問題之前討論過, M記而家用first order first service 呢個濕鳩系統, 前面果個如果一次買左3個餐, 後面等拎野食既人就食撚屎<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /></blockquote><br />\n應該有快慢線架喎，買得多係會後少少</blockquote><br />\n上次我買個包, 都等左15分鐘<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"2bf5a5f8414313fb3a0136886f50d96be6ebbb3b","tid":303694,"uid":65649,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-06-30T11:32:16.000Z","msg":"佢地真係好撚滋游<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"40d238e52649208dcfe6ba16ff0652ee89ee11b7","tid":303694,"uid":89064,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2017-06-30T11:32:46.000Z","msg":"<blockquote>佢地真係好撚滋游<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\nagger, 果種滋游係會令到人無名火起<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},{"pid":"ad9047183ed8af968f2f399269c4c140bcc68a93","tid":303694,"uid":14131,"like":1,"dislike":4,"score":-3,"citedBy":0,"replyTime":"2017-06-30T11:37:07.000Z","msg":"不如你答我點解要快<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2c2891b7d1a24ffcaa30c21ff0adc90727fe2a39","tid":303694,"uid":3172,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T11:37:23.000Z","msg":"半個鐘  終於買到"},{"pid":"941cb41e5599afc15fbc469944c273c02be29606","tid":303694,"uid":67864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T11:37:55.000Z","msg":"少人食咪快囉"},{"pid":"f453f67c9a85a6111778c27f2de8877fdd455148","tid":303694,"uid":4173,"like":11,"dislike":0,"score":