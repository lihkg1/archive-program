1T16:48:41.000Z","msg":"推"},{"pid":"f73e2054266125e8b413dcd3bd98045cccefa555","tid":1529203,"uid":216555,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T16:52:22.000Z","msg":"推"},{"pid":"a82fd16fd672610d3c9c0f91e0d40f6da1fddcb2","tid":1529203,"uid":278392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T17:00:14.000Z","msg":"其實佢係為左最後chok個下可以上鏡啫<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"308b18885dc030649d8a7d79589805071625ef6d","tid":1529203,"uid":132322,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-01T17:03:51.000Z","msg":"你有權保持緘默<br />\n唔係事必要你講，但你講既野將會成為呈堂證供<br />\n呢個係市民權利<br />\n乜原來係法律意見<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n原來個個呀蛇都係律師<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n原來毅進仔可以做律師<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n難怪呀蛇做野唔駛人教<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n但如果呀蛇唔係律師<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><br />\n而呀蛇又提供法律意見<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n根據佢既邏輯呢個係阻差辦工<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n姐係個個呀蛇講完市民權利都係阻差辦公<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n難怪二哥話有一半既呀蛇都要停職<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n以後呀蛇返工都係唔好講咁多野<br />\n聽日四點鐘不如叫謝蛇澄清返究竟呀蛇係咪律師<br />\n記得叫佢對著個鏡頭講<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"26cd2e2cc4d67e7afb43b98bf439224f6772a954","tid":1529203,"uid":216555,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T23:10:43.000Z","msg":"推"},{"pid":"18ec6bf2c7c2a8cf489ba5354aab310bf5d8eab0","tid":1529203,"uid":265739,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T00:45:29.000Z","msg":"上鏡+10000"}]}