/2019464-%E6%B8%AF%E8%81%9E-%E6%94%BF%E5%BA%9C%E9%AB%98%E5%B1%A4%E6%B7%B1%E5%A4%9C%E6%80%A5%E5%8F%AC%E6%9C%83%E8%AD%B0+%E6%9E%97%E9%84%AD%E6%96%99%E4%BB%8A%E5%AE%A3%E5%B8%83%E6%9A%AB%E7%B7%A9%E4%BF%AE%E4%BE%8B\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fstd.stheadline.com%2Fdaily%2Farticle%2Fdetail%2F2019464-%25E6%25B8%25AF%25E8%2581%259E-%25E6%2594%25BF%25E5%25BA%259C%25E9%25AB%2598%25E5%25B1%25A4%25E6%25B7%25B1%25E5%25A4%259C%25E6%2580%25A5%25E5%258F%25AC%25E6%259C%2583%25E8%25AD%25B0%2B%25E6%259E%2597%25E9%2584%25AD%25E6%2596%2599%25E4%25BB%258A%25E5%25AE%25A3%25E5%25B8%2583%25E6%259A%25AB%25E7%25B7%25A9%25E4%25BF%25AE%25E4%25BE%258B&d=eu0lilLN9Tjy39QEn%2BRylqb0OKgTvMyjK8k7SjVk7cc%3D&h=bf6b81c5\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fstd.stheadline.com%2Fdaily%2Farticle%2Fdetail%2F2019464-%25E6%25B8%25AF%25E8%2581%259E-%25E6%2594%25BF%25E5%25BA%259C%25E9%25AB%2598%25E5%25B1%25A4%25E6%25B7%25B1%25E5%25A4%259C%25E6%2580%25A5%25E5%258F%25AC%25E6%259C%2583%25E8%25AD%25B0%2B%25E6%259E%2597%25E9%2584%25AD%25E6%2596%2599%25E4%25BB%258A%25E5%25AE%25A3%25E5%25B8%2583%25E6%259A%25AB%25E7%25B7%25A9%25E4%25BF%25AE%25E4%25BE%258B&h=1b0a023e\" data-auto-link target=\"_blank\">http://std.stheadline.com/daily/article/detail/2019464-%E6%B8%AF%E8%81%9E-%E6%94%BF%E5%BA%9C%E9%AB%98%E5%B1%A4%E6%B7%B1%E5%A4%9C%E6%80%A5%E5%8F%AC%E6%9C%83%E8%AD%B0+%E6%9E%97%E9%84%AD%E6%96%99%E4%BB%8A%E5%AE%A3%E5%B8%83%E6%9A%AB%E7%B7%A9%E4%BF%AE%E4%BE%8B</a><br />\n<br />\n星島日報報道）政府原定在今年七月前完成《逃犯條例》修訂草案審議，惹來反對派連番發動遊行示威阻撓，甚至釀成暴力衝突。據悉，專責香港事務的中央港澳協調小組組長韓正近日南下深圳，並曾與特首林鄭月娥商討事件。而林鄭在衡量各種因素後，決定暫緩修例，重新諮詢。林鄭昨晚深夜召開全體司局長會議，商討有關決定，並會在今早會晤全體建制派議員交代決定及作出解釋，然後即會向公眾作出宣布。消息人士表示，今次決定是希望有關《逃犯條例》的修訂能夠回歸理性，讓政府有時間聽取民意，</blockquote><br />\n<br />\n<code>#1 - 六九真係好煩，要諗咁多既</code><br />\n<a href=\"https://lihkg.com/thread/1190576/page/1?ref=sharer&amp;post=1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1190576/page/1?ref=sharer&amp;post=1</a><br />\n<blockquote>又要睇隔離左右自後係咪鬼<br />\n又話要醒目<