gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/09/181531_60148f910f5baf34843266ec26d08c02.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F09%2F181531_60148f910f5baf34843266ec26d08c02.jpg&h=a77824fa&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/09/181537_28077ce4d47755edd55b23301bed2b6a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F09%2F181537_28077ce4d47755edd55b23301bed2b6a.jpg&h=bcbd4ac1&s={SIZE}\" />"},{"pid":"e3d5cbac68cf47e41da989dbc7e23aecbbb16242","tid":519574,"uid":153796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-09T11:15:43.000Z","msg":"幾好睇，支持<br />\n我都想今年秋季去"},{"pid":"51e55e9e0c9e12b93831a98891c4307eec8c5c8e","tid":519574,"uid":164449,"like":0,"dislike":0,"score":0,"quote":{"pid":"fe9a900c213056b73ca67c1ff6a3a7c9432a72a9","tid":519574,"uid":71712,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-09T09:43:04.000Z","msg":"樓主深圳飛成都幾錢 <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-09T11:27:34.000Z","msg":"2千3港紙來回..."}]}