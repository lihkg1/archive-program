51f363e2632a27d24e9fe4b.jpg&h=5516b532&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-01-08T12:58:56.000Z","msg":"巴打去果時咁嚴寒<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <br />\n如果我係呢個天氣去可能行唔到上去"},"citedBy":0,"replyTime":"2018-01-08T13:03:25.000Z","msg":"唔嚴寒啦...<br />\n10月尾是亞丁既旺季, 只係我太唔好彩..<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"e6fe66508d7ba4e9abbcc849312cb73d443ba141","tid":519574,"uid":106032,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-08T13:11:07.000Z","msg":"我上年12月中去的<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/08/210704_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F08%2F210704_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=1642a71d&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/08/210823_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F08%2F210823_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=21b32a9f&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/08/211057_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F08%2F211057_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=996573e8&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/08/211105_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F08%2F211105_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=9d643f85&s={SIZE}\" />"},{"pid":"d4da137918514edc3e921216fe7c907e1560b7a0","tid":519574,"uid":106032,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-08T13:12:49.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/01/08/211247_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F08%2F211247_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=b67b1af0&s={SIZE}\" />"},{"pid":"30aba6997b4aaef278e016e7835e3955ba940df1","tid":519574,"uid":164449,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-09T02:59:51.000Z","msg":"Day 2 康定-&gt;理塘縣(全球最高海拔縣城4013米)-&gt;稻城 <br />\n<br />\n朝早一起身嘔吐怪已經開始覺得唔對路，有想嘔既感覺。而小學雞男友就頭暈暈，雞WING就肚痛不止，尋日已經屙塞左個廁所。而其他團友就一切正常，只係有D肚餓。<br />\n<br />\n由於時間緊迫嘅關係，天未光我地就出發趕路啦，時間只係朝早嘅6點半，個個都係未訓醒咁樣，有幾個係訓唔到咁樣。<br />\n講返個旅程，康定距離我地第一個景點『天路十八彎』大約170公里，我地大概要頭搖又尾擺咁3個幾鐘先到達。<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/09/071746_6d4f693faa4fb87652550a05e83a4a12.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F09%2F071746_6d4f693faa4fb87652550a05e83a4a12.png&h=be3d927a&s={SIZE}\" /><br />\n<br />\n終於爆到上山啦，D髮夾彎加上師傅手車真係人都癲！！<br />\n<br />\n偉大既黨哪會放過任何一個放標語既機會？<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/09/071903_f0dfd8eb5556a643e5608bb090ec250b.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F09%2F071903_f0dfd8eb5556a643e5608bb090ec250b.png&h=eb7a5b3c&s={SIZE}\" /><br />\n<br />\n<br />\n到達海拔4700 米的卡子拉山，好撚大風<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/09/071944_3f471abbd21ffba416fe88d5edd13772.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F09%2F071944_3f471abbd21ffba416fe88d5edd13772.png&h=08d44cd4&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/09/080753_d30c63f3f7be526d69beb8bdaa596b7e.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F09%2F080753_d30c63f3f7be526d69beb8bdaa596b7e.png&h=a74a42dc&s={SIZE}\" /><br />\n<br />\n<br />\n天氣極好，係透唔到氣差啲姐。雞wing，嘔吐怪 同小學雞男友已經行唔到落去影相<br />\n<br />\n<br />\n去左幾個景點都成12點，肚都打撚晒鼓啦，師傅睇落好好人咁幫我地book左間餐廳，仲落埋柯打食咩餸，由於佢講既唔係講普通話，所以都唔知佢叫左啲咩，諗住都係黎黎去去個啲川菜啦。而去緊餐廳既途中，山路依然彎曲，沿途啲山路真係轉到人頭都暈撚埋，啲人成日話咩九曲十三彎，我地由山腳幾經含撚如苦終於過左十八個彎上到山。嘔吐怪當時既靈魂直情係進入左飄移境界，點解呢？因為佢一開頭話頭痛痛暈，過多幾分鐘就用把就死既聲問有冇膠袋，保姆即刻隊左個膠袋比佢，一遞過去即係嘔晒琴晚餐飯出黎，傑ta ta，車內既酸度馬上急升，傳出一陣惡臭。而小學雞男友嘅頭暈都未停過，進入左冬眠狀態；雞WING就肚痛到好似蝦米咁。但係嘔吐怪個胃仲未停手，斷斷續續地嘔下停下，嘴都紫埋呀陰公。好彩，坐多一陣都終於落車啦，感謝主帶領！<br />\n<br />\n<br />\n一入到餐廳，個老闆見嘔吐怪同小學雞男友個樣咁唔掂即刻叫佢地吸氧氣，話佢地係高山反應。本身佢兩個都有猶豫吸唔吸，因為網上聽人講吸得多唔好，會上癮，而且更難適應到高海拔。但當下佢兩個連行路都慢過隻臨終既烏龜，所以決定吸下。老闆即刻好熱情咁開行部吸氧機比佢地索，索左10幾分鐘後，嘔吐怪個嘴終於變返個正常人，仲話唔頭痛，即刻生猛返講到野，可以食午餐。而雞wing同小學雞男友去爆左個石之後都正常返，可以一齊共晉午餐。<br />\n <img src=\"https://img.eservice-hk.net/upload/2018/01/09/072036_0683d709c0272b76b0ab52cca5747143.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F09%2F072036_0683d709c0272b76b0ab52cca5747143.png&h=46821574&s={SIZE}\" /><br />\n老闆聲稱上圖有7公斤牛肉，仲有3個菜一個菜湯<br />\n<br />\n<br />\n好啦，匆匆忙忙咁食完一餐，係時候埋單，屌你老尾係咪傻撚左？呢餐飯收左我地7xx人仔？？？尋日食左9個餸明明都只係二百幾蚊，當下我地冇出聲，因為佢一開始懶係對我地好好，又比吸氧機我地用，加上又唔係我地落單同埋呢個老闆同師傅好似本身識，加埋師傅全程都話無餐廳開有得食好食，所以都係算，照比<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n*祥鶴賓館*疑似黑店<br />\n<br />\n食飽又繼續繼續上路啦<br />\n<br />\n<br />\n兔兒山海拔4696米，結冰既石路上到去就係掛滿五色經幡既平地，藏民深信五色經幡能消除厄運和祈福，當風吹過經幡相當於經幡上面的經文念過一遍。<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/09/074919_4418d04b8fe6d86932f6887a8e991b04.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F09%2F074919_4418d04b8fe6d86932f6887a8e991b04.png&h=27546730&s={SIZE}\" /><br />\n<br />\n<br />\n入稻城之前係河邊睇埋個日落<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/09/081446_b39a6520ddd5ec33370fb8f23461cbe2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F09%2F081446_b39a6520ddd5ec33370fb8f23461cbe2.png&h=e6ab9d0e&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/09/081449_d2b298a562cb5230ca0fc2debd662fb4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F09%2F081449_d2b298a562cb5230ca0fc2debd662fb4.png&h=6a88cccb&s={SIZE}\" /><br />\n<br />\n比個表大家參考下咁多人嘅狀態。<br />\n<br />\nDay 2 狀態表<br />\n雞WING: 肚痛<br />\n辣妹子: 長興奮狀況又跑又跳<br />\n小學雞: 有D感冒, 其他正常<br />\n小學雞男友: 頭痛, 進入冬眠狀態<br />\n高妹: 一切正常<br />\n嘔吐怪: 瘋狂嘔吐<br />\n保母: 一切正常<br />\n淆底獸: (竟然)一切正常"},{"pid":"92dc26e617e0450312ccf425f50aa6bc8ab6f0c1","tid":519574,"uid":164449,"like":0,"dislike":0,"score":0,"quote":{"pid":"4342cedfb2d6605b73037f767c839f6f7f2160dd","tid":519574,"uid":46807,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-01-08T09:01:04.000Z","msg":"<blockquote><blockquote>我上年5月都去左<br />\n真係好靚<br />\n<br />\n稻城景區間旅館望出窗既風景<br />\n<img src=\"https://i.imgur.com/2ATJAVv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2F2ATJAVv.jpg&h=a131cbd2&s={SIZE}\" /><br />\n牛奶海<br />\n<img src=\"https://i.imgur.com/KbuuHYE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FKbuuHYE.jpg&h=fb543824&s={SIZE}\" /></blockquote>好靚...<br />\nBTW 我上年10月去.....<br />\n<br />\n牛奶海</blockquote><br />\n<br />\n<br />\n牛奶海....<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/08/165952_eb4e6bd7420256744abff17da6fcd5df.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F08%2F165952_eb4e6bd7420256744abff17da6fcd5df.jpg&h=66841031&s={SIZE}\" /><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/08/170047_c155f65e651f363e2632a27d24e9fe4b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F08%2F170047_c155f65e651f363e2632a27d24e9fe4b.jpg&h=5516b532&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-01-09T03:01:22.000Z","msg":"有冇騎馬？"},{"pid":"9df504368779af7ac32e51b3ed34f276acce4f5a","tid":519574,"uid":32818,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-09T03:29:40.000Z","msg":"留"},{"pid":"e85e8ae840