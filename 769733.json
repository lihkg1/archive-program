{"tid":769733,"cid":1,"subCid":0,"title":"屋企人好撚中意講蝗語點算","createTime":"2018-08-06T12:02:03.000Z","updateTime":"2018-08-06T14:51:36.000Z","uid":133557,"like":8,"dislike":2,"uniUserReply":11,"replies":[{"pid":"9bc50d2911367defeef4628d78dabd9ec722c097","tid":769733,"uid":133557,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-06T12:02:03.000Z","msg":"就咁<br />\n我家姐平日傾計都一般冇事<br />\n唔知點解講到一陣間就好中意彈撚嗮啲蝗語詞語出黎<br />\n好地地一個地名又用蝗語講<br />\n睇戲見到啲subtitle又冇啦啦用蝗語重覆一次<br />\n屌搞到睇戲個氣氛唔撚見嗮<br />\n作為聽者嗰個<br />\n我真係好撚辛苦<br />\n平時佢講野已經冇乜常識<br />\n加埋蝗語真係唔知佢想點<br />\n次次聽到都好撚想一拳打柒佢<br />\n求救<br />\n可以點解決呢件事<br />\n當口當面唔知可以點同佢講"},{"pid":"f0edba46a40c8b29977a5a92c6f0b66211f6ba54","tid":769733,"uid":56240,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-08-06T12:03:54.000Z","msg":"屌撚柒佢"},{"pid":"f6db9bbc59af764afbf5c41cde4a2dfeb3650396","tid":769733,"uid":133557,"like":0,"dislike":3,"score":-3,"quote":{"pid":"f0edba46a40c8b29977a5a92c6f0b66211f6ba54","tid":769733,"uid":56240,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-08-06T12:03:54.000Z","msg":"屌撚柒佢"},"citedBy":1,"replyTime":"2018-08-06T12:12:53.000Z","msg":"當面唔敢屌，所以先上連登屌"},{"pid":"cdaec260aa44c1850b01ca6a1f2c5e41c01a50a3","tid":769733,"uid":56240,"like":2,"dislike":0,"score":2,"quote":{"pid":"f6db9bbc59af764afbf5c41cde4a2dfeb3650396","tid":769733,"uid":133557,"like":0,"dislike":3,"score":-3,"quote":{"pid":"f0edba46a40c8b29977a5a92c6f0b66211f6ba54","tid":769733,"uid":56240,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-08-06T12:03:54.000Z","msg":"屌撚柒佢"},"citedBy":1,"replyTime":"2018-08-06T12:12:53.000Z","msg":"當面唔敢屌，所以先上連登屌"},"citedBy":1,"replyTime":"2018-08-06T12:13:26.000Z","msg":"垃圾"},{"pid":"00f166bc9f148a5a3be5e0f59dda982788d3069e","tid":769733,"uid":133557,"like":0,"dislike":0,"score":0,"quote":{"pid":"cdaec260aa44c1850b01ca6a1f2c5e41c01a50a3","tid":769733,"uid":56240,"like":2,"dislike":0,"score":2,"quote":{"pid":"f6db9bbc59af764afbf5c41cde4a2dfeb3650396","tid":769733,"uid":133557