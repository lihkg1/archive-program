70062,"like":0,"dislike":0,"score":0,"quote":{"pid":"c88e7e8a7600bd34f0d1e93a38767765d77bbf2a","tid":2319844,"uid":13138,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-12-10T11:07:03.000Z","msg":"一排以為自己冇事 過一排又喊到仆街<br />\n<br />\n成日發夢係個森林搵佢<br />\n個夢好真實 有任何風吹草動我都以為佢係我附近 但每次醒都係搵佢唔到<br />\n<br />\n每次朝早喊到醒 沒完沒了咁<br />\n<br />\n試過不斷做運動 做gym 返工麻醉自己 同其他人 其他女仔傾計 但都係冇用<br />\n<br />\n講下背景<br />\n為咗段關係我都好盡力<br />\n至少我係忠誠咁愛佢一個 亦都對佢幾好 會主動帶佢周圍去 準備好多<br />\nEven佢講過大話呃我 心入面有另一個 我都原諒咗佢 心入面係有條刺 但我唔會將負面情緒發落佢度 佢話會補償返我 我信用時間睇 不過我包容的確係低咗<br />\n<br />\n但最後發現無論我點做 佢都唔會滿足 一樣完咗就會到另一樣 會比較 罵交分手收場<br />\n<br />\n<br />\n依家諗 點解我愛一個人 唔會拎佢同人比較 其實係岩定錯？<br />\n好似我唔會覺得人地女朋友會點點點 佢就應該點點點<br />\n因為咁樣好辛苦 每個人都唔一樣 我覺得只要佢為我做 我己經珍惜 從來冇因為依啲事而嘈佢 但佢嘅要求好似永冇止境<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-10T11:34:03.000Z","msg":"486唔要你咩<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-10T13:57:12.000Z","msg":"唔玩膠"},{"pid":"f6c311021c376de6405c3bfd478d8be04fac53ab","tid":2319844,"uid":75404,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2020-12-10T14:34:01.000Z","msg":"同路人留下正皮<br />\n<br />\n1.比啲耐性<br />\n對的人會係未來等你 <br />\n所以呢一刻開始對你自己好啲<br />\n<br />\n2.愛你既人係唔會咁樣對你<br />\n<br />\n3.既然佢都唔識珍惜你<br />\n你都唔好再花腦力同時間唸起佢<br />\n<strong><span class=\"x-large\">你已經投資得夠多 要止蝕</span></strong>"},{"pid":"621aa8599be59a65f9bc3d9769d9cf8695295c4c","tid":2319844,"uid":231089,"like":0,"dislike":0,"score":0,"quote":{"pid":"175d424bfb0b89cdf4331bff7bd143e2b5b7c35f","tid":2319844,"uid":154063,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2020-12-10T11:45:00.000Z","msg":"永遠無可能會放低到<br />\n因為始終係回憶嘅一部分<br />\n與其忘記 不如好好記住學到嘅道理<br />\n回憶始終塑造宜家嘅你 係生命嘅一部份<br />\n反而應該明白人總會面對經歷散聚<br />\n無論親人愛人都係<br />\n<br />\n利申被分手幾日"},"citedBy":0,"replyTime":"2020-12-10T14:35:44.000Z","msg":"講得好好<img src=\"/assets/faces/fs/adore.gif\" class=\"hkgmoji\" /><br />\n我都好記得分手嘅感受<br />\n學到好多嘢 不過都想屌返去<br />\n出軌斷賓州<img src=\"/assets/faces/fs/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/adore.gif\" class=\"hkgmoji\" />"},{"pid":"845026a943bf6b5f3d53c633faaabac6e596e415","tid":2319844,"uid":351117,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-10T15:00:34.000Z","msg":"雖然我同佢最後都冇一齊 但係我每一日都好掛住佢 已經半年喇<img src=\"/assets/faces/mouse/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/tired.gif\" class=\"hkgmoji\" />"},{"pid":"5e00ec740624aa5d94b0c3154bf29347b7fed933","tid":2319844,"uid":300937,"like":2,"dislike":2,"score":0,"quote":{"pid":"8f2deb9c941b546875811025e669122acafc8c0b","tid":2319844,"uid":13138,"like":33,"dislike":0,"score":33,"citedBy":2,"replyTime":"2020-12-10T11:18:52.000Z","msg":"朋友話森林仲有好多樹<br />\n睇開啲<br />\n我明 但如果棵棵樹我都可以岩<br />\n我嘅愛又係咪一樣已經變得廉價<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n終於明sam點解會死<br />\n對佢黎講 森林係有好多樹<br />\n佢想要絕對會有<br />\n但佢從來都只係想要一棵樹<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-10T15:09:20.000Z","msg":"但其實佢似係個啲恐怖情人同控制狂多啲"},{"pid":"1ea05b5cce0223bf82718aea37f3505feb4a7dc4","tid":2319844,"uid":350206,"like":0,"dislike":0,"score":0,"quote":{"pid":"8f2deb9c941b546875811025e669122acafc8c0b","tid":2319844,"uid":13138,"like":33,"dislike":0,"score":33,"citedBy":2,"replyTime":"2020-12-10T11:18:52.000Z","msg":"朋友話森林仲有好多樹<br />\n睇開啲<br />\n我明 但如果棵棵樹我都可以岩<br />\n我嘅愛又係咪一樣已經變得廉價<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n終於明sam點解會死<br />\n對佢黎講 森林係有好多樹<br />\n佢想要絕對會有<br />\n但佢從來都只係想要一棵樹<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-10T15:43:32.000Z","msg":"同我諗嘅一樣<br />\n我只係想要一棵樹<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d53947d506ec9b1d4da3203a759fcb01a92a44c7","tid":2319844,"uid":217877,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-10T15:59:50.000Z","msg":"初頭以為冷戰，⋯⋯⋯只係消失⋯⋯⋯聽「隔離」lee首歌真係喊到⋯⋯⋯"},{"pid":"235146ba82480bf8297c99af423f34f934763a4e","tid":2319844,"uid":13138,"like":0,"dislike":0,"score":0,"quote":{"pid":"f6c311021c376de6405c3bfd478d8be04fac53ab","tid":2319844,"uid":75404,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2020-12-10T14:34:01.000Z","msg":"同路人留下正皮<br />\n<br />\n1.比啲耐性<br />\n對的人會係未來等你 <br />\n所以呢一刻開始對你自己好啲<br />\n<br />\n2.愛你既人係唔會咁樣對你<br />\n<br />\n3.既然佢都唔識珍惜你<br />\n你都唔好再花腦力同時間唸起佢<br />\n<strong><span class=\"x-large\">你已經投資得夠多 要止蝕</span></strong>"},"citedBy":0,"replyTime":"2020-12-11T07:17:12.000Z","msg":"人非草木呀<img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />"},{"pid":"fbba4cf38d27e7726ea6650402d1d43c3832be04","tid":2319844,"uid":232701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T07:29:37.000Z","msg":"咁要睇你對&ldquo;放低&rdquo;既定義係咩"},{"pid":"cd06d9c3993035baf7a514a1bfa681defdc5a7a7","tid":2319844,"uid":188455,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-11T08:56:31.000Z","msg":"Time heals<br />\n好老土 但係真...<br />\n自問每段感情都係一心一意<br />\n但時間過後會慢慢明白<br />\n雙方之間唔適合就係唔適合<br />\n無謂勉強 <br />\n最後真係會放得低前任<br />\n<br />\n我覺得盡力愛過就唔會有所謂放唔低了<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"a7ff503eb31ff8e20aa061c029b737c3050c12c1","tid":2319844,"uid":13138,"like":2,"dislike":0,"score":2,"quote":{"pid":"cd06d9c3993035baf7a514a1bfa681defdc5a7a7","tid":2319844,"uid":188455,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-11T08:56:31.000Z","msg":"Time heals<br />\n好老土 但係真...<br />\n自問每段感情都係一心一意<br />\n但時間過後會慢慢明白<br />\n雙方之間唔適合就係唔適合<br />\n無謂勉強 <br />\n最後真係會放得低前任<br />\n<br />\n我覺得盡力愛過就唔會有所謂放唔低了<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-11T09:10:49.000Z","msg":"係唔明點解我連佢講多次大話 我未冇放棄過佢<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" /><br />\n但每次罵交 佢都鐘意用分手同冷戰黎要脅我 鐘意拎我比較<br />\n<br />\n最後我過咗臨界點 一次過爆曬出黎"},{"pid":"f2768645740ff5249b8effd58d2f52981826e808","tid":2319844,"uid":29627,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T09:14:28.000Z","msg":"男人老狗man d啦<br />\n喊乜鬼"},{"pid":"bd2e4080ea9552c1635370bab3013af8479254c2","tid":2319844,"uid":348884,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-11T09:36:26.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"05fc640a21b5be4626062c41f4a3b9395d898606","tid":2319844,"uid":14697,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T10:23:44.000Z","msg":"睇完樓豬post 我以為自己打出黎 一直以黎我都做得好卑微，佢想要咩我盡量做，每次講分手我都哄返佢，死纏爛打咁哄佢，最後話sorry I tried but i just cant continue因為唔鐘意我"},{"pid":"8100f287a2d5cf5d2d9300d4814bee90fa8ee2ad","tid":2319844,"uid":14697,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T10:26:38.000Z","msg":"最後佢話想要自由，搵下個更鐘意黎取代我<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 明明一開始當初我可以做到自己，慢慢被佢mental control我變成佢想要既模樣"},{"pid":"53dde5a2b09245568d490c8877f2644a06f67203","tid":2319844,"uid":85586,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T10:35:42.000Z","msg":"經過今次經驗就學識唔好將個世界完全放落去一個人度<br />\n感情關係除非你係M你係覺得就佢係一種享受<br />\n正常係應該大家都對等<br />\n唔係單方面完全遷就迎合另一方<br />\n同埋學識拎得起放得低<br />\n人變咗心就變咗<br />\n要學識接受事實同長痛不如短痛及早分手<br />\n感情唔係投資就有回報嘅嘢<br />\n修補關係唔係靠單方面嘅努力就得"},{"pid":"2796aa136d30412c23a0c9ee97ed72a723df6a78","tid":2319844,"uid":136924,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-12-11T12:24:33.000Z","msg":"放低晒一定唔會<br />\n但係會適應到冇佢嘅生活<br />\n愛情 其實只係一樣各取所需嘅關係<br />\n唔好諗到佢幾神聖<br />\n咩除咗佢其他人都唔要個啲說話<br />\n只係感動到自己<br />\n最重要你知道自己係一段關係嘅位置<br />\n同埋放唔低就唔好拎起<br />\n嚟個係愛情嘅真面目"},{"pid":"c707d865db0d84a345d82cabca698c3b9b7d1f1f","tid":2319844,"uid":186374,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-12-11T13:00:37.000Z","msg":"一條條答你<br />\n<br />\n1. 依家諗 點解我愛一個人 唔會拎佢同人比較 其實係岩定錯？<br />\n<br />\n你係啱一半<br />\n如果你本身拍過拖 你絕對有資格去拎佢同你前任比較<br />\n不過唔係比較邊個大波啲呢啲on9野<br />\n係去反思到底而家呢個同你係咪1)有條件磨合 2)有心磨合<br />\n<br />\n<br />\n2. Even佢講過大話呃我 心入面有另一個 我都原諒咗佢 心入面係有條刺 但我唔會將負面情緒發落佢度 佢話會補償返我 我信用時間睇 不過我包容的確係低咗<br />\n但最後發現無論我點做 佢都唔會滿足 一樣完咗就會到另一樣 會比較 罵交分手收場<br />\n<br />\n你係新界牛? 唔用腦嘅努力其實係最大嘅懶惰有無聽過<br />\n根本你發覺自己每次努力做好多野對方都無滿足<br />\n你就應該停一停諗一諗<br />\n對方到底需要啲乜 你明唔明白對方<br />\n你嘅努力到底係滿足緊你自己所為嘅&ldquo;愛&rdquo; 定真係為緊對方<br />\n同埋對方需要嘅野你到底有無能力比佢 <br />\n如果代價係你要無咗自己一啲原則你先可以滿足佢<br />\n你有無考慮過自己要唔要繼續<br />\n你如果連呢啲野都唔諗<br />\n你拍拖根本好似買六合彩咁<br />\n所有野都唔到你話事 比人飛都係抵撚死<br />\n因為你唔識自愛亦無底線"},{"pid":"c7ec6c61d341dc591e76ac94b03278aa37d9a0fc","tid":2319844,"uid":76272,"like":1,"dislike":0,"score":1,"quote":{"pid":"a7ff503eb31ff8e20aa061c029b737c3050c12c1","tid":2319844,"uid":13138,"like":2,"dislike":0,"score":2,"quote":{"pid":"cd06d9c3993035baf7a514a1bfa681defdc5a7a7","tid":2319844,"uid":188455,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-11T08:56:31.000Z","msg":"Time heals<br />\n好老土 但係真...<br />\n自問每段感情都係一心一意<br />\n但時間過後會慢慢明白<br />\n雙方之間唔適合就係唔適合<br />\n無謂勉強 <br />\n最後真係會放得低前任<br />\n<br />\n我覺得盡力愛過就唔會有所謂放唔低了<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-11T09:10:49.000Z","msg":"係唔明點解我連佢講多次大話 我未冇放棄過佢<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" /><br />\n但每次罵交 佢都鐘意用分手同冷戰黎要脅我 鐘意拎我比較<br />\n<br />\n最後我過咗臨界點 一次過爆曬出黎"},"citedBy":0,"replyTime":"2020-12-11T14:01:08.000Z","msg":"你愛佢 佢唔愛你<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3a9ce943964a6ebbfda531502136619c548d1dfa","tid":2319844,"uid":5289,"like":0,"dislike":0,"score":0,"quote":{"pid":"fdf74e1584c6c2aadb50d6185b40fc7db999c3fa","tid":2319844,"uid":169198,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-12-10T11:36:51.000Z","msg":"對方唔愛你 做咩都無用<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-11T15:02:17.000Z","msg":"係<br />\n<br />\n就算你有無限錢<br />\n<br />\n都只係一張長期飯票"},{"pid":"9fdf38eac869046e54ccfdb826baba2767acc310","tid":2319844,"uid":377258,"like":0,"dislike":0,"score":0,"quote":{"pid":"2796aa136d30412c23a0c9ee97ed72a723df6a78","tid":2319844,"uid":136924,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-12-11T12:24:33.000Z","msg":"放低晒一定唔會<br />\n但係會適應到冇佢嘅生活<br />\n愛情 其實只係一樣各取所需嘅關係<br />\n唔好諗到佢幾神聖<br />\n咩除咗佢其他人都唔要個啲說話<br />\n只係感動到自己<br />\n最重要你知道自己係一段關係嘅位置<br />\n同埋放唔低就唔好拎起<br />\n嚟個係愛情嘅真面目"},"citedBy":0,"replyTime":"2020-12-11T15:07:29.000Z","msg":"愛情 其實只係一樣各取所需嘅關係<br />\n唔好諗到佢幾神聖<br />\n依兩句講得好好<br />\n其實咩感情都係<br />\n友情都係<br />\n唔知有幾多人睇得透依點<br />\n而睇得透既人又有幾多係自欺欺人緊"}]}