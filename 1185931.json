192e9bf5b6803d5a4e355","tid":1185931,"uid":139244,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-04T17:40:28.000Z","msg":"你有撚用！<br />\n你冇撚用！<br />\n都係話你冇用"},{"pid":"9b0dd64b1eb31b2e7ab1b3546cf5dec1c0a6683c","tid":1185931,"uid":13108,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2019-06-04T18:56:06.000Z","msg":"上床 落床都係<br />\n一瞓上床就瞓著 vs 一瞓落床就瞓著"},{"pid":"2df5f355b323bad9879f58d9241eaf1bd36890d1","tid":1185931,"uid":21757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-04T20:30:56.000Z","msg":"落街通常住樓 落樓下附近<br />\n出街 離開屋企<br />\n上街  去遊行"},{"pid":"9928859348b9fff914ca43da99ef0b0c38d72489","tid":1185931,"uid":149534,"like":1,"dislike":0,"score":1,"quote":{"pid":"6c818a8cd7a20e82d73d1248fed8336b675534e0","tid":1185931,"uid":52238,"like":29,"dislike":1,"score":28,"citedBy":2,"replyTime":"2019-06-04T14:43:42.000Z","msg":"我9估 會唔會係想強調嘅主體唔同？<br />\n「上街」強調嘅係你去街到做某啲野，所主體係條街<br />\n「落街」所強調嘅係你由屋企移動到另一個地方，主體係屋企"},"citedBy":0,"replyTime":"2019-06-04T21:32:12.000Z","msg":"我地睇法都接近，不過我覺得強調既係個位階既分別<br />\n<br />\n上街遊行，要上即係件事高級啲。上街行下同落街行下個性質已經有分別。<br />\n<br />\n落街買餸，落即係普通既小事。<br />\n或者官員落區視察，就係從高位落去街頭。"},{"pid":"b33c34cee23ad03fe85618f7f08ef49338f146e2","tid":1185931,"uid":149534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-04T21:32:56.000Z","msg":"slim chance<br />\nfat chance"},{"pid":"4c0ebcbef6f37f5f8d79ec2bc8f0d6fc357386ba","tid":1185931,"uid":4709,"like":3,"dislike":0,"score":3,"quote":{"pid":"a9b4202954a6de43b088ef7601c2ad5ea34f563f","tid":1185931,"uid":810,"like":2,"dislike":0,"score":2,"quote":{"pid":"031bd265649b8b70e0aa1969777a2532a3245116","tid":1185931,"uid":70524,"like":3,"dislike":26,"score":-23,"citedBy":3,"replyTime":"2019-06-04T14:41:54.000Z","msg":"上船 落船"},"citedBy":1,"replyTime":"2019-06-04T15:43:35.000Z","msg":"啲細蚊仔邊識架<br />\n你睇你負皮多能到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-04T22:22:50.000Z","msg":"以前呀婆講完全唔明白<br />\n<br />\n真係有少少年紀先會知，上面仲要問做左功課未<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"456ef437fbf55a0e22ef2f53a8cd3fbb54f6242f","tid":1185931,"uid":156582,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-04T22:30:58.000Z","msg":"放工 收工 都一樣意思"},{"pid":"cf5840f38d758703ce882bae246c746af6bd9888","tid":1185931,"uid":162738,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-04T22:38:17.000Z","msg":"好不高興 同 好高興 都係一樣意思"},{"pid":"ba3453c6506ea97ffc1f2e066bd1f198ab3189ea","tid":1185931,"uid":51612,"like":0,"dislike":0,"score":0,"quote":{"pid":"847149e0071462e7b9b944bc3b5bff04e3fb7e6b","tid":1185931,"uid":201604,"like":20,"dislike":1,"score":19,"quote":{"pid":"0a7c2762f9be1f164f36c2bf1f08920e1475f915","tid":1185931,"uid":62532,"like":26,"dislike":28,"score":-2,"citedBy":3,"replyTime":"2019-06-04T14:43:38.000Z","msg":"大勝 大敗<br />\n去到中學先知原來大敗都係贏"},"citedBy":2,"replyTime":"2019-06-04T14:59:14.000Z","msg":"呢個真 點解咁多負評"},"citedBy":1,"replyTime":"2019-06-05T01:20:03.000Z","msg":"即係點？"},{"pid":"38edf18d68e04946eb90527dd0d9b4eb368431d0","tid":1185931,"uid":14075,"like":0,"dislike":0,"score":0,"quote":{"pid":"ba3453c6506ea97ffc1f2e066bd1f198ab3189ea","tid":1185931,"uid":51612,"like":0,"dislike":0,"score":0,"quote":{"pid":"847149e0071462e7b9b944bc3b5bff04e3fb7e6b","tid":1185931,"uid":201604,"like":20,"dislike":1,"score":19,"quote":{"pid":"0a7c2762f9be1f164f36c2bf1f08920e1475f915","tid":1185931,"uid":62532,"like":26,"dislike":28,"score":-2,"citedBy":3,"replyTime":"2019-06-04T14:43:38.000Z","msg":"大勝 大敗<br />\n去到中學先知原來大敗都係贏"},"citedBy":2,"replyTime":"2019-06-04T14:59:14.000Z","msg":"呢個真 點解咁多負評"},"citedBy":1,"replyTime":"2019-06-05T01:20:03.000Z","msg":"即係點？"},"citedBy":0,"replyTime":"2019-06-05T02:26:52.000Z","msg":"戰勝 &amp; 擊敗"},{"pid":"84775676e7ad22ffc9b9022d7948311b73e420aa","tid":1185931,"uid":225371,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-05T02:53:48.000Z","msg":"上街：走上街道，由於街道係主要通道/大路，所以用上。例如上高速公路。<br />\n<br />\n落街：同上街有同樣意思。應該係因為城市化，大部分人都居住在樓層，所以&ldquo;落街&rdquo;會比&ldquo;上街&rdquo;形容得更貼切。<br />\n<br />\n利申：個人睇法"},{"pid":"f0ee30a0c0ac15e6a362fb8ca242bf0cf13a5cf7","tid":1185931,"uid":96708,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-05T03:04:05.000Z","msg":"落街遊行<br />\n出街遊客<br />\n上街遊行<br />\n<br />\n啱呀，無分別<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: x-small;\"><span style=\"color: teal;\">曲</span></span>"}]}