":2,"dislike":0,"score":2,"quote":{"pid":"d76afb06defa14099b32f7d1e777128a53d44f09","tid":2184403,"uid":46943,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-01T13:44:03.000Z","msg":"信唔過本地人咩<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-01T14:16:36.000Z","msg":"支那賤畜內心一樣唔相信共產黨<br />\n最初貿易戰初期，減少美國肉類，<br />\n引入俄羅斯非洲猪苗叫支那賤畜養猪，養完玩猪瘟又要佢地殺晒,殺完唔比錢,<br />\n之後又叫佢地再養,點知又再爆多次猪瘟，又再殺咁樣玩咗二次<br />\n支那賤畜就唔想養猪養了<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"a71704865fc6d081a9e35a64d92678dc94ae82e3","tid":2184403,"uid":3776,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-01T14:19:22.000Z","msg":"已經養緊14億豬"},{"pid":"2faff7e185c3a6dc688de236a127894fc21a741d","tid":2184403,"uid":245849,"like":1,"dislike":0,"score":1,"quote":{"pid":"17c5fac4cd065fb5fdcb91ddec439ff3c478c4e4","tid":2184403,"uid":296600,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2020-09-01T13:45:28.000Z","msg":"阿根廷人頭腦幾清醒，唔會淨係為經濟利益隻眼開隻眼閉"},"citedBy":0,"replyTime":"2020-09-01T14:22:21.000Z","msg":"經濟利益關佢班民眾撚事<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n係藍屍咁白痴覺得四叔發達佢有份"},{"pid":"18a3e150841d88ad854b6f02e973eb6ed029e58d","tid":2184403,"uid":296600,"like":0,"dislike":0,"score":0,"quote":{"pid":"aaa088935f492ffe860cbb1612a63c1ddb5c400e","tid":2184403,"uid":58147,"like":2,"dislike":0,"score":2,"quote":{"pid":"17c5fac4cd065fb5fdcb91ddec439ff3c478c4e4","tid":2184403,"uid":296600,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2020-09-01T13:45:28.000Z","msg":"阿根廷人頭腦幾清醒，唔會淨係為經濟利益隻眼開隻眼閉"},"citedBy":1,"replyTime":"2020-09-01T14:04:46.000Z","msg":"兩樣嘢，<br />\n一個係賺錢嘅政府，<br />\n另一個係無涉及利益嘅團體組織。"},"citedBy":0,"replyTime":"2020-09-01T14:34:13.000Z","msg":"不過可能有班阿根廷商家支持都未定<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}