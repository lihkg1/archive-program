017%2F05%2F10%2F110750_201b9c199b59cb5bd2ed71f2315b6c92.jpg&h=f46d14e3&s={SIZE}\" /><br />\n好耐之前 即係阿波羅未賣森巴撈麵之前已經有<br />\n麵質 乾蒜 味精都係最好食<br />\n不過之後出咗唔同版本喇"},{"pid":"f4d8c3c6b007439761df709bcad5f57e59ab8888","tid":236732,"uid":13554,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-10T03:10:57.000Z","msg":"<blockquote>好撚鹹<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n而家係咸咗啲<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 可能佢味精多咗就返啲鍾意食咸嘅人？<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n你落少啲味精就ok<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"f01dc52d7ebcfb08c583aa6a2da5ca57968bb639","tid":236732,"uid":78971,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-10T03:12:12.000Z","msg":"<blockquote>腎功能出問題未<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 真心唔好食咁多<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n食咗廿年身體慣曬<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"76e6b098898bc201fc75b8a2a1fe5fa0ccdbe8cb","tid":236732,"uid":1249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-10T03:14:38.000Z","msg":"太油<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"807e4c7ba05115914774d6fa5a26c47441269951","tid":236732,"uid":13554,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-10T03:14:46.000Z","msg":"不過七仔煮得好撚難食<br />\n唔明叫點解<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 明明都係咁煮<br />\n啲味完全唔同<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3701d61a95b3a171d7a929734a3774c621a02899","tid":236732,"uid":1249,"like":0,"dislike"