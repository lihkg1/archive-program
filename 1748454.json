ote":{"pid":"d47c3ceaa3fcf8df44b1c8b3be4e95442317203c","tid":1748454,"uid":159928,"like":2,"dislike":3,"score":-1,"citedBy":1,"replyTime":"2019-11-23T16:34:47.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-11-23T16:39:26.000Z","msg":"點解叫人投票要貼bam圖<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"68ec32db85f0dcaa6a7a3d4b1980fb2c4e19c427","tid":1748454,"uid":159928,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T16:40:31.000Z","msg":"此回覆已被刪除"},{"pid":"e4d515d59bd732941240d942786c990c271c1fee","tid":1748454,"uid":232261,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T16:40:35.000Z","msg":"推"},{"pid":"fb3c1bef4bd10506e66dd7eb007f5ceb12502f25","tid":1748454,"uid":45332,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T16:40:42.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"8d820e10e07cd270e429fe356d4b2eae78d671b3","tid":1748454,"uid":53003,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T16:40:44.000Z","msg":"叫人投票都唔使bam圖<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5ac1e1052a82eca32d9c393e953db94f360c18a4","tid":1748454,"uid":221265,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-23T16:41:30.000Z","msg":"當大家仲好有原則咁話個game唔公平<br />\n冇用<br />\n有大bug<br />\n唔投依個唔投嗰個<br />\n<br />\n甚至投保皇<br />\n<br />\n<br />\n相信保皇同中共已開定香檳<br />\n統一戰線大成功<br />\n<br />\n用反間計離間計<br />\n<br />\n不戰而勝<br />\n<br />\n全世界傳媒，議員開哂口話今次係變相公投<br />\n世界各國傳媒喺香港 議員嚟觀察<br />\n<br />\n但香港人畢竟多政治白痴<br />\n喺受薪三毛 分化撚橫行嘅鋪天蓋地宣傳下<br />\n唔團結 好有原則 好冇策略<br />\n對住個狡猾同最叻玩政治，最叻分化嘅政權 <br />\n條路自己揀<br />\n仆街唔好喊<br />\n<br />\n唉 我只係覺得好可惜<br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\">如果輸咗<br />\n萬劫不復<br />\n<br />\n一定投反建制<br />\n得建制同熱狗對決 就為大局投lesser evil 熱狗<br />\n<br />\n大家聽日早啲去投票<br />\n全家總動員<br />\nCall齊親友</span>"},{"pid":"5c1846c1770ea65ec15f20d42d7e534a42a0d2f2","tid":1748454,"uid":279401,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T16:41:53.000Z","msg":"今日投票要咁做<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1748421\" data-auto-link target=\"_blank\">https://lih.kg/1748421</a>"},{"pid":"2477c2bae074fed698a92d201b5c6af3270b1606","tid":1748454,"uid":232261,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T16:45:00.000Z","msg":"Solomon Yue同David Webb都出左聲"},{"pid":"8e8f4d67bbb12e81cbe0cdca86612d55f304774d","tid":1748454,"uid":90328,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T16:45:24.000Z","msg":"推"},{"pid":"452f083364a458a6c78077c68ff8f87a4d61be69","tid":1748454,"uid":232261,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T01:13:28.000Z","msg":"推"},{"pid":"dbb224bd0d1705ef29745ae73b667190383a8ae6","tid":1748454,"uid":291002,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-24T01:18:47.000Z","msg":"仲有許智峰 區軒 同譚文豪點計？ 連郭家麒都勇到俾人告"},{"pid":"6afee4dfd97ed1a9431c0385e0bae9b58616a809","tid":1748454,"uid":216664,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T01:22:58.000Z","msg":"記得投票不過<br />\n<span style=\"font-size: x-large;\">制度內只有假民主，可以DQ可以舞弊</span>"}]}