{"tid":1085414,"cid":11,"subCid":0,"title":"明 日 戰 記","createTime":"2019-03-31T06:51:02.000Z","updateTime":"2019-04-02T01:09:05.000Z","uid":184679,"like":12,"dislike":1,"uniUserReply":13,"replies":[{"pid":"79003a9f5dcc2556e9b7433e543a715303c1c11e","tid":1085414,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-31T06:51:02.000Z","msg":"<img src=\"https://wmoov.com/assets/movie/photo/201903/FB_IMG_1552727886107_1552736641.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwmoov.com%2Fassets%2Fmovie%2Fphoto%2F201903%2FFB_IMG_1552727886107_1552736641.jpg&h=7dec98a5&s={SIZE}\" /><br />\n<br />\n<br />\n片長 : --<br />\n級別 : --<br />\n語言 : 粵語 (中英文字幕)<br />\n分類 : 動作/科幻<br />\n上映 : 2019-06-27<br />\n<br />\n導演<br />\n吳炫輝<br />\n<br />\n主演<br />\n劉青雲、古天樂、劉嘉玲、張家輝、姜皓文<br />\n<br />\n故事簡介<br />\n2055年的未來世界，外星異種藤蔓「潘朵拉」入侵，造成人類異變，空氣以及水源都受到污染，曾經繁華的都市因而荒廢，倖存人類為了生存，必須與將要「潘朵拉」決一死戰，更要面對「天幕計劃」的謎團。"},{"pid":"b528ddfc25698e86de476da873f2834bbaea2b45","tid":1085414,"uid":1441,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-31T07:24:08.000Z","msg":"6月上<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0369673d02ffcf3c9e9ca051fc731b830d9be007","tid":1085414,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-31T16:02:01.000Z","msg":"<img src=\"https://upload.wikimedia.org/wikipedia/zh/thumb/7/75/Warriors_of_Future.jpg/220px-Warriors_of_Future.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.wikimedia.org%2Fwikipedia%2Fzh%2Fthumb%2F7%2F75%2FWarriors_of_Future.jpg%2F220px-Warriors_of_Future.jpg&h=f05bdb7f&s={SIZE}\" />"},{"pid":"99ad2cbe11cbf039bbebc93f838e465ac58da8f2","tid":1085414,"uid":108273,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-31T16:06:04.000Z","msg":"<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bomb.gif\" class=\"hk