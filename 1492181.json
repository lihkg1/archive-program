80e1f9256d69aaa4864843084903f540baa682","tid":1492181,"uid":13106,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T18:37:34.000Z","msg":"搞Boycott"},"citedBy":0,"replyTime":"2019-08-21T01:02:51.000Z","msg":"Boycott 支那 series！！<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><br />\n我要攬炒！！我冇波睇 支那人都唔可以有波睇！！<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"55989b0628dda494bc91655d13b7d0093182205e","tid":1492181,"uid":128100,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T01:19:19.000Z","msg":"銀仔表示要搵錢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d66e69825a73da4cef358b328ad7eb6319e18c7e","tid":1492181,"uid":29900,"like":1,"dislike":0,"score":1,"quote":{"pid":"55989b0628dda494bc91655d13b7d0093182205e","tid":1492181,"uid":128100,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T01:19:19.000Z","msg":"銀仔表示要搵錢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-21T02:56:07.000Z","msg":"咁就要班球員明知老解喺隔離都照打<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: red;\"><strong><span style=\"font-size: xx-large;\">我要攬炒!!<br />\n取消NBA Preseason 支那 series深圳站!!</span></strong></span>"},{"pid":"dc20f12f145f4695f4a974413093b1e04f000d0c","tid":1492181,"uid":29900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T06:13:04.000Z","msg":"推"}]}