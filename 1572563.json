有得諗，就幫手spread出去同用力push，小弟廢J P牌仔自push都做唔到</span></span></strong>，sosaad。"},{"pid":"d4410beb00ee150a2bacd4cfd551ede8c7c0e3a5","tid":1572563,"uid":98151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T15:27:32.000Z","msg":"<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" />"},{"pid":"4e5194557b048670bd24be611f0765503e1b990e","tid":1572563,"uid":98151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T16:47:16.000Z","msg":"<img src=\"/assets/faces/mf/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6651b4f5b7e95d585aa38253fb820e78da4413ce","tid":1572563,"uid":98151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T23:50:19.000Z","msg":"推"},{"pid":"3ec00e8b826b4e062322e7fa471c628a15558ba3","tid":1572563,"uid":17967,"like":0,"dislike":0,"score":0,"quote":{"pid":"02c0dd21a939f41e0c0087d5f396f8a83ce4f9eb","tid":1572563,"uid":98151,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa3904dc8e79bb6a29eb1d73f726f9b2c2428e9a","tid":1572563,"uid":17967,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-17T14:21:22.000Z","msg":"10月23唔得？😞"},"citedBy":2,"replyTime":"2019-09-17T14:22:30.000Z","msg":"你話呢"},"citedBy":1,"replyTime":"2019-09-18T06:53:01.000Z","msg":"都係天秤喎"},{"pid":"60067202c0c91ba2f625cbf4af7e3a9db9a35f55","tid":1572563,"uid":98151,"like":0,"dislike":0,"score":0,"quote":{"pid":"3ec00e8b826b4e062322e7fa471c628a15558ba3","tid":1572563,"uid":17967,"like":0,"dislike":0,"score":0,"quote":{"pid":"02c0dd21a939f41e0c0087d5f396f8a83ce4f9eb","tid":1572563,"uid":98151,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa3904dc8e79bb6a29eb1d73f726f9b2c2428e9a","tid":1572563,"uid":17967,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-17T14:21:22.000Z","msg":"10月23唔得？😞"},"citedBy":2,"replyTime":"2019-09-17T14:22:30.000Z","msg":"你話呢"},"citedBy":1,"replyTime":"2019-09-18T06:53:01.000Z","msg":"都係天秤喎"},"citedBy":0,"replyTime":"2019-09-18T07:11:37.000Z","msg":"睇你點計"},{"pid":"3058bdac42f2caa0fb115a0ec7ec50e529b8b9