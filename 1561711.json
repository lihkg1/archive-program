\"https://na.cx/i/yM2WNBw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyM2WNBw.jpg&h=9433ed2f&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/zasf29R.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fzasf29R.jpg&h=aca10195&s={SIZE}\" />"},{"pid":"fe8060b948771beabab0b19264c24f50f40a9b7c","tid":1561711,"uid":18844,"like":0,"dislike":4,"score":-4,"quote":{"pid":"490e4ad107c67efef912dfd6b6d4fae19fe31a2f","tid":1561711,"uid":67434,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-11T23:43:25.000Z","msg":"校園白色恐怖"},"citedBy":3,"replyTime":"2019-09-12T00:29:29.000Z","msg":"可能個阿sir無睇開真&middot;新聞，或者政治冷感先無去接觸更多既source<br />\n<br />\n真真正正解決「誤會」既方法，係溝通！<br />\n建議同學仔應該將黑驚濫暴、插贓嫁禍及非禮少女既直播精華打包儲起，遲啲用善意既態度俾黃sir睇，俾佢知道「真相」。<br />\n<br />\n我估計，佢而家既想法係：「學生被假新聞洗腦做出愚蠢行為。」<br />\n<br />\n而家要做既係：<br />\n大家睇緊的野係直播內容，一手戰地真實資料，並唔係「假新聞」！<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n樓上都有巴絲提，可能黃sir係個類同人溝通唔係好得<br />\n<br />\n講野唔理人感受，但唔代表佢心地差係壞人<br />\n<br />\n而家唔係街外人，係你老師<br />\n唔應該下下都民革式批鬥<br />\n真心想爆粗，唔好因為上得多連登，就學埋晒啲衰野，下下都網上批鬥人<br />\n<br />\n利申：好似中2讀垃圾班，數學佢教，某次測驗後，全班都好低分，結果佢同全班講「你地在座無一個人可以原校升到中六」<br />\n<br />\n我當時都呆撚左（但結果我係佢預料之外，升到中六又入到U）<br />\n<br />\n但我個人對佢又無乜嘢，雖然佢下下講野好似有骨咁？尤其是對成績差，操行差既壞學生<br />\n<br />\n但佢應該又真係俾心機教既老師來，聰明既學生跟佢應該學到野<br />\n<br />\n又成日9up講故事（歷史/神話/冷知識），呢樣我好鐘意，雖然好多人覺得係廢話<br />\n<br />\n我有個朋友係學校打橋牌既，上過佢屋企，朋友話佢對自己學生好好（friend既愛徒、叻學生）<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n聽聞佢而家係訓導主任<br />\n佢而家只係叫你地返課室唔好嘈<br />\n<br />\n真正藍絲仆街做法會係點？<br />\n首先同學記過，寫悔過書，再見埋家長乜乜乜，用盡所有權力咁樣來打壓你<br />\n再出公告俾全校上下禁止一切有關反送中既活動、文宣..."},{"pid":"1a424e2e54538465dc10e7deaf2023cdb258d3d0","tid":1561711,"uid":146074,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-09-12T02:14:33.000Z","msg":"推 田家炳一分<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" />"},{"pid":"8a02474cdf1db13c3d21c31e6fb2a37ab9dd8912","tid":1561711,"uid":243677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T02:18:07.000Z","msg":"<img src=\"/assets/faces/mf/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/fire.gif\" class=\"hkgmoji\" />"},{"pid":"c1ba0690aa81b48b4f0a9982028ad3a3fc2131f4","tid":1561711,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T02:21:46.000Z","msg":"<img src=\"/assets/faces/mf/dead.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/clown.gif\" class=\"hkgmoji\" />"},{"pid":"03524a608f0d6494a5d47f7537404ffffc216afd","tid":1561711,"uid":266207,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-09-12T02:37:45.000Z","msg":"曱甴黃仲做緊訓導主任？<br />\n今日屯門有人鏈，等我返去會一會佢老人家先"},{"pid":"3f536e8146fcdd9654d85538ceabda451370347a","tid":1561711,"uid":164511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T02:44:12.000Z","msg":"diu 原來係曱甴黃<br />\n食屎啦叫佢, 驚西, 煮到佢冇得再教<img src=\"/assets/faces/mf/fire.gif\" class=\"hkgmoji\" />"},{"pid":"b994b4df232c98144d29e296b73da04e5fc404ed","tid":1561711,"uid":117282,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T02:45:02.000Z","msg":"接放學"},{"pid":"60c93c5ca070eee225a1050ce81315c3e9cd3821","tid":1561711,"uid":222970,"like":0,"dislike":0,"score":0,"quote":{"pid":"acd0feaa41e28a19d64e07180464a086f6bd55c2","tid":1561711,"uid":67434,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-09-11T16:48:56.000Z","msg":"開學後抗爭行動遍地開花，多間中學都有學生在校內高叫口號和張貼標語。《蘋果》獲悉，屯門仁愛堂田家炳中學有老師涉在校內打壓學生。該名老師形容示威者皆為「暴徒」，又不斷高聲質問學生「你係咪撐（暴徒）？」，並聲言「全世界都知香港傳媒講緊大話」；他又涉高聲喝罵及威嚇學生不得再在校內叫口號，有學生受驚啜泣。校方稱正在調查，會嚴肅跟進。<br />\n<br />\n<br />\n記者 鄧力行<br />\n<br />\n多名仁愛堂田家炳中學學生向《蘋果》投訴，數十名同學上周四（5日）於午膳時間在走廊展示「光復香港 時代革命」標語並高叫口號。一名黃姓訓導老師到場，要求同學立即返回課室。翌日（6日）同學再於午膳時間叫口號，<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">黃老師再次「清場」並追入課室，指着一名同學高聲質問「你係咪撐？」重複問了4至5次。有同學不解反問「撐乜嘢？」黃大聲回應：「你哋係咪撐暴徒？」</span></span></strong><br />\n<br />\n<br />\n當日在場學生形容，黃老師當時情緒激動，向學生高聲喝罵。他以「暴徒」形容示威者，批評他們阻塞交通和破壞公物，「全世界都知香港傳媒講緊大話」，<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">又威嚇同學不可再叫口號：「雖然我唔可以好似暴徒咁上嚟打你哋，但係我會不斷咁上嚟講同一番說話！」</span></span></strong><br />\n<br />\n有在場女學生向《蘋果》憶述，當日與多名同學一同受驚落淚，她至今猶有餘悸，「真係好驚，而家講返我自己都好驚。讀咗書咁耐，都未試過見一個老師咁樣，用政治理由咁樣去鬧你，我覺得直程係恐嚇⋯⋯成件事好恐怖」。<br />\n<br />\n據悉，涉事的黃老師本周一（9日）開始請假至今，校方同日在禮堂舉行座談會，讓全校同學和關心事件的家長和校友參加。《蘋果》取得座談會錄音，有家長在會上指出，女兒當日回家後情緒激動，「好似俾人質咗一搥咁」，認為該名老師即使不公開向全校學生交代，校方亦應與受影響班別傾談，強調學生情緒的確因老師言行而感到不舒服，認為問題需要解決。<br />\n<br />\n副校長孔敏芳在會上回應稱，學校不同持份者會有不同立場，校方指引未能清楚告訴老師，應如何處理同學在校內喊叫的情況，而老師就其職責有必要維持秩序，「但係亦都因為指引不清，老師有啲行動，但我未了解清楚背後原因」，認為指引不清是學校管理層的責任，校方需要時間處理。<br />\n<br />\n仁愛堂田家炳中學回覆《蘋果》查詢時表示，正在調查事件，會嚴肅處理及跟進。<br />\n<br />\n<br />\n<a href=\"https://hk.news.appledaily.com/local/realtime/article/20190912/60033903\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20190912%2F60033903&d=y6uglPlKbSLkZz%2BcPL4okZMi8MJ45PejcSMOUziyDL0%3D&h=46bcb9f8\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20190912%2F60033903&h=df4947c7\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/realtime/article/20190912/60033903</a>"},"citedBy":0,"replyTime":"2019-09-12T02:45:50.000Z","msg":"年輕人有前途！堅毅！"},{"pid":"4d2a88afe8e293cc590427a9c2318187e3349074","tid":1561711,"uid":42461,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-12T03:01:41.000Z","msg":"呢條蛋散正一教畜<img src=\"/assets/faces/mf/dead.png\" class=\"hkgmoji\" />"},{"pid":"c44a21b0928c5b0c46103560baa184c5f9294328","tid":1561711,"uid":166474,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T03:04:48.000Z","msg":"沒有暴徒，只有暴政<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c8c1e20cc7d6a04d0a1832bf78562f7bf2525256","tid":1561711,"uid":144626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T03:12:55.000Z","msg":"打尻個教畜喇"},{"pid":"869ed30c19fddb72651ee6881350b4ddd9dc98f7","tid":1561711,"uid":66686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T03:29:19.000Z","msg":"又威嚇同學不可再叫口號：「雖然我唔可以好似暴徒咁上嚟打你哋，但係我會不斷咁上嚟講同一番說話！」<br />\n<br />\n指黑警？？？？？？？"},{"pid":"6204945fd3929af8fe125617123cc0a9e3826d9f","tid":1561711,"uid":997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T03:34:02.000Z","msg":"曱甴<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"9a95fe5389bbe238540859e691a35e465d490068","tid":1561711,"uid":306337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T03:38:10.000Z","msg":"圍鳩佢啦 係咪屯門嗰間?"},{"pid":"a3ae34d2265b955479fa3738a22bb0adfc8fb266","tid":1561711,"uid":1335,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T04:45:47.000Z","msg":"推"},{"pid":"1720051400c51d4210f9bcdd95555637d3151866","tid":1561711,"uid":70227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T04:47:42.000Z","msg":"推"},{"pid":"2a46888479af9e07aabb986b2b56437e4e619b22","tid":1561711,"uid":261430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T04:58:01.000Z","msg":"全世界都知香港政府講緊大話阿<img src=\"/assets/faces/mf/angry.gif\" class=\"hkgmoji\" />"},{"pid":"2235d53dd048abaf50154dcef13a1976682f7fc3","tid":1561711,"uid":121666,"like":1,"dislike":0,"score":1,"quote":{"pid":"fe8060b948771beabab0b19264c24f50f40a9b7c","tid":1561711,"uid":18844,"like":0,"dislike":4,"score":-4,"quote":{"pid":"490e4ad107c67efef912dfd6b6d4fae19fe31a2f","tid":1561711,"uid":67434,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-11T23:43:25.000Z","msg":"校園白色恐怖"},"citedBy":3,"replyTime":"2019-09-12T00:29:29.000Z","msg":"可能個阿sir無睇開真&middot;新聞，或者政治冷感先無去接觸更多既source<br />\n<br />\n真真正正解決「誤會」既方法，係溝通！<br />\n建議同學仔應該將黑驚濫暴、插贓嫁禍及非禮少女既直播精華打包儲起，遲啲用善意既態度俾黃sir睇，俾佢知道「真相」。<br />\n<br />\n我估計，佢而家既想法係：「學生被假新聞洗腦做出愚蠢行為。」<br />\n<br />\n而家要做既係：<br />\n大家睇緊的野係直播內容，一手戰地真實資料，並唔係「假新聞」！<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n樓上都有巴絲提，可能黃sir係個類同人溝通唔係好得<br />\n<br />\n講野唔理人感受，但唔代表佢心地差係壞人<br />\n<br />\n而家唔係街外人，係你老師<br />\n唔應該下下都民革式批鬥<br />\n真心想爆粗，唔好因為上得多連登，就學埋晒啲衰野，下下都網上批鬥人<br />\n<br />\n利申：好似中2讀垃圾班，數學佢教，某次測驗後，全班都好低分，結果佢同全班講「你地在座無一個人可以原校升到中六」<br />\n<br />\n我當時都呆撚左（但結果我係佢預料之外，升到中六又入到U）<br />\n<br />\n但我個人對佢又無乜嘢，雖然佢下下講野好似有骨咁？尤其是對成績差，操行差既壞學生<br />\n<br />\n但佢應該又真係俾心機教既老師來，聰明既學生跟佢應該學到野<br />\n<br />\n又成日9up講故事（歷史/神話/冷知識），呢樣我好鐘意，雖然好多人覺得係廢話<br />\n<br />\n我有個朋友係學校打橋牌既，上過佢屋企，朋友話佢對自己學生好好（friend既愛徒、叻學生）<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n聽聞佢而家係訓導主任<br />\n佢而家只係叫你地返課室唔好嘈<br />\n<br />\n真正藍絲仆街做法會係點？<br />\n首先同學記過，寫悔過書，再見埋家長乜乜乜，用盡所有權力咁樣來打壓你<br />\n再出公告俾全校上下禁止一切有關反送中既活動、文宣..."},"citedBy":0,"replyTime":"2019-09-12T04:58:35.000Z","msg":"你好似想幫個阿sir口 但好似越幫越衰<br />\n照你咁講 佢對叻學生就好好 對差學生就成日講野有骨<br />\n聰明既學生先跟佢學到野 簡單咁講 唔好話做唔到有教無類咁高要求 直頭係好嚴重既差別待遇<br />\n同埋 而家點樣係民革式批鬥? 佢因為政治立場屌完人兇完人 比人投訴同係網上面討論就係民革?有無人逼佢跪低認錯訓豬欄再鞭打佢?<br />\n佢講野唔理人感受 又要人地講野理佢感受?<br />\n訓導主任大哂?佢可以叫人唔好嘈 但佢而家係質問學生係咪支持暴徒 同叫人唔好嘈係兩回事 而且當時係lunch time 我唔知個間學校咩規矩 正常係嘈到拆天都無人理 今次明顯同佢訓導主任既職位無關 佢係利用職位去打壓不同意見既學生"},{"pid":"0941c170ddf94c07fb02fb8236dc4c2aea5d7384","tid":1561711,"uid":190970,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T05:24:43.000Z","msg":"有無非禮女學生"},{"pid":"a247432fd835fea99bb561adf750e9240a91e947","tid":1561711,"uid":49812,"like":0,"dislike":0,"score":0,"quote":{"pid":"e18822950495bd3fa1508876e6c25387fe582758","tid":1561711,"uid":6103,"like":29,"dislike":0,"score":29,"citedBy":2,"replyTime":"2019-09-11T17:00:36.000Z","msg":"件教畜講完就冧水<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n咁撚正氣凜然做咩放假丫<br />\n聽土共話，敢於抗爭，旗幟鮮明咁返學校繼續做啦，屌你老母<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-12T05:26:43.000Z","msg":"<a href=\"https://petitions.whitehouse.gov/petition/request-abolish-united-states-hong-kong-policy-act-if-hong-kong-implement-emergency-regulations-ordinance\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Frequest-abolish-united-states-hong-kong-policy-act-if-hong-kong-implement-emergency-regulations-ordinance&d=y6uglPlKbSLkZz%2BcPL4okZMi8MJ45PejcSMOUziyDL0%3D&h=b3bd16a4\" target=\"_blank\">https://petitions.whitehouse.gov/petition/request-abolish-united-states-hong-kong-policy-act-if-hong-kong-implement-emergency-regulations-ordinance</a>"},{"pid":"7d21b1857644ce05005f7133e66fbe66a84ecbf9","tid":1561711,"uid":77092,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T05:31:13.000Z","msg":"此回覆已被刪除"},{"pid":"b340635599de135574e00593a0fc48c4bddbb221","tid":1561711,"uid":227581,"like":0,"dislike":0,"score":0,"quote":{"pid":"152c62fcd4da3b580774a6d580c52d9a6bfdf6e9","tid":1561711,"uid":151199,"like":1,"dislike":0,"score":1,"citedBy":4,"replyTime":"2019-09-11T17:19:40.000Z","msg":"曱甴黃<br />\n條友好似10A<br />\n利申 校友"},"citedBy":1,"replyTime":"2019-09-12T05:31:53.000Z","msg":"我畢業果年仲係黎Sir做訓導呀頭<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n今日收工番去睇下"},{"pid":"1626bdcde9e1268c71cace539d9f8987eaf7642e","tid":1561711,"uid":10757,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-12T05:34:00.000Z","msg":"咩樣架<img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"f87503904a345f25658c85088e925c355eb6ed42","tid":1561711,"uid":227627,"like":0,"dislike":0,"score":0,"quote":{"pid":"87c29d8c8fe52664e34ed7cff011f0540d401724","tid":1561711,"uid":61106,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-09-11T17:12:58.000Z","msg":"邊個黃老師？我番去屌7佢"},"citedBy":0,"replyTime":"2019-09-12T05:39:36.000Z","msg":"黃偉智<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" /><br />\n成世都記得呢個仆街嘅名"},{"pid":"2a1a6e1362aaeff5a52db880716a7202cbe5cf9a","tid":1561711,"uid":62948,"like":0,"dislike":0,"score":0,"quote":{"pid":"b340635599de135574e00593a0fc48c4bddbb221","tid":15617