ormal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"0a9552aa785a9b73788754f23548b6d943a74a17","tid":1473212,"uid":15070,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-08-15T06:49:56.000Z","msg":"真<br />\n人瑞俾人逼㗎<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n我諗周柏豪個case一樣"},{"pid":"8af97dd806f958a8a36bcdc5564e625cae79feea","tid":1473212,"uid":307683,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-15T07:00:05.000Z","msg":"其實好多藝人發佈嘅立場同言論都唔係藝人本人可以左右，主要係經理人公司控制。而經理人公司又會因各方面(例如內地投資公司/電影公司/電視台等)受壓，先被迫要出護旗手/表示維護中共主權 etc<br />\n<br />\n如果唔做，係有可能要賠錢，被封殺。唔係個個都可以唔賺人仔又有飯開，香港市場個餅好細架。所以係 經營管理角度係可以理解。<br />\n<br />\n同意真心奶，撐警果批要大大力屌，入清算list。"},{"pid":"fa6bc68029ef44875539d37fb25ea5bfb3d2d103","tid":1473212,"uid":246787,"like":0,"dislike":0,"score":0,"quote":{"pid":"0a9552aa785a9b73788754f23548b6d943a74a17","tid":1473212,"uid":15070,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-08-15T06:49:56.000Z","msg":"真<br />\n人瑞俾人逼㗎<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n我諗周柏豪個case一樣"},"citedBy":1,"replyTime":"2019-08-15T10:35:32.000Z","msg":"但人瑞不停比人屌喎係連登 ph就做聖人"},{"pid":"3189e0dcc3471430bef65b6f6b8a5fe858d87a97","tid":1473212,"uid":15070,"like":2,"dislike":1,"score":1,"quote":{"pid":"fa6bc68029ef44875539d37fb25ea5bfb3d2d103","tid":1473212,"uid":246787,"like":0,"dislike":0,"score":0,"quote":{"pid":"0a9552aa785a9b73788754f23548b6d943a74a17","tid":1473212,"uid":15070,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-08-15T06:49:56.000Z","msg":"真<br />\n人瑞俾人逼㗎<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n我諗周柏豪個case一樣"},"citedBy":1,"replyTime":"2019-08-15T10:35:32.000Z","msg":"但人瑞不停比人屌喎係連登 ph就做聖人"},"citedBy":0,"replyTime":"2019-08-15T10:36:32.000Z","msg":"識人做佢公司 真係俾人逼 如果唔係賠錢賠到嘔"},{"pid":"7e455cfc2d5c066ec0c8dba41aff412f81b2fadf","tid":1473212,"uid":43061,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-08-15T10:37:58.000Z","msg":"兩種都要屌啦ON9<img src=\"/assets/f