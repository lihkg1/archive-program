%2F%2Fwww.physicsclassroom.com%2Fclass%2F1DKin%2FLesson-6%2FKinematic-Equations.&d=fHP5IXxumHaeL4ipNikGLaWGW%2FHqnCni%2B1xW1zXhD2s%3D&h=f134e544\" data-auto-link target=\"_blank\">http://www.physicsclassroom.com/class/1DKin/Lesson-6/Kinematic-Equations.</a><br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"72cfc7381f826aa5ac82a3e687434d514c69df55","tid":575223,"uid":89956,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-28T05:31:00.000Z","msg":"重點係最高果一點只係得horizontal既speed<br />\n之後就可以搵到initial同final既vertical既speed係幾多"},{"pid":"d5ce613843213808d8e79f7bc36edb745b0f50f0","tid":575223,"uid":119091,"like":0,"dislike":0,"score":0,"quote":{"pid":"73716f7866f3886600b7bea1434a7795f99708eb","tid":575223,"uid":165187,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-28T05:28:42.000Z","msg":"use kinematics equations to solve.<br />\n<br />\n<a href=\"http://www.physicsclassroom.com/class/1DKin/Lesson-6/Kinematic-Equations.\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.physicsclassroom.com%2Fclass%2F1DKin%2FLesson-6%2FKinematic-Equations.&d=fHP5IXxumHaeL4ipNikGLaWGW%2FHqnCni%2B1xW1zXhD2s%3D&h=f134e544\" data-auto-link target=\"_blank\">http://www.physicsclassroom.com/class/1DKin/Lesson-6/Kinematic-Equations.</a><br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-28T05:43:48.000Z","msg":"識個d formula但唔識solve<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"3d9c81249920a19932066fcb5db9e354001d14eb","tid":575223,"uid":100412,"like":1,"dislike":0,"score":1,"quote":{"pid":"3208d98134c6ae39606ef9bdf7c398acf971b87b","tid":575223,"uid":119091,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-28T05:21:54.000Z","msg":"有冇巴打知呢題點做?<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n(a) 2.07<br />\n(b) 29.9<br />\n(c) 1.13<br />\n(d) 12.1 <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/28/132152_1d73910f6896dceb7364e8907d56dae3.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F28%2F132152_1d73910f6896dceb7364e8907d56dae3.png&h=717d63aa&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-02-28T05:47:38.000Z","msg":"(a)<br />\n(1/2)(m)(12.8^2 - 11.1^2) = mgh<br />\n=&gt; h = 2.07<br />\n<br />\n(b) 11.1 係 horizontal speed<br />\nvertical speed = sqrt(12.8 ^2 - 11.1^2) = 6.37<br />\nangle of projection = arctan(6.37/11.1) = 29.9<br />\n<br />\n(c)<br />\n(1/2)(m)(12.8^2 - 11.9^2) = mgh<br />\n=&gt; h = 1.13<br />\n<br />\n(d)<br />\n設 time of flight 為 t<br />\n考慮 vertical motion<br />\n1.13 = (6.37)t - (1/2)gt^2<br />\nt = 0.212 or 1.09<br />\n<br />\n拎大啲嗰個<br />\nhorizontal distance = (1.09)(11.1) = 12.1"},{"pid":"13f90310380a7ec15aab20c527cb8a201695de28","tid":575223,"uid":119091,"like":0,"dislike":0,"score":0,"quote":{"pid":"3d9c81249920a19932066fcb5db9e354001d14eb","tid":575223,"uid":100412,"like":1,"dislike":0,"score":1,"quote":{"pid":"3208d98134c6ae39606ef9bdf7c398acf971b87b","tid":575223,"uid":119091,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-28T05:21:54.000Z","msg":"有冇巴打知呢題點做?<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n(a) 2.07<br />\n(b) 29.9<br />\n(c) 1.13<br />\n(d) 12.1 <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/28/132152_1d73910f6896dceb7364e8907d56dae3.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F28%2F132152_1d73910f6896dceb7364e8907d56dae3.png&h=717d63aa&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-02-28T05:47:38.000Z","msg":"(a)<br />\n(1/2)(m)(12.8^2 - 11.1^2) = mgh<br />\n=&gt; h = 2.07<br />\n<br />\n(b) 11.1 係 horizontal speed<br />\nvertical speed = sqrt(12.8 ^2 - 11.1^2) = 6.37<br />\nangle of projection = arctan(6.37/11.1) = 29.9<br />\n<br />\n(c)<br />\n(1/2)(m)(12.8^2 - 11.9^2) = mgh<br />\n=&gt; h = 1.13<br />\n<br />\n(d)<br />\n設 time of flight 為 t<br />\n考慮 vertical motion<br />\n1.13 = (6.37)t - (1/2)gt^2<br />\nt = 0.212 or 1.09<br />\n<br />\n拎大啲嗰個<br />\nhorizontal distance = (1.09)(11.1) = 12.1"},"citedBy":0,"replyTime":"2018-02-28T06:02:52.000Z","msg":"感激不盡<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"43b90530d51c1b0f87dfc9306f12522a0cb161dd","tid":575223,"uid":165187,"like":0,"dislike":0,"score":0,"quote":{"pid":"d5ce613843213808d8e79f7bc36edb745b0f50f0","tid":575223,"uid":119091,"like":0,"dislike":0,"score":0,"quote":{"pid":"73716f7866f3886600b7bea1434a7795f99708eb","tid":575223,"uid":165187,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-28T05:28:42.000Z","msg":"use kinematics equations to solve.<br />\n<br />\n<a href=\"http://www.physicsclassroom.com/class/1DKin/Lesson-6/Kinematic-Equations.\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.physicsclassroom.com%2Fclass%2F1DKin%2FLesson-6%2FKinematic-Equations.&d=fHP5IXxumHaeL4ipNikGLaWGW%2FHqnCni%2B1xW1zXhD2s%3D&h=f134e544\" data-auto-link target=\"_blank\">http://www.physicsclassroom.com/class/1DKin/Lesson-6/Kinematic-Equations.</a><br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-28T05:43:48.000Z","msg":"識個d formula但唔識solve<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-28T06:06:22.000Z","msg":"樓下已經幫你solve咗啦， a part係用 conservation of energy. 即係 kinetic energy 轉咗去 potential energy 咁解<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d6d89f70b5b174741883e3b84880bdcb361905f1","tid":575223,"uid":4526,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-02-28T07:05:13.000Z","msg":"Projectile 咁易都唔識，樓豬都係及早drop科算啦<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"62327995ed1de0da85e0736f6edcbb6ac3909aa5","tid":575223,"uid":45914,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-28T07:30:17.000Z","msg":"此回覆已被刪除"},{"pid":"d64e460311309fcbc5c7f4387d5a0845f5854829","tid":575223,"uid":137038,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-28T07:31:36.000Z","msg":"上小卒搵textbook solution"}]}