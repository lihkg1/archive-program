=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f560beca85c556ccd2bc8ce1cbfb249e3cf32954","tid":1880413,"uid":134571,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-15T05:35:28.000Z","msg":"記得加密<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"0efd973fddaf20db4c3449849c676c6e5f075f43","tid":1880413,"uid":125502,"like":0,"dislike":0,"score":0,"quote":{"pid":"f560beca85c556ccd2bc8ce1cbfb249e3cf32954","tid":1880413,"uid":134571,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-15T05:35:28.000Z","msg":"記得加密<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-15T07:46:57.000Z","msg":"梗係費事畀機會員見到搶埋一份<br />\n同埋而家好多人用bot搶裕華網店嗰個<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"50598b4a8df2fa6beb15b061495306e897ef9904","tid":1880413,"uid":125502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-15T07:47:21.000Z","msg":"<img src=\"https://na.cx/i/ubAv0qk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FubAv0qk.jpg&h=ea268c89&s={SIZE}\" /><br />\n<br />\n有大量使用bot兩點八就已經話賣曬？"},{"pid":"ae288e817adb23382bb698ca3625bc47f6bcc177","tid":1880413,"uid":125502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-15T13:25:33.000Z","msg":"<img src=\"https://na.cx/i/sTEAtX6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsTEAtX6.jpg&h=c00fe518&s={SIZE}\" /><br />\n【📣預告：❗明日❗2月16日 莎莎 x THE GULU 網上派籌！📱】<br />\n<br />\n☃❄天氣日漸寒冷，而且間中有雨🌧，為能讓各位可以安全、舒適地購買口罩，我們將於❗明日❗2⃣月1⃣6⃣日(星期日)聯同THE GULU推出網上派籌，讓各位不用風吹雨打，只要安在家中，也可取到籌號，購買口罩😷<br />\n<br />\n是次，我們成功採購約1⃣8⃣0⃣0⃣0⃣包日本Fitty口罩，於莎莎全線8⃣9⃣間分店發售！我們吸取過往經驗，為方便大家，將按照不同區域，開放共8⃣個領籌時段，務求讓大家更有效地領取口罩籌！ <br />\n<br />\n⭐產品：日本Fitty 三層過濾絲滑親膚口罩<br />\n⭐售價：$24.6/包 (7個裝) 😱<br />\n⭐派籌日期：❗明日❗2月16日<br />\n⭐派籌時間：<br />\n時段1⃣ : 上午 9時正開始⏰灣仔區分店 <br />\n時段2⃣ : 上午 9時15分開始⏰中西區、東區、南區分店 <br />\n時段3⃣ : 上午 9時30分開始⏰油尖旺區分店<br />\n時段4⃣ : 上午 9時45分開始⏰油尖旺區、深水埗區分店<br />\n時段5⃣ : 上午 10時正開始⏰九龍城區、黃大仙區、觀塘區、西貢區分店 <br />\n時段6⃣ : 上午 10時15分開始⏰沙田區、大埔區、葵青區、離島區分店 <br />\n時段7⃣ : 上午 10時30分開始⏰北區、荃灣區、葵青區分店 <br />\n時段8⃣ : 上午 10時45分開始⏰元朗區、屯門區分店 <br />\n<br />\n⭐取貨店舖：領籌時所選之莎莎分店 (請參考附圖）<br />\n取貨時間：2⃣月1⃣6⃣日所選分店之營業時間內<br />\n📍每間指定分店各有2⃣1⃣0⃣張籌<br />\n📍因貨量有限，每人憑籌限購1⃣包<br />\n<br />\n產品資料：<br />\n14.5cm x 9cm 適合女士及兒童使用<br />\n通過BFE測試：細菌過濾率  99%<br />\n通過VFE測試：病毒過濾率  99%<br />\n通過PFE測試：顆粒過濾率  99%<br />\n有效過濾99%花粉及飛沫中包含之病菌<br />\n<br />\n🔍領籌須知 <br />\n1⃣ 領取口罩籌前，請細閱條款及細則<br />\n2⃣成功領籌後，代表已預留貨品，請於即日(營業時間內)到領籌時所選之莎莎分店購買貨品<br />\n3⃣購買前須出示THE GULU App之籌號以作掃描確認，截圖或其他形式一律無效<br />\n4⃣口罩籌上顯示的&rdquo;飛號&rdquo;只作內部運作用途，與購買之先後次序無關<br />\n5⃣THE GULU App之籌號可以主頁面下方之「我的」(猩猩頭像)＞「排隊」查看<br />\n6⃣如有任何爭議，莎莎化粧品有限公司及THE GULU 將保留最終決定權<br />\n<br />\n💬有關最新口罩及消毒用品的發售訊息，請繼續留意莎莎Facebook專頁/Instagram 。<br />\n<br />\n#莎莎香港 #sasahk #sasahk_official #莎莎與你齊心抗疫 #全城抗疫 #齊心抗疫情 #一齊打氣加油 #口罩 #洗手液 #消毒用品 #THEGULU"},{"pid":"2c9c86237728c2e4af0eccdd374cd930c52b3eac","tid":1880413,"uid":125502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-16T15:48:12.000Z","msg":"Push"},{"pid":"0a3f6c2081631d55901c79c33e0acbebfc510b17","tid":1880413,"uid":125502,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-16T16:45:02.000Z","msg":"<img src=\"https://na.cx/i/eqpdpKD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeqpdpKD.jpg&h=f9bc4086&s={SIZE}\" />"}]}