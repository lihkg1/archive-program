%97%E7%A7%81%E5%AE%B6%E8%BB%8A%E6%A3%84%E4%B8%83%E6%94%AF%E6%B0%A3%E6%B2%B9%E5%BD%88-%E5%85%A7%E5%9C%B0%E4%BA%BA%E5%8F%8A%E6%B8%AF%E7%94%B7%E8%A2%AB%E8%90%BD%E6%A1%88%E8%B5%B7%E8%A8%B4-%E4%BB%8A%E6%97%A9%E7%B2%89%E5%B6%BA%E6%8F%90%E5%A0%82\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E7%25AA%2581%25E7%2599%25BC%2F364895%2F%25E5%2585%2583%25E6%259C%2597%25E7%25A7%2581%25E5%25AE%25B6%25E8%25BB%258A%25E6%25A3%2584%25E4%25B8%2583%25E6%2594%25AF%25E6%25B0%25A3%25E6%25B2%25B9%25E5%25BD%2588-%25E5%2585%25A7%25E5%259C%25B0%25E4%25BA%25BA%25E5%258F%258A%25E6%25B8%25AF%25E7%2594%25B7%25E8%25A2%25AB%25E8%2590%25BD%25E6%25A1%2588%25E8%25B5%25B7%25E8%25A8%25B4-%25E4%25BB%258A%25E6%2597%25A9%25E7%25B2%2589%25E5%25B6%25BA%25E6%258F%2590%25E5%25A0%2582&d=TNp%2FFCzVUvAW3I%2FC9AhTY1T2VSzVBU3ss%2BeERvjOeOk%3D&h=24dd55df\" data-auto-link target=\"_blank\">https://www.hk01.com/%E7%AA%81%E7%99%BC/364895/%E5%85%83%E6%9C%97%E7%A7%81%E5%AE%B6%E8%BB%8A%E6%A3%84%E4%B8%83%E6%94%AF%E6%B0%A3%E6%B2%B9%E5%BD%88-%E5%85%A7%E5%9C%B0%E4%BA%BA%E5%8F%8A%E6%B8%AF%E7%94%B7%E8%A2%AB%E8%90%BD%E6%A1%88%E8%B5%B7%E8%A8%B4-%E4%BB%8A%E6%97%A9%E7%B2%89%E5%B6%BA%E6%8F%90%E5%A0%82</a>"},{"pid":"bfe17cd0db7aaaf9febb5a85de9e4be2cd1ce4d1","tid":1507630,"uid":13308,"like":2,"dislike":4,"score":-2,"citedBy":1,"replyTime":"2019-08-26T08:44:59.000Z","msg":"仲要開幾多個炒車post"},{"pid":"cb440b6cf168e623da04c1436fd80db985b6ae47","tid":1507630,"uid":286499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T08:45:05.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5c110d9460f2857b120d1e613da44ddc2c2cc994","tid":1507630,"uid":112551,"like":2,"dislike":0,"score":2,"quote":{"pid":"bfe17cd0db7aaaf9febb5a85de9e4be2cd1ce4d1","tid":1507630,"uid":13308,"like":2,"dislike":4,"score":-2,"citedBy":1,"replyTime":"2019-08-26T08:44:59.000Z","msg":"仲要開幾多個炒車post"},"citedBy":2,"replyTime":"2019-08-26T08:45:36.000Z","msg":"炒咩車？"},{"pid":"a72fdc74a440c16960b55e9ff5ede8