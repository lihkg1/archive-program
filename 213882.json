29ced332003a","tid":213882,"uid":31847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-27T03:51:14.000Z","msg":"藍眼布偶<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"ab64892cbea4f48ead6f277e7857e4cde772250e","tid":213882,"uid":37413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-27T03:55:31.000Z","msg":"美短"},{"pid":"a1f15959a520bac08ce13be2cf8d9a039afb89ef","tid":213882,"uid":64318,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-27T05:16:45.000Z","msg":"但係佢地好易病"},{"pid":"2c6c8b2215b80715dc7e9eb8bb361c74b37fc0e5","tid":213882,"uid":76463,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-27T08:06:44.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/04/27/160619_5d2bf933bf4f1b5dd85f7818fa961714.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F04%2F27%2F160619_5d2bf933bf4f1b5dd85f7818fa961714.jpg&h=39bd74fd&s={SIZE}\" /><br />\n異短主人<img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" />"},{"pid":"3a55974e5abf3935a252ac05871ffaf61f682c36","tid":213882,"uid":45645,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-27T08:15:09.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/04/27/161458_6a9b1dd4d6b63e1cb3032f0cce0f9c15.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F04%2F27%2F161458_6a9b1dd4d6b63e1cb3032f0cce0f9c15.jpg&h=04f779c7&s={SIZE}\" />香港短毛貓"},{"pid":"d4b187ee86843c65fc0cb1e3eb3263375b8cb7ca","tid":213882,"uid":112211,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-27T08:18:50.000Z","msg":"美短<img src=\"/assets/faces/lomoji/35.png\" class=\"hkgmoji\" />"},{"pid":"2c8db20cc897f1505acefadafb38b6c4f21cd255","tid":213882,"uid":112211,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-27T08:20:40.000Z","msg":"<blockquote><blockquote>養緊美短表示美短好爛玩<img src=\"/assets/faces/normal/smile.gif\" class=