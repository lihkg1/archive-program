 src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"97749d97f84fdaa597ea0c1033db2759d749cb47","tid":2094732,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-07T09:18:56.000Z","msg":"泛民周六日初選 設251票站  戴耀廷：無違國安法 籲市民參與爭35+<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/2098140\" data-auto-link target=\"_blank\">https://lih.kg/2098140</a>"},{"pid":"006f66e3be6b24bf0e0c39d437c38bd61ccf0bd3","tid":2094732,"uid":55089,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-07T09:23:35.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"f3cda4f17c42b5c1c6eaf314c13aaa38bcc46640","tid":2094732,"uid":92385,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-07T09:24:39.000Z","msg":"Push"},{"pid":"dd7bc53938757fd0eec65a043e971baed335e2fc","tid":2094732,"uid":293227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-07T09:25:36.000Z","msg":"手足加油"},{"pid":"381f473c4e5e8449ded0c82132e3504d4f7a1024","tid":2094732,"uid":81140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-07T10:01:11.000Z","msg":"Push"}],"pinned":{"pid":"9d3ecb1a8cafd35f62280f9a6d6597f559c9e330","tid":2094732,"uid":131157,"like":10,"dislike":1,"score":9,"citedBy":1,"replyTime":"2020-07-05T02:33:52.000Z","msg":"<img src=\"https://na.cx/i/4YHZpsz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4YHZpsz.jpg&h=c752f190&s={SIZE}\" /><img src=\"https://na.cx/i/CQ0Xa7A.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCQ0Xa7A.jpg&h=fb6c8245&s={SIZE}\" /><img src=\"https://na.cx/i/2LZ1CNA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F2LZ1CNA.jpg&h=81739c65&s={SIZE}\" />"}}