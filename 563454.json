<br />\n豬豬係有靈性，幫人耤田....請大家唔好食豬! 我都已經開始戒...<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"2ff416cba96ad1d18699ff1e0447f6263dcfe926","tid":563454,"uid":47359,"like":0,"dislike":3,"score":-3,"quote":{"pid":"ed84aa3184058922f6b4c0956df9042bf39dcceb","tid":563454,"uid":102096,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-02-17T04:20:46.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-02-17T04:27:02.000Z","msg":"<span style=\"font-size: xx-large;\">五毛戚繼光</span><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/17/122653_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F17%2F122653_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=883315fe&s={SIZE}\" />"},{"pid":"d69db28b9453b71dfbb783668b7b06736abf0088","tid":563454,"uid":47359,"like":2,"dislike":1,"score":1,"quote":{"pid":"2ff416cba96ad1d18699ff1e0447f6263dcfe926","tid":563454,"uid":47359,"like":0,"dislike":3,"score":-3,"quote":{"pid":"ed84aa3184058922f6b4c0956df9042bf39dcceb","tid":563454,"uid":102096,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-02-17T04:20:46.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-02-17T04:27:02.000Z","msg":"<span style=\"font-size: xx-large;\">五毛戚繼光</span><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/17/122653_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F17%2F122653_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=883315fe&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-02-17T04:29:05.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/02/17/122903_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F17%2F122903_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=9b79f3d0&s={SIZE}\" />"},{"pid":"702a82fd10cfe62c7370a977f5ffde684ab810a3","