.imageupload.net/2020/06/25/Blankcat_hk-ZZ01.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimagehost.imageupload.net%2F2020%2F06%2F25%2FBlankcat_hk-ZZ01.jpg&h=07a34cf9&s={SIZE}\" /><br />\n<br />\n<img src=\"https://imagehost.imageupload.net/2020/06/25/Blankcat_hk-ZZ02.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimagehost.imageupload.net%2F2020%2F06%2F25%2FBlankcat_hk-ZZ02.jpg&h=892c4b1a&s={SIZE}\" /><br />\n<br />\n<br />\n<a href=\"https://forum.hkgolden.com/thread/5844174/page/1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforum.hkgolden.com%2Fthread%2F5844174%2Fpage%2F1&d=6wD9ZzBID4i2v0E%2BCeDzwP7c%2B9HD3JYLAdxAiSxEDXo%3D&h=f098f3b0\" data-auto-link target=\"_blank\">https://forum.hkgolden.com/thread/5844174/page/1</a><br />\n<br />\n<br />\n坦白講這件事對我有好大壓力<br />\n尋日我去大家樂食飯當時外面落好大雨<br />\n唔知係唔係取消左攝影活動定乜我唔知總之隔離台座了一班龍友<br />\n佢地個個拿著部手機就係談論緊我呢單野<br />\n個個都笑我係今天又話我傻的嗎又話我要準備好跳樓<br />\n聽到後我心情真係好沉重 情況比起我初初跟團去影model俾班人圍著我笑我用sony機心情更加沉重<br />\n我既出發點係對既好似wayman chan咁你估我想搞佢係佢不停出爛相又唔肯改變我先咁憎佢成日搵機會搞佢 就算係stephen ng我都想搵機會扮同佢交惡再搞佢等佢唔洗唔停咁出爛相 不過有識佢既fan同我講&quot;哂勁氣因為佢只在乎like的數量 like多代表自己影得好亦即是影得好過你同我 人講乜佢係唔會聽咁過癮架 &quot;所以先打消搞stephen ng這個念頭<br />\n<br />\n但係做事唔會理後果同當時人或被拖連者感受因而搞出個大頭佛<br />\n在此誠意向satta omega先生和其他被拖連者道歉<br />\n希望大人有大量原諒我 我保證唔會再有下次<br />\n相已經刪走原post我無能力和辦法刪除好抱歉<br />\n祝福satta omega先生攝影技術與日俱增和得到明師指導<br />\n<br />\n謝謝"},{"pid":"d140cf9a176b91ba2b144b8338fc35c1eeda9707","tid":2087163,"uid":185452,"like":0,"dislike":0,"score":0,"quote":{"pid":"cec45fd8211480ec85c9f70781fb3a499186fdeb","tid":2087163,"uid":36157,"like":12,"dislike":0,"score":12,"quote":{"pid":"d49ef16a65d45221b75591ec9bdc3b533300c2f8","tid":2087163,"uid":71341,"like":0,"dislike":3,"score":-3,"quote":{"pid":"076ae8edd0884845a50212ab4684e3e3093aa141","tid":2087163,"uid":185452,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-30T15:13:53.000Z","msg":"揾自己影的相片，<br />\n黎形容 6月30 之後，你心中的香港<br />\n<br />\n<img src=\"https://upload.cc/i1/2020/0