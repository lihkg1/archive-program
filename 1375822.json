障返參加者, 我地有同事負責係附近接參加者, 唔會直接公開地址<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"3cd6d9a5e5ca1b34513ae9ba35af592a83af5052","tid":1375822,"uid":29167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:13:03.000Z","msg":"PISH"},{"pid":"e0b6a6c2877092d786f1f4e0387241e0b87ec2bd","tid":1375822,"uid":29167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:13:29.000Z","msg":"PISH"},{"pid":"f107daf71e1537c8e7bb9b2c62fbcc7425899f75","tid":1375822,"uid":29167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:13:43.000Z","msg":"PISH"},{"pid":"a593cdcee5bf3662412ed7b038466d9b803261cc","tid":1375822,"uid":29167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:13:53.000Z","msg":"自push"},{"pid":"dacc45004812559967266217647f1fb0c546e877","tid":1375822,"uid":152667,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:14:00.000Z","msg":"PISH"},{"pid":"583af231f9c93a8649e60c795ec11a2c2e1924f7","tid":1375822,"uid":29167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:14:05.000Z","msg":"自push"},{"pid":"3b7ee7e8a0485bab74c2a9b019ded00675737104","tid":1375822,"uid":29167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:14:31.000Z","msg":"推"},{"pid":"426c945895177d34df5533d64a1f9001b0496b3a","tid":1375822,"uid":29167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:14:45.000Z","msg":"push"},{"pid":"41bba660c3bd9456628b69513299e5142a3995aa","tid":1375822,"uid":29167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:14:56.000Z","msg":"pish"},{"pid":"337e7c859901f47615a5d7787054d3bda974e4fc","tid":1375822,"uid":235853,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T07:19:18.000Z","msg":"push"},{"pid":"4d3768b60a77cecf484e72b8857c6f7cf5c01822","tid":1375822,"uid":212646,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2019-07-28T07:24:56.000Z","msg":"有無通宵地方落腳？<img src=