e":{"pid":"d67205ab75fe85fda757c55f326764992eeb2404","tid":2110773,"uid":269498,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-16T09:05:07.000Z","msg":"唉<br />\n今日OH-58撞地又死兩個軍人<br />\n一月先死左一班指揮層<br />\n點撚解台灣啲訓練同maintain咁撚衰"},"citedBy":0,"replyTime":"2020-07-16T09:48:17.000Z","msg":"OH-58直升機太老舊"}]}