{"tid":2157982,"cid":5,"subCid":10,"title":"周一起香港往北京旅客須出示特區政府認可機構檢測證明","createTime":"2020-08-15T11:57:38.000Z","updateTime":"2020-08-15T13:02:40.000Z","uid":79563,"like":0,"dislike":2,"uniUserReply":2,"replies":[{"pid":"3ce8c15754a78731ba99c3486e224a6053554194","tid":2157982,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T11:57:38.000Z","msg":"<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1543924-20200815.htm?spTabChangeable=0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1543924-20200815.htm%3FspTabChangeable%3D0&d=kJyKEnCePQht%2Ftv3UrQe8QwUaSA5OUQt3qQG7WIDhAk%3D&h=05e31191\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1543924-20200815.htm%3FspTabChangeable%3D0&h=1e24af78\" target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1543924-20200815.htm?spTabChangeable=0</a><br />\n<br />\n香港國際機場網站公布，由星期一起，所有由香港前往北京的旅客，須出示由特區政府認可檢測機構，發出有效的新型冠狀病毒核酸檢測證明，結果必須為陰性。<br />\n<br />\n有關檢測須在旅客登機前7日內進行。"},{"pid":"c631286ab75082f1211b2a5df8b08bf4467130f8","tid":2157982,"uid":138790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T13:02:28.000Z","msg":"<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"fb0dcf6f078ec2fc51465ba47cd21f9b1f49a53a","tid":2157982,"uid":138790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T13:02:40.000Z","msg":"<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"}]}