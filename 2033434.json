{"tid":2033434,"cid":5,"subCid":0,"title":"［請幫推］新戰線-連結海外華人否認中共政權正當性","createTime":"2020-05-24T15:52:40.000Z","updateTime":"2020-05-24T16:12:11.000Z","uid":130898,"like":4,"dislike":0,"uniUserReply":4,"replies":[{"pid":"a406d2b4e18f95c20f16003286b1dd8e7b17225b","tid":2033434,"uid":130898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-24T15:52:40.000Z","msg":"點解咁多五毛分化港臺關係<br />\n係因為如果流散係世界各地既華人<br />\n都一齊係同一時間抗議否認中共政權既正當性<br />\n中國自已都冇話可說 <br />\n<br />\n戰街行動有3項<br />\n1）香港 類似今日既街頭抗議<br />\n2）海外華人係各自國家既抗議<br />\n3）中國國境內人民既安全發聲（例如係同一個時間一齊播起來不願做奴隸...，以示支持香港一齊否認中共政權，但又難以被追究）<br />\n<br />\n大家認為如何？請幫推<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"23a80e4f91fdfb16535616a8d649abdaa41be4c3","tid":2033434,"uid":79117,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-05-24T15:53:42.000Z","msg":"海外華人點會否認<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n上年仲睇唔透？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dcfa0e506a7db68444b34c6702d0474cd321356c","tid":2033434,"uid":130898,"like":1,"dislike":0,"score":1,"quote":{"pid":"23a80e4f91fdfb16535616a8d649abdaa41be4c3","tid":2033434,"uid":79117,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-05-24T15:53:42.000Z","msg":"海外華人點會否認<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n上年仲睇唔透？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\