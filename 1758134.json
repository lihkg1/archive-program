%3A%2F%2Fwww.facebook.com%2Fsearch%2Ftop%2F%3Fq%3D%E6%83%85%E4%BE%B6%E9%97%9C%E4%BF%82%2520%E5%81%B7%E6%8B%8D%26epa%3DSEARCH_BOX&d=CdC2hxDFSK2eX8E0jz8mRHljxErbpFF6VcGzQu2DuOQ%3D&h=dfc398b0\" target=\"_blank\">https://www.facebook.com/search/top/?q=情侶關係%20偷拍&amp;epa=SEARCH_BOX</a>"},{"pid":"691b821343f6f61a1d8262c50cbecf4e81165cea","tid":1758134,"uid":10503,"like":1,"dislike":10,"score":-9,"citedBy":3,"replyTime":"2019-11-27T02:35:21.000Z","msg":"有冇片<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"b13bdb4f40521791934afdf4e3d6994b78089b91","tid":1758134,"uid":178364,"like":2,"dislike":0,"score":2,"quote":{"pid":"691b821343f6f61a1d8262c50cbecf4e81165cea","tid":1758134,"uid":10503,"like":1,"dislike":10,"score":-9,"citedBy":3,"replyTime":"2019-11-27T02:35:21.000Z","msg":"有冇片<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-27T02:37:36.000Z","msg":"<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />你唔撚係人嚟"},{"pid":"d68e8881540e29e17c545247ef77da33cdc9663c","tid":1758134,"uid":178364,"like":0,"dislike":0,"score":0,"quote":{"pid":"64bdc7a9787d3273a139c6644ef42e4a33ec5fee","tid":1758134,"uid":178364,"like":4,"dislike":0,"score":4,"quote":{"pid":"c5839b0cd3f47b5e0c686601e8677776991f86c7","tid":1758134,"uid":133033,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2019-11-27T02:29:06.000Z","msg":"無論點 韓國人既秋後同清算能力 係要學習"},"citedBy":2,"replyTime":"2019-11-27T02:33:57.000Z","msg":"超同意!<br />\n好多國家嘅transitional justice/面對歷史係選擇忘記...<br />\n韓國人絕對接受唔到咁! 好似香港咁，無理由警察唔使制裁㗎嘛?<br />\n所以睇一個判決要睇埋上訴庭點判: <br />\n例如最近韓國法院先裁定就算情侶關係都唔可以偷拍 !!<br />\n<a href=\"https://www.facebook.com/search/top/?q=情侶關係%20偷拍&amp;epa=SEARCH_BOX\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fsearch%2Ftop%2F%3Fq%3D%E6%83%85%E4%BE%B6%E9%97%9C%E4%BF%82%2520%E5%81%B7%E6%8B%8D%26epa%3DSEARCH_BOX&d=CdC2hxDFSK2eX8E0jz8mRHljxErbpFF6VcGzQu2DuOQ%3D&h=dfc398b0\" target=\"_blank\">https://www.facebook.com/search/top/?q=情侶關係%20偷拍&amp;epa=SEARCH_BOX</a>"},"citedBy":0,"replyTime":"2019-11-27T02:39:20.000Z","msg":"<a href=\"https://www.facebook.com/cyrus.ngkihong.dhrlrhkd/posts/720155028388145\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fcyrus.ngkihong.dhrlrhkd%2Fposts%2F720155028388145&d=CdC2hxDFSK2eX8E0jz8mRHljxErbpFF6VcGzQu2DuOQ%3D&h=2d0e3524\" target=\"_blank\">https://www.facebook.com/cyrus.ngkihong.dhrlrhkd/posts/720155028388145</a><br />\n<pre><code data-type=\"\">【韓國大法院裁定戀人之間在沒共識下拍攝對方身體都會以性罪行受罰】\n#韓國 #大法院 #情侶 #戀人 #共識 #不法偷拍 #偷拍對方身體 #性罪行\n韓國大法院作出判決指，即使是戀人關係，如果在沒有經過同意的情況下拍攝對方身體，也會因性暴力而受到處罰。\n大法院2部在對因涉嫌非法拍攝交往中的女性(《性暴力處罰法》和攝像機等照片)而被起訴的金某(36歲)的上訴審判中，確定了200萬韓圜的罰款和相關措施。\n金某因涉嫌在2017年3月與當時交往的女性A某發生性關係時未經同意拍攝裸體而被起訴。一審中，法院表示「即使已經達成協議併發生了性關係，亦不代表已經同意拍照」，並下達了罰款200萬韓圜和40小時的性暴力治療項目移交命令。\n一審法院表示，事發當時，金某事先向被害人詢問或未徵得被害人同意就拍了照片，金某在交往期間也多次向被害人要求將拍攝身體照片的照片寄給被害人，受害者平時也不願意把照片傳送給金某等，受害者在毫無防備的情況下被金某拍下裸照，這讓人很難接受。\n金某表示，受害者是對拍照知情，認爲受害者同意了，並提起了上訴。但是，二審法院不接受這一主張，並裁定應追加宣判以兒童青少年爲對象的機關及殘疾人福利設施就業限制命令。\n二審裁判部表示，現行《兒童青少年保護法》對性犯罪者和被判刑者下達了就業限制命令，但對現行法施行前的犯罪，將依照以前的相關規定，在沒有確定判決的情況下也可以命令對就業限制。另外，法院還同時宣判了在沒有確定判決的情況下，根據可以限制就業的《殘疾人福利法》，限制殘疾人福利設施一年就業的命令。金某認爲該就業限制不合理，並提出了上訴，但大法院維持原判，指原審裁決合理。</code></pre>"},{"pid":"4fba293c214202ff67e62c0455f7333f15f48a69","tid":1758134,"uid":8500,"like":0,"dislike":0,"score":0,"quote":{"pid":"691b821343f6f61a1d8262c50cbecf4e81165cea","tid":1758134,"uid":10503,"like":1,"dislike":10,"score":-9,"citedBy":3,"replyTime":"2019-11-27T02:35:21.000Z","msg":"有冇片<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-27T02:40:29.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"2cb7783e230eb9a7646a59d2c548f4b071a8daf8","tid":1758134,"uid":230054,"like":0,"dislike":0,"score":0,"quote":{"pid":"64bdc7a9787d3273a139c6644ef42e4a33ec5fee","tid":1758134,"uid":178364,"like":4,"dislike":0,"score":4,"quote":{"pid":"c5839b0cd3f47b5e0c686601e8677776991f86c7","tid":1758134,"uid":133033,"like"