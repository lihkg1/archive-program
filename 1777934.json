":0,"score":0,"quote":{"pid":"417024ce0dea5a2da04a2f66f1ceaf34bb61f063","tid":1777934,"uid":13149,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-12-10T14:33:05.000Z","msg":"小學雞"},"citedBy":0,"replyTime":"2019-12-10T14:36:31.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"9ecd58922516fab08b8befdd7485538e4452492d","tid":1777934,"uid":265192,"like":1,"dislike":0,"score":1,"quote":{"pid":"b9b99cc00032ba5f56fcd3a7b28c529a7c27dd30","tid":1777934,"uid":84102,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-12-10T14:35:33.000Z","msg":"溫家寶 寶寶"},"citedBy":0,"replyTime":"2019-12-10T14:36:53.000Z","msg":"乜都唔做都好過做錯"},{"pid":"ce5c19e1f444e5e7258ff6b392e9c1e847dbac92","tid":1777934,"uid":216828,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-12-10T14:36:59.000Z","msg":"習近平"},{"pid":"b63ed3d5f426d895fe8cb42e82aef33e4c9ec566","tid":1777934,"uid":113074,"like":0,"dislike":0,"score":0,"quote":{"pid":"b9b99cc00032ba5f56fcd3a7b28c529a7c27dd30","tid":1777934,"uid":84102,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-12-10T14:35:33.000Z","msg":"溫家寶 寶寶"},"citedBy":0,"replyTime":"2019-12-10T14:37:04.000Z","msg":"贏曬啦畀佢漏埋<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"288183ad4a6ff7dcbbc94ff883ca4fcfccbe8ef1","tid":1777934,"uid":275238,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-10T14:37:53.000Z","msg":"<img src=\"https://na.cx/i/XVR9v8V.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXVR9v8V.png&h=eb8e5d9f&s={SIZE}\" />"},{"pid":"64e63e5cf02d72781dc5a1f1e5f53b5b1ba8c462","tid":1777934,"uid":301820,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-12-10T14:38:46.000Z","msg":"甴近平"},{"pid":"8933e9a58c2582d813f9475bc0a2765863f79e44","tid":1777934,"uid":251945,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-10T14:54:50.000Z","msg":"華國鋒<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"p