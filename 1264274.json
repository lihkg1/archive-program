kgmoji\" />"},{"pid":"cee910b4c4b07d9eab5d00dffaf094c4cb783242","tid":1264274,"uid":89974,"like":0,"dislike":0,"score":0,"quote":{"pid":"6ddc7ab34ec81d99c9f6cfd3efcd0bbb9431e421","tid":1264274,"uid":36088,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-28T17:49:03.000Z","msg":"<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-28T18:18:32.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"894718a16d36ccb03a2f98c1ef016781cc3c7e9e","tid":1264274,"uid":226955,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-28T18:19:00.000Z","msg":"自從9號開始，大大話話都有成十幾場示威活動，大家都為救港而付出心力、甚至血汗，但相信有唔少人可能已經覺得攰，為咗延續抗爭情緒，避免運動消散，大家有冇諗過可以將戰線擴展去「世界文宣」嘅工作？好似之前嘅眾籌登全世界報紙咁，大家有冇諗過定期開眾籌，再由連登熟悉各大専業嘅巴打分別負責設計、文稿、翻譯、構圖、美術、排版、聯絡、宣傳等等，而覺得攰嘅而又有心巴打可以參與下討論，各位一齊比啲意見，再向全世界各大報章、各旅遊景點名勝廣告版，定期公佈中共禍港惡行甚至宣傳中共國內打壓人權嘅問題，爭取國際關注，令世界更多人認清中共真實嘅一面，美國又可以有更多嘅籌碼同中共談判，而中共又一定要虛耗更多財力去打文宣戰（好似之前中共某大啤酒集團以十倍價錢買下韓國報紙頭版），多角度向中共作出抗議，又不致運動慢慢步入消散崩潰，呢個就係「世界文宣」嘅大意。錢嘅問題，200萬人每個捐10蚊都2000萬啦，財力上應該冇乜問題，究竟有冇得諗下呢？大家可以傾下"},{"pid":"4cc9914501d7f4d5d24ab986027656ffed1e1f2f","tid":1264274,"uid":89974,"like":0,"dislike":0,"score":0,"quote":{"pid":"894718a16d36ccb03a2f98c1ef016781cc3c7e9e","tid":1264274,"uid":226955,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-28T18:19:00.000Z","msg":"自從9號開始，大大話話都有成十幾場示威活動，大家都為救港而付出心力、甚至血汗，但相信有唔少人可能已經覺得攰，為咗延續抗爭情緒，避免運動消散，大家有冇諗過可以將戰線擴展去「世界文宣」嘅工作？好似之前嘅眾籌登全世界報紙咁，大家有冇諗過定期開眾籌，再由連登熟悉各大専業嘅巴打分別負責設計、文稿、翻譯、構圖、美術、排版、聯絡、宣傳等等，而覺得攰嘅而又有心巴打可以參與下討論，各位一齊比啲意見，再向全世界各大報章、各旅遊景點名勝廣告版，定期公佈中共禍港惡行甚至宣傳中共國內打壓人權嘅問題，爭取國際關注，令世界更多人認清中共真實嘅一面，美國又可以有更多嘅籌碼同中共談判，而中共又一定要虛耗更多財力去打文宣戰（好似之前中共某大啤酒集團以十倍價錢買下韓國報紙頭版），多角度向中共作出抗議，又不致運動慢慢步入消散崩潰，呢個就係「世界文宣」嘅大意。錢嘅問題，200萬人每個捐10蚊都2000萬啦，財力上應該冇乜問題，究竟有冇得諗下呢？大家可以傾下"},"citedBy":0,"replyTime":"2019-06-28T18:21:24.000Z","msg":"眾籌喺好方向<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"98f71a49955ed466d42d9b1f73c293c9f0f4c689","tid":1264274,"uid":36088,"like":0,"dislike":0,"score":0,"