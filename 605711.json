>\n過左咁多年，都攰啦"},{"pid":"dde6f7ae64802ee70c0bd220c643937b6963e8fd","tid":605711,"uid":174013,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-03-26T02:46:53.000Z","msg":"<img src=\"https://vignette.wikia.nocookie.net/evchk/images/9/9f/Mona_lunsa_wfc.gif/revision/latest?cb=20060824120252\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fevchk%2Fimages%2F9%2F9f%2FMona_lunsa_wfc.gif%2Frevision%2Flatest%3Fcb%3D20060824120252&h=9b883924&s={SIZE}\" />"},{"pid":"5c21247f91747e4a16fca7d861b682837184a0ec","tid":605711,"uid":39706,"like":0,"dislike":0,"score":0,"quote":{"pid":"61ea91ea0324fde2efa85a9fd963c81b0689175b","tid":605711,"uid":23758,"like":5,"dislike":0,"score":5,"quote":{"pid":"42493304df8c1acc6a783416e7acd73610c6808d","tid":605711,"uid":39706,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T02:06:56.000Z","msg":"如果自已都愛唔自已, 人哋又點樣愛你呢?"},"citedBy":1,"replyTime":"2018-03-26T02:14:23.000Z","msg":"愛自己先要同人群隔離<br />\n唔洗再比人煩到，開開心心做自己鍾意既野<br />\n都唔洗比人傷害"},"citedBy":1,"replyTime":"2018-03-26T02:48:44.000Z","msg":"人可以選你, 你都可以搵一啲你相處會覺得舒服嘅人."},{"pid":"57b4ab4c66414542347312f533326c2443cc8aba","tid":605711,"uid":23758,"like":0,"dislike":0,"score":0,"quote":{"pid":"dde6f7ae64802ee70c0bd220c643937b6963e8fd","tid":605711,"uid":174013,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-03-26T02:46:53.000Z","msg":"<img src=\"https://vignette.wikia.nocookie.net/evchk/images/9/9f/Mona_lunsa_wfc.gif/revision/latest?cb=20060824120252\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fevchk%2Fimages%2F9%2F9f%2FMona_lunsa_wfc.gif%2Frevision%2Flatest%3Fcb%3D20060824120252&h=9b883924&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-03-26T03:01:06.000Z","msg":"Me2<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a5b5f38cd2a51de6b3035c8b6773cf5be3953864","tid":605711,"uid":23758,"like":0,"dislike":0,"score":0,"quote":{"pid":"5c21247f91747e4a16fca