ormal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"b49d2cd5fe3b0fd06a3cd91745306448a738689b","tid":605241,"uid":42804,"like":54,"dislike":0,"score":54,"quote":{"pid":"f1fa10a0ca634a9b0bea44a899c38f27e1a87530","tid":605241,"uid":135995,"like":39,"dislike":1,"score":38,"citedBy":1,"replyTime":"2018-03-25T14:18:35.000Z","msg":"呢種文化入侵仲攞命過極權"},"citedBy":1,"replyTime":"2018-03-25T14:37:47.000Z","msg":"最衰就係好多人覺得冇問題。<br />\n有錢人或者中產子女覺得呢啲廣東話粗俗冇文化，寧願你說得一口流利英語、普通話好過學埋哂啲有傷風化嘅粗鄙方言（佢哋當廣東話=粗口，難登大雅之堂。）<br />\n窮人又覺得識埋呢啲嘢影衰自己，寧願學普通話溝通好過。<br />\n新香港人：「我從小就說普通話，為啥要學方言？廣州話有啥用？香港是中國的，沒有中國，香港就完了！還說甚麼方言來遷就你？」"},{"pid":"0d4876a4155389c1f176050771e523a5324ab123","tid":605241,"uid":153689,"like":29,"dislike":0,"score":29,"quote":{"pid":"b49d2cd5fe3b0fd06a3cd91745306448a738689b","tid":605241,"uid":42804,"like":54,"dislike":0,"score":54,"quote":{"pid":"f1fa10a0ca634a9b0bea44a899c38f27e1a87530","tid":605241,"uid":135995,"like":39,"dislike":1,"score":38,"citedBy":1,"replyTime":"2018-03-25T14:18:35.000Z","msg":"呢種文化入侵仲攞命過極權"},"citedBy":1,"replyTime":"2018-03-25T14:37:47.000Z","msg":"最衰就係好多人覺得冇問題。<br />\n有錢人或者中產子女覺得呢啲廣東話粗俗冇文化，寧願你說得一口流利英語、普通話好過學埋哂啲有傷風化嘅粗鄙方言（佢哋當廣東話=粗口，難登大雅之堂。）<br />\n窮人又覺得識埋呢啲嘢影衰自己，寧願學普通話溝通好過。<br />\n新香港人：「我從小就說普通話，為啥要學方言？廣州話有啥用？香港是中國的，沒有中國，香港就完了！還說甚麼方言來遷就你？」"},"citedBy":2,"replyTime":"2018-03-25T19:11:18.000Z","msg":"真正冇文化嘅人其實就係依種人，為左利益連自己文化都可以出賣，到頭來連自己係邊個都唔記得"},{"pid":"cbaa1958fb8c627d8afb92e7bd078d55fb72f601","tid":605241,"uid":2429,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-25T19:40:19.000Z","msg":"係街見到D小學生全部普通話交談。<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"eb2e1dc7fce8d51c0b13d587df7e7fc979c50c24","tid":605241,"uid":137921,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-03-26T01:03:03.000Z","msg":"垃圾00後<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8e9ef5ed411e0218dac58fb6b0313f4668586fef","tid":605241,"uid":53498,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2018-03-26T01:05:36.000