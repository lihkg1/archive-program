png\" class=\"hkgmoji\" />"},{"pid":"35ae768c3079baf1595bcbee57c590d0da8834c7","tid":791972,"uid":12486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-25T02:52:15.000Z","msg":"Diabetic ketoacidosis"},{"pid":"1e165e6bdb5b705958b3670e9310717939fb315f","tid":791972,"uid":32706,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-08-25T03:39:19.000Z","msg":"都唔知信邊個好"},{"pid":"0a19a4551050449fba29ed9de9b5ff91250275e6","tid":791972,"uid":51134,"like":1,"dislike":0,"score":1,"quote":{"pid":"1e165e6bdb5b705958b3670e9310717939fb315f","tid":791972,"uid":32706,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-08-25T03:39:19.000Z","msg":"都唔知信邊個好"},"citedBy":0,"replyTime":"2018-08-25T03:42:04.000Z","msg":"樣樣都食 但唔好食太多<br />\n恆常運動 保持心境開朗<br />\n<br />\n之後就盡人事聽天命"},{"pid":"b761572ae18e95595f2beff5f7916d1d16e62e9e","tid":791972,"uid":126523,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-25T03:44:10.000Z","msg":"我兩年前keto左半年，減了40磅<br />\n<br />\n減肥黎講，絕對work。健康唔健康就見仁見智。"},{"pid":"f3ad4f53357a42ed9d34ba44abe9517e0ee372eb","tid":791972,"uid":22889,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-08-25T03:44:20.000Z","msg":"根本就冇一種飲食係適合所有人，睇研究結果既同時都睇下自己身體反應"},{"pid":"2ff9bfdc49ddd68ddc4e6b012baa8a13be1378f0","tid":791972,"uid":124824,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-08-25T06:57:12.000Z","msg":"掂呀 唔洗咁長命"},{"pid":"326081eac61d5714b4b1996f1c513d7a843f98be","tid":791972,"uid":55851,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ff9bfdc49ddd68ddc4e6b012baa8a13be1378f0","tid":791972,"uid":124824,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-08-25T06:57:12.000Z","msg":"掂呀 唔洗咁長命"},"citedBy":0,"replyTime":"2018-08-25T07:01:29.000Z","msg":"不如直接自殺，搞咁多做乜"}]}