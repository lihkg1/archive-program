://na.cx/i/OCBypV8.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOCBypV8.gif&h=d3183b47&s={SIZE}\" /><img src=\"https://na.cx/i/OCBypV8.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOCBypV8.gif&h=d3183b47&s={SIZE}\" /><img src=\"https://na.cx/i/OCBypV8.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOCBypV8.gif&h=d3183b47&s={SIZE}\" /><img src=\"https://na.cx/i/OCBypV8.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOCBypV8.gif&h=d3183b47&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/tqFvr8Y.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FtqFvr8Y.gif&h=4c38f9ed&s={SIZE}\" /><img src=\"https://na.cx/i/3prq0tY.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3prq0tY.jpg&h=40f5c367&s={SIZE}\" />"},{"pid":"df1430fce0687d9e0a0de358b0813478fb39df45","tid":1514021,"uid":212023,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T14:39:44.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"e79c6db65f720885979a4623d9e4646eff24c1fb","tid":1514021,"uid":212023,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-28T14:40:42.000Z","msg":"聽日繼續嗌<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"c4b060702e5de146e6386cf74335a9180c2bd522","tid":1514021,"uid":259906,"like":1,"dislike":0,"score":1,"quote":{"pid":"e79c6db65f720885979a4623d9e4646eff24c1fb