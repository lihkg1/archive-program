-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Funwire.hk%2F2018%2F11%2F05%2Fsamsung-foldable-phone-leaked%2Fmobile-phone%2F&d=I%2BPZ7fZjwMgx79LWQpytRQdLCpCjoNGxXEizPMjNmRM%3D&h=58691a27\" data-auto-link target=\"_blank\">https://unwire.hk/2018/11/05/samsung-foldable-phone-leaked/mobile-phone/</a>"},{"pid":"77d17a55732e71a60935742c4b885f96c4ac57e6","tid":894733,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-13T20:08:51.000Z","msg":"<img src=\"https://media.giphy.com/media/3oKIP6IlphX50sZehi/giphy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2F3oKIP6IlphX50sZehi%2Fgiphy.gif&h=44d6a8ed&s={SIZE}\" />"},{"pid":"b12243c31d37735af8264d79c36bba46d8444327","tid":894733,"uid":157918,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-13T22:25:18.000Z","msg":"返工打機睇波一流<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"fcd16a4d9425a33df25e48b22b7b1ad281db6d68","tid":894733,"uid":46560,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-13T22:54:43.000Z","msg":"磚頭<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"}]}