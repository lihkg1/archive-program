%A0%E7%AE%A1\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhd.stheadline.com%2Fnews%2Fdaily%2Fhk%2F818511%2F%25E6%2597%25A5%25E5%25A0%25B1-%25E6%25B8%25AF%25E8%2581%259E-%25E4%25B8%2589%25E7%25BD%25B7%25E6%2597%25A5-%25E7%2596%2591%25E6%25AC%25B2%25E5%2588%25BA%25E7%25A9%25BF%25E8%25BB%258A%25E8%25BC%259B%25E8%25BC%25AA%25E8%2583%258E-%25E8%25AD%25A6%25E6%258B%259812%25E4%25BA%25BA%25E5%258C%2585%25E6%258B%25AC%25E6%2595%2599%25E5%25B8%25AB%25E6%25B6%2589%25E8%2597%258F%25E9%2590%25B5%25E9%2587%2598%25E8%2586%25A0%25E7%25AE%25A1&d=doP1hY1jTMShcZ7HAjrDwoc%2FDYnbIFO1z8NzTSvCTwQ%3D&h=52a6e97e\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fhd.stheadline.com%2Fnews%2Fdaily%2Fhk%2F818511%2F%25E6%2597%25A5%25E5%25A0%25B1-%25E6%25B8%25AF%25E8%2581%259E-%25E4%25B8%2589%25E7%25BD%25B7%25E6%2597%25A5-%25E7%2596%2591%25E6%25AC%25B2%25E5%2588%25BA%25E7%25A9%25BF%25E8%25BB%258A%25E8%25BC%259B%25E8%25BC%25AA%25E8%2583%258E-%25E8%25AD%25A6%25E6%258B%259812%25E4%25BA%25BA%25E5%258C%2585%25E6%258B%25AC%25E6%2595%2599%25E5%25B8%25AB%25E6%25B6%2589%25E8%2597%258F%25E9%2590%25B5%25E9%2587%2598%25E8%2586%25A0%25E7%25AE%25A1&h=24b0fdf1\" data-auto-link target=\"_blank\">http://hd.stheadline.com/news/daily/hk/818511/%E6%97%A5%E5%A0%B1-%E6%B8%AF%E8%81%9E-%E4%B8%89%E7%BD%B7%E6%97%A5-%E7%96%91%E6%AC%B2%E5%88%BA%E7%A9%BF%E8%BB%8A%E8%BC%9B%E8%BC%AA%E8%83%8E-%E8%AD%A6%E6%8B%9812%E4%BA%BA%E5%8C%85%E6%8B%AC%E6%95%99%E5%B8%AB%E6%B6%89%E8%97%8F%E9%90%B5%E9%87%98%E8%86%A0%E7%AE%A1</a>"},"citedBy":0,"replyTime":"2019-12-11T08:57:57.000Z","msg":"其實可以唔同👮講做邊行㗎！😣😣😣<br />\n教師呢一行嘅註冊係由政府負責，如果<strong>教師本身唔係公務員</strong>，而又無被<strong>起底</strong>，學校或政府未必知。<br />\n依家好明顯政府打嘅主意係盡量提高示威者被捕後所付出嘅成本，不但要告得你重啲，更要搞到釘你牌，等你搵食都艱難，就算你間學校有幾黃有幾包容，只要一釘你牌就等你連書都無得教。<br />\n<a href=\"https://m.mingpao.com/ins/%E6%B8%AF%E8%81%9E/article/20191210/s00001/1575990090605/%E6%95%99%E5%B8%AB%E4%B8%8A%E6%B0%B4%E8%A2%AB%E6%8D%95-%E6%95%99%E8%82%B2%E5%B1%80%E8%A6%81%E6%B1%82%E8%80%83%E6%85%AE%E6%9A%AB%E5%81%9C%E8%81%B7%E5%8B%99\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%25E6%25B8%25AF%25E8%2581%259E%2Farticle%2F20191210%2Fs00001%2F1575990090605%2F%25E6%2595%2599%25E5%25B8%25AB%25E4%25B8%258A%25E6%25B0%25B4%25E8%25A2%25AB%25E6%258D%2595-%25E6%2595%2599%25E8%2582%25B2%25E5%25B1%2580%25E8%25A6%2581%25E6%25B1%2582%25E8%2580%2583%25E6%2585%25AE%25E6%259A%25AB%25E5%2581%259C%25E8%2581%25B7%25E5%258B%2599&d=doP1hY1jTMShcZ7HAjrDwoc%2FDYnbIFO1z8NzTSvCTwQ%3D&h=d2890de1\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%25E6%25B8%25AF%25E8%2581%259E%2Farticle%2F20191210%2Fs00001%2F1575990090605%2F%25E6%2595%2599%25E5%25B8%25AB%25E4%25B8%258A%25E6%25B0%25B4%25E8%25A2%25AB%25E6%258D%2595-%25E6%2595%2599%25E8%2582%25B2%25E5%25B1%2580%25E8%25A6%2581%25E6%25B1%2582%25E8%2580%2583%25E6%2585%25AE%25E6%259A%25AB%25E5%2581%259C%25E8%2581%25B7%25E5%258B%2599&h=84f936ee\" data-auto-link target=\"_blank\">https://m.mingpao.com/ins/%E6%B8%AF%E8%81%9E/article/20191210/s00001/1575990090605/%E6%95%99%E5%B8%AB%E4%B8%8A%E6%B0%B4%E8%A2%AB%E6%8D%95-%E6%95%99%E8%82%B2%E5%B1%80%E8%A6%81%E6%B1%82%E8%80%83%E6%85%AE%E6%9A%AB%E5%81%9C%E8%81%B7%E5%8B%99</a>"}]}