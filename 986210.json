ass=\"hkgmoji\" />"},{"pid":"3294c860adec4393e439332b8917e68df06ed963","tid":986210,"uid":2429,"like":0,"dislike":0,"score":0,"quote":{"pid":"752087702bdbe51fb8eab6ae015fea49a468636c","tid":986210,"uid":5489,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-01-18T20:59:05.000Z","msg":"澳門有23條都敢咁揚<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-18T23:45:07.000Z","msg":"<img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" />"},{"pid":"7d25f0dba364d0dd62535d43cf6eed9bcf104825","tid":986210,"uid":24140,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-01-19T00:20:07.000Z","msg":"最初睇完有種感覺：香港輸出獨立革命<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f648b0d6f96e87fca4985029cfc9602d96fce236","tid":986210,"uid":50328,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-01-19T00:24:41.000Z","msg":"此回覆已被刪除"},{"pid":"1e6c075694c1c822942a7096b868e8c5c9e0a599","tid":986210,"uid":182499,"like":0,"dislike":0,"score":0,"quote":{"pid":"7d25f0dba364d0dd62535d43cf6eed9bcf104825","tid":986210,"uid":24140,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-01-19T00:20:07.000Z","msg":"最初睇完有種感覺：香港輸出獨立革命<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-19T00:25:57.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e293da327b10ed6be3ddc4b510668069fc045f1a","tid":986210,"uid":24140,"like":0,"dislike":0,"score":0,"quote":{"pid":"1e6c075694c1c822942a7096b868e8c5c9e0a599","tid":986210,"uid":182499,"like":0,"dislike":0,"score":0,"quote":{"pid":"7d25f0dba364d0dd62535d43cf6eed9bcf104825","tid":986210,"uid":24140,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-01-19T00:20:07.000Z","msg":"最初睇完有種感覺：香港輸出獨立革命<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-19T00:25:57.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-19T00:31:15.000Z","msg":"你望下條片，同埋個法理獨立篇就明<br />\n同香港果套都幾似"}]}