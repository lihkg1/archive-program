 />\n<a href=\"https://lih.kg/1581858\" data-auto-link target=\"_blank\">https://lih.kg/1581858</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"68870453801dac9be9a0409374b62fd75169e169","tid":1590201,"uid":12824,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T15:25:55.000Z","msg":"<img src=\"/assets/faces/mf/kill.gif\" class=\"hkgmoji\" />"},{"pid":"9d7481b974804f4244ebca5477c7322807f76c5b","tid":1590201,"uid":243666,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T15:26:15.000Z","msg":"集思廣益"},{"pid":"6f49fd2414ab0810f3e1e16eea37d1a7ba78f513","tid":1590201,"uid":269718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T15:27:06.000Z","msg":"push"}]}