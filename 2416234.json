ad.gif\" class=\"hkgmoji\" />"},{"pid":"fec50d5624c889db7b1aa3ea837d25aaa2bf6d4d","tid":2416234,"uid":25345,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-21T04:58:52.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4f5cef08722edaf7a41b5a68794015b55f5a487a","tid":2416234,"uid":137569,"like":0,"dislike":0,"score":0,"quote":{"pid":"b504ec88d477c08a130fd8b87da033d0847374c1","tid":2416234,"uid":25345,"like":3,"dislike":1,"score":2,"quote":{"pid":"ac43c1b0adc2fa8b11d700c7ac646b5c5e599901","tid":2416234,"uid":149494,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-21T02:40:47.000Z","msg":"鹿晗吳亦凡張藝興真係走得好<br />\n留響EXO真係等食屎"},"citedBy":1,"replyTime":"2021-02-21T02:53:21.000Z","msg":"點解我覺得exo班人型過防彈個班<br />\n防彈有一個成個王小虎咁既樣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-21T06:00:13.000Z","msg":"防彈sell才華嘛<br />\nExo太花美男（當然都有個王祖男<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />，王祖男扮女人就話啫，花美男就<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"51d734b2e0c7be92defff7947efb2706db4af0c2","tid":2416234,"uid":53705,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-21T06:00:39.000Z","msg":"新聞淨係見到成功例子, 仲有大把失敗例子<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n每個大陸城市, 都有 演藝學院<br />\n每年都有幾萬人畢業, 但真正出名既, 可能都係幾百人左右<br />\n<br />\n大把人讀完演藝學院, 再比貪官/導演屌完, 都係無得拍戲, 浪費時間, 心機"}]}