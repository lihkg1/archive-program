gmoji\" />"},{"pid":"0b1de1d73737ccf2ef78a9085a51daf315623eb1","tid":1343862,"uid":2569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:03:50.000Z","msg":"推撚到條仆街坐監"},{"pid":"4b04a12f6645e0a49b241b511ee1caa0045c7308","tid":1343862,"uid":2569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:04:17.000Z","msg":"成立新政府第一個清算佢！"},{"pid":"fce9cf0a8d4e3f5bbc8a1ff8499122df0ca50fba","tid":1343862,"uid":2569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T12:55:36.000Z","msg":"<img src=\"https://na.cx/i/nqQU9eP.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnqQU9eP.png&h=71043ab4&s={SIZE}\" /><br />\n<br />\n抵撚死"},{"pid":"382ef435afb0a82322a0e08d17d49578301ab710","tid":1343862,"uid":2569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T12:55:50.000Z","msg":"推"},{"pid":"9574158ccf854d6b67aeee6f5ed7ad960d7c169a","tid":1343862,"uid":2569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T12:56:04.000Z","msg":"推到何君堯收皮！"},{"pid":"588805533f8d9fdf99573e310719c6025d3bef2e","tid":1343862,"uid":267924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T12:57:57.000Z","msg":"<img src=\"https://na.cx/i/1pjyFnh.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1pjyFnh.png&h=e70f1b40&s={SIZE}\" />"},{"pid":"5cdd8e7079658470c1f29c6a962a3c3cc4520a8b","tid":1343862,"uid":103759,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T13:00:10.000Z","msg":"【港鐵職員建議在港鐵遇險時如何自保/逃生】<br />\n<br />\n如沒有警察下， 在列車門沒有關上:<br />\n1) 可以試自行拉動車門關上<br />\n2) 車上有滅火筒， 請對準外面畜生 (但要緊記夠力先用, 否則會被搶去反被人扑頭)<br />\n3) 通知 車長 , 列車有煙有火， 車長必然會搵TC (traffic controller, 行車控制主任) 報警， call消防。<br />\n4) 如果 在車站內， 或 月台中， 可以按動任何消防警報器， 如沒記錯， 那個警報會直接連接消防<br />\n5) 在非常迫不得以下， 走去列車兩端的控制室， 推開緊急逃生門， 不過， 要小心路軌可能有其他列車， 雖然 emergency door一推， 車長會報TC, TC會 hold住所有列車， ( 但我唔確定 那車長會有人性報TC )  e door一推， 就會係港鐵嘅 重大事故， 冇警察實有消防救護， 就算無消防無救護， 都會有一隊MTR staff衝住嚟 <br />\n<br />\n緊記! 推 e door唔一定要走, 因為落路軌有風險, 所以推 e door係俾個訊息車長, 有人 可能落咗路軌, 但我哋會當真做, 咁個車長無得食花生睇打交!<br />\n<br />\n6) 如在站內，可以拿起滅火筒自保。 盡快逃去車站控制室， 門外有對講機， 和站長對話， 站長可以放人入內<br />\n7) 如附近有消防喉，可用水 對準畜生和禽獸。請用盡車站，月台或列車中的設施自保<br />\n<br />\n&mdash;金水Facebook"}]}