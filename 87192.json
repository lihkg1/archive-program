Mpf%2BxaYALWD30NrPgBHvMcj1OveTHk6NUHU39nRk%3D&h=220ea862\" target=\"_blank\">http://www.pixiv.net/member_illust.php?mode=medium&amp;illust_id=48226669</a><br />\n<a href=\"http://www.pixiv.net/member_illust.php?mode=medium&amp;illust_id=42037431\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.pixiv.net%2Fmember_illust.php%3Fmode%3Dmedium%26illust_id%3D42037431&d=bfHMpf%2BxaYALWD30NrPgBHvMcj1OveTHk6NUHU39nRk%3D&h=aeb7b72c\" target=\"_blank\">http://www.pixiv.net/member_illust.php?mode=medium&amp;illust_id=42037431</a><br />\n<a href=\"http://www.pixiv.net/member_illust.php?mode=medium&amp;illust_id=56685097\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.pixiv.net%2Fmember_illust.php%3Fmode%3Dmedium%26illust_id%3D56685097&d=bfHMpf%2BxaYALWD30NrPgBHvMcj1OveTHk6NUHU39nRk%3D&h=0cb0f8d7\" target=\"_blank\">http://www.pixiv.net/member_illust.php?mode=medium&amp;illust_id=56685097</a><br />\n<br />\n聯絡ki後 得知對方完全不知道電視台於廣告中使用他繪畫的圖片  (對話如下)<br />\n<br />\n<img src=\"https://s30.postimg.org/hhae9wb8h/image.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs30.postimg.org%2Fhhae9wb8h%2Fimage.jpg&h=48df40bf&s={SIZE}\" /><br />\n---------------------------------------<br />\n<br />\n問:你好 我在香港tvb電視台節目《1+1的幸福》的電視宣傳廣告看見由你繪畫的圖片  請問你知不知道這件事?<br />\n<br />\n答: 你好。<br />\n不，我完全不知道<br />\n是怎樣的節目廣告呢?<br />\n<br />\n--------------------------------------<br />\n<br />\n上述對話  證實tvb電視台在原繪畫者ki不知情的狀況下 私自盜用了ki繪畫的插圖!<br />\n<br />\ntvB電視台偷圖惡行人神共憤 不能姑息 大家幫手將單野推上報公告天下  等全香港民眾知道tvB電視台既所作所為 為繪畫者討回公道!</blockquote>"},{"pid":"2e8c992d0990b9753e16bf8cfa8e4e5d36f1dbd9","tid":87192,"uid":7307,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-19T15:17:52.000Z","msg":"推"},{"pid":"e5ba0f0ef6b9ca7b4df2f07add910433696a3912","tid":87192,"uid":27446,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-19T15:19:17.000Z","msg":"推"},{"pid":"b233e988363bcd74d77c542a83e2e86da0e07bcf","tid":87192,"uid":7307,"like":0,"dislike":0,"score":0,"citedBy":0,