{"tid":1294902,"cid":5,"subCid":0,"title":"【2年前的手法】盧偉聰稱定性暴亂非為開槍找藉口　指事件迥異以往示威","createTime":"2019-07-08T01:07:56.000Z","updateTime":"2019-07-08T01:07:56.000Z","uid":50457,"like":1,"dislike":0,"uniUserReply":1,"replies":[{"pid":"8df9bbdb951001c8a1987b8c1c4f14ecd684ca32","tid":1294902,"uid":50457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-08T01:07:56.000Z","msg":"旺角於年初二凌晨發生嚴重警民衝突，其間有警員見同袍被打而向天開了兩槍示警，示威者則向警員投擲磚頭及玻璃樽等雜物。<br />\n<br />\n警務處長盧偉聰下午召開記者會，被問到當局把事件定性為「暴亂」，是否為開槍找藉口，盧指今次騷亂的確和以前不一樣，超過10處被縱火，更有人不容許消防救火，稱他們為「暴徒」、「暴亂」，不是為行動找藉口。<br />\n<br />\n<span style=\"color: red;\">至於有警員拾起磚頭向示威者掟回去是否不應該，盧偉聰說，若有人投訴，警方是歡迎的，並會全面檢討和調查，但他不想以2秒鏡頭就判斷警員是否過分或是否正確。</span><br />\n<br />\n<a href=\"https://m.mingpao.com/ins/%E6%B8%AF%E8%81%9E/article/20160209/s00001/1455008715440/%E3%80%90%E7%9F%AD%E7%89%87-%E6%97%BA%E8%A7%92%E6%9A%B4%E5%8A%9B%E8%A1%9D%E7%AA%81%E3%80%91%E7%9B%A7%E5%81%89%E8%81%B0%E7%A8%B1%E5%AE%9A%E6%80%A7%E6%9A%B4%E4%BA%82%E9%9D%9E%E7%82%BA%E9%96%8B%E6%A7%8D%E6%89%BE%E8%97%89%E5%8F%A3-%E6%8C%87%E4%BA%8B%E4%BB%B6%E8%BF%A5%E7%95%B0%E4%BB%A5%E5%BE%80%E7%A4%BA%E5%A8%81\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%25E6%25B8%25AF%25E8%2581%259E%2Farticle%2F20160209%2Fs00001%2F1455008715440%2F%25E3%2580%2590%25E7%259F%25AD%25E7%2589%2587-%25E6%2597%25BA%25E8%25A7%2592%25E6%259A%25B4%25E5%258A%259B%25E8%25A1%259D%25E7%25AA%2581%25E3%2580%2591%25E7%259B%25A7%25E5%2581%2589%25E8%2581%25B0%25E7%25A8%25B1%25E5%25AE%259A%25E6%2580%25A7%25E6%259A%25B4%25E4%25BA%2582%25E9%259D%259E%25E7%2582%25BA%25E9%2596%258B%25E6%25A7%258D%25E6%2589%25BE%25E8%2597%2589%25E5%258F%25A3-%25E6%258C%2587%25E4%25BA%258B%25E4%25BB%25B6%25E8%25BF%25A5%25E7%2595%25B0%25E4%25BB%25A5%25E5%25BE%2580%25E7%25A4%25BA%25E5%25A8%2581&d=Tc8prIKBo9hF1z3tnQ%2BJRh3udkpk2VnOHMKOPHAv%2FIQ%3D&h=2041ba93\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%25E6%25B8%25AF%25E8%2581%259E%2Farticle%2F20160209%2Fs00001%2F1455008715440%2F%25E3%25