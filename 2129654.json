\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/yeoM3bG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyeoM3bG.jpg&h=97486dec&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-07-29T04:01:36.000Z","msg":"今朝?"},{"pid":"7e71c4f60555eccd635f56c01fe6c7bbadd01a1f","tid":2129654,"uid":240319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-29T04:03:27.000Z","msg":"推"},{"pid":"6f09e7d4aa38fda49ab1066a2f2e18bbfc39e002","tid":2129654,"uid":130797,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d40cbd79904e289babeae642580115f966a5960","tid":2129654,"uid":79563,"like":0,"dislike":0,"score":0,"quote":{"pid":"b8bf52a582db2ee16c5c68420dcb432f57bb75aa","tid":2129654,"uid":304281,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2020-07-28T18:35:02.000Z","msg":"《香港大學條例》第12（9）條規定：「校務委員會不得終止任何教師的聘任，但如該委員會在對有關事實妥為作出調查，及在接獲教務委員會就該項調查結果所提供的意見後，<strong><span class=\"xx-large\"><span class=\"red\">認為有好的因由終止聘任</span></span></strong>，則不在此限。」<br />\n<br />\n同調查結果相反都係「好的因由」？有無得告鳩校務委員會"},"citedBy":1,"replyTime":"2020-07-29T02:07:15.000Z","msg":"所以係任UP的<br />\n<br />\n除非去JR佢, 但結果應該係無乜用"},"citedBy":0,"replyTime":"2020-07-29T04:03:54.000Z","msg":"推<br />\n就算唔係為個教席<br />\n都應該利用呢單野對中共出招<br />\n<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"cc2bdc3cc869622e36d81871ae5b2c8b814e785c","tid":2129654,"uid":49669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-29T04:06:48.000Z","msg":"屌"},{"pid":"b6e7c9c40e8bcdb50d4ed94a4f87cd38822730bc","tid":2129654,"uid":286209,"like":0,"dislike":0,"score":0,"quote":{"pid":"14ddfd5187bdaee0175d9ae5d11c5a6547a29046","tid":2129654,"uid":79563,"like":0,"dislike":0,"score":0,"quote":{"pid":"3f881894c6fb49f2965d492f5f47e76ba62c5a23","tid":2129654,"uid":286209,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2020-07-29T02:48:07.000Z","msg":"你當香港市第一人民大學係浪得虛名？<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/yeoM3bG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyeoM3bG.jpg&h=97486dec&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-07-29T04:01:36.000Z","msg":"今朝?"},"citedBy":0,"replyTime":"2020-07-29T04:31:15.000Z","msg":"唔係，Throwback黎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d2fd960cdd6eccb4d33529778b3911fc373d40e8","tid":2129654,"uid":67553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-29T04:35:28.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"74de51e2be5f5041c418fa9725ec9beaa8fd2b1c","tid":2129654,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-29T04:46:47.000Z","msg":"戴耀廷決定就被辭退 向大學校監<strong><span class=\"xx-large\"><span class=\"red\">特首林鄭月娥</span></span></strong>提出上訴<br />\n<br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1540511-20200729.htm?spTabChangeable=0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1540511-20200729.htm%3FspTabChangeable%3D0&d=jpV%2F2%2Bss%2F2Wq3uOsKpdaDy%2F0jIrp0bHqVoz25JuQVd4%3D&h=f35fed59\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1540511-20200729.htm%3FspTabChangeable%3D0&h=0752e650\" target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1540511-20200729.htm?spTabChangeable=0</a><br />\n<br />\n港大校務委員會通過解僱法律系副教授戴耀廷。他今早在社交網站表示，決定向港大校監、即特首林鄭月娥，就校委會辭退他的決定提出上訴。戴耀廷說，雖然知道上訴不可能成功，但不會讓林鄭月娥在傷害香港學術自由的事上置身事外，大學以外勢力推翻大學的決定是昭然若揭，之後會否提出司法覆核，有待與律師團隊商量。<br />\n<br />\n戴耀廷表示，基於保密原則，他不能夠公開大學的文件，但與律師團隊商量後，他向大學提交的文件是可以公開的，公眾可從他提交的文件中，大概掌握爭議的地方是甚麼。<br />\n<br />\n他又指出，雖然離開了港大的崗位，但不會停下法治的研究及教學工作，他計劃用一至兩年時間完成一本有關法治的普及讀物，亦會在香港社區推動法治教育，會為香港法治的重生而繼續抗爭，同時希望支援其他為香港法治重生而戰的人。"}]}