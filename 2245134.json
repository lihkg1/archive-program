的兄弟上<br />\n<br />\n<img src=\"https://hk.appledaily.com/resizer/zQgwXU-K_dJGECywVNcnh4CRIcA=/720x405/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/XTMJVLQP6FFSLBNCSWKP7QOWTY.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FzQgwXU-K_dJGECywVNcnh4CRIcA%3D%2F720x405%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FXTMJVLQP6FFSLBNCSWKP7QOWTY.jpg&h=c41d8251&s={SIZE}\" />"},"citedBy":2,"replyTime":"2020-10-16T03:33:10.000Z","msg":"內部傳出來？"},"citedBy":1,"replyTime":"2020-10-16T03:34:56.000Z","msg":"睇啲字感覺係狗咬狗"},"citedBy":0,"replyTime":"2020-10-16T05:07:11.000Z","msg":"除咗狗仲邊有人叫長官"},{"pid":"de5b44fb959dc06682d665fb3c5bd7a8eaae43bb","tid":2245134,"uid":19817,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T05:08:33.000Z","msg":"<a href=\"https://lihkg.com/thread/2244825/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/2244825/page/1</a><br />\n<br />\n睇清楚兩黨同左媒形勢，就應該做實事, 背水一戰<img src=\"/assets/faces/lomoji/33.png\" class=\"hkgmoji\" />"},{"pid":"7aabf824d637f6aaa038c917d110daf5b16e949c","tid":2245134,"uid":282494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T05:08:58.000Z","msg":"黑警時代"},{"pid":"c26b4baff8bbdedf2830ba48333c873a6f4b0d3d","tid":2245134,"uid":33263,"like":0,"dislike":0,"score":0,"quote":{"pid":"0568476b9b0133f04a37441e6b1ca9f5fb1edf76","tid":2245134,"uid":31447,"like":6,"dislike":0,"score":6,"quote":{"pid":"7c996b79c9921ad0165c85016a10c68dd4fed9f4","tid":2245134,"uid":327934,"like":3,"dislike":0,"score":3,"citedBy":3,"replyTime":"2020-10-16T03:49:34.000Z","msg":"冧友咁大單<br />\n收買個SIP就可以解決？<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-10-16T04:21:57.000Z","msg":"絕對得<br />\n差佬會叫黑社會嗰邊搵人頂左佢<br />\n多數係道友同債仔"},"citedBy":0,"replyTime":"2020-10-16T05:09:03.000Z","msg":"<img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" /><img src=\