30901,"uid":192367,"like":0,"dislike":0,"score":0,"quote":{"pid":"8508043030130eee2856d7b6ebe3435a98784d2b","tid":1530901,"uid":47248,"like":0,"dislike":0,"score":0,"quote":{"pid":"22600663a3f6767922d61fab8be7a1df6d135c3b","tid":1530901,"uid":38819,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-02T05:58:36.000Z","msg":"仲有好多嘢可以做架！唔准諗死呀！<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-09-02T09:24:32.000Z","msg":"我唔知仲可以做啲咩<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-02T20:47:06.000Z","msg":"同我地一班手足訴苦先！"},{"pid":"55916df24e9004b72308d11e08096cfbfd413a68","tid":1530901,"uid":47248,"like":0,"dislike":0,"score":0,"quote":{"pid":"18d9cbf03229de0418d7afab2150ca697e814bcc","tid":1530901,"uid":17623,"like":0,"dislike":0,"score":0,"quote":{"pid":"015fed76e99652d200848a18e7fa9b845b3b969c","tid":1530901,"uid":47248,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-02T20:37:52.000Z","msg":"啱啱返到屋企<br />\n有人企跳<br />\n我好怕有日下一個係我<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-02T20:45:24.000Z","msg":"唔好咁諗啦，有時我都好頹，但只要諗到冇嘢會難到香港人㗎，就有動力堅持落去！<br />\n要捱就一齊捱，唔好扔低身邊努力緊嘅每一位，加油！"},"citedBy":0,"replyTime":"2019-09-02T20:48:14.000Z","msg":"我好想搵人同我同路 但我搵唔到<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"e383b26c69f855eabd8d32d53b48d8d8d50e032c","tid":1530901,"uid":158404,"like":0,"dislike":0,"score":0,"quote":{"pid":"715a084dbabbb15fd7ce557a013cc66404cdce8e","tid":1530901,"uid":47248,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-02T05:39:06.000Z","msg":"對唔住大家 哩個po將會有好多負能量<br />\n但我希望大家可以一齊振作落去<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n我本身係半個港豬 但哩場香土online改變咗我好多<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n6月 啱啱開始返我第一份full time<br />\n每日放工就去政總 天光就返屋企梳洗再返工<br />\n好攰 但大家一齊靜坐 感覺好值得<br />\n6.16 我參與人生第一次夢遊<br />\n我好高興我能成為200萬+1 嘅一分子<br />\n<br />\n7月 行動慢慢升級 一開始我對前線做嘅嘢好理解唔到<br />\n後來 經過慢慢思考 開始接受 而且 點都唔割<br />\n黑驚 政府做嘅越來越過分 我好嬲好嬲<br />\n但我咩都做唔到 就連最和平嘅遊行 我都要返工<br />\n機緣巧合我上咗前面 去完一次 我好想再同大家齊上齊落<br />\n但原諒我未能每次都同到大家並肩作戰<br />\n<br />\n8月 每次殺到公司附近 我好想衝落樓<br />\n但好多人同我講要長大 唔可以咁任性<br />\n我每次都去咗返工 每次都只能夠望住直播 擔心、憤怒、傷心<br />\n究竟我仲可以做啲咩<br />\n<br />\n烈士嘅出現，催淚放題勃起，好多時我只能夠望住電腦mon心痛落淚<br />\n<br />\n望住黑驚做嘢越來越恐怖，我恨不得被捕被打被性騷擾嘅人係我唔再係其他有將來嘅人<br />\n<br />\n我係一個熱愛返工嘅港豬<br />\n因為我要靠每個月嘅萬零蚊養活自己<br />\n但最近令我唔想再繼續行落去<br />\n我好想辭職 我想用自己仲年輕嘅本錢 幫大家擋子彈<br />\n究竟香港同自己 我應該點揀<br />\n淺白嘅道理每個人都知 先好好照顧自己先有力氣去上前救港<br />\n但心靈上生活上 我只能靠自己<br />\n除咗要食自己 我唔知哩啲嘢仲可以搵邊個講<br />\n我遇過太多人話陪我一齊行 但最終扔低咗我自己一個<br />\n每晚我都望住街上嘅車 每次都諗緊不幸究竟幾時降臨喺我身上<br />\n死 可能解決唔到啲咩 但我真係好攰<br />\n攰到 連喊嘅力氣都冇 <br />\n黑社會們 不如下次射我<br />\n<br />\n希望大家睇完唔好俾我影響到<br />\n我相信你哋能夠帶俾香港前路光明<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">香港人 加油</span></span><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: orange;\">光復香港<br />\n時代革命<br />\n<br />\n五大訴求<br />\n缺一不可<br />\n<br />\n沒有暴動<br />\n只有暴政</span></span>"},"citedBy":0,"replyTime":"2019-09-02T20:50:11.000Z","msg":"加油 環境惡劣 但場仗仲有我同你打"},{"pid":"e246dc9a97fe449eee8b16a387c52bcbd6194bcc","tid":1530901,"uid":182088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T20:58:48.000Z","msg":"一定要調整心情<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"0bc875ee45c7a59e54d3c4ac9670e0887a50aac5","tid":1530901,"uid":244306,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T23:30:40.000Z","msg":"巴打<br />\n從字裏行間睇你係一個有同理心嘅人<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><br />\n大家望住事態發展，望住咁多犧牲，有情緒係人之常情，因為你係一個人<img src=\"/assets/faces/fs/want_die.gif\" class=\"hkgmoji\" /><br />\n我地都好渴望自己有一己之力改變一切嘅力量/能力，但容我再提大家一次殘酷嘅事實，現實世界係冇超人亦唔會有superhero<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /><br />\n根據以上邏輯，你同我同呢度任何人都係一樣，大家都冇&quot;一己之力&quot;，咁你又何必將成個運動嘅重擔都揹負上身？你攬哂上身咁我地幾百萬人加埋咪仲廢過你一個？<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /><br />\n<br />\n再者，作為一個有同理心嘅人，你亦不妨咁諗<br />\n呢度任何一個兄弟手足出事，包括你，我地都會無差別地心痛欲絕，難道你好想全香港嘅人因為你而更傷心？我諗你都明每每睇到呢啲新聞時個心有幾乸<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" /><br />\n係囉，大家都已經好傷，唔好令我地更傷啦<br />\n<br />\n最後，請謹記，現實唔係漫畫唔係電影，好難好難好難會今日付出聽日就有收穫，亦唔一定辛苦完就包有好結果<br />\n換句話，冇錯今次係長期戰，但我地唔係軍隊，唔係要你每日都去奮戰到底再上黎報告吓你今日敗敵幾多貢獻幾多<br />\n<br />\n如果你係都要去量化到底要做到點自己先安樂先問心無愧，我會答你只要你有關心過香港，你有擔心過香港，你已經配得上分享今次運動嘅credit<br />\n因為你嘅關心，終有一刻一定會轉化做行動，可以係下一秒，可以係聽日，可以係下個月，可以係出年，可以係任何時候(事實係你已經行動過添)<br />\n<br />\n滴水穿石，從來都唔係解一滴水去穿石<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><br />\nBe water my friend<img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" /><br />\n<br />\n共勉之<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"2f3c5ec0a8a6292674d8a8cba3705db2fb488d09","tid":1530901,"uid":47248,"like":0,"dislike":0,"score":0,"quote":{"pid":"bb76ecb01afea53d3946a241e33ac688cf5c802c","tid":1530901,"uid":192367,"like":0,"dislike":0,"score":0,"quote":{"pid":"abbaa720702825a19fa0dcd5a388fc111626eff1","tid":1530901,"uid":47248,"like":0,"dislike":0,"score":0,"quote":{"pid":"7d3ccded401f91955624dca8a28f029cc741bee1","tid":1530901,"uid":281219,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-02T05:41:48.000Z","msg":"可以失望 不能絕望<br />\n要留番有用之軀！"},"citedBy":2,"replyTime":"2019-09-02T05:51:16.000Z","msg":"我已經幫唔到手做任何嘢<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-02T20:46:01.000Z","msg":"出去已經係幫手！發夢最緊要係起碼要有人<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n你已經好叻，自供自給的情況下，要翻工之餘一有時間就發夢，大家都好明，所以唔好自責。<br />\n<br />\n<br />\n應承大家，要係煲底相認<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-03T01:41:28.000Z","msg":"我好想辭職 但我有責任在身<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n其實我有好多嘅限制令我唔可以返到屋企做返完全嘅自己 好辛苦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n我好想有人明我<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"}]}