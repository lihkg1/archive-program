cdfda8d&s={SIZE}\" /><img src=\"https://na.cx/i/DqksFP4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDqksFP4.jpg&h=b4b8fed1&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-09-04T11:49:35.000Z","msg":"我哋一齊唱"},{"pid":"27c20dfc5b51d81e18bc536733ba02785771db60","tid":1540494,"uid":197563,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-09-04T11:49:37.000Z","msg":"<img src=\"https://na.cx/i/S0Y2uMa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FS0Y2uMa.jpg&h=fb852f58&s={SIZE}\" />"},{"pid":"9c8b98c93052ec32fcca13109a9d1169dc429c39","tid":1540494,"uid":301479,"like":0,"dislike":0,"score":0,"quote":{"pid":"b70b9d735e353616d832e8a0eb73afe566f21fa7","tid":1540494,"uid":43785,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T11:38:39.000Z","msg":"其實你知唔知我哋贏緊？？？ 唔該唔好喺見到曙光嘅時候就散水。 五大訴求缺一不可<br />\n我哋唔好再犯五年前嘅錯啦好嗎？？<br />\n<br />\n共產黨出名欺善怕惡同犯賤㗎，香港直頭係共產黨個春袋， 香港人越反抗，越惡越可以攞到共產黨更加多嘅利益去氹你哋班香港人， 澳門乖乖地做順民反而乜嘢利益都冇 。<br />\n<br />\n喺10月1呢條死線之前， 已經回應咗一大訴求， 你估一直咁樣搞落去我哋可唔可以攞到五大訴求丫拿？<br />\n<br />\n你聽建制果邊講就知，獨立調查委員會已經一早預備咗， 湯家驊亦都講過可以特赦， 至於真普選， 中共喉舌已經晨早講咗 好多次香港普選嘅嘢 ，我哋亦有香港民主人權法案企後面。<br />\n企硬話唔回應既，最難嘅一步已經撤回咗。<br />\n五大訴求完全達成，係絕對有可能㗎！<br />\n<br />\n<br />\n<br />\n社運再搞落去，你知唔知我哋真係望到好大曙光， 因為有幾條死線等住共產黨去食。<br />\n----------------------------<br />\n十月一號前香港平亂賀國慶，係中共俾林鄭既死線， 搞唔掂，係習近平治國不力， 中共70週年國慶仍然不得安寧。<br />\n若果情況持續，大陸有唔少地方都會有公民覺醒運動。<br />\n<br />\n美國復會， 討論《香港民主人權法案》係港共高官黑警死線。 甚至乎可以加快香港雙普選進程。<br />\n若果制裁到中共高官， 玩到凍結資產， 上面隨時鬼打鬼，政變都嚟緊。<br />\n<br />\n最終玩到美國廢除/大改《香港關係法》， 係共產黨亡國既死線。<br />\n<br />\n再係咁搞落去機場禁制令， 仲會搞到機場啲商舖攬炒， 日日蝕租金蝕人工。<br />\n<br />\n樓價大跌， 地產舖大裁員。<br />\n藥房生意大減， 執笠裁員<br />\n金舖鐘錶等奢侈品生意大減， 陸續結業， 騰空更多舖頭畀其他有心人<br />\n鋪租大減。 地產霸權神話慢慢玩完。<br />\n嚟香港讀書人數減少， 香港人升大學學位增加。<br />\n自由行來港人數大減， 香港各區回復寧靜乾淨。<br />\n<br />\n<br />\n我哋香港人贏緊呀， 你哋明唔明呀？"},"citedBy":0,"replyTime":"2019-09-04T11:52:53.000Z","msg":"push"},{"pid":"22eb1cf6b84f46ab673ead47a81258d47888bf99","tid":1540494,"uid":43785,"like":0,"dislike":0,"sco