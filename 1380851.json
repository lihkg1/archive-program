019-07-29T06:19:14.000Z","msg":"10"},{"pid":"7ae8c412fcf18f8c670b3131d958848b63426236","tid":1380851,"uid":228656,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T06:19:24.000Z","msg":"9"},{"pid":"5154b8ddf8dbf84bf1d0ef2f879c1b127b6d579e","tid":1380851,"uid":228656,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T06:19:34.000Z","msg":"8"},{"pid":"9252c4a300b63c89f1cc65614366badb25ec2a39","tid":1380851,"uid":208452,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T06:19:41.000Z","msg":"<span style=\"font-size: large;\"><span style=\"color: red;\">推! 8月5罷工!!!!! </span></span><br />\n<br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">今日(7月29)1500-1830</span></span>會有義工係<span style=\"color: red;\"><span style=\"font-size: large;\">旺角東天橋</span></span>擺街站等無上連登的市民都可以寫底感受比我地,希望大家支持<br />\n<span style=\"color: red;\"><span style=\"font-size: x-large;\">【眾籌】 已集合超過1000名巴絲感想 香港編年史</span></span><br />\n<a href=\"https://lihkg.com/thread/1379634/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1379634/page/1</a>"},{"pid":"caef31309aad842bf2991ee2280fb15bea56e766","tid":1380851,"uid":228656,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T06:19:44.000Z","msg":"7"},{"pid":"8d7e8ffa48b64daeac93896cd8ffec0e463a4692","tid":1380851,"uid":228656,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T06:20:04.000Z","msg":"8月5罷工!"},{"pid":"cf169ffbcc2f96f601231c91a77b1fe86c942390","tid":1380851,"uid":228656,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T06:22:19.000Z","msg":"人呢"},{"pid":"be0b582ade8ae966e549f7d294b94c3af29ee56e","tid":1380851,"uid":228656,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T06:22:29.000Z","msg":"10"},{"pid":"4f0d7ba0d869d14fbd01babc0949005bca5c71cb","tid":1380851,"uid":228656,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T06:22:39.000Z","msg":"9"},{"pid":"7bf922126f1f594042ab7