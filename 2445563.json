data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrmcCr8i.png&h=d26a3ce7&s={SIZE}\" />"},{"pid":"7a09d12b58e2af9905ff9c69ba8b5a81f9bdd201","tid":2445563,"uid":61604,"like":0,"dislike":0,"score":0,"quote":{"pid":"f7ffca39c4f560f7052f862874bd669955b10121","tid":2445563,"uid":4574,"like":2,"dislike":0,"score":2,"quote":{"pid":"8f1c0acccfcfa4bd2d8950cb544c78349959de47","tid":2445563,"uid":19627,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-03-13T23:40:22.000Z","msg":"當初好似佢講唔好打針政治化？<br />\n點解而家科興咁多負面新聞時 唔打科興勉救返啲形象 走去打biontech <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n佢係疫苗團隊成員 好應該要打科興啦"},"citedBy":2,"replyTime":"2021-03-14T02:23:10.000Z","msg":"既然唔係政治問題<br />\n一個專家決定打復必泰<br />\n即係復必泰&gt;&gt;&gt;&gt;&gt;科興"},"citedBy":0,"replyTime":"2021-03-14T02:37:44.000Z","msg":"最好： 唔打疫苗（蔡堅）&gt; biotech(許樹昌） &gt;科興（高官）&gt; 長期病患（死撚埋）"},{"pid":"da4f624abf9dd8f9c32487d75f84a1e56cbebc75","tid":2445563,"uid":222614,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-03-14T02:40:27.000Z","msg":"與滅活疫苗（例如流感疫苗）不同，mRNA 疫苗打入人體之後，細胞會讀取 RNA 上嘅指令，然後根據指令，製造出指定嘅蛋白質<br />\n<br />\n以輝瑞嘅 covid vaccine 為例, RNA 會指示細胞製造 covid virus 表面嘅抗原，從而令身體產生免疫反應<br />\n<br />\n正常細胞讀取 RNA，然後製造病毒抗原，然後抗原會浮出，佈滿該細胞嘅表面<br />\n當免疫系統貞測到細胞表面上嘅抗原，就會引起免疫反應，將細胞殺死<br />\n免疫系統會記得呢隻抗原，當下次再遇到嘅時候，就會更快有免疫反應，即係所謂嘅「對病毒免疫／有抗體」"},{"pid":"d28ef757215686449051fe6c8f5a8fda9b991095","tid":2445563,"uid":154978,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-03-14T02:44:19.000Z","msg":"垃圾許樹昌淨係識得做打手<br />\n讀唔撚嘢Science<br />\nData唔夠你會出到paper咩"},{"pid":"9bbaa03a4b2554536cdf3302f6697df279c6fa1d","tid":2445563,"uid":19627,"like":0,"dislike":0,"score":0,"quote":{"pid":"f7ffca39c4f560f7052f862874bd669955b10121","tid":2445563,"uid":4574,"like":2,"dislike":0,"score":2,"quote":{"pid":"8f1c0acccfcfa4bd2d8950cb544c78349959de47","tid":2445563,"uid":19627,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-03-13T23:40:22.000Z","msg":"當初好似佢講唔好打針政治化？<br />\n點解而家科興咁多負面新聞時 唔打科興勉救返啲形象 走去打biontech <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n佢係疫苗團隊成員 好應該要打科興啦"},"citedBy":2,"replyTime":"2021-03-14T02:23:10.000Z","msg":"既然唔係政治問題<br />\n一個專家決定打復必泰<br />\n即係復必泰&gt;&gt;&gt;&gt;&gt;科興"},"citedBy":0,"replyTime":"2021-03-14T02:50:05.000Z","msg":"好似都係佢講 外國疫苗未必啱中國人 都係佢講<br />\n而家走去打biontech 咁即係.....<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}