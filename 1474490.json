000000 或 N/A<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=%2BEgMKdsH73Wj%2FuX4aBpXdjizWcNDgH0nsvPDQhA%2BiAk%3D&h=7758d511\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"5c211ad6f3f3ff759294e2a7d1a6d0b1b897432a","tid":1474490,"uid":236073,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:04:00.000Z","msg":"此回覆已被刪除"},{"pid":"94ea9c0cd887842783bcf38ad16818b28aff09ed","tid":1474490,"uid":264203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:04:29.000Z","msg":"推"},{"pid":"ba4a841d7f875d1b803976f5f81e525421beb0df","tid":1474490,"uid":31369,"like":0,"dislike":0,"score":0,"quote":{"pid":"89817d170f9d7a5c1670b74ca079a41d19d5bf4a","tid":1474490,"uid":181581,"like":7,"dislike":0,"score":7,"citedBy":2,"replyTime":"2019-08-15T07:55:20.000Z","msg":"帶 會擺入袋"},"citedBy":0,"replyTime":"2019-08-15T08:05:01.000Z","msg":"岩 冇咩都唔想帶住 熱到"},{"pid":"4113330ce9abff61927c82c3af56180fb1ca1e50","tid":1474490,"uid":235465,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:05:02.000Z","msg":"個人支持唔帶 帶口罩 真點完左就散"},{"pid":"d06d930693903c8f9d3371ce55c58b31abf82a88","tid":1474490,"uid":259166,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:17:38.000Z","msg":"唔可以用常理推測狗下一步行動。 昨晚ssp 冇人都會發tg啦!"},{"pid":"038e6717fedce3335e3d3e0afd8fd60475717384","tid":1474490,"uid":31369,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T09:10:11.000Z","msg":"可能帶個豬嘴算"},{"pid":"2cb990fe7fd181fea4f630c6d1a83427ac9f1a01","tid":1474490,"uid":278634,"like":0,"dislike":0,"score":0,"quote":{"pid":"9e01dba82aaff7a2223ba2f10af513dc117d2cb3","tid":1474490,"uid":31369,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-15T07:54:40.000Z","msg":"投票結果唔係重點 大家討論下"},"citedBy":0,