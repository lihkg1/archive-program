g src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"b43f14f73ba8f41169fd639b4889f45ca000369a","tid":1157483,"uid":155095,"like":4,"dislike":0,"score":4,"quote":{"pid":"d4f02226c238fe9820e321a544f32e2500c6a0ab","tid":1157483,"uid":49197,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2019-05-16T10:34:39.000Z","msg":"當時的上海市長陳毅形容他們是「空降部隊」。<br />\n<br />\n呢條打靶咁講野<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-16T11:13:23.000Z","msg":"寧要核子不要褲子都係<br />\n陳毅做外交部長嗰陣講"}]}