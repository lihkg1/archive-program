-30T04:16:57.000Z","msg":"另外都想討論和理非應否報警嘅問題<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><br />\n<strong><span style=\"color: red;\">[思想都要Full Gear]不要說是私了，試著說政府撕毀了社會契約</span></strong><br />\n<a href=\"https://lihkg.com/thread/1515859/\" target=\"_blank\">https://lihkg.com/thread/1515859/</a>"},{"pid":"50ee14949d4275962282a3a991fe4e4735e28ae4","tid":1517730,"uid":87780,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T04:18:12.000Z","msg":"兩個字 恐懼"},{"pid":"c4bc9c413a4b8ffad5648dbe16db7320f3e24c5b","tid":1517730,"uid":143016,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T04:21:53.000Z","msg":"點解決"},{"pid":"fa3e641c9c2d6f9ede105e3c057b207b33e89b39","tid":1517730,"uid":273157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T04:22:35.000Z","msg":"<img src=\"https://na.cx/i/PNrnwJP.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPNrnwJP.jpg&h=f502a4b5&s={SIZE}\" />"},{"pid":"f8f58def80493879463527c684d7f5f2a62ff12c","tid":1517730,"uid":210682,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T04:23:24.000Z","msg":"最唔想緊急法出現嘅其實係習近平"},{"pid":"991dc8045155a172eb76e7a568251ca2aae5429d","tid":1517730,"uid":234271,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T04:23:32.000Z","msg":"佢哋估我地就算民陣取消都會繼續出遮打<br />\n而港島區方面應該就會佈重兵捉你非法集結"},{"pid":"13246e6657089ac4a1014db1078fcce3b63b3ba3","tid":1517730,"uid":44562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T04:25:06.000Z","msg":"非法集會, 拉得就拉, 佢仲可以點 ?"},{"pid":"306088af9e324b5044cbc89a1b6405a80fa244cb","tid":1517730,"uid":50904,"like":1,"dislike":0,"score":1,"quote":{"pid":"991dc8045155a172eb76e7a568251ca2aae5429d","tid":1517730,"uid":234271,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T04:23:32.000Z","msg":"佢哋估我地就算民陣取消都會繼續出遮打<br />\n而港島區方面應該就會佈重兵捉你非法集結"},"citedBy":1,"replyTime":"2019-08-30T04:26:24.000Z","msg":"我估其實佢考慮係港島線封定唔封好，點做都死<br />\n中聯辦落硬重兵，無左遊行大隊cover，full gear過去太高危"},{"pid":"73166bb1fcf91cb24907cbfe5a3eabd74661d014","tid":1517730,"uid":271778,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-30T04:31:34.000Z","msg":"你認為政府認為呢種形式嘅緊急法有機會唔引致外資撤資？<br />\n好似送中條例咁，條文本身唔係最重要，法治破壞左就係破壞左，我相信外資好清楚呢件事。"},{"pid":"ad4bb36d7daa902b3d0345764353a292bd60f5a6","tid":1517730,"uid":50904,"like":0,"dislike":1,"score":-1,"quote":{"pid":"73166bb1fcf91cb24907cbfe5a3eabd74661d014","tid":1517730,"uid":271778,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-30T04:31:34.000Z","msg":"你認為政府認為呢種形式嘅緊急法有機會唔引致外資撤資？<br />\n好似送中條例咁，條文本身唔係最重要，法治破壞左就係破壞左，我相信外資好清楚呢件事。"},"citedBy":0,"replyTime":"2019-08-30T04:38:29.000Z","msg":"我覺得政府當然知到自己做緊乜，但撤資係已經進行中，佢已經救唔到<br />\n但好多人出黎佢又局住要做啲野，港島線封站、或者係中環出水炮一樣係對自己金融中心好大殺傷力<br />\n同時佢亦都要為9月1做啲佈署，但機埸又好難宜接出手，先迫於再用惡法大你"},{"pid":"fa5e2c4793eef6dfe6bdbd759ac541fdbac595e4","tid":1517730,"uid":284264,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T04:40:20.000Z","msg":"總之一定要行出來！！！"},{"pid":"e464df69c43976de33d91bf3ea5f6f6b81032dcd","tid":1517730,"uid":205469,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T04:43:24.000Z","msg":"聲東擊西有冇得諗？<br />\n但有擊邊度？"},{"pid":"abbef0ccb8f72feb671fe9ae7fdea24f7d22513f","tid":1517730,"uid":50904,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa5e2c4793eef6dfe6bdbd759ac541fdbac595e4","tid":1517730,"uid":284264,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T04:40:20.000Z","msg":"總之一定要行出來！！！"},"citedBy":0,"replyTime":"2019-08-30T04:48:16.000Z","msg":"無錯，繼續比壓力政府，佢無牌可用時一係攬炒、一係跪低"},{"pid":"8e33d82e8c00aa570299fc4378a0d835c53b1c73","tid":1517730,"uid":154277,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-30T04:49:16.000Z","msg":"殘體注意, twitter睇到:<br />\n按照剧情，香港警方已经明确发布了&mdash;831反对游行通知，如果港人依然继续游行，则香港政府借机执行&ldquo;紧急法&rdquo;，当天晚上或进行强制清场，9月1日，进行大抓捕！然后胡锡进指导的港媒开始歪曲报道，&ldquo;紧急法&rdquo;执行过程中，军队的克制以及示威者的暴力，第二天采访事先准备好的&ldquo;市民&rdquo;对香港恢复秩序，充满感恩！<br />\n//<br />\n党卫军&ldquo;轮换&rdquo;进入香港、中共通报十一大阅兵；所有的重大信息里我