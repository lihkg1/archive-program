ata-type=\"rb\">def pk_month?(日主)\n  return true if 流月月干 == 日主\n\n  流月月干. between?(流年年干.受剋之月, 日主) if 流年年干 == 日主\nend</code></pre>"},{"pid":"e15de8b4078a55e4fdc54f986ad4e0f1490b0a30","tid":2463041,"uid":125976,"like":0,"dislike":0,"score":0,"quote":{"pid":"e493b56826ef0530352dafc0b0117b0e98ae1368","tid":2463041,"uid":57503,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-26T12:00:18.000Z","msg":"五行缺水係咪代表姻緣差同窮？"},"citedBy":0,"replyTime":"2021-03-26T12:07:52.000Z","msg":"睇水係你十神嘅乜"},{"pid":"6ee9ffa9f5d459a0d10803b961681c4b5b731906","tid":2463041,"uid":73410,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-26T12:08:58.000Z","msg":"我八字要木火<br />\n究竟舊年衰啲 定今年會更衰<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},{"pid":"a06a76a4a650a7a41c12f36fc0e483f2186880a1","tid":2463041,"uid":356078,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-26T12:09:59.000Z","msg":"有人話我八字都係陽，仲要女仔，話我會姻緣好差，同性朋友關係都差<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"15bad41af6aa2f37a53ef920feb6ff7fa3448e52","tid":2463041,"uid":387826,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-26T12:11:17.000Z","msg":"真<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"48b4bcefb63ba378c51933c349522a31fb87fa70","tid":2463041,"uid":125976,"like":0,"dislike":0,"score":0,"quote":{"pid":"f6439e6ae0e44df7592fc5da79925d798de2e5e1","tid":2463041,"uid":163945,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-26T12:00:20.000Z","msg":"食傷生財啲人 要點先搵到大錢？"},"citedBy":0,"replyTime":"2021-03-26T12:12:50.000Z","msg":"𠵱個又係 good question<br />\n<br />\n唔好以為財運好 == 打好工、人工高，好多人唔識用財運<br />\n<br />\n財運係要透過自己嘅 performance 生出嚟，所以大部分打工仔份糧都唔係財運一部分，反而人工高唔高屬官運<br />\n<br />\n財運要用到得幾個方法：<br />\n1. 做生意、銷售業務、買賣<br />\n2. 投資（要有技術嗰種，非投機）<br />\n3. freelance (因為多勞多得屬財運)<br />\n<br />\n所以財運唔係咁易用，賭錢博彩嗰啲都唔算"},{"pid":"729e7841e569f00b6925c49930a3a2b4e04ec1e0","tid":2463041,"uid":125976,"like":0,"dislike":0,"score":0,"quote":