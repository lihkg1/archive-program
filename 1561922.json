id":"3e11e2ef8d329a4a0bdc05d0f7a6eb30f3386b3b","tid":1561922,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T22:53:52.000Z","msg":"<img src=\"/assets/faces/mf/good.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/good.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/good.png\" class=\"hkgmoji\" />"},{"pid":"f045dbc0c948d5724d2ee9cf4cf3b875f2db9c85","tid":1561922,"uid":20723,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-09-11T22:55:19.000Z","msg":"<img src=\"https://na.cx/i/0pEqbc4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0pEqbc4.png&h=1f16fd8e&s={SIZE}\" /><br />\n<br />\n<a href=\"https://petitions.whitehouse.gov/petition/request-communist-china-government-redeem-imperial-dynasty-s-bond\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Frequest-communist-china-government-redeem-imperial-dynasty-s-bond&d=y6uglPlKbSLkZz%2BcPL4okfkXgXr6FxeO6pMo8RORPdo%3D&h=dc40f854\" target=\"_blank\">https://petitions.whitehouse.gov/petition/request-communist-china-government-redeem-imperial-dynasty-s-bond</a><br />\n<br />\n<span style=\"font-size: large;\"><strong>記得click verify email</strong></span><br />\n<br />\n任何國際之間既債務都有繼承義務<br />\n慈禧簽果條辛丑條約 一戰果時民國繼續還<br />\n仲要還到1938年因爲打二戰窮到pk<br />\n去求條約國唔追辛丑賠款先可以停<br />\n既然中共自稱滿清正統承繼人<br />\n呢張債券自然本利點都要還<br />\n唔還既佢講乜差野要用南京條約去收番香港<br />\n而且美國政府係未同中共追還錢<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/wjpU2AG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwjpU2AG.jpg&h=45a46f02&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">Yes! US</span></strong></span><br />\n<br />\n<img src=\"/assets/faces/mf/special3.gif\" class=\"hkgmoji\" />"},{"pid":"4f04823987be8cb2b4d584425c2b5d1691945f16","tid":1561922,"uid":28028,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2019-09-11T22:56:43.000Z","msg":"同以前講唔好勇武啊<br />\n光