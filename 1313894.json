 src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3569c8391a21a557e5d8bba02779543ee4cf67b2","tid":1313894,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-14T03:27:18.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"eff9b532ba1eb8bc1634346babae6b4f7b991631","tid":1313894,"uid":34722,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-07-14T03:29:50.000Z","msg":"東方連三歲智商都沒<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 仲講緊行動要有人組織，老屎忽思維<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"d25f3f3fbdc4810c3c43b58a3acdcbaf1d69827b","tid":1313894,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-14T03:36:46.000Z","msg":"<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"d83370105b0af72c3d339edda8dbb124dc50dd1c","tid":1313894,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-14T03:39:58.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 全世界，外國媒體都報道香港係國際示威嘅革新者，<br />\n沒有大台，沒有領袖，全民自發<br />\n<br />\n支共媒體，支共，政府，克警就一口咬定係泛民／外國勢力<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n人地外國仲清楚過你地住係香港嘅支共人"},{"pid":"cfed82c12c0fa3b7048e0082ce3aed3cfedad7b0","tid":1313894,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-14T03:39:59.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"690935c238c43d339ed08ecdfc7b44ebe853b2e6","tid":1313894,"uid":134071,"like":0,"dislike":0,"score":0,"quote":{"pid":"23c8b8c4beadbe9fd67662e75328aa500057468d","tid":1313894,"uid":277316,"like":1,"dislike":0,"score":1,"quote":{"pid":"26a14a1d047a15d1272e932056a15a47a21f098f","tid":1313894,"uid":4462,"like":18,"disl