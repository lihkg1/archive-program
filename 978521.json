b02b2569f6b1c9820bea3","tid":978521,"uid":49812,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-01-14T05:39:50.000Z","msg":"<a href=\"https://lihkg.com/thread/930358\" target=\"_blank\">https://lihkg.com/thread/930358</a><br />\n#17<br />\n<br />\n有機會係火牛過熱<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />，亦有機會係火牛唔夠力<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"4b6bb2cb15ae9af8c0f15c22a8c277171cb67e4e","tid":978521,"uid":92166,"like":0,"dislike":0,"score":0,"quote":{"pid":"ca96a282550f72abd63b02b2569f6b1c9820bea3","tid":978521,"uid":49812,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-01-14T05:39:50.000Z","msg":"<a href=\"https://lihkg.com/thread/930358\" target=\"_blank\">https://lihkg.com/thread/930358</a><br />\n#17<br />\n<br />\n有機會係火牛過熱<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />，亦有機會係火牛唔夠力<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-14T05:54:01.000Z","msg":"低機會過燒板<br />\n<br />\n無限重開黎講<br />\n壞板&gt;&gt;&gt;&gt;&gt;&gt;&gt;壞牛&gt;&gt;壞u<br />\n<br />\n直機橫機都好，板好多人拗住落唔覺，螺絲鬆緊冇拿捏好，case有工差又唔知，又孭住張vga，一兩年冇乜野，日子長左d導電，電容焊點越扭越勁就會出斷電保護，就無限重開<br />\n<br />\n總之裝工，機箱工藝，板本身質素，擺放方式，都會影響塊板耐久度，以唔oc一般用家黎計最快打柴既係板，因為太多因素損耗到佢<br />\n<br />\n而牛雖然都有質素參差問題，但一般都會買隻大過用量要求既輕輕鬆鬆行，唔係做咩某d廠敢保到5年以上<br />\n<br />\n而u除oc同個別例子，造工最精良既就係佢<br />\n<br />\n<br />\n乜都好，壞板就預換8成野當升級啦"},{"pid":"788bdb15a22a7d101ab9965085bc9b89bb3a0bfa","tid":978521,"uid":19218,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-14T07:17:31.000Z","msg":"感謝大家回覆指教，如果係咁，我唔拎出去整了。"},{"pid":"c517fac54b