replyTime":"2020-07-23T23:43:03.000Z","msg":"Push"},{"pid":"80b5190e95421db3f27498f563539039aebb87f1","tid":2122083,"uid":216621,"like":0,"dislike":0,"score":0,"quote":{"pid":"541fd99e8a942af922f50e1973efdf3e4b1c74fd","tid":2122083,"uid":74339,"like":0,"dislike":0,"score":0,"quote":{"pid":"2774304e4107dc2aa6108388794f04fd4d63e4b1","tid":2122083,"uid":12086,"like":0,"dislike":0,"score":0,"quote":{"pid":"85cede23dc437e72b0e006f5c839828010c62e4b","tid":2122083,"uid":36901,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-23T22:38:29.000Z","msg":"taxi"},"citedBy":1,"replyTime":"2020-07-23T23:08:54.000Z","msg":"講真唔係衰的士佢會唔會變左民主派元老"},"citedBy":1,"replyTime":"2020-07-23T23:37:20.000Z","msg":"即係點 我年紀細唔知發生咩事 可以講多啲嘛？<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-07-23T23:43:34.000Z","msg":"Wiki有講<br />\n<a href=\"https://zh.wikipedia.org/wiki/%E8%AD%9A%E6%83%A0%E7%8F%A0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E8%25AD%259A%25E6%2583%25A0%25E7%258F%25A0&d=7JJHJI7m8dwGfBTVwC1i6JS3ibws79Cb3MvuL7akqOg%3D&h=9ea218d7\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/wiki/%E8%AD%9A%E6%83%A0%E7%8F%A0</a>"},{"pid":"e5910b5497b5b92ead8edc9746b4c8af3730dc42","tid":2122083,"uid":74339,"like":0,"dislike":0,"score":0,"quote":{"pid":"80b5190e95421db3f27498f563539039aebb87f1","tid":2122083,"uid":216621,"like":0,"dislike":0,"score":0,"quote":{"pid":"541fd99e8a942af922f50e1973efdf3e4b1c74fd","tid":2122083,"uid":74339,"like":0,"dislike":0,"score":0,"quote":{"pid":"2774304e4107dc2aa6108388794f04fd4d63e4b1","tid":2122083,"uid":12086,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-23T23:08:54.000Z","msg":"講真唔係衰的士佢會唔會變左民主派元老"},"citedBy":1,"replyTime":"2020-07-23T23:37:20.000Z","msg":"即係點 我年紀細唔知發生咩事 可以講多啲嘛？<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-07-23T23:43:34.000Z","msg":"Wiki有講<br />\n<a href=\"https://zh.wikipedia.org/wiki/%E8%AD%9A%E6%83%A0%E7%8F%A0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E8%25AD%259A%25E6%2583%25A0%25E7%258F%25A0&d=7JJHJI7m8dwGfBTVwC1i6JS3ibws79Cb3MvuL7akqOg%3D&h=9ea218d7\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/wiki/%E8%AD%9A%E6%83%A0%E7%8F%A0</a>"},"citedBy":2,"replyTime":"2020-07-23T23:47:00.000Z","msg":"Thx<br />\n<br />\n//1990年7月，《壹週刊》揭發譚惠珠身為交通諮詢委員會主席，竟然擁有從事的士牌炒賣活動的「先達的士公司」股份，而且未有申報該利益。由於事件涉及利益衝突[10][11]，更因事件被無綫新聞跟進，而向無綫主席邵逸夫申訴，掀起一場干預新聞自由風波[12]，令當時港英政府逐漸與她疏遠，事件成了她政治生涯轉捩點。1991年，譚惠珠不再獲委任為行政局議員、立法局議員及交通諮詢委員會主席，最後因誠信破產而一度被迫淡出政壇。[13]<br />\n<br />\n到1990年代後，譚惠珠言行變為極親中共，如2002年就《基本法》第二十三條立法，過程引起香港各界反彈，條文被指是針對民主派。譚惠珠更說：「反對的人，不配做中國公民」，對此番言論，已故香港民主派元老司徒華曾在《且看看譚惠珠的昨天》一文中提及，曾為「四料議員」及太平紳士的譚惠珠，過去五次宣誓效忠英女皇，任職基本法起草委員會期間，在一些會議中代表為英國一方發言[14]。2013年，譚惠珠獲頒授大紫荊勳章，民主派立法會議員李卓人批評，譚惠珠是政治投機分子，不站在港人立場說過半句話：「回歸前親英鬧中國政府、回歸後幫中共打壓香港人。」//"},{"pid":"263dc6b63bf1d9dc0d9a67c0b1711b0d2e2ae097","tid":2122083,"uid":177578,"like":0,"dislike":0,"score":0,"quote":{"pid":"71ecef85649487963839df0826c2d5c7fb2e29c0","tid":2122083,"uid":79005,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-23T20:39:40.000Z","msg":"點解佢會變成咁<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-23T23:48:33.000Z","msg":"身在曹營心在漢<br />\n歷史一定還佢清白<br />\n<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"52f146ce18081229715278d9f251825d4e3acd4f","tid":2122083,"uid":41243,"like":0,"dislike":0,"score":0,"quote":{"pid":"e5910b5497b5b92ead8edc9746b4c8af3730dc42","tid":2122083,"uid":74339,"like":0,"dislike":0,"score":0,"quote":{"pid":"80b5190e95421db3f27498f563539039aebb87f1","tid":2122083,"uid":216621,"like":0,"dislike":0,"score":0,"quote":{"pid":"541fd99e8a942af922f50e1973efdf3e4b1c74fd","tid":2122083,"uid":74339,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTi