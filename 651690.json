2.000Z","msg":"係的"},"citedBy":2,"replyTime":"2018-05-03T10:05:30.000Z","msg":"我已經寫好咗段code了<br />\n如果某一格入面根本無8位數字，你想條function顯示啲咩呀？"},"citedBy":0,"replyTime":"2018-05-03T10:12:14.000Z","msg":"formula都做到，返到屋企先post"},{"pid":"089dbfd10ad2d3d8bc358d660889fbe2e6eeeb8b","tid":651690,"uid":71237,"like":0,"dislike":0,"score":0,"quote":{"pid":"0619049eade14f07744715c2055fe7a1328981b3","tid":651690,"uid":78186,"like":0,"dislike":0,"score":0,"quote":{"pid":"257df2893e24550c26500ddc090d45d3f0f3ce30","tid":651690,"uid":71237,"like":0,"dislike":0,"score":0,"quote":{"pid":"3639803902d2d4e42e432ef77add54a7f6c437a3","tid":651690,"uid":78186,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-03T09:57:42.000Z","msg":"係的"},"citedBy":2,"replyTime":"2018-05-03T10:05:30.000Z","msg":"我已經寫好咗段code了<br />\n如果某一格入面根本無8位數字，你想條function顯示啲咩呀？"},"citedBy":1,"replyTime":"2018-05-03T10:11:35.000Z","msg":"&quot; &quot;, 空格就得了, THANKS, 大師"},"citedBy":0,"replyTime":"2018-05-03T10:18:27.000Z","msg":"你之前用過vba未？知唔知點樣加一條function？<br />\n如果唔知的話，由下面果條Youtube片的1:13至1:40，會教你點樣貼code。<br />\n貼完之後你就有一個function叫「find_eight」（唔鍾意依個名的話，你都可以自己修改）<br />\n跟住當普通function咁用就可以。<br />\n<br />\n<br />\n<a href=\"https://youtu.be/f0G1QUOWN2E?t=74\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Ff0G1QUOWN2E%3Ft%3D74&d=tvs6FLCP3kzxy%2BifI1j3NS7PofNJLCAwyGXsi6MH%2FEQ%3D&h=346a50ae\" target=\"_blank\">https://youtu.be/f0G1QUOWN2E?t=74</a><br />\n<br />\n以下係vba的程式碼：<br />\n<br />\nFunction find_eight(Input_String As String)<br />\n<br />\nLength = Len(Input_String)<br />\n<br />\n    For i = 1 To Length - 7<br />\n        If Mid(Input_String, i, 1) = 8 Then<br />\n            For j = 1 To 7<br />\n                If IsNumeric(Mid(Input_String, i + 1, 7)) Then<br />\n                    find_eight = Mid(Input_String, i, 8)<br />\n                    Exit Function<br />\n                End If<br />\n            Next j<br />\n        End If<br />\n    Next i<br />\n    find_eight = &quot; &quot;<br />\nEnd Function"},{"pid":"5cc607807c79ff4810225d638bc7ed7eb1a1ad35","tid":651690,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-03T10:21:31.000Z","msg":"<blockquote><br />\n以下係vba的程式碼：<br />\n<br />\nFunction find_eight(Input_String As String)<br />\n<br />\nLength = Len(Input_String)<br />\n<br />\n    For i = 1 To Length - 7<br />\n        If Mid(Input_String, i, 1) = 8 Then<br />\n            <span style=\"color: red;\">For j = 1 To 7</span><br />\n                If IsNumeric(Mid(Input_String, i + 1, 7)) Then<br />\n                    find_eight = Mid(Input_String, i, 8)<br />\n                    Exit Function<br />\n                End If<br />\n            <span style=\"color: red;\">Next j</span><br />\n        End If<br />\n    Next i<br />\n    find_eight = &quot; &quot;<br />\nEnd Function</blockquote><br />\nsorry，頭先果段code打多咗兩行。<br />\n你可以delete返佢。<br />\n（雖然唔delete都無問題）"},{"pid":"7afecec010c7fa6e5bab949b2d6b5896e97bf264","tid":651690,"uid":78186,"like":0,"dislike":0,"score":0,"quote":{"pid":"5cc607807c79ff4810225d638bc7ed7eb1a1ad35","tid":651690,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-03T10:21:31.000Z","msg":"<blockquote><br />\n以下係vba的程式碼：<br />\n<br />\nFunction find_eight(Input_String As String)<br />\n<br />\nLength = Len(Input_String)<br />\n<br />\n    For i = 1 To Length - 7<br />\n        If Mid(Input_String, i, 1) = 8 Then<br />\n            <span style=\"color: red;\">For j = 1 To 7</span><br />\n                If IsNumeric(Mid(Input_String, i + 1, 7)) Then<br />\n                    find_eight = Mid(Input_String, i, 8)<br />\n                    Exit Function<br />\n                End If<br />\n            <span style=\"color: red;\">Next j</span><br />\n        End If<br />\n    Next i<br />\n    find_eight = &quot; &quot;<br />\nEnd Function</blockquote><br />\nsorry，頭先果段code打多咗兩行。<br />\n你可以delete返佢。<br />\n（雖然唔delete都無問題）"},"citedBy":0,"replyTime":"2018-05-03T11:11:49.000Z"