f74710018d1a185b1e6","tid":1530420,"uid":172349,"like":9,"dislike":2,"score":7,"citedBy":2,"replyTime":"2019-09-02T03:10:08.000Z","msg":"罷工同罷課係兩件事，唔好成日綑綁一齊講<br />\n<br />\n大學罷課比全港罷工容易搞得多<br />\n<br />\n大學罷課都未搞得到，唔好輕言講全港罷工"},"citedBy":1,"replyTime":"2019-09-02T03:16:04.000Z","msg":"agger"},{"pid":"3ef8a479ec3164af6fb4aeaf6ca1d4b0ce01144b","tid":1530420,"uid":150930,"like":9,"dislike":0,"score":9,"citedBy":3,"replyTime":"2019-09-02T03:20:31.000Z","msg":"其實我好懷疑罷工既功效<br />\n先唔討論好多要養家同手停口停 唔會罷工<br />\n我想討論既係<br />\n究竟邊啲行業罷工先有用<br />\n<br />\n例如我係個零食公司文員仔<br />\n我罷工 對你有影響嗎？對社會有影響嗎？社府會回應嗎？<br />\n罷完一日工之後 我聽日咪又係要做番晒琴日未做既野<br />\n<br />\n假如我係一個巴士司機<br />\n我罷工 對你有影響嗎？對社會有影響嗎？<br />\n前兩題肯定有人會答有<br />\n至於政府就肯定唔太在乎。<br />\n<br />\n好明顯罷工職業有分貴賤。<br />\n<br />\n成個社會覺得最最最唔罷得既工<br />\n就係醫生護士消防<br />\n對你有影響嗎？對社會有影響嗎？<br />\n一定有<br />\n政府要回應嗎要解決嗎？肯定要<br />\n但政府知道呢班員工個個心地好 唔會過道德底線去罷工<br />\n所以一直道德綁架緊佢地<br />\n減醫療開支 消防人工低<br />\n知你唔反抗 綁架你又如何？"},{"pid":"93cf219129ee795deacdb268dfba308361258aa0","tid":1530420,"uid":150930,"like":0,"dislike":0,"score":0,"quote":{"pid":"4d80572720eec7317f191fb2b8f93a4fef1fda8b","tid":1530420,"uid":36761,"like":2,"dislike":0,"score":2,"quote":{"pid":"575829fd6710b296d8731f74710018d1a185b1e6","tid":1530420,"uid":172349,"like":9,"dislike":2,"score":7,"citedBy":2,"replyTime":"2019-09-02T03:10:08.000Z","msg":"罷工同罷課係兩件事，唔好成日綑綁一齊講<br />\n<br />\n大學罷課比全港罷工容易搞得多<br />\n<br />\n大學罷課都未搞得到，唔好輕言講全港罷工"},"citedBy":1,"replyTime":"2019-09-02T03:16:04.000Z","msg":"agger"},"citedBy":1,"replyTime":"2019-09-02T03:21:50.000Z","msg":"同意<br />\n大學生罷足一個sem都無問題<br />\n反而中學生罷學係有難度<br />\n有時比罷工重難"},{"pid":"6e87b95cd04b7e4a7ca014db1a6f6edd842c5c35","tid":1530420,"uid":172349,"like":0,"dislike":0,"score":0,"quote":{"pid":"93cf219129ee795deacdb268dfba308361258aa0","tid":1530420,"uid":150930,"like":0,"dislike":0,"score":0,"quote":{"pid":"4d80572720eec7317f191fb2b8f93a4fef1fda8b","tid":1530420,"uid":36761,"like":2,"dislike":0,"score":2,"quote":{"pid":"575829fd6710b296d8731f74710018d1a185b1e