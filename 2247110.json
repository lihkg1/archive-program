g src=\"https://cf.shopee.tw/file/b0670046267f79a295d439c7da0a2671\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcf.shopee.tw%2Ffile%2Fb0670046267f79a295d439c7da0a2671&h=e6bad2cc&s={SIZE}\" />"},{"pid":"304f908620690bf84179a303efe3e27a2d3ee42a","tid":2247110,"uid":306547,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-17T14:56:22.000Z","msg":"反對啦,哪次不反對"},{"pid":"581e24f97f367f3a7f982716e998faa6121604eb","tid":2247110,"uid":95445,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-17T15:01:44.000Z","msg":"好嬲呀<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"1f8e8c12bb311772d58eb4f26f92cbb43c477e10","tid":2247110,"uid":255637,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-10-17T15:03:59.000Z","msg":"用大和田 萬能key已經足夠"},{"pid":"9d830e2595ff83b260ca94d12a529917c4c6dbf3","tid":2247110,"uid":92448,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-10-17T15:26:26.000Z","msg":"<img src=\"https://na.cx/i/pkP4sp6.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpkP4sp6.gif&h=358e260e&s={SIZE}\" />"},{"pid":"bb7e7217afa1b97ee348c69f6d4fc869310f6145","tid":2247110,"uid":211466,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-17T15:27:56.000Z","msg":"<span class=\"red\"><span class=\"xx-large\">又要屌人地國家又唔block 啲國民唔俾移民過去<br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /></span></span>"},{"pid":"4173b6bbe99ae8f55148a414aec6dd4eef758627","tid":2247110,"uid":24080,"like":0,"dislike":0,"score":0,"quote":{"pid":"097cdc42865008782543a6f30ebead3bf2be442d","tid":2247110,"uid":231583,"like":25,"dislike":0,"score":25,"citedBy":2,"replyTime":"2020-10-17T14:44:49.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2020-10-17T15:28:34.000Z","msg":"上圖係未身2季   未見過