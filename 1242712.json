":"cb74a298fbf972c17b46d9b3b7ee2ee6441e8af8","tid":1242712,"uid":154554,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T07:23:46.000Z","msg":"推"},{"pid":"0af251f0d14b60558109cb3db2974ddedf8338e1","tid":1242712,"uid":220985,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T07:43:00.000Z","msg":"推"},{"pid":"340783c425913c1636d600f9a3922ac2e30503b5","tid":1242712,"uid":182802,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T07:57:26.000Z","msg":"請大家停止打飛機！"},{"pid":"377f1a946a4e46d49111a784abafba950c501ec2","tid":1242712,"uid":235796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T08:04:47.000Z","msg":"唔好再分心啦連登仔"},{"pid":"1473d77b3e71873508844dca1c47ec23cd0bb28b","tid":1242712,"uid":235796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T08:05:37.000Z","msg":"大敵當前，唔好再分心喺啲膠po，投票po"},{"pid":"25b25513376a72308529313410381eb71f216748","tid":1242712,"uid":156936,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-19T08:05:39.000Z","msg":"各位好 阻阻大家<br />\n夢見好多人想開放日遊覽禮賓府。<br />\n但聽聞條斜路好危險，驚人多出現意外。<br />\n為安全著想，出席任何活動前，<span style=\"color: red;\">大家都有義務了解該地環境</span>，<br />\n希望各位唔好一知半解的情況下跟隨人流，造成危險。<br />\n===============<br />\n建議巴士路線及巴士站<br />\n===============<br />\n【新巴】13 旭龢道 - 中環（大會堂）23B 寶馬山 - 羅便臣道<br />\n【城巴】40M 華富（北） - 金鐘（政府總部）<br />\n【九巴】103 竹園邨 - 蒲飛路<br />\n<img src=\"https://na.cx/i/pZoOuRy.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpZoOuRy.jpg&h=6ca9e50d&s={SIZE}\" /> <img src=\"https://na.cx/i/5v6z9Rz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F5v6z9Rz.jpg&h=7291e991&s={SIZE}\" /> <br />\n===============<br />\n建議地鐵步行路線<br />\n===============<br />\n<img src=\"https://na.cx/i/JUqEBwz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJUqEBwz.jpg&h=f978913f&s={SIZE}\" /> <br />\n===============================<br />\n禮賓府高空、地則及2018香港地圖懶人包<br />\n===============================<br />\n<img src=\"https://na.cx/i/QEDVUie.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQEDVUie.jpg&h=db80f34f&s={SIZE}\" /> <br />\n<img src=\"https://na.cx/i/YFueqpV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FYFueqpV.jpg&h=2680d5df&s={SIZE}\" /> <img src=\"https://na.cx/i/bc0tuRA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fbc0tuRA.jpg&h=7815bbe6&s={SIZE}\" /> <br />\n<img src=\"https://na.cx/i/zeyZBwz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzeyZBwz.jpg&h=6ed57e57&s={SIZE}\" /> <br />\n===============<br />\n禮賓府地下通道新聞<br />\n===============<br />\n<img src=\"https://na.cx/i/ceZBDKW.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FceZBDKW.jpg&h=7ac3a5fb&s={SIZE}\" /> <br />\n<br />\n樓主現時收集以下的資料及圖片，作學術研究之用 :<br />\n1. 禮賓府正確的出入口和閘門總數<br />\n2. 禮賓府旁舊樓梯及非行車小徑等Google Map無法標示之通道<br />\n3. 急救站、飲水機、洗手間或可設立急救站空地等休息位置<br />\n4. 野生犬隻出沒或聚居地點 (可以Google map mark比我最好)<br />\n5. 由蘭桂坊或香港動植物公園前往的最佳路線<br />\n<br />\n歡迎加入討論: <strong>圖解香港禮賓府旅遊路線</strong><br />\n<a href=\"https://lihkg.com/thread/1241712/page/1\" target=\"_blank\">https://lihkg.com/thread/1241712/page/1</a><br />\n更多細節請用追故模式<br />\n<br />\n最後，禮賓府係法定古蹟，落成年份為1851年，相當有歷史價值，係一家大細親子好去處，大家記得要遵守秩序，<span style=\"color: red;\">去之前記得做足功課</span><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />等每年既開放日一到就一齊去啦<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />平時無開放千奇唔好去呀"},{"pid":"0e4b31348cd799eaa6ee53823bc9f14b33e13de2","tid":1242712,"uid":235796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T08:06:20.000Z","msg":"1. 購買裝備<br />\n前線裝備差距太大 最少要整紙皮盾同大聲公 遮嘅防禦力太低 大聲公可以有效叫支援 上次天橋啲人係戇居 但有大公聲可以立即叫佢哋後包圍<br />\n<br />\n2. 加強文宣<br />\n呢兩日太靜 大家都以為其他人收貨 要召集番69前嘅宣傳力 宣傳620死線 Airdrop大軍也好 派傳單都好 多一個人就一個人 仲有keep住呢兩日都出嚟有啲活動 唔好俾個集體感覺冇嘢好做"},{"pid":"12