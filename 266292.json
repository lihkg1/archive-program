faces/lomoji/31.png\" class=\"hkgmoji\" />"},{"pid":"54219669439d8ce16a95ee1944903bb101a17212","tid":266292,"uid":14494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-01T13:02:54.000Z","msg":"又係疑犯死左 close file<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"c981a9987c9f547e8883c317747e24059448a2b4","tid":266292,"uid":46328,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-06-01T13:11:25.000Z","msg":"黑警：<br />\n<br />\n<img src=\"http://img.ziines.com/600x338/ziines-user-upload/upload/2016/07/09/15274_20160709160152_5780af70af6d5.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.ziines.com%2F600x338%2Fziines-user-upload%2Fupload%2F2016%2F07%2F09%2F15274_20160709160152_5780af70af6d5.gif&h=22349c93&s={SIZE}\" />"},{"pid":"fd64b94216b81a1d8f309cf1f4919424bf238776","tid":266292,"uid":113000,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-01T13:12:21.000Z","msg":"遺書話係人誤會佢所以自殺<br />\n<br />\n被屈？<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"d1544203a2591d9020cc2b98705a910fecbc2734","tid":266292,"uid":51978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-01T13:14:15.000Z","msg":"警暫未有證據顯示死者與偷拍案有關<br />\n<br />\n沙田警區助理指揮官（刑事）常俊傑署理警司表示，案件列為自殺案，現由沙田警區重案組第一隊跟進。探員在死者房間內檢獲兩封遺書，並向在家的袁母了解事件。常俊傑指，警方目前暫未有證據顯示袁與一宗不誠實使用電腦案有關。常俊傑又指，死者兩封遺書於5月26日撰寫，內容指自己因捲入事件感到不開心，感到被人誤會，消息又指，內容有提及死者跟同事相處得不開心。<br />\n<br />\n<a href=\"https://www.hk01.com/article/95105\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2Farticle%2F95105&d=X1LzviS17SySsPZJwcPYb9r9upuAghWR75VkZoMWgf8%3D&h=bbd40efa\" target=\"_blank\">https://www.hk01.com/article/95105</a>"},{"pid":"d36d267d251c151415f82dfaad8c3caaee92445b","tid":266292,"uid":55533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-01T13:15:12.000Z","msg":"<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"f496f3b6ae1ce7db52be4fd57b54664111f58d83","tid":266292,"uid":113000,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-01T13:15:33.000Z","msg":"<a href=\"http://hk.on.cc/hk/bkn/cnt/news/20170601/bkn-20170601174420402-0601_00822_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20170601%2Fbkn-20170601174420402-0601_00822_001.html&d=X1LzviS17SySsPZJwcPYb9r9upuAghWR75VkZoMWgf8%3D&h=144a365e\" data-auto-link target=\"_blank\">http://hk.on.cc/hk/bkn/cnt/news/20170601/bkn-20170601174420402-0601_00822_001.html</a><br />\n<br />\n警登門查拍裙底春　碩士社工墮樓亡<br />\n<br />\n沙田大圍翠田街愉景花園發生墮樓事件。下午4時許，有保安人員乍聞巨響，循聲查看後，赫見一名男子倒臥在屋苑範圍路面，部分肢體斷開，奄奄一息。救護員將他送院，惟搶救後傷重不治，事後多名男女親友趕到醫院了解。<br />\n<br />\n據悉，黃大仙警區刑事調查隊早前接獲一宗偷拍裙底案，涉及一名男子偷拍女同事裙底春光，更有證人指證該名男子。探員經調查後，下午到懷疑涉案男子的住所了解，當探員到達現場向單位敲門，一名男子身穿赤膊應門，得知探員登門感到意外，並表示要着衫及拿鎖匙開門，未幾即有人從單位內墮樓。<br />\n<br />\n消息指出，死者姓袁(30歲)，與父母居於愉景花園已有20多年，為家中獨子。他於香港中文大學社工系碩士畢業後，在黃大仙一間機構任職社工，有親密女友。<br />\n<br />\n警方在場調查，檢獲2封遺書，一封給父母，一封給女友，內容大致透露與同事工作不開心，懷疑被人屈，又指感到世界好灰。<br />\n<br />\n沙田警區署理警司常俊傑表示，下午4時40分，黃大警區刑事調查隊到上址調查一宗在5月25日、於黃大仙區一間社區中心發生的不誠實使用電腦案件，4名探員到達單位表明來意後，一名赤膊、穿短褲的30歲中國籍男子着探員稍等，以便他取鎖匙打開鐵閘。探員等候約5分鐘，男子從高處跌落地下，送院死亡，案件列自殺，交由沙田警區重案組跟進。<br />\n<br />\n常俊傑又指出，在死者睡房檢獲2封、於5月26日寫下的遺書，透露因不誠實使用電腦事件而不開心，覺得其他人誤會了他，所以有輕生念頭。案發翌日，男子已無上班，他亦無案底，無長期病患記錄，警方暫時未檢獲案件相關證物。"},{"pid":"05c66acdad867bbc6ba2db770e965a1a97c9a3f5","tid":266292,"uid":53947,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-01T13:15:55.000Z","msg":"唉<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"9183bba0f9c30aeb3918962178e6d426a625a5e4","tid":266292,"uid":4083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-01T13:16:50.000Z","msg":"<blockquote>警暫未有證據顯示死者與偷拍案有關<br />\n<br />\n沙田警區助理指揮官（刑事）常俊傑署理警司表示，案件列為自殺案，現由沙田警區重案組第一隊跟進。探員在死者房間內檢獲兩封遺書，並向在家的袁母了解事件。常俊傑指，警方目前暫未有證據顯示袁與一宗不誠實使用電腦案有關。常俊傑又指，死者兩封遺書於5月26日撰寫，內容指自己因捲入事件感到不開心，感到被人誤會，消息又指，內容有提及死者跟同事相處得不開心。<br />\n<br />\n<a href=\"https://www.hk01.com/article/95105\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com