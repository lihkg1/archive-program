{"tid":1452311,"cid":1,"subCid":0,"title":"【那年今日丨時光匆匆，讀讀朱自清】","createTime":"2019-08-12T00:45:14.000Z","updateTime":"2019-08-12T00:47:04.000Z","uid":299202,"like":1,"dislike":0,"uniUserReply":1,"replies":[{"pid":"ee03b70c2ab8756f5972e19558ff44682fd7117a","tid":1452311,"uid":299202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T00:45:14.000Z","msg":"【那年今日丨時光匆匆，讀讀朱自清】①洗手時，日子從水盆里過去；吃飯時，日子從飯碗里過去；默默時，便從凝然的雙眼前過去；②踮著腳，伸著頸，只知道「等待」的人，他們事事都等待明天去做，今天卻專作為等待之用；自然，到了明天，又須等待明天的明天了。1948年的今天，朱自清逝世。閱讀，惜時！ ​​​<img src=\"https://na.cx/i/OFyZm4E.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOFyZm4E.jpg&h=4ab055fb&s={SIZE}\" />"},{"pid":"33dc8e16d2ed01a87120839b15fe9a901ec1a400","tid":1452311,"uid":299202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T00:45:23.000Z","msg":"1"},{"pid":"461427341897811870fa064d7d8bc9652bb1f697","tid":1452311,"uid":299202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T00:45:38.000Z","msg":"2"},{"pid":"54531d58f9f443d85cdad3976548272e10612368","tid":1452311,"uid":299202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T00:45:50.000Z","msg":"3"},{"pid":"029467cf3dd45fd64306b7aac3bf862a4eeaf16d","tid":1452311,"uid":299202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T00:46:00.000Z","msg":"4"},{"pid":"0b95b80e9dd13a9136305187be0a5ecfbb516b52","tid":1452311,"uid":299202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T00:46:10.000Z","msg":"5"},{"pid":"4cc302bdacd71d4966c598ac84aa827be6bdc8cf","tid":1452311,"uid":299202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T00:46:20.000Z","msg":"6"},{"pid":"c3f0c90fb6bbaeaa30df8628f4b581cf7611074b","tid":1452311,"uid":299202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T00:46:30.000Z","msg":"7"},{"pid":"c05476bf79e0bc6fbe939e71c38e5d477f29fa16","tid":1452311,"uid":299202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-0