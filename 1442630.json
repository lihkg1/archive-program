77bf38cb3dd2025","tid":1442630,"uid":280349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:19:02.000Z","msg":"【文宣戰線】香港首家長輩Youtube頻道上線啦！〔2〕<br />\n<a href=\"https://lih.kg/1440488\" data-auto-link target=\"_blank\">https://lih.kg/1440488</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"e28520d8cf431ebadd35106592f6ee077f248225","tid":1442630,"uid":158766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:20:53.000Z","msg":"721"},{"pid":"d180e2c8e353518c5eb305e78e2236c68e066f34","tid":1442630,"uid":23587,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:21:05.000Z","msg":"721 721 721"},{"pid":"19a67b0691c1bf805090c32ce9bc1daa4e4407e3","tid":1442630,"uid":6942,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:21:29.000Z","msg":"721"},{"pid":"a81b9a4736a5af7dae7a2c92683680a304b58d98","tid":1442630,"uid":79602,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:29:05.000Z","msg":"推"},{"pid":"6a3a9feaef4af316718d4c8b80335599465c8f11","tid":1442630,"uid":245371,"like":0,"dislike":0,"score":0,"quote":{"pid":"56f98961ffe1a4321e7dbd7bfe5b5fb04d9d11ca","tid":1442630,"uid":158613,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-11T04:16:45.000Z","msg":"721 官警黑元朗恐襲<br />\n<br />\n726 張建宗向市民道歉 及 警察屌張建宗<br />\n<br />\n811 張建宗對警隊的專業表現和克制，予以充分肯定和全力支持。<br />\n他指，<span style=\"color: red;\">反送中 已停止，近日的暴力行為，明顯偏離最初原則。 (但對 721 官警黑元朗恐襲 隻字不提)</span><br />\n<br />\n<br />\n大家完全忘記了<span style=\"color: red;\">721 官警黑元朗恐襲 係激起最大民憤嘅原因，大量中立撚都醒哂，呢個核彈政府係無得拆的</span>，所以今個星期開始拉返大家去Focus 反送中 。<br />\n<br />\n我明白5大訴求 缺一不可，但呢家要先用 「721 官警黑元朗恐襲」 打破缺口。"},"citedBy":0,"replyTime":"2019-08-11T05:31:50.000Z","msg":"小心誤變成連登蠕蟲及幫兇<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/dAEcdS\" data-auto-link target=\"_blank\">https://lih.kg/dAEcdS</a><br />\n<br />\n幫推  光復連登"}]}