域上的開放[9]。"},{"pid":"0c09b75d51d90b02212c1267a73b2d21f3145020","tid":1944044,"uid":95138,"like":0,"dislike":0,"score":0,"quote":{"pid":"ee03abbeb9d4c415e039bbd5c960f40c33a765b2","tid":1944044,"uid":247892,"like":0,"dislike":0,"score":0,"quote":{"pid":"3acc1516b54e0d8a566493f38bf03de8da47151d","tid":1944044,"uid":95138,"like":0,"dislike":0,"score":0,"quote":{"pid":"b3c3243d40c8962a38d165371cdc2d1a654cf37a","tid":1944044,"uid":322195,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-03-26T09:02:49.000Z","msg":"點解外交部冇反應嘅<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-26T09:09:37.000Z","msg":"好唔正常 平時應該強烈譴責左"},"citedBy":1,"replyTime":"2020-03-26T09:14:32.000Z","msg":"仲圍爐商量緊點應對"},"citedBy":0,"replyTime":"2020-03-26T09:23:37.000Z","msg":"可能身有屎 有異動 美軍先咁多行動<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5a40750b6b0566ccb57301e1382707e982180fc1","tid":1944044,"uid":95138,"like":0,"dislike":0,"score":0,"quote":{"pid":"ac4ad81f02faca586b75733d4fa3dccdd6bb14e2","tid":1944044,"uid":271894,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-26T09:00:28.000Z","msg":"遼寧號呢 中國海軍呢<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-26T09:27:15.000Z","msg":"冇晒聲氣<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"45e816441725ee8be23ee5dbb234a78f4b12926b","tid":1944044,"uid":95138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-26T09:42:47.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2687926bf61986056dd5079a230f1a0e1c1031db","tid":1944044,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"79a5d82eedefe9820b087d8b400dffa1a804dbb2","tid":1944044,"uid":138964,"like":2,"dislike":0,"scor