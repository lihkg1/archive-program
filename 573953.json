rmal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"d90f3bfac3497e6b439ab6a91ada590bf444a438","tid":573953,"uid":128261,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-02-27T04:49:37.000Z","msg":"仲佔中，當年啲雨傘人士都DQ曬啦，習總都稱帝啦，仲佔中<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dc8bc11f37ac857a05f90b21d5a24260ad3f5106","tid":573953,"uid":39527,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-27T04:52:05.000Z","msg":"咁佢真係姓屈架麻  唔咁講點對得住佢個姓<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"10b558d81295b316de3949e0be35c308521acfad","tid":573953,"uid":86408,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-02-27T04:52:08.000Z","msg":"呃稿費呃到好似中學生搵份體育版做剪報一撚樣<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d23ec7d8fcce354b4f7a071d33f17b0e0a001ae1","tid":573953,"uid":85819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-27T04:52:20.000Z","msg":"此回覆已被刪除"},{"pid":"b83266b16dffdf950968805c09d9af2cafd2a136","tid":573953,"uid":80294,"like":0,"dislike":0,"score":0,"quote":{"pid":"4ccb5addf602f4018257de821bf23e74ce0f4908","tid":573953,"uid":39464,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-27T03:05:11.000Z","msg":"人生馬拉松&mdash;&mdash;造神工程<br />\n<br />\n　反對派的造神工程一向很成功，回歸二十年，幾乎每半年就出一個「神」。<br />\n<br />\n　　搞一次反國教，捧出一大班孩子王；掀一回雨傘暴動，孩子王步上神壇成國際巨星；擲完磚的，有本事在選舉拿六萬票；走私禁書的，都可以捧為「對抗強權的香港之光」。<br />\n<br />\n　　他們的造神手法百發百中，除了一、兩回選錯蠢卒，敗事的「釘書機」林子健，算是一個爛泥扶唔上壁的例外。<br />\n<br />\n　　最近一次造神契機，有點慘不忍睹，因為要踩着九巴大車禍十九條屍體上位，是一趟兵行險着。不過反對派絕非省油的燈，透過WhatsApp群組，只用了五日時間，九巴女車長葉蔚琳就成立了個「月薪車長大聯盟」，並成功搶佔傳媒鎂光燈，騎劫了八千全職司機的話語權，不但搞了個五車罷駛「大」行動，更在昨日發起佔領九巴車廠，還提出最後通牒，公司若在凌晨二時不回應訴求，就將行動升級。<br />\n<br />\n　　圍堵、佔領、限時回覆&hellip;&hellip;葉蔚琳記者會最後一句話很面熟：「毋忘初心！」熟悉的對白、熟悉的劇本，當然還要配個浪漫名字：逆權車長，一場熟悉的造神運動，就這樣展開了。<br />\n<br />\n　　我不糾纏於這場勞資糾紛的是與非，我只以常理、以平常心提出疑問。<br />\n<br />\n　　九巴公司有全職及兼職車長近九千人，目前有五個活躍工會，分別是隸屬工聯會的「汽車交通運輸業總工會九巴分會」、港九工團聯合總會屬會的「九巴職工總會」、「九巴僱員工會」、「九巴職員權益工會」及職工盟屬會「九巴員工協會」。因為前面兩大工會的會員人數已佔九成員工，故資方一直只與頭兩個工會談判，檢討薪酬待遇問題。<br />\n<br />\n　　作為資方，面對五個工會各種不同訴求，如何取捨？已經有五個山頭了，今天葉車長再插一支旗叫「月薪車長大聯盟」，明天可能又會有人搞個「七十後車長關注組」，後日又或者出現個「男車長大聯盟」，一人提三個訴求，三八就二十四個訴求，順得哥情失嫂意，資方該如何是好？<br />\n<br />\n　　看那天率領罷駛行動的葉蔚琳背後站了長毛、劉小麗、譚文豪、譚得志&hellip;&hellip;再看看這位演藝學院畢業生棄花旦不做跑來當車長的年份，是四年前，佔中那年，一切巧合，你懂的。行動的成敗已不重要，重點是，反對派再次成功塑造了一個神。<br />\n<br />\n<a href=\"http://hd.stheadline.com/news/columns/398/20180227/649125/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhd.stheadline.com%2Fnews%2Fcolumns%2F398%2F20180227%2F649125%2F&d=u9aNrW9w0vJ2xZCPsOckSSwN645TRhVPBLeqKBQ2Igw%3D&h=c2663344\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fhd.stheadline.com%2Fnews%2Fcolumns%2F398%2F20180227%2F649125%2F&h=a29d6c98\" data-auto-link target=\"_blank\">http://hd.stheadline.com/news/columns/398/20180227/649125/</a>"},"citedBy":0,"replyTime":"2018-02-27T04:57:40.000Z","msg":"# 真係笑話"},{"pid":"319b7393a8ee2ef37b394a1f3cd35aa2baba1e96","tid":573953,"uid":53278,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-27T04:58:24.000Z","msg":"個八婆都係靠佔中彈起<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"83fd140206a227d54e1692f608b7b4d41dbc34a7","tid":573953,"uid":4880,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-02-27T04:59:07.000Z","msg":"Chris Kwong &middot; Hong Kong<br />\n香港原本冇乜大病，小小問題梗會有，依家全身插滿喉管，條條都話救香港，我睇香港可以捱幾耐？<br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1b753e6479ecd656952b4c71f5e2cb4d28290e23","tid":573953,"uid":14625,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-27T05:00:22.000Z","msg":"究竟林超榮點解會娶得落條痴線西<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"996f5198accd5457d89966f3092671038f630b72","tid":573953,"uid":67302,"like":0,"dislike":1,"score":-1,"quote":{"pid":"c3d4a1ba5cb84c0b67ca72334b577e93a68dc656","tid":573953,"uid":2419,"like":349,"dislike":1,"score":348,"citedBy":2,"replyTime":"2018-02-27T03:08:30.000Z","msg":"佢人生係咪得佔中<img src=\"/assets/faces/normal/clo