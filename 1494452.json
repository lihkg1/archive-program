{"tid":1494452,"cid":5,"subCid":10,"title":"男子深水埗梯間門框自縊亡","createTime":"2019-08-21T15:53:03.000Z","updateTime":"2019-08-21T16:05:13.000Z","uid":56533,"like":0,"dislike":0,"uniUserReply":5,"replies":[{"pid":"368d62a0b73658b10d8a45ede8cb2d48871eeb3b","tid":1494452,"uid":56533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T15:53:03.000Z","msg":"<img src=\"https://fs.mingpao.com/ins/20190821/s00001/f1f6ef6afbf39f9c9ac01ec48b8af2af.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffs.mingpao.com%2Fins%2F20190821%2Fs00001%2Ff1f6ef6afbf39f9c9ac01ec48b8af2af.jpg&h=b98a83e5&s={SIZE}\" /><br />\n<br />\n早上6時許，一名44歲男子在深水埗大南街206號後樓梯間門框上吊，一名拾荒者發現事件報警，救護員到場證實男子死亡，警方在場檢獲遺書，初步相信事件無可疑。據了解，事主並非居於上址。<br />\n<br />\n<a href=\"https://news.mingpao.com/ins/%E6%B8%AF%E8%81%9E/article/20190821/s00001/1566351435900/%E7%94%B7%E5%AD%90%E6%B7%B1%E6%B0%B4%E5%9F%97%E6%A2%AF%E9%96%93%E9%96%80%E6%A1%86%E8%87%AA%E7%B8%8A%E4%BA%A1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.mingpao.com%2Fins%2F%25E6%25B8%25AF%25E8%2581%259E%2Farticle%2F20190821%2Fs00001%2F1566351435900%2F%25E7%2594%25B7%25E5%25AD%2590%25E6%25B7%25B1%25E6%25B0%25B4%25E5%259F%2597%25E6%25A2%25AF%25E9%2596%2593%25E9%2596%2580%25E6%25A1%2586%25E8%2587%25AA%25E7%25B8%258A%25E4%25BA%25A1&d=qWTZpUodHfCf2bB0mbfn00cGFqE5jXx4AE4DM0839cs%3D&h=c0ef8897\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.mingpao.com%2Fins%2F%25E6%25B8%25AF%25E8%2581%259E%2Farticle%2F20190821%2Fs00001%2F1566351435900%2F%25E7%2594%25B7%25E5%25AD%2590%25E6%25B7%25B1%25E6%25B0%25B4%25E5%259F%2597%25E6%25A2%25AF%25E9%2596%2593%25E9%2596%2580%25E6%25A1%2586%25E8%2587%25AA%25E7%25B8%258A%25E4%25BA%25A1&h=3e17c80b\" target=\"_blank\">https://news.mingpao.com/ins/%E6%B8%AF%E8%81%9E/article/20190821/s00001/1566351435900/%E7%94%B7%E5%AD%90%E6%B7%B1%E6%B0%B4%E5%9F%97%E6%A2%AF%E9%96%93%E9%96%80%E6%A1%86%E8%87%AA%E7%B8%8A%E4%BA%A1</a>"},{"pid":"dc41a1722b5c449340d0edd1b6b4681395d6e452","tid":1494452,"uid":1