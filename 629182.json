i2-kknews-cc.cdn.ampproject.org%2Fii%2Fw1200%2Fs%2Fi2.kknews.cc%2FSIG%3De12468%2Frss000358s79p51o05n.jpg&h=d015ce9d&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-04-14T14:59:27.000Z","msg":"人地核潛艇潛去你門口打柒你<br />\n你就導彈列車由湖南車去湖北<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-04-14T15:32:50.000Z","msg":"就當中國核武趕上美國同俄羅斯，中國打核戰都係明顯劣勢而且係先天性，美國導彈潛艇出入太平洋大西洋都暢通無阻，俄羅斯潛艇可以係北冰洋破冰發射導彈，<br />\n<br />\n中國唔只海岸線比人短，中國潛艇出入太平洋只有幾條水道，容易被美國日本暗中追踪，所以逼於無奈搞俄羅斯都唔再用既鐵路發射。美國潛艇係海洋發射可分散敵方攻擊力，中國用鐵路發射令本土承受更多核彈攻擊。"},{"pid":"a04ef8f7c54a74a6e09e98545d0f86434199c1ac","tid":629182,"uid":5489,"like":1,"dislike":0,"score":1,"quote":{"pid":"ff4d5773580ae0cf6c57f402b94a139dde717442","tid":629182,"uid":173002,"like":4,"dislike":0,"score":4,"quote":{"pid":"e6932ba7d91848f169c28abde645f466683fc8ae","tid":629182,"uid":5489,"like":21,"dislike":0,"score":21,"quote":{"pid":"bab3246a86c54382b1fdb6bfb89d491943f8bd8d","tid":629182,"uid":14918,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-14T13:12:47.000Z","msg":"<img src=\"http://hk.on.cc/cn/bkn/cnt/news/20161008/photo/bkncn-20161008112426402-1008_05011_001_01p.jpg?20161008140351\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fhk.on.cc%2Fcn%2Fbkn%2Fcnt%2Fnews%2F20161008%2Fphoto%2Fbkncn-20161008112426402-1008_05011_001_01p.jpg%3F20161008140351&h=ea5b5be9&s={SIZE}\" /><br />\n<br />\n亞太局勢持續緊張之際，中國頻頻亮劍，展示最新戰略軍備，一輛疑似被視為解放軍秘密武器之一、有中國版末日列之稱的東風41戰略導彈列車，近日在網上曝光，由於其隱蔽性高，加上導彈射程估計逾1.4萬公里，打擊範圍足以覆蓋美國全境，外界認為導彈列車的曝光，警告美國意味濃厚。 <br />\n<br />\n從該張疑似東風41戰略導彈列車的照片可見，有數列全白色車身的列車，車體明顯較一般列車圓，其中一節車卡的長度更是其他車卡的一至兩倍。美國媒體曾報道，去年12月中國在西部地區，進行過一次在列車上發射洲際彈道導彈的試射，認為解放軍正推動建設和部署難以定位的軌道發射東風41導彈系統，標誌着中國戰略武器開發達到一個新的里程碑階段。 <br />\n<br />\n有分析認為，東風41導彈最多可攜帶10個彈頭，射程可達1.4萬公里，是中國最強大的洲際彈道導彈，加上它全向攻擊的能力，打擊範圍基本覆蓋全球，不存在死角，足以威脅美國全境。 <br />\n<br />\n內地軍事專家指出，<span style=\"color: green;\">導彈列車是為提高中國戰略武器在遭對方打擊一次後的生存能力</span>，以保證中方的核反擊能力。而導彈列車的速度快，承載大重量的戰略核導彈時，平均時速也能達到100公里，衞星相對難對其進行定位，加上中國鐵路網四通八達，進一步增加對方追蹤的難度，生存能力大幅提升。 <br />\n<br />\n