oyLN1PNQjS0%3D&h=e9aa511a\" target=\"_blank\">https://www.openrice.com/zh/hongkong/restaurants?chainId=10005145&amp;chainName=%E7%87%89</a>"},{"pid":"2c7b45a86ae7ce6ebe157058250f28e17afe17e0","tid":1836462,"uid":192851,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-23T11:32:32.000Z","msg":"推下比支那人睇"},{"pid":"71d483678f326b995e6625f3500b6be8f3a98ea0","tid":1836462,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-23T11:32:59.000Z","msg":"嘩"},{"pid":"548356ef0d2c981275bdfabfae8665037bf05e18","tid":1836462,"uid":88743,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-23T11:34:09.000Z","msg":"<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">是</span></span></strong>"},{"pid":"0868c8e31b8194765ffda0f152e92507f786c942","tid":1836462,"uid":43600,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-23T11:35:29.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5515cb63f94b54f9880326a4780d276dad82ef15","tid":1836462,"uid":192851,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-23T11:41:30.000Z","msg":"push"},{"pid":"f5ce1dbdade41b041470d177aea61822e361125b","tid":1836462,"uid":76398,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-23T11:44:12.000Z","msg":"推"}]}