"推"},{"pid":"cf363a1ba00f0cf280db3628f59e24ae935c8c07","tid":1402941,"uid":272569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T02:16:26.000Z","msg":"hit and run ah"},{"pid":"409d5e83f7f168856b329e00428cbca0d487adcd","tid":1402941,"uid":42943,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T02:37:57.000Z","msg":"Hit and run"},{"pid":"2b30ed2b369944b04cc88604e02bead84aad24b3","tid":1402941,"uid":42943,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T02:39:14.000Z","msg":"Hit and run"},{"pid":"86091f3bbac461b32ed228371d2f5d52ff2f7a4e","tid":1402941,"uid":42943,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T02:42:59.000Z","msg":"Hit and run"},{"pid":"3caf36e0e3ca6adfb89759dc85319d59cfab8970","tid":1402941,"uid":42943,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T02:45:16.000Z","msg":"Hit and run 加街坊勇武，一定有得做"},{"pid":"9aaa16cf8d574fbe2ab17c3568e3816772244f76","tid":1402941,"uid":268935,"like":0,"dislike":0,"score":0,"quote":{"pid":"937108f08ed3249b641332fb449ff7b5436dfd0d","tid":1402941,"uid":42943,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-03T17:19:09.000Z","msg":"我唔想再見到有手足比人拉。<br />\n<br />\n見唔見到早兩晚馬鞍山 hit and run 幾咁成功啊？<br />\n<br />\n留守對峙係作用唔大，仲會有手足比人拉。<br />\n<br />\n今日搞完尖沙咀狗屋，收到風有狗黎就應該走，唔一定散水，可以係轉場轉目標啊。<br />\n<br />\n你地見唔見到幾多出黎做支援嘅女仔比人拉啊，你班撚樣！<br />\n<br />\n今日見到有幾架車狗著黑衫扮同路人，我就更加肯定前線係有鬼！<br />\n<br />\n我今日都有走到前線，但我唔敢屌大家。我聽日一定再上去同前線講，屌到你地開花！<br />\n<br />\n<br />\n-唔需要set時間幾時走，睇情況，睇scout報料<br />\n-有50狗以上即轉場<br />\n-拉想守嘅手足走<br />\n-有必要時會打鳩堅持留嘅人<br />\n<br />\n咪撚再守啊<br />\n<br />\n<span style=\"font-size: x-large;\">Hit and Run </span><br />\n<br />\n正皮- hit and run<br />\n<br />\n負皮- 守佢老母，用「光復香港，時代革命」呢句口號，音波攻擊震撚死啲狗"},"citedBy":1,"replyTime":"2019-08-04T02:47:41.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f2b84b598d81248441e9659bbec2f6d8d198209f","tid":1402941,"uid":42242,"like":2,"dislike":0,"score":2,"cite