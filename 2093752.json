83f6f","tid":2093752,"uid":106408,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-04T07:21:12.000Z","msg":"比少少骨氣好冇呀<br />\n唔係想吊高黎賣呀<img src=\"/assets/faces/lm2/donno.gif\" class=\"hkgmoji\" />"},{"pid":"4f29828b37770e2e1ab5a6122123aeb9d8027954","tid":2093752,"uid":179966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-04T07:22:55.000Z","msg":"<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"18b1f2c6497c088156c7ff864988b9a64633c973","tid":2093752,"uid":199957,"like":0,"dislike":0,"score":0,"quote":{"pid":"f4a471335a57ba20ff8293146dcc5103a908dbe5","tid":2093752,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-04T05:25:06.000Z","msg":"<a href=\"https://hk.appledaily.com/international/20200704/J2XZFU5MNM53MMJL343URLQD6E/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Finternational%2F20200704%2FJ2XZFU5MNM53MMJL343URLQD6E%2F&d=C%2Fe7%2FQel5OtnIpuNpUi2IPMFbVPULjdiAdi6tpyrPMY%3D&h=cbb2509b\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Finternational%2F20200704%2FJ2XZFU5MNM53MMJL343URLQD6E%2F&h=37276caa\" data-auto-link target=\"_blank\">https://hk.appledaily.com/international/20200704/J2XZFU5MNM53MMJL343URLQD6E/</a><br />\n<br />\n世界衞生組織更新官網上有關武漢肺炎疫情的時序紀錄，顯示世衞去年底首次接到武漢爆發肺炎病毒的警告，是由世衞駐華代表處發出，而非中國政府主動向世衞通報示警。"},"citedBy":0,"replyTime":"2020-07-04T07:26:54.000Z","msg":"左右橫跳"},{"pid":"8759d558361be397b56a936eab4a8da7edb00a1a","tid":2093752,"uid":65074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-04T07:29:24.000Z","msg":"屌<br />\n零公信力<br />\n執柒左佢啦"},{"pid":"d8838ad73e120f0a28bbe44eb1f7c168cfc10450","tid":2093752,"uid":144848,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-04T07:31:59.000Z","msg":"張支票入咗<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"52315a6677ee07540dd234fea01b29896bebd5c7","tid":2093752,"uid":133319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-04T07:32:41.000Z","msg":"割了"},{"pid":"8153634f818026af14854653503b72937354c04a","tid":2093752,"uid":31150,"like":0,"dislike":0,"score":0,"quote":{"pid":"bcb9e4f7a2ad394718177b946aac5261f40351e9","tid":2093752,"uid":21470,"like":0,"dislike":0,"score":0,"quote":{"pid":"fe786b3bf34c02e469e5dccc578c61b0911c9f09","tid":2093752,"uid":21470,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2020-07-04T05:32:33.000Z","msg":"世衛組織駐華代表<br />\n高力醫生是世衛組織駐華代表。他曾任世衛組織歐洲區辦事處非傳染性疾病和促進生命全程健康司司長。<br />\n<br />\n高醫生是公共衛生醫生，1998年加入世衛組織工作，曾在蘇瓦、馬尼拉的西太平洋區域辦事處和日內瓦的世衛組織總部任職。<br />\n<br />\n高醫生在非傳染病領域積極發聲，無論是在國家層面還是在全球層面均十分活躍。他參與製定了國家非傳染病防治分步驟方法，首先於太平洋島國實施，並在循證的基礎上倡導將非傳染病工作與全球發展議程相關聯；2011年召開的聯合國非傳染病高級別會議就是一例。他協助革新了貫穿生命全程的健康促進和公共衛生的方法。在世衛組織歐洲區，上述努力推動了兒童和青少年健康、兒童營養不良、婦女保健行動計劃的製定，以及歐洲男性健康行動計劃的製定。<br />\n<br />\n高醫生廣泛發表文章，並對計算機編程和數據科學在當今公共衛生實踐中的應用有著強烈的個人興趣。<br />\n<br />\n<a href=\"https://www.who.int/china/zh/about-us/head-of-who-office\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.who.int%2Fchina%2Fzh%2Fabout-us%2Fhead-of-who-office&d=C%2Fe7%2FQel5OtnIpuNpUi2IPMFbVPULjdiAdi6tpyrPMY%3D&h=db16742b\" data-auto-link target=\"_blank\">https://www.who.int/china/zh/about-us/head-of-who-office</a>"},"citedBy":3,"replyTime":"2020-07-04T05:33:29.000Z","msg":"<blockquote><img src=\"https://na.cx/i/FXZ5c0H.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFXZ5c0H.jpg&h=dea41f49&s={SIZE}\" /><br />\n</blockquote>"},"citedBy":0,"replyTime":"2020-07-04T07:37:10.000Z","msg":"成個龜頭咁"},{"pid":"b240d69f235c0edf9e1ada1a4518d5e0a62e2a27","tid":2093752,"uid":267410,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-04T07:40:23.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"82d96da79957fe9eaf5132f4254fd254aaecddf3","tid":2093752,"uid":188282,"like":0,"dislike":0,"score":0,"quote":{"pid":"bf20350ac67e281066c1755bedff65c1bffc9de2","tid":2093752,"uid":346701,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"20