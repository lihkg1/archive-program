faces/lomoji/07.png\" class=\"hkgmoji\" />"},{"pid":"557be86876cf843fea6aad516a397545cf93ec1f","tid":405944,"uid":132038,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-09-19T09:43:53.000Z","msg":"此回覆已被刪除"},{"pid":"11e3e3048dfe1743d5b15661775beee233d3aa15","tid":405944,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T11:57:09.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1e371d9e61fe0e88b2ba4391383623ff8e6fcdb1","tid":405944,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T12:10:29.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"667f41ed7d21e231b1fd020bfe0655792f73cf74","tid":405944,"uid":51937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T12:13:31.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"4e34a35dccf0ed5a34c362f3cf9020fb59fba549","tid":405944,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T12:39:04.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f0082e70d59aed1e1387010abb8bd43671489a87","tid":405944,"uid":37413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T12:42:07.000Z","msg":"知都唔理㗎啦， 佢對向大陸嘅啫， 升官發財就得"},{"pid":"76872513a90237b9f4057a9b56963d58042081f2","tid":405944,"uid":41245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T13:03:04.000Z","msg":"肥彭都舐共<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n佢舐都冇人受佢啦"},{"pid":"8ad0e33f8b108854019f9f748ca487027fb16655","tid":405944,"uid":41245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T13:04:20.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><strong><span style=\"font-size: xx-large;\">彭定康：袁國強政治決定覆核刑期　如不知向國際發出何種訊息　太天真</span></strong><br />\n<br />\n<img src=\"https://cdn.thestandnews.com/media/photos/cache/chris-09_m7vDE_1200x0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2Fchris-09_m7vDE_1200x0.png&h=8549a80f&s={SIZE}\" /><br />\n<br />\n末代港督彭定康近日訪港，今日出席香港外國記者會午宴。他再次回應「雙學三子」被判囚一案，炮轟律政司司長袁國強是基於「政治決定」提刑期覆核。他又指若袁國強不知道此舉會對國際社會發出甚麼訊息，將是太過天真。<br />\n<br />\n彭定康今日在午宴上致辭，談到香港的法治情況。他表示一般不會評論法官的決定，但對於黃之鋒等人的案件，他認為袁國強是因「政治決定」而提出刑期覆核。他認為袁國強應知道自己決定所帶來的後果，應知道這決定會向國際社會傳達甚麼訊息，否則就是太過天真。<br />\n<br />\n他提及，早前牛津大學有邀請袁國強到校發表演說，當時袁國強形容香港是法治的「國際樞紐」。彭定康稱，自己非常認同這個主張，但反問如今發生的事情，是否就是袁國強要示範的方法。<br />\n<br />\n彭定康以往已多次就「雙學三子」被判囚已發聲。上月他在愛丁堡出席活動，就形容羅冠聰、黃之鋒、周永康三人的名字將會被人們記住，「我想他們會被記住，他們的名字會被記住，久遠至到時已沒有人記得我是誰，或甚是沒有人記得（國家主席）習近平是誰。」，又指大家應該為這些孩子感到驕傲。<br />\n<br />\n他之後又在《金融時報》撰文，形容三子被囚實為香港政府的嚴重錯誤，難以說服國際社會，本港的自由、多元生活方式未有進一步惡化。他強調律政司司長袁國強決定刑期覆核上的角色顯著，「這個令人遺憾的決定，責任明顯落在香港政府的肩膀上」。文章又質疑刑期覆核的決定，實質上是要阻止三人參選立法會。<br />\n<br />\n<a href=\"https://thestandnews.com/politics/彭定康-袁國強政治決定覆核刑期-如不知向國際發出何種訊息-太天真/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%E5%BD%AD%E5%AE%9A%E5%BA%B7-%E8%A2%81%E5%9C%8B%E5%BC%B7%E6%94%BF%E6%B2%BB%E6%B1%BA%E5%AE%9A%E8%A6%86%E6%A0%B8%E5%88%91%E6%9C%9F-%E5%A6%82%E4%B8%8D%E7%9F%A5%E5%90%91%E5%9C%8B%E9%9A%9B%E7%99%BC%E5%87%BA%E4%BD%95%E7%A8%AE%E8%A8%8A%E6%81%AF-%E5%A4%AA%E5%A4%A9%E7%9C%9F%2F&d=jWODVY9xXFwp0mmthCJ0jJ7TfgnX9jywtYe9GXZmhCU%3D&h=02272272\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%E5%BD%AD%E5%AE%9A%E5%BA%B7-%E8%A2%81%E5%9C%8B%E5%BC%B7%E6%94%BF%E6%B2%BB%E6%B1%BA%E5%AE%9A%E8%A6%86%E6%A0%B8%E5%88%91%E6%9C%9F-%E5%A6%82%E4%B8%8D%E7%9F%A5%E5%90%91%E5%9C%8B%E9%9A%9B%E7%99%BC%E5%87%BA%E4%BD%95%E7%A8%AE%E8%A8%8A%E6%81%AF-%E5%A4%AA%E5%A4%A9%E7%9C%9F%2F&h=e9a7692b\" target=\"_blank\">https://thestandnews.com/politics/彭定康-袁國強政治決定覆核刑期-如不知向國際發出何種訊息-太天真/</a></blockquote><br />\n我都唔撚明，咁今時今日肥彭你英國點解唔根據中英聯合聲明義務出聲姐。</blockquote><br />\n<br />\n因為佢唔識睇中文字同無上連登<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n英國佬都唔少人奶共<br />\n唔為錢既人又有幾多個<br />\n唯有靠自己</blockquote><br />\n<a href=\"https://www.gov.uk/government/uploads/system/uploads/attachment_data/file/644798/The_Six_Monthly_Report_-_1_January__to_30_June_2017.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.gov.uk%2Fgovernment%2Fuploads%2Fsystem%2Fuploads%2Fattachment_data%2Ffile%2F644798%2FThe_Six_Monthly_Report_-_1_January__to_30_June_2017.pdf&d=jWODVY9xXFwp0mmthCJ0jJ7TfgnX9jywtYe9GXZmhCU%3D&h=12df02c8\" target=\"_blank\">https://www.gov.uk/government/uploads/system/uploads/attachment_data/file/644798/The_Six_Monthly_Report_-_1_January__to_30_June_2017.pdf</a><br />\n最新嘅香港半年報告書原文，雖然唔係話真係好強硬, 但都數咗港中殖民政府同中國政府所做嘅衰嘢出嚟.</blockquote><br />\n始終政府冇個立場係要收返香港嘅<br />\n佢地啲報告真係只可以係噉"},{"pid":"1b949d18d0e9973477c4d7d5514484df2cb82998","tid":405944,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T13:49:35.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8da55b613de796351c21ebe38eb5664d148f1f70","tid":405944,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T13:57:01.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"83af9ff5e30a13773b25fa1b7c18d9999e91e583","tid":405944,"uid":83582,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T14:08:07.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c21924c224990c6eb1a0ee44dc9ce50a5a4224ca","tid":405944,"uid":106544,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T14:25:34.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"7a5834f9cb6d0a56e78cbcdf3d73e25c5e8454f7","tid":405944,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T14:32:31.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"157d77304ac200f701d08691d56d0dfb325c2786","tid":405944,"uid":49588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T14:46:04.000Z","msg":"英國佬還可以為1997前的做些甚麼事？！"},{"pid":"374f2ece9f24296e40176ef6bc8ab19233ecd077","tid":405944,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-19T23:17:36.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"07113f19a04df683ac981f46c06cb61f79a3bf4f","tid":405944,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T03:01:58.000Z","msg":"<blockquote>肥彭都舐共<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n佢舐都冇人受佢啦</blockquote><br />\n舐共? 你有無聽佢個午餐會演講?<br />\n<a href=\"https://youtu.be/OVWmYrsS808\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FOVWmYrsS808&d=jWODVY9xXFwp0mmthCJ0jJ7TfgnX9jywtYe9GXZmhCU%3D&h=eda2dcba\" target=\"_blank\">https://youtu.be/OVWmYrsS808</a>"},{"pid":"f98e7b1d4de3e9dad85c7ae03c5a47d065d76c6e","tid":405944,"uid":39838,"like":7,"dislike":1,"score":6,"citedBy":0,"replyTime":"2017-09-20T03:13:14.000Z","msg":"我覺得肥彭對香港, 對香港人已經仁至義盡<br />\n當年搞直選比啲廢老話佢搞屎棍<br />\n起世界第一新機場比人屌佢地貪走香港啲儲備<br />\n到97要走又屌佢敗走香港<br />\n<br />\n但人地呢廿年來每次有大是大非都幫香港講好說話<br />\n香港人仲屌佢唔幫香港行使返中英聯合聲明<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n屌你而家英國or 總理叫文翠珊唔係彭定康"},{"pid":"b938d5e0167199b7b8fc03d631faedc96dff57b5","tid":405944,"uid":51904,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T03:14:26.000Z","msg":"「末代港督」彭定康來港宣傳新書，今日（19日）首站出席外國記協出席午餐會，就港獨言論爭議等近期多宗政治事件發表意見，指言論自由是有限制的，奚落死者家人及聲言要殺害他人均不正確，更不應發表任何仇恨言論（hateful speech）。他重申，港獨主張是不可能達到的，認為兩方應冷靜下來、展開對話。"},{"pid":"992f3f4fe19820918570928a091c7f448ab799b5","tid":405944,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T11:51:02.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"80d62e0132a57442841cb86174ec73ba92f2f333","tid":405944,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T11:56:58.000Z","