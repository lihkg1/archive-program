98%258E-%25E5%259A%25B4%25E5%258E%25B2%25E8%2599%2595%25E7%2590%2586&h=219d7171\" data-auto-link target=\"_blank\">https://news.mingpao.com/ins/%E6%B8%AF%E8%81%9E/article/20190906/s00001/1567766832289/%E3%80%90%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B%E3%80%91%E5%85%83%E6%9C%97%E5%A4%A9%E4%B8%BB%E6%95%99%E4%B8%AD%E5%AD%B8%E5%89%AF%E6%A0%A1%E9%95%B7%E6%B6%89%E7%88%86%E7%B2%97%E6%92%95%E6%96%87%E5%AE%A3-%E6%A0%A1%E6%96%B9%E7%99%BC%E8%81%B2%E6%98%8E-%E5%9A%B4%E5%8E%B2%E8%99%95%E7%90%86</a><br />\n<br />\n網上流傳一段約4分鐘的影片，片中一名女子撕走貼在天橋的文宣，引起罵戰，拍片者爆粗，女子以粗口回應，說「你係咪要X啊，除褲喇」。有指該女士為元朗天主教中學副校長陳秀芬。該校今日在網頁發出聲明，稱「會嚴厲處理、認真了解、不偏不倚地跟進」事件。<br />\n<br />\n元朗天主教中學在聲明確認，該校「陳副校長於下班後在公眾地方，涉嫌撕掉宣傳單張及海報，及其於回應拍攝者時引起的言語衝突」。該校稱，尊重每個人有表達意見的權利。校方另向家長發特別通告，表示已就事件啟動危機處理機制，安排社工等為有需要師生提供支援。<br />\n<br />\n教育局表示，已收到相關投訴，會按既定程序跟進事件，以及因應需要為學校提供適切支援。局方強調，社會重視教師專業操守，「任何損害教師專業形象的行為都絕對不能接受」。"},{"pid":"d9593e0e3af32ba96e9e95ebb29492b6a54e18b6","tid":2232490,"uid":51790,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-10-06T12:01:40.000Z","msg":"未<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"c39c8d63d8d5f4b26ee2e3593199512140e68f0f","tid":2232490,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-06T12:03:38.000Z","msg":"推"},{"pid":"5b2caf91767652578863629c18867c6024508ed5","tid":2232490,"uid":51271,"like":4,"dislike":0,"score":4,"quote":{"pid":"d9593e0e3af32ba96e9e95ebb29492b6a54e18b6","tid":2232490,"uid":51790,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-10-06T12:01:40.000Z","msg":"未<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-06T12:04:09.000Z","msg":"真係屌教育局老母"},{"pid":"280f7ef800b2b751d66c558f4548a0ef6eb08c5a","tid":2232490,"uid":151313,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-06T12:04:30.000Z","msg":"推"},{"pid":"dda24ba2dcd29a31bfd005c282a4ea74fe68243c","tid":2232490,"uid":67553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-06T12:04:57.000