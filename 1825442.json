ets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-15T09:35:43.000Z","msg":"咁另外層數可唔可以打比你？"},"citedBy":2,"replyTime":"2020-01-15T09:39:27.000Z","msg":"可以，但點解咁岩係我走左唔使30秒就打入去<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-15T12:35:15.000Z","msg":"就係咁岩，唔準問點解"},{"pid":"d7ba35e8ba9e9f56f78f6102423538a3fd700274","tid":1825442,"uid":15283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T12:44:01.000Z","msg":"拉"},{"pid":"ea35ac0d76aa5873c6333bf022e1d230bd268511","tid":1825442,"uid":15283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T12:44:12.000Z","msg":"拉"},{"pid":"20092207729ed0ec0e523f2b7d77f03adcf865e0","tid":1825442,"uid":258106,"like":1,"dislike":0,"score":1,"quote":{"pid":"fecf46eddac88f1dbcf550870100d3b20264ea3e","tid":1825442,"uid":164920,"like":16,"dislike":0,"score":16,"quote":{"pid":"c305ee0137b2f610a0ce5b4cc6ca2366bdd410d4","tid":1825442,"uid":279023,"like":156,"dislike":2,"score":154,"citedBy":2,"replyTime":"2020-01-15T10:31:13.000Z","msg":"你地公關公司停止發呢類垃圾作文文章啦，<br />\n呢啲農場文香討首頁熱賣，<br />\n咁都睇唔出農場文章既各位網民返去讀下書"},"citedBy":1,"replyTime":"2020-01-15T12:26:27.000Z","msg":"【網民熱話】租住酒店驚現神秘電話問&ldquo;洗唔洗打針&rdquo;"},"citedBy":0,"replyTime":"2020-01-15T12:45:57.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n拉"},{"pid":"07b5c2da803ddda53c4a8c805a83156b9e5e414d","tid":1825442,"uid":188125,"like":0,"dislike":0,"score":0,"quote":{"pid":"8009315c518a222bb2ed5ad0d4185f0a1c919aaf","tid"