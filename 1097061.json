{"tid":1097061,"cid":16,"subCid":0,"title":"（1日兩po）smile yogurt 食評","createTime":"2019-04-08T06:55:07.000Z","updateTime":"2019-04-16T10:35:51.000Z","uid":21545,"like":7,"dislike":42,"uniUserReply":17,"replies":[{"pid":"ef1da316ced82091cf687024caf1d7f88650463d","tid":1097061,"uid":21545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-08T06:55:07.000Z","msg":"<img src=\"https://na.cx/i/dAmYTRH.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FdAmYTRH.png&h=7e64ec07&s={SIZE}\" /><br />\n<br />\n食完大阪燒 好熱 決定去食翻個乳酪雪糕消暑<br />\n我叫唗一個banana split <br />\n入面有一塊蝴蝶酥 一粒士多啤梨 （食咗先記得影<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />）<br />\n雪糕被脆米脆皮朱古力漿包住 之後分別有一層消化餅碎 一層雪糕 一層香蕉蓉 再一層雪糕 最後用青蘋果塾底<br />\n<br />\n材料之間配合得好好 做到相互輝映 <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<br />\n價錢：$56/杯 <br />\n<br />\n評分： 8.5/10<br />\n<br />\n總結：打卡自用兩相宜<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"fd70768414038e88d78f2134b042fbe2969a0db3","tid":1097061,"uid":135445,"like":10,"dislike":2,"score":8,"citedBy":1,"replyTime":"2019-04-08T06:57:47.000Z","msg":"去左打劫？"},{"pid":"8a4bbc2ced5d564434433c5ec2e901d5851eb33e","tid":1097061,"uid":21545,"like":0,"dislike":2,"score":-2,"quote":{"pid":"fd70768414038e88d78f2134b042fbe2969a0db3","tid":1097061,"uid":135445,"like":10,"dislike":2,"score":8,"citedBy":1,"replyTime":"2019-04-08T06:57:47.000Z","msg":"去左打劫？"},"citedBy":1,"replyTime":"2019-04-08T06:59:32.000Z","msg":"冇打劫<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"b6f88a213d382847eccfb4f513325f1229c226ec","tid":1097061,"uid":135445,"like":7,"dislike":1,"score":6,"quote":{"pid":"8a4bbc2ced5d564434433c5ec2e901d5851eb33e","tid":1097061,"uid":21545,"like":0,"dislike":2,"score":-2,"quote":{"pid":"fd70768414038e88d78f2134b042fbe2969a0db3","tid":1097061,"uid":135445,"like":10,"dislike":2,"score":8,"citedBy":1,"replyTime":"2019-04-08T06:57:47.000Z","msg":"去左打劫？"},"citedBy":1,