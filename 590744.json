ass=\"hkgmoji\" />"},{"pid":"389d963e707b416f6f1e8044c42af4c73a31b8df","tid":590744,"uid":124410,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-13T02:15:00.000Z","msg":"垃圾<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"ec087c6ed84a0f2cac502c7bdedbb5ff923acc2b","tid":590744,"uid":35014,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-03-13T02:16:07.000Z","msg":"此回覆已被刪除"},{"pid":"e6f9c487125186af0f99525fee72b98184aeca27","tid":590744,"uid":6530,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-13T02:17:45.000Z","msg":"唔係見過隔籬台嗰煲三文魚湯 真係唔會明佢點解會想跳樓<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c19f6d0baaedc12f8de50fcd7fe9df8bfb4704b6","tid":590744,"uid":58209,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-03-13T02:18:59.000Z","msg":"一睇到雞翼魚蛋湯就知old news<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"8a77e2977298d1f95df112949f74e845c06c43ad","tid":590744,"uid":35430,"like":0,"dislike":0,"score":0,"quote":{"pid":"5fb8b89fa295f63123d3aa476bb3e223d9bba3a5","tid":590744,"uid":3501,"like":0,"dislike":0,"score":0,"quote":{"pid":"a722b6b10dbbd3f3c468de52f1d884694a431e91","tid":590744,"uid":113626,"like":18,"dislike":0,"score":18,"citedBy":1,"replyTime":"2018-03-13T02:09:58.000Z","msg":"好心你唔好改左煲野佢<br />\n真果張圖當年高登睇完好多人都認同女童做法 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-13T02:11:12.000Z","msg":"見到張圖都諗 唔同咗樣嘅喂！"},"citedBy":0,"replyTime":"2018-03-13T02:20:24.000Z","msg":"我重懷疑自己係咪肚餓<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b4eb7d4139e0a35225c64fcdf1e85fff2791f2fc","tid":590744,"uid":22554,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-13T02:23:25.000Z","msg":"雖然係回帶, 但都係覺得女仔好慘,<br />\n<br />\n有心煮, 平野都可以煮得有心思, 好味, <br />\n<br />\n雞翼魚蛋湯真係求其到極致, 根本係浪費食物"},{"pid":"eab3ed48a9d5efb86e554f149a615585c561fce0","tid":590744,"uid":19542,"like":4,"dislike":0,"score":4,"quote":{"pid":"ec087c6ed84a0f2cac502c7bdedbb5ff923acc2b","tid":590744,"uid":35014,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-03-13T02:16:07.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-03-13T02:24:35.000Z","msg":"煲野唔食得 個女食得<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"6ba9be947ddaf1ed531999979e712c000bf68593","tid":590744,"uid":172840,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-13T02:24:41.000Z","msg":"民以食為天<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"06891876c114b03d82a836cf298a5e7ed55f6b10","tid":590744,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-13T02:24:51.000Z","msg":"個女無做錯"},{"pid":"94ac2d235fe43e054385b824ba10e51c650d2745","tid":590744,"uid":129335,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-13T02:26:50.000Z","msg":"有兩隻閪驚乜？大把錢"},{"pid":"10ac78ce07065c2e13f34b437b4aad56c2833e62","tid":590744,"uid":90704,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-13T02:29:37.000Z","msg":"窮人生仔......"},{"pid":"709cad636eec68836e54d68ce71734f08c073ea7","tid":590744,"uid":100230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-13T02:48:35.000Z","msg":"佢係仔就跳 係女?怕咩窮"},{"pid":"b1a0ae1cef98461b68e9dd96f276b0fcea20bd65","tid":590744,"uid":82717,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-13T03:04:09.000Z","msg":"有次去朋友屋企坐，本來都諗住走架啦，佢地好熱情咁叫我地留低食個便飯，點知就中伏，難食到呢，完全唔食又唔好意思，我同老婆都嗱嗱聲將白飯食晒話食飽<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n心諗有小朋友應該ok掛，但去多幾次唔同朋友屋企做客後，深深覺得屋企有餐好飯食並唔係必然，要好好咁多謝你嘅屋企人<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}