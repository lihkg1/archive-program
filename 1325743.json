f\" class=\"hkgmoji\" />"},{"pid":"69e85e642582d8fbd1f163091ff839866a5ee6da","tid":1325743,"uid":114754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T05:29:50.000Z","msg":"推"},{"pid":"65877b1e12bc1c271779618a015d4e5857f03adb","tid":1325743,"uid":258055,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T05:30:49.000Z","msg":"7.21 唔理衝唔衝 齊裝出金鐘"},{"pid":"70951ff407ed751f014f6c9561d7bb231306ec8b","tid":1325743,"uid":181257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T05:31:57.000Z","msg":"推"},{"pid":"3ef786c01f86d13b51e43c3bdcadc3abb19e6d6e","tid":1325743,"uid":181257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T05:32:51.000Z","msg":"推"},{"pid":"a91a50eed4d183cf35826c85ad5073188b63aa77","tid":1325743,"uid":181257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T05:33:09.000Z","msg":"推"},{"pid":"39cc04db7527c4b9e032b2ba22b6cd0d70499793","tid":1325743,"uid":274244,"like":0,"dislike":0,"score":0,"quote":{"pid":"c5a5b63d82a3e0b0d950bb7f76afe891078ad7d1","tid":1325743,"uid":181257,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-17T03:35:04.000Z","msg":"還記得我們對他許下的諾言嗎？<br />\n<br />\n<img src=\"https://na.cx/i/oPaUq3D.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FoPaUq3D.png&h=e21e3fcf&s={SIZE}\" /><br />\n<br />\n<img src=\"https://na.cx/i/5Ektvvn.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F5Ektvvn.png&h=0d40a0d9&s={SIZE}\" /><br />\n<br />\n<br />\n已經一個多月了，五大訴求有無一項做到？<br />\n一百萬人上街 政府唔理<br />\n二百萬人上街 政府唔理<br />\n有人以死明志 政府唔理<br />\n警察受輕傷 政府仆到去理<br />\n<br />\n<br />\n我唔知再出最後結果係咪都一樣，但係，我哋應承得嘅，就一定要做，一日未達成共識，都要出<br />\n<br />\n大家成年人 唔洗再睇風向做人 要點做自己諗<br />\n<br />\n但我想問一個問題，咁多人犧牲 受傷 被補<br />\n如果結果係咁 你甘心咩？"},"citedBy":0,"replyTime":"2019-07-17T05:36:57.000Z","msg":"<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"f2c8f7bd0d22d1e4c8f69ceeae04abd7c6cfe30e","tid":1325743,"uid