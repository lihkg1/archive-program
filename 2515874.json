 src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmaxsWSMUMzPo11dAnC9bUH8Bxv7oYKqazuZFwRBhvboAy?filename=taoELgH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FtaoELgH.jpg&h=ce3d1f92&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n我地真係好想入冊前，可以比各位手足買到食到自己親手包嘅糭<br />\n真係好好味架，食完人都聰明咗，考試100分<br />\n我叫你試吓呀！<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmP3DsutsgMCsnaEi2S1E1odvXoGzGPcj6rDpZcSinFeER?filename=KcjHH3N.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKcjHH3N.jpg&h=e02ed90b&s={SIZE}\" /></blockquote>"},{"pid":"f54bba36434d3e4bcc899630cc368281823510a5","tid":2515874,"uid":209830,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-04T09:32:25.000Z","msg":"推<br />\n住沙田 星期六去買<img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" />"},{"pid":"2fd0105a55ee04c9b142bbbce9d6ea5e577f88e5","tid":2515874,"uid":187232,"like":0,"dislike":0,"score":0,"quote":{"pid":"f54bba36434d3e4bcc899630cc368281823510a5","tid":2515874,"uid":209830,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-04T09:32:25.000Z","msg":"推<br />\n住沙田 星期六去買<img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-05-04T09:47:04.000Z","msg":"感激<br />\n<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />"}]}