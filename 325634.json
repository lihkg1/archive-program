/faces/lomoji/36.png\" class=\"hkgmoji\" />"},{"pid":"89fbcb708e837894f4d33bc0bb596752d8f6faa4","tid":325634,"uid":57103,"like":254,"dislike":1,"score":253,"citedBy":0,"replyTime":"2017-07-17T11:16:04.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/07/17/191603_8c9c46d7cde1fa0504a9772b1acee861.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F17%2F191603_8c9c46d7cde1fa0504a9772b1acee861.jpg&h=f72fc4ba&s={SIZE}\" />"},{"pid":"f02c0dbb169f3ecc199659657bbbddbf0027b014","tid":325634,"uid":57103,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2017-07-17T11:17:01.000Z","msg":"唔識嘛<img src=\"/assets/faces/lomoji/19.png\" class=\"hkgmoji\" /> ，見佢連企都未企得穩"},{"pid":"fa335d088c9d548b45174a3c8b44f33efb4dca81","tid":325634,"uid":50483,"like":203,"dislike":0,"score":203,"citedBy":0,"replyTime":"2017-07-17T11:17:06.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2017/07/17/191603_8c9c46d7cde1fa0504a9772b1acee861.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F17%2F191603_8c9c46d7cde1fa0504a9772b1acee861.jpg&h=f72fc4ba&s={SIZE}\" /></blockquote><br />\n你見唔見到佢啤住隻蛋<img src=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" />"},{"pid":"c03ef5ab356ff4074dfc3ccb840f038d61b9f5f2","tid":325634,"uid":34834,"like":31,"dislike":0,"score":31,"citedBy":0,"replyTime":"2017-07-17T11:17:58.000Z","msg":"煎隻蛋比佢食"},{"pid":"c4968c4bdce1279a9673ae7cbb36d1d03c766ee3","tid":325634,"uid":50483,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2017-07-17T11:19:12.000Z","msg":"<blockquote>唔識嘛<img src=\"/assets/faces/lomoji/19.png\" class=\"hkgmoji\" /> ，見佢連企都未企得穩</blockquote><br />\n小心啲 驚佢有病 始終佢食既野都係隨街 唔知有冇禽流感<br />\n<img src=\"/assets/faces/lomoji/36.png\" class=\"hkgmoji\" />  仲有佢食到蟲就Ok 再細啲可以餵蛋黃"},{"pid":"c70415b68cdaebae25254243c5d4f04b40ef9e41","tid":325634,"uid":57103,"like":23,"dislike":2,"score":21,"citedBy":0,"replyTime":"2017-07-17T11:19:16.000Z","msg":"<blockquote><blockquote><img src=\"https://img.eservice-hk.net/upload/2017/07/17/191603_8c9c46d7cde1fa0504a9772b1acee861.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F17%2F191603_8c9c46d7cde1fa0504a9772b1acee861.jpg&h=f72fc4ba&s={SIZE}\" /></blockquote><br />\n你見唔見到佢啤住隻蛋<img src=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" /></blockquote><br />\n咁應唔應該喺佢面前打爛隻蛋<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"84293713e861c215509d04fdd8d07e882ee3afce","tid":325634,"uid":50483,"like":35,"dislike":2,"score":33,"citedBy":0,"replyTime":"2017-07-17T11:19:39.000Z","msg":"<blockquote><blockquote><blockquote><img src=\"https://img.eservice-hk.net/upload/2017/07/17/191603_8c9c46d7cde1fa0504a9772b1acee861.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F17%2F191603_8c9c46d7cde1fa0504a9772b1acee861.jpg&h=f72fc4ba&s={SIZE}\" /></blockquote><br />\n你見唔見到佢啤住隻蛋<img src=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" /></blockquote><br />\n咁應唔應該喺佢面前打爛隻蛋<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /></blockquote><br />\n抱住佢煎蛋"},{"pid":"40b3d2a60f4175fc4acc0a3b56d7ee35b3ac0656","tid":325634,"uid":128444,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-07-17T11:22:29.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> 嚇到佢即飛"},{"pid":"60b15c5a56586e0aeca0f258b930bfbaad4363e4","tid":325634,"uid":57103,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-07-17T11:24:12.000Z","msg":"佢由吹乾左之後就不斷叫，一路無停過，又唔知佢咩事，蟲又食左，水又飲左，屎都屙埋<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" />"},{"pid":"5b21f61e24aae297d0f3c75f94731d3c5f75c3ce","tid":325634,"uid":74821,"like":10,"dislike":1,"score":9,"citedBy":0,"replyTime":"2017-07-17T11:26:21.000Z","msg":"<blockquote>佢由吹乾左之後就不斷叫，一路無停過，又唔知佢咩事，蟲又食左，水又飲左，屎都屙埋<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" /></blockquote><br />\n係咪驚咋？我早幾日都執到隻，但唔肯食野之後過一日就死左<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"838b1e2122b37ce17662fa24fe3b695459f6ca83","tid":325634,"uid":23266,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2017-07-17T11:26:42.000Z","msg":"麻雀係羣體生活<br />\n叫係搵緊同伴呀"},{"pid":"25c4ee96e522abec66c186100a80f322bd15bb24","tid":325634,"uid":3818,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-07-17T11:27:37.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"d488e8d590d019b4531d45f21046ab87944c8d13","tid":325634,"uid":37413,"like":27,"dislike":0,"score":27,"citedBy":0,"replyTime":"2017-07-17T11:28:26.000Z","msg":"<blockquote>佢由吹乾左之後就不斷叫，一路無停過，又唔知佢咩事，蟲又食左，水又飲左，屎都屙埋<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" /></blockquote><br />\n因為你困住佢囉<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f0b8d5486cfcf2b63fb9b0e58524c625337815b3","tid":325634,"uid":57103,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-07-17T11:29:02.000Z","msg":"<blockquote><blockquote>佢由吹乾左之後就不斷叫，一路無停過，又唔知佢咩事，蟲又食左，水又飲左，屎都屙埋<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" /></blockquote><br />\n係咪驚咋？我早幾日都執到隻，但唔肯食野之後過一日就死左<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /> 我嗰隻肯食野，但係要將條麥皮蟲一開四先食到，因為我本身養左隻守宮，得啲大條嘅蟲"},{"pid":"ff62a8ac483a99b3ed2779c2832a5fcf5f9d8119","tid":325634,"uid":57103,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2017-07-17T11:29:57.000Z","msg":"<blockquote>麻雀係羣體生活<br />\n叫係搵緊同伴呀</blockquote><br />\n唔該，但係出面好大雨，我唔敢放返佢出去"},{"pid":"f7c4c66ab6fbc9954e59ea1ff257e77cfb777075","tid":325634,"uid":20328,"like":83,"dislike":1,"score":82,"citedBy":0,"replyTime":"2017-07-17T11:37:08.000Z","msg":"好耐之前有個fd又係執到隻bb<br />\n跟住餵完佢食野之後佢又係咁叫<br />\n到第二朝早出面有其他雀仔接佢走<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9548fc7ab162b3ec77fffe4248c9c2a8e73ca6dd","tid":325634,"uid":37413,"like":156,"dislike":1,"score":155,"citedBy":0,"replyTime":"2017-07-17T11:37:20.000Z","msg":"<blockquote><blockquote>麻雀係羣體生活<br />\n叫係搵緊同伴呀</blockquote><br />\n唔該，但係出面好大雨，我唔敢放返佢出去</blockquote><br />\n佢哋有辦法生存㗎啦， 落大雨會死咁雀鳥絕咗種啦<br />\n冇咁大雨放番原位啦"},{"pid":"ecb573f725d7004c4191945bc3e3d582d431be68","tid":325634,"uid":49004,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-07-17T11:37:42.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"3a519774074180245e91aa4c32dc2bf43cad7c47","tid":325634,"uid":121580,"like":59,"dislike":0,"score":59,"citedBy":0,"replyTime":"2017-07-17T11:40:06.000Z","msg":"<blockquote>好耐之前有個fd又係執到隻bb<br />\n跟住餵完佢食野之後佢又係咁叫<br />\n到第二朝早出面有其他雀仔接佢走<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n無錯,之前捉左隻受傷既麻雀<br />\n日叫夜叫,有麻雀圍住個雀籠<br />\n餵佢個陣順手喂埋佢d friend<br />\n見佢識行識跳就放返<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5c52c4ee72798cc7b141fa3160e4843f1566d861","tid":325634,"uid":55614,"like":98,"dislike":13,"score":85,"citedBy":0,"replyTime":"2017-07-17T11:40:33.000Z","msg":"你都on99 以為技能發動好威威？<br />\n對你 佢好大機會有禽流感 <br />\n對佢 你唔識養又唔比佢走 點生存"},{"pid":"51042d8b4a984b84098ffef675c4a1091fc33253","tid":325634,"uid":9979,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-07-17T11:41:03.000Z","msg":"正呀喂"},{"pid":"37af1b1fc135ea19e9177289659e6da