-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ft.me%2Fthankyouyuli&d=9YhXM5wGpBmAIWfwXK7ScMF4Sk7tP0df8nBEIt5zy0g%3D&h=b3926d32\" target=\"_blank\">t.me/thankyouyuli</a><br />\n<br />\n<img src=\"https://na.cx/i/pyqxxHV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpyqxxHV.jpg&h=6a2391ee&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/aZ1wOgf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaZ1wOgf.jpg&h=6e1bafb7&s={SIZE}\" /><br />\n<br />\n1207大召集！！鐵定星期六3點，愛丁堡廣場支持被逐印尼手足！！！！！<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/eDaQdS\" data-auto-link target=\"_blank\">https://lih.kg/eDaQdS</a>"},{"pid":"6a1f86e2ecff8a67fd2e361bf455d3a4e4dc8f39","tid":1771072,"uid":224836,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T16:03:32.000Z","msg":"<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"5bbdb0d8b9fe320cf5e5acbe5d88f4522e073b6e","tid":1771072,"uid":224836,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-06T12:20:31.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}