{"tid":1775844,"cid":5,"subCid":0,"title":"又一城，我祝你聖誕快樂，鼠年行大運","createTime":"2019-12-09T06:11:29.000Z","updateTime":"2019-12-09T06:11:29.000Z","uid":51271,"like":1,"dislike":0,"uniUserReply":1,"replies":[{"pid":"124ecf4a2fd7dafd2e9951dcfc80f7d7f2953516","tid":1775844,"uid":51271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-09T06:11:29.000Z","msg":"<a href=\"https://www.facebook.com/standnewshk/photos/a.720050934747196/2687702977981972/?type=3&amp;theater\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fstandnewshk%2Fphotos%2Fa.720050934747196%2F2687702977981972%2F%3Ftype%3D3%26theater&d=2Jo0d4zpMW7MEYOmRW2LdR0Z1crOiE0eyIPSb4MeDzY%3D&h=ea02c2bc\" data-auto-link target=\"_blank\">https://www.facebook.com/standnewshk/photos/a.720050934747196/2687702977981972/?type=3&amp;theater</a><br />\n<br />\n【又一城設施尚待修復】<br />\n<br />\n上月九龍塘又一城商場發生嚴重警民衝突後，商場設施被人破壞，商場之後一直關閉至今。今日有部份店舖員工可以進入商場，讀者提供的圖片顯示多層玻璃圍欄及扶手電梯仍未修復。<br />\n<br />\n<img src=\"https://scontent-hkg3-2.xx.fbcdn.net/v/t1.0-9/78925621_2687702981315305_9189685427236241408_n.jpg?_nc_cat=103&amp;_nc_eui2=AeHnryZNbePic669yqC7y-MXX5xE_8zF2TkQwkJ0ErKyz-RC-0ViubQA1XqMvX5CwZRdTxIHWHU4NjS9gKo2iBe7k6bv1XGyiC-mJ-L6bJeWAA&amp;_nc_ohc=4-0gatwLOPsAQnqmIEHR03WTQMgmzWFQ9GyvFrjdzkp1o1sSjDmLeBMIw&amp;_nc_ht=scontent-hkg3-2.xx&amp;oh=b5515b8b57a5a39f7a737be6137e5125&amp;oe=5E739C83\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkg3-2.xx.fbcdn.net%2Fv%2Ft1.0-9%2F78925621_2687702981315305_9189685427236241408_n.jpg%3F_nc_cat%3D103%26_nc_eui2%3DAeHnryZNbePic669yqC7y-MXX5xE_8zF2TkQwkJ0ErKyz-RC-0ViubQA1XqMvX5CwZRdTxIHWHU4NjS9gKo2iBe7k6bv1XGyiC-mJ-L6bJeWAA%26_nc_ohc%3D4-0gatwLOPsAQnqmIEHR03WTQMgmzWFQ9GyvFrjdzkp1o1sSjDmLeBMIw%26_nc_ht%3Dscontent-hkg3-2.xx%26oh%3Db5515b8b57a5a39f7a737be6137e5125%26oe%3D5E739C83&h=5cf870e0&s={SIZE}\" />"}]}