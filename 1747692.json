al/smile.gif\" class=\"hkgmoji\" />"},{"pid":"e9c7657232f6eb4c995cba8c4d0f07be6e79adda","tid":1747692,"uid":277640,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T16:34:44.000Z","msg":"推！"},{"pid":"777fe74d308ed16c0883515e2e02044425346ee5","tid":1747692,"uid":206207,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T17:10:57.000Z","msg":"<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"6318dfe82b905726c827c557c184c8956aa5c19c","tid":1747692,"uid":41545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T17:13:14.000Z","msg":"手足<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /> <br />\n我就算比人斬我都會投左我個票佢<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n唔係我直情愧對人呢個字<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"5ea8e8504606af770ff52d9d97ec3de95a3b8ebb","tid":1747692,"uid":221265,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T17:13:44.000Z","msg":"Push"},{"pid":"53863e60e9f7490e8bd75fe53584634a6f4bae78","tid":1747692,"uid":229141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T17:14:20.000Z","msg":"「所以我希望，11月24日，香港人可以用和平嘅方式去爭取，去令香港民主，珍惜呢一票，希望大家聽日可以行出去投票。」<br />\n1<br />\n0"},{"pid":"5e08a0a060a1ec7de8c369308371656c026f625d","tid":1747692,"uid":161711,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T17:49:20.000Z","msg":"唔係講笑"},{"pid":"cccec82e24bac92579c7e4e9ac45c5a214578b7c","tid":1747692,"uid":42767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T17:57:16.000Z","msg":"熱狗準備屌義士拎光環"},{"pid":"a22599312b970ca0fa39b6b8871f556c08c75063","tid":1747692,"uid":71847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T18:14:07.000Z","msg":"推"},{"pid":"f6d74ec7f7f4dc5697cb5852cbec1c240a09c2ce","tid":1747692,"uid":262428,"like":0,"dislike":0,"score":0,"quote":{"pid":"17c35df81b6e1cf65b09ae3c78a66c56afd4e0f0","tid":1747692,"uid":156547,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-23T10:34:34.000Z","msg":"反修例風波持續逾5個月，受傷的抗爭者不計其數，有人疑被警方以橡膠子彈射爆眼，也有人因為警暴而骨折，21歲學生周柏均更在本月11日「全民三罷」當日在西灣河被警方槍擊受傷，他出院後今午首度會見傳媒，憶述當日中槍一刻曾以為就此結束短暫一生，但迅速提醒自己：「我要活落去，我先可以見到香港有民主嘅一日。」逃出鬼門關，暫時未能上前線，他唯有轉在文宣方面支援「手足」，而在激烈抗爭行動外，<span style=\"font-size: xx-large;\">他指區選也極為重要，是一個和平爭取民主的方式，他即使負傷，明天也會投票，也呼籲市民履行公民責任，「因為多你一票真係好多，每一票都係好關鍵」。</span><br />\n<br />\n記者：陳嘉裕 <br />\n<br />\n11.11「全民三罷」當日在西灣河被交通警槍傷的周柏均是慈幼舊生，今午在其中學師兄、立法會議員陳志全，及身兼其代表律師的前議員鄭家富陪同下接受傳媒訪問，仍在康復中的他需要依賴柺仗步行，喉嚨亦因為當日緊急插喉而受傷，聲音虛弱又沙啞，訪問過程中他不時用右手按住腰間位置，止住傷口的痛楚。他透露，身上一共有5個傷口，其中一個是槍擊所致，被子彈傷及的右邊腎臟已經切除，肝亦有受傷；目前只可短時間步行，「行一步路都係要痛一步」，腰間的傷口不時劇痛，但他的康復進度比想像中理想，他感謝市民的支持和鼓勵，令他可以度過難關。<br />\n<br />\n周同學說中彈的感覺如同被一種衝力撞低，「無感覺嘅，唔會feel（感覺）到有劇痛，入到醫院做完手術先至會有個痛楚」，又透露中彈一刻自己完全清醒，能聽見周圍的情況，惟身體乏力難以郁動，他曾經想過自己會否因此喪命，但立即提醒自己：<span style=\"font-size: xx-large;\">「我要活落去，我先可以見到香港有民主嘅一日」</span>，周以頑強意志力奇蹟地完成手術，走過鬼門關。<br />\n<br />\n受傷的身體可以在醫護照顧下慢慢康復，但槍擊案的陰霾卻是周同學不能磨滅的回憶，他坦言住院頭五晚都未能安眠，除了傷口的痛楚，亦因為一合上眼就會想起槍擊一刻，「喺深夜凌晨2點、4點、5點，我就會醒一醒，諗起關家榮﹙開槍交通警﹚拎把槍指住我個人去開槍，我嗰下係好驚」。提及會否想過警方會以實彈對付抗爭者？他怒斥「荒謬」，指當時情況沒有人在馬路，且未有對警員構成威脅，但若然再選擇一次，他相信自己仍然會有同一舉動。<br />\n<br />\n提到以生命換取民主是否值得？周同學坦言，年輕一輩將自己的命運押於香港的民主，「我會形容（我哋）係被選中嘅一代，2014年（雨傘運動）、2016年（旺角魚蛋革命）、2019年（反修例）一個咁密集嘅抗爭運動，去到而家連續5個月，我哋呢代嘅年青人，係押上咗前途同性命，去爭取我哋嘅民主自由」，但他認為以生命換民主並不值得，「民主同自由，根本上係basic（基本）嘅嘢嚟，香港政府一直都無畀我哋，《基本法》都寫咗，我哋有普選嘅權利，所以我哋唔應該用性命去換取（民主），係政府必然要畀我哋嘅一個權利」。<br />\n<br />\n在病榻上的日子，周同學仍然關心街上的情況，手術後他最想知道其他抗爭者有否被捕，以及中大抗爭者的情況，「想知道佢哋可唔可以好似我咁大步檻過，無大嘅傷勢，唔想警方再不斷濫暴」。他指，香港過去5個月經歷了多次激烈抗爭，明天的11.24區議會選舉將是一個和平爭取民主的方式，多次呼籲香港市民要踴躍投票：<span style=\"font-size: xx-large;\">「所以我希望，11月24日，香港人可以用和平嘅方式去爭取，去令香港民主，珍惜呢一票，希望大家聽日可以行出去投票。」</span><br />\n<br />\n雖然周同學已經出院，但仍有機會面對警方的檢控，其代表律師鄭家富指，目前周同學仍在保釋候查中，實際罪名有待警方確認，又透露保釋紙未有寫上罪名，對此他感到詫異，形容自己做律師多年情況罕見。他指，若周同學身體情況許可將會錄取進一步的口供，稱已有一隊資深的刑事大律師團隊準備為周同學辯護。 <br />\n<br />\n<span style=\"font-size: xx-large;\">人地鎗都中埋都話去投票<br />\n你仲有咩藉口唔投票?</span>"},"citedBy":0,"replyTime":"2019-11-23T18:15:58.000Z","msg":"【好多人唔知】【請幫手廣傳】記住，聽日區議會係一人有三票！<br />\n<a href=\"https://lih.kg/1747875\" data-auto-link target=\"_blank\">https://lih.kg/1747875</a><br />\n<br />\n幫手說服多啲人投"},{"pid":"c2312b6794d7d345cabbe27a79f08c1ec3eba966","tid":1747692,"uid":206207,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T00:24:20.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"722e49acae4e03a20e79c1ec5e8c9feb9a6f9b88","tid":1747692,"uid":156547,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T01:01:01.000Z","msg":"<span style=\"font-size: xx-large;\">「因為多你一票真係好多，每一票都係好關鍵」</span>"},{"pid":"1065af3db596b3d2380b74cfb641cee92ca12f46","tid":1747692,"uid":156547,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T01:09:59.000Z","msg":"<span style=\"font-size: xx-large;\"><br />\n「所以我希望，11月24日，香港人可以用和平嘅方式去爭取，去令香港民主，珍惜呢一票，希望大家聽日可以行出去投票。」</span>"},{"pid":"04139b3d7add3364cb7d183874da46e635551a69","tid":1747692,"uid":114252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T04:56:22.000Z","msg":"推"},{"pid":"5bf2860d6dfc48ea604348c1edb4db75cf2c8c6c","tid":1747692,"uid":199739,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T06:15:34.000Z","msg":"義士"},{"pid":"51eb04fccee4ee719224dc715fe1e1cf04fed242","tid":1747692,"uid":95138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T06:17:17.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"cb28564d9751acd92062cce0aac114286186ff9d","tid":1747692,"uid":275688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T06:22:02.000Z","msg":"唔好推啦，白票黨睇到情何以堪<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"abbee0b7eac1d0e176f037952b31a653b51640d4","tid":1747692,"uid":165683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T07:14:31.000Z","msg":"Push"},{"pid":"6e1c7655c84610c9b94305d004b317c7392f99fb","tid":1747692,"uid":165683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T07:15:57.000Z","msg":"Push"}]}