/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-13T11:40:43.000Z","msg":"侵譴責國會衝擊事件 + 美軍參謀長聯席會議譴責國會衝擊事件 = 美軍參謀長聯席會議認同侵譴責國會衝擊事件"},{"pid":"8657f1467939638b3b25e0cb34637c466ac16ce2","tid":2364971,"uid":199771,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2021-01-13T11:42:49.000Z","msg":"內戰啦"},{"pid":"b631129f738931cc8f09e4eb93f28c9b3fe24738","tid":2364971,"uid":209890,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-13T11:43:13.000Z","msg":"一切都係計特朗普156智商入面既<del>計</del>中計中計中計中計中計中計<br />\n等你入左八奇思考領域就明"},{"pid":"9df6806d4793df440556d964d987ac1ecc23f61f","tid":2364971,"uid":348370,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-01-13T11:43:53.000Z","msg":"<img src=\"https://na.cx/i/EUBveCz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEUBveCz.jpg&h=a38f6557&s={SIZE}\" />"},{"pid":"e5e86a0a6aa639129cae7e5d18a2ba450c904c22","tid":2364971,"uid":54373,"like":1,"dislike":0,"score":1,"quote":{"pid":"d167c1cc388a201ee17a20a589f6d189741fb403","tid":2364971,"uid":20563,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2021-01-13T11:39:54.000Z","msg":"內文邊一句話支持侵<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-13T12:10:45.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />廢登力news 不意外<br />\n<br />\nhe won 1000.0"},{"pid":"b3dc4db0181bf631730cf9247b90371eeb10cbfc","tid":2364971,"uid":281071,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-13T12:12:48.000Z","msg":"屌 <strong><span class=\"xx-large\"><span class=\"red\">標題黨</span></span></strong>"},{"pid":"3faa899a54fcb01558fa5e312c7637969a495e20","tid":2364971,"uid":263944,"like":0,"dislike":0,"score":0,"cite