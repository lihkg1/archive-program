ze: xx-large;\">621我覺得可以同民陣討論<br />\n絕對唔係要比大台騎劫<br />\n但要明白民陣既一個呼籲比我地係連登開posts既聲音可以傳得更廣。</span></span>"},{"pid":"2f319f73944613655b5fe0118df2c6cc5b2a10e3","tid":1241841,"uid":7971,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T00:36:33.000Z","msg":"推"},{"pid":"a49a5a7cb6b7befcc310df3b9aac48ca1f0f61d1","tid":1241841,"uid":7971,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T00:36:55.000Z","msg":"求幫推"},{"pid":"a4423beafe8f3fb7f06adc9990934490a1722c37","tid":1241841,"uid":7971,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T00:37:14.000Z","msg":"推推推"},{"pid":"f590406d5732a4deae73445f003374e734338c4c","tid":1241841,"uid":7971,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T00:37:25.000Z","msg":"推"}]}