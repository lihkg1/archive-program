-20T17:34:24.000Z","msg":"推"},{"pid":"463ccbab728745e948a0e6645b46c6659fd834a1","tid":1742164,"uid":203499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T17:35:01.000Z","msg":"推"},{"pid":"78f974424a6b5f7df21d027a42b2827b18917f9f","tid":1742164,"uid":225798,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T17:35:22.000Z","msg":"<img src=\"https://na.cx/i/g4ZDJeL.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fg4ZDJeL.gif&h=433fcbe0&s={SIZE}\" />"},{"pid":"895cf82cbcc3dcc0d9f251fe2e76cbb05c5eaf9b","tid":1742164,"uid":150842,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-20T17:36:03.000Z","msg":"好多人已經忘記左<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />"},{"pid":"ba5cadbd9c77f2a14ae0d64553b1f66f52bdc79f","tid":1742164,"uid":150707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T17:37:32.000Z","msg":"推"},{"pid":"5d30684972b28f04d6ad8affc8724adae88be77c","tid":1742164,"uid":137037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T17:38:31.000Z","msg":"Push"},{"pid":"a399e16f7d0271e7d284d58ed0cd73e0ad34beff","tid":1742164,"uid":25699,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-20T17:43:42.000Z","msg":"有樣野唔知岩唔岩<br />\n<br />\n個人發覺，民意歸邊係事實，但所謂既民意歸邊只係適用係非港豬身上，我當200萬黃，50萬藍。港豬仲有450萬。係黎明行動睇到好多人仲係置身事外。<br />\n我地應該要突破同溫層，起碼將黃既拉到去半數，長遠黎講一定有用"},{"pid":"9d25dd8a39a3149dc9dd8ba8d337ebd4ca5904a6","tid":1742164,"uid":8880,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T17:59:13.000Z","msg":"最重要係be water"},{"pid":"55b1555f4a48fbc8f8d63f3551364483e26d564b","tid":1742164,"uid":90305,"like":0,"dislike":0,"score":0,"quote":{"pid":"a399e16f7d0271e7d284d58ed0cd73e0ad34beff","tid":1742164,"uid":25699,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-20T17:43:42.000Z","msg":"有樣野唔知岩唔岩<br />\n<br />\n個人發覺，民意歸邊係事實，但所謂既民意歸邊只係適用係非港豬身上，我當200萬黃，50萬藍。港豬仲有450萬。係黎明行動睇到好多人仲係置身事外。<br />\n我地應該要突破同溫層，起碼將黃既拉到去半數，長遠黎講一定有用"},"citedBy":0,"replyTime":"2019-11-20T18:04:42.000Z","msg":"係，當然，餘下就係耐性既問題。<br />\n我有朋友藍到黑既爸爸變成黃，用左3個月。<br />\n好辛苦，但就係成功左。<br />\n<br />\n宜家再轉係極難，但難都要做。我覺得未必要佢地藍轉中立或者黃，只要佢對藍信心減少，甚至消失就可以。"},{"pid":"6cf4511b19a1b45798ffff3541e66b4a2fe72e82","tid":1742164,"uid":90305,"like":0,"dislike":0,"score":0,"quote":{"pid":"895cf82cbcc3dcc0d9f251fe2e76cbb05c5eaf9b","tid":1742164,"uid":150842,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-20T17:36:03.000Z","msg":"好多人已經忘記左<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-20T18:08:54.000Z","msg":"係啊，好多一開始大家都同意，又超有用既嘢<br />\n漸漸因為各種原因消失<br />\n所以其實問返6 7月既自己係最實際<br />\n<br />\n但ok 既，完全理解點解大家有習慣，疲態，晦氣： 一日半日好啦。<br />\n但大家都係時候pick up 返，重新上路。"},{"pid":"4999398a2a5ceb2ad3c28477525bf01b544c1aa6","tid":1742164,"uid":254381,"like":1,"dislike":0,"score":1,"quote":{"pid":"a399e16f7d0271e7d284d58ed0cd73e0ad34beff","tid":1742164,"uid":25699,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-20T17:43:42.000Z","msg":"有樣野唔知岩唔岩<br />\n<br />\n個人發覺，民意歸邊係事實，但所謂既民意歸邊只係適用係非港豬身上，我當200萬黃，50萬藍。港豬仲有450萬。係黎明行動睇到好多人仲係置身事外。<br />\n我地應該要突破同溫層，起碼將黃既拉到去半數，長遠黎講一定有用"},"citedBy":1,"replyTime":"2019-11-20T18:27:23.000Z","msg":"g持<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /> 我睇完啲數據都覺感化藍綠方面絕對有得再做多啲 我同我啲friend研究緊實際要點突破溫層 應該過一兩日會開 post 講講<br />\n<br />\n有興趣可以望下survey result分析：<br />\n<br />\n[和理非戰略] 民意分析及文宣方向<br />\n<a href=\"https://lih.kg/1738027\" data-auto-link target=\"_blank\">https://lih.kg/1738027</a><br />\n- 分享自 LIHKG 討論區"}]}