=\"/assets/faces/fs/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/good.gif\" class=\"hkgmoji\" /><br />\n隔離post<br />\n<br />\n<br />\n其實不需要再問XXX口號是否違法和要求政府比清晰指引，國安法是故意寫得那麼含糊，否則就不能製造自我審查和寒蟬效應，所以他們永遠不會告訴你什麼是合法，只會告訴你現在這個是違法了，現在那個也是違法了。<br />\n<br />\nby facebook"},{"pid":"6c59de9278c543e40e674b50a1153c7a9c8aa280","tid":2091164,"uid":195350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-02T14:55:41.000Z","msg":"Push"},{"pid":"30df5faa98d355de1c0b728911bffb92e83396db","tid":2091164,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-02T15:33:12.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"ec2208eab3169de148719fec00a4d46b42d10350","tid":2091164,"uid":80162,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-02T18:20:13.000Z","msg":"推"},{"pid":"15375ad45211cd8e856e14ba534716297f8584a1","tid":2091164,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-03T03:31:09.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"07b3d4df0512e78b620b9ec231ba0026aecb7706","tid":2091164,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-03T09:01:22.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"8fbbf8842e571a3ee9d4c0a91b6bae2408f64672","tid":2091164,"uid":35347,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-03T09:06:54.000Z","msg":"連登真係對人不對事<img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" />"},{"pid":"afaa5ef661ced7dc581eab76a38b5ccbe09b0d26","tid":2091164,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTi