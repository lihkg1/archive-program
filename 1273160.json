7:05.000Z","msg":"推"},{"pid":"eef3589a843bba77db7ec0363f4def31f4793f87","tid":1273160,"uid":89848,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:07:07.000Z","msg":"應該給現有政府在短時間內回應訴求，當中應包括要求8月普選新特首，9月普選新立法會，否則呼籲現政府各行政部門及香港警隊內義士變節，呼籲市民上街包圍政府機關逐一由新政府接管，由香港人角度出發重新實施一國兩制（避免因港獨或分離主義影響外國支持），只要香港境內只實施香港人認同的法例及政策，甚麼人大決議或釋法未經本地立法會確認均屬無效，一國兩制都夠香港人玩）。"},{"pid":"822408f9e334fdeab84d91b62c2e7020ca13b639","tid":1273160,"uid":220779,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:07:08.000Z","msg":"推"},{"pid":"a1d59396c9ff9609665f6d5a4e7d58514ae45f3f","tid":1273160,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:07:11.000Z","msg":"推"},{"pid":"2be65f84d4bd79e6762bce29e03e32a20872ce09","tid":1273160,"uid":256908,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:07:15.000Z","msg":"1. 正式撤回《逃犯條例》修訂草案；<br />\n 2. 成立獨立調查委員會，調查警方是否在示威活動當中使用過度武力；<br />\n3. 釋放所有被捕示威者並承諾不檢控任何示威人士；<br />\n4. 撤銷6.12暴動定義；<br />\n5. 實行真普選<br />\n1. Withdraw the bill;<br />\n2. Appoint an independent commission to inquire into the excessive violence used by the police in the protests; <br />\n3. Release all arrested protesters unconditionally without the threat of future prosecution;<br />\n4. Renounce the characterisation of the 12 June protests as &ldquo;riots&rdquo;;<br />\n5. realise our rights to elect a truly democratic government by universal suffrage."},{"pid":"9e070067004b66ece507f0be072197c38e02c1fa","tid":1273160,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:07:21.000Z","msg":"推"},{"pid":"478833a96380e528e682b6d3439c137876cdd852","tid":1273160,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:07:33.000Z","msg":"推"},{"pid":"6b40e764ba8a3dd7e7a08ba75749c15d71264cf4","tid":1273160,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:07:46.000Z","msg":"推"},{"pid":"3312def1fe47222bf85e46e192330abaaf19f40d","tid":