03a12af86325d1d191157cf8a","tid":1141021,"uid":197125,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f3a34615de93296d2e0c70854b219cab317a34a","tid":1141021,"uid":235671,"like":9,"dislike":0,"score":9,"quote":{"pid":"a52f67a2627bac61ae2f9aceef21c82a609d164e","tid":1141021,"uid":129013,"like":0,"dislike":16,"score":-16,"citedBy":3,"replyTime":"2019-05-06T09:07:19.000Z","msg":"都未聽過<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-06T09:36:23.000Z","msg":"捷旅，勝景，翠明，金怡。你未聽過只能講你未去到join 呢D團嘅階段<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-06T10:28:49.000Z","msg":"未聽過仲要大大聲講出嚟俾人笑<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-06T10:55:12.000Z","msg":"笑得開心d<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"69f84abae997a3ec694a806bc1eb53b9e564a5b1","tid":1141021,"uid":113373,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2019-05-06T11:32:17.000Z","msg":"<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">反對修訂逃犯條例 香港的終局之戰</span><br />\n<br />\n星期六 早上9點 <br />\n立法會將會開會討論有關修訂 暫未知會否表決 <br />\n由於秘書處政變 原本由涂謹申主持會議改為石禮謙主持<br />\n<br />\n<span style=\"color: red;\">事態危急</span><br />\n一定要阻止立法<br />\n否則香港直送中國受審<br />\n到時中國話你犯咗中國法律 無需證據 無需理由<br />\n就可以光明正大係香港夾你返中國 <br />\n坐黑獄 洗你腦<br />\n<br />\n<br />\n<span style=\"color: red;\">此修例禍害大於23條立法<br />\n23條&gt;&gt;&gt;(需危害國家安全，香港審判，香港監禁)<br />\n<br />\n修訂逃犯條例 &gt;&gt;&gt;(莫需有，中國政府可任意控告香港人任何罪行，香港會配合執法將你拘捕，移交中國審判及監禁，無需證據 無需理由)</span></span></strong>"},{"pid":"ab79640c5dcda7f66bd6a08f48f390d42f20dcf2","tid":1141021,"uid":63177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-06T11:35:00.000Z","msg":"跟團點都要去幾個購物點<br />\n無論跟邊間都要去<br />\n最多貴團咪去少1個半個"},{"pid":"2fc9474ffec22e45c15831729c714fa6f6d69cd3","tid":1141021,"uid":79410,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-05-06T11:39:34.000Z","msg":"埋單連小費4100. 呢個價有購物時間有幾奇. <br />\n你報名有冇講名唔要有購物時間, 要純玩團呀?"}]}