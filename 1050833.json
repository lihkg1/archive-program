rmal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"cce8370f4514ef7972e88eb47991122736d1bfc4","tid":1050833,"uid":45376,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-07T08:39:19.000Z","msg":"支那本身就係想借呢次機會黎確立可以引渡班有錢撚返去然後掠水<br />\n豁條毛咩"},{"pid":"aca1d6087e184ff953f7495be7fefdd84bdd5b29","tid":1050833,"uid":63154,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-03-07T08:39:24.000Z","msg":"商界太天真，共產黨眼中先唔在乎殺人罪，人命好閒咋，經濟犯罪正正先係中共想做嘅，因為容易屈呀<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"4b780dd8e4c733441739c9a5bb017c635aa90f2f","tid":1050833,"uid":55597,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-07T08:43:03.000Z","msg":"做咩唔係大灣區？"},{"pid":"becfee27fe12c33e07534ea654990bf0af6f49a1","tid":1050833,"uid":65406,"like":3,"dislike":0,"score":3,"quote":{"pid":"d6fbd5a213e94f2dc92860398edf849d60870f6e","tid":1050833,"uid":166474,"like":3,"dislike":0,"score":3,"quote":{"pid":"dae023ae7e89d60dca969a6389bbfc12a5f3c1ec","tid":1050833,"uid":28435,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-03-07T07:10:45.000Z","msg":"大陸要入你，無犯過罪都可以入啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-07T08:38:37.000Z","msg":"除非完全冇番過大陸，桂民海夠話佢十幾年前醉駕撞死人番去自首啦，大陸要做假證據易如反掌<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-07T08:43:31.000Z","msg":"信共產黨既人，一定無睇過零零柒。<br />\n仲有成日話香港法院可以&rdquo;把關&rdquo;。<br />\n中共話田少起東莞非禮阿婆，香港既官點判斷中共講大話定田少講大話?咪又要信公安比既證據"},{"pid":"5cf9f940cfc7e98030a95ffb1fc6ab1fcb1a6474","tid":1050833,"uid":42304,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-07T08:48:30.000Z","msg":"班友驚取消獨立關稅區，冇晒油水<br />\n打工仔邊會明"},{"pid":"77bb5347876fc4de808f3f17837064c55917942a","tid":1050833,"uid":6752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-07T08:48:38.000Z","msg":"講到台灣會ok咁<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"590d12365b9092d579f71699e4606ebb9db6ba9e","tid":1050833,"uid":148332,"like":1,"dislike":1,"score":0,"quote":{"pid":"b77b1df53e1f2e51ba818cc2879ace378371a8bd","tid":1050833,"uid":39464,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-07T06:59:44.000Z","msg":"<img src=\"https://cdn.thestandnews.com/media/photos/cache/tien-09_YPyMP_1200x0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2Ftien-09_YPyMP_1200x0.png&h=48bef627&s={SIZE}\" /><br />\n<br />\n保安局籍本港少女在台被殺案，建議修訂《逃犯條例》，容許以「個案形式」，與過百個包括中國在內，未有簽署移交逃犯協議的國家或司法管轄區，可以逐次商討引渡疑犯；估計政府會在暑假前把修訂案送立法會表決。雖然建制派力陳修訂條例只是處理漏洞，不會被濫用，但近日具商界背景的自由黨前主席田北俊、黨魁鍾國斌，及實政圓桌立法會議員田北辰都分別指，商界對修訂條例涉及經濟罪行有保留及擔心，建議先將經濟罪行剔除，讓謀殺等嚴重刑事罪行「先行先試」。<br />\n<br />\n根據政府上月呈交予立法會保安事務委員會的文件，建議中修訂的《逃犯條例》仍然會涵蓋在法例附表中列的 46 項嚴重罪行，獲轄免的只有違反「一罪兩審」原則的案件、涉及政治性質罪行、因種族、宗教、國籍或政治意見而被檢控罪行，以及未獲保證不判處死刑的引渡請求。<br />\n<br />\n可引渡罪行三分一涉經濟犯罪<br />\n<br />\n《逃犯條例》附表一中所羅列的罪行，有多達最少 15 項和經濟罪行有關，由洗黑錢，到走私，甚至頗為空泛的「與財政事宜、課稅或關稅有關的罪行。」都包括。（值得一提，重婚亦是可引渡罪行之一）自由黨黨魁鍾國斌在接受《蘋果日報》訪問時，指兩地法制差異，加上可移交範圍包括的經濟罪行空泛，舉例經找換店匯錢都會誤墮法網。<br />\n<br />\n他指不少商界人士向他表達對修改逃犯條例的憂慮，又以去年有港人經找換店匯款到內地被指洗黑錢，「可能咁就中咗㗎啦，中咗非法匯錢，甚至乎嚴重啲講緊影響國家金融體系都可以」，小事可被化大。他亦指即使被移交人士可循法院上訴，但當中或涉及大量時間及金錢，非一般中小企能負擔。不過他表明，因修訂源於香港少女在台被殺案，即使當局不修正，都「必定要支持」。<br />\n<br />\n據《星島日報》周初的報道，保安局局長李家超上周曾「與個別代表商界的政黨」會晤，該黨中人向李家超提出，縮減《逃犯條例》中 46 種罪行的類別，只包含附表中前 7 項，即謀殺或誤殺、協助教唆他人自殺、惡意傷人或殘害他人、性罪行、對兒童的性罪行、綁架拐帶及非法禁錮，以及刑事恐嚇。而包括欺詐、盜用公款、貪污、知識產權、破產等經濟罪行則被剔除。<br />\n<br />\n星島：商界政黨建議只保留頭七項嚴重罪行<br />\n<br />\n《星島》引述指，商界不單只擔心觸犯內地商業糾紛或經濟罪行而被引渡，更指可能影響內地富豪來港購置物業，損害香港的豪宅巿場。不過，報道指李家超對縮減罪行的要求並不認同。<br />\n<br />\n自由黨榮譽主席田北俊今早出席 now 新聞台節目《時事全方位》時指，商界起初對修例無異議，但修例細節才顯示包含 46 項罪行，「只有頭幾樣係殺人放火標參」，而大部份和香港有引渡協議的國家，「法治概念同執行方法同香港相似」，但內地的執法則不然。他指自回歸後商界和內地關係密切，「講開人人自危」。<br />\n<br />\n田北俊認為，政府可將相關經濟罪行剔除，「不如只係針對嗰十項八項罪行去做，咁商界擔心就會少啲」。田少更指中港司法制度不同，自己甚少聽聞在內地與政府打官司會贏，「如果（商界）同內地省、市政府打官司，會贏咩？」<br />\n<br />\n田二少：內地好多稅又成日改　有時有無妄之災<br />\n<br />\n田北俊的弟弟、身兼港區人大代表的實政圓桌立法會議員田北辰在北京亦指出，內地稅務法規朝令夕改，商界憂慮合理，「好多人一早入咗去（內地）呢，果陣時稅務又唔清楚，你話就算今日，稅都唔知係咪交足啦！（內地）好多好多稅吖嘛，又成日改喎，有時係無妄之災，你又唔知，商界憂慮係啱。所以你話如果商業罪案唔計呢，我都覺得政府都應該諗下，因為依家（內地）入面果啲條例日日變，係好亂，我都搞唔清楚。」<br />\n<br />\n美國商周一就修例向保安局提交意見書，對修例表示「極之保留」（serious reservations）。商會指修例對香港作為亞洲國際城市，以及國際商業中心有明顯影響（significant implications）。商會又指對這項極複雜及重要議題，公眾諮詢只有很少時間，商會甚至未能完全地研究以及諮詢會員意見，但商會都希望表達基本立場及憂慮。<br />\n<br />\n法政匯思召集人吳宗鑾今早在商台節目《在晴朗的一天出發》中表示，美國商會鮮有就政治議題發聲，但今次亦就《逃犯條例》修例表達憂慮，相信意見會有一定影響力。至於可否把經濟罪行剔除，吳宗鑾認為不可行，認為會失去《逃犯條例》的立法原意，而且當權者亦可把政治罪行包裝成兇殺案，把涉事人士移交。<br />\n<br />\n<a href=\"https://thestandnews.com/politics/開始識驚-田氏兄弟偕鍾國斌忽發功-倡-逃犯條例-修訂剔除經濟罪行/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%E9%96%8B%E5%A7%8B%E8%AD%98%E9%A9%9A-%E7%94%B0%E6%B0%8F%E5%85%84%E5%BC%9F%E5%81%95%E9%8D%BE%E5%9C%8B%E6%96%8C%E5%BF%BD%E7%99%BC%E5%8A%9F-%E5%80%A1-%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B-%E4%BF%AE%E8%A8%82%E5%89%94%E9%99%A4%E7%B6%93%E6%BF%9F%E7%BD%AA%E8%A1%8C%2F&d=m7n5JD7ZMd19sx07z0x1QFlsl4SrcEEyWLual4COuMU%3D&h=029ea4ec\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%E9%96%8B%E5%A7%8B%E8%AD%98%E9%A9%9A-%E7%94%B0%E6%B0%8F%E5%85%84%E5%BC%9F%E5%81%95%E9%8D%BE%E5%9C%8B%E6%96%8C%E5%BF%BD%E7%99%BC%E5%8A%9F-%E5%80%A1-%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B-%E4%BF%AE%E8%A8%82%E5%89%94%E9%99%A4%E7%B6%93%E6%BF%9F%E7%BD%AA%E8%A1%8C%2F&h=eabeb18f\" target=\"_blank\">https://thestandnews.com/politics/開始識驚-田氏兄弟偕鍾國斌忽發功-倡-逃犯條例-修訂剔除經濟罪行/</a>"},"citedBy":0,"replyTime":"2019-03-07T09:01:14.000Z","msg":"桂民海都無啦啦酒駕撞死人，求其比條殺人罪你根本唔難<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"4f6371954ef7e1760cd2b58ed3ac84da69e073a3","tid":1050833,"uid":47359,"like":3,"dislike":0,"score":3,"quote":{"pid":"c4253b009189e940c81c62f8f5d60bb8a2b4e2b2","tid":1050833,"uid":57376,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-03-07T07:44:08.000Z","msg":"其實諗下都知班有錢人最後一定無事<br />\n拉嘅永遠都係平民"},"citedBy":0,"replyTime":"2019-03-07T09:04:18.000Z","msg":"肖建華<br />\n谷卓恆"},{"pid":"752c3a8cb1928454d41b6bb23d0df7ebbcdb