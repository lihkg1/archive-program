e=\"color: gold;\">[同我推晒佢] 力抗膠post 621行動討論整合<br />\n<a href=\"https://lih.kg/1242813\" data-auto-link target=\"_blank\">https://lih.kg/1242813</a></span></span>"},{"pid":"1dcce70e213fc2e826c2630a26a4dbbc386eba13","tid":1242381,"uid":49302,"like":3,"dislike":0,"score":3,"quote":{"pid":"c27fe6bc2168d90510b5d53c6d89c3d3dee04b83","tid":1242381,"uid":53122,"like":5,"dislike":1,"score":4,"citedBy":1,"replyTime":"2019-06-19T04:51:46.000Z","msg":"你同班連登仔講李德哈特會唔會對牛彈琴"},"citedBy":0,"replyTime":"2019-06-19T12:46:59.000Z","msg":"其實咪四個字: 避實擊虛 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"86efeb04a46746b80cbad773f54f90f48c118c2b","tid":1242381,"uid":161626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T13:05:47.000Z","msg":"推"},{"pid":"7b34315ce4ccd98768ff54f34753bb505038df22","tid":1242381,"uid":264994,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T14:45:35.000Z","msg":"推"},{"pid":"54714699ae332156a16a145e3f95e40966819a18","tid":1242381,"uid":55511,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-19T15:06:12.000Z","msg":"冇估錯既話條友是咪普魯士人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c3010b02bd81ddc4579c0c86bd4e1775598b31ba","tid":1242381,"uid":262677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T15:42:27.000Z","msg":"推"},{"pid":"a56c5f4514baea88501a919f63727da5da61bec4","tid":1242381,"uid":10679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T16:10:26.000Z","msg":"推"},{"pid":"119d2d87dd3223476779b3113c19168f328a17c7","tid":1242381,"uid":259928,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T20:41:04.000Z","msg":"推"},{"pid":"3570a927f692ce2961e1f8bab0de4f67d8cf9b2a","tid":1242381,"uid":53122,"like":0,"dislike":0,"score":0,"quote":{"pid":"54714699ae332156a16a145e3f95e40966819a18","tid":1242381,"uid":55511,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-19T15:06:12.000Z","msg":"冇估錯既話條友是咪普魯士人<img src=\"