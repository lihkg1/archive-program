normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-13T15:10:47.000Z","msg":"我啊媽大陸落黎 小學未畢業 黃到仆街<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> 日日喊到收唔到 又屌狗"},{"pid":"545f86d64c90bb523035f88c6bcaf6c58d3f99d8","tid":1717274,"uid":328100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T15:13:20.000Z","msg":"我老豆，小學程度，極深黃，日日屌林奠<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"ce4cb5f6b8aa93ab4ad9e742c709e22040854de5","tid":1717274,"uid":190043,"like":0,"dislike":0,"score":0,"quote":{"pid":"060c4ed1c150d5141fbcac99426a3dd6896064e7","tid":1717274,"uid":193217,"like":0,"dislike":0,"score":0,"quote":{"pid":"ac362dfe76f7e3831a9322399da347928d936940","tid":1717274,"uid":190043,"like":0,"dislike":0,"score":0,"quote":{"pid":"4c5b8fc296167bf823bccd85de45e0b08da7925d","tid":1717274,"uid":53853,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-11-13T14:47:08.000Z","msg":"我老豆老母唔高學歴，但係屋企當年文革搞到好慘而長期深黃"},"citedBy":2,"replyTime":"2019-11-13T15:01:27.000Z","msg":"將黃字改成藍/紅<br />\n就係我屋企"},"citedBy":1,"replyTime":"2019-11-13T15:04:08.000Z","msg":"所以我成日唔明呢堆人到底唸乜<br />\n連民革都經歷過.都仍然會變藍<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-13T15:15:45.000Z","msg":"佢哋話中共繁榮就係改緊<br />\n唔好問我邊撚到繁榮<br />\n唔駛明佢哋諗咩<br />\n因為唔會明<br />\nChinazi係最好<br />\n冇得解釋<br />\n<br />\n話示威者唔比港共改嘅機會<br />\n好撚小氣<br />\n睇cctvb係咁上下<br />\n所以人一藍就腦殘冇講錯<br />\n佢哋只會睇一層示威 亂<br />\n唔撚得<br />\n其他黑警港共賣港唔撚理"},{"pid":"6386ba8f1f47fc0242dea6e6d34bf7bd3bd46e95","tid":1717274,"uid":323582,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T15:16:13.000Z","msg":"係有冇良心有冇腦嘅問題<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"97f5720f602f08a8f2788fe6215c3fbbdd39b20d","tid":1717274,"uid":96794,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T15:24:11.000Z","msg":"唔關事啦！我呀爸呀媽高中同初中畢業中到深黃..<br />\n婆婆字都唔識深黃<br />\n<br />\n反而美加讀書嘅朋友深藍 9到乜咁"},{"pid":"98553f6ebe7e09ead4c696ce9f769e90368eed51","tid":1717274,"uid":234459,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T15:26:04.000Z","msg":"唔關事，我老母phd照藍<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"6be617e0824a52d3423baa8408a26da33bd63745","tid":1717274,"uid":265521,"like":0,"dislike":0,"score":0,"quote":{"pid":"4ad2fc8a1760f6cfd3cb96152403a3ac6d194136","tid":1717274,"uid":193217,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-13T14:34:18.000Z","msg":"而低學歷既就大部份藍<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n好似我老母為例.考大學時受到四人幫控制<br />\n連考試都係考住書黎考.佢講返比我聽.搞到唔想考<br />\n但到今日都居然話大陸非常好<br />\n呢種人大部份係因為比親戚茶毒<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />好似我老母為例<br />\n同佢地講道理真係晒氣<br />\n好彩既係佢無極端到見人就屌班細路<br />\n但次次佢一嘈.我就廢時同佢講野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-13T15:29:11.000Z","msg":"不如話高學歷嘅人通常係黃絲，低學歷嘅人通常藍絲。"},{"pid":"79ebf167e8a9ebb2b1923820282d632f3440e129","tid":1717274,"uid":259489,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T15:31:13.000Z","msg":"大把公司高層都藍到扑街啦"},{"pid":"8cd86bca5ae4f784347d87f3a86152c2c88b5f95","tid":1717274,"uid":319824,"like":0,"dislike":0,"score":0,"quote":{"pid":"9dbe8ccda06496007f5bbfda9cec636ee4b3e24c","tid":1717274,"uid":305009,"like":0,"dislike":0,"score":0,"quote":{"pid":"08ab3744ef07f10d421f9d054bee7d0cd6f572dd","tid":1717274,"uid":165682,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-11-13T14:39:51.000Z","msg":"老豆: 大學 淺黃 最中意屌林鄭<br />\n老母: 小學 中立/淺藍 唔中意暴力 覺得好冇人性<br />\n<br />\n利申: 點都不割 我愛佢地"},"citedBy":1,"replyTime":"2019-11-13T14:42:09.000Z","msg":"我奉行孝之有理,我好想割兩老但係冇力割<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />最近又見到勁多負面新聞,佢哋從來唔覺得警察有錯<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-13T15:32:45.000Z","msg":"我老母見到有手足比狗開槍射：抵啦 射死哂就啱<br />\n睇到叔一燒：陰公囉 咁樣比人燒法<br />\n之後仲屌鳩林鄭廢 唔夠強硬<br />\n利申 學生哥 冇經濟能力 冇本錢割席 每日都好辛苦<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" />"}]}