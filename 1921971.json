"tid":1921971,"uid":246289,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d4af7fda8d1437243529a2ff55ee15ced357d0c","tid":1921971,"uid":314767,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-17T13:52:52.000Z","msg":"#3 <span style=\"color: red;\">佢哋/他們</span>發現(佢們)"},"citedBy":1,"replyTime":"2020-03-17T14:00:15.000Z","msg":"你自己計分啦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n勁喎<br />\n咁都見到<br />\n你逐隻字咁睇㗎<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-17T14:02:24.000Z","msg":"係啊 咁樣會投入啲 仲可以幻想埋個情景出嚟<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-17T14:11:28.000Z","msg":"我都會咁做嘅<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n<br />\n不過點都冇<br />\n你兩個癲佬 <br />\n睇得咁仔細囉<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"e4187b452091d39a303c9dd89686a2d8a26e2ac9","tid":1921971,"uid":314767,"like":0,"dislike":0,"score":0,"quote":{"pid":"f3c202e5e50825c0ba4afb814cb6b13ffa19704b","tid":1921971,"uid":246289,"like":0,"dislike":0,"score":0,"quote":{"pid":"73e84eb7ea119f7762607b4201185d7f04dd3e09","tid":1921971,"uid":314767,"like":1,"dislike":0,"score":1,"quote":{"pid":"7d1519d5d452e44b51c422cee4aa6b00e088b63d","tid":1921971,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-17T14:00:15.000Z","msg":"你自己計分啦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n勁喎<br />\n咁都見到<br />\n你逐隻字咁睇㗎<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-17T14:02:24.000Z","msg":"係啊 咁樣會投入啲 仲可以幻想埋個情景出嚟<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-17T14:11:28.000Z","msg":"我都會咁做嘅<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n<br />\n不過點都冇<br />\n你兩個癲佬 <br />\n睇得咁仔細囉<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-17T14:16:49.000Z","msg":"我第一次都睇唔到嫁 係啱啱爬文諗住搵返科學家個異能係咩 跟著先比我發現到咋"},{"pid":"f47f76106f51fe9332e8936eda2992d1f7a0e820","tid":1921971,"uid":206998,"like":1,"dislike":0,"score":1,"quote":{"pid":"5d4af7fda8d1437243529a2ff55ee15ced357d0c","tid":1921971,"uid":314767,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-17T13:52:52.000Z","msg":"#3 <span style=\"color: red;\">佢哋/他們</span>發現(佢們)"},"citedBy":0,"replyTime":"2020-03-17T15:01:09.000Z","msg":"因為本身係書面語稿，改得夠唔仔細<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"85969f8e7fddfd25dc80090bbf8b755fff7e04b0","tid":1921971,"uid":314767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-22T20:42:03.000Z","msg":"肥巴呢？"},{"pid":"1129a54dc36b7d02d8aeeed8f0e480e0644ecf82","tid":1921971,"uid":206998,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T06:09:55.000Z","msg":"第四話：<br />\n<br />\nA：有一個人坐咗係到<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n除咗神秘莫測的星系圖之外，仲有個人坐咗係張凳上面背對住我哋，我睇唔到佢嘅樣，亦唔知佢係到做緊咩，我同夏娃相望咗一眼，舉起雙手進入備戰狀態，慢步走向嗰個人嘅同時，出言試探：<br />\n<br />\n「我係銀河系亞夫星球嘅最強人造人亞當，你依家身處隸屬於亞夫星球嘅人造小衛星伊甸園上面，我依家執行緊探索任務，請你保持冷靜同配合我地，唔好嘗試反抗。」<br />\n<br />\n聲音係房間入面傳遞，傳嚟陣陣回音，但我卻得唔到任何嘅回應。<br />\n<br />\n緊張嘅局勢令我沉住氣，繼續步步進逼。<br />\n<br />\n直到我走到佢位置隔離嘅時候，佢依然一無所動，冇發出半點聲響，亦冇移動過半分。<br />\n<br />\n我感覺到事件嘅唔尋常，深呼吸，望咗望佢...<br />\n<br />\n點知係...<br />\n<br />\n灰白淡色、晶瑩剔透嘅...<br />\n<br />\n一副完整嘅人體骨架。<br />\n<br />\n原來係一副披住衣服嘅骨頭，難怪佢一直冇回應，因為死人又點會識講嘢呢。<br />\n<br />\n真相大白後，我仔細咁打量一番，發現骨架死前嘅姿勢別有洞天。<br />\n<br />\n佢雙腳盤坐於凳上，雙手輕放係大腿骨之上，一手張開五指朝地，另一手握蓮花之指向天；骨頭雖然披上厚厚灰塵，但依然無阻我觀察；骨架粗大，生前最少有兩米之高；雖然已過萬載，但骨頭依舊屹立不倒，似係有種不得不完成嘅決意。<br />\n<br />\n我應該...<br />\n<br />\nA：搜索衣服<br />\n<br />\nB：搜索房間<br />\n<br />\nC：飲酒定驚<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n十二點截止，票多者勝。"},{"pid":"50bfbc41519e4b05f106482047afc94c860c8d4e","tid":1921971,"uid":206998,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-03-28T06:14:27.000Z","msg":"因為工作關係，寫文嘅時間大幅減少，而我想主力寫《再一次抗爭》先，大家會唔會想我定期更新呢篇文，但係每篇嘅字數減少，等我可以忙裡偷閒，每日攞搭車休息嘅時間寫文。<br />\n<br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />：密而短<br />\n<br />\n<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />：梭而長"},{"pid":"405dae0b74a38a208ed43b5ab92e2a99cad1e7b5","tid":1921971,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T10:16:05.000Z","msg":"C<img src=\"/assets/faces/lm2/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"f26776a7be1cb677d029c2a58dfb0887e7a80a4e","tid":1921971,"uid":297436,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T15:17:45.000Z","msg":"&nbsp;C<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"5f22cf4b7fd7493d72e95dab642b0c192a26f3d7","tid":1921971,"uid":314767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-29T12:11:51.000Z","msg":"C"},{"pid":"d0cf17c7550b4744e7b6dd7c3427fc6e591b0e2b","tid":1921971,"uid":314767,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-29T12:12:53.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" /><br />\n我決定比肥巴自己揀"}],"pinned":{"pid":"50bfbc41519e4b05f106482047afc94c860c8d4e","tid":1921971,"uid":206998,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-03-28T06:14:27.000Z","msg":"因為工作關係，寫文嘅時間大幅減少，而我想主力寫《再一次抗爭》先，大家會唔會想我定期更新呢篇文，但係每篇嘅字數減少，等我可以忙裡偷閒，每日攞搭車休息嘅時間寫文。<br />\n<br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />：密而短<br />\n<br />\n<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />：梭而長"}}