/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"72989660795c6d406266fac2130274f34653373c","tid":876622,"uid":92908,"like":3,"dislike":57,"score":-54,"citedBy":0,"replyTime":"2018-10-25T17:58:43.000Z","msg":"其實ot冇乜問題，但最老尷係條女話要接收工，有時真係唔知叫佢走先定等埋好<br />\n所以成日見d女，開post屌男友話咩唔比你接佢收工，其實係唔想你等，只不過口硬，話你阻住曬姐"},{"pid":"7747bf187343bedf56537f26820c9caeaa786d94","tid":876622,"uid":193601,"like":101,"dislike":0,"score":101,"citedBy":1,"replyTime":"2018-10-25T17:59:32.000Z","msg":"完全唔知關你女友咩事<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5cd34b2dd7441b92432d0c3dcc2bfbbecad9d4ac","tid":876622,"uid":2959,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2018-10-25T17:59:46.000Z","msg":"咩老闆黎<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"ee52f598ec6ac463f3572df0d431a5e4ba202d1b","tid":876622,"uid":2959,"like":101,"dislike":2,"score":99,"quote":{"pid":"7747bf187343bedf56537f26820c9caeaa786d94","tid":876622,"uid":193601,"like":101,"dislike":0,"score":101,"citedBy":1,"replyTime":"2018-10-25T17:59:32.000Z","msg":"完全唔知關你女友咩事<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-25T18:00:28.000Z","msg":"樓豬只係想囇女同有個好老闆"},{"pid":"0eb8ca87794504c5d9caa24906d2244eba0713cd","tid":876622,"uid":143288,"like":196,"dislike":1,"score":195,"citedBy":4,"replyTime":"2018-10-25T18:01:55.000Z","msg":"睇極都睇唔明個重點喺邊"},{"pid":"2ca455b7dddf997c7357879480da07a8bf0f98c3","tid":876622,"uid":143288,"like":73,"dislike":0,"score":73,"quote":{"pid":"0eb8ca87794504c5d9caa24906d2244eba0713cd","tid":876622,"uid":143288,"like":196,"dislike":1,"score":195,"citedBy":4,"replyTime":"2018-10-25T18:01:55.000Z","msg":"睇極都睇唔明個重點喺邊"},"citedBy":0,"replyTime":"2018-10-25T18:02:54.000Z","msg":"有幾撚冷暖幾撚險惡<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"a0994ab9e2871642