GqeW%2Bx3Iou9iuErJt32EjuWI86Zw%3D&h=f82ea1f4\" target=\"_blank\">https://www.db-fiddle.com/f/dSVUVZMe5fbFBorzSUUCFz/3</a><br />\n<pre><code data-type=\"sql\">SELECT TABLE_A.A\nFROM TABLE_A\n\tINNER JOIN TABLE_B ON TABLE_A.B = TABLE_B.B\nGROUP BY TABLE_A.A\nHAVING COUNT(DISTINCT(TABLE_A.B)) &gt; 1 and\n    COUNT(TABLE_B.C) &gt; 0 and\n    SUM(CASE WHEN TABLE_B.C IS NULL THEN 1 ELSE 0 END) &lt; 2</code></pre>"},{"pid":"4242be3f1181b3776aca88e5a26b39a5c76f0d99","tid":905271,"uid":213607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-17T05:40:49.000Z","msg":"<a href=\"https://www.db-fiddle.com/f/36yk27AdB9cW34KDgPpzrQ/1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.db-fiddle.com%2Ff%2F36yk27AdB9cW34KDgPpzrQ%2F1&d=uYzQBpRLOc79lpwGqeW%2Bx3Iou9iuErJt32EjuWI86Zw%3D&h=f737f02e\" target=\"_blank\">https://www.db-fiddle.com/f/36yk27AdB9cW34KDgPpzrQ/1</a><br />\n唔該各位 有神人幫我咁樣鄧梓峰左<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"d743074bb67f8e27f423e93c415e8d834da09729","tid":905271,"uid":148135,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-17T05:44:39.000Z","msg":"<img src=\"https://na.cx/i/xXoThv0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxXoThv0.png&h=f47905d0&s={SIZE}\" /><br />\nSELECT * From TABLE_A INNER JOIN TABLE_B ON TABLE_A.B = TABLE_B.B <br />\nAND NOT EXISTS (SELECT * From TABLE_B WHERE B IS NULL AND C IS NULL) <br />\nAND (TABLE_A.A = TABLE_A.B OR TABLE_A.A = TABLE_B.C);<br />\n<br />\n係咪咁??"},{"pid":"441c48a91749b21b892d0ab8d4782f30334ec53c","tid":905271,"uid":148135,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-17T05:52:50.000Z","msg":"SORRY 自膠<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"dcd84812feeaba16de20dba47ad6f76923309582","tid":905271,"uid":213607,"like":0,"dislike":0,"score":0,"quote":{"pid":"8106eb3b9391d8c43efcc1f62e6f37222dc6bba0","tid":905271,"uid":23953,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-17T05:38:29.000Z","msg":"自膠<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"https://www.db-fiddle.com/f/dSVUVZMe5fbFBorzSUUCFz/3\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.db-fiddle.com%2Ff%2FdSVUVZMe5fbFBorzSUUCFz%2F3&d=uYzQBpRLOc79lpwGqeW%2Bx3Iou9iuErJt32EjuWI86Zw%3D&h=f82ea1f4\" target=\"_blank\">https://www.db-fiddle.com/f/dSVUVZMe5fbFBorzSUUCFz/3</a><br />\n<pre><code data-type=\"sql\">SELECT TABLE_A.A\nFROM TABLE_A\n\tINNER JOIN TABLE_B ON TABLE_A.B = TABLE_B.B\nGROUP BY TABLE_A.A\nHAVING COUNT(DISTINCT(TABLE_A.B)) &gt; 1 and\n    COUNT(TABLE_B.C) &gt; 0 and\n    SUM(CASE WHEN TABLE_B.C IS NULL THEN 1 ELSE 0 END) &lt; 2</code></pre>"},"citedBy":1,"replyTime":"2018-11-17T06:01:25.000Z","msg":"巴打你呢個都<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 不過我個case<br />\n<pre><code data-type=\"\">SELECT t1.A\nFROM t1 JOIN t2 ON t2.B = t1.B\nGROUP BY t1.A\nHAVING COUNT(t1.B) &gt; 1 and\n    SUM(CASE WHEN t2.C IS NOT NULL THEN 1 ELSE 0 END) &gt; 0</code></pre><br />\n就可以了"}]}