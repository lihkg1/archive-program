eddf66aa31f558aa5e5402","tid":1756904,"uid":301479,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T12:16:38.000Z","msg":"push"},{"pid":"a6c42d3bf5c1b22e38ee20d1ac826b5fcea52d4e","tid":1756904,"uid":164761,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T12:19:21.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c8559004be719b97252c4d17053a5bfdf2806abd","tid":1756904,"uid":265066,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T12:19:57.000Z","msg":"<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"37d2658e6f7e584e5d4382e78d5d2c27bf0d7bc6","tid":1756904,"uid":42122,"like":0,"dislike":0,"score":0,"quote":{"pid":"6695c8f94a9a6bda615d4c614270d342601df68e","tid":1756904,"uid":60200,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-26T08:58:20.000Z","msg":"推到荷蘭叻入制裁名單<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://news.ltn.com.tw/news/world/breakingnews/2987710\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F2987710&d=%2BSgL3cCD37R2%2BMUJ9ALV01KEWDR5zjN73Co06CeqttY%3D&h=f5d85ae4\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F2987710&h=9c19bfe4\" target=\"_blank\">https://news.ltn.com.tw/news/world/breakingnews/2987710</a><br />\n荷蘭議會通過議案：禁止違反人權的人士入境<br />\n<br />\n〔即時新聞／綜合報導〕繼美國參眾兩院通過《香港人權與民主法》後，荷蘭議會於昨（22）日以95比54通過一項議案，要求荷蘭政府必須於2020年1月31日前實施荷蘭版本的《馬格尼茨基人權問責法》（Magnitsky Act）。<span style=\"color: red;\">未來該法案將禁止違反人權者，包括香港、中國、俄羅斯等地的人士入境荷蘭，並且凍結他們的資產。<br />\n</span><br />\n荷蘭著名基金管理人、全球「馬格尼茨基司法運動」負責人布勞德（Bill Browder）在推特上透露，「荷蘭議會以95比54通過一項決議，要求荷蘭政府在2020年1月31日前開始實施荷蘭版《馬格尼茨基人權問責法》。」<br />\n<br />\n綜合媒體報導，根據該項甫通過的決議，<span style=\"color: red;\">荷蘭政府將設立一份違反人權者的名單，而即將實施的人權問責法案將禁止名單上違反人權或貪腐的各別人士入境，並予以凍結資產</span>。根據法案提案人舍爾德馬（Sjoerd Sjoerdsma）在推特上轉推的報導，《馬格尼茨基法案》起於俄羅斯律師馬格尼茨基（Sergei Magnitsky），因在俄國發現了大規模的稅務欺詐，於2009年在莫斯科的一個牢房中去世。<br />\n<br />\n繼美國參議院2015年12月17日通過了《馬格尼茨基人權問責法》，目前英國、加拿大、愛沙尼亞、拉脫維亞、立陶宛及直布羅陀等6個國家已經通過了類似的法案，而歐盟、澳洲、法國、瑞典也正在審議相關法案。"},"citedBy":0,"replyTime":"2019-11-26T12:28:45.000Z","msg":"唉，香港而家同中俄齊名。"},{"pid":"8cd32087eddfab7ac04646677ebad35846341c61","tid":1756904,"uid":61020,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T12:31:37.000Z","msg":"荷蘭正"},{"pid":"90a9711a441701b02a0bd13b5be18e7d0e3c111f","tid":1756904,"uid":73893,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T12:34:24.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"cde6e42c4841bb56141666535bab87cd26248837","tid":1756904,"uid":124983,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T12:41:53.000Z","msg":"繼美國之後最重要戰線<br />\n我要狗官全家以後不能踏足文明世界 返大灣區<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"68d78753e3f3079cedf5d3d8eb349c20def4c88c","tid":1756904,"uid":83557,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T12:51:33.000Z","msg":"push<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"71a1972859a04bab8910b53188538de24616cc08","tid":1756904,"uid":4180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T12:57:36.000Z","msg":"打破第一扇窗<br />\n以後陸續有黎<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"4069d1dd257939c18f0fbfeb6614ebdddfa58b1a","tid":1756904,"uid":137837,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-26T13:01:45.000Z","msg":"Holand yeah<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"4694ec232878bfa9834630a76e6655bdf2c21fe2","tid":1756904,"uid":8308,"like":0,"dislike":0,"score":0,"quote":{"pid":"205701a1577a53f7d8b38b9249e8364edeae7521","tid":1756904,"uid":40415,"like":0,"dislike"