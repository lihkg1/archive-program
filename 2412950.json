i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fd299RwP.png&h=7cd59633&s={SIZE}\" />"},{"pid":"f1aa340c951450a46d30d1f2fbe5ffd32e6e9e36","tid":2412950,"uid":42246,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-18T11:56:48.000Z","msg":"嬲到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a17938057a8f06fd65ed3bb63d5b371b71b492f5","tid":2412950,"uid":311626,"like":0,"dislike":0,"score":0,"quote":{"pid":"3e9c1d1ac724dd80a8327bc9d3ed4be6bf0587a5","tid":2412950,"uid":42246,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-18T10:39:36.000Z","msg":"足球熱話｜曼聯名宿堅尼自打嘴巴玩IG　貼文反高潮兩日獲百萬追蹤 <br />\n<br />\nHK01<br />\n<br />\n<br />\n球員時代已是話題人物的曼聯名宿堅尼，近日連開設Instagram個人帳戶都成為足球界焦點，這位昔日中場悍將在情人節出Post，引來球迷激烈討論。<br />\n<br />\n<span class=\"red\">一代曼聯鐵血隊長堅尼近年轉任評述員，在電視直播間不時批評保羅普巴等「紅魔」球員因沉迷社交網站而分心。不過這位曼聯名宿日前「自打嘴巴」，竟然在Instagram上開設個人帳户。</span><br />\n<br />\n堅尼的IG「惡搞」味甚濃，他以自己小時候的可愛照片做頭像，跟場上兇狠的他形成強烈對比。而他的第一個貼文便上載了自己跟愛犬的合照，並寫道：「人類最好的朋友」，盡顯男人的浪漫。<br />\n<br />\n這位前紅魔中場昨日情人節再「出招」，幽大家一默。他呼籲大家在情人節要向身邊人展示愛意，不過配圖卻令人意想不到：一張昔日他效力諾定咸森林時，跟韋斯咸球員史杜亞沙特（Stuart Slater）及比索（Ian Bishop）打架叉頸的相片，或者堅尼想說的是「打者愛也」？<br />\n<br />\n<br />\n這個貼文除了引來網民紛紛讚好，同屬「講波佬」的加歷查亦有留言，以4個「笑到喊」的表情符號回應；而阿仙奴名宿伊恩胡禮就讚堅尼出post「有一手」，並笑指對方「好難捉摸」<br />\n<br />\n堅尼「加盟」IG成為體壇熱話，雖然他未有「追蹤」任何人，但開戶短短兩日就已獲過百萬人「追蹤」。<br />\n<br />\n「追蹤者」除萬人迷碧咸等外國球星，香港首席桌球手傅家俊、香港羽毛球「一哥」伍家朗及港超理文中場顏樂楓等本地運動員也不例外<br />\n<br />\n<br />\n<br />\n<br />\n曼聯明叔就是這樣<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n成日自打嘴巴<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-18T12:02:39.000Z","msg":"開戰味"},{"pid":"2231561e47cd0a137ec7cb526861ec6b9690a3f0","tid":2412950,"uid":199804,"like":1,"dislike":0,"score":1,"quote":{"pid":"9813e3049c3c2322f746ae924b2b31f2a7bf7e8c","tid":2412950,"uid":67225,"like":24,"dislike":2,"score":22,"citedBy":4,"replyTime":"2021-02-18T11:48:05.000Z","msg":"而他的第一個貼文便上載了自己跟愛犬的合照，並寫道：「人類最好的朋友」，盡顯男人的浪漫。<br />\n<br />\n曼聯明叔（圖左），港毒之父（圖右）<br />\n<br />\n<img src=\"https://na.cx/i/d299RwP.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fd299RwP.png&h=7cd59633&s={SIZE}\" />"},"citedBy":0,"replyTime":"2021-02-18T12:16:16.000Z","msg":"秒左父<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"09607ac4cc469b9b9f013f1f6e01e4273f362c4f","tid":2412950,"uid":73381,"like":0,"dislike":0,"score":0,"quote":{"pid":"9813e3049c3c2322f746ae924b2b31f2a7bf7e8c","tid":2412950,"uid":67225,"like":24,"dislike":2,"score":22,"citedBy":4,"replyTime":"2021-02-18T11:48:05.000Z","msg":"而他的第一個貼文便上載了自己跟愛犬的合照，並寫道：「人類最好的朋友」，盡顯男人的浪漫。<br />\n<br />\n曼聯明叔（圖左），港毒之父（圖右）<br />\n<br />\n<img src=\"https://na.cx/i/d299RwP.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fd299RwP.png&h=7cd59633&s={SIZE}\" />"},"citedBy":1,"replyTime":"2021-02-18T12:18:09.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a80da787341e143f03f4a7d1151fd3ce56fbc0d8","tid":2412950,"uid":17606,"like":0,"dislike":0,"score":0,"quote":{"pid":"09607ac4cc469b9b9f013f1f6e01e4273f362c4f","tid":2412950,"uid":73381,"like":0,"dislike":0,"score":0,"quote":{"pid":"9813e3049c3c2322f746ae924b2b31f2a7bf7e8c","tid":2412950,"uid":67225,"like":24,"dislike":2,"score":22,"citedBy":4,"replyTime":"2021-02-18T11:48:05.000Z","msg":"而他的第一個貼文便上載了自己跟愛犬的合照，並寫道：「人類最好的朋友」，盡顯男人的浪漫。<br />\n<br />\n曼聯明叔（圖左），港毒之父（圖右）<br />\n<br />\n<img src=\"https://na.cx/i/d299RwP.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fd299RwP