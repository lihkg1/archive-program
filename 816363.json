363,"uid":52215,"like":11,"dislike":0,"score":11,"citedBy":2,"replyTime":"2018-09-12T16:45:42.000Z","msg":"失業最多返鄉下"},"citedBy":2,"replyTime":"2018-09-12T17:09:22.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/09/13/010921_8d95b445f407f3b6e3a8d27af972376b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F13%2F010921_8d95b445f407f3b6e3a8d27af972376b.jpg&h=009b1fb3&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-09-13T00:44:16.000Z","msg":"返鄉下幹革命<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"af0be2e2b2ac3986b3f56d8b69b6385664ac4ff0","tid":816363,"uid":20867,"like":0,"dislike":0,"score":0,"quote":{"pid":"c15447ac7b5dec4a5f70b5d6de865a70e9d34b84","tid":816363,"uid":19454,"like":10,"dislike":1,"score":9,"citedBy":1,"replyTime":"2018-09-12T17:13:06.000Z","msg":"<img src=\"http://imgs.ntdtv.com/pic/2017/3-12/p8058891a20099708.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimgs.ntdtv.com%2Fpic%2F2017%2F3-12%2Fp8058891a20099708.jpg&h=968cd01f&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-09-13T00:45:34.000Z","msg":"嚇鬼咩<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"037730effecfbd100954f389f6d7b0c6ad80312f","tid":816363,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-13T03:31:52.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"}]}