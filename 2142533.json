6b4a6fab23499b4fe9f","tid":2142533,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"b080e29843b7090d4cb0d8136cb44603e17f3737","tid":2142533,"uid":216344,"like":0,"dislike":1,"score":-1,"quote":{"pid":"99e5aada3fb89af9681e3e28fec36160502143d0","tid":2142533,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-06T12:55:42.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-06T12:57:49.000Z","msg":"<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-06T12:58:27.000Z","msg":"<img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-06T13:01:15.000Z","msg":"<img src=\"/assets/faces/dog/bark.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bark.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bark.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bark.gif\" class=\"hkgmoji\" />"},{"pid":"9c153f832d9878e86317fac1945b5e0f6dae0fc9","tid":2142533,"uid":36901,"like":86,"dislike":0,"score":86,"citedBy":1,"replyTime":"2020-08-06T13:01:48.000Z","msg":"日用品變軍火？港大講師化學名舉隅<br />\n<br />\n2016-02-22&nbsp;&nbsp;&nbsp;&nbsp;<br />\n<br />\n<br />\n今日（2月22日）較早時間，《壹》仔報導過，警方尋日喺天水圍天晴邨破門入屋拘捕「本土民主前線」發言人黃台仰時，聲稱於單位內檢獲「電磁炮」同化學品，不過有外界有指警方小題大造，例如「電磁炮」係可以喺淘寶以23蚊港紙買到嘅科學玩具、啲化學品其實都係日常用品可見。<br />\n<br />\n而港大理學院講師陳志宏博士更於Facebook「教路」，活用化學名稱：「在平常的生活之中，只需要多花一點點心思，家中隨時都可聽起來像個軍火庫啊」。<br />\n<br />\n警方尋日檢走「可疑化學品」時，有現場消息指，當中包括硝酸銨、二氧化硅等，而硝酸銨可用作製造炸藥；但陳志宏舉例，肥料、瀉藥及「吸濕大笨象」等常見用品，都可以講成「硝酸銨」、「聚乙二醇」和「二氧化硅」。而微波爐可叫「集束隱形輻射共振電磁束」、「攪拌機」升lv做「高強度合金漩渦鋒面」，而「光管」都可以叫「毫秒瞬時高壓燃點電磁波放射組件」等，問你驚唔驚。<br />\n<br />\n家居用品－＞名後<br />\n<br />\n松節水 ─＞ 易燃液體<br />\n肥料 ─＞ 硝酸銨<br />\n瀉藥 ─＞ 聚乙二醇<br />\n抽濕大笨象 ─＞ 二氧化硅<br />\nDVD機 ─＞ 微米激光破譯儀<br />\n攪拌機 ─＞ 高強度合金漩渦鋒面<br />\n除塵機 ─＞ 無定向離子附着裝置<br />\n微波爐 ─＞ 集束隱形輻射共振電磁束<br />\n光管 ─＞ 毫秒瞬時高壓燃點電磁波放射組件<br />\n<br />\n<a href=\"https://hk.nextmgz.com/article/2_358048_0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.nextmgz.com%2Farticle%2F2_358048_0&d=il%2BrReVPph3FBkDtfLAFOhyAur%2Bbp9MVyOkMM5%2FMxDY%3D&h=446e8d75\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.nextmgz.com%2Farticle%2F2_358048_0&h=c32eda70\" data-auto-link target=\"_blank\">https://hk.nextmgz.com/article/2_358048_0</a>"},{"pid":"f31a4beff6b5f56bdb19f27314226ef491d862df","tid":2142533,"uid":15084,"like":11,"dislike":0,"score":11,"citedBy":1,"replyTime":"2020-08-06T13:03:11.000Z","msg":"咁都要借啲2拉去香港到？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n警狗啲PR真係"},{"pid":"00c71d5471c10a7d872b51c5cf2e807a559b2b31","tid":2142533,"uid":222524,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-08-06T13:03:17.000Z","msg":"人地炸到有蘑菇雲，香港？"},{"pid":"020f6123e1698f60288385873a0f486b779418fe","tid":2142533,"uid":290118,"like":33,"dislike":1,"score":32,"citedBy":0,"replyTime":"2020-08-06T13:04:21.000Z","msg":"拎人哋不幸嚟抽水，呢班垃圾真係早日死咗去啦"},{"pid":"10e96e81897ac61782cbd8db1f51d158a59b92ad","tid":2142533,"uid":183844,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2020-08-06T13:04:33.000Z","msg":"cls關你撚事咩死黑警"},{"pid":"862f42fd3122c3ffc6fd26ee211b79e6b8e22495","tid":2142533,"uid":284855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T13:04:35.000Z","msg":"毅進仔教化學？"},{"pid":"cda28e11d3eb184baa8a59628040