ts/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"b3d6454c0f35586478cffc00ad2c5652d21c9114","tid":2142533,"uid":343361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T14:32:04.000Z","msg":"此回覆已被刪除"},{"pid":"2172451be79be2a891b11b55fc3513053ee57f71","tid":2142533,"uid":295735,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-06T14:33:02.000Z","msg":"幾時拉日本城負責人？"},{"pid":"797b83627b03a6fcfffb9d6df8071cb7649660dc","tid":2142533,"uid":51271,"like":0,"dislike":0,"score":0,"quote":{"pid":"2172451be79be2a891b11b55fc3513053ee57f71","tid":2142533,"uid":295735,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-06T14:33:02.000Z","msg":"幾時拉日本城負責人？"},"citedBy":0,"replyTime":"2020-08-06T14:42:32.000Z","msg":"幾時去花墟掃場<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"73e40725fec1195f32cf277d6e51c620728f46b5","tid":2142533,"uid":74442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T14:46:08.000Z","msg":"鋼夠一直用來整飛機大炮啦<br />\n我屋企十尻幾個鋼煲係咪拉埋我呀屌你老母？"},{"pid":"9250d5f05f6623b9e2712b1decd90d7c222a754e","tid":2142533,"uid":174060,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-06T14:55:48.000Z","msg":"好肯定係呢班恐怖分子策劃嘅<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/p5jE2mr.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fp5jE2mr.jpg&h=efa2ca7e&s={SIZE}\" />"},{"pid":"d60a007d2afd3f1bb42666ac2871a04f683566ea","tid":2142533,"uid":53610,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T15:15:51.000Z","msg":"我心諗<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"41ca58abed49d2b3ea7da890fcb9c278c10ef44e","tid":2142533,"uid":194597,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T15:17:13.000Z","msg":"攞景贈興 <img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"0b5bc0ef264322ff2c9bf4c90b4dbaa8001e5f04","tid":2142533,"uid":39872,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T15:25:43.000Z","msg":"即係曲線話支共恐襲黎巴嫩啫"},{"pid":"3da813f0804d71f664f215bd552898f3ebc3a112","tid":2142533,"uid":80455,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T15:37:16.000Z","msg":"有讀過chem 都知<br />\nAmmonium nitrate 係好common 嘅肥料<br />\n<br />\n不過毅進仔讀到中三撚識咩<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"9c153f832d9878e86317fac1945b5e0f6dae0fc9","tid":2142533,"uid":36901,"like":86,"dislike":0,"score":86,"citedBy":1,"replyTime":"2020-08-06T13:01:48.000Z","msg":"日用品變軍火？港大講師化學名舉隅<br />\n<br />\n2016-02-22&nbsp;&nbsp;&nbsp;&nbsp;<br />\n<br />\n<br />\n今日（2月22日）較早時間，《壹》仔報導過，警方尋日喺天水圍天晴邨破門入屋拘捕「本土民主前線」發言人黃台仰時，聲稱於單位內檢獲「電磁炮」同化學品，不過有外界有指警方小題大造，例如「電磁炮」係可以喺淘寶以23蚊港紙買到嘅科學玩具、啲化學品其實都係日常用品可見。<br />\n<br />\n而港大理學院講師陳志宏博士更於Facebook「教路」，活用化學名稱：「在平常的生活之中，只需要多花一點點心思，家中隨時都可聽起來像個軍火庫啊」。<br />\n<br />\n警方尋日檢走「可疑化學品」時，有現場消息指，當中包括硝酸銨、二氧化硅等，而硝酸銨可用作製造炸藥；但陳志宏舉例，肥料、瀉藥及「吸濕大笨象」等常見用品，都可以講成「硝酸銨」、「聚乙二醇」和「二氧化硅」。而微波爐可叫「集束隱形輻射共振電磁束」、「攪拌機」升lv做「高強度合金漩渦鋒面」，而「光管」都可以叫「毫秒瞬時高壓燃點電磁波放射組件」等，問你驚唔驚。<br />\n<br />\n家居用品－＞名後<br />\n<br />\n松節水 ─＞ 易燃液體<br />\n肥料 ─＞ 硝酸銨<br />\n瀉藥 ─＞ 聚乙二醇<br />\n抽濕大笨象 ─＞ 二氧化硅<br />\nDVD機 ─＞ 微米激光破譯儀<br />\n攪拌機 ─＞ 高強度合金漩渦鋒面<br />\n除塵機 ─＞ 無定向離子附着裝置<br />\n微波爐 ─＞ 集束隱形輻射共振電磁束<br />\n光管 ─＞ 毫秒瞬時高壓燃點電磁波放射組件<br />\n<br />\n<a href=\"https://hk.nextmgz.com/article/2_358048_0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.nextmgz.com%2Farticle%2F2_358048_0&d=il%2BrReVPph3FBkDtfLAFOhyAur%2Bbp9MVyOkMM5%2FMxDY%3D&h=446e8d75\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.nextmgz.com%2Farticle%2F2_358048_0&h=c32eda70\" data-auto-link target=\"_blank\">https://hk.nextmgz.com/article/2_358048_0</a>"}}