282c7da79d4f63347aed9fbd0bdcbd","tid":2142533,"uid":55055,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T13:20:37.000Z","msg":"係咪係咁講就會變真<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"b30c0bfe824f2149b8ab7add60cd21ec3399e1c4","tid":2142533,"uid":39470,"like":0,"dislike":0,"score":0,"quote":{"pid":"806603a5b61aa57807be6f1234308fcbd36c1d20","tid":2142533,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"146d78821de2ac6e902be71ee0524be310c011d9","tid":2142533,"uid":273703,"like":49,"dislike":0,"score":49,"citedBy":4,"replyTime":"2020-08-06T12:54:57.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2020-08-06T12:55:32.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-06T13:21:39.000Z","msg":"每個女人身上都有一對攻擊性武器<img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" />"},{"pid":"f33414e9514d5c6a380d687b1c7b20179a437a59","tid":2142533,"uid":19707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T13:22:36.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"9fd4def14b60c0dc08d783e3d95a266be906ec2c","tid":2142533,"uid":279513,"like":0,"dislike":0,"score":0,"quote":{"pid":"37fbc54cd613712e2bfc65e8e7b5065f335a5eef","tid":2142533,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-06T12:53:23.000Z","msg":"【 提防有炸 &bull; 硝酸銨 】<br />\n<br />\n硝酸銨(Ammonium nitrate)是一種工業化學品，主要用作農業肥料中的重要成份。在特定條件下，硝酸銨可能引發爆炸。根據報導，最近黎巴嫩貝魯特的大爆炸亦與硝酸銨有關。<br />\n<br />\n<strong><span class=\"red\">事實上，硝酸銨是近年恐怖組織製作土製炸彈的主要原料之一，警方在過去多次涉及炸彈的拘捕行動中，亦曾經搜出硝酸銨等化學品。當中包括2019年12月9日灣仔皇后大道東、2020年3月8日大角咀必發街商業大廈，與及2020年3月26日小西灣龍躍徑的爆炸品及土製炸彈案。</span></strong><br />\n<br />\n警方重申，任何人士管有硝酸銨並意圖用作製造爆炸品，有可能干犯「製造或管有炸藥」罪，最高可處監禁14年。<br />\n<br />\n<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-06T13:22:58.000Z","msg":"你老母剩係上年先有咩<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"71364e6c55cde6f97c72067f6262d687ba4d9d2f","tid":2142533,"uid":57205,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-06T13:29:33.000Z","msg":"又陰D陰D去塑造&quot;恐怖份子&quot;<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"608396cb55b52ef2a608055570b4966574d1ede5","tid":2142533,"uid":56698,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T13:30:34.000Z","msg":"九唔搭八<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"fd83e7a46e002337834edcd72507ffb3229a9483","tid":2142533,"uid":69416,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-08-06T13:32:22.000Z","msg":"<span class=\"red\"><span class=\"xx-large\"><strong>關你老母撚事<br />\n人地果邊千尻幾噸<br />\n你D撚樣見撚幾微克就吠撚到大大聲<br />\n食屎啦賤種狗 衝出黎柒</strong></span></span>"},{"pid":"9a43fd3441b40d05858f074e28674196df9b1925","tid":2142533,"uid":281054,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c153f832d9878e86317fac1945b5e0f6dae0fc9","tid":2142533,"uid":36901,"like":86,"dislike":0,"score":86,"citedBy":1,"replyTime":"2020-08-06T13:01:48.000Z","msg":"日用品變軍火？港大講師化學名舉隅<br />\n<br />\n2016-02-22&nbsp;&nbsp;&nbsp;&nbsp;<br />\n<br />\n<br />\n今日（2月22日）較早時間，《壹》仔報導過，警方尋日喺天水圍天晴邨破門入屋拘捕「本土民主前線」發言人黃台仰時，聲稱於單位內檢獲「電磁炮」同化學品，不過有外界有指警方小題大造，例如「電磁炮」係可以喺淘寶以23蚊港紙買到嘅科學玩具、啲化學品其實都係日常用品可見。<br />\n<br />\n而港大理學院講師陳志宏博士更於Facebook「教路」，活用化學名稱：「在平常的生活之中，只需要多花一點點心思，家中隨時都可聽起來像個軍火庫啊」。<br />\n<br />\n警方尋日檢走「可疑化學品」時，有現場消息指，當中包括硝酸銨、二氧化硅等，而硝酸銨可用作製造炸藥；但陳志宏舉例，肥料、瀉藥及「吸濕大笨象」等常見用品，都可以講成「硝酸銨」、「聚乙二醇」和「二氧化硅」。而微波爐可叫「集束隱形輻射共振電磁束」、「攪拌機」升lv做「高強度合金漩渦鋒面」，而「光管」都可以叫「毫秒瞬時高壓燃點電磁波放射組件」等，問你驚唔驚。<br />\n<br />\n家居用品－＞名後<br />\n<br />\n松節水 ─＞ 易燃液體<br />\n肥料 ─＞ 硝酸銨<br />\n瀉藥 ─＞ 聚乙二醇<br />\n抽濕大笨象 ─＞ 二氧化硅<br />\nDVD機 ─＞ 微米激光破譯儀<br />\n攪拌機 ─＞ 高強度合金漩渦鋒面<br />\n除塵機 ─＞ 無定向離子附着裝置<br />\n微波爐 ─＞ 集束隱形輻射共振電磁束<br />\n光管 ─＞ 毫秒瞬時高壓燃點電磁波放射組件<br />\n<br />\n<a href=\"https://hk.nextmgz.com/article/2_358048_0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.nextmgz.com%2Farticle%2F2_358048_0&d=il%2BrReVPph3FBkDtfLAFOhyAur%2Bbp9MVyOkMM5%2FMxDY%3D&h=446e8d75\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.nextmgz.com%2Farticle%2F2_358048_0&h=c32eda70\" data-auto-link target=\"_blank\">https://hk.nextmgz.com/article/2_358048_0</a>"},"citedBy":0,"replyTime":"2020-08-06T13:34:32.000Z","msg":"PIN this"},{"pid":"b6b3efff2e434996a8cb0e0d2da064e92d97c51c","tid":2142533,"uid":19213,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-08-06T13:35:08.000Z","msg":"<img src=\"https://na.cx/i/NgtuEEb.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNgtuEEb.png&h=07e0abe1&s={SIZE}\" /><br />\n大圍斬人案 疑凶手持伸縮棍 <br />\n<br />\n事實上，伸縮警棍是近年警方在鎮壓示威行動中多次使用的武器之一。<br />\n<br />\n<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />"},{"pid":"5afc798e48c66aa1812909858ced8f35a0acb529","tid":2142533,"uid":103981,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-08-06T13:36:08.000Z","msg":"呢班陷家鏟以為自己好醒識抽水<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"63fbb4b1e4f9d04a0143308b0cae70f5ca82b656","tid":2142533,"uid":258106,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T13:36:30.000Z","msg":"Cap 圖 -》 推上twitter tag 黎巴嫩手足 -〉 推到真主黨都知<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d485cd0f556aceb4bbd72a998bc0a3ac8bd569d3","tid":2142533,"uid":346701,"like":13,"dislike":0,"score":13,"quote":{"pid":"146d78821de2ac6e902be71ee0524be310c011d9","tid":2142533,"uid":273703,"like":49,"dislike":0,"score":49,"citedBy":4,"replyTime":"2020-08-06T12:54:57.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-08-06T13:41:31.000Z","msg":"黑警:<br />\n【 提防有炸 &bull; 砂糖 】<br />\n<br />\n砂糖（sugar）是一種帶有甜味的晶體，由碳、氫及氧三種原子組成。在特定條件下，砂糖可能引發爆炸。根據實驗，2008年美國糖廠的大爆炸亦與砂糖有關。<br />\n<br />\n事實上，砂糖是近年恐怖組織製作土製炸彈的主要原料之一，黑警在過去多次涉及炸彈的砌生猪肉行動中，亦曾經搜出砂糖等化學品。<br />\n<br />\n警犬重申，任何人士管有砂糖並意圖用作製造爆炸品，有可能干犯「製造或管有炸藥」罪，最高可處監禁14年。"},{"pid":"32bf4a634d6374b00bf9db0ad93f0b9955125d13","tid":2142533,"uid":333214,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T13:41:34.000Z","msg":"咁快認叻？"},{"pid":"ce23696978c3bfac4ceb8ee6ff3f4791f4e0a2a0","tid":2142533,"uid":335434,"like":4,"dislike":0,"score":4,"quote":{"pid":"146d78821de2ac6e902be71ee0524be310c011d9","tid":2142533,"uid":273703,"like":49,"dislike":0,"score":49,"citedBy":4,"replyTime":"2020-08-06T12:54:57.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-08-06T13:43:35.000Z","msg":"警謊: 南亞地區的大海嘯與一氧化二氫有關 在過去多次涉及社會運動的拘捕行動中 亦曾經搜出大量液化一氧化二氫<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5c56252db2418f64b53e821315159a7cb48e46bd","tid":2142533,"uid":43062,"like":2,"dislike":0,"score":2,"quote":{"pid":"e85fdadd3c0605d81d7661bc333cae7ee1709919","tid":2142533,"uid":50386,"like":21,"dislike":0,"score":21,"citedBy":1,"replyTime":"2020-08-06T13:14:18.000Z","msg":"驚方：印度的連環強姦案與J有關，在過去的行動中，驚方拘捕過好多有J嘅人<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n典型嘅偷換概念<br />\n本身硝酸銨可以當肥料用<br />\n人哋爆炸係不幸嘅意外嚟<br />\n黑狗就偷換概念成買硝酸銨係拎黎整炸彈<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><br />\n<br />\n雖然呢種偷換概念法班無腦藍尸好受落<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-06T13:44:57.000Z","msg":"呢啲荒謬邏輯藍屍好受落"},{"pid":"68c3aa1315bae15da5793262d0f87813834d0ed4","tid":2142533,"uid":199689,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T13:49:04.000Z","msg":"應該唔俾人買肥料<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"cc34298407a597580b3093a18ee9537fd653ced6","tid":2142533,"uid":66049,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T13:50:27.000Z","msg":"黎巴嫩嗰啲硝酸銨係咪支那運過去"},{"pid":"5fc6351ec5ecafc98ac848f2f85ee2f42efd91f3","tid":2142533,"uid":308486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-06T13:51:26.000Z","msg":"即係黎巴嫩大爆炸係香港暴徒策劃<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" />"},{"pid":"4489214cbd1f00af2f7a9d965d178f692d9b20e4","tid":2142533,"uid":282347,"like":3,"dislike":0,"score":3,"quote":{"pid":"2468d4b95a8cbb49c4d9c00fdab21c2d79ba6f9b","tid":2142533,"uid":343361,"like":33,"dislike":0,"score":33,"citedBy":2,"replyTime":"2020-08-06T12:54:27.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2020-08-06T13:57:17.000Z","msg":"驚方毅進化學部：<br />\n一氧化二氫(Dihydrogen monoxide)是一種日常化學品，主要用作農業肥料中的重要成份。在特定條件下，一氧化二氫可能引發爆炸。根據報導，最近黎巴嫩貝魯特的大爆炸亦與一氧化二氫有關。<br />\n<br />\n事實上，一氧化二氫是近年恐怖組織製作土製炸彈的主要原料之一，警方在過去多次涉及炸彈的拘捕行動中，亦曾經搜出一氧化二氫等化學品。當中包括2019年12月9日灣仔皇后大道東、2020年3月8日大角咀必發街商業大廈，與及2020年3月26日小西灣龍躍徑的爆炸品及土製炸彈案。<br />\n<br />\n警方重申，任何人士管有一氧化二氫並意圖用作製造爆炸品，有可能干犯「製造或管有炸藥」罪，最高可處監禁14年。"},{"pid":"bdf782867810847618d7bea37c2d655a045374a4","tid":2142533,"uid":36968,"like":0,"dislike":0,"score":0,"quote":{"pid":"146d78821de2ac6e902be71ee0524be310c