022,"like":0,"dislike":0,"score":0,"quote":{"pid":"6fedef009518df97baf53f56144ccf19f3b01f0d","tid":2158622,"uid":201359,"like":0,"dislike":0,"score":0,"quote":{"pid":"3570ca2a46924152026991b232ba0d4b4fdb2e45","tid":2158622,"uid":359022,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-15T23:54:57.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-15T23:55:33.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-15T23:56:29.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-15T23:57:39.000Z","msg":"<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"3c30c6e764deb8fc09e6ce32dc496d6310bc8745","tid":2158622,"uid":206668,"like":0,"dislike":0,"score":0,"quote":{"pid":"f861ee451b6cded57249ba25116286f6609c7a90","tid":2158622,"uid":154486,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2020-08-15T21:07:18.000Z","msg":"<strong><span class=\"x-large\">誠懇呼籲唔好舉呢支旗</span></strong><br />\n<br />\n白羅斯<br />\n<br />\n<img src=\"https://na.cx/i/HJHMqRp.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHJHMqRp.jpg&h=624029b2&s={SIZE}\" /><br />\n<br />\nsource國際文宣組tg<br />\n<img src=\"https://na.cx/i/vOGxmpN.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FvOGxmpN.jpg&h=355979b6&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/QGQ2JC8.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQGQ2JC8.png&h=bdae0503&s={SIZE}\" /><br />\n<br />\n1991年白羅斯自蘇聯獨立後，曾於1992年立法恢復使用1918年至1920年白羅斯人民共和國時的白紅白雙色三條式國旗。<br />\n<br />\n直到1995年因為白羅斯強人總統盧卡申科的親俄背景，改採白俄羅斯蘇維埃社會主義共和國國旗，將該旗稍做修改（取消蘇聯時期的金色鐮刀錘子及金邊紅色五角星圖案）後即成為現在的樣式。<br />\n<br />\n<br />\n<br />\n<a href=\"https://zh.m.wikipedia.org/wiki/%E7%99%BD%E4%BF%84%E7%BD%97%E6%96%AF%E5%9B%BD%E6%97%97\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wikipedia.org%2Fwiki%2F%25E7%2599%25BD%25E4%25BF%2584%25E7%25BD%2597%25E6%2596%25AF%25E5%259B%25BD%25E6%2597%2597&d=Z4osEZd2TI9THLKNWu9EL7ccVloK1XwbfTGMhSGe0oU%3D&h=48c9385e\" data-auto-link target=\"_blank\">https://zh.m.wikipedia.org/wiki/%E7%99%BD%E4%BF%84%E7%BD%97%E6%96%AF%E5%9B%BD%E6%97%97</a><br />\n<br />\n<br />\n<span class=\"xx-large\">呢D反白倒盧既旗<br />\n大家千祈唔好因為手痕以為人地唔識就Print出黎周圍貼</span>"},"citedBy":0,"replyTime":"2020-08-15T23:58:11.000Z","msg":"唔get 咁舉咩旗好"},{"pid":"d367bb693b20a2f2e74466a53220649a18ce19b1","tid":2158622,"uid":359022,"like":0,"dislike":0,"score":0,"quote":{"pid":"dbca53ebd33459c63757eadbf37eb606945a7393","tid":2158622,"uid":201359,"like":0,"dislike":0,"score":0,"quote":{"pid":"a1491c6897b7eaf2efaa30f9282eb0be5979158c","tid":2158622,"uid":359022,"like":0,"dislike":0,"score":0,"quote":{"pid":"6fedef009518df97baf53f56144ccf19f3b01f0d","tid":2158622,"uid":201359,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-15T23:55:33.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-15T23:56:29.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-15T23:57:39.000Z","msg":"<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-15T23:58:13.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"befa196a4500154d4bab562854ebb43489f572f5","tid":2158622,"uid":201359,"like":0,"dislike":0,"score":0,"quote":{"pid":"d367bb693b20a2f2e74466a53220649a18ce19b1","tid":2158622,"uid":359022,"like":0,"dislike":0,"score":0,"quote":{"pid":"dbca53ebd33459c63757eadbf37eb606945a7393","tid":2158622,"uid":201359,"like":0,"dislike":0,"score":0,"quote":{"pid":"a1491c6897b7eaf2efaa30f9282eb0be5979158c","tid":2158622,"uid":359022,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-15T23:56:29.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" clas