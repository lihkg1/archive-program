/>"},{"pid":"f0160c54bf57b2675ca56790ad081a1abe9ceb47","tid":1033490,"uid":181294,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-02-23T11:17:48.000Z","msg":"此回覆已被刪除"},{"pid":"a2dc805ad4d7dbee75443363bb949e59c6931122","tid":1033490,"uid":188176,"like":0,"dislike":0,"score":0,"quote":{"pid":"1387637aef32cc11cfbde3d213601a8e4f8aa4ff","tid":1033490,"uid":13504,"like":0,"dislike":1,"score":-1,"quote":{"pid":"4bcfa44cc40f6d0576d566d6d9cdbeb2448988b0","tid":1033490,"uid":159448,"like":5,"dislike":14,"score":-9,"citedBy":1,"replyTime":"2019-02-23T11:01:39.000Z","msg":"求樓豬老母 果然IPHONE係配公屋<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/BP99k3r.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBP99k3r.jpg&h=f68a5c84&s={SIZE}\" /><br />\n<a href=\"https://www.hk01.com/%E6%95%B8%E7%A2%BC%E7%94%9F%E6%B4%BB/298418/national-geographic%E6%94%9D%E5%BD%B1%E5%A4%A7%E8%B3%BD-%E9%A6%99%E6%B8%AF%E6%89%8B%E6%A9%9F%E7%B5%84%E5%86%A0%E8%BB%8D-iphone%E6%8B%8D%E5%87%BA%E5%B1%8B%E9%82%A8%E5%91%B3\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E6%2595%25B8%25E7%25A2%25BC%25E7%2594%259F%25E6%25B4%25BB%2F298418%2Fnational-geographic%25E6%2594%259D%25E5%25BD%25B1%25E5%25A4%25A7%25E8%25B3%25BD-%25E9%25A6%2599%25E6%25B8%25AF%25E6%2589%258B%25E6%25A9%259F%25E7%25B5%2584%25E5%2586%25A0%25E8%25BB%258D-iphone%25E6%258B%258D%25E5%2587%25BA%25E5%25B1%258B%25E9%2582%25A8%25E5%2591%25B3&d=gMg1FBwAZA1XbJy1Uvmn1DizWcNDgH0nsvPDQhA%2BiAk%3D&h=d82678a6\" data-auto-link target=\"_blank\">https://www.hk01.com/%E6%95%B8%E7%A2%BC%E7%94%9F%E6%B4%BB/298418/national-geographic%E6%94%9D%E5%BD%B1%E5%A4%A7%E8%B3%BD-%E9%A6%99%E6%B8%AF%E6%89%8B%E6%A9%9F%E7%B5%84%E5%86%A0%E8%BB%8D-iphone%E6%8B%8D%E5%87%BA%E5%B1%8B%E9%82%A8%E5%91%B3</a>"},"citedBy":1,"replyTime":"2019-02-23T11:05:05.000Z","msg":"硬係覺得個signage 破壞曬成幅相"},"citedBy":0,"replyTime":"2019-02-23T11:19:44.000Z","msg":"中間分界<img src=\"/assets/faces/n