d53744dda885","tid":2348703,"uid":121580,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-01T03:52:47.000Z","msg":"<img src=\"/assets/faces/lm2xm/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2021-01-01T03:53:53.000Z","msg":"細菌同病毒正常唔會入到血"},"citedBy":1,"replyTime":"2021-01-01T04:18:37.000Z","msg":"你拎愛滋病人既血黎飲同打J試下呀"},"citedBy":0,"replyTime":"2021-01-01T06:14:02.000Z","msg":"呼吸系統病同免疫系統病邊有得咁比較<img src=\"/assets/faces/xm/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"a7164af036d50aff4eb950615d7e139616851ff6","tid":2348703,"uid":362366,"like":3,"dislike":1,"score":2,"quote":{"pid":"b45c0baf4561a56f4ccf0be84f92c88a7a63985c","tid":2348703,"uid":122275,"like":7,"dislike":6,"score":1,"quote":{"pid":"53c03dc7a93063294e8c09c2f66cd53744dda885","tid":2348703,"uid":121580,"like":0,"dislike":0,"score":0,"quote":{"pid":"2580c1905a340abf9bd6724cefaf649a6a6186e0","tid":2348703,"uid":122275,"like":7,"dislike":4,"score":3,"citedBy":3,"replyTime":"2021-01-01T03:50:18.000Z","msg":"中肺炎血唔會有病毒喎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-01T03:52:47.000Z","msg":"<img src=\"/assets/faces/lm2xm/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2021-01-01T03:53:53.000Z","msg":"細菌同病毒正常唔會入到血"},"citedBy":0,"replyTime":"2021-01-01T06:14:41.000Z","msg":"<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><br />\n<br />\nThe coronavirus enters the body through the respiratory tract &mdash; through the mouth or nose and into the lungs &mdash; so to infect a person it needs to bind to an enzyme found on the surface of respiratory cells, Cioe-Pe&ntilde;a said.  <br />\n<br />\nBut once the coronavirus is actually in the body, it can get into the bloodstream, and from the bloodstream, SARS-CoV-2 can travel to, and invade, other organs. ''Once it's in the human body, it doesn't have a problem getting into different types of cells.'' Cioe-Pe&ntilde;a told Live Science. That is ''unfortunate because it causes all these other organ problems.''<br />\n<br />\n<a href=\"https://www.livescience.com/coronavirus-damages-other-organs.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.livescience.com%2Fcoronavirus-damages-other-organs.html&d=h8K6dYNnEA4rSgnLcindhQogPkW5zMkxdNnzPoGklno%3D&h=549b0ce5\" data-auto-link target=\"_blank\">https://www.livescience.com/coronavirus-damages-other-organs.html</a><br />\n<br />\n<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><br />\n<br />\nViremia is the medical term for when viruses enter the bloodstream.<br />\n<br />\nSome common or well-known causes of viremia include:<br />\n<br />\nHIV types 1 and 2<br />\ninfluenza<br />\nviral pneumonia<br />\nviral meningitis<br />\nvaricella zoster virus (chicken pox or shingles)<br />\nmeasles, mumps, and rubella<br />\nrotavirus<br />\nenterovirus<br />\nherpes<br />\nhuman papillomavirus (HPV)<br />\nhepatitis B and C<br />\nZika virus<br />\nWest Nile Virus<br />\nadenovirus<br />\navian influenza virus<br />\ndengue fever<br />\nyellow fever<br />\nJapanese encephalitis virus<br />\ncytomegalovirus<br />\nebola<br />\nRift Valley fever virus<br />\ncroup<br />\nrabies<br />\npolio<br />\n<br />\n<a href=\"https://www.medicalnewstoday.com/articles/320817#What-is-viremia?\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.medicalnewstoday.com%2Farticles%2F320817%23What-is-viremia%3F&d=h8K6dYNnEA4rSgnLcindhQogPkW5zMkxdNnzPoGklno%3D&h=c819ae55\" data-auto-link target=\"_blank\">https://www.medicalnewstoday.com/articles/320817#What-is-viremia?</a>"},{"pid":"466f2ae5b6576321fc8b25e22c8be4b8b45faae5","tid":2348703,"uid":178459,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T06:20:51.000Z","msg":"<img src=\"/assets/faces/xm/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/kill.gif\" class=\"hkgmoji\" />"},{"pid":"d6cdc36ff336327f0a02924dc5a6ddcbac9f650d","tid":2348703,"uid":154255,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T06:22:22.000Z","msg":"睇過佢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n驗個血再望望就成皮埋單"},{"pid":"d2a97eeffba5f813ac2ec74fc44b24bd550023bd","tid":2348703,"uid":136416,"like":0,"dislike":0,"score":0,"quote":{"pid":"a08886ed2a43ebfb6e25410879768ad89dc97dde","tid":2348703,"uid":52358,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2021-01-01T03:45:31.000Z","msg":"血源詛咒<img src=\"/assets/faces/dogxm/scare.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-01T06:24:51.000Z","msg":"<img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" />"},{"pid":"2093504e15031faa6d3c10606496d476431aba9f","tid":2348703,"uid":249979,"like":1,"dislike":0,"score":1,"quote":{"pid":"7b7e56b8870940390a5c68d8b74ae44b29d54e9c","tid":2348703,"uid":365791,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2021-01-01T04:52:16.000Z","msg":"up乜L野<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/