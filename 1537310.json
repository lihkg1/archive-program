29.000Z","msg":"姐係isis?"},"citedBy":0,"replyTime":"2019-09-04T01:49:42.000Z","msg":"面對isis係香港出現會點"},{"pid":"ef9a30f0ca527e63358ac17dcd0ec8b3326a2303","tid":1537310,"uid":93986,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T02:04:41.000Z","msg":"推"},{"pid":"1ab92cb0a77e99efa34d366124616732370fcd8f","tid":1537310,"uid":93986,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T02:05:30.000Z","msg":"推"},{"pid":"9756830f7d1220964c0d9f00ecf61049711a1e72","tid":1537310,"uid":62270,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T02:06:03.000Z","msg":"不如911對外正式宣布啦"},{"pid":"2993d0b3ab027585083a91760be28f62513efb0a","tid":1537310,"uid":93986,"like":0,"dislike":0,"score":0,"quote":{"pid":"9756830f7d1220964c0d9f00ecf61049711a1e72","tid":1537310,"uid":62270,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T02:06:03.000Z","msg":"不如911對外正式宣布啦"},"citedBy":0,"replyTime":"2019-09-04T02:07:48.000Z","msg":"要正名化。唔好俾班狗拎光環<br />\n做雞做到佢有貞節牌坊？"},{"pid":"cbfa383a18cfc11ef7e7f9514e394a85573d593d","tid":1537310,"uid":265234,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T02:12:14.000Z","msg":"<img src=\"https://na.cx/i/QgnuQOg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQgnuQOg.jpg&h=5fff8b90&s={SIZE}\" /><br />\n<br />\n9月6號，全民戴裝日<br />\n<br />\n目的係提醒大家行街坐車都會隨時被襲擊，扑頭、噴椒、或身處毒霧環境，所以要戴上防具作象徵，靜默地抗議。<br />\n<br />\n以下幾點提議比番大家:<br />\n1. 番學番工放工時間做，越多人做效果越好，人多亦唔易比人check身份證<br />\n2. 行街坐車行商場都戴住，唔使怕奇怪，因為更無理既事日日都發生緊<br />\n3. 番工裝扮未必帶到頭盔，但唔戴都帶住，作為一個象徵，又或者只帶口罩眼罩<br />\n4. 真勇武就小心，比人check身份證留record就麻煩<br />\n5. 只帶防具，只係要保護自己，唔好有其他可疑裝備<br />\n<br />\n當人人都有頭盔口罩係身既時候，就可以淡化帶gear本身既奇怪，保護大家，亦比一份支持勇武。"},{"pid":"390db2d104413c088d52c48d088d57e4678df64a","tid":1537310,"uid":93986,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T02:14:55.000Z","msg":"推"},{"pid":"9e0c4e484e2e4c3dd4aa20ee9a87cfa02e6fadf4","tid":1537310,"uid":93986,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T02:21:43.000Z","msg":"香港警察=恐怖主義武裝組織"},{"pid":"121252e5f1aa300c466d26dd3d70dd271cadfd0c","tid":1537310,"uid":93986,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T02:53:54.000Z","msg":"香港警察=香港恐怖主義武裝組織"},{"pid":"7dc992ce86fbd14995bc38920ea7fcf919df91a3","tid":1537310,"uid":93986,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T03:31:23.000Z","msg":"香港警察=香港恐怖主義武裝組織"},{"pid":"5aa61510cfbcc2051b2aa190caee4be66b1dcd62","tid":1537310,"uid":108347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T03:32:14.000Z","msg":"求吓大家，暫停鑽牛角尖睇多啲評論<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1537499\" data-auto-link target=\"_blank\">https://lih.kg/1537499</a>"}]}