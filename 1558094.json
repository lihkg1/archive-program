ss=\"hkgmoji\" />"},{"pid":"89d1743ea6a30e24f4e2c83f62ac9b472078951b","tid":1558094,"uid":26266,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-10T10:53:14.000Z","msg":"俾19講中咗<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"1f66441f02c44915be68f9c594db3cba61d638db","tid":1558094,"uid":177152,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T10:55:54.000Z","msg":"合理 絕對支持<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"962720bd239f2be092dade4105f1cf30ede5750b","tid":1558094,"uid":16055,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T10:56:44.000Z","msg":"行得正企得正驚咩"},{"pid":"6a650affc0dba6c97044fa6ecf5b76f87766edc7","tid":1558094,"uid":231583,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T10:58:34.000Z","msg":"諗起條弱智仔移民sir<br />\n不過做得過街老鼠都已經delete曬"},{"pid":"ff4fe5620c1a00541e1dd6d72ed7e86bc7b6ddc6","tid":1558094,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T12:22:43.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"}]}