lass=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/q1U4oxx.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fq1U4oxx.gif&h=b9aaf29e&s={SIZE}\" /><br />\n<br />\n眾所周知 爆丸一放近鐵 就會爆開 <br />\n套用喺呢個情況上面 一爆開 表面面積就增加<br />\n更利於抓實啲硬屎 <img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/DRctQB8.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDRctQB8.gif&h=ec02def6&s={SIZE}\" /><br />\n<br />\n爆丸通便法<img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/juqGraC.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjuqGraC.gif&h=9b776b0e&s={SIZE}\" /><br />\n推完啲屎出嚟洗下粒爆丸 <br />\n又可以俾下位有需要嘅巴打用<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-08T15:50:59.000Z","msg":"便秘解決，患者死撚咗。<img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"c6e02b3f26629e93d255e2af7372189b33ffae50","tid":2358922,"uid":110278,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-08T15:53:22.000Z","msg":"<img src=\"/assets/faces/cat/annoyed.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/annoyed.gif\" class=\"hkgmoji\" />"},{"pid":"78f9dd7aa09b066b4e6d4a16fc22aaa6de62d98b","tid":2358922,"uid":371571,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-08T15:53:55.000Z","msg":"粒爆丸又畫得幾正<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"3f15e8443b03eecef6c08ef7181fe32f859636f7","tid":2358922,"uid":166308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-08T15:55:53.000Z","msg":"<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"65010d1fd899c3ce0cc85fe63795117f376c8ff6","tid":2358922,"uid":51346,"like":29,"dislike":7,"score":22,"citedBy":1,"replyTime":"2021-01-08T13:17:14.000Z","msg":"以下行為經特別訓練 家庭觀眾切勿模仿"}}