,"uid":135485,"like":9,"dislike":6,"score":3,"quote":{"pid":"bcf22905a0454eca4e15634fcd8144d36ea537c5","tid":2140863,"uid":118346,"like":90,"dislike":8,"score":82,"citedBy":3,"replyTime":"2020-08-05T09:24:13.000Z","msg":"樓主係自私師 <img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2020-08-05T10:14:14.000Z","msg":"其實外國好多人都唔會撳...<br />\n係香港人咁趕時間 連幾秒都等唔到先會撳 <br />\n如果驚又想撳 咪用鎖匙/筆撳囉"},"citedBy":0,"replyTime":"2020-08-05T10:58:49.000Z","msg":"唔好用用鎖匙撳唔<br />\n唔係面頭塊膠會穿<br />\n就個制會花<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"32a13bf721ff8d8ed921ec7181cf16970424cbdf","tid":2140863,"uid":33188,"like":0,"dislike":0,"score":0,"quote":{"pid":"a8fe9d70d6f0e28adf302abed996eb5e1a716046","tid":2140863,"uid":288659,"like":11,"dislike":0,"score":11,"citedBy":1,"replyTime":"2020-08-05T10:19:37.000Z","msg":"撳個掣有乜所謂，又唔係lam個掣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n反正返到去都洗手"},"citedBy":0,"replyTime":"2020-08-05T11:00:11.000Z","msg":"咪係 撳完唔周圍摸<br />\n即刻搓手咪得<br />\n咁驚就唔好出街<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"085a627bd3addc7e4e4067c8017622762e7602f2","tid":2140863,"uid":13193,"like":0,"dislike":0,"score":0,"quote":{"pid":"8d08b16cd9df2f8a94dbf667224f05a0a6cc63a9","tid":2140863,"uid":33359,"like":19,"dislike":3,"score":16,"quote":{"pid":"ce77bf0a3c617ba0f4fa47b528eaa2ce72021745","tid":2140863,"uid":53530,"like":57,"dislike":1,"score":56,"citedBy":1,"replyTime":"2020-08-05T09:27:25.000Z","msg":"鳩企師<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-05T09:29:46.000Z","msg":"齊齊攬炒係架𨋢到過夜<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-05T11:01:13.000Z","msg":"有冇靚女？"},{"pid":"56f62dfa6e9d44d5a02bd7b90bb4027249d16393","tid":2140863,"uid":86509,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-05T11:02:08.000Z"