/>\n「不如...熄燈先啦？」April問。<br />\n<br />\nA. 熄<br />\nB. 唔熄<br />\n<br />\n<br />\n<br />\n<br />\n(April 好感度：2)<br />\n上幾篇唔記得講，揀學妹好感度初始值為2，每個角色好感度最高5，最低-5"},{"pid":"5ee306d4fb63afff4ae731b1e46de2190e9eae17","tid":1914050,"uid":269707,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-03-08T10:14:00.000Z","msg":"C"},{"pid":"660aba4cfa3fa438d71a18cfaab547c518b7a5fa","tid":1914050,"uid":20285,"like":8,"dislike":1,"score":7,"citedBy":2,"replyTime":"2020-03-08T10:15:15.000Z","msg":"btw...我仲以為你哋會揀晒A cup<br />\n我仲已經有玩撳釘嘅準備"},{"pid":"d15f8a0c2e01ef9ce88931a3025cf98d94fe1bd2","tid":1914050,"uid":28761,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T10:15:37.000Z","msg":"B"},{"pid":"584f958132f3ed3c379bd010d4855cab273ce9df","tid":1914050,"uid":205125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T10:17:59.000Z","msg":"B"},{"pid":"084246c391fee7c5eda0afcce5127c264b3305ca","tid":1914050,"uid":286131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T10:22:15.000Z","msg":"<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />B"},{"pid":"f6ee680bfb7afb22af97ee39b11f5c51c97f4c65","tid":1914050,"uid":240372,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T10:32:02.000Z","msg":"B"},{"pid":"d6cfdfa61279eadd7ee4c9b6e7fbf53a0a265267","tid":1914050,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T10:33:20.000Z","msg":"B"},{"pid":"1809b9040148a8f717e0d35d57420f49018d9852","tid":1914050,"uid":17090,"like":0,"dislike":0,"score":0,"quote":{"pid":"660aba4cfa3fa438d71a18cfaab547c518b7a5fa","tid":1914050,"uid":20285,"like":8,"dislike":1,"score":7,"citedBy":2,"replyTime":"2020-03-08T10:15:15.000Z","msg":"btw...我仲以為你哋會揀晒A cup<br />\n我仲已經有玩撳釘嘅準備"},"citedBy":0,"replyTime":"2020-03-08T10:40:51.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"0327536219f740eb7209df6d4bb5f799d5a5971a","tid":1914050,"uid":83440,"like":0,"dislike":0,"score":0,"