s/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"175cabb4bc3cb6069d998952cfcbaf76be744b9f","tid":461802,"uid":67447,"like":7,"dislike":1,"score":6,"citedBy":0,"replyTime":"2017-11-08T06:42:08.000Z","msg":"同支那報紙行文一樣 語法不通 造作濫情"},{"pid":"0128bb05d52c63a36341e7beb4fda12c2fa47809","tid":461802,"uid":23999,"like":21,"dislike":1,"score":20,"citedBy":0,"replyTime":"2017-11-08T06:44:30.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2017/11/08/140517_f03132c8bd7c2ca4dd0c92ff98ba94ef.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F08%2F140517_f03132c8bd7c2ca4dd0c92ff98ba94ef.jpg&h=44fa8854&s={SIZE}\" /><br />\n<br />\n咩叫 &quot;我覺得他是我可以找到package最好的對象&quot;？ 完全唔make sense<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n應該係 &quot;我覺得他是我可以找到<span style=\"color: red;\">的</span>package<span style=\"color: red;\">之中</span>最好的對象&quot;</blockquote><br />\n咁既話意思就會變咗 佢喺package裡面搵佢對象，但package唔係佢要搵既野，package只係佢對象所擁有既東西，佢要搵既係對象。<br />\n若果要改的話應該係：我覺得他是我可以找到的對象之中，package最好的一位。"},{"pid":"3cb60325ba44214fc9fcb7ef1ec91f06adfdffb8","tid":461802,"uid":58552,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-11-08T06:46:59.000Z","msg":"01歷史"},{"pid":"c55f450a62babc2cfc8232fc67486826327c1fbc","tid":461802,"uid":32483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-08T06:47:51.000Z","msg":"簡單黎講 係矯情<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"00b5c3e747453ee8e8be6cb8786f787e8a267dc8","tid":461802,"uid":42119,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-08T06:49:08.000Z","msg":"垃圾網媒"},{"pid":"997e6eb861e388b68d622c585823c47c32b930b9","tid":461802,"uid":33477,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-08T06:50:56.000Z","msg":"得罪講句，娛樂版邊會有好文筆 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"adb2e7bc40eca265f1f14717833089fc30702c57","tid":461802,"uid":38781,"like":8,