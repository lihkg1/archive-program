c173d04b9f892b0bda4412202c3eb","tid":2077574,"uid":192517,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-07T16:54:00.000Z","msg":"agger"},{"pid":"5318c2e11fbdabbbcff53ab1a120dbfe89af68b0","tid":2077574,"uid":59922,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-07T17:38:23.000Z","msg":"全部都唔係誠實可靠，全部都講大話㗎啦。全部死全家"},{"pid":"5481ccad174dfc4ce90078f0206158917f1ffc30","tid":2077574,"uid":123774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-07T17:42:52.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f31b8e81bb40f6969c94ed0b70252a5cdc9949f8","tid":2077574,"uid":123774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-08T07:47:04.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8064a9b268eed143fa163ead3a6ec2aa46ad7a5b","tid":2077574,"uid":123774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-08T08:13:31.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"dc171c377cd6708aee77dd339c1a6d418931f243","tid":2077574,"uid":123774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-09T16:45:05.000Z","msg":"落街洗衫變襲警<br />\n<br />\n原來事件發生於去年十一月某一日的夜晚，九龍灣有人設路障堵路。防暴警員接報到場後，堵路者大部份已離開，惟九龍灣港鐵站行人天橋附近，卻有一個右手拉住手推車、左手抱住大膠袋，穿汗衫短褲，踢一對白色拖鞋的39歲男人因「落街洗衫」，而在現場出現。按辯方大狀表述案情，這男人被指以右肩膊撞向防暴警員的盾牌，致使同時戴著面罩和眼罩的警員顴骨觸痛，他因此被控以「襲警」罪名。<br />\n<br />\n洗衫男昨日在庭上憶述案情，他指當時遭三、四名防暴警員圍住，其中一人說：「X你老母！」，另一人說：「你做乜X嘢？係咪嗰啲人？」當時他這樣回答：「我係香港人。」警員回應：「你宜家好X型呀？我就告你襲警。」昨日庭上，辯方大狀問道「香港人」是甚麼意思？洗衫男說：「我想表達我係街坊，我係普通香港巿民。」<br />\n<br />\n隨即洗衫男被防暴警員近距離（按警員證供是少於半米至一米距離）直射胡椒噴霧，讓他戴了隱形眼鏡的雙眼刺痛兼有如火燒。按被告陳述，中間還包含很多細節，諸如他雙腳被跪低、雙手從後被扣索帶、被警員照頭淋水、被強行抬起手腳致面朝地面前行，同時被威嚇：「宜家先啱啱開始，有X排同你玩。」以及當他在警車上嘔吐後，防暴警員曾言「舔乾淨啲嘔吐物」等。<br />\n<br />\n<a href=\"https://www.hkcnews.com/article/31757/%E8%A3%81%E5%88%A4%E6%B3%95%E9%99%A2-31757/%E3%80%90%E4%BB%96%E8%90%BD%E8%A1%97%E6%B4%97%E8%A1%AB%EF%BC%8C%E5%8D%BB%E6%83%B9%E4%B8%8A%E3%80%8C%E8%A5%B2%E8%AD%A6%E3%80%8D%E5%AE%98%E9%9D%9E\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hkcnews.com%2Farticle%2F31757%2F%25E8%25A3%2581%25E5%2588%25A4%25E6%25B3%2595%25E9%2599%25A2-31757%2F%25E3%2580%2590%25E4%25BB%2596%25E8%2590%25BD%25E8%25A1%2597%25E6%25B4%2597%25E8%25A1%25AB%25EF%25BC%258C%25E5%258D%25BB%25E6%2583%25B9%25E4%25B8%258A%25E3%2580%258C%25E8%25A5%25B2%25E8%25AD%25A6%25E3%2580%258D%25E5%25AE%2598%25E9%259D%259E&d=Dkz3eIcuz1ZryPyeMF8ZPpnDgp1V90hxAqV0yKYrtpw%3D&h=c498c395\" data-auto-link target=\"_blank\">https://www.hkcnews.com/article/31757/%E8%A3%81%E5%88%A4%E6%B3%95%E9%99%A2-31757/%E3%80%90%E4%BB%96%E8%90%BD%E8%A1%97%E6%B4%97%E8%A1%AB%EF%BC%8C%E5%8D%BB%E6%83%B9%E4%B8%8A%E3%80%8C%E8%A5%B2%E8%AD%A6%E3%80%8D%E5%AE%98%E9%9D%9E</a>"},{"pid":"99f14fff8d1881596c6dd1b5b2579c483f77393a","tid":2077574,"uid":123774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-10T09:59:36.000Z","msg":"10/7<br />\n<br />\n庭上供稱被告拒捕 片段顯示無反抗 警稱要看360度大環境<br />\n<br />\n<a href=\"https://lih.kg/2102064\" data-auto-link target=\"_blank\">https://lih.kg/2102064</a><br />\n- 分享自 LIHKG 討論區"}],"pinned":{"pid":"dc171c377cd6708aee77dd339c1a6d418931f243","tid":2077574,"uid":123774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-09T16:45:05.000Z","msg":"落街洗衫變襲警<br />\n<br />\n原來事件發生於去年十一月某一日的夜晚，九龍灣有人設路障堵路。防暴警員接報到場後，堵路者大部份已離開，惟九龍灣港鐵站行人天橋附近，卻有一個右手拉住手推車、左手抱住大膠袋，穿汗衫短褲，踢一對白色拖鞋的39歲男人因「落街洗衫」，而在現場出現。按辯方大狀表述案情，這男人被指以右肩膊撞向防暴警員的盾牌，致使同時戴著面罩和眼罩的警員顴骨觸痛，他因此被控以「襲警」罪名。<br />\n<br />\n洗衫男昨日在庭上憶述案情，他指當時遭三、四名防暴警員圍住，其中一人說：「X你老母！」，另一人說：「你做乜X嘢？係咪嗰啲人？」當時他這樣回答：「我係香港人。」警員回應：「你宜家好X型呀？我就告你襲警。」昨日庭上，辯方大狀問道「香港人」是甚麼意思？洗衫男說：「我想表達我係街坊，我係普通香港巿民。」<br />\n<br />\n隨即洗衫男被防暴警員近距離（按警員證供是少於半米至一米距離）直射胡椒噴霧，讓他戴了隱形眼鏡的雙眼刺痛兼有如火燒。按被告陳述，中間還包含很多細節，諸如他雙腳被跪低、雙手從後被扣索帶、被警員照頭淋水、被強行抬起手腳致面朝地面前行，同時被威嚇：「宜家先啱啱開始，有X排同你玩。」以及當他在警車上嘔吐後，防暴警員曾言「舔乾淨啲嘔吐物」等。<br />\n<br />\n<a href=\"https://www.hkcnews.com/article/31757/%E8%A3%81%E5%88%A4%E6%B3%95%E9%99%A2-31757/%E3%80%90%E4%BB%96%E8%90%BD%E8%A1%97%E6%B4%97%E8%A1%AB%EF%BC%8C%E5%8D%BB%E6%83%B9%E4%B8%8A%E3%80%8C%E8%A5%B2%E8%AD%A6%E3%80%8D%E5%AE%98%E9%9D%9E\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hkcnews.com%2Farticle%2F31757%2F%25E8%25A3%2581%25E5%2588%25A4%25E6%25B3%2595%25E9%2599%25A2-31757%2F%25E3%2580%2590%25E4%25BB%2596%25E8%2590%25BD%25E8%25A1%2597%25E6%25B4%2597%25E8%25A1%25AB%25EF%25BC%258C%25E5%258D%25BB%25E6%2583%25B9%25E4%25B8%258A%25E3%2580%258C%25E8%25A5%25B2%25E8%25AD%25A6%25E3%2580%258D%25E5%25AE%2598%25E9%259D%259E&d=Dkz3eIcuz1ZryPyeMF8ZPpnDgp1V90hxAqV0yKYrtpw%3D&h=c498c395\" data-auto-link target=\"_blank\">https://www.hkcnews.com/article/31757/%E8%A3%81%E5%88%A4%E6%B3%95%E9%99%A2-31757/%E3%80%90%E4%BB%96%E8%90%BD%E8%A1%97%E6%B4%97%E8%A1%AB%EF%BC%8C%E5%8D%BB%E6%83%B9%E4%B8%8A%E3%80%8C%E8%A5%B2%E8%AD%A6%E3%80%8D%E5%AE%98%E9%9D%9E</a>"}}