w.shadowera.com/cards/sf201.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.shadowera.com%2Fcards%2Fsf201.jpg&h=a728b709&s={SIZE}\" /></blockquote>"},{"pid":"da7c4a4a5b980820532c958b1ff410cf99961a8f","tid":547723,"uid":114127,"like":0,"dislike":0,"score":0,"quote":{"pid":"f81cc33aa73dbf5b0b01b35c69f5038793503f06","tid":547723,"uid":37288,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd86289e73f583825ceea6e106979f626beeaa4d","tid":547723,"uid":114127,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-02T17:16:57.000Z","msg":"呢隻game係香港好泠門<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-03T08:08:55.000Z","msg":"巴打有玩? 用咩英?"},"citedBy":1,"replyTime":"2018-02-03T19:20:41.000Z","msg":"主玩shadow嗰邊，最鐘意darkclaw 同banebow。但自從玩左mtg之後就冇玩se了，始於更新得太慢。"},{"pid":"f69f6bf22f88758b802b2a16d4fbea8c882bcd8b","tid":547723,"uid":37288,"like":0,"dislike":0,"score":0,"quote":{"pid":"da7c4a4a5b980820532c958b1ff410cf99961a8f","tid":547723,"uid":114127,"like":0,"dislike":0,"score":0,"quote":{"pid":"f81cc33aa73dbf5b0b01b35c69f5038793503f06","tid":547723,"uid":37288,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd86289e73f583825ceea6e106979f626beeaa4d","tid":547723,"uid":114127,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-02T17:16:57.000Z","msg":"呢隻game係香港好泠門<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-03T08:08:55.000Z","msg":"巴打有玩? 用咩英?"},"citedBy":1,"replyTime":"2018-02-03T19:20:41.000Z","msg":"主玩shadow嗰邊，最鐘意darkclaw 同banebow。但自從玩左mtg之後就冇玩se了，始於更新得太慢。"},"citedBy":2,"replyTime":"2018-02-04T09:04:52.000Z","msg":"我係齋用Elementalis, 佢依加更新得幾密, 3月又有大更新。啱啱先發現故事mode佢都整咗唔止一版, 好有心機 <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/04/170351_1dff5efd6e62fbc258eaf30773da6e44.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F04%2F170351_1dff5efd6e62fbc258eaf30773da6e44.png&h=477113ec&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/02/04/170407_7675df48ab18c355bda459b4e3221d76.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F04%2F170407_7675df48ab18c355bda459b4e3221d76.png&h=b973b09b&s={SIZE}\" />"},{"pid":"0ee07a634c51739878d025eeb9b2f220006c5ddd","tid":547723,"uid":37288,"like":0,"dislike":0,"score":0,"quote":{"pid":"f69f6bf22f88758b802b2a16d4fbea8c882bcd8b","tid":547723,"uid":37288,"like":0,"dislike":0,"score":0,"quote":{"pid":"da7c4a4a5b980820532c958b1ff410cf99961a8f","tid":547723,"uid":114127,"like":0,"dislike":0,"score":0,"quote":{"pid":"f81cc33aa73dbf5b0b01b35c69f5038793503f06","tid":547723,"uid":37288,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-03T08:08:55.000Z","msg":"巴打有玩? 用咩英?"},"citedBy":1,"replyTime":"2018-02-03T19:20:41.000Z","msg":"主玩shadow嗰邊，最鐘意darkclaw 同banebow。但自從玩左mtg之後就冇玩se了，始於更新得太慢。"},"citedBy":2,"replyTime":"2018-02-04T09:04:52.000Z","msg":"我係齋用Elementalis, 佢依加更新得幾密, 3月又有大更新。啱啱先發現故事mode佢都整咗唔止一版, 好有心機 <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/04/170351_1dff5efd6e62fbc258eaf30773da6e44.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F04%2F170351_1dff5efd6e62fbc258eaf30773da6e44.png&h=477113ec&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/02/04/170407_7675df48ab18c355bda459b4e3221d76.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F04%2F170407_7675df48ab18c355bda459b4e3221d76.png&h=b973b09b&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-02-04T09:06:56.000Z","msg":"同埋啲ai聰明咗, 再加埋佢update 埋啲ai 嘅deck, 就算打電腦有啲英3星都好難打<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ba3afdeb45115be6149e7987756e4a9e78b2311c","tid":547723,"uid":37288,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-04T09:50:32.000Z","msg":"現在會把地方名，年份，月份及神名譯中文，只有人名保留英文，方便大家理解邊個打邊個及暗影時代 (Shadow Era) 的世界觀。<br />\n<br />\n第一篇: <br />\n<img src=\"http://www.shadowera.com/attachment.php?s=4884f3b470271904017d9fe933d0e6ba&amp;attachmentid=3936&amp;d=1365821112\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.shadowera.com%2Fattachment.php%3Fs%3D4884f3b470271904017d9fe933d0e6ba%26attachmentid%3D3936%26d%3D1365821112&h=132a97c3&s={SIZE}\" /> <br />\n<br />\n最終之戰998年，蜂蜜酒之月16日，火之日 <br />\n<br />\n這是漫長的一年，雖然距離所有事情的完結只是過了兩個多月，但現在我發現自己比以往老得更快。Rothem一直都是一個好人；一個公平的國王，但有時候我覺得他受過太多苦了。最終之戰過了接近一千年，但他仍認為拉亞爾需要向世界顯示它的實力。我本身已經不太喜歡閱兵，但今次他計劃興建的新城堡實在不能接受。 <br />\n<br />\n巴洛亞之峰自古以來只有很少人能成功登上，然而國王竟然試圖在它頂上建築！當然，他也不至於愚蠢到在頂峰動土。但如果他在城堡上蓋個尖塔讓自己更接近天空，我也不感意外。我不確定他是否很重用祭司，但肯定這個傻瓜正試圖以一人之力阻止我。Nishaven不就是他身旁最信任的顧問嗎？ 媽的，他們太熱衷國王的驕傲了！ <br />\n<br />\n不過我也不能說只有國王令我感到憂慮，我兒子也一樣。雖然我知道他不怎麼熱愛宗教，但他竟然公開表明自己根本不信奉七位巴洛亞之神？這已不是我能想像的了。他一直說自己所做的一切是為了和世上的黑暗對抗，而很多神殿的人都相信是黑暗令他變成這樣。我們並不知道這個男孩的親生父母是誰，但我的門徒肯定他會在里茨那裡高興的說出自己根本不信奉神這些事情。所以，「她」，必須成為我兒子的老師，阻止我兒子在班上宣揚他新發現的「信仰」。Zhanna一直是我們女神的忠實追隨者，這一點令我對她很有信心。明顯地，我在這方面弄錯了，因為昨天晚上她向我說自己也為教導我兒子感到困惑，竟然反問我如何才可以感化他。我感到非常悲傷。 <br />\n<br />\n我希望到了雪之月或狼之月會有些好事情發生，因此我向雅拉達祈禱，祈求最終之戰1000年會帶來一些讓人放鬆的事情。也許到了籽之月 Rothem和Loest都會放棄他們的狂野觀念。到時我可能還會變年輕了！ <br />\n<br />\nRothem, 拉亞爾之王: <br />\n<img src=\"https://vignette.wikia.nocookie.net/shadowera/images/1/17/NewRothem.jpg/revision/latest?cb=20140129222114\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fshadowera%2Fimages%2F1%2F17%2FNewRothem.jpg%2Frevision%2Flatest%3Fcb%3D20140129222114&h=842d863a&s={SIZE}\" /> <br />\n<br />\nRothem 的樣貌: <br />\n<img src=\"https://vignette.wikia.nocookie.net/shadowera/images/a/a6/Visage.jpg/revision/latest?cb=20131208011024\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fshadowera%2Fimages%2Fa%2Fa6%2FVisage.jpg%2Frevision%2Flatest%3Fcb%3D20131208011024&h=08df96bf&s={SIZE}\" /> <br />\n<br />\nNishaven: <br />\n<img src=\"https://vignette.wikia.nocookie.net/shadowera/images/4/4b/Se005.jpg/revision/latest?cb=20131012061141\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fshadowera%2Fimages%2F4%2F4b%2FSe005.jpg%2Frevision%2Flatest%3Fcb%3D20131012061141&h=59f60d98&s={SIZE}\" /> <br />\n<br />\nZhanna Mist: <br />\n<img src=\"http://tradingcardgames.com/wp-content/uploads/2014/12/Zhannas.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Ftradingcardgames.com%2Fwp-content%2Fuploads%2F2014%2F12%2FZhannas.png&h=bdbcfccc&s={SIZE}\" />"},{"pid":"2216297ae5c4bf75267a65d9d13f506c5fb5f615","tid":547723,"uid":114127,"like":0,"dislike":0,"score":0,"quote":{"pid":"f69f6bf22f88758b802b2a16d4fbea8c882bcd8b","tid":547723,"uid":37288,"like":0,"dislike":0,"score":0,"quote":{"pid":"da7c4a4a5b980820532c958b1ff410cf99961a8f","tid":547723,"uid":114127,"like":0,"dislike":0,"score":0,"quote":{"pid":"f81cc33aa73dbf5b0b01b35c69f5038793503f06","tid":547723,"uid":37288,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-03T08:08:55.000Z","msg":"巴打有玩? 用咩英?"},"citedBy":1,"replyTime":"2018-02-03T19:20:41.000Z","msg":"主玩shadow嗰邊，最鐘意darkclaw 同banebow。但自從玩左mtg之後就冇玩se了，始於更新得太慢。"},"citedBy":2,"replyTime":"2018-02-04T09:04:52.000Z","msg":"我係齋用Elementalis, 佢依加更新得幾密, 3月又有大更新。啱啱先發現故事mode佢都整咗唔止一版, 好有心機 <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/04/170351_1dff5efd6e62fbc258eaf30773da6e44.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F04%2F170351_1dff5efd6e62fbc258eaf30773da6e44.png&h=477113ec&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/02/04/170407_7675df48ab18c355bda459b4e3221d76.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F04%2F170407_7675df48ab18c355bda459b4e3221d76.png&h=b973b09b&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-02-04T13:08:21.000Z","msg":"期待新HERO😁😁😁"},{"pid":"1ba82157fa1df7c10b600d0d2d2fc40c240b9ba6","tid"