>\n<img src=\"https://na.cx/i/06jJwXv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F06jJwXv.jpg&h=1856e204&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-01-23T18:32:42.000Z","msg":"推！"},{"pid":"46fc2e2da0e3d2a3c65be1a2e69d4ffd9a5e116e","tid":1837284,"uid":41998,"like":0,"dislike":0,"score":0,"quote":{"pid":"8aac976ed70aac62e5e650eeb480a85e0e56490a","tid":1837284,"uid":21545,"like":0,"dislike":0,"score":0,"quote":{"pid":"6b1dfdf0995a7a099bde33cfd30a56660415da26","tid":1837284,"uid":43062,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-23T14:32:24.000Z","msg":"呢啲都算係警暴啦屌你<img src=\"/assets/faces/big/dead.gif\" class=\"hkgmoji\" /><br />\n<br />\n暴係包括埋言語上嘅暴力"},"citedBy":1,"replyTime":"2020-01-23T14:35:11.000Z","msg":"但「睇」唔到啊嘛<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-24T01:19:23.000Z","msg":"呢單嘢都係一個幾有力嘅證據，<br />\n話比人知投訴警察課真係垃撚圾嚟<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"0a81dcf92bdd1ffc0fe0c1eedd69018c2a5a0fc9","tid":1837284,"uid":37303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T01:24:12.000Z","msg":"推"},{"pid":"cc864e8eaf92312168f4e69e7d68a16755fa7cda","tid":1837284,"uid":38204,"like":0,"dislike":0,"score":0,"quote":{"pid":"46fc2e2da0e3d2a3c65be1a2e69d4ffd9a5e116e","tid":1837284,"uid":41998,"like":0,"dislike":0,"score":0,"quote":{"pid":"8aac976ed70aac62e5e650eeb480a85e0e56490a","tid":1837284,"uid":21545,"like":0,"dislike":0,"score":0,"quote":{"pid":"6b1dfdf0995a7a099bde33cfd30a56660415da26","tid":1837284,"uid":43062,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-23T14:32:24.000Z","msg":"呢啲都算係警暴啦屌你<img src=\"/assets/faces/big/dead.gif\" class=\"hkgmoji\" /><br />\n<br />\n暴係包括埋言語上嘅暴力"},"citedBy":1,"replyTime":"2020-01-23T14:35:11.000Z","msg":"但「睇」唔到啊嘛<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-24T01:19:23.000Z","msg":"呢單嘢都係一個幾有力嘅證據，<br />\n話比人知投訴