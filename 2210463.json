u=https%3A%2F%2Fyoutu.be%2F31fClz9Ig-s&d=eCiXx0TsV7ZnsYjNRM2Omq9osQ3F9Lpm1EhhEwxE9Bk%3D&h=9516c835\" target=\"_blank\">https://youtu.be/31fClz9Ig-s</a><br />\n<br />\n想咁多位手足 幫個手推高reach rate <img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" /><br />\n如果可以 更加希望下年頭推到拎獎<br />\n<br />\nlink: <a href=\"https://m.facebook.com/story.php?story_fbid=3237779492943383&amp;id=2107034039351273\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2Fstory.php%3Fstory_fbid%3D3237779492943383%26id%3D2107034039351273&d=eCiXx0TsV7ZnsYjNRM2Omq9osQ3F9Lpm1EhhEwxE9Bk%3D&h=6798fd53\" target=\"_blank\">https://m.facebook.com/story.php?story_fbid=3237779492943383&amp;id=2107034039351273</a>"},"citedBy":0,"replyTime":"2020-09-24T09:59:20.000Z","msg":"幫推，支持<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"53fab5776a0113441bfbbf1e09a10f7cc3b0420c","tid":2210463,"uid":33586,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-24T12:17:03.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"1673d731b34dcbf032d274316e5890b72d1cd2a2","tid":2210463,"uid":33586,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-24T18:27:36.000Z","msg":"push"},{"pid":"dac2d0bfbe4937f3910fc1b6b85478867dac1f27","tid":2210463,"uid":229057,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-24T18:55:00.000Z","msg":"推推推"},{"pid":"a01955f9dd894b490904d5e16c6825e75912be0c","tid":2210463,"uid":33586,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-25T03:35:41.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"d9a720c8f1131eb5b163c4011b901c77b1fe5b42","tid"