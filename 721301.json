i\" />"},{"pid":"3c130f3feaff918093f8775de2ec18123022e5d0","tid":721301,"uid":62061,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-28T16:51:55.000Z","msg":"有無得兼職淨係做下侍應傳下酒咁<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"3bbfd9da1797a5c326fd76a8821d8811bf5a8057","tid":721301,"uid":112709,"like":3,"dislike":1,"score":2,"quote":{"pid":"eb0d29201b12b307a863a713f65816f994400491","tid":721301,"uid":169964,"like":0,"dislike":0,"score":0,"quote":{"pid":"efbf6352a52ddd6a624b39a4154fdd4f9348e60b","tid":721301,"uid":112709,"like":1,"dislike":0,"score":1,"quote":{"pid":"397d5eb75a076be625a17d131d1799c2f653d647","tid":721301,"uid":169964,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-06-28T15:50:21.000Z","msg":"<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-28T16:01:54.000Z","msg":"<a href=\"https://youtu.be/GkhKgION1Sc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FGkhKgION1Sc&d=RYqZaRrScIHxWGlkNoPyFQRJEaK469wi7EMLOMkgk88%3D&h=0ecd3ff1\" target=\"_blank\">https://youtu.be/GkhKgION1Sc</a><br />\n<br />\n你應該係好呢味"},"citedBy":2,"replyTime":"2018-06-28T16:06:17.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-28T16:54:47.000Z","msg":"我係餐廳吧出身，但果陣炒散仔一個無諗過有得做。<br />\n做左一排都係頂唔到癮(本身自己一早中意同有好大興趣)膽粗粗問當時個bartender可唔可以做，一星期後，佢就做左我師傅帶左我入行，兩個半月前叫做自己總算學有所成，可以由白紙變做獨立企Bar撐起個檔，宜家跟埋師傅過檔做緊清Bar。<br />\n<br />\n辛酸野，我只會講入得呢行仲要當時係學徒仔一個，係會好多。我都同啲朋友講過，無興趣真係唔好只係為左貪Shake cocktail，調酒之類嘅動作好型而去做呢行。你去飲野望到個Bartender喺你面前shake得好型，但你唔會知佢過往落過幾多心機改進啲野。<br />\n<br />\n英文，你自己想做呢行都練下學下啦，好多酒名同Cocktail名要記，仲未計配料名同有時要同客吹下水。加油啦~"},{"pid":"2bc2dc2ab3e7f348435a01a63e25f64f75f81182","tid":721301,"uid":112709,"like":0,"dislike":1,"score":-1,"quote":{"pid":"64dbcabfb2217080cdfdd2cc9032d2ef40f92d3f","tid":721301,"uid":175077,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-28T16:47:07.000Z","msg":"你最鍾意邊款cocktail?"},"citedBy":0,"replyTime":"2018-06-28T16:56:33.000Z","msg":"兩隻，會睇心情飲<br />\nMojito<br />\nSex on the Beach"},{"pid":"1d6e26b3f35dbcf5783fc9eaf6d4a7a76b67d1ef","tid":721301,"uid":143351,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-28T16:58:17.000Z","msg":"幾千一個鐘"},{"pid":"c1f45e3f926fda510bf975116d60f55df8f11dfb","tid":721301,"uid":14065,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-28T16:58:21.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"a1d5436285dd7e0132f0fef905837ae39e9b3a5d","tid":721301,"uid":14065,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1f45e3f926fda510bf975116d60f55df8f11dfb","tid":721301,"uid":14065,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-28T16:58:21.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-28T16:59:56.000Z","msg":"睇到了"},{"pid":"ba584cb34b929d8854f57080cdd423f41243bf4d","tid":721301,"uid":112709,"like":0,"dislike":0,"score":0,"quote":{"pid":"3dd32cfacd8b72206356e07dc357a7b14c241891","tid":721301,"uid":36467,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-28T16:49:51.000Z","msg":"自己屋企玩咗年調酒。<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n重讀緊書想知呢行有冇唔係通宵<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-28T17:01:07.000Z","msg":"我都讀緊書，雖然已經暑假<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /> <br />\n入得呢行就要預左日夜癲到，什至難搵另一半，因為日頭就係你嘅夜晚會用來訓，夜晚就係你嘅日頭用來開工。理論上你日頭已經喺床到昏迷左唔會有時間拍拖，就算搵到另一半都大機會係夜貓來。<br />\n<br />\n利申，我已經係過緊0600訓，1500起床嘅生活<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"4556e5e455caa6f67f7e7863909a9efde2a63fbb","tid":721301,"uid":169964,"like":0,"dislike":0,"score":0,"quote":{"pid":"3bbfd9da1797a5c326fd76a8821d8811bf5a8057","tid":721301,"uid":112709,"like":3,"dislike":1,"score":2,"quote":{"pid":"eb0d29201b12b307a863a713f65816f994400491","tid":721301,"uid":169964,"like":0,"dislike":0,"score":0,"quote":{"pid":"efbf6352a52ddd6a624b39a4154fdd4f9348e60b","tid":721301,"uid":112709,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-06-28T16:01:54.000Z","msg":"<a href=\"https://youtu.be/GkhKgION1Sc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FGkhKgION1Sc&d=RYqZaRrScIHxWGlkNoPyFQRJEaK469wi7EMLOMkgk88%3D&h=0ecd3ff1\" target=\"_blank\">https://youtu.be/GkhKgION1Sc</a><br />\n<br />\n你應該係好呢味"},"citedBy":2,"replyTime":"2018-06-28T16:06:17.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-28T16:54:47.000Z","msg":"我係餐廳吧出身，但果陣炒散仔一個無諗過有得做。<br />\n做左一排都係頂唔到癮(本身自己一早中意同有好大興趣)膽粗粗問當時個bartender可唔可以做，一星期後，佢就做左我師傅帶左我入行，兩個半月前叫做自己總算學有所成，可以由白紙變做獨立企Bar撐起個檔，宜家跟埋師傅過檔做緊清Bar。<br />\n<br />\n辛酸野，我只會講入得呢行仲要當時係學徒仔一個，係會好多。我都同啲朋友講過，無興趣真係唔好只係為左貪Shake cocktail，調酒之類嘅動作好型而去做呢行。你去飲野望到個Bartender喺你面前shake得好型，但你唔會知佢過往落過幾多心機改進啲野。<br />\n<br />\n英文，你自己想做呢行都練下學下啦，好多酒名同Cocktail名要記，仲未計配料名同有時要同客吹下水。加油啦~"},"citedBy":1,"replyTime":"2018-06-28T17:01:41.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"243922bfb81885860f816f057f57cff28f18b4db","tid":721301,"uid":19973,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-28T17:04:06.000Z","msg":"見到呢個post<br />\n先醒起曾經我既夢想都係成為一個bartender<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"78d7c97ad3613ba43b1c837a7586089602afc665","tid":721301,"uid":112709,"like":0,"dislike":0,"score":0,"quote":{"pid":"1d6e26b3f35dbcf5783fc9eaf6d4a7a76b67d1ef","tid":721301,"uid":143351,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-28T16:58:17.000Z","msg":"幾千一個鐘"},"citedBy":0,"replyTime":"2018-06-28T17:04:56.000Z","msg":"好闊，睇你咩料咩經驗<br />\n<br />\n由$5X至$1XX/hr 不等"},{"pid":"2a8d287fb039d5c8ec6007f07a3cc411ced73f55","tid":721301,"uid":112709,"like":0,"dislike":0,"score":0,"quote":{"pid":"243922bfb81885860f816f05