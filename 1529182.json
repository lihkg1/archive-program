},{"pid":"bc71dc91bbef53e22b06a8955a5d6c0269ad4faa","tid":1529182,"uid":52230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T16:37:24.000Z","msg":"睇唔明"},{"pid":"3e7bffc7cdefb5ff2ad5109cbd995b11dc53d226","tid":1529182,"uid":288824,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T16:42:33.000Z","msg":"用玻璃刀先劃個交义, 扑兩下易爆好多"},{"pid":"4f21ba5380ee7a53a131f862c38cde4d5d7b67d4","tid":1529182,"uid":288824,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T16:45:17.000Z","msg":"<a href=\"https://zhidao.baidu.com/question/59030079.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzhidao.baidu.com%2Fquestion%2F59030079.html&d=c1rUz8TxCzzDRK4zYpKqdOdgoykoOisTuuABwIAScok%3D&h=375eb123\" data-auto-link target=\"_blank\">https://zhidao.baidu.com/question/59030079.html</a><br />\n<br />\n玻璃刀上有金刚石。金刚石磨有一个角度比较大但很尖锐的刃。用玻璃刀划过玻璃表面，刃就会在玻璃上留下一个底部很尖的槽。<br />\n<br />\n然后使玻璃带槽的这个面受拉，由于槽底很尖，存在很大的应力集中，脆性材料的玻璃很容易沿着这个槽裂开。"}]}