.000Z","msg":"推"},{"pid":"6dfee3353a1632f289d4088d8325b07cd859580c","tid":1270320,"uid":107498,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-30T23:00:13.000Z","msg":"twitch.tv/gbt_sky"},{"pid":"50a272d1728e74f34b75c55d1bd00c7810df9199","tid":1270320,"uid":235080,"like":0,"dislike":0,"score":0,"quote":{"pid":"6dfee3353a1632f289d4088d8325b07cd859580c","tid":1270320,"uid":107498,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-30T23:00:13.000Z","msg":"twitch.tv/gbt_sky"},"citedBy":0,"replyTime":"2019-06-30T23:00:44.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"657f42ee64c0de513451c11901f83421dcb92adc","tid":1270320,"uid":92230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T23:02:11.000Z","msg":"推"},{"pid":"f9cab5c81110f239e5935343681322c4c8935bd9","tid":1270320,"uid":69285,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T23:04:54.000Z","msg":"Push"},{"pid":"410c59aed8a3f2c3986bc6d5b8bd3ff1c1df9bd3","tid":1270320,"uid":98431,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-30T23:05:36.000Z","msg":"希望有人睇到<br />\n<br />\n勇武同送頭係有分別<br />\n<br />\n我明呢幾日好多事令大家氣餒 想今日盡地一煲<br />\n<br />\n但部份人感覺有D似自暴自棄 唔好攬炒 <br />\n<br />\n政權不痛不癢 心痛會既係香港人<br />\n<br />\n要留住血肉之軀 鬥長命阿!<br />\n<br />\n重申 唔係叫大家死忍 但要為自己留一線餘地"},{"pid":"9837db58b60a4703ddd476ca82cd8986e078dd18","tid":1270320,"uid":235080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T23:05:53.000Z","msg":"現場大量狗查身份證<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"dd197be5d7bb9c8bac0687e92bfe58a562191abf","tid":1270320,"uid":235080,"like":0,"dislike":0,"score":0,"quote":{"pid":"410c59aed8a3f2c3986bc6d5b8bd3ff1c1df9bd3","tid":1270320,"uid":98431,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-30T23:05:36.000Z","msg":"希望有人睇到<br />\n<br />\n勇武同送頭係有分別<br />\n<br />\n我明呢幾日好多事令大家氣餒 想今日盡地一煲<br />\n<br />\n但部份人感覺有D似自暴自棄 唔好攬炒 <br />\n<br />\n政權不痛不癢 心痛會既係香港人<br 