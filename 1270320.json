74f5f09aa1fe","tid":1270320,"uid":36478,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-01T04:06:55.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-01T04:38:53.000Z","msg":"sure why not<br />\n最緊要問懷疑犯邊條法+點解懷疑<br />\n上面有講過佢要講嘅理由!"},{"pid":"f667dfec21ba1bda3917b5df3ac769226523b05d","tid":1270320,"uid":145736,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:40:05.000Z","msg":"推"},{"pid":"24530e509a60e20be82e5dc49be4b421751a3f3f","tid":1270320,"uid":224323,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:47:15.000Z","msg":"推"},{"pid":"7963a55d5d62635a7c0d902d72787152902c85c9","tid":1270320,"uid":143805,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:49:38.000Z","msg":"推 好有用"},{"pid":"87d0d2a035d32e9debd54f421f2c9a9942dff06f","tid":1270320,"uid":67069,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:50:17.000Z","msg":"推"},{"pid":"d61a669f5fb67f8910b72a8a2d92cbcc4041f397","tid":1270320,"uid":36742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:50:27.000Z","msg":"推"}]}