7636dc135fbe7c388a6bdc","tid":1519243,"uid":212473,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T13:53:56.000Z","msg":"打得太多丁"},{"pid":"3e0640bf39e29f841664cb2754e427215fe63a41","tid":1519243,"uid":167330,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b82a32d9ec7bd571c7636dc135fbe7c388a6bdc","tid":1519243,"uid":212473,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T13:53:56.000Z","msg":"打得太多丁"},"citedBy":0,"replyTime":"2019-08-30T13:55:00.000Z","msg":"好耐之前開始已經每日一丁，應該唔關事"},{"pid":"f114c9b260a45f19c376e397ba6b9f4a6d5e68bd","tid":1519243,"uid":85644,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T18:41:01.000Z","msg":"肚餓咪再食囉 反正你食極唔肥<br />\n好過我呢啲夜晚肚餓要忍口"},{"pid":"2d083ca3d867d7ef2b543c6138d08e2fad0aaa58","tid":1519243,"uid":167330,"like":0,"dislike":0,"score":0,"quote":{"pid":"f114c9b260a45f19c376e397ba6b9f4a6d5e68bd","tid":1519243,"uid":85644,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T18:41:01.000Z","msg":"肚餓咪再食囉 反正你食極唔肥<br />\n好過我呢啲夜晚肚餓要忍口"},"citedBy":0,"replyTime":"2019-08-30T18:48:56.000Z","msg":"驚腸胃問題，平時唔係咁<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" />"},{"pid":"9e850440522afdc262552f964a8fbd1edcd1e33c","tid":1519243,"uid":51540,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T20:39:07.000Z","msg":"我幾個月前都試過係咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n食完飯都覺得好餓 係全日都餓嗰種 <br />\n嚴重嗰陣就算冇食嘢都會肚痾 <br />\n有諗過自己係咪肚生蟲<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><br />\n不過諗諗下覺得應該係關個胃事<img src=\"/assets/faces/lm2/think.gif\" class=\"hkgmoji\" /><br />\n因為嗰陣感冒咗成個月<br />\n冇睇醫生 日日都食必理痛 <br />\n可能就係咁傷咗個胃<br />\n之後好返抖咗半個月先正常返<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"7d0a2f4458997ba87d8eb2ce2cefd9fbff99535d","tid":1519243,"uid":258513,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-03T03:26:42.000Z","msg":"有時可能係口渴帶嚟嘅錯覺<br />\n試吓餓時飲水 如果係假餓飲完餓感會慢慢消失<br />\n如果依然係餓先食嘢"},{"pid":"c1cada18272fcb3d381ac2ecbc0fbb1fef05980b","tid":1519243,"uid":322304,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-13T15:04:43.000Z","msg":"此回覆已被刪除"}]}