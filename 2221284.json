le.gif\" class=\"hkgmoji\" />"},{"pid":"5030b8940b92c46ac6d05bb9a54fdea54897c7fe","tid":2221284,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-29T00:10:25.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"c5eb609af32c423cdfea54a3019dc104ce28b518","tid":2221284,"uid":120955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-29T00:11:23.000Z","msg":"整病毒梗係會整埋疫苗啦"},{"pid":"c2dd50bf5d5e286fce7e86b49a625de88e425896","tid":2221284,"uid":72994,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-29T00:37:12.000Z","msg":"人體實驗<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"43b8ad4cc86e9699ba6041f187f01e8fe0d83079","tid":2221284,"uid":237562,"like":0,"dislike":0,"score":0,"quote":{"pid":"fcca8e228534ba776a6568e2410eb05981ad1171","tid":2221284,"uid":274996,"like":11,"dislike":1,"score":10,"citedBy":4,"replyTime":"2020-09-28T23:08:24.000Z","msg":"以中共既習性，就算疫苗出事，由於政治任務高於一切，會下瞞上欺，修改紀錄，造假，令受害者封口，最後話疫苗完全安全有效。<br />\n<br />\n到大量生產時，中國人求求其其既性格，品質問題，假貨，過期貨，存儲不當就會大量發生。。。"},"citedBy":0,"replyTime":"2020-09-29T00:56:50.000Z","msg":"唔整啲渣嘢<br />\n點搵錢啊"},{"pid":"840f0f426a12114f3abd6c020333a6e0b83cfa72","tid":2221284,"uid":19126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-29T00:58:08.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"9d78654af63bb5b8fca6ae8fa7a38c7cb2940d78","tid":2221284,"uid":39796,"like":0,"dislike":0,"score":0,"quote":{"pid":"7e762a82d7af2c48b9bb0672fd8d7ffb77159643","tid":2221284,"uid":3457,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-09-28T23:19:09.000Z","msg":"香港警察優先喇"},"citedBy":0,"replyTime":"2020-09-29T01:02:03.000Z","msg":"呀蛇辛苦啦 執番劑疫苗先啦"},{"pid":"7be8025890d0ba1700ba80472b895ead965a25cf","tid":2221284,"uid":123738,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-29T01:02:52.000Z","msg":"支那係最好既試驗場，夠多支那狗可以用完即棄<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"}