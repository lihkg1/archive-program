c640c6f2a3b02a6bd3ff74de024c14bf0e1b9","tid":2124362,"uid":11067,"like":0,"dislike":0,"score":0,"quote":{"pid":"069012d79f061f4461caedf649ebf54d56fc29b9","tid":2124362,"uid":238186,"like":0,"dislike":5,"score":-5,"quote":{"pid":"857965bddc81f620c89cba6ca60ec9de509e8f67","tid":2124362,"uid":161767,"like":7,"dislike":0,"score":7,"citedBy":2,"replyTime":"2020-07-25T11:37:42.000Z","msg":"佢收左訂就賠錢囉<br />\n<br />\n口講既話<br />\n算鳩數啦"},"citedBy":1,"replyTime":"2020-07-25T11:41:47.000Z","msg":"啱呀，個牙叔將所有既歪理講到理所當然咁。佢唔gur既係遲過我到。但佢有錢佢大哂囉"},"citedBy":0,"replyTime":"2020-07-25T12:18:03.000Z","msg":"你買二手林寶？講到好貴咁<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"16aff8035addde1b78355f74da0b56289e58649f","tid":2124362,"uid":130797,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-07-25T12:18:54.000Z","msg":"如果我係賣家<br />\n又未收你訂 又無簽合約 <br />\n而另外又有個同價既人想買<br />\n梗係會揀個爽手即pay既<br />\n係佢角度黎講 又唔洗再sell你 <br />\n又唔洗再出黎俾你睇車之後可能搵到有野你唔岩心水<br />\n仲搞到佢無埋呢個即pay客<br />\n<br />\n當然有賣家係講信用講規矩 會覺得係你先就會留俾你<br />\n不過呢個case佢要決定賣俾邊個真係好易揀<br />\n<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"fadcafbec8ed639d5030301badb9d2aad100fb89","tid":2124362,"uid":14103,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-25T12:19:38.000Z","msg":"準備收<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"59d2ba033c091a85451d8bca57fad1ead9e1329b","tid":2124362,"uid":249874,"like":0,"dislike":0,"score":0,"quote":{"pid":"16f0d2474ebe6ae0c8f199eef83228fe5724100b","tid":2124362,"uid":184677,"like":12,"dislike":1,"score":11,"quote":{"pid":"ee11d0af5184c43edf5cf518313966935d6cf346","tid":2124362,"uid":238186,"like":2,"dislike":52,"score":-50,"quote":{"pid":"8e5e6bbb2ac1f974dc73b7867e3df9d41fcc930a","tid":2124362,"uid":4340,"like":6,"dislike":1,"score":5,"citedBy":1,"replyTime":"2020-07-25T11:24:02.000Z","msg":"其實究竟收咗你訂未，如果未收訂，咁唔怪得個車主喎"},"citedBy":7,"replyTime":"2020-07-25T11:31:32.000Z","msg":"準備收㗎啦，約緊驗車。但下個車主到左，佢走去娛樂個買家。佢suppose應該講我要左架車。個牙叔黎到望過架車，之後拉走左車主之之浸，車主就應該話我落訂/準備落訂，咁個阿叔見有機，就趁機約埋試車。個問題就黎啦，我係車主隔離，佢冇尊重過我。差啲打交。"},"citedBy":1,"replyTime":"2020-07-25T11:35:56.000Z","msg":"準備收<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-25T12:21:20.000Z","msg":"如果真係好想要嘅咁要睇下車主有無講過驗埋車就收訂之類嘅嘢 因為同車房佬成交一刻你個份仲算open contract 嘅話真係可以追<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n不過我認為搵過架會簡單得多<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dc02419e1943e86f148edda42bc106109afe7c30","tid":2124362,"uid":10044,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-25T12:21:30.000Z","msg":"你咪放相同車牌上嚟囉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n追就無得追架啦 <br />\n車房佬爭得都唔會咩貴車啦"},{"pid":"dffb35b69c7dae843dcbf17a8e4875a6691ace6d","tid":2124362,"uid":4340,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-07-25T12:23:02.000Z","msg":"我估你個出價同車行佬差唔多，咁如果我係車主，我都寧願賣比車行佬，因為煩少好多野<br />\n<br />\n車行佬收車通常唔會驗車，今日落訂，過2日比埋尾數，運輸處都唔使去，簽份合約就搞掂<br />\n<br />\n但如果賣比私人，又要約試車，又要約驗車，試完驗完又肯定比人壓下價，如果價錢相差唔遠，賣比車行佬乾手淨腳"},{"pid":"6cb9bec666423b162d791dadc83f6bd0cb3c1886","tid":2124362,"uid":260722,"like":6,"dislike":0,"score":6,"quote":{"pid":"1802964b1ef02edca3e430985bbeed35697def9c","tid":2124362,"uid":238186,"like":1,"dislike":17,"score":-16,"citedBy":1,"replyTime":"2020-07-25T11:10:14.000Z","msg":"多謝各位🙏長知識<br />\n我知道有份臨時買賣合約，可以同車主簽。<br />\n但冇諗過會遇到呢啲情況。"},"citedBy":1,"replyTime":"2020-07-25T12:23:25.000Z","msg":"你要驗車<br />\n末驗車前都唔肯定部車有冇問題<br />\n正常都末簽臨約及俾訂<br />\n<br />\n如果呢個時候有人先過你落訂<br />\n就一定係人哋嫁啦<br />\n<br />\n2手車買唔到呢部<br />\n咪等吓囉<br />\n買2手車最緊要有耐性"},{"pid":"bbd13d27627a5d97c4775c087fa5125c225c6df1","tid":2124362,"uid":238186,"like":0,"dislike":3,"score":-3,"quote":{"pid":"dc02419e1943e86f148edda42bc106109afe7c30","tid":2124362,"uid":10044,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-25T12:21:30.000Z","msg":"你咪放相同車牌上嚟囉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n追就無得追架啦 <br />\n車房佬爭得都唔會咩貴車啦"},"citedBy":0,"replyTime":"2020-07-25T12:23:57.000Z","msg":"無謂啦😂只希望新買家小心駕駛"},{"pid":"9987e7348b20d24d490e5e163362a6359bd54a65","tid":2124362,"uid":238186,"like":0,"dislike":7,"score":-7,"quote":{"pid":"6cb9bec666423b162d791dadc83f6bd0cb3c1886","tid":2124362,"uid":260722,"like":6,"dislike":0,"score":6,"quote":{"pid":"1802964b1ef02edca3e430985bbeed35697def9c","tid":2124362,"uid":238186,"like":1,"dislike":17,"score":-16,"citedBy":1,"replyTime":"2020-07-25T11:10:14.000Z","msg":"多謝各位🙏長知識<br />\n我知道有份臨時買賣合約，可以同車主簽。<br />\n但冇諗過會遇到呢啲情況。"},"citedBy":1,"replyTime":"2020-07-25T12:23:25.000Z","msg":"你要驗車<br />\n末驗車前都唔肯定部車有冇問題<br />\n正常都末簽臨約及俾訂<br />\n<br />\n如果呢個時候有人先過你落訂<br />\n就一定係人哋嫁啦<br />\n<br />\n2手車買唔到呢部<br />\n咪等吓囉<br />\n買2手車最緊要有耐性"},"citedBy":1,"replyTime":"2020-07-25T12:26:30.000Z","msg":"今鋪衰左冇禁定錢冇印定份約<br />\n當今世代，仲有邊個會帶cash係身😂"},{"pid":"cc91786eac50738a5c9755aa59671de8afcf59bf","tid":2124362,"uid":249874,"like":2,"dislike":1,"score":1,"quote":{"pid":"d5e3c0ba62433c6afc1b5431929c9b066097f986","tid":2124362,"uid":238186,"like":0,"dislike":20,"score":-20,"quote":{"pid":"dfb868ea152183b73713d152161bceecadbaa341","tid":2124362,"uid":189633,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-07-25T11:32:20.000Z","msg":"<span class=\"red\">我就決定俾訂再擇日驗車<br />\n之後就有個買家黎到</span><br />\n<br />\n決定俾訂，即係比左未？"},"citedBy":1,"replyTime":"2020-07-25T11:36:56.000Z","msg":"係未俾，車主口頭上決定左收訂，我亦都同意俾訂先，我地