":156547,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2018-05-13T07:24:10.000Z","msg":"樓上班友有冇睇清楚篇文內文<br />\n十幾年前架<br />\n蓋清意思係今日人手短缺，某程度係醫學會班醫生自己造成"},{"pid":"78a3847569ccfd0003d14d2c8eae2bfceafdffe3","tid":663191,"uid":46933,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2018-05-13T07:25:33.000Z","msg":"八萬五又反<br />\n醫生學額又反<br />\n九七打後果幾年根本係自毀長城"},{"pid":"95940684d411ffe40c263b986d46bebf50c821ce","tid":663191,"uid":51469,"like":0,"dislike":0,"score":0,"quote":{"pid":"8884f3e4de23af76fbe1a6c4ed0b9ca8b0f2506b","tid":663191,"uid":35815,"like":4,"dislike":0,"score":4,"quote":{"pid":"7e1736f9e8432381f266ced757977a5d21dc55a6","tid":663191,"uid":51469,"like":0,"dislike":0,"score":0,"quote":{"pid":"eddf662ff06aa2ab0c4cff0d42da56d523629bcf","tid":663191,"uid":35815,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2018-05-13T06:44:56.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-05-13T06:45:58.000Z","msg":"醫學會唔係醫管局喎<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2018-05-13T07:10:46.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-05-13T07:36:57.000Z","msg":"HA係支持醫改<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4c2f94ddebcf3dec7bd984c93a7a007d159af225","tid":663191,"uid":37869,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-05-13T07:46:05.000Z","msg":"佢又點估到中國會一車車咁送d廢中廢老落黎"},{"pid":"59edf8a0b22edb71282396a3b385f4e9cf841f4b","tid":663191,"uid":51469,"like":0,"dislike":0,"score":0,"quote":{"pid":"4c2f94ddebcf3dec7bd984c93a7a007d159af225","tid":663191,"uid":37869,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-05-13T07:46:05.000Z","msg":"佢又點估到中國會一車車咁送d廢中廢老落黎"},"citedBy":0,"replyTime":"2018-05-13T07:56:36.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d6de8c05bfcaea16b8830e3b5a3b4b9fa2670e74","tid":663191,"uid":140538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-13T08:00:14.000Z","msg":"hi ball"},{"pid":"5db77aa33fc3dadfa2a8c591bd2a70d5bf2c8928","tid":663191,"uid":51469,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-13T08:31:47.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b96d45e98c957fd5f0b169a935d041f40ea34763","tid":663191,"uid":57513,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-13T08:36:39.000Z","msg":"成班人無睇年份。<br />\n<br />\n睇呢篇野都知如果無支那人移民就吸會有醫療壓力<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"219abf0d0242ebbc947146640825a3d167aa7410","tid":663191,"uid":51469,"like":0,"dislike":0,"score":0,"quote":{"pid":"b96d45e98c957fd5f0b169a935d041f40ea34763","tid":663191,"uid":57513,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-13T08:36:39.000Z","msg":"成班人無睇年份。<br />\n<br />\n睇呢篇野都知如果無支那人移民就吸會有醫療壓力<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-13T09:17:20.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"https://www.inmediahk.net/node/1029611a\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1029611a&d=qRw7cheuvZB7jhbJTHvDN4zu7PIJYhBZqlGrkalTKs4%3D&h=f91ef806\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1029611a&h=5f5d170d\" target=\"_blank\">https://www.inmediahk.net/node/1029611a</a><br />\n<br />\n　　「單程證」起初沒有統一的審批準則，總之內地當局擁有全權，簽發配額限定為每日75個，獲批准者憑「前往港澳通行證」通過羅湖口岸進入香港，港方亦不會過問持證人基於什麼原因獲准定居香港。這種配額機制一直沿用至今，歷年來已為香港輸入過百萬人口，成為本港最主要的輸入人口政策。<span style=\"color: red;\">由於「單程證」配額有限而申請者眾，實行十多年來積壓了大量分隔家庭的申請個案，到1995年配額提高到每日150個</span>，而且建立一套分類及計分機制以決定各類別的批核次序。"},{"pid":"36586c4fbea87b95fd723b48da87b4a1eadb6660","tid":663191,"uid":57513,"like":0,"dislike":2,"score":-2,"quote":{"pid":"219abf0d0242ebbc947146640825a3d167aa7410","tid":663191,"uid":51469,"like":0,"dislike":0,"score":0,"quote":{"pid":"b96d45e98c957fd5f0b169a935d041f40ea34763","tid":663191,"uid":57513,"like":0,"dislike