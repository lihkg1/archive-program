58.000Z","msg":"咁食碘片會唔會有咩副作用？"},"citedBy":0,"replyTime":"2019-11-17T02:01:30.000Z","msg":"呢個我唔熟 <br />\n但本身醫學界同營養界都成日叫大家抗氧化抗癌<br />\n講返重點係抗氧化我地無手尾跟唔駛擔心"},{"pid":"ade6fb0d0347231dfc7de01a7f083fef5bfab65f","tid":1728464,"uid":85822,"like":0,"dislike":0,"score":0,"quote":{"pid":"8b39b23e75e7da0071e0df98977f80ac6410ca04","tid":1728464,"uid":8308,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-11-17T01:56:13.000Z","msg":"其實依d都係正常保健野<br />\n保健冇壞<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-17T02:02:04.000Z","msg":"啱喔<br />\n最緊要呢個時勢順便做多d <br />\n保障自己同屋企人"},{"pid":"35f95d3da1a42e739b37e6406b98be795f368f9e","tid":1728464,"uid":70417,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-11-17T02:02:15.000Z","msg":"Google下毒理先得唔得<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />唔係氧化<br />\n係氧化就唔會咁穩定"},{"pid":"fd208e1e6832efd20bac3aacc01309f04deb3242","tid":1728464,"uid":66559,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2019-11-17T02:03:09.000Z","msg":"Dioxin 咁毒係因為佢個coplanar structure，唔關咩氧化/自由基事<br />\n<br />\n你食再多抗氧化劑都無補於事<br />\n唯一解決方法係減少接觸/解決源頭<br />\n<br />\n利: 化學博士"},{"pid":"19c548f62818724a528d1ea317e7bbfb02cfa390","tid":1728464,"uid":194609,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-17T02:03:55.000Z","msg":"<img src=\"https://na.cx/i/scLGbK8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FscLGbK8.jpg&h=656e6394&s={SIZE}\" /><br />\n<a href=\"http://www.aqhi.gov.hk/tc/sub-download/sub-air-quality-reports/dioxin2019.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.aqhi.gov.hk%2Ftc%2Fsub-download%2Fsub-air-quality-reports%2Fdioxin2019.html&d=PiwLpsDni%2BEQUOLZDbBUzwX2xtV6HnGzrHUHOMeG36I%3D&h=c90b748f\" data-auto-link target=\"_blank\">http://www.aqhi.gov.hk/tc/sub-download/sub-air-quality-reports/dioxin2019.html</a>"},{"pid":"d13d9b89c16fad81718b8128a58f9bf2f687cd0b","tid":1728464,"uid":70417,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-11-17T02:04:29.000Z","msg":"另碘片唔可以亂食<br />\n極懷疑樓主係黎sell保健食品"},{"pid":"f77e030d4aad62857a70a6ae412d8410416b3156","tid":1728464,"uid":85822,"like":0,"dislike":2,"score":-2,"quote":{"pid":"d13d9b89c16fad81718b8128a58f9bf2f687cd0b","tid":1728464,"uid":70417,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-11-17T02:04:29.000Z","msg":"另碘片唔可以亂食<br />\n極懷疑樓主係黎sell保健食品"},"citedBy":0,"replyTime":"2019-11-17T02:05:56.000Z","msg":"我黎得大家食咩保健<br />\n我點控制<br />\n大家要長命贏共匪"},{"pid":"4a3920bf7c026f422b1ffb950a18d2ee669e68d2","tid":1728464,"uid":136700,"like":1,"dislike":0,"score":1,"quote":{"pid":"d13d9b89c16fad81718b8128a58f9bf2f687cd0b","tid":1728464,"uid":70417,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-11-17T02:04:29.000Z","msg":"另碘片唔可以亂食<br />\n極懷疑樓主係黎sell保健食品"},"citedBy":2,"replyTime":"2019-11-17T02:06:32.000Z","msg":"由唔好咁講既<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 樓主用意都只係想大家身體健康d啫。而且vitamin A, E呢d平時食普通食物都已經足夠。唔洗靠食supplement既"},{"pid":"1e2d8f67472e73f82de6cd08a68b86ae44286bdc","tid":1728464,"uid":209391,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-11-17T02:07:00.000Z","msg":"其實google下都知你個方法唔word 如果咁簡單就搞掂dioxin大家就唔使咁緊張啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n二噁英是一種細胞毒。以TCDD為例，其進入人體後將誘導&delta;-氨基乙酰丙酸合酶（Aminolevulinic acid synthetase,ALAS）的產生，此酶為血紅素合成的限速酶。過多的ALAS會破壞細胞組織，並可能表現出類似卟啉症的病徵[6]。二噁英可以誘導淋巴細胞凋亡，抑制殺傷性T細胞（cytotoxic T cell,Tc或CTL）的產生並促進免疫抑制因子的高度表達[7]，引起免疫系統調節功能障礙。二噁英亦能侵入DNA分子，誘發突變，由此而具有致畸與致癌作用。二噁英在體內不易代謝，可隨排泄物進入環境。"},{"pid":"afdc9058055baf9907e76b66c67cbdd58d446770","tid":1728464,"uid":66559,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-11-17T02:07:05.000Z","msg":"強烈懷疑樓主食人血饅頭<br />\n<br />\n借機sell所謂嘅保健產品 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n唔好諗住亂咁拋啲科學名詞出嚟就呃到人<br />\n<br />\n大把真正嘅專業人士有跟進二噁英單嘢"},{"pid":"9623f109b4177979e0696e323d3282e9896733ca","tid":1728464,"uid":209391,"like":1,"dislike":0,"score":1,"quote":{"pid":"d13d9b89c16fad81718b8128a58f9bf2f687cd0b","tid":1728464,"uid":70417,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-11-17T02:04:29.000Z","msg":"另碘片唔可以亂食<br />\n極懷疑樓主係黎sell保健食品"},"citedBy":0,"replyTime":"2019-11-17T02:07:44.000Z","msg":"有同感<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f6f3d0139f30cb8d849af3aeba9f776320cf9f4d","tid":1728464,"uid":125168,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T02:07:46.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"efea32a5102bd9da880c13456884d4744b1afd92","tid":1728464,"uid":312858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T02:07:48.000Z","msg":"二噁英入左人體就好難分解，食呢啲d保健野無L用<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />換新衫新gear好過<br />\n<br />\nPublic Health Significance of Dioxins<br />\n<br />\nDioxins <span style=\"font-size: large;\">dissolve in fat</span> in nature and are<span style=\"color: red;\"><span style=\"font-size: large;\"> not easily broken down</span></span>. They tend to accumulate in fatty tissues and are passed up the food chain from plants to animals to humans.<br />\n<br />\nReferences: <br />\nCentre for Food Safety<br />\nWorld Health Organization"},{"pid":"474887261ea4e4dda3c6b05c580ae5afb8e421bd","tid":1728464,"uid":70417,"like":7,"dislike":0,"score":7,"quote":{"pid":"4a3920bf7c026f422b1ffb950a18d2ee669e68d2","tid":1728464,"uid":136700,"like":1,"dislike":0,"score":1,"quote":{"pid":"d13d9b89c16fad81718b8128a58f9bf2f687cd0b","tid":1728464,"uid":70417,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-11-17T02:04:29.000Z","msg":"另碘片唔可以亂食<br />\n極懷疑樓主係黎sell保健食品"},"citedBy":2,"replyTime":"2019-11-17T02:06:32.000Z","msg":"由唔好咁講既<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 樓主用意都只係想大家身體健康d啫。而且vitamin A, E呢d平時食普通食物都已經足夠。唔洗靠食supplemen