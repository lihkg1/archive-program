.cx/i/U5kpCHq.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FU5kpCHq.png&h=4602514d&s={SIZE}\" />"},{"pid":"95ab07cd6c1f8835aae0e190df09191c68342bc2","tid":1458044,"uid":4948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T15:13:12.000Z","msg":"<img src=\"https://na.cx/i/U5kpCHq.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FU5kpCHq.png&h=4602514d&s={SIZE}\" />"},{"pid":"430584fc01b25e93d18e098201e630365f9e0397","tid":1458044,"uid":297672,"like":0,"dislike":0,"score":0,"quote":{"pid":"c2dd6e6617d7e121e47a526341e679ecd6852733","tid":1458044,"uid":280436,"like":7,"dislike":1,"score":6,"citedBy":1,"replyTime":"2019-08-12T12:56:07.000Z","msg":"【散 定唔散 都係政府個局入面】<br />\n<br />\n政府<span style=\"color: red;\"><span style=\"font-size: medium;\">操縱緊我地嘅言論</span></span>去<span style=\"color: red;\"><span style=\"font-size: large;\">分化</span></span>勇武同和理非<br />\n<br />\n<span style=\"color: red;\">如果散</span> <br />\n就發表大量<span style=\"color: red;\"><span style=\"color: red;\"><span style=\"font-size: large;\">屌撚散水狗</span></span></span>嘅言論<br />\n馬後砲<br />\n指責班合理擔心安全嘅和理非<br />\n<span style=\"color: blue;\"><span style=\"font-size: x-large;\">be water</span></span>係大家一直以來重視嘅嘢<br />\n根本勇武唔會怪責<br />\n可見係政府故意引起割席<br />\n<br />\n如果<span style=\"color: red;\">唔散</span><br />\n警察真係做嘢<br />\n就會湧現和理非怪責勇武嘅言論<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: gold;\">一切 都係政府設下嘅套路！</span></span><br />\n<br />\n今日真係有取消/延誤航班 <br />\n警察真係有佈防 而且有機會用得到<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">但真正目的並非實質行動<br />\n而係分化大家</span></span><br />\n<br />\n最近安插臥底係前線同樣<br />\n都有一層目的係為左令尼場運動嘅參與者<span style=\"color: red;\"><span style=\"font-size: xx-large;\">自行瓦解</span></span><br />\n<br />\n大量網軍混入連登，Facebook，telegram<br />\n散播謠言<br />\n令大家<span style=\"color: red;\">質疑</span>盟友嘅可信性<br />\n<span style=\"color: red;\"><span style=\"font-size: large;\">互相猜忌</span></span><br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: xx-large;\">請大家千奇唔好中政府嘅詭計</span></span><br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: x-large;\">謹記 不分化 不割席</span></span><br />\n<br />\n佢嘅陰濕招數 我地只要團結 一定搵到方法破解"},"citedBy":0,"replyTime":"2019-08-12T15:14:44.000Z","msg":"屌評唔到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />推你"},{"pid":"808d12fdddbfadb1d1717bbd7b804298e4c9006b","tid":1458044,"uid":110509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T15:32:48.000Z","msg":"PUSH"},{"pid":"87475899071fddce29fa4f878ecb920f8dfe70cd","tid":1458044,"uid":157304,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T15:54:56.000Z","msg":"光復香港 時代革命"},{"pid":"2f93c0e3f37e24cf74b5b9233c9d01c33e241af9","tid":1458044,"uid":15625,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T16:45:29.000Z","msg":"push"},{"pid":"d5e0d7ae93d76b5566b33ee4f194396d38e30ca3","tid":1458044,"uid":157304,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T16:49:58.000Z","msg":"光復香港 時代革命"},{"pid":"08140864ba5311cfc15f6a3af44339394f21783d","tid":1458044,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T16:51:51.000Z","msg":"要諗定認對方法 唔好到時先"}]}