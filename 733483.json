":"a70d5995222e7be5d76906f776d592dc3114fd1c","tid":733483,"uid":79495,"like":0,"dislike":10,"score":-10,"citedBy":1,"replyTime":"2018-07-08T00:46:09.000Z","msg":"無知一問，OLED 係咪比較護眼過LCD?"},{"pid":"aebbf7835bb559fbce2786519581d84ebde63e78","tid":733483,"uid":36791,"like":4,"dislike":1,"score":3,"quote":{"pid":"735e19fb4e743a46f6e60fe6f88a913c58432395","tid":733483,"uid":23677,"like":5,"dislike":49,"score":-44,"quote":{"pid":"406dd5442b22c53eca99e4a8d5d110179aae2243","tid":733483,"uid":64457,"like":11,"dislike":2,"score":9,"quote":{"pid":"650f19ca815e7233d12821c0e886643182f6fb98","tid":733483,"uid":60231,"like":56,"dislike":3,"score":53,"citedBy":1,"replyTime":"2018-07-07T19:58:34.000Z","msg":"中共：小小香港出埋晒d咁高汁既野？ 唔得咁樣既<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-07-07T21:23:03.000Z","msg":"好快會話係中国自主研發<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-07-07T21:39:05.000Z","msg":"黨報01個標題已經講左 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n<strong><span style=\"color: red;\">科大國家重點實驗室研發FLCD顯示器技術　解像度增近3倍成本反降</span></strong><br />\n<br />\n國家中央科技部和財政部早前宣布，日後本港大學及科研機構，可直接向中央財政科技計劃申請項目經費，實現「科研資金過河」，而香港科技大學先進顯示與光電子技術國家重點實驗室團隊，則研發出「有源驅動鐵電液晶顯示器（FLCD）」技術。<br />\n<br />\nFLCD技術理論上像素密度可達2,500 ppi（每英寸像素），較一般常見顯示器的700 ppi增加逾三倍。與此同時，新技術能減少電力損耗，更能減少高達三成製造成本。科大研究人員表示，正與數間屏幕生產商洽談合作，希望一年後能推出應用FLCD技術的屏幕產品。<br />\n<br />\n<a href=\"https://www.hk01.com/社會新聞/204471/科大國家重點實驗室研發flcd顯示器技術-解像度增近3倍成本反降\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%E7%A4%BE%E6%9C%83%E6%96%B0%E8%81%9E%2F204471%2F%E7%A7%91%E5%A4%A7%E5%9C%8B%E5%AE%B6%E9%87%8D%E9%BB%9E%E5%AF%A6%E9%A9%97%E5%AE%A4%E7%A0%94%E7%99%BCflcd%E9%A1%AF%E7%A4%BA%E5%99%A8%E6%8A%80%E8%A1%93-%E8%A7%A3%E5%83%8F%E5%BA%A6%E5%A2%9E%E8%BF%913%E5%80%8D%E6%88%90%E6%9C%AC%E5%8F%8D%E9%99%8D&d=s3HBX4posvzDLP5f%2Fuwbz54f2li5K%2Fs6EGgmwhp