6:40.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">WHATEVER IT TAKES</span></strong></span>"},{"pid":"c279fa6ba8a552e8c4db117900e01df7ba3eed1d","tid":1478894,"uid":155462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T17:22:49.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">WHATEVER IT TAKES</span></strong></span>"},{"pid":"87afd6bd47b8eada5baaf4dd46ce3826ef6cbb32","tid":1478894,"uid":155462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T17:28:40.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">WHATEVER IT TAKES</span></strong></span>"},{"pid":"561632b3354a16ec4cd0fc5f9aee5b12c7e07c3f","tid":1478894,"uid":255563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T21:19:29.000Z","msg":"push"},{"pid":"ca925342d00c58d77295d6a34a7bc0c1200a7b13","tid":1478894,"uid":2861,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T19:05:44.000Z","msg":"Push"},{"pid":"2ac8d953651307a331d5d0ad26dedb55ad3bded5","tid":1478894,"uid":257422,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T19:10:32.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"33fb5ade2b3938151736b0f40940bb08e1da4c65","tid":1478894,"uid":7807,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T19:20:11.000Z","msg":"無錯係咁玩喇🤘🏻"},{"pid":"1e34f70a1e44ebaf9970c6137a673e10ac816637","tid":1478894,"uid":12517,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T19:51:06.000Z","msg":"呢d「和平」光環係抗爭包袱<br />\n事實上前線一d都唔和平<br />\n呢d完左個運動先搞啦"},{"pid":"4620f8c70186f9146212ab0e5b68f428ede1b1a5","tid":1478894,"uid":115467,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T19:54:08.000Z","msg":"林鄭: 多謝，世界都認同我領導下既香港人<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e781365af0ab04f59d56a3a3891462bcf722e19a","tid":1478894,"uid":115467,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T19:54:59.000Z","msg":"林鄭: 多謝，世界都認同我領導下既香港<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}