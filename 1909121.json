score":0,"citedBy":0,"replyTime":"2020-03-04T02:09:51.000Z","msg":"推"},{"pid":"6674a4b9b58d1d6e6cb72ce23257b84073cfcfc7","tid":1909121,"uid":252596,"like":0,"dislike":0,"score":0,"quote":{"pid":"19f8a42fb1940cd4ba103a6a854b146f227c642d","tid":1909121,"uid":36716,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-03T17:51:52.000Z","msg":"<img src=\"https://na.cx/i/RJPOS6V.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRJPOS6V.jpg&h=f1838512&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-03-04T02:11:23.000Z","msg":"推"},{"pid":"9be3912a8037dc0cdbf13d99a75a982fba98e455","tid":1909121,"uid":36716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-04T02:29:02.000Z","msg":"Push"},{"pid":"af7cd1b2ea78c8ebb5909ccde6d37136fbe5b971","tid":1909121,"uid":11013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-04T02:37:05.000Z","msg":"幫推 <br />\n<br />\n唔好意思 借一借位<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n和理非 手足 家長 學生都請入黎 <br />\n<br />\ntg 支足channel<br />\n<a href=\"https://t.me/materials201920\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fmaterials201920&d=VxC68O7S0S1nNKmf4pYeIQjMvzJQG4GdM8cyRMJzdLg%3D&h=83045776\" data-auto-link target=\"_blank\">https://t.me/materials201920</a>"},{"pid":"9e7dd52497039140336e69484a61fa044b7690fd","tid":1909121,"uid":60259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-04T02:38:22.000Z","msg":"Pushhh"},{"pid":"2595607199eaa04ed6f39a36ed6e22012c041817","tid":1909121,"uid":60434,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-04T02:39:17.000Z","msg":"周梓樂冇得投功能組別"},{"pid":"00e88249512d0de2a69af00df5752f980e45e0e3","tid":1909121,"uid":36716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-04T02:39:26.000Z","msg":"Push"},{"pid":"8a9965ad0a0aff69742b2326e89c5762fd990bdb","tid":1909121,"uid":45910,"like":3,"dislike":0,"s