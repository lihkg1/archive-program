=\"_blank\">https://lihkg.com/thread/1186605/page/1</a>"},{"pid":"5f1feb1920622c4600472e680a89978f47ff1693","tid":1185690,"uid":171192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-07T10:30:24.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ae8f63748bef4c0d5bc29d58d832abc1a9496c49","tid":1185690,"uid":237496,"like":0,"dislike":0,"score":0,"quote":{"pid":"3f0c5f9e22caa9d431152d5c98ff94677df16992","tid":1185690,"uid":92376,"like":2,"dislike":0,"score":2,"quote":{"pid":"2679e5f4d33e9f6b9eb294445b982971ee2058b6","tid":1185690,"uid":77731,"like":7,"dislike":1,"score":6,"citedBy":3,"replyTime":"2019-06-04T13:26:06.000Z","msg":"咁樣出人全相<br />\n唔怪得俾廢中話民主派係弱智"},"citedBy":1,"replyTime":"2019-06-04T15:08:26.000Z","msg":"屌你知唔知全相點解架<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><br />\n如果有全相睇我又真係唔拘呀<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-08T10:55:59.000Z","msg":"你就真係唔知點解<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />&nbsp;依個詞本身係出自吐蕃最早期咖佛教經文.<br />\n例如全相, 真相, 表相, 本相, 有相同無相等等...<br />\n全相一路都係解「完全同原本既樣貌」. <br />\n多年混族後中原好多歷史文化都係由民間既人傳播開,<br />\n同一個詞係唔同年代都有唔同既解釋, 係好亂咖<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n<br />\n而粵港台多地漢化最嚴重, 連自己列祖列宗個姓點黎都已經冇曬記錄.<br />\n偏西南較早發展依家較落後既廣東地區都仲有記錄<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n而你地既粵語同用詞, 大多數係中央70年洗腦洗出黎咖漢字翻譯黎.<br />\n部份係由魯迅個代人係日本上堂傳返黎<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"}]}