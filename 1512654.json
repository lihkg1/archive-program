w%3D1&d=zAhFImnUcMh%2FonyB55KWQy%2F0jIrp0bHqVoz25JuQVd4%3D&h=a8dcd132\" data-auto-link target=\"_blank\">https://docs.google.com/forms/d/e/1FAIpQLSe-vNbJsdOviermmz3NGLPkXZN0GvOPKkkTrDb8QxaeS35C7w/viewform?vc=0&amp;c=0&amp;w=1</a><br />\n<br />\n<img src=\"https://na.cx/i/Yi8wPfF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FYi8wPfF.jpg&h=e926e235&s={SIZE}\" /><img src=\"https://na.cx/i/akg2VVG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fakg2VVG.jpg&h=1780cd27&s={SIZE}\" />"},{"pid":"a4ba94b9792891147e16755a70f1d1cdc42d0bff","tid":1512654,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T03:45:33.000Z","msg":"<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"b83067de70acc954ada9028c4228cd7b34175c75","tid":1512654,"uid":65686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T03:46:34.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />快通過，我唔想返工"},{"pid":"11a14974e99c085d6dc96b5097855ab31706a0fd","tid":1512654,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T03:46:50.000Z","msg":"<strong>盛智文認為現階段毋須引用緊急法</strong><br />\n對於行政長官林鄭月娥昨日提出推行緊急法來止暴制亂，本身是商人的團結香港基金理事盛智文認為，現階段未需要推行，因為香港激進示威者已變得愈來愈少，如果未來的示威方式太暴力，林鄭月娥推行緊急法是可以接受。<br />\n<br />\n盛智文又認為，市民提出的五大訴求，需與政府進行溝通及對話，不能只單一提出而不作溝通協商。他期望政府能盡快停止暴力，讓社會回復平靜。<br />\n<br />\n被問到如果推行緊急法會否對大灣區項目帶來嚴重影響，他表示一定會對經濟有影響，但相信香港有能力再重新建設起來。<br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1477258-20190828.htm?spTabChangeable=0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1477258-20190828.htm%3FspTabChangeable%3D0&d=zAhFImnUcMh%2FonyB55KWQy%2F0jIrp0bHqVoz25JuQVd4%3D&h=48aea8e8\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1477258-20190828.htm%3FspTabChangeable%3D0&h=9de96b13\" target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1477258-20190828.htm?spTabChangeable=0</a><br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"ed4fb520a9370bbe25d65be5d37e796156b5485f","tid":1512654,"uid":132999,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-28T03:48:22.000Z","msg":"商家佬人哋叫你跪就跪<br />\n其實咪又係 condom<br />\n<br />\n講真到時有雙普選<br />\n重有 so 其實係班商人<br />\n因為選舉始終講錢<br />\n但係又無紅底嘅負擔"},{"pid":"5529c56ded30287d5f312730b0550a5aace5d95a","tid":1512654,"uid":255637,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-28T03:48:35.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 商界全部笠水<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />攬炒之母"},{"pid":"78a6d8d6df82fae2237a34c8dc429ca6f19b91be","tid":1512654,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T03:49:42.000Z","msg":"<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"e2f5b21e83e443d836d99c78d25730cbf88f50fe","tid":1512654,"uid":73340,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-28T03:51:33.000Z","msg":"用經濟去計<br />\n緊急法簡直係幫助大家重新洗牌<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a80a041a37f12bec282ab75514928387b84000cc","tid":1512654,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T03:51:35.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{