span style=\"color: orange;\">雙手奉上</span></strong><br />\n<img src=\"https://upload.cc/i1/2019/09/02/9dojRG.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2019%2F09%2F02%2F9dojRG.png&h=baf47345&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/JXMrzU3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJXMrzU3.jpg&h=4fd76574&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/uZFWW8o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuZFWW8o.jpg&h=4196affc&s={SIZE}\" />"},{"pid":"2a774e78fdf3bddd0e802babd6211a82dbbdccc9","tid":1541993,"uid":112910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T17:19:30.000Z","msg":"6/10 推啊"},{"pid":"f213dcef76d47c612b8d81f88430ee565d1ec547","tid":1541993,"uid":112910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T17:19:41.000Z","msg":"7/10"},{"pid":"9389977bdc969d99f5561d0639ae3637b067c804","tid":1541993,"uid":112910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T17:19:51.000Z","msg":"8/10"},{"pid":"74f56ac11d56c4a1ace774735e606f779c5257bf","tid":1541993,"uid":112910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T17:20:03.000Z","msg":"9/10"},{"pid":"70f82b9e73f742e5f63742d940d711407f92a32f","tid":1541993,"uid":127333,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-09-04T17:20:19.000Z","msg":"淆底既話 買單程票再跳好似好啲"},{"pid":"88b637d3b4e4dc47567049c20f553aaaceb290d7","tid":1541993,"uid":112910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T17:20:19.000Z","msg":"10/10 聽日再推"},{"pid":"2eb73a1573231acd3154ec6b32c7ce30b3943ce8","tid":1541993,"uid":212336,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-04T17:21:58.000Z","msg":"跳又唔跳推又無種,返屋企含撚啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"7fbbb849700da6cb246da38d4ca2767d5a3b669c","tid":1541993,"uid":201011,"like":0,"dislike":0,"score":0,"citedBy":0,"r