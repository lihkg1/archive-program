」<br />\n<br />\n<img src=\"https://na.cx/i/Mn6qcoq.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FMn6qcoq.png&h=373d935d&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-09-14T11:24:46.000Z","msg":"達賴=大中華膠"},{"pid":"28de12acc4a053f9368d811bedfab7ae0065f2b3","tid":2202024,"uid":55089,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-14T11:29:54.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"f06fcae8531b3cca34db0c8b8a71ccf49f35b2f6","tid":2202024,"uid":279326,"like":3,"dislike":0,"score":3,"quote":{"pid":"bc81e62acbea869876938633aecc643e84164b3d","tid":2202024,"uid":290118,"like":15,"dislike":1,"score":14,"citedBy":1,"replyTime":"2020-09-14T09:23:34.000Z","msg":"<img src=\"http://www.ipkmedia.com/wp-content/uploads/2020/01/%E9%99%B3%E5%B7%A7%E6%96%87-%E4%BA%BA%E6%AC%8A-20200113204414_1249_large.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.ipkmedia.com%2Fwp-content%2Fuploads%2F2020%2F01%2F%25E9%2599%25B3%25E5%25B7%25A7%25E6%2596%2587-%25E4%25BA%25BA%25E6%25AC%258A-20200113204414_1249_large.png&h=2dcafd08&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-09-14T11:36:56.000Z","msg":"祖師爺"},{"pid":"09343e15ef0ff478dee5f857e8af748241cdba8c","tid":2202024,"uid":8091,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-14T11:39:48.000Z","msg":"推"},{"pid":"97e39b5398b7acabdf8119fe223e410a78ed54db","tid":2202024,"uid":45089,"like":0,"dislike":0,"score":0,"quote":{"pid":"a38e000e6736bd853eaa247e78ea2a1fa544e5b9","tid":2202024,"uid":25601,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-09-14T10:06:25.000Z","msg":"其實我覺得只要攻得入西藏門口 西藏入面既人會一齊起義<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"r