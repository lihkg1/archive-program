e90e0296a364b95e","tid":1683131,"uid":200873,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-30T14:10:12.000Z","msg":"哎呀<br />\n就是霸凌呀<br />\n香港是這樣叫嗎<br />\n<br />\n有一些同學不斷的欺負我<br />\n還有一些 例如 升年級之後的壓力啊<br />\n然後到某一天就突然崩潰<br />\n<br />\n我的手指也被我咬的很慘<br />\n（咬手指+指甲是很焦慮的行為<br />\n不太會拍 抱歉<img src=\"https://na.cx/i/sCjpNre.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsCjpNre.jpg&h=399d7b26&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/NVao2ZD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNVao2ZD.jpg&h=2085e966&s={SIZE}\" />"},{"pid":"5f949a1e5b9d5b9ceac9d679a6e5e8b783d7e222","tid":1683131,"uid":200873,"like":0,"dislike":0,"score":0,"quote":{"pid":"8e0088e17dd27f838f290d6af450cb98788e2469","tid":1683131,"uid":269202,"like":0,"dislike":0,"score":0,"quote":{"pid":"69a77b7ac39b343989209d08a99095d1b2b167bd","tid":1683131,"uid":200873,"like":0,"dislike":0,"score":0,"quote":{"pid":"e9277d599cdc5a7b20febfcdd04fa7b29f9252bf","tid":1683131,"uid":269202,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-30T13:32:59.000Z","msg":"關於什麼事？<br />\n<br />\n台灣需要年青人的團結力量，每一分都需要"},"citedBy":1,"replyTime":"2019-10-30T13:41:22.000Z","msg":"同學+各種小事<br />\n全部加在一起"},"citedBy":1,"replyTime":"2019-10-30T14:09:22.000Z","msg":"多花點時間愛自已"},"citedBy":1,"replyTime":"2019-10-30T14:11:28.000Z","msg":"啊啊啊<br />\n謝謝你 我會加油<br />\n我現在也把班上一些事推掉<br />\n讓自己輕鬆一點"},{"pid":"aa0d123556679d61199e0bcfcf840d4cdc248887","tid":1683131,"uid":269202,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f949a1e5b9d5b9ceac9d679a6e5e8b783d7e222","tid":1683131,"uid":200873,"like":0,"dislike":0,"score":0,"quote":{"pid":"8e0088e17dd27f838f290d6af450cb98788e2469","tid":1683131,"uid":269202,"like":0,"dislike":0,"score":0,"quote":{"pid":"69a77b7ac39b343989209d08a99095d1b2b167bd","tid":1683131,"uid":200873,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-30T13:41:22.000Z","msg":"同學+各種小事<br />\n全部加在一起"},"citedBy":1,"replyTime":"2019-10-30T14:09:22.000Z","msg":"多花點時間愛自已"},"citedBy":1,"replyTime":"2019-10-30T14:11:28.000Z","msg":"啊啊啊<br />\n謝謝你 我會加油<br />\n我現在也把班上一些事推掉<br />\n讓自己輕鬆一點"},"citedBy":0,"replyTime":"2019-10-30T14:17:50.000Z","msg":"你還懂得這些，也不算太差呀<br />\n你需要重新啟動一下<br />\n先守好以下守則令自已處最佳狀態：<br />\n睡7小時，吃健康，好的食物，運動<br />\n<br />\n然後才是工作。要對準台灣最需要你的地方<br />\n班級上，功課上的事，只是很短暫的<br />\n<br />\n你會到連登上來，你也是知情者吧（在中國假新聞包圍網外的人）<br />\n不要浪費時間在對你無益的人，要多和有益的人在一起"},{"pid":"d0804e16fbc2b9171509b6075cbbc2a5d7fafc7e","tid":1683131,"uid":319312,"like":0,"dislike":0,"score":0,"quote":{"pid":"34f44c075d26bb55b49baef4e90e0296a364b95e","tid":1683131,"uid":200873,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-30T14:10:12.000Z","msg":"哎呀<br />\n就是霸凌呀<br />\n香港是這樣叫嗎<br />\n<br />\n有一些同學不斷的欺負我<br />\n還有一些 例如 升年級之後的壓力啊<br />\n然後到某一天就突然崩潰<br />\n<br />\n我的手指也被我咬的很慘<br />\n（咬手指+指甲是很焦慮的行為<br />\n不太會拍 抱歉<img src=\"https://na.cx/i/sCjpNre.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsCjpNre.jpg&h=399d7b26&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/NVao2ZD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNVao2ZD.jpg&h=2085e966&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-10-30T14:20:28.000Z","msg":"我之前也試過整個人崩潰 短期的焦慮抑鬱是正常的 只要不超過六個月就沒有問題 這段時間停下手頭上的工作 好好面對自己的心情 不要選擇去逃避 不需強顏歡笑 好好抒發 好好發洩一下 然後再計劃一下將來 不用急慢慢來 也許轉個新環境對你有用"},{"pid":"d442184e5304b8f13a5be67396071c7f6e52caef","tid":1683131,"uid":200873,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-30T14:25:28.000Z","msg":"唉<br />\n我是中共包圍網之外的之外<br />\n<br />\n我會試試看你們的建議<br />\n謝謝<br />\n<br />\n是說 我要申請自學<br />\n你們如何看<br />\n覺得可以？？"},{"pid":"0867a2a02c1779e11581c2bccc5ea0af5b292e77","tid":1683131,"uid":200873,"like":0,"dislike":0,"score":0,"quote":{"pid":"d0804e16fbc2b9171509b6075cbbc2a5d7fafc7e","tid":1683131,"uid":319312,"like":0,"dislike":0,"score":0,"quote":{"pid":"34f44c075d26bb55b49baef4e90e0296a364b95e","tid":1683131,"uid":200873,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-30T14:10:12.000Z","msg":"哎呀<br />\n就是霸凌呀<br />\n香港是這樣叫嗎<br />\n<br />\n有一些同學不斷的欺負我<br />\n還有一些 例如 升年級之後的壓力啊<br />\n然後到某一天就突然崩潰<br />\n<br />\n我的手指也被我咬的很慘<br />\n（咬手指+指甲是很焦慮的行為<br />\n不太會拍 抱歉<img src=\"https://na.cx/i/sCjpNre.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsCjpNre.jpg&h=399d7b26&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/NVao2ZD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNVao2ZD.jpg&h=2085e966&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-10-30T14:20:28.000Z","msg":"我之前也試過整個人崩潰 短期的焦慮抑鬱是正常的 只要不超過六個月就沒有問題 這段時間停下手頭上的工作 好好面對自己的心情 不要選擇去逃避 不需強顏歡笑 好好抒發 好好發洩一下 然後再計劃一下將來 不用急慢慢來 也許轉個新環境對你有用"},"citedBy":1,"replyTime":"2019-10-30T14:41:49.000Z","msg":"有 我媽媽現在每天下課後<br />\n都帶我去不同地方 寫功課<br />\n和 歌詞<br />\n<br />\n我其實真的逃避<br />\n（最高等級的 自殺 <br />\n我前天晚上拿著刀子<br />\n走到我媽媽房門前（我腳步聲大 他有聽到<br />\n他來開門之後 我趕快把刀子往旁邊的盒子裡放<br />\n也還好是他來開門 不然真的刺下去"},{"pid":"23877f28c376a2f9b7c0d6000f1e96583dfa9d2b","tid":1683131,"uid":85852,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-30T15:08:52.000Z","msg":"可以試試自學，再不行的話可能要轉學。平時可以去夜市射射氣球、去湯姆熊跟小朋友玩。切記生命誠可貴"}]}