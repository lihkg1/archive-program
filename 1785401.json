m/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dogxm/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dogxm/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dogxm/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"c6ad36a01124c8337f64ed1e7804b3c8339d8397","tid":1785401,"uid":208940,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-17T00:05:02.000Z","msg":"D手套成日過底，戴左等於無戴，把撚"},{"pid":"1c8ee803a0c84d0fb19721a14f3b222376e15ccc","tid":1785401,"uid":276273,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-17T00:06:27.000Z","msg":"藍店不了"},{"pid":"1130994fa367171bbfb4b04aa90798081c382918","tid":1785401,"uid":29726,"like":0,"dislike":0,"score":0,"quote":{"pid":"e0b2a781093d6de935aaf8ab8b78f578dfb54b7f","tid":1785401,"uid":266716,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-12-16T12:33:26.000Z","msg":"見過啲阿伯有kfc阿姐餵"},"citedBy":0,"replyTime":"2019-12-17T00:10:34.000Z","msg":"<img src=\"/assets/faces/pigxm/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"32960dcb475dbd55bb03fe64b3e4bcd79c4bc74e","tid":1785401,"uid":107681,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-17T00:12:09.000Z","msg":"我fd上次冇戴，咁就奶左野，醫生話冇得醫<img src=\"/assets/faces/pigxm/arrested_g.gif\" class=\"hkgmoji\" />"},{"pid":"523ed9ab52e751ec42ad2143f738edc784b9dd58","tid":1785401,"uid":49178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-17T00:14:13.000Z","msg":"怡和不了"},{"pid":"8227a2981887c19b98092f0514bba3010f4f6e82","tid":1785401,"uid":196552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-17T00:16:43.000Z","msg":"緊係唔帶<img src=\"/assets/faces/dogxm/treat.gif\" class=\"hkgmoji\" /><br />\n問佢攞刀叉切黎食<img src=\"/assets/faces/dogxm/wet.gif\" class=\"hkgmoji\" />"},{"pid":"d7154ca5aeaaed9142a584e1332e210eca7dccf2","tid":1785401