0:47.000Z","msg":"push <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"9d95f0b7df23aa0f1c0addbb2d8b1cdf64fbc437","tid":2100074,"uid":170143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-08T21:22:03.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"c25a5c1fd72da2e08f11ca5c24b7bf814549ee22","tid":2100074,"uid":90601,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-08T21:22:20.000Z","msg":"<span class=\"x-large\"><span class=\"red\">初選注意事項：</span></span><br />\n<br />\n要帶 (任何一樣)<br />\n1. 住址證明<br />\n2. 官方選舉選民通知書<br />\n3. 選民登記網站截圖（呢度cap）(最好cap定先<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />)<br />\n<a href=\"https://www1.voterinfo.gov.hk/bd_reovi/OVIES/jsp/mob/index.jsp\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww1.voterinfo.gov.hk%2Fbd_reovi%2FOVIES%2Fjsp%2Fmob%2Findex.jsp&d=LWtkxptWC%2F4RDCuqQUibmnwvfzOYOHHotQSumXQzHeA%3D&h=8fd533be\" data-auto-link target=\"_blank\">https://www1.voterinfo.gov.hk/bd_reovi/OVIES/jsp/mob/index.jsp</a><br />\n證明你係嗰區居民/選民<br />\n<br />\n用自己電話去票站scan qr code 喺app投票<br />\n票站有少量後備公家機<br />\n部分票站有實體票（記得check咗邊個票站有先）<br />\n<br />\n要填<br />\n1. 身分證後四位數字（唔包括號內數字）<br />\n2. 身分證簽發日期（年月日）<br />\n3. 出生日期（日期ONLY）"},{"pid":"4e3a8a1b9bab84f798d381981c98998692149e8d","tid":2100074,"uid":213246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-08T21:24:23.000Z","msg":"推"},{"pid":"ff2a9b168e449cc11c8b3a267ce79dfe9bebc55d","tid":2100074,"uid":90601,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-08T22:08:08.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"1c200392134b38996011e3cc99047fa9298043c9","tid":2100074,"uid":67292,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-0