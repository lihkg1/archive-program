thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqqTtdgN.gif&h=81f11a18&s={SIZE}\" />"},{"pid":"c6bcdb9a209863ab99865eba6e24ca5cd18557b5","tid":1513274,"uid":38588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T10:37:20.000Z","msg":"靜啦仆街"},{"pid":"61f625fdf9bb9b5d0cbc1e54e22d11e919eb041f","tid":1513274,"uid":116625,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T10:37:28.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n都唔明點解我屋企人會咁信佢講野<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8e946571799a707a2d3961b79d117d5799d3ecd2","tid":1513274,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T10:37:49.000Z","msg":"救國燒<br />\n屌你"},{"pid":"5a8d99afdaa1a1bde03d9ec46c82395b542bbfbd","tid":1513274,"uid":212706,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T10:37:50.000Z","msg":"咪出聲la"},{"pid":"dda8cb0e8fef4e41f7f8222862d5fced727e02e6","tid":1513274,"uid":103653,"like":2,"dislike":0,"score":2,"quote":{"pid":"1e50d5eea1b817ecdb45a7d6b2d7f4b35bb74f8c","tid":1513274,"uid":137156,"like":186,"dislike":0,"score":186,"citedBy":3,"replyTime":"2019-08-28T09:13:56.000Z","msg":"<img src=\"https://na.cx/i/LLVpWkT.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLLVpWkT.gif&h=09e1a977&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-08-28T10:38:42.000Z","msg":"<img src=\"https://na.cx/i/LEeoMHq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLEeoMHq.jpg&h=8379355b&s={SIZE}\" />"}]}