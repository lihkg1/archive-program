5ff4&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-07-11T01:24:47.000Z","msg":"神就是神<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"486ac9033e676888addae4b10fb71228df98ab44","tid":1304482,"uid":240534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T01:31:40.000Z","msg":"推"},{"pid":"095593f73b8631bfe134705b528b52bcc403bb32","tid":1304482,"uid":223609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T01:32:37.000Z","msg":"推！"},{"pid":"7de7bfd17e134a79afefdb7599f9713d7edf7021","tid":1304482,"uid":37135,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-11T01:33:31.000Z","msg":"呢個要推"},{"pid":"6d8f0de371d5458be81a632bd934704c7a2b0c9e","tid":1304482,"uid":242323,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-07-11T01:34:14.000Z","msg":"希望大家沉住氣 <br />\n不過呢件事上 令藍屍廢中老又出醜"},{"pid":"d32d7b22b2df67bed549483c0a44b37e2540e147","tid":1304482,"uid":17220,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T01:34:46.000Z","msg":"推"},{"pid":"d2edb0148f8b3280e2a8302209f7060bee0b7524","tid":1304482,"uid":87582,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T01:35:55.000Z","msg":"社會信用評分系統懶人包<br />\n<a href=\"https://lih.kg/1300184\" data-auto-link target=\"_blank\">https://lih.kg/1300184</a><br />\n<br />\n【文宣】社會信用系統文宣圖，麻煩各位手足返工返學掟撚哂出去<br />\n<a href=\"https://lih.kg/1301880\" data-auto-link target=\"_blank\">https://lih.kg/1301880</a><br />\n<br />\n急! 突發，3年內將引入「社會信用評分系統」。文宣組幫幫手<br />\n<a href=\"https://lih.kg/1298213\" data-auto-link target=\"_blank\">https://lih.kg/1298213</a><br />\n<br />\n有無人真係好驚社會信用制度...<br />\n<a href=\"https://lih.kg/1300476\" data-auto-link target=\"_blank\">https://lih.kg/1300476</a><br />\n<br />\n【逆權運動】政府稱絕不在港實施社會信用評分 內地信用官網驚現預留港澳台連結<br />\n<a href=\"https://lih.kg/1300395\" data-auto-link target=\"_blank\">https://lih.kg/1300395</a><br />\n<br />\n［信你一成］政府澄清，不會在香港施行社會信用體系。<br />\n<a href=\"https://lih.kg/1300401\" data-auto-link target=\"_blank\">https://lih.kg/1300401</a><br />\n<br />\n［社會信用體系］我真係唔撚同你講笑，禁入去拉到最底睇下，港豬<br />\n<a href=\"https://lih.kg/1300241\" data-auto-link target=\"_blank\">https://lih.kg/1300241</a><br />\n<br />\n政制及內地事務局局長聶德權： 信用制度不會在港實施<br />\n<a href=\"https://lih.kg/1300116\" data-auto-link target=\"_blank\">https://lih.kg/1300116</a>"},{"pid":"8d137879e4b2305bf674aab9bb03b13def00c1e5","tid":1304482,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T01:36:17.000Z","msg":"推"},{"pid":"13bb2ff70280932deb35b7b6567913186413bdd5","tid":1304482,"uid":1059,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-07-11T01:40:38.000Z","msg":"推 <br />\n你拆 我貼 有撚所謂 守黎比藍絲打既 有咩意思"},{"pid":"15e013dc02aad110fe3d2f046da5762b02c4c94c","tid":1304482,"uid":198957,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T01:41:20.000Z","msg":"五大訴求:<br />\n一、徹底撤回修例<br />\n二、收回暴動定義<br />\n三、撤銷對所有反送中抗爭者控罪<br />\n四、徹底追究警隊濫權情況<br />\n五、以行政命令解散立法會，立即實行雙真普選"},{"pid":"9980588ddf6b703afbd1f88ff92adb2b489e3cef","tid":1304482,"uid":179966,"like":1,"dislike":1,"score":0,"quote":{"pid":"ab491259098a3b6c3293f775ab2f9b00d9852303","tid":1304482,"uid":514,"like":328,"dislike":2,"score":326,"citedBy":6,"replyTime":"2019-07-10T15:30:06.000Z","msg":"雨革就係輸在死守一個地方<br />\n而家又點解要守連儂牆？<br />\n連儂牆最重要係佢嘅精神。有呢個精神嘅人，去到邊，嗰度就係連儂牆<br />\n<br />\nBe water<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-11T01:44:53.000Z","msg":"因為最緊要嗰啲嘢守唔到<br />\n只能夠守住幅牆 <img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"b06c818f9ccb3c368832d57f66a0cc6aed10d4b8","tid":1304482,"uid":50968,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2019-07-11T01:50:47.000Z","msg":"今日睇段片見到個廢中打啲後生仔<br />\n但班後生又真係企定定係度比佢打<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n雖然我係心痛亦覺得要告個廢中<br />\n但都要屌個後生<br />\n見到個廢中係度撕你咪由佢<br />\n呢啲無成本嘅野你用肉身頂值唔值呀<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">以