{"tid":1581891,"cid":5,"subCid":0,"title":"(美國巴打)香港貿易發展局會喺Downtown LA JW Marriott's 酒店舉行會議","createTime":"2019-09-19T19:20:48.000Z","updateTime":"2019-09-20T14:17:17.000Z","uid":48210,"like":22,"dislike":0,"uniUserReply":17,"replies":[{"pid":"7d8abdd3d9dcf2fc023176f1b0e31affd292ee4b","tid":1581891,"uid":48210,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-19T19:20:48.000Z","msg":"<a href=\"http://www.hktdc.com/ncs/thinkasiathinkhk2019/en/s/info-program.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.hktdc.com%2Fncs%2Fthinkasiathinkhk2019%2Fen%2Fs%2Finfo-program.html&d=kSOQn%2BAsZtDywzIR1u7IPyNFMfcMnrnh95DLK%2BYL5kQ%3D&h=2dffbc71\" target=\"_blank\">http://www.hktdc.com/ncs/thinkasiathinkhk2019/en/s/info-program.html</a><br />\n聽日9月20日貿發局會Downtown LA舉行會議，貿發局局長邱騰華亦會出席<br />\n到時將會有唔少傳媒出席<br />\n已經有一少部分香港人會到場示威<br />\n不過真係唔係好夠人<br />\n我知聽日大家可能都要番工，不過住LA附近唔該黎參加一下聽日洛杉磯嘅遊行<br />\n<br />\n<br />\nDate: 09/20/2019 08:30 AM<br />\nVenue: 900 W Olympic Blvd, Los Angeles, CA 90015 (DTLA JW Marriot&rsquo;s)<br />\n<br />\n<img src=\"https://i.imgur.com/ENFb8vi.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FENFb8vi.png&h=85341dfb&s={SIZE}\" />"},{"pid":"7061b42422b9fd402869ece7d209a3e3712ded0d","tid":1581891,"uid":48210,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-19T19:23:48.000Z","msg":"推"},{"pid":"0639662e2bda70966d6e6573a0a01f2a1c883316","tid":1581891,"uid":106252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-19T19:25:12.000Z","msg":"Posh"},{"pid":"a98dd2af423843c0b1fd21d68c732a43cfcb465a","tid":1581891,"uid":106252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-19T19:25:23.000Z","msg":"推"},{"pid":"4c5b5696055b726a874fe94597df5962283206ad","tid":1581891,"uid":182088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-19T19:25:30.000Z","msg":"幫推<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"e0428166dcdc99664fbb6f897b3c