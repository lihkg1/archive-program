5%85%A7%E5%AE%B9-092700427.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.money.yahoo.com%2Fvideo%2F%25E9%25A6%25AC%25E5%258C%2596%25E9%25A8%25B0%25E5%25A4%25A9%25E5%25A4%25A9%25E5%259C%25A8%25E7%259C%258B-%25E5%25BE%25AE%25E4%25BF%25A1%25E8%2581%25B2%25E6%2598%258E-%25E4%25B8%258D%25E6%259C%2583%25E7%259C%258B%25E7%2594%25A8%25E6%2588%25B6%25E5%25BE%25AE%25E4%25BF%25A1%25E5%2585%25A7%25E5%25AE%25B9-092700427.html&d=N3QkE9bSYQyAbLB4T37GqttKgwQIhJBw7VlnLihElrQ%3D&h=548fc6b9\" target=\"_blank\">https://tw.money.yahoo.com/video/%E9%A6%AC%E5%8C%96%E9%A8%B0%E5%A4%A9%E5%A4%A9%E5%9C%A8%E7%9C%8B-%E5%BE%AE%E4%BF%A1%E8%81%B2%E6%98%8E-%E4%B8%8D%E6%9C%83%E7%9C%8B%E7%94%A8%E6%88%B6%E5%BE%AE%E4%BF%A1%E5%85%A7%E5%AE%B9-092700427.html</a>"}]}