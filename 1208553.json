9:29.000Z","msg":"<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"5d39f0953e4d0319f691ae0c175ae6cf9674e387","tid":1208553,"uid":226824,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T14:07:54.000Z","msg":"Push<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"347ecc0bad1f868748884eb4a9d77d2e14a92130","tid":1208553,"uid":87917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T14:13:02.000Z","msg":"唔緊要啦 6 7 80後都唔記得左點解要走難落黎香港了 而家竟然又支持返中共 一齊死啦仆街 <br />\n<br />\n到你地下一代想反抗 我地唔係黨員就係搵銀  到我地指住佢地唔好搞亂香港了<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"451cee011b4b64be01e839a6bec5726f396f7051","tid":1208553,"uid":226824,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T14:43:13.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />擺低負皮就走，無撚用"}]}