 src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"961b443f147aefcb251f3b21df18d04464861d9c","tid":736271,"uid":28563,"like":2,"dislike":0,"score":2,"quote":{"pid":"7ca9890e3a9c0c850440d784687a4cd6e6ff1fa7","tid":736271,"uid":53857,"like":0,"dislike":0,"score":0,"quote":{"pid":"55783a04f17ed8d646af5c760a6d6787e64d32a4","tid":736271,"uid":28563,"like":0,"dislike":0,"score":0,"quote":{"pid":"75957a303ffcfdea336e75377184b19f813d04bc","tid":736271,"uid":53857,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-10T08:15:42.000Z","msg":"點呀<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n你又有興趣呀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> ?"},"citedBy":1,"replyTime":"2018-07-10T08:17:35.000Z","msg":"一皮一粒64c128t，仲可以打孖上<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-10T08:20:36.000Z","msg":"Intel都出膠水xeon<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n睇定啲先好，兩間野打緊核戰<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-10T08:21:00.000Z","msg":"corean war<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ccb808e63c84ed49d9c2125a54801a28098c912c","tid":736271,"uid":53857,"like":0,"dislike":0,"score":0,"quote":{"pid":"961b443f147aefcb251f3b21df18d04464861d9c","tid":736271,"uid":28563,"like":2,"dislike":0,"score":2,"quote":{"pid":"7ca9890e3a9c0c850440d784687a4cd6e6ff1fa7","tid":736271,"uid":53857,"like":0,"dislike":0,"score":0,"quote":{"pid":"55783a04f17ed8d646af5c760a6d6787e64d32a4","tid":736271,"uid":28563,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-10T08:17:35.000Z","msg":"一皮一粒64c128t，仲可以打孖上<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"}