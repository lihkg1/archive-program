ly%2Farticle%2F20040405%2F3961951&h=f0a2465e\" target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20040405/3961951</a>"},{"pid":"30050b35d43368fd54f976fbf5158580e7b5e9e8","tid":476722,"uid":39539,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T09:26:05.000Z","msg":"叫林鄭掃描Qr code過$500落去佢支付寶"},{"pid":"3a4620353ae331b35b5ea56346f68a13d19da35c","tid":476722,"uid":16120,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T09:44:29.000Z","msg":"隔離個隻野係大仔? <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6a096b8e1989fff2fe1d390464ab13ffaa23e7c1","tid":476722,"uid":531,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T09:45:48.000Z","msg":"香港冇乜人有支那寶"}]}