jiq68w%3D&h=b90a347d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20190811%2F59921763&h=c2132835\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/breaking/realtime/article/20190811/59921763</a><br />\n之前所有鐳射筆 掟磚 燃燒彈極有可能全部都係佢地自編自導自演<br />\n被控暴動既示威者應以此為最有力既合理疑點<br />\n3. 射爆示威者眼球 意圖謀殺<br />\n<a href=\"https://lihkg.com/thread/1446612/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1446612/page/1</a><br />\n4. 蓄意傷害無反抗能力之人士 <br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=f4h8dEMNQSE&amp;feature=youtu.be\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3Df4h8dEMNQSE%26feature%3Dyoutu.be&d=WSAeeZJF6zK6RlDtvYZcplcETUAZGKrTpJw0Ojiq68w%3D&h=b41d8efd\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=f4h8dEMNQSE&amp;feature=youtu.be</a> <br />\n牙都比佢地撳爆<br />\n5. 插贜嫁禍示威者<br />\n<br />\n<a href=\"https://www.facebook.com/753523274/videos/10158746973253275/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F753523274%2Fvideos%2F10158746973253275%2F&d=WSAeeZJF6zK6RlDtvYZcplcETUAZGKrTpJw0Ojiq68w%3D&h=16f28d05\" data-auto-link target=\"_blank\">https://www.facebook.com/753523274/videos/10158746973253275/</a> <br />\n6. 地鐵站內射催淚彈<br />\n不跟從指引 係室內放催淚彈 意圖謀殺<br />\n<a href=\"https://www.facebook.com/groups/hkon9agroup/permalink/3017915218249522?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fgroups%2Fhkon9agroup%2Fpermalink%2F3017915218249522%3Fsfns%3Dmo&d=WSAeeZJF6zK6RlDtvYZcplcETUAZGKrTpJw0Ojiq68w%3D&h=bbf0ca08\" data-auto-link target=\"_blank\">https://www.facebook.com/groups/hkon9agroup/permalink/3017915218249522?sfns=mo</a><br />\n7. 極近距離行刑式掃射示威者<br />\n同樣係意圖謀殺<br />\n<a href=\"https://hk.news.appledaily.com/breaking/realtime/article/20190811/59919757\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20190811%2F59919757&d=WSAeeZJF6zK6RlDtvYZcplcETUAZGKrTpJw0Ojiq68w%3D&h=c5379289\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20190811%2F59919757&h=b7b18c36\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/breaking/realtime/article/20190811/59919757</a>"},{"pid":"7d053eb860061108593eac1ba17967fe6956a2d9","tid":1449480,"uid":84228,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T17:19:52.000Z","msg":"收皮啦屌你老母，好撚好玩？"},{"pid":"1be060d79da136b0b821a23299c6644925b8cb14","tid":1449480,"uid":60695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T17:21:27.000Z","msg":"樓主想引彈"},{"pid":"ba46ff3e06262ae56f13841bbc964390daa29fb1","tid":1449480,"uid":221571,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-11T17:21:45.000Z","msg":"就算場場炒人10:0都唔會開心<br />\n我寧願贏嘅係香港<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n唉"},{"pid":"e1492134491b8279382398cf97d20e26cdacf1f3","tid":1449480,"uid":120575,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-08-11T17:22:42.000Z","msg":"呢個時候仲開膠post 好撚過癮？"},{"pid":"91da20350be25af9eb704be8b3218fe36460c2de","tid":1449480,"uid":15950,"like":0,"dislike":6,"score":-6,"citedBy":0,"replyTime":"2019-08-11T17:22:54.000Z","msg":"聽朝文宣<br />\n<br />\n1. 爆眼，港鐵站內極近距離開槍<br />\n<br />\n2. 扮示威者，縱火打人都是警察做<br />\n<br />\n3. 港鐵站內過期有毒TG，會經冷氣及隧道系統傳到所有站，市民請帶備口罩<br />\n<br />\n聽日要所有連儂牆都見到，射去自己區group。做文宣戰士，我要A1，要掛牆橫額，大撚到阿婆阿伯都睇到！！<br />\n<br />\n除左連儂場，全港都要貼滿海報，商場，燈柱，公廁，巴士向外車窗，所有有人地方都要貼！<br />\n<br />\nKeyboard fighter出擊<br />\n所有唔關事既po都要洗佢版 <br />\n<br />\n下星期唔適合再戰，我地再遊行要忍，要忍到有民陣大遊行，再設下死線，之後下次不合作唔會再係馬路、唔會再係遊擊！！<br />\n<br />\n『要。搞。機。場』<br />\n<br />\n煲大文宣，集合罷工搞機場<br />\n封所有路線，停所有航班<br />\n<br />\n香港要贏，機場要死"},{"pid":"ea0653241c6873d72bfc42beee67241d38db4ca8","tid":1449480,"uid":15950,"like":0,"dislike":8,"score":-8,"quote":{"pid":"ba46ff3e06262ae56f13841bbc964390daa29fb1","tid":1449480,"uid":221571,"like