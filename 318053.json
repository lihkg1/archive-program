話有個人考完都係得10分無點升過，咁佢就真係面對現實出去打工好過會比較好囉"},{"pid":"98f5a83d1c6c69ba854e304cdf1f3a01fd254ef0","tid":318053,"uid":34301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-13T06:52:54.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d9fad85ff286b535ef1d6aade4f603f65084922a","tid":318053,"uid":36383,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-13T07:02:29.000Z","msg":"<blockquote><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3eeece5750b3037136bf406f99a79c0a429f527f","tid":318053,"uid":34301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-13T07:44:13.000Z","msg":"<blockquote><blockquote><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"016b47c02519fdc650aeb5f82392485f460cf132","tid":318053,"uid":34301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-13T09:43:00.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}