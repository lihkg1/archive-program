c1af4a1a4d4b284dbb43500","tid":1420611,"uid":32586,"like":0,"dislike":0,"score":0,"quote":{"pid":"b7f35f54f925ad822cbed027e718366e78014d35","tid":1420611,"uid":52585,"like":1,"dislike":0,"score":1,"quote":{"pid":"706b1c0941d5ba5dd96b019237d4f0bb98d78bb1","tid":1420611,"uid":32586,"like":18,"dislike":0,"score":18,"quote":{"pid":"559eb51a182fcbf5894e01d962cd77b254af8c05","tid":1420611,"uid":215876,"like":0,"dislike":12,"score":-12,"citedBy":2,"replyTime":"2019-08-06T05:42:55.000Z","msg":"大家會唔會換人民幣<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-06T05:46:18.000Z","msg":"食懞左先會換"},"citedBy":1,"replyTime":"2019-08-06T05:53:10.000Z","msg":"換上去call g! why not ar"},"citedBy":0,"replyTime":"2019-08-06T05:54:20.000Z","msg":"仲上去?"},{"pid":"f5e72a51689f4bb6820d6e221acc5adc8347cd2f","tid":1420611,"uid":75023,"like":19,"dislike":1,"score":18,"citedBy":4,"replyTime":"2019-08-06T05:54:54.000Z","msg":"幾年前試過,班大陸人襯人仔仲係高過港幣就好急落o黎買香港樓,例如:1000萬港幣嘅樓,實際只係俾800萬. 仲要係公司名義買FULL PAY,之後再將間公司連物業出售,變為白錢.<br />\n而且港幣係可以直接換到美金,佢哋再去其他地方買物業. <br />\n我相信o黎緊短期內都有呢個效應,除非大陸人自己都唔信有一國兩制,覺得港元會脫勾.<br />\n<br />\n長遠會導致通脹,甚至滯脹,因為銀紙貶值購買力降低,而資產賬面上會升值,到時有可能太古城4萬元一呎,大家樂焗豬賣100元.<br />\n<br />\n利申:無讀過ECON"},{"pid":"40c6a43e20a55e53e95ed7bdf964488d2cb39105","tid":1420611,"uid":82482,"like":10,"dislike":0,"score":10,"citedBy":2,"replyTime":"2019-08-06T05:58:21.000Z","msg":"好似話當年南韓,日本,印尼都係夠一招,一貶貶到底的做法,然後經濟慢慢復蘇<br />\n<br />\n值得一提以上國家算係自由經濟體系,而且有民主的法律基礎先能重回正軌<br />\n<br />\n至於中國,現況的做斬件式貶值<br />\n<br />\n若果以M2的方式及GDP掛勾的方式計,人民幣合理價係廿零蚊<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><br />\n<br />\n一貶到底的方法可能震盪幾年（或更長）,但係政治體制的因素要睇返<br />\n<br />\n斬件式的方法會令外資有充足時間撤資<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"8bbf3f253716a0dab65aee739314d73238bc2b41","tid":1420611,"uid":10249,"like":2,"dislike":0,"score":2,"quote":{"pid":"40c6a43e20a55e53e95ed7bdf964488d2cb39105","tid":1420611,"uid":8