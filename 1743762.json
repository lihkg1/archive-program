 src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"32692a544faf6063967e3fd89b7360d700826452","tid":1743762,"uid":272652,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T11:37:45.000Z","msg":"呢班撚樣靠枱底交易肚滿腸肥<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"d4a39966a095db52af9f216dfb72d63f371a78aa","tid":1743762,"uid":286792,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T11:38:23.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"56542ada6bac7354f2a96bf76e6ec709a88ea14b","tid":1743762,"uid":62842,"like":0,"dislike":0,"score":0,"quote":{"pid":"aa32348c0c58e3e52913742f49c4f5347637d92d","tid":1743762,"uid":40999,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-11-21T11:37:44.000Z","msg":"哇蘋果整份裝修名單出嚟咁惡毒<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-21T11:39:35.000Z","msg":"<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3ec8d3c49278883f7cf76116fe7116e47f72e3f0","tid":1743762,"uid":119232,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T11:43:15.000Z","msg":"真係好黑暗"},{"pid":"c3ef4bdae50d3d662924e202b8bb637200027260","tid":1743762,"uid":81140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T12:15:36.000Z","msg":"推"},{"pid":"950dc1b339632db5ecaf72833b770d48bb3404f6","tid":1743762,"uid":182061,"like":0,"dislike":0,"score":0,"quote":{"pid":"aa32348c0c58e3e52913742f49c4f5347637d92d","tid":1743762,"uid":40999,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-11-21T11:3