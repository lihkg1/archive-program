d":"a4c06ab0c33cfdad6d6ae6a992b512020ca78b7e","tid":2370702,"uid":134071,"like":0,"dislike":0,"score":0,"quote":{"pid":"eef598ed2ead088ecc2f84f21087ef295903690e","tid":2370702,"uid":305767,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-01-18T09:41:54.000Z","msg":"<em></em>"},"citedBy":0,"replyTime":"2021-01-18T11:48:05.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"cb970695bfb155bd220fe0a8fb436dfc881b32a8","tid":2370702,"uid":134071,"like":0,"dislike":0,"score":0,"quote":{"pid":"130aa1b0239007f0aa32081e3eedc2f15d0f1985","tid":2370702,"uid":265553,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-18T11:46:31.000Z","msg":"紅黃戲都有份<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-18T11:48:19.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"eb3d5715a5e6f5c63c0dd7cab74995c57e22a968","tid":2370702,"uid":20170,"like":0,"dislike":0,"score":0,"quote":{"pid":"6a52d3c9ebfbda79720b18ddbd24f2e954c153bc","tid":2370702,"uid":218082,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2021-01-18T09:05:19.000Z","msg":"成日覺得電影評論學會頒啲獎合理過金像獎好多<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n金像獎成日論資排輩等攞獎,有時有啲獎根本冇人值得拎都照夾硬頒<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-18T11:59:40.000Z","msg":"前者比較偏向學院派，後者多數業界渣莊"},{"pid":"aa378b64cdee75a0cc7f9e4e1f9ffcf521db7c88","tid":2370702,"uid":279463,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-18T12:01:02.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a2a299660f78e411edf8ac7cbdfe5fb4738149ab","tid":2370702,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-18T12:02:18.000Z","msg":"今年冇人拎到最佳男演員<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"588c42a19558bdfdfa21731bf490631493b6b1fd","tid":2370702,"uid":91321,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-18T12:02:34.000Z","msg":"金像獎最佳有冇機？"},{"pid":"599d9c374490e9eb123495b16995bc4fc906807a","tid":2370702,"uid":226955,"like":0,"dislike":0,"score":0,"quote":{"pid":"588c42a19558bdfdfa21731bf490631493b6b1fd","tid":2370702,"uid":91321,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-18T12:02:34.000Z","msg":"金像獎最佳有冇機？"},"citedBy":1,"replyTime":"2021-01-18T12:04:39.000Z","msg":"要喺戲院上夠指定次數以上先上提名資格，戲院唔敢上映嘅話唔會有機"}],"pinned":{"pid":"555d326c37f14196f3be4db7dc752bed31ac8c57","tid":2370702,"uid":134071,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-01-18T08:22:53.000Z","msg":"仲有兩套黃圈電影得獎<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />：<br />\n《夜香．鴛鴦．深水埗》《一秒拳王》"}}