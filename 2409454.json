55aa4c","tid":2409454,"uid":312598,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-15T23:58:23.000Z","msg":"<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"a2206c58d471e3514d1663e75ec5ba4e251aa310","tid":2409454,"uid":274149,"like":0,"dislike":0,"score":0,"quote":{"pid":"0b317170e042bdd61109ffff2d2ac7806855aa4c","tid":2409454,"uid":312598,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-15T23:58:23.000Z","msg":"<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-16T00:02:51.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}