&nbsp;:&nbsp;開支比例<br />\n<br />\n1997年庫房的錢&nbsp;比2019庫房的錢更多<br />\n<br />\n庫房有好多錢成萬億只是假象"},{"pid":"45a0bd37261dbb277e71ee6b1c755259a9ef4c97","tid":2421671,"uid":11148,"like":153,"dislike":4,"score":149,"citedBy":6,"replyTime":"2021-02-24T16:14:01.000Z","msg":"<img src=\"https://na.cx/i/cLuF3eg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcLuF3eg.jpg&h=4f3f4740&s={SIZE}\" />"},{"pid":"a849ecbfb0633495af4123ffe1e780350ca730f2","tid":2421671,"uid":35699,"like":59,"dislike":0,"score":59,"quote":{"pid":"4e8242619525bc954f5e26c9c5d1294355ee5c75","tid":2421671,"uid":6347,"like":210,"dislike":0,"score":210,"citedBy":10,"replyTime":"2021-02-24T16:09:15.000Z","msg":"個logo成碌野咁<br />\n有咩含意<img src=\"/assets/faces/lny/tongue2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-24T16:16:03.000Z","msg":"叫香港人含撚"},{"pid":"119bcf0041202c09ebce256ac56b66ca46db226d","tid":2421671,"uid":6347,"like":62,"dislike":1,"score":61,"quote":{"pid":"50f49098a37078a01aa80b155681f20c7289e204","tid":2421671,"uid":352873,"like":4,"dislike":301,"score":-297,"quote":{"pid":"4e8242619525bc954f5e26c9c5d1294355ee5c75","tid":2421671,"uid":6347,"like":210,"dislike":0,"score":210,"citedBy":10,"replyTime":"2021-02-24T16:09:15.000Z","msg":"個logo成碌野咁<br />\n有咩含意<img src=\"/assets/faces/lny/tongue2.gif\" class=\"hkgmoji\" />"},"citedBy":9,"replyTime":"2021-02-24T16:10:49.000Z","msg":"廚師帽啊 on9仔<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-24T16:17:46.000Z","msg":"成個龜頭畫埋出黎啦<br />\n廚你老母<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6830981248b7e94a597b7b7729103d95f5a29461","tid":2421671,"uid":193642,"like":7,"dislike":0,"score":7,"quote":{"pid":"4e8242619525bc954f5e26c9c5d1294355ee5c75","tid":2421671,"uid":6347,"like":210,"dislike":0,"score":210,"citedBy":10,"replyTime":"2021-02-24T16:09:15.000Z","msg":"個logo成碌野咁<br />\n有咩含意<img src=\"/assets/faces/lny/tongue2.gif\" class=\"hkgmoji\" />"}