ts/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"33609b5dfcb3003dd76980079395cca10bb65a89","tid":2056571,"uid":210612,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2020-06-08T23:56:59.000Z","msg":"條友好煩 一定要喵足十分鐘摸足十分鐘先比我訓 煲水煲足十分鐘 勁嘈 <br />\n然後訓我枕頭邊/腳底<br />\n六點半隨機又叫醒我 無覺好訓"},{"pid":"25823b619cfc8d677902b3dc993e5447c45b509a","tid":2056571,"uid":296455,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-08T23:58:41.000Z","msg":"有一隻間中會陪訓，背貼背熱到癲<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"217b66077418b4e11deaaf170ae47400cb90ac07","tid":2056571,"uid":151330,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-06-09T00:13:17.000Z","msg":"唔會一齊瞓，但會係我鬧鐘響即刻衝黎要我摸<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n同痴住我隻手<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"2dcf2e35e97e418dd0242215600cf96a537dc3cc","tid":2056571,"uid":82214,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-09T04:52:54.000Z","msg":"開晒門佢想訓邊就訓邊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n不過如果起身見到佢係我頭頂會好開心<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"f372efe9af24222f0e2d49cddaf2ecccc76caf49","tid":2056571,"uid":32577,"like":1,"dislike":0,"score":1,"quote":{"pid":"2dcf2e35e97e418dd0242215600cf96a537dc3cc","tid":2056571,"uid":82214,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-09T04:52:54.000Z","msg":"開晒門佢想訓邊就訓邊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n不過如果起身見到佢係我頭頂會好開心<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-09T04:56:15.000Z","msg":"起身俾罐罐啦，仆街（一隻貓掌一野啪過去）"},{"pid":"7a238621d60f1e948e8cff102ea7b9b4d4dfcbfb","tid":2056571,"uid":2786,"like":0,"dislike":0,"score":0,"quote":{"pid":"33609b5dfcb3003dd76980