d":2377333,"uid":86449,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-13T14:06:27.000Z","msg":"睇緊, 留名"},{"pid":"7a5fa07058ea5fef1c3f8be7e6c821e4be59dbb6","tid":2377333,"uid":256059,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-13T14:19:31.000Z","msg":"cls ... 用個火機黎燒...<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"6dcd4961f8d20c3cbd573a8ace9c588824c2dc99","tid":2377333,"uid":30,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-20T14:39:57.000Z","msg":"【Anjo廚房 VS 麥太廚房】（上集）<br />\n<br />\n參賽嘉賓：<br />\n【Anjo廚房】梁曉豐(Anjo)與媽媽<br />\n【麥太廚房】麥芷誼(Koyi)與媽媽<br />\n<br />\n指定食材：茄子<br />\n<br />\n今集有梁曉豐(Anjo)、麥芷誼(Koyi)帶同媽媽出戰我煮場，兩組嘉賓都是破天荒首次同場下廚。Anjo與媽媽都非常喜歡下廚，但二人的煮食文化卻大不同，因此兩母子堅持每人各煮一道菜，兩代人的煮食意念有何差異？平日很有主見的Koyi，在今次的煮場上卻化身成為媽媽的小助手，對煮茄子毫無頭緒，Koyi媽媽又如何評價她的廚藝表現？<br />\n<br />\n<a href=\"https://youtu.be/EgoXG9tQncM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FEgoXG9tQncM&d=m1YmCj491ZwsIKcmlD2Tah%2FwB%2Fd2Hr%2Bf%2F5fgrRWXORU%3D&h=5979d76f\" data-auto-link target=\"_blank\">https://youtu.be/EgoXG9tQncM</a>"}}