ets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"8346790a2531693ac8028bb4955de4ca2aba85f9","tid":1200360,"uid":138502,"like":0,"dislike":0,"score":0,"quote":{"pid":"eb32aab7e54e967fe15044a894ba3e9992feddce","tid":1200360,"uid":258348,"like":7,"dislike":0,"score":7,"quote":{"pid":"0cf8d6bd03535c6ae6b30ea812ac9e05d06aec0a","tid":1200360,"uid":138502,"like":1,"dislike":5,"score":-4,"citedBy":2,"replyTime":"2019-06-10T18:55:46.000Z","msg":"教人買藥比物資部 比人周到告多條非法管有第一部毒藥 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://hk.on.cc/hk/bkn/cnt/news/20170724/bkn-20170724050025113-0724_00822_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20170724%2Fbkn-20170724050025113-0724_00822_001.html&d=bDeBUyUVyPRGeZhx3zx6ldDxg6radaiL0c7rOhjaEfM%3D&h=dc3fb3fe\" target=\"_blank\">https://hk.on.cc/hk/bkn/cnt/news/20170724/bkn-20170724050025113-0724_00822_001.html</a>"},"citedBy":1,"replyTime":"2019-06-10T18:58:50.000Z","msg":"我講嘅完全冇第一類，全部都係合法地可以向藥房藥劑師買"},"citedBy":1,"replyTime":"2019-06-10T19:02:12.000Z","msg":"Telfast, Ibuprofen, Codeine唔係Part I poison係咩? <img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><br />\n最大問題係D藥都唔算太應急<br />\n反而幾欣賞你教點處理比野噴到"},{"pid":"afd340044494f8c6951ae6eca12c41c50a82e744","tid":1200360,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-10T19:02:35.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"86ca4871b3ad9ea286c529dbf659982a60383372","tid":1200360,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-10T19:02:47.000Z","msg":"<span style=\"color: gold;\">Sorry<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />香港宜家正值歷史危機當前<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />我想同大家講少少嘢</span><br />\n<br />\n<blockquote>唔想勇武咪和理非囉<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />唱聖詩又好，想成隊百人管弦樂團一齊奏交響曲都得呀<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n一百萬人遊行只係個開始，大家仲有好多好多嘢可以做，例如今晚開始直到12號喺政總舉行嘅祈禱聖詩會，甚至罷工罷課等，我希望大家要明白一樣嘢，任何願意作出反惡法嘅行動都應該要支持！香港人唔可以再比三毛分化，和理非同勇武必須一齊合作，佔大多數嘅和理非請用盡一切合法方法反對逃犯條例，逃犯條例絕對唔可以通過，否則我地同下一代就會生長喺講句說話都要就住就住，擔驚受怕嘅環境之中，大家絕對唔可以比逃犯條例過到<br />\n<br />\n我地應該要接受香港和理非佔大多數呢個事實，大多數人都唔會衝始終法律後果太重，所以大家可以用合法方式全力阻止惡法，只要係合法渠道去反送中，我相信唔少人都唔介意做多兩步，有啲人可能覺得有啲和理非行動聽起上嚟好似好膠，但請唔好理人點做，只要記住大家都係反送中嘅同路人，我地就應該尊重同埋支持佢地，去爭取更多市民同國際社會反送中，唔好話無用，你去做起碼仲有1%會成功，完全唔做就絕對唔會成功。大家一定要盡自己可以承受到嘅所有後果同力量，以政府徹回逃犯條例為成功目標。記住，唔好再鬧分化，和理非有和理非做，其他人有其他人做，兄弟爬山，各自努力。<br />\n<br />\n歷史例子：<br />\n柏林圍牆冧之前幾個月冇人會覺得有生之年可以見到冧牆嘅一日，03年23條同12年國教都冇人會覺得可以令政府撤回23條同國教，正如今次亦都冇人會覺得可以令政府撤回逃犯條例。<span style=\"color: red;\">再強調一次，唔好話無用，你去做起碼仲有1%會成功，完全唔做就絕對唔會成功。</span>"},{"pid":"4ee5dafdea388e375646cd34dc9dd0b3a7415dbf","tid":1200360,"uid":258348,"like":0,"dislike":0,"score":0,"quote":{"pid":"8346790a2531693ac8028bb4955de4ca2aba85f9","tid":1200360,"uid":138502,"like":0,"dislike":0,"score":0,"quote":{"pid":"eb32aab7e54e967fe15044a894ba3e9992feddce","tid":1200360,"uid":258348,"like":7,"dislike":0,"score":7,"quote":{"pid":"0cf8d6bd03535c6ae6b30ea812ac9e05d06aec0a","tid":1200360,"uid":138502,"like":1,"dislike":5,"score":-4,"citedBy":2,"replyTime":"2019-06-10T18:55:46.000Z","msg":"教人買藥比物資部 比人周到告多條非法管有第一部毒藥 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://hk.on.cc/hk/bkn/cnt/news/20170724/bkn-20170724050025113-0724_00822_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20170724%2Fbkn-20170724050025113-0724_00822_001.html&d=bDeBUyUVyPRGeZhx3zx6ldDxg6radaiL0c7rOhjaEfM%3D&h=dc3fb3fe\" target=\"_blank\">https://hk.on.cc/hk/bkn/cnt/news/20170724/bkn-20170724050025113-0724_00822_001.html</a>"},"citedBy":1,"replyTime":"2019-06-10T18:58:50.000Z","msg":"我講嘅完全冇第一類，全部都係合法地可以向藥房藥劑師買"},"citedBy":1,"replyTime":"2019-06-1