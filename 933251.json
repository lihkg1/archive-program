=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"07f35759d28d6f58d117ee396d3f1d758a86bcca","tid":933251,"uid":37413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-08T14:51:00.000Z","msg":"因為有特權囉"},{"pid":"f72f09818e38711340e6898a2c3b85348d6193e3","tid":933251,"uid":100509,"like":1,"dislike":0,"score":1,"quote":{"pid":"9022150a313dea0f43de751e6496d881011c29cd","tid":933251,"uid":31475,"like":1,"dislike":4,"score":-3,"quote":{"pid":"535cd472330f296d60c3226b32c02442032fea59","tid":933251,"uid":203703,"like":87,"dislike":0,"score":87,"citedBy":5,"replyTime":"2018-12-08T12:24:17.000Z","msg":"香港700萬人 但特區護照發出數係多過700萬好多<br />\n係咩原因大家心照"},"citedBy":2,"replyTime":"2018-12-08T14:31:47.000Z","msg":"大把人海外pr拿香港passport 住海外<br />\n唔好on9啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n連登仔智商低到"},"citedBy":0,"replyTime":"2018-12-08T14:54:22.000Z","msg":"你有無睇巴拿馬流出，N咁多大陸西都有特區護照"},{"pid":"0b30d6a394d569477f86fb81b53e60ea22e1b8df","tid":933251,"uid":4783,"like":28,"dislike":0,"score":28,"citedBy":1,"replyTime":"2018-12-08T14:54:51.000Z","msg":"張達明（法律學者）<br />\nPage Liked &middot; 7 hrs &middot; <br />\n<br />\n <br />\n註：看到一些評論，認為孟晚舟擁有三本不同號碼的特區護照不足為奇，因為在續領或補領特區護照時，護照號碼都會改變，她可能「坐飛機多過坐巴士」，所以舊護照蓋滿章後便需要換領。<br />\n<br />\n作出這些評論的人可能沒有留意當中關鍵細節，就是三本護照都是K J字頭，表示三本護照是在一段短時期內簽發，這麼快便蓋滿章的機會不高（特別是現在很多國家出入境也不再需要在護照上蓋章）。更重要的是，入境處資料顯示，護照持有人在領取新護照時，必須將舊護照交回入境處註銷，但根據美國司法部呈交的資料 (<a href=\"https://www.scribd.com/document/395185754/Surrey-RCMP-Const-Winston-Yep-s-affidavit#fullscreen&amp;from_embed,\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.scribd.com%2Fdocument%2F395185754%2FSurrey-RCMP-Const-Winston-Yep-s-affidavit%23fullscreen%26from_embed%2C&d=nT0JRHd2LMoASC6Ir7WJpP7vEz4FU%2Bq4m%2F6ZFrWLoTs%3D&h=dd9f51b3\" data-auto-link target=\"_blank\">https://www.scribd.com/document/395185754/Surrey-RCMP-Const-Winston-Yep-s-affidavit#fullscreen&amp;from_embed,</a> at p 11)，她這次是用第二本護照(即KJ0403962)入境加拿大，而並非用最新簽發的第三本護照(即KJ0479108)，這表示她在未有註銷第二本護照的情況下獲簽發第三本護照。<br />\n<br />\n故此，我仍然認為香港政府需要盡快徹查事件及作出公開解釋。<br />\n<br />\n__________<br />\n根據美國司法部呈交的文件(<a href=\"https://www.scribd.com/document/395185756/Letter-from-the-U-S-Justice-Department\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.scribd.com%2Fdocument%2F395185756%2FLetter-from-the-U-S-Justice-Department&d=nT0JRHd2LMoASC6Ir7WJpP7vEz4FU%2Bq4m%2F6ZFrWLoTs%3D&h=88aae41f\" data-auto-link target=\"_blank\">https://www.scribd.com/document/395185756/Letter-from-the-U-S-Justice-Department</a>)，孟晚舟居然擁有由香港政府發出的三本不同號碼的護照，為避免世界各國懷疑香港特區護照的可靠性，影響香港市民的利益，香港政府需要盡快徹查事件及作出公開解釋。<br />\n<br />\n<br />\n<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"1ec2f412bc957eacb1e4a2e12356d8cbcf410609","tid":933251,"uid":48083,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-12-08T14:57:55.000Z","msg":"張達明<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"67e8c6f3186efa84598e6ba856d065ff4ba306e3","tid":933251,"uid":81518,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-08T14:58:24.000Z","msg":"此回覆已被刪除"},{"pid":"a272ab2ef50511f55f43cc0cf37bbc394f0dfc63","tid":933251,"uid":100509,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2018-12-08T14:59:25.000Z","msg":"<a href=\"https://nextplus.nextmedia.com/news/latest/20160510/393865\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnextplus.nextmedia.com%2Fnews%2Flatest%2F20160510%2F393865&d=nT0JRHd2LMoASC6Ir7WJpP7vEz4FU%2Bq4m%2F6ZFrWLoTs%3D&h=1ef6cd5e\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnextplus.nextmedia.com%2Fnews%2Flatest%2F20160510%2F393865&h=5d9f73f1\" data-auto-link target=\"_blank\">https://nextplus.nextmedia.com/news/latest/20160510/393865</a><br />\n<br />\n巴拿馬洩密》毛阿敏特區護照曝光 揭居港權審批漏洞<br />\n<br />\n無住香港又唔係香港出身都拎到香港passport<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"a1d62df68d679818cef4b91fe6934678ac494790","tid":933251,"uid":197920,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-08T15:02:04.000Z","msg":"強國法律笑死人<br />\n<br />\n依家被揭發左香港護照成人比用黎做衰野<br />\n<br />\n遲啲各國家收返哂你地免簽 <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"5e4533d0139b2502202d2ffdcf80b30d99b026e3","tid":933251,"uid":162409,"like":0,"dislike":0,"score":0,"quote":{"pid":"0b30d6a394d569477f86fb81b53e60ea22e1b8df","tid":933251,"uid":4783,"like":28,"dislike":0,"score":28,"citedBy":1,"replyTime":"2018-12-08T14:54:51.000Z","msg":"張達明（法律學者）<br />\nPage Liked &middot; 7 hrs &middot; <br />\n<br />\n <br />\n註：看到一些評論，認為孟晚舟擁有三本不同號碼的特區護照不足為奇，因為在續領或補領特區護照時，護照號碼都會改變，她可能「坐飛機多過坐巴士」，所以舊護照蓋滿章後便需要換領。<br />\n<br />\n作出這些評論的人可能沒有留意當中關鍵細節，就是三本護照都是K J字頭，表示三本護照是在一段短時期內簽發，這麼快便蓋滿章的機會不高（特別是現在很多國家出入境也不再需要在護照上蓋章）。更重要的是，入境處資料顯示，護照持有人在領取新護照時，必須將舊護照交回入境處註銷，但根據美國司法部呈交的資料 (<a href=\"https://www.scribd.com/document/395185754/Surrey-RCMP-Const-Winston-Yep-s-affidavit#fullscreen&amp;from_embed,\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.scribd.com%2Fdocument%2F395185754%2FSurrey-RCMP-Const-Winston-Yep-s-affidavit%23fullscreen%26from_embed%2C&d=nT0JRHd2LMoASC6Ir7WJpP7vEz4FU%2Bq4m%2F6ZFrWLoTs%3D&h=dd9f51b3\" data-auto-link target=\"_blank\">https://www.scribd.com/document/395185754/Surrey-RCMP-Const-Winston-Yep-s-affidavit#fullscreen&amp;from_embed,</a> at p 11)，她這次是用第二本護照(即KJ0403962)入境加拿大，而並非用最新簽發的第三本護照(即KJ0479108)，這表示她在未有註銷第二本護照的情況下獲簽發第三本護照。<br />\n<br />\n故此，我仍然認為香港政府需要盡快徹查事件及作出公開解釋。<br />\n<br />\n__________<br />\n根據美國司法部呈交的文件(<a href=\"https://www.scribd.com/document/395185756/Letter-from-the-U-S-Justice-Department\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.scribd.com%2Fdocument%2F395185756%2FLetter-from-the-U-S-Justice-Department&d=nT0JRHd2LMoASC6Ir7WJpP7vEz4FU%2Bq4m%2F6ZFrWLoTs%3D&h=88aae41f\" data-auto-link target=\"_blank\">https://www.scribd.com/document/395185756/Letter-from-the-U-S-Justice-Department</a>)，孟晚舟居然擁有由香港政府發出的三本不同號碼的護照，為避免世界各國懷疑香港特區護照的可靠性，影響香港市民的利益，香港政府需要盡快徹查事件及作出公開解釋。<br />\n<br />\n<br />\n<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-08T15:03:44.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"54c895d13ee6f4194de44c3082d1d34cad44b327","tid":933251,"uid":197920,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-08T15:03:51.000Z","msg":"<blockquote>強國法律笑死人<br />\n<br />\n依家被揭發左香港護照成<span style=\"color: red;\">日</span>比人用黎做衰野<br />\n<br />\n遲啲各國家收返哂你地免簽 <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"964ab87279625ce28a2fff8f5a6f90be6fcfaa04","tid":933251,"uid":162409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-08T15:05:35.000Z","msg":"攬炒<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d3d3e74db584e29c35cafb24efa5bd6a60d40158","tid":933251,"uid":162409,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-12-08T15:05:58.000Z","msg":"香港護照從此變垃圾<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ae27389e42552f2969804ecc8f68b396889fba75","tid":933251,"uid":43428,"like":0,"dislike":0,"score":0,"quote":{"pid":"25698dad2b45445fbaa3d2d0b9a9ce3ac4801d23","tid":933251,"uid":162409,"like":1,"dislike":2,"score":-1,"quote":{"pid":"5c802fd44c1c7683acc3f27a5b79528ca0918c38","tid":933251,"uid":92178,"like":0,"dislike":13,"score":-13,"quote":{"pid":"405152682249998a8452b4244de377e462c98ef2","tid":933251,"uid":5195,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-08T11:49:01.000Z","msg":"中國律師陳南沙表示，根據《中華人民共和國國籍法》，持有中國護照人士不可同時持有其他護照如特區護照，兩者只能2選1；如孟晚舟同時持有2本護照，唯一解釋是她在取得香港居民身份及申請特區護照後，無註銷中國護照。<br />\n<br />\n孟晚舟辯方律師馬丁（David Martin）在庭上交代，孟晚舟有許多過期的護照，但她現在只有<span style=\"color: red;\">兩本有效護照</span>：一本中國護照和一本香港特區護照。香港特區護照在她遭逮捕時，已由加拿大政府收走。她的中國護照正從中國寄來，也已準備交出。"},"citedBy":1,"replyTime":"2018-12-08T12:25:50.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-12-08T13:27:13.000Z","msg":"續新時唔係要交番俾入境處<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-12-08T15:09:31.000Z","msg":"最近先續完 唔洗收"},{"pid":"3616bf21819db3d9f0a688f4198b95d2c5f343f3","tid":933251,"uid":121409,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-08T15:10:34.000Z","msg":"攞咁多護照等吳京救你<img src=\"/assets/faces/lm2/wfc2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"15918560380e6487ea342b2ee500dc82ff0d9f79","tid":933251,"uid":66324,"like":0,"dislike":0,"score":0,"quote":{"pid":"ae27389e42552f2969804ecc8f68b396889fba75","tid":933251,"uid":43428,"like":0,"dislike":0,"score":0,"quote":{"pid":"25698dad2b45445fbaa3d2d0b9a9ce3ac4801d23","tid":933251,"uid":162409,"like":1,"dislike":2,"score":-1,"quote":{"pid":"5c802fd44c1c7683acc3f27a5b79528ca0918c38","tid":933251,"uid":92178,"like":0,"dislike":13,"score":-13,"citedBy":1,"replyTime":"2018-12-08T12:25:50.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-12-08T13:27:13.000Z","msg":"續新時唔係要交番俾入境處<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-12-08T15:09:31.000Z","msg":"最近先續完 唔洗收"},"citedBy":1,"replyTime":"2018-12-08T15:12:41.000Z","msg":"但會註消 (好似係剪角)<br />\n所以如果佢有兩本無剪角而且有效的特衰護照就有問題"},{"pid":"5448b35eb8cc43558fad824a44543ea502f26dde","tid":933251,"uid":203703,"like":0,"dislike":0,"score":0,"quote":{"pid":"9022150a313dea0f43de751e6496d881011c29cd","tid":933251,"uid":31475,"like":1,"dislike":4,"score":-3,"quote":