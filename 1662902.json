Y8&h=08ea05a6\" data-auto-link target=\"_blank\">https://news.now.com/home/local/player?newsId=366767&amp;fbclid=IwAR1zmlNfkKmyCQWlvKzNwmBxb5pfES4AjKzVwzoscYg4JitINkDhw-iZ-Y8</a>"},"citedBy":0,"replyTime":"2019-10-19T06:17:40.000Z","msg":"幫襯光時。<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" />"},{"pid":"b4ccfe365bcb8fcfaab53c6f278174cabf037308","tid":1662902,"uid":78394,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-19T08:02:36.000Z","msg":"阿姐間野大埔友口馥<br />\n藍鋪"},{"pid":"f4d423d01909ecd328425d608ffdf408209df9ad","tid":1662902,"uid":64981,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-19T08:05:30.000Z","msg":"藍絲小店就一定杯葛㗎喇<br />\n<br />\n但中資企業唔單止要杯葛，仲要重點裝修<br />\n食住nba暴雪個勢，專打紅色資本，用行動向國際展示香港人抵制紅色資本"},{"pid":"dabcaf51cd372a210c0a9829c6c8699f71ca4406","tid":1662902,"uid":54303,"like":0,"dislike":0,"score":0,"quote":{"pid":"eee2978dc3af0593f71a950030142d4ec4992d5b","tid":1662902,"uid":289751,"like":11,"dislike":0,"score":11,"citedBy":2,"replyTime":"2019-10-19T05:29:51.000Z","msg":"快d擴大黃色生活圈<br />\n我要衣食住行都係黃色"},"citedBy":0,"replyTime":"2019-10-19T08:16:30.000Z","msg":"岩呀，愛支那既人死去深圳搵食<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},{"pid":"b3549fc10f64367be75186001e455495796b817a","tid":1662902,"uid":107368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-19T08:16:56.000Z","msg":"推"},{"pid":"7f8bdacc7c93299cb655de8ed0f56e420203b94e","tid":1662902,"uid":289623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-19T08:19:32.000Z","msg":"等藍絲食"},{"pid":"5ef92c476c4a8d8fc46345a20b5cf30f82b5f325","tid":1662902,"uid":268123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-19T08:29:28.000Z","msg":"【香城施政報告2019】群策群力 轉危為機<br />\n<a href=\"https://lih.kg/1656908\" data-auto-link target=\"_blank\">https://lih.kg/1656908</a><br />\n<br />\n<em><strong>政治問題</strong></em><br />\n<br />\n- 重塑公民身分戶口政策保障國家、香港安全和利益<br />\n- 取消18區區議會、建立地域市政議會<br />\n- 禁止公務人員在任前、任內和任後獲港外榮典<br />\n- 改善高鐵一地兩檢操作方式<br />\n<br />\n<em><strong>便民基建</strong></em><br />\n<br />\n- 興建東鐵、西鐵快速線並完善輕鐵和西鐵聯乘關係<br />\n- 完善機場集體運輸並加強機場、港珠澳大橋協同發展<br />\n- 修正港鐵、巴士可加可減機制<br />\n<br />\n<em><strong>醫療、教育方向</strong></em><br />\n<br />\n- 興建至少四所新區域全科醫院<br />\n- 以減少送院為目標的社區護理服務<br />\n- 重塑教育, 著重知識、技能層次分工<br />\n<br />\n求正評及幫推！"},{"pid":"19589c1e8901e54661f167ed5a35b94960b6e0e6","tid":1662902,"uid":70034,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-19T10:15:03.000Z","msg":"佢仲笑得出喎<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"bb279cdd532eb1e4afbc730ffb0627f107a87954","tid":1662902,"uid":271617,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-19T10:15:25.000Z","msg":"<img src=\"https://na.cx/i/avzrZ01.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FavzrZ01.gif&h=96fcff81&s={SIZE}\" />"},{"pid":"11200278a40b4a93a7522785bd53134524ff59c6","tid":1662902,"uid":166474,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-19T10:18:20.000Z","msg":"杯葛好過裝修啦，杯葛從來都係軟性暴力，好似一班朋友入面突然杯葛其中一個人，可以逼到果個人走向絕路<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ac813768c04fd767e66d7e21a373ecb31286a99f","tid":1662902,"uid":7818,"like":0,"dislike":0,"score":0,"quote":{"pid":"838755ad9549290fb7f31b1f0f717b216e0a65f0","tid":1662902,"uid":151352,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-10-19T05:57:22.000Z","msg":"藍絲原來得把口支持<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-19T10:19:53.000Z","msg":"有人比錢佢地咪去消費囉<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"4b721409303223559b38ecac900c47dfa81a34c2","tid":1662902,"uid":83009,"like":0,"dislike":0,"score":0,"quote":{"pid":"b4ccfe365bcb8fcfaab53c6f278174cabf037308","tid":1662902,"uid":78394,"like":0,"disl