sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.aboluowang.com%2F2020%2F0611%2F1463213.html&d=TNVh%2FXBsTmD9bRjMILuVa7tFVp6nBI01qSlVibQweWg%3D&h=ae393663\" data-auto-link target=\"_blank\">https://hk.aboluowang.com/2020/0611/1463213.html</a>"},{"pid":"62e0509a58f9ca54bc9b873b3f13771e4d73ae3c","tid":2058780,"uid":187489,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-11T08:03:45.000Z","msg":"推<br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: large;\">615 全港 黑衫、白絲帶<br />\n</span></span><br />\n民陣呼籲615全港黑衣、佩戴白絲帶，悼念梁凌杰逝世一周年。<br />\n<a href=\"https://lih.kg/2058235\" data-auto-link target=\"_blank\">https://lih.kg/2058235</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"03bb855e1a8f5458408ead3aac9121804905884e","tid":2058780,"uid":106798,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-11T08:05:44.000Z","msg":"推"},{"pid":"48c6a8c83320d06b051dffee5674c8b4d36fb947","tid":2058780,"uid":105924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-11T09:07:00.000Z","msg":"律師行話x小姐警署被強姦係真，其餘啲咩雞姦輪姦都唔係好信"},{"pid":"53b5a036cf806dbf5fe702f04597a64e1143ec7c","tid":2058780,"uid":132810,"like":0,"dislike":0,"score":0,"quote":{"pid":"c37152c09ba5d07abad7aeb3db5a19f0139c8d4b","tid":2058780,"uid":165028,"like":0,"dislike":3,"score":-3,"citedBy":2,"replyTime":"2020-06-11T00:40:36.000Z","msg":"男都姦？有冇可能"},"citedBy":0,"replyTime":"2020-06-11T09:09:39.000Z","msg":"早排有新聞話有人比警察搞春袋<br />\n<br />\n咁你話"},{"pid":"35e523524eff1af3aa808de02051d9d95d8fab05","tid":2058780,"uid":80931,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-11T09:13:06.000Z","msg":"我記得的...."}]}