d":"9f2bc79fb272efae03907d24e2de698559108715","tid":903023,"uid":20867,"like":1,"dislike":0,"score":1,"quote":{"pid":"1f0a0b2999020400e0ff93addda5f234522cdaa7","tid":903023,"uid":29804,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-15T10:20:35.000Z","msg":"個別關稅領域"},"citedBy":0,"replyTime":"2018-11-15T10:28:08.000Z","msg":"個別 = individual"},{"pid":"748302a922ef69e656c32a8b436c35fb02573469","tid":903023,"uid":19454,"like":0,"dislike":0,"score":0,"quote":{"pid":"95d1281fc106cd1257235fea505ed4d83ba02234","tid":903023,"uid":26451,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2018-11-15T10:23:11.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-11-15T10:29:02.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"3a42257660e12f57dc4288db220723c19c49945d","tid":903023,"uid":19454,"like":1,"dislike":0,"score":1,"quote":{"pid":"95d1281fc106cd1257235fea505ed4d83ba02234","tid":903023,"uid":26451,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2018-11-15T10:23:11.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-11-15T10:29:37.000Z","msg":"HK Police Force<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"7385203d9e980bf992a3126535fd8c93014f160d","tid":903023,"uid":121146,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-15T10:30:31.000Z","msg":"你地講緊自由民主  你係度講咩關稅區啊屌你<br />\n話緊你用緊香港關係法黎偷科技啊on9"},{"pid":"8da098e7e9528790bef31a7b1e3443cf68a3ada3","tid":903023,"uid":57346,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-11-15T10:44:08.000Z","msg":"依單野真係好大鑊，班庸官唔好柒啦，你要奶共都要你有利用價值架！<br />\n<br />\n香港最大作用就係做中美既門戶，美國放棄你，香港係中共眼中一d價值都冇。<br />\n<br />\n一野充公晒你成個庫房、資產、土地⋯⋯都冇所謂！<br />\n<br />\n西藏親中就比中國滅左、錫金兩邊靠就比印度滅左、不丹親印度反而無事！<br />\n<br />\n你地靠邊都靠個有少少道理講下既國家啦！<br />\n<br />\n香港既情況冇得親美，但起碼要兩邊靠啦，奶共有鬼用咩？佢絕對唔會當你自己人架！"},{"pid":"a84b673d4dea77dd44525a095e50c16ea7ebda08","tid":903023,"uid":49812,"like":0,"dislike":0,"score":0,"quote":{"pid":"b22e7cdc35d95dde3d8f7388d2da05de68f700f7","tid":903023,"uid":39527,"like":9,"dislike":0,"score":9,"citedBy":2,"replyTime":"2018-11-15T09:04:12.000Z","msg":"獨立都唔敢講  你點說服人香港同支那有分別<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-15T10:46:29.000Z","msg":"你咁講又會俾屈毛鬧「腥講人同大陸人係好撚有分別架」、「腥講好到咁，你踩乜鳩呀？」"},{"pid":"97e65d5680138806f5451c90823d494ff79cbffd","tid":903023,"uid":68904,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-15T10:48:31.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> 外國勢力"},{"pid":"a58db7b90bd888b16abd0bf86bb4927af39f2b31","tid":903023,"uid":23180,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-11-15T10:54:41.000Z","msg":"候任政務司司長邱生麻煩講野有骨氣D<br />\n<br />\n人地班愛支議員都起碼言論一致:<br />\n<br />\n工聯會立法會議會陸頌雄又指，美方提出將香港和中國內地視為同一個關稅區域，是中美貿易戰的一部分，目的是壓制中國，強調香港作為獨立關稅區，是建基於《基本法》，是國際認可，<span style=\"color: red;\">毋須由美國施捨和恩賜</span>。<br />\n<br />\n林健鋒指，有人建議將香港和中國內地視為同一個關稅區域，是「火上加油」、「唯恐天下不亂」，認為香港是全世界最自由的經濟體，批評是別有用心的人，提出損人不利己的建議，斥提出的人要不是無常識，要不就是想煽風點火。他又反駁報告中對香港言論自由的憂慮，認為是與事實不符，強調香港按《基本法》落實一國兩制，並依法享有言論自由，指外國政府不應介入香港事務。<br />\n<br />\nDAB葛博士則指，若美國採取單邊主義，加強科技出口管控政策，會拖慢人類整體科技發展，同時會激發其他技術相對落後的國家在科研上發奮圖强，認為做法損人又不利己。她形容，「欲加之罪何患無辭」，斥美國千方百計遏制中國的社會經濟和科技發展，甚至不惜以抺黑及打擊香港以制衡中國，又批評反對派議員為虎作倀，附和美國的一派胡言。<br />\n<br />\n<br />\nBtw,既然吹到個獨立關稅區係國際認可，你地又講咁多廢話干預人地內政做咩?"},{"pid":"f31e27f11438e7cb5cb1f9565509b312380a7296","tid":903023,"uid":46700,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-11-15T11:20:39.000Z","msg":"侵已經聽夠贏國講呢套說話<br />\n家陣香港仲要重複多幾次<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"60a2eed867199cafe2c140228aeb4981e603cc9a","tid":903023,"uid":11809,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-15T11:31:50.000Z","msg":"你老闆話唔撚驚咯<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"16219cfef86589f5105ea63760af926302b4bc9e","tid":903023,"uid":11809,"like":0,"dislike":0,"score":0,"quote":{"pid":"403366d55da801f6fc14162bbec6bfa505700e6d","tid":903023,"uid":91631,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-11-15T09:19:43.000Z","msg":"呢幾年個政府做過d咩<br />\n你唔係以為歐美國家係盲架下話<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n<br />\n以為講兩句就無數咩"},"citedBy":0,"replyTime":"2018-11-15T11:33:28.000Z","msg":"佢當人老馮<img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" />"},{"pid":"b609187503f8fd5adb17fc3121d37f914294807a","tid":903023,"uid":49102,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-15T11:43:01.000Z","msg":"食兩家茶禮唔得㗎喎<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"45857bbb2417c18275324f04a9fc5f2f4ae3d5bc","tid":903023,"uid":63311,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-15T11:44:17.000Z","msg":"冇美國比你 你會有？ 從來？<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"51dd561ac836d0fc1e31a977185f506150fe044a","tid":903023,"uid":90735,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-11-15T11:46:31.000Z","msg":"依家<span style=\"color: red;\">獨立</span>關稅區都唔講得，要用<span style=\"color: red;\">單獨</span><br />\n<br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"}]}