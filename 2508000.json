/na.cx/i/hS6BQiF.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhS6BQiF.png&h=1f33544f&s={SIZE}\" />"},"citedBy":1,"replyTime":"2021-04-28T12:17:44.000Z","msg":"條女打扮似大陸人<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"f9e293a7bc699581f4ca3a84bd5fe950abcc63f7","tid":2508000,"uid":329466,"like":0,"dislike":0,"score":0,"quote":{"pid":"3773c01aaa49d313b2cb14ea8f4b0006b261fe8c","tid":2508000,"uid":258174,"like":1,"dislike":0,"score":1,"quote":{"pid":"e65e738764f59a611a10e6fa7b403e58ee34b05a","tid":2508000,"uid":219128,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2021-04-28T12:07:16.000Z","msg":"<img src=\"https://na.cx/i/xhraULi.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxhraULi.png&h=54f1489a&s={SIZE}\" /><img src=\"https://na.cx/i/hS6BQiF.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhS6BQiF.png&h=1f33544f&s={SIZE}\" />"},"citedBy":1,"replyTime":"2021-04-28T12:17:44.000Z","msg":"條女打扮似大陸人<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-28T12:19:03.000Z","msg":"對眼咁撚闊一定有支那種"},{"pid":"a68a2d6472ef3d9bc4606729e8bf94a16d53cfbf","tid":2508000,"uid":135124,"like":0,"dislike":0,"score":0,"quote":{"pid":"24e5d2b425791575597ece7415ee32611f2aad7e","tid":2508000,"uid":71508,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-04-28T11:58:08.000Z","msg":"Kongu仔仲衰過ive仔<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-28T12:21:23.000Z","msg":"元朗喎<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"258fdfb8ffa76f63f621c908e07c97c4e058650c","tid":2508000,"uid":146525,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-28T12:21:31.000Z","msg":"FB-&gt;連登-&gt;公海-&gt;連登"},{"pid":"167fb2f8a8db0ee812dc1b11845aa567b7a6b34b","tid":2508000,"uid":342823,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-28T12:23:18.000Z","msg":"他指年初與朋友叫外賣，發現朋友經foodpanda訂餐後不用付款，才獲悉這蠱惑招，「學校好多人都咁做」。<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"e9fff86dd50dfb3e950c8e7bf0e6394e05176fc6","tid":2508000,"uid":57151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-28T12:23:57.000Z","msg":"咁少錢都呃<img src=\"/assets/faces/dog/beg_connect.gif\" class=\"hkgmoji\" />"}]}