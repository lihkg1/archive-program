.pk/6ztcv4rg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2F6ztcv4rg&h=13c97fc6&s={SIZE}\" />"},{"pid":"f0eacd2bd6bba3beff5e76afd1554d2d06dab39b","tid":36462,"uid":19557,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-12T20:14:46.000Z","msg":"<blockquote><blockquote>有免費牌都做唔住唔通有人特登去第個平台睇你？</blockquote><br />\n100毛都無免費牌但大把人睇<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n毛記依家都走下坡喇 新屎坑三日香 <br />\n仲要依家係atv 做 一定係d 共匪類節目 邊有人睇架<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4ea6dce4918c26d3af40081c073fab7571954759","tid":36462,"uid":21056,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-12T23:00:06.000Z","msg":"又未死呀？"},{"pid":"a52b4d706cf0f2badbb32effa398cf9eaac93dc4","tid":36462,"uid":41821,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-13T00:40:44.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"bbeecd92ecfc7dbb1c2dc82de49d9e8cad9f1bbd","tid":36462,"uid":42326,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-13T00:42:56.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> 搵緊工<br />\n想做"}]}