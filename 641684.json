續：點解咁多負皮<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"c0b61983ed893b080b6c27cd81d891e85cdeacf1","tid":641684,"uid":81598,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-29T03:22:23.000Z","msg":"豬撚到仆街"},{"pid":"a3aa7b92da64b383dd9fe3c003c1f30c9223b7d4","tid":641684,"uid":97486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-29T04:13:38.000Z","msg":"Pish"},{"pid":"964a0b7fa23689e3b295a23eeb75631bc3db9192","tid":641684,"uid":15481,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-29T20:15:05.000Z","msg":"出快啲啦<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"}]}