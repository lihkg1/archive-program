b2f0b1c980e826ceb46ea5","tid":2376571,"uid":7323,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-23T02:14:35.000Z","msg":"<span class=\"xx-large\">好!</span>"},{"pid":"329b26bccc59a77867e2f638e5e04273a3baf7e8","tid":2376571,"uid":129828,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-01-23T02:17:08.000Z","msg":"點解會有一個負皮<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},{"pid":"66d621242bdc044ad4fb4e4a076b8be4318a637b","tid":2376571,"uid":245879,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-01-23T02:18:12.000Z","msg":"狂賀！ btw uninstall有線啦樓主"},{"pid":"a3065a1542d04bdf5020d6dda17992f02f52ee84","tid":2376571,"uid":297997,"like":7,"dislike":0,"score":7,"quote":{"pid":"329b26bccc59a77867e2f638e5e04273a3baf7e8","tid":2376571,"uid":129828,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-01-23T02:17:08.000Z","msg":"點解會有一個負皮<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-23T02:18:13.000Z","msg":"一定係Mon po 撚屌狗"},{"pid":"859a36f1ff7e3a8abb2950b75c25c5794463e294","tid":2376571,"uid":177168,"like":0,"dislike":0,"score":0,"quote":{"pid":"329b26bccc59a77867e2f638e5e04273a3baf7e8","tid":2376571,"uid":129828,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-01-23T02:17:08.000Z","msg":"點解會有一個負皮<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-23T02:39:12.000Z","msg":"一名男警員初步確診2019冠狀病毒病<br />\n＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊<br />\n  一名駐守香港警察學院的四十歲男警員初步確診2019冠狀病毒病。他的家人較早前懷疑對2019冠狀病毒病呈陽性反應，於是他亦安排接受測試。昨日（一月二十二日）該名男警初步證實對2019冠狀病毒病呈陽性反應。他於過去十四日沒有外遊記錄，工作期間有佩戴口罩，並沒有與公眾接觸。他最後一日上班日為一月十九日。<br />\n<br />\n  警方高度關注事件，並有以下訊息：<br />\n<br />\n  一）在等候衞生署進一步評估及建議前，與該名警員可能有緊密接觸的警務人員及文職人員，均獲安排接受病毒檢測；<br />\n<br />\n  二）警方會派員清潔及消毒該名警員的相關工作地方；<br />\n<br />\n  三）警方亦經常提醒同事注意個人衞生，減少社交接觸，減低傳染風險，如有任何不適，須立即呈報並求醫；以及<br />\n<br />\n  四）警方會靈活調派人手，確保相關服務不受影響。<br />\n<br />\n  警方將會繼續與衞生署保持緊密聯繫，主動提供該名警員的近日工作記錄和執勤表等資料，以及安排相關密切接觸者進入檢疫中心接受檢疫。<br />\n <br />\n完<br />\n2021年1月23日（星期六）<br />\n香港時間9時05分<br />\n新聞資料庫   <br />\n<a href=\"https://www.info.gov.hk/gia/general/202101/23/P2021012300230.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.info.gov.hk%2Fgia%2Fgeneral%2F202101%2F23%2FP2021012300230.htm&d=0UfJYUPH4CcS6uVeskuI5G9Dn5prBKp8mj11ELPip4s%3D&h=7a7dab81\" data-auto-link target=\"_blank\">https://www.info.gov.hk/gia/general/202101/23/P2021012300230.htm</a>"},{"pid":"05a0082c636fdf531b39faff9515b9ad97b80718","tid":2376571,"uid":218082,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-01-23T02:40:06.000Z","msg":"確診係唔夠,中武肺死先夠<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"6fb2a904894e50a97b19b5df84457db830c78430","tid":2376571,"uid":46161,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-23T02:40:44.000Z","msg":"犬舍"},{"pid":"f8a97b0b3ae7722fe938343c1c420a59e3744ac6","tid":2376571,"uid":41861,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-01-23T02:41:07.000Z","msg":"學院都要駐守<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c1653992c22c15b5a94ad610a55ae2ada6890e6a","tid":2376571,"uid":10998,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-01-23T03:09:57.000Z","msg":"死咗先報啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />次次都係一隻半隻中招"},{"pid":"01c9ccea9a38c6e8bf9e2c734b017e2812ee5f28","tid":2376571,"uid":76382,"like":1,"dislike":0,"score":1,"quote":{"pid":"f8a97b0b3ae7722fe938343c1c420a59e3744ac6","tid":2376571,"uid":41861,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-01-23T02:41:07.000Z","msg":"學院都要駐守<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-23T03:40:13.000Z","msg":"可能係教官之類"},{"pid":"8bc4e87a9ca80215a3113bf8a8f7617f03a9b16c","tid":2376571,"uid":295459,"like":0,"dislike":0,"score":0,"citedB