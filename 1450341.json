ass=\"hkgmoji\" />"},{"pid":"8941b92dec87c7285f7d0825ce962dcfaf850093","tid":1450341,"uid":33668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T07:28:22.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />回頭是岸呀"},{"pid":"9bb2041d7b229374ec77ef064b20266bd7919bd2","tid":1450341,"uid":33668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-31T04:56:12.000Z","msg":"致前線香港警察：831勸降書<br />\n<a href=\"https://lih.kg/1521004\" data-auto-link target=\"_blank\">https://lih.kg/1521004</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"535dcd7f0d635a2e4c445e5d627bb9d74e06c470","tid":1450341,"uid":237809,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-31T06:05:45.000Z","msg":"此回覆已被刪除"},{"pid":"7ef2ca3e8e302bb048c0632c7bcd098761a4d5fc","tid":1450341,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-31T06:06:26.000Z","msg":"<div style=\"text-align: center;\">830 大濫捕 黑警被斬 完全將焦點轉移<br />\n<br />\n提提大家 我地今日出黎目的係<br />\n<br />\n因為5年前831中共就普選設下「提名委員會」<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: x-large;\">還我真普選！</span></span><br />\n<br />\n今日港島見！<br />\n<span style=\"color: orange;\">Sogo&mdash;&mdash;&gt;遮打<br />\n遮打&mdash;&mdash;&gt;Sogo</span><br />\n<br />\n光復香港 時代革命<br />\n<br />\n<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /></div>"}]}