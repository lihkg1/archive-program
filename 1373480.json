aces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"77c46f7ea44ed47ebfdf09e08d15af37fa5ff734","tid":1373480,"uid":28503,"like":0,"dislike":0,"score":0,"quote":{"pid":"ed102ad8360cfcb71e7da1b40d2aebbe1d72f3f8","tid":1373480,"uid":235515,"like":0,"dislike":0,"score":0,"quote":{"pid":"e113b397887f8b3d1bc2599e3b04498d9a951e31","tid":1373480,"uid":28503,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-07-27T15:48:55.000Z","msg":"係咁唔誤傳尾班車真係好戇鳩<br />\n果到起碼走左幾百人<br />\n如果冇走 起碼整多個朗屏站戰線分散黑警兵力<br />\n不過過左去就算 下次唔好自亂陣腳"},"citedBy":1,"replyTime":"2019-07-27T15:51:25.000Z","msg":"明明楊岳橋都係咁叫話仲有車，班人都仲係到叫話尾班車"},"citedBy":0,"replyTime":"2019-07-27T15:57:31.000Z","msg":"真係好多人誤報軍情<br />\n朗屏走左百幾人之後我仲磨左陣都冇事<br />\n返到屋企沖哂涼先見到元朗站出速龍<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"110fadf94382bef1b9441ac91453b1ef627e5658","tid":1373480,"uid":55810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T16:00:32.000Z","msg":"所以次次都要睇定啲先，根本好多時都鳩叫，叫走晒啲back up"},{"pid":"21c5c9d2ed08db1fb6fdda2df23e99a7ed110c5c","tid":1373480,"uid":55810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T16:02:04.000Z","msg":"同埋 有冇可能六七點就尾班車呀？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4bdf6cebc3c024c8c7f72cd999149a09522475b4","tid":1373480,"uid":17008,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T16:05:07.000Z","msg":"唔知得咁少 以為好多警察包緊 <br />\n<br />\n雖然話 今晚危險 唔適合留太夜 但都要見到有一定威脅先走下ma<br />\n唔係話要留到最後 但留多多一分鐘  都有一定作用<br />\n留係站大堂 月台怕乜 咩都無做過<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}