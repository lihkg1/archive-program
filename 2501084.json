hkgmoji\" />"},{"pid":"23196de9638e78d37aec247e405728b885fe16cd","tid":2501084,"uid":339630,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-23T07:26:52.000Z","msg":"腦細照肺唔做野 --&gt; 有人走 --&gt;啲野冇人做 --&gt;啲人做唔切 --&gt;腦細照肺唔做野 --&gt; 有人走 --&gt; 無限loop<br />\n<br />\n其實個腦細都幾on9, 係唔夠人就落力啲留人啦， 一未照肺就會無啦啦做倒啲野去？"},{"pid":"e1dad10bb49770509eff618b95bc40b5aa44d811","tid":2501084,"uid":3172,"like":4,"dislike":1,"score":3,"quote":{"pid":"177bd7e975e5866577de42b48d8be9ac981faaf5","tid":2501084,"uid":88327,"like":3,"dislike":14,"score":-11,"quote":{"pid":"afa8811d993bfc9d2ce84e0751468022f6f1862b","tid":2501084,"uid":23445,"like":13,"dislike":2,"score":11,"citedBy":2,"replyTime":"2021-04-23T06:34:55.000Z","msg":"人工幾多先?<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-04-23T06:40:49.000Z","msg":"兩皮幾，未到3皮<img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-04-23T07:28:11.000Z","msg":"am得2皮幾<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"c6b0ec0d3500ea3520bde9fc3afd4598410d3a2b","tid":2501084,"uid":72228,"like":0,"dislike":1,"score":-1,"quote":{"pid":"177bd7e975e5866577de42b48d8be9ac981faaf5","tid":2501084,"uid":88327,"like":3,"dislike":14,"score":-11,"quote":{"pid":"afa8811d993bfc9d2ce84e0751468022f6f1862b","tid":2501084,"uid":23445,"like":13,"dislike":2,"score":11,"citedBy":2,"replyTime":"2021-04-23T06:34:55.000Z","msg":"人工幾多先?<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-04-23T06:40:49.000Z","msg":"兩皮幾，未到3皮<img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-23T07:31:28.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />邊行咁悲哀"},{"pid":"bbfec8da2b0493598b9544b5a95a00c4d62dca04","tid":2501084,"uid":198175,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2021-04-23T07:32:25.000Z","msg":"過咗試用期未,&nbsp;未過係咪可以1個星期通知走人?<br />\n<br />\n有糧出住,&nbsp;點解要即刻走? 梗係到試用期完前先遞信,&nbsp;hea住做, 要見工就請事假,&nbsp;搵工優先<br />\n<br />\n呢份工你先做咗2個星期,&nbsp;CV都廢Q事寫入去, 見工時提都唔好提,&nbsp;HR會話你jumpy唔捱得<br />\n<br />\n仲有你都識講D deadline過晒先開始做,&nbsp;即係呢D所謂deadline係流嘅,&nbsp;set嚟係畀你去miss,&nbsp;呢間公司管理咁Q亂嚟,&nbsp;你咪當入去玩一陣見識吓<img src=\"/assets/faces/lm2/yeah.gif\" class=\"hkgmoji\" />"},{"pid":"3b288fa857f6966d4570a3af6662a2f37b07248d","tid":2501084,"uid":47556,"like":0,"dislike":0,"score":0,"quote":{"pid":"0161d539063138223a4ce47cc16f8a5a2be2fdca","tid":2501084,"uid":88327,"like":0,"dislike":0,"score":0,"citedBy":5,"replyTime":"2021-04-23T06:25:36.000Z","msg":"話說轉咗新工兩個星期，開始發現愈來愈唔對路<br />\n每個星期都有同事last day<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><br />\n同事話我呢個位係replacement ，同team本來有4個人，走咗3個...而家請返我1個<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n<br />\n工作量唔係話好多（因為新入職咩系統都未開）<br />\n不過已經感受到好多有deadline 既野都過咗deadline先比我做...<br />\n<br />\n早兩日腦細照肺，叫我搵D新生意比公司<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />（心諗：What?/舊野都未做得切，重想搵新？）又話我手腳慢，D job過晒期（<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />因為你過咗期先比我做啫）<br />\n<br />\n已經send緊CV搵緊工，諗緊過唔過到下星期，驚到時又比腦細照肺<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n不如早D遞信，廢事拖兩拖又話過唔到試用期，寫花我CV"},"citedBy":0,"replyTime":"2021-04-23T07:32:53.000Z","msg":"唔過試用都唔會落CV架喇，點樣整花你CV呀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"46241b2d003198b2740b01cc074de01e6d9088df","tid":2501084,"uid":33959,"like":3,"dislike":0,"score":3,"quote":{"pid":"c4c3f81dc3828b59ba6eeca500b962b1a08ed162","tid":2501084,"uid":88327,"like":1,"dislike":47,"score":-46,"quote":{"pid":"f7ef9c