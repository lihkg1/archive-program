3:49.000Z","msg":"十卜 留名跟進"},{"pid":"3633e29d4379c86eb6936504b656fda25c5f9039","tid":610921,"uid":98659,"like":0,"dislike":0,"score":0,"quote":{"pid":"860588c50038358a87e87c0c85f73ba25b40aa05","tid":610921,"uid":21041,"like":0,"dislike":0,"score":0,"quote":{"pid":"152643ea7e4518761a881d40e0cdbb30aaf1d13b","tid":610921,"uid":15921,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-01T10:28:56.000Z","msg":"林芝應該仲睇到桃花<br />\n睇下入唔入到新措"},"citedBy":1,"replyTime":"2018-04-01T10:32:21.000Z","msg":"新措靚撚到<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />  好想返去"},"citedBy":0,"replyTime":"2018-04-01T16:00:30.000Z","msg":"果陣就花去到，乜撚都睇唔到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ddf14cca28b215acb9c7d592f66cb30f3b40fbcb","tid":610921,"uid":70832,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-01T16:16:48.000Z","msg":"留名"},{"pid":"c35d87ae60372bdb1f01bb9009161e7276a4c5c8","tid":610921,"uid":126038,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-01T16:20:05.000Z","msg":"娃娃際堅好食"},{"pid":"0fe24dda254a920125764e2f32298af48ef718d2","tid":610921,"uid":15916,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-01T16:28:54.000Z","msg":"上年都去左 一樣路線<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"023b79b6d4e55f8235a82d73e68ce1b71f9aa2ff","tid":610921,"uid":67699,"like":0,"dislike":0,"score":0,"quote":{"pid":"c35d87ae60372bdb1f01bb9009161e7276a4c5c8","tid":610921,"uid":126038,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-01T16:20:05.000Z","msg":"娃娃際堅好食"},"citedBy":0,"replyTime":"2018-04-01T16:55:20.000Z","msg":"<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <br />\n點煮法？"},{"pid":"b80b0beec56abe1d5d6ea2fef195545ea147437c","tid":610921,"uid":67699,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-01T17:12:04.000Z","msg":"Day 2<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/02/005909_26e69d51bc7a317c8f4aff5f0f55a53a.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F02%2F005909_26e69d51bc7a317c8f4aff5f0f55a53a.png&h=940e2907&s={SIZE}\" /><br />\n<br />\n10蚊人仔早餐<br />\n個饅頭乾到以為自己行軍要帶上路食<br />\n不過入得西藏，堅係要預無啖好食<br />\n清清淡淡算係咁<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/02/010253_0ba1b3f35a6bc1d6e28d39e3156a1b13.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F02%2F010253_0ba1b3f35a6bc1d6e28d39e3156a1b13.png&h=07e22614&s={SIZE}\" /><br />\n<br />\n今日第一個行程係先去整車先！因為個車尾箱門開唔到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 師傅話我地係千年一遇嘅黑仔王⋯⋯第一日先係高速公路塞左兩個半鐘，上到山又落雨落雪兼大霧，然後今日又因為稻城亞丁落雪，無謂入去爬山無嘢睇，最後決定改道！<br />\n<br />\n經商議後，走完林芝會行山南路線<br />\n再玩返上拉薩"},{"pid":"390642a5fdf7322c41a02ebd4d4657e1ae3f3e6d","tid":610921,"uid":143621,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-01T17:21:24.000Z","msg":"有冇踩單車去過嘅巴打？ 揮個手<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"d63996889ee0eb59075c1363b37d857a12edaeea","tid":610921,"uid":84508,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-01T17:24:07.000Z","msg":"包車幾錢"},{"pid":"dfd488ba0f4ecb1676db968a3acd77037fe302ea","tid":610921,"uid":29188,"like":0,"dislike":0,"score":0,"quote":{"pid":"6868be1c7ec993449b23ee160bcac03fbddbd3a3","tid":610921,"uid":67699,"like":0,"dislike":0,"score":0,"quote":{"pid":"6ddf71e2b49f6b3c716d0d2cb1b7f28c9b870777","tid":610921,"uid":126590,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-01T11:13:45.000Z","msg":"娃娃魚唔係禁食架咩？"},"citedBy":1,"replyTime":"2018-04-01T12:24:43.000Z","msg":"唔知呀 明買明賣"},"citedBy":0,"replyTime":"2018-04-01T17:47:15.000Z","msg":"野生唔得，但養殖可以"},{"pid":"34abb9ebc7719252f3531e3e2e724f830c57ab8a","tid":610921,"uid":67699,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-02T04:19:19.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/04/02/115148_c0942f42ddeca295c4c975406f552f9e.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F02%2F115148_c0942f42ddeca295c4c975406f552f9e.png&h=a084e7dd&s={SIZE}\" /><br />\n<br />\n包車最好既地方係<br />\n見到靚景可以即刻叫司機停低<br />\n咁既雪景真係一流<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/02/121824_47ebe8b42dd99211d2ada5a4e4736314.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F02%2F121824_47ebe8b42dd99211d2ada5a4e4736314.png&h=71f84321&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/04/02/121852_7e3b9758400fff6ad8fc486483ed5501.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F02%2F121852_7e3b9758400fff6ad8fc486483ed5501.png&h=956e8fbd&s={SIZE}\" />"},{"pid":"1dff77659b771dff7af7c29f8ba0c06e4cc6dcaf","tid":610921,"uid":34394,"like":0,"dislike":0,"score":0,"quote":{"pid":"aa691d66e96f0c26d92c84c6a26490720bea2c30","tid":610921,"uid":67699,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-01T10:02:36.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/04/01/175930_762ee73479344ea04a1471eb2a510355.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F01%2F175930_762ee73479344ea04a1471eb2a510355.png&h=f866edd5&s={SIZE}\" /><br />\n<br />\n食飯見到又有啲你唔知點解會食嘅嘢<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-02T04:22:47.000Z","msg":"唔係瀕危動物嚟架咩<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"bb7f7ebfa5fb99cdbfaccf91a9c42e9ddd6257a7","tid":610921,"uid":67699,"like":0,"dislike":0,"score":0,"quote":{"pid":"d63996889ee0eb59075c1363b37d857a12edaeea","tid":610921,"uid":84508,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-01T17:24:07.000Z","msg":"包車幾錢"},"citedBy":0,"replyTime":"2018-04-02T04:47:34.000Z","msg":"因為個行程變黎變去<br />\n出發前一星期先搵到<br />\n一日都2000人仔一架車<br />\n唔知叫正常定貴"},{"pid":"cc30a0f4b2a42827be06dc366f5fc67225a0ace0","tid":610921,"uid":67699,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-02T10:34:27.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/04/02/182757_ce508e328fc84927ab03b703663750fd.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F02%2F182757_ce508e328fc84927ab03b703663750fd.png&h=a68a46f7&s={SIZE}\" /><br />\n<br />\n趕路上巴塘住左晚之後<br />\n終於今日出發，叫做踏入西藏啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n一邊係西藏界，一邊係四川界<br />\n好多人停低影相留念<br />\n<br />\n好似話川藏線最爛既路就係依段<br />\n其他都修得七七八八<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/02/183111_a28ba83a3e17607ca5db20c26dedde4f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F02%2F183111_a28ba83a3e17607ca5db20c26dedde4f.png&h=81493c65&s={SIZE}\" /><br />\n<br />\n去到某個影相位時，山下有架爛車<br />\n其實係川藏路線都幾常見既，爛車到處都係<br />\n不話個度有個牌<br />\n寫左啲咁嘅嘢⋯⋯⋯<br />\n<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/02/183341_f471e8eb3fcaf22b2c213a33b1ecf0d0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F02%2F183341_f471e8eb3fcaf22b2c213a33b1ecf0d0.png&h=55402c21&s={SIZE}\" />"},{"pid":"89ef29824ff699631bc42bdc60b9efaf53762083","tid":610921,"uid":61697,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-02T13:19:48.000Z","msg":"lm"},{"pid":"4b76a64c224222d44662d433d10eeff3e1f15af5","tid":610921,"uid":67699,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-03T05:33:34.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/04/03/132945_900f74b3e037a3c402f0dc1fce3c3d9f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F03%2F132945_900f74b3e037a3c402f0dc1fce3c3d9f.png&h=9ece7ddb&s={SIZE}\" /><br />\n<br />\n仲未到林芝但已經有桃花<br />\n好靚啊<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/03/133315_e5f63b8fd3302d8bdda880e3d974e776.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F03%2F133315_e5f63b8fd3302d8bdda880e3d974e776.png&h=edcfc57d&s={SIZE}\" />"}]}