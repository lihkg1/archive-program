f\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/KbguuwO.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKbguuwO.png&h=efad5478&s={SIZE}\" />"},{"pid":"f3435482640991e79d3c121ad7e0296ffd6f777f","tid":1277151,"uid":67043,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T07:27:34.000Z","msg":"仲有最重要一點係已有3位義士"},{"pid":"04b5c5f144eaa4f9ef901eec3293241d44b666ed","tid":1277151,"uid":60037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T00:05:01.000Z","msg":"老實講，勁太多。台灣太陽花唔算係一個成功嘅社運。"},{"pid":"1889943c8a9d9ee328a624ea782d6a39d85644e7","tid":1277151,"uid":35438,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T00:15:20.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}