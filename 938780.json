z4KPzs.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FYz4KPzs.png&h=3dd55819&s={SIZE}\" />"},"citedBy":2,"replyTime":"2018-12-12T15:16:44.000Z","msg":"你試下用hdmi直駁<br />\n<br />\n如果個mon太舊冇hdmi頭就將你部電腦駁落電視度開機，見到有畫面姐係adapter問題"},"citedBy":1,"replyTime":"2018-12-12T15:23:18.000Z","msg":"其實佢張卡嗰兩個DVI頭都係DVI-D, 根本冇analog signal出, 係冇可能靠個頭就轉到VGA, 一定要係主動式轉換先得"},"citedBy":2,"replyTime":"2018-12-12T15:27:12.000Z","msg":"咁姐係我要買過個mon?<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"d169f8ad78324f32223ec375e463a6944e32a310","tid":938780,"uid":61942,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-12T15:31:39.000Z","msg":"換埋個mon啦 1060 6gb仲要用vga<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n我有隻應該用左十年既mon都齊dvi hdmi"},{"pid":"d500f512a6c5d406c99891d41be45b056f75a1e2","tid":938780,"uid":196924,"like":4,"dislike":0,"score":4,"quote":{"pid":"b78386aab5bdfadae89c97f301ca5cf769b7ae7f","tid":938780,"uid":18276,"like":0,"dislike":0,"score":0,"quote":{"pid":"630244a3f43d6aaac7fd94bc09b5a91e71f9f00f","tid":938780,"uid":196924,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-12T15:16:01.000Z","msg":"Dual-link DVI-D *2\u000b<br />\nHDMI-2.0b*1 (Max Resolution: 4096x2160 @60 Hz)<br />\n\u000bDisplay Port-1.4 *1 (Max Resolution: 7680x4320 @60 Hz)<br />\n<br />\nDVI-D冇得直轉VGA喎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 你買咗個咩轉插<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-12-12T15:21:52.000Z","msg":"我都唔知 唔太識電腦 好努力google<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-12T15:32:20.000Z","msg":"&quot;VGA&quot;係傳統analog signal(「模擬信號」) ;<br />\n而&quot;HDMI&quot;就係digital signal(「數碼信號」);<br />\n&quot;DVI&quot; 就有三類, 三類針腳別同信號係有分別:<br />\n第一類&quot;DVI-A&quot; 只出analog signal (此類極少見),<br />\n第二類&quot;DVI-D&quot; 只出digital signal,<br />\n第三類&quot;DVI-I&quot; 兩種signal都出。<br />\nDVI-I/ DVI-D 同HDMI兼容, 可直接被動轉換, DVI-I/ DVI-A 就可以被動轉成VGA。<br />\n你張卡係<br />\nDual-link <span style=\"color: red;\">DVI-D</span> *2\u000b<br />\nHDMI-2.0b*1 (Max Resolution: 4096x2160 @60 Hz)<br />\n\u000bDisplay Port-1.4 *1 (Max Resolution: 7680x4320 @60 Hz)<br />\n因為只得Digital, 而VGA係純analog, 理論上要轉換就必須靠「主動式」轉換, 一般冇可能靠一個咁既轉接頭就轉到。<br />\n「被動式」轉換: 信號本身兼容, 唔需要做任何嘢就轉到, e.g. DVI-D -&gt; HDMI<br />\n「主動式」轉換: 信號本身唔兼容, 要靠晶片接收信號處理完再output, e.g. DVI-D -&gt; VGA, DP -&gt; VGA"},{"pid":"23b21fb8a59c6a4915990c746c189cc2dfb9f1e3","tid":938780,"uid":196924,"like":0,"dislike":0,"score":0,"quote":{"pid":"36620436da6d043c44eeb3d4f8f4875d1b260c81","tid":938780,"uid":18276,"like":0,"dislike":0,"score":0,"quote":{"pid":"ee0e885696197e89c8dc22c6a6d6a28f135e6d1e","tid":938780,"uid":196924,"like":0,"dislike":0,"score":0,"quote":{"pid":"68907c4c585f4493e1ae9a258fe62ec3918d63c9","tid":938780,"uid":208752,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-12-12T15:16:44.000Z","msg":"你試下用hdmi直駁<br />\n<br />\n如果個mon太舊冇hdmi頭就將你部電腦駁落電視度開機，見到有畫面姐係adapter問題"},"citedBy":1,"replyTime":"2018-12-12T15:23:18.000Z","msg":"其實佢張卡嗰兩個DVI頭都係DVI-D, 根本冇analog signal出, 係冇可能靠個頭就轉到VGA, 一定要係主動式轉換先得"},"citedBy":2,"replyTime":"2018-12-12T15:27:12.000Z","msg":"咁姐係我要買過個mon?<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-12-12T15:33:24.000Z","msg":"而家都2018年, 純VGA而有1080p既mon應該極少, 你個Mon係咪用咗好耐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ae9f28a0c075c9da0a18f82ab2bbbba76d11be85","tid":938780,"uid":61942,"like":0,"dislike":0,"score":0,"quote":{"pid":"36620436da6d043c44eeb3d4f8f4875d1b260c81","tid":938780,"uid":18276,"like":0,"dislike":0,"score":0,"quote":{"pid":"ee0e885696197e89c8dc22c6a6d6a28f135e6d1e","tid":938780,"uid":196924,"like":0,"dislike":0,"score":0,"quote":{"pid":"68907c4c585f4493e1ae9a258fe62ec3918d63