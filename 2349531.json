">https://hkshadowparliament.com/zh/%e6%84%8f%e8%a6%8b%e6%94%b6%e9%9b%86/</a>"},{"pid":"cd35effc8dbf017d107b3965aae2ed3ec58ca33a","tid":2349531,"uid":164837,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T16:08:17.000Z","msg":"push"},{"pid":"68ad5c82a8235a6d32d70ba6baac47162e421c8f","tid":2349531,"uid":164837,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T16:29:28.000Z","msg":"push"},{"pid":"0fc499ce9f15c23e07f4383a5342c4b41ac266f6","tid":2349531,"uid":293511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:10:49.000Z","msg":"push"},{"pid":"702b1ea3c5545d49d5e55011c97b0b2513c2144c","tid":2349531,"uid":293511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:11:16.000Z","msg":"<img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" />"},{"pid":"49f5761041d1f267267c10d2f62e34cec0bbac95","tid":2349531,"uid":293511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:13:22.000Z","msg":"<img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b295480add599953ae4bb5696a0966a3257e3304","tid":2349531,"uid":293511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:15:19.000Z","msg":"push"},{"pid":"379492e70c5738b529c5429fb878667ae311c9d1","tid":2349531,"uid":293511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:15:37.000Z","msg":"push"},{"pid":"1e890456f955b517a3c3aae6b90c29db538c4ced","tid":2349531,"uid":293511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:35:09.000Z","msg":"push"},{"pid":"186922103fe61dcc08b17fb20b7bb2a6bcd6118f","tid":2349531,"uid":182197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T19:46:35.000Z","msg":"Push"},{"pid":"396a579a2a9311d102bce91696538fe44a748061","tid":2349531,"uid":293511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T20:53:49.000Z","msg":"<img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" />"},{"pid":"d542acf6fc0aa08a0640f4aab1033aed2d9926d7","tid":2349531,"uid":293511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T21:02:27.000Z","msg":"<img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" />"},{"pid":"99852de996bcbf24ea93040b02eb062872f9ad7c","tid":2349531,"uid":329551,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-01-01T21:08:40.000Z","msg":"美國大選話俾我哋聽，身份要保密嘅話又冇嚴格嘅合格選民名單嘅話根本冇可能。到最後要靠大家老實。<br />\n<br />\n證實香港人身份可以用FB入Group先過Admin嘅方法，但<strong>考核去中間化</strong>。利用被隨機被派做<em>考官</em>(身份核實陪審團)N次嘅公民參與作爲代價，增加大量作弊(灌水)嘅人力成本同知識需求。<br />\n<br />\n申請程序:<br />\n1) 每個申請者會獲派2個考官，兩個考官決定唔一致嘅話由第三考官決定。<br />\n2) 用一對一短信形式對話。申請者嘅回答不會保留紀錄，免得考官亂問身份證號碼，申請人又傻傻咁報上。<br />\n3) 考官覺得50-50問唔出嚟嘅話可以Pass換人問<br />\n4) 申請者如果覺得考官問題離譜可以 Report + 換人。<br />\n<br />\n考官任務<br />\n1) 問題由考官自行判斷。要問啲唔係香港人好大機會唔識得答，但香港人一定識得嘅題目。可以有 Follow Up question. <br />\n2) 唔好問啲套料/主觀問題，例如係黃係藍，身份證號碼。<br />\n3) 問題唔好機械化，有標準答案可以抄。<br />\n4) 多人 Report 嘅考官嘅問題紀錄會拎出嚟公審係唔係惡意破壞。(投票決定係唔係踢出局)<br />\n<br />\n公民參與<br />\n1) 成功參與者請盡公民責任，多接受電腦隨機派嘅考官job<br />\n2) 成功申請者戶口要等完成最少接N個考官任務先至可以解封投票。如果冇咁多考官任務，過一段時間會自動解封。<br />\n<br />\n問題技巧<br />\n1) 申請時可以選擇提出在港嘅大概年份。方便分派到唔會問你唔喺香港嘅時代嘅問題嘅考官。<br />\n2) 求其舉我會問嘅問題例子:<br />\n- 「點解真正嘅民主要三權分立？」<br />\n- 「舉一個香港法治被破壞嘅例子」<br />\n- 「點解咁多人叫黑警死全家？」<br />\n- 「禮拜日皇后像廣場最多乜嘢人？」"},{"pid":"cb9f3a53f3b9cede4dbf6aca5bcc6f3d9a637746","tid":2349531,"uid":216892,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T21:22:15.000Z","msg":"Push<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c4f48d946ec37f99209c05084db7483bfdb1cd3d","tid":2349531,"uid":154486,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-01-01T21:34:08.000Z","msg":"<img src=\"https://na.cx/i/ohW5J7F.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FohW5J7F.jpg&h=e6e323f1&s={SIZE}\" />"},{"pid":"132f1402ffd6c407843bd2aaaeddec3724d7e9db","tid":2349531,"uid":14830,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T21:35:44.000Z","msg":"臨瞓推一推<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"},{"pid":"76df2aa1cf8962096ec8b298076f80767a4e980b","tid":2349531,"uid":164837,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T22:07:03.000Z","msg":"push"},{"pid":"5b5a4e7c9fcb7694d24e779087bb1474d62be141","tid":2349531,"uid":91397,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T22:09:58.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"168c41a6da3fd5903d87a0228c3eee06fce57315","tid":2349531,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-01T22:11:17.000Z","msg":"Push<br />\n我一間整番個懶人版<br />\n另外我建議HKSP 呢D Q&amp;A可以斬開幾段片分開出<br />\n咁樣就可以減輕工作量同時做到保持熱度既效果<br />\n辛苦哂!"},{"pid":"aabb435a2a83222ef99315360694182fe51f59c5","tid":2349531,"uid":154486,"like":0,"dislike":0,"score":0,"quote":{"pid":"168c41a6da3fd5903d87a0228c3eee06fce57315","tid":2349531,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-01T22:11:17.000Z","msg":"Push<br />\n我一間整番個懶人版<br />\n另外我建議HKSP 呢D Q&amp;A可以斬開幾段片分開出<br />\n咁樣就可以減輕工作量同時做到保持熱度既效果<br />\n辛苦哂!"},"citedBy":0,"replyTime":"2021-01-01T22:13:30.000Z","msg":"可能一條片淨係答兩三條問題咁樣<br />\n片多而精既話就好容易可以Build up到你既content"},{"pid":"212d8213c2de46b91f12deb976bb6b1b5d1853bd","tid":2349531,"uid":293511,"like":0,"dislike":0,"score":0,"quote":{"pid":"168c41a6da3fd5903d87a0228c3eee06fce57315","tid":2349531,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-01T2