ww.hkqf.gov.hk%2Ffilemanager%2Fcommon%2FEQF%2FEQF_Consultation_E.pdf&d=wXXh3%2FvEyoclwUBZuqJaJBv1o3X72Fc8dbph17rWX2c%3D&h=3bca946b\" target=\"_blank\">https://www.hkqf.gov.hk/filemanager/common/EQF/EQF_Consultation_E.pdf</a><br />\n政府都寫明 btec level5的話best fit to hd/asso<br />\n無證無據 一陣返到香港搵野做多得你呢啲謠言唔少<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},{"pid":"e295b23f69818200787a31fc13bed1174af61994","tid":256810,"uid":75457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-25T07:04:53.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><blockquote>btec係比啲冇5條2既人入，認受性一定差過asso/hd<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n最低係33222</blockquote><br />\n<a href=\"http://www.cbcc.edu.hk/chi/programmes/fulltime/hm/btec.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.cbcc.edu.hk%2Fchi%2Fprogrammes%2Ffulltime%2Fhm%2Fbtec.html&d=wXXh3%2FvEyoclwUBZuqJaJBv1o3X72Fc8dbph17rWX2c%3D&h=a952c6d2\" target=\"_blank\">http://www.cbcc.edu.hk/chi/programmes/fulltime/hm/btec.html</a><br />\n只要有一科3就得啦喎，前年去in，佢話我maths同ls有4係佢地到已經好勁<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />咁5，5星，5星星叫乜<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n定係我認真咗<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n咁有5有5* 唔使讀呢啲啦<br />\n搵黎比....<br />\n我都知香港係鐘意見高拜 見低踩<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /></blockquote><br />\n冇話見高拜 見低踩，但一定衰過 hd/ asso</blockquote><br />\n只可以講sample pool無咁大<br />\n同埋普遍讀既人差啲姐<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /> <br />\n讀書差都想有重生機會</blockquote><br />\n如果中英有2，同埋其他科都2以上，一定係hd/asso先，btec通常比你外國升學為主，asso/hd係本地升學為主"},{"pid":"dd561e15f69ae46e4acca509c073461c9a0472be","tid":256810,"uid":37874,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-25T07:06:32.000Z","msg":"<blockquote><blockquote><blockquote>收皮啦想付出最少換左最多野<br />\n而你最後只會一場空<br />\nAsso仔廢極都有出息過你 反省下<br />\n最出名係指大 好行唔送<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /></blockquote><br />\n咪係，到時仆街唔好喊</blockquote><br />\n你咁講英國年年成堆人都仆街啦<br />\n講真係香港讀書環境先係咁壓迫<br />\n啲人鍾意壓迫 唔代表要其他人都要受<br />\n幾多人去外國讀 <br />\n總好過台灣讀「大學」<br />\n我地都要辛辛苦苦做paper<br />\n唔好講到咁難聽<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /></blockquote><br />\n的確係成埋仆街 你冇講錯<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n本身勁果d去外國讀可能係唔想香港讀<br />\n但廢既人去係因為冇得係香港讀<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n大把大英番黎都冇野做<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <br />\n尤其話香港冇呢科 但本身冷門既 <br />\n咩遊戲設計果類 大把連工都搵唔到 做文員保險<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"f768fe3bf90654e41951b53802b689219235eaf6","tid":256810,"uid":44113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-25T07:06:35.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><blockquote><blockquote>btec係比啲冇5條2既人入，認受性一定差過asso/hd<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n最低係33222</blockquote><br />\n<a href=\"http://www.cbcc.edu.hk/chi/programmes/fulltime/hm/btec.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.cbcc.edu.hk%2Fchi%2Fprogrammes%2Ffulltime%2Fhm%2Fbtec.html&d=wXXh3%2FvEyoclwUBZuqJaJBv1o3X72Fc8dbph17rWX2c%3D&h=a952c6d2\" target=\"_blank\">http://www.cbcc.edu.hk/chi/programmes/fulltime/hm/btec.html</a><br />\n只要有一科3就得啦喎，前年去in，佢話我maths同ls有4係佢地到已經好勁<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />咁5，5星，5星星叫乜<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n定係我認真咗<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n咁有5有5* 唔使讀呢啲啦<br />\n搵黎比....<br />\n我都知香港係鐘意見高拜 見低踩<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /></blockquote><br />\n冇話見高拜 見低踩，但一定衰過 hd/ asso</blockquote><br />\n只可以講sample pool無咁大<br />\n同埋普遍讀既人差啲姐<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /> <br />\n讀書差都想有重生機會</blockquote><br />\n如果中英有2，同埋其他科都2以上，一定係hd/asso先，btec通常比你外國升學為主，asso/hd係本地升學為主</blockquote><br />\n而家香港本地top up 都會收<br />\n果陣有幾個都入左scope 但佢地英文ok ielts 考到6.5<br />\nUgc我識既既話有一個 細我一年<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /> 學霸黎<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" />"},{"pid":"c3d5a45af9705a4da5f45aba284b9b2a1ec2eef1","tid":256810,"uid":44113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-25T07:07:39.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>收皮啦想付出最少換左最多野<br />\n而你最後只會一場空<br />\nAsso仔廢極都有出息過你 反省下<br />\n最出名係指大 好行唔送<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /></blockquote><br />\n咪係，到時仆街唔好喊</blockquote><br />\n你咁講英國年年成堆人都仆街啦<br />\n講真係香港讀書環境先係咁壓迫<br />\n啲人鍾意壓迫 唔代表要其他人都要受<br />\n幾多人去外國讀 <br />\n總好過台灣讀「大學」<br />\n我地都要辛辛苦苦做paper<br />\n唔好講到咁難聽<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /></blockquote><br />\n的確係成埋仆街 你冇講錯<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n本身勁果d去外國讀可能係唔想香港讀<br />\n但廢既人去係因為冇得係香港讀<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n大把大英番黎都冇野做<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <br />\n尤其話香港冇呢科 但本身冷門既 <br />\n咩遊戲設計果類 大把連工都搵唔到 做文員保險<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /></blockquote><br />\n我讀商科 無咁偏既<img src=\"/assets/faces/lomoji/16.png\" class=\"hkgmoji\" /> <br />\n岩岩個暑假都搵到intern仔 係英國囉不過<img src=\"/assets/faces/lomoji/27.png\" class=\"hkgmoji\"