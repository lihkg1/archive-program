12:22.000Z","msg":"無錯，就係曾經比佢鍾意過<br />\n先會知個分別喺邊<br />\n先會知佢真係唔鍾意我喇"},{"pid":"f44d394f0994b417718fc2a42793c17180545a03","tid":748143,"uid":113773,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-21T20:13:42.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"fde1ef552bd2c5f23dfe0980e3956bf3d7a00028","tid":748143,"uid":13693,"like":0,"dislike":0,"score":0,"quote":{"pid":"b101ed00fa551931d9039206d405e780afce2196","tid":748143,"uid":597,"like":0,"dislike":1,"score":-1,"quote":{"pid":"b886d4e56acf5936cc59144fb3dbcf6a36fc8a41","tid":748143,"uid":13693,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2018-07-21T16:40:46.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-21T16:57:44.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-22T01:54:01.000Z","msg":"<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"5862a6928f2d92a2fb6651ad01d930d66cbc0a8f","tid":748143,"uid":43061,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-22T02:03:33.000Z","msg":"岩 成個星期囉<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"29bf29b24d8f95df008594b060585409bc84ab82","tid":748143,"uid":172306,"like":0,"dislike":0,"score":0,"quote":{"pid":"fde1ef552bd2c5f23dfe0980e3956bf3d7a00028","tid":748143,"uid":13693,"like":0,"dislike":0,"score":0,"quote":{"pid":"b101ed00fa551931d9039206d405e780afce2196","tid":748143,"uid":597,"like":0,"dislike":1,"score":-1,"quote":{"pid":"b886d4e56acf5936cc59144fb3dbcf6a36fc8a41","tid":748143,"uid":13693,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2018-07-21T16:40:46.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-21T16:57:44.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-22T01:54:01.000Z","msg":