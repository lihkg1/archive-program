46.000Z","msg":"好詳細，感謝！"},{"pid":"5f2ddb4fbbbc87bb1ed4a147d101d81fb84bbe6d","tid":1759291,"uid":217098,"like":0,"dislike":0,"score":0,"quote":{"pid":"b642eac559c27759860227e84d33c81b842c07fd","tid":1759291,"uid":142314,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-11-27T14:26:42.000Z","msg":"睇多啲沙維"},"citedBy":0,"replyTime":"2019-11-27T15:26:22.000Z","msg":"睇左好耐卻奧斯，唔係好學到野"},{"pid":"1e556458afd6a6d119e80780ce3562ec7f3ef474","tid":1759291,"uid":217098,"like":0,"dislike":0,"score":0,"quote":{"pid":"180b29b328765d71e703b79fd3c9c64647a056b4","tid":1759291,"uid":58346,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-11-27T14:31:11.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2019/11/27/223003_3c83c67b45d6c2d36795cf15c79266e2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F11%2F27%2F223003_3c83c67b45d6c2d36795cf15c79266e2.jpg&h=76ea98ac&s={SIZE}\" /><br />\n參考下"},"citedBy":0,"replyTime":"2019-11-27T15:26:35.000Z","msg":"wtf？！"},{"pid":"d93db076b758a70d895c4d8535194c1dd6eeeb9e","tid":1759291,"uid":217098,"like":0,"dislike":0,"score":0,"quote":{"pid":"a1e849a850b580b760c654baa933df8c8a86462f","tid":1759291,"uid":4957,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-27T14:38:02.000Z","msg":"睇多d奧燒點踢"},"citedBy":0,"replyTime":"2019-11-27T15:27:01.000Z","msg":"佢個啲天份波多好多，難學"},{"pid":"e27334abadfd5abc1205199ab3639657dc4ebcf5","tid":1759291,"uid":217098,"like":0,"dislike":0,"score":0,"quote":{"pid":"347d9fc479d6cb6b6702839e3d33026d2168e574","tid":1759291,"uid":54373,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-27T15:02:26.000Z","msg":"唔x識1腳？<br />\n<br />\n下下上腳以為自己球王<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-27T15:28:09.000Z","msg":"係既王大哥，踢開翼慣左<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e9c3e31de755f72bf38b9619d13890fa21109d60","tid":1759291,"uid":217098,"like":1,"dislike":0,"score":1,"quote":{"pid":"b8b44e96715122e6a7eaebbddfe7df18bf4d63d1","tid":1759291,"uid":95489,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-11-27T14:57:12.000Z","msg":"睇佐仔d球王片學下啦 幾舒服"},"citedBy":0,"replyTime":"2019-11-27T15:29:10.000Z","msg":"嘩，我冇契爺架，踢多兩場就變後備了"},{"pid":"149af8bf353a035a36322a16945eeb96681a7630","tid":1759291,"uid":217098,"like":0,"dislike":0,"score":0,"quote":{"pid":"66684866ff9d995310e5755ccbb5ff1255b0d145","tid":1759291,"uid":218659,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-11-27T15:08:30.000Z","msg":"你有無踢過11人比賽? 有無聽過&rdquo;豆&ldquo;住中場<br />\n我就同過一個中場中踼過, 一樣無身形無高度, 佢唔係好扭得, 又唔係最快<br />\n但基本功好札扎實, 控波, 包位, 長短傳, 入波, 樣樣有, 而佢可以係成場零失誤, 你唔洗幫佢, 但佢會衝過黎幫你<br />\n我自問都踢過好多比賽, 但如果對手強, 難免會怯場緊張<br />\n但有佢在場, 你會好放心, 可以發揮返自己水準, 自然成隊波生哂"},"citedBy":0,"replyTime":"2019-11-27T15:29:53.000Z","msg":"屌<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />又潮文"},{"pid":"09d8bc8e6917a14861b02f46a74d6411bb5e9b52","tid":1759291,"uid":34572,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-27T15:33:17.000Z","msg":"hold到波嘅就練下Vision啦，我明你點解會咁，因為你踢翼時只需要望住中間同另一條邊線嚟踢，即係同一個方向，踢中間就要望多個方向，係要習慣下"},{"pid":"2d77fd4e007c5582fd2a00e9ec15ac206c62e4e0","tid":1759291,"uid":58206,"like":0,"dislike":0,"score":0,"quote":{"pid":"09d8bc8e6917a14861b02f46a74d6411bb5e9b52","tid":1759291,"uid":34572,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-27T15:33:17.000Z","msg":"hold到波嘅就練下Vision啦，我明你點解會咁，因為你踢翼時只需要望住中間同另一條邊線嚟踢，即係同一個方向，踢中間就要望多個方向，係要習慣下"},"citedBy":0,"replyTime":"2019-11-28T02:46:52.000Z","msg":"踢中場對眼要睇360"}]}