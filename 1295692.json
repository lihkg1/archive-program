p"},{"pid":"0fc17d42087eaeebc6f0d4bbd95dc07d8c2c9bba","tid":1295692,"uid":92859,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-08T06:05:45.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">幫手推上熱門<br />\n</span></span><br />\n<br />\n［重要］區議會選舉招募各路人馬<br />\n<a href=\"https://lih.kg/1295057\" data-auto-link target=\"_blank\">https://lih.kg/1295057</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n各位香港人，光復行動冇可能每日都做<br />\n好似屯門公園搞到今日咁烏煙瘴氣區議員責無旁貸<br />\n要清洗屯門公園始終要由根源做起<br />\n所以除左投立法會外<br />\n都請記得投票區議會踢走自動當選建制派<br />\n<br />\n唔好再俾建制派霸哂啲議席<br />\n就算唔係參選都可以做提名人，義工，助選團<br />\n行出第一步拒絕自動當選！<br />\n<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">總台TG：<br />\n<a href=\"https://t.me/DistrictCouncil2019\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FDistrictCouncil2019&d=JetPiwFZRsNB2TajAgP4V%2BdFAmKeyJhstBKVrdqrVyA%3D&h=67b57e26\" data-auto-link target=\"_blank\">https://t.me/DistrictCouncil2019</a><br />\n</span></span><br />\n登記左做選民既全部入group<br />\n急需大量提名人，義工助選團，Design等職位<br />\n入group後右下角Discuss入公頻搵各區admin<br />\n<br />\n要對抗黑警濫權一定要有議員抗衡<br />\n否則只會一直任人魚肉"},{"pid":"3c987e9e06fd133bbf00492a370c1e224c8d8c87","tid":1295692,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-08T06:08:18.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n[英文速譯] 綜合大量警察嚴重違規行為<br />\n<a href=\"https://lih.kg/1295342\" data-auto-link target=\"_blank\">https://lih.kg/1295342</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"d0b3b0069e8eccc8bb7dd1592a62489e7988cb42","tid":1295692,"uid":92908,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-08T06:10:57.000Z","msg":"邊一間？"},{"pid":"953f96f9a0101298fe179a4463cd19809e8de219","tid":1295692,"uid":92908,"like":0,"dislike":0,"score":0,"quote":{"pid":"d0b3b0069e8eccc8bb7dd1592a62489e7988cb42","tid":1295692,"uid":92908,"like":0,"dislike":0,"score":0,"cit