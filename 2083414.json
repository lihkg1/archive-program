g/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSFhqdoQ.jpg&h=c0149a0a&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-06-28T17:25:01.000Z","msg":"對唔住冇睇到<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f6ea263c7875b6437b0171fb1c8d5a7f9e98c085","tid":2083414,"uid":209057,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-28T17:25:37.000Z","msg":"Push"},{"pid":"b4fe0f662eaafac8d4e17afb8b039b12f8b9600d","tid":2083414,"uid":127929,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-28T17:26:23.000Z","msg":"<img src=\"https://na.cx/i/G24oKwK.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FG24oKwK.jpg&h=448352f8&s={SIZE}\" />"},{"pid":"37ab74af86adacb35aca2b4e0b5ab5cbc2828e7e","tid":2083414,"uid":304769,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-28T17:26:25.000Z","msg":"無文宣，得文字<br />\n<br />\n今年七一要加主題：<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\"><br />\n寧願最後不得善終<br />\n也不考慮含淚折衷<br />\n<br />\n我要美國制裁，無懼與支共同歸於盡，寧死捍衛自由民主</span></span></strong><br />\n<br />\n認同就拎張紙舉比美國睇，咪比條廢老Martin Lee騎劫我地，搞到美國以為我地驚攬炒而唔做野<br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">黃世澤出左香港自治法篤灰指南，好有用，大家入去睇</span></span></strong><br />\n<br />\n\t<br />\n\t<a href=\"https://youtu.be/s6o2r5DkT-w\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fs6o2r5DkT-w&d=wLbnxcWodPR608ZqId7G8fGl%2B26pDsgLotMYn9d4AWI%3D&h=f1e79eb0\" target=\"_blank\">https://youtu.be/s6o2r5DkT-w</a><br />\n<br />\n<br />\n借個位<br />\n正視聽：若抗爭方向不隨局勢改變，只會無謂地損兵折將<br />\n香港街頭抗爭目標，亦都係街頭抗爭最大效果；&ldquo;攬炒&rdquo;已經達到，今次搞蟈安法其實仲攬炒過上年出老解。<br />\n宜家<strong><span style=\"color: red;\">跟著落黎就係引導全球政府同議會（尤其美國）對付支那以及滅共</span></strong>，所以大家重點應該著眼帶出清晰民意授權比各國政府做野，畫面靚+全球廣泛報導（類似反蟈安法銅鑼灣自由行）係最理想，用選票帶出民意亦十分重要。<br />\n<br />\n<strong><span style=\"color: red;\">大家要小心五毛、熱狗放負風向：美國唔會幫我地（舊年年尾）-》英國係廢國無用架（今年年頭）-》歐盟奶共唔會幫我地（宜家）</span></strong><br />\n<br />\n大家要記住，香港生路只有一條：救香港人+攬炒促進支爆+重建香港。<strong><span style=\"color: red;\">沒有支爆，香港獨立或者歸英等重建方案全部都係痴人說夢。</span></strong><br />\n<br />\n未來幾個月至支共瓦解期間大家要做嘅事：1.<strong><span style=\"color: red;\">走資</span></strong>2.全球救生艇<strong><span style=\"color: red;\">救手足加有細路既黃絲家庭</span></strong>（細路是重點，香港未來棟樑，正如今時今日d前線義士，咪比佢地洗腦變小糞紅，否則香港係真正玩完）3.比足夠<strong><span style=\"color: red;\">民意授權，敦促美國以至各國凌遲式消除香港作為支那獲得外資渠道</span></strong>，包括但不限於：禁止美國個人或公司投資港股，暫停接受香港用美元結算等等4.最後就真係等<span style=\"color: red;\"><strong>支那自己爆</strong></span>"},{"pid":"f8904fc883b23f4f98923d63143986271114efa4","tid":2083414,"uid":227929,"like":0,"dislike":0,"score":0,"quote":{"pid":"37ab74af86adacb35aca2b4e0b5ab5cbc2828e7e","tid":2083414,"uid":304769,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-28T17:26:25.000Z","msg":"無文宣，得文字<br />\n<br />\n今年七一要加主題：<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\"><br />\n寧願最後不得善終<br />\n也不考慮含淚折衷<br />\n<br />\n我要美國制裁，無懼與支共同歸於盡，寧死捍衛自由民主</span></span></strong><br />\n<br />\n認同就拎張紙舉比美國睇，咪比條廢老Martin Lee騎劫我地，搞到美國以為我地驚攬炒而唔做野<br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">黃世澤出左香港自治法篤灰指南，好有用，大家入去睇</span></span></strong><br />\n<br />\n\t<br />\n\t<a href=\"https://youtu.be/s6o2r5DkT-w\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fs6o2r5DkT-w&d=wLbnxcWodPR608ZqId7G8fGl%2B26pDsgLotMYn9d4AWI%3D&h=f1e79eb0\" target=\"_blank\">https://youtu.be/s6o2r5DkT-w</a><br />\n<br />\n<br />\n借個位<br />\n正視聽：若抗爭方向不隨局勢改變，只會無謂地損兵折將<br />\n香港街頭抗爭目標，亦都係街頭抗爭最大效果；&ldquo;攬炒&rdquo;已經達到，今次搞蟈安法其實仲攬炒過上年出老解。<br />\n宜家<strong><span style=\"color: red;\">跟著落黎就係引導全球政府同議會（尤其美國）對付支那以及滅共</span></strong>，所以大家重點應該著眼帶出清晰民意授權比各國政府做野，畫面靚+全球廣泛報導（類似反蟈安法銅鑼灣自由行）係最理想，用選票帶出民意亦十分重要。<br />\n<br />\n<strong><span style=\"color: red;\">大家要小心五毛、熱狗放負風向：美國唔會幫我地（舊年年尾）-》英國係廢國無用架（今年年頭）-》歐盟奶共唔會幫我地（宜家）</span></strong><br />\n<br />\n大家要記住，香港生路只有一條：救香港人+攬炒促進支爆+重建香港。<strong><span style=\"color: red;\">沒有支爆，香港獨立或者歸英等重建方案全部都係痴人說夢。</span></strong><br />\n<br />\n未來幾個月至支共瓦解期間大家要做嘅事：1.<strong