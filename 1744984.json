":48187,"like":2,"dislike":0,"score":2,"quote":{"pid":"4ffe8c11e60c3c84f88b33af92c1cfcad6cd2db9","tid":1744984,"uid":131153,"like":6,"dislike":0,"score":6,"citedBy":2,"replyTime":"2019-11-22T04:37:19.000Z","msg":"唱得幾難聽 聽左兩句出返黎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-22T04:45:45.000Z","msg":"呢個真，我想撐架但唱得麻麻<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"27ef537b9abb51067c08a241225caf752d291af4","tid":1744984,"uid":317874,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-22T04:46:59.000Z","msg":"<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"ba5c63fdf36e45504a4a4712f7feb3332d40480f","tid":1744984,"uid":146341,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-22T05:18:31.000Z","msg":"推"},{"pid":"2ff32fa1acba50566c1af0f7f83d28878a83dbb9","tid":1744984,"uid":244876,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-22T07:16:06.000Z","msg":"<img src=\"/assets/faces/dog/lihkg.gif\" class=\"hkgmoji\" />樹窿再次歡迎大家加入<br />\n知道過去五個月，大家既生活都過得好壓抑。有人係依五個月之間同父母嗌大交，同伴侶分手，同朋友斷交，有人晚晚夜歸，有人用到無哂錢。或者你覺得好迷惘好無奈，或者你覺得無岀路。有見及此，開左個谷俾大家入黎吐下苦水，只談現實，不談夢境。希望大家可以舒發下，減減壓，然後大家一齊繼續向前行。<br />\n<br />\n發緊想發未發就發夢都唔好係公海講<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" /><br />\n保障大家安全<img src=\"/assets/faces/dog/FBI.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n講明先 係歡迎任何人講既<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n理得你藍定黃 狗定人 貓定兔<br />\n我地好希望大家可以有個好始既渠道釋放咁耐以來既情緒<br />\n如果大家有朋友仔想入來都無任歡迎咖<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n同埋記得不指責不質問 任何指責及質問均無助大家發洩情緒<img src=\"/assets/faces/lm2/dislike.gif\" class=\"hkgmoji\" /><br />\n<br />\nlink:<br />\n<a href=\"https://t.me/ourtreehole\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fourtreehole&d=t5TWSf1rAjisfLcmnBMt809C3ZeEg%2BAMpIxt97RLrpY%3D&h=adc0759a\" data-auto-link target=\"_blank\">https://t.me/ourtreehole</a><br />\n<br />\n無論你係邊一到，保護自己，不要透露個人資料<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n香港人，反抗！<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"d4b9bd5c87d39459a828f65990237bf84a3346c7","tid":1744984,"uid":23575,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-22T07:17:32.000Z","msg":"推呀 mv<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"d062bea755e346c2197cab8fce14e1ac17f7b767","tid":1744984,"uid":224400,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-22T09:00:17.000Z","msg":"甴近平"},{"pid":"ae795c35c983ae418b685d04ba79b6aac731cb1d","tid":1744984,"uid":183425,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-22T09:42:51.000Z","msg":"推"},{"pid":"634c5e7115894d697d5c3b915f5e5414572c5651","tid":1744984,"uid":30836,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-22T10:03:21.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"ee92a471c910e049ab6acd8c22e2e8bdf6911c94","tid":1744984,"uid":236171,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-22T10:12:38.000Z","msg":"push<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" />"},{"pid":"aa1f1351a2207adb37b33ab4cbe65113d277b849","tid":1744984,"uid":122122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-22T10:37:48.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />城大手足"},{"pid":"ad2c513b71199ff80245f4586e7e645e4b0fda89","tid":1744984,"uid":25195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-22T10:40:19.000Z","msg":"shitty校友同我推<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"af0b1c6244926dcfff25c2108da790fd95984544","tid":1744984,"uid":62052,"like":0,"dislike":0,"score":0,"citedBy":