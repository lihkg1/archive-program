84f57156e6dd3705542894bd53069","tid":2198442,"uid":161251,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-11T16:10:04.000Z","msg":"大驚小怪<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7d2505a528d656525c431ff21c945625c7bec85c","tid":2198442,"uid":56731,"like":0,"dislike":0,"score":0,"quote":{"pid":"4d64329838b49094773a233781b5b83f8b74e4a3","tid":2198442,"uid":25260,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-09-11T15:51:38.000Z","msg":"0分重作<br />\n<br />\n而家小食部邊有開"},"citedBy":0,"replyTime":"2020-09-11T16:34:01.000Z","msg":"有開架,不過係俾你外賣買走出戲院食<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"063ec727eef4169acf3ffd29d7877b5e4f555fe0","tid":2198442,"uid":333199,"like":2,"dislike":1,"score":1,"quote":{"pid":"eaff67e8e2d84f57156e6dd3705542894bd53069","tid":2198442,"uid":161251,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-11T16:10:04.000Z","msg":"大驚小怪<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-09-11T16:55:48.000Z","msg":"我都覺樓主有D正義撚,無影響咪算<br />\n<br />\nBTW,有次睇戲院, 買飛坐正個阿叔隔離<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n成場得我同阿叔同2,3個人, 個2,3個人分開好遠, 我就坐正阿叔隔離<br />\n<br />\n一坐埋位, 個阿就口UPUP話三唔識七坐隔離做乜尻,又細細聲UP叫我去死,又話ON99係要坐佢隔離, 又用酒精搓手液噴左我2次<br />\n<br />\n平時我不嬲買中間排對正畫面既位, 無理有無人係隔離<br />\n<br />\n結果個阿叔好唔GUR啤我幾次, 我望返佢一次, 照坐唔撚理佢<br />\n<br />\n最後我同阿叔都坐得好撚唔自在咁睇完成套戲<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n條撚樣同我都唔讓步掉位<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" />"}]}