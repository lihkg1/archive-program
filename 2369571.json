a44b8cd87111c6c45cc145ce892ab4faa562f4f","tid":2369571,"uid":110832,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-17T11:16:29.000Z","msg":"屌你老母標題撚"},{"pid":"5aca965ff58b96d4275f3e2f2abc232f71b4b6fa","tid":2369571,"uid":339805,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-17T11:17:40.000Z","msg":"幾時先有得睇彩露晒上下半球<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"df6ca09e3346ff49e58c0aeb100d71d106799dc4","tid":2369571,"uid":76804,"like":10,"dislike":0,"score":10,"quote":{"pid":"1e4c26dff5cf82e2de5b28da38198c8c1fcf0afa","tid":2369571,"uid":108078,"like":810,"dislike":1,"score":809,"citedBy":5,"replyTime":"2021-01-17T09:14:02.000Z","msg":"北半球?<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-17T11:18:58.000Z","msg":"全球暖化融曬"},{"pid":"c820d221973cf4be3aba849f9443999c9f10e9f8","tid":2369571,"uid":6942,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-17T11:21:26.000Z","msg":"地球平架 好似係"},{"pid":"f250a78a3bb29dc88ec804d678c6bd7dbed807e4","tid":2369571,"uid":126306,"like":1,"dislike":0,"score":1,"quote":{"pid":"1e4c26dff5cf82e2de5b28da38198c8c1fcf0afa","tid":2369571,"uid":108078,"like":810,"dislike":1,"score":809,"citedBy":5,"replyTime":"2021-01-17T09:14:02.000Z","msg":"北半球?<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-17T11:30:35.000Z","msg":"乒乓球"},{"pid":"cba507dea23ac3d7691be79b59e4d7e0ae7a9612","tid":2369571,"uid":108078,"like":9,"dislike":0,"score":9,"quote":{"pid":"c70f24a63f28fdd8fdc89467f87f3584d7f054f4","tid":2369571,"uid":32906,"like":258,"dislike":1,"score":257,"quote":{"pid":"1e4c26dff5cf82e2de5b28da38198c8c1fcf0afa","tid":2369571,"uid":108078,"like":810,"dislike":1,"score":809,"citedBy":5,"replyTime":"2021-01-17T09:14:02.000Z","msg":"北半球?<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":11,"replyTime":"2021-01-17T10:40:45.000Z","msg":"地平說<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-17T11:31:49.000Z","msg":"本黎都想屌鳩信地平說<br />\n但依家我都信了"},{"pid":"a669958f696f7faa39e8ac2e944a6c4153351f64","tid":2369571,"uid":228223,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f4f8020dd5370e395be412553f79bc7805f7df4","tid":2369571,"uid":16659,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-17T09:09:13.000Z","msg":"「日劇天王」木村拓哉與工藤靜香17歲女兒木村光希跟19歲的姊姊心美也追隨爸媽腳步出道，可說是日本背景最強大的星二代之一，姊妹倆時常開直播和網友互動，IG的追蹤人數已破百萬。一向走清新氣質路線的木村心美，在近日分享了性感露肩照，引起話題。<br />\n<br />\n<img src=\"https://attach.setn.com/newsimages/2020/05/09/2545361-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2020%2F05%2F09%2F2545361-XXL.jpg&h=28116ad7&s={SIZE}\" /><br />\n▲▼木村光希跟木村心美。（圖／翻攝自木村光希IG）<br />\n<img src=\"https://attach.setn.com/newsimages/2020/06/30/2635426-PH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2020%2F06%2F30%2F2635426-PH.jpg&h=2a267770&s={SIZE}\" /><br />\n<br />\n木村拓哉的小女兒木村光希以「最強星二代」身份出道後沒多久，姊姊木村心美也以藝名Cocomi入行，造成極大話題。木村拓哉一家4口可說是有任何風吹草動都能攻占日本新聞版面。近日姊妹倆都受邀成為迪奧化粧品代言，喜歡紅色的木村心美，特地穿上一件紅色露肩禮服，難得展現性感一面，才一天就獲得12萬讚，相當驚人。<br />\n<br />\n<img src=\"https://attach.setn.com/newsimages/2021/01/17/2987748-PH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2021%2F01%2F17%2F2987748-PH.jpg&h=db75c3b8&s={SIZE}\" /><br />\n▲▼木村心美穿上紅色低胸禮服。（圖／翻攝自木村心美IG）<br />\n<img src=\"https://attach.setn.com/newsimages/2021/01/17/2987749-PH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2021%2F01%2F17%2F2987749-PH.jpg&h=1afb1c78&s={SIZE}\" /><br />\n<br />\n木村光希每次要跟姊姊心美開直播，都會事先請粉絲提供想知道的問題，並在直播中回答，之前姊妹倆被問到心中理想型男友，認真提出手好看、聲音低沉、有背肌、肩膀寬、適合穿西裝，以及「能好好保護我」等6大條件，說完之後，木村光希忍不住心中嚮往，脫口說出：「好想早點結婚喔！」<br />\n<br />\n有趣的是，姊妹倆開出的條件，爸爸木村拓哉全都完美符合，這也讓網友笑說「果然爸爸是理想型」、「喜歡的男生條件跟爸爸好像」、「說的就是木村啊」。其實，木村光希跟木村心美聊起家庭生活時，總是處處流露出對爸爸的崇拜，也曾直接說希望找「一個像爸爸一樣的人」當男友，讓網友苦笑直呼：「難度太高啦！」"},"citedBy":0,"replyTime":"2021-01-17T11:44:22.000Z","msg":"都戀父姊妹花嘅<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b9da6b08254b361a0da8b843797158fb25001bad","tid":2369571,"uid":245668,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-01-17T11:48:25.000Z","msg":"其實大女個樣有啲怪"},{"pid":"19bdf363e0743fe80fefc2aa1308eb668a8e7e44","tid":2369571,"uid":74361,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-17T11:48:28.000Z","msg":"<img src=\"https://images.chinatimes.com/newsphoto/2020-04-20/1024/20200420005228.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimages.chinatimes.com%2Fnewsphoto%2F2020-04-20%2F1024%2F20200420005228.jpg&h=fb5e79f6&s={SIZE}\" />"},{"pid":"585b88e6e2a17f45c7bc5f5431b13c5913974cfa","tid":2369571,"uid":101805,"like":5,"dislike":0,"score":5,"quote":{"pid":"c70f24a63f28fdd8fdc89467f87f3584d7f054f4","tid":2369571,"uid":32906,"like":258,"dislike":1,"score":257,"quote":{"pid":"1e4c26dff5cf82e2de5b28da38198c8c1fcf0afa","tid":2369571,"uid":108078,"like":810,"dislike":1,"score":809,"citedBy":5,"replyTime":"2021-01-17T09:14:02.000Z","msg":"北半球?<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":11,"replyTime":"2021-01-17T10:40:45.000Z","msg":"地平說<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-17T11:53:16.000Z","msg":"comment of the year"},{"pid":"bdfb92b73ccdf7c08ebd40901de1dab8dbc86793","tid":2369571,"uid":55628,"like":1,"dislike":0,"score":1,"quote":{"pid":"1e4c26dff5cf82e2de5b28da38198c8c1fcf0afa","tid":2369571,"uid":108078,"like":810,"dislike":1,"score":809,"citedBy":5,"replyTime":"2021-01-17T09:14:02.000Z","msg":"北半球?<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-17T11:56:57.000Z","msg":"撒哈拉北半<img src=\"/assets/face