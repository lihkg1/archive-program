/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"7737b1524c87d53e720ab325340609c49c117829","tid":1921883,"uid":25825,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T10:40:09.000Z","msg":"A"},{"pid":"f4b1d89f1e6aa8015cd5d13a7ee648ce89cd165c","tid":1921883,"uid":270506,"like":1,"dislike":0,"score":1,"quote":{"pid":"e250377a01e449c447432c387b693e364cddf106","tid":1921883,"uid":125168,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-03-12T08:43:08.000Z","msg":"中西區區會禁止中聯辦出席地區活動<br />\n民政專員：睇唔到請中聯辦有幾干預香港自治<br />\n<br />\n報導：<a href=\"http://bit.ly/2THtZzO\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2F2THtZzO&d=2sQmvy6tOK2oFHH%2BrBh9legAExyYYV7WT87CuOwwBqU%3D&h=9595bcbd\" data-auto-link target=\"_blank\">http://bit.ly/2THtZzO</a><br />\n<br />\n中西區區議會在財務委員會上，通過停止邀請中聯辦代作為區議會撥款活動嘉賓。民主派質疑中聯辦派員出席地區活動，有滲透社區宣傳之嫌，亦不應讓團體以區議會撥款申辨活動作政治表忠。<br />\n<br />\n民政事務專員黃何詠詩多次反駁議員，認為不能限制活動邀請嘉賓，需要與民政總署再作討論，又指「睇唔到請中聯辦有幾干預香港自治」。"},"citedBy":0,"replyTime":"2020-03-12T10:40:29.000Z","msg":"其實只要攞住條基本法第22條就可以叫嗰個八婆"}],"pinned":{"pid":"a507cd9db10807416785f6fd56066be6e142b409","tid":1921883,"uid":125168,"like":47,"dislike":1,"score":46,"citedBy":1,"replyTime":"2020-03-12T08:45:57.000Z","msg":"由區議會撥款舉行的活動中停止邀請中聯辦人士出席和作為嘉賓，並直言「佢（活動）要邀請就唔好批區議會錢！」"}}