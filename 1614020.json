d1c1e5cbec6d771301592eb33b0e","tid":1614020,"uid":288707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T16:41:38.000Z","msg":"召喚之前搞狗屋既隨機轉盤<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"791433fa989cad30ab95e8dec0861e2fcf2497ed","tid":1614020,"uid":76364,"like":1,"dislike":0,"score":1,"quote":{"pid":"0635e1025c070115b5498bd60aa0be6146ce3d95","tid":1614020,"uid":30491,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-10-02T16:39:40.000Z","msg":"之前每次D狗咁高戰力係因為有時間比佢地PLAN好作戰計劃<br />\n今次就唔同 幾個鍾前就決定圍你一獲<br />\n今日好多都係番工 街坊 LOOK落街<br />\n你班狗仔唔同 又要上GEAR又要PLAN<br />\n點似得我地真香港人既團結<br />\n最後<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: pink;\">五大訴求 缺一不可 光復香港 時代革命</span></span>"},"citedBy":0,"replyTime":"2019-10-02T16:41:51.000Z","msg":"Popo就算有gear都要休息<br />\n而家係佢地連休息既時間都唔可以有<br />\n但我地可以輪流出場<br />\n再配合hit and run戰術就已經可以搞殘佢地"},{"pid":"57501cedc0ca1821d22e1c85b48d010df57e4aea","tid":1614020,"uid":75277,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T16:41:54.000Z","msg":"打倒共產黨<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"a007661118ac69fcab877a45bc157ca817d96fb8","tid":1614020,"uid":282654,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-02T16:45:57.000Z","msg":"對方知你有新戰術，佢又會變<br />\n一招唔可用到老"},{"pid":"ebd37cac3013676fec5e16bfaaf1e03686a6b15f","tid":1614020,"uid":76364,"like":0,"dislike":0,"score":0,"quote":{"pid":"d4e48d7de4522c45f1a9463df94042eacdc291fa","tid":1614020,"uid":38737,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-02T16:41:22.000Z","msg":"但我地都會攰<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-02T16:45:59.000Z","msg":"但我地人數上佔優勢<br />\n今日攰未靠其他人，第二日人地攰未輪到我地<br />\n但popo佢地冇得咁做<br />\n<br />\n而且我都冇話要日日搞<br />\n你平日搵兩三日仲要黎突襲，都已經令佢地每一日唔可以鬆懈<br />\n人係長時間唔休息仲要冇得放鬆係好易就會崩潰<br />\n既然我地無法咁多個月無法令佢地士氣下跌<br />\n咁就只好令佢地體力上精神上崩潰先<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"285c92c8866908d092612ea6fbf129aaa080a6bb","tid":1614020,"uid":60941,"like":0,"dislike":0,"score":0,"quote":{"pid":"f0294cfe230d2c96754b22371e47586fc2677929","tid":1614020,"uid":108337,"like":9,"dislike":0,"score":9,"quote":{"pid":"cd729d2ca6050ea513d2c1cdabbaade0046c1fd2","tid":1614020,"uid":66221,"like":10,"dislike":0,"score":10,"citedBy":2,"replyTime":"2019-10-02T16:32:09.000Z","msg":"打紅色企業店鋪絕對安全過圍狗屋<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-10-02T16:38:19.000Z","msg":"仲可以令中資受經濟制裁<br />\n同時將啲錢流向其他地方， eg裝修要錢，食飯迫住去第度食<br />\n還富於民<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-10-02T16:47:05.000Z","msg":"幫大家手罷食罷買<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"9054cb4bf336de867e9acfa579b72c5459bc5d29","tid":1614020,"uid":76364,"like":0,"dislike":0,"score":0,"quote":{"pid":"285c92c8866908d092612ea6fbf129aaa080a6bb","tid":1614020,"uid":60941,"like":0,"dislike":0,"score":0,"quote":{"pid":"f0294cfe230d2c96754b22371e47586fc2677929","tid":1614020,"uid":108337,"like":9,"dislike":0,"score":9,"quote":{"pid":"cd729d2ca6050ea513d2c1cdabbaade0046c1fd2","tid":1614020,"uid":66221,"like":10,"dislike":0,"score":10,"citedBy":2,"replyTime":"2019-10-02T16:32:09.000Z","msg":"打紅色企業店鋪絕對安全過圍狗屋<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-10-02T16:38:19.000Z","msg":"仲可以令中資受經濟制裁<br />\n同時將啲錢流向其他地方， eg裝修要錢，食飯迫住去第度食<br />\n還富於民<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-10-02T16:47:05.000Z","msg":"幫大家手罷食罷買<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-02T16:48:10.000Z","msg":"罷完藍/紅店仲可以支持黃店<img src=\"/assets/faces/normal/agre