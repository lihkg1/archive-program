ime":"2017-05-05T13:59:13.000Z","msg":"唔洗俾錢入珠就有入珠嘅快感<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"89fdb447ac10130f927aceb2f0a355593fc25d02","tid":230353,"uid":89696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-05T16:40:40.000Z","msg":"樓主切柒保平安<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"}]}