pid":"42ddc25c4f71e7bf116f98e0d26244494705af18","tid":1081373,"uid":195169,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-28T09:27:45.000Z","msg":"答到九唔撚搭八咁, 又真係唔知點反駁嘅<br />\n即係我鬧你貪錢, 你話你鍾意食屎, 點駁你呢??"},{"pid":"a0984dcde567c6593ccb07a72e5a922ff80014ce","tid":1081373,"uid":52942,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-03-28T09:27:49.000Z","msg":"陳水扁算係台灣唔錯既時期啦"},{"pid":"7fa1274d0294695596ea333c620ac250e4935a02","tid":1081373,"uid":35790,"like":2,"dislike":0,"score":2,"quote":{"pid":"afd313af0f0892278f49daf217d78b9dda47956c","tid":1081373,"uid":10757,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-03-28T09:26:19.000Z","msg":"中時<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-28T09:28:07.000Z","msg":"此貼已完"},{"pid":"0c2c614a058f3a609731766a1ac5454fc7e36bf2","tid":1081373,"uid":177047,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-28T09:30:54.000Z","msg":"反駁左D乜?九唔搭八懶高深"},{"pid":"5de6fcccc00c363196334f984865ba3e7e78a7d3","tid":1081373,"uid":201197,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-28T09:31:37.000Z","msg":"佢意思係：<br />\n你做總統咁差，我都無死，活下來？難道還有比你更差的嗎？<br />\n<br />\n我估大概係咁"}]}