 src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"75a271bef71941072a06b88542e54276d3f665bb","tid":1661100,"uid":186814,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-19T11:56:38.000Z","msg":"到底邊條撚頭係獲獲發夢前出刀手斬人打人去令個夢境升溫<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4ff719754b584cf3b47868dc2cde104ba8cc2549","tid":1661100,"uid":43469,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-19T13:51:49.000Z","msg":"【1020 尖咀見】真。遊行指南參考<br />\n<a href=\"https://lih.kg/1662725\" target=\"_blank\">https://lih.kg/1662725</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n香城OL V10.20 最新攻略<img src=\"/assets/faces/pig/whip_connect.gif\" class=\"hkgmoji\" />"},{"pid":"3fc91a3d7439d5ce1d84ba64d6c3cdeb4035b3e9","tid":1661100,"uid":43469,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T02:38:49.000Z","msg":"<img src=\"https://i.lih.kg/540/https://na.cx/i/nRG2D4h.png\" /><br />\n<br />\nG..."},{"pid":"3ef365bef7688a25ba4d0266d143e3f88c0d1177","tid":1661100,"uid":43469,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T03:45:51.000Z","msg":"<img src=\"https://na.cx/i/42yTMbr.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F42yTMbr.png&h=7b5c8911&s={SIZE}\" /><br />\n<br />\nCHANGE NG CHANGE HO<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"9d9d290b5d43d268719e1894340ff68b88346c89","tid":1661100,"uid":43469,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T05:08:47.000Z","msg":"<img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"}]}