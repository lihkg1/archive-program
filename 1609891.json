891,"uid":159913,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-01T15:55:59.000Z","msg":"其實冇撚用<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"968298b1b84d5cf91a9ad9580169221e2d6334e0","tid":1609891,"uid":169254,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T16:01:46.000Z","msg":"同埋除咗今日開嘅大技之外<br />\n都可以用雞蛋呢啲一技<br />\n雖然要等幾個回合<br />\n但係唔使用咁多魔 扣血效果又唔差<br />\n性價比唔差<br />\n當然用一技就應該用返喺啲適合嘅地方<br />\n廢事下個回合即刻俾人清"},{"pid":"0d6bed6e0fe30771f54b992b66c3c7f9d7369d94","tid":1609891,"uid":243350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T16:06:42.000Z","msg":"狗舍"},{"pid":"c339a662e3f9c06c6ef8d41c26c1aae8bc5b5382","tid":1609891,"uid":9457,"like":0,"dislike":0,"score":0,"quote":{"pid":"83f09e68ed8da92413e5937cb01af20d6fc45106","tid":1609891,"uid":159913,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-01T15:55:59.000Z","msg":"其實冇撚用<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-01T16:59:37.000Z","msg":"唔做又點知啫"},{"pid":"78b506da743bd9dbf5d83d118bc9d4897cdba93e","tid":1609891,"uid":258602,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T17:02:06.000Z","msg":"狗屋"}]}