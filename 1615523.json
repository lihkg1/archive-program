ouse.gov/petition/grant-permanent-residence-hong-kong-citizens-who-will-be-america-and-territories-specific-period-time?fbclid=IwAR3WGy8m65CMEuwd9Y1Gftmi0W60y_qwH6246LVgPd0qSLzwVq4G9x9NG3E</a><br />\n<br />\n<br />\n唔簽連署嘅話 你對得住被告暴動嘅手足咩"},{"pid":"a54b125946068fc592a8c3802bb93ab534db52ed","tid":1615523,"uid":24465,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-03T06:38:38.000Z","msg":"另外 如果你係有做我講過嘅行動嘅手足<br />\n多謝你地<br />\n<br />\n行動做到幾多得幾多嘅你地 要繼續努力<br />\n<br />\n覺得未夠嘅 諗下自己有冇咩可以做得更多<br />\n覺得做咗好多嘅 諗下有冇咩方法叫身邊嘅人做多啲<br />\n<br />\n香港人<br />\n加油"},{"pid":"f62d12e3c12ad49e432dda227019131fcd840106","tid":1615523,"uid":24465,"like":0,"dislike":0,"score":0,"quote":{"pid":"56d5af0d87bacfc8606c8af73b2c8c6fca17069f","tid":1615523,"uid":58803,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9aaf85ed4bb6663898b979397cb5aa15c33a907","tid":1615523,"uid":89974,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-10-03T06:28:04.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />分行動派同吹水派"},"citedBy":1,"replyTime":"2019-10-03T06:34:02.000Z","msg":"岩"},"citedBy":1,"replyTime":"2019-10-03T06:41:23.000Z","msg":"不過巡例講句<br />\n不割<br />\n<br />\n對準政權<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"3ce0a13bca38066131ff985982df0f9779c0f1ce","tid":1615523,"uid":24465,"like":0,"dislike":0,"score":0,"quote":{"pid":"f62d12e3c12ad49e432dda227019131fcd840106","tid":1615523,"uid":24465,"like":0,"dislike":0,"score":0,"quote":{"pid":"56d5af0d87bacfc8606c8af73b2c8c6fca17069f","tid":1615523,"uid":58803,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9aaf85ed4bb6663898b979397cb5aa15c33a907","tid":1615523,"uid":89974,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-10-03T06:28:04.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />分行動派同吹水派"},"citedBy":1,"replyTime":"2019-10-03T06:34:02.000Z","msg":"岩"},"citedBy":1,"replyTime":"2019-10-03T06:41:23.000Z","msg":"不過巡例講句<br />\n不割<br />\n<br />