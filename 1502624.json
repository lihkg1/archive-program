ttps://na.cx/i/TXGLDvz.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTXGLDvz.gif&h=e093d080&s={SIZE}\" />"},{"pid":"f2233fe7bddf8982f4973242a75461f5edf8c2c5","tid":1502624,"uid":4180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T01:37:34.000Z","msg":"<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"10eed7f33dbe2782b0f5bddae0e3d20089f7eaa9","tid":1502624,"uid":110509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T01:41:55.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">9月1 (日) 一定係機場</span></span><br />\n<span style=\"font-size: small;\">9月14中秋,未必CALL 到人, 所以</span><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">9月6 (六), 9 月7(日) 連續2日一定係機場</span></span><br />\n<span style=\"font-size: medium;\"><span style=\"color: red;\">之後既每個星期六/日 要起碼有一日一定係機場</span></span>"},{"pid":"b340249d61be662a6061fbf08e2a46b67b84c88f","tid":1502624,"uid":33875,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-25T05:35:51.000Z","msg":"有朋友今朝見到已經俾人撕咗<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n<br />\n但可以從中吸收經驗，包括邊張特別難撕，邊個高度佢根本撕唔到 <img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><br />\n<br />\n撕一貼十 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://i.imgur.com/BEunIU1h.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FBEunIU1h.jpg&h=d9891e4c&s={SIZE}\" />"},{"pid":"3f5f9f88333d7113228cadc683597799bc3fba43","tid":1502624,"uid":126005,"like":0,"dislike":0,"score":0,"quote":{"pid":"b3ef31c775b943f546ea173c229b8e06daeed6a5","tid":1502624,"uid":33875,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-24T16:51:06.000Z","msg":"<img src=\"https://i.imgur.com/4ebVcnYh.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2F4ebVcnYh.png&h=851c0d8c&s={SIZE}\" /><br />\n<br />\n早幾日講開樓下幅牆好單調 ，問下有冇人想佈置下 <img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><br />\n幅牆前後大概有八、九張文宣出現過<br />\n右邊幾張太高藍老膝頭痛跳唔到上去撕 <img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=hWWc5TGCl2Y&amp;feature=youtu.be\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DhWWc5TGCl2Y%26feature%3Dyoutu.be&d=BZKFieMwLRuYRu3HtqC84vYtrFBHe52Fn%2F6n3rMGN5k%3D&h=6b1a3384\" target=\"_blank\">https://www.youtube.com/watch?v=hWWc5TGCl2Y&amp;feature=youtu.be</a><br />\n<br />\n人鏈完返去開咗個頭，寫咗幾隻字 <img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><br />\n<strong><span style=\"color: gold;\"><span style=\"font-size: large;\">823 烏溪沙連儂牆正式上線</span></span></strong> <img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n不過第二朝就唔見哂 <img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://i.imgur.com/76V9NtSh.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2F76V9NtSh.png&h=baa7a41c&s={SIZE}\" /><br />\n<br />\n估唔到824 下午有兩位女學生山長水遠由新西騎牛牛到新東搞撕一貼十 <img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n窮無錢派，唯有應承請佢飲汽水 <img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n所以，<strong><span style=\"color: gold;\"><span style=\"font-size: large;\">824 烏溪沙連儂牆又上線喇</span></span></strong> <img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://i.imgur.com/luuMnBXh.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FluuMnBXh.png&h=9fce4a3f&s={SIZE}\" /><br />\n<br />\n利安、翠擁、銀湖、迎海既手足係時候準備紙筆墨硯了 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-25T05:58:31.000Z","msg":"LM"},{"pid":"5757151e66e5570f9921be9f0012fa71ebb08176","tid":1502624,"uid":33875,"like":0,"dislike":0,"score":0,"quote":{"pid":"06ab7b79c4a73139c6954041825fe60f1be1a49e","tid":1502624,"uid":92042,"like":0,"dislike":0,"score":0,"quote":{"pid":"02e604c702cee8d28c75a2ea5898091fdba2bb2c","tid":1502624,"uid":33875,"like":0,"dislike":0,"score":0,"quote":{"pid":"110ec2a6ea413337fe4db87a7bb1f0670314e022","tid":1502624,"uid":92042,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-24T17:01:26.000Z","msg":"我覺得要買啲地拖物體黎痴高位<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-24T17:08:38.000Z","msg":"旁邊有啲「中國律師」廣告痴到三米高，年幾都無人清到<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-24T18:57:20.000Z","msg":"點先可以痴到咁高<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-25T05:59:35.000Z","msg":"利安有梯買<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"acf4704580b79100baa314bda8fcd73635ad82fb","tid":1502624,"uid":269194,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-25T08:10:53.000Z","msg":"好！支持<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n前日諗住揾mos連儂橋, 揾極都揾唔到！"},{"pid":"89c1feeb93536af5e9032958743b6fd1a4f3dd7d","tid":1502624,"uid":33875,"like":0,"dislike":0,"score":0,"quote":{"pid":"acf4704580b79100baa314bda8fcd73635ad82fb","tid":1502624,"uid":269194,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-25T08:10:53.000Z","msg":"好！支持<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n前日諗住揾mos連儂橋, 揾極都揾唔到！"},"citedBy":1,"replyTime":"2019-08-25T15:11:27.000Z","msg":"馬鞍山站向新港城方向直出直行就係<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid"