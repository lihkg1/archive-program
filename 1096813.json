7746,"like":1,"dislike":2,"score":-1,"quote":{"pid":"06f1e1a8c6cc2d829fe5123115d0f47b14f809d5","tid":1096813,"uid":240250,"like":0,"dislike":1,"score":-1,"quote":{"pid":"9ea72c77d03ff04e47fecb0213613ec41774d7c5","tid":1096813,"uid":37746,"like":126,"dislike":3,"score":123,"quote":{"pid":"5ede7ec83e35bb2bf6b66ccabd1373d6a80cc8d3","tid":1096813,"uid":240250,"like":1,"dislike":53,"score":-52,"citedBy":1,"replyTime":"2019-04-08T03:59:02.000Z","msg":"你廢姐<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-04-08T03:59:34.000Z","msg":"間野唔乾淨"},"citedBy":2,"replyTime":"2019-04-08T04:12:33.000Z","msg":"垃圾"},"citedBy":1,"replyTime":"2019-04-08T04:22:44.000Z","msg":"唔好咁話自己啦"},{"pid":"b30fdf0cecb1d583271e790ca98d9c3453cb2d65","tid":1096813,"uid":21747,"like":129,"dislike":2,"score":127,"citedBy":1,"replyTime":"2019-04-08T04:25:50.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/realtime/article/20180727/58494767\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20180727%2F58494767&d=Qy2hiQzhAVWh7XuXj3aMUUPclXdXKQfB%2FlJdEd6ZkMI%3D&h=0e7727da\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20180727%2F58494767&h=6d445401\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/realtime/article/20180727/58494767</a><br />\n7名市民進食「炑八韓烤」銅鑼灣分店的外賣食物，包括奄列和鰻魚後，出現屙嘔、肚痛等症狀，懷疑食物中毒，其中5人需要求醫。衞生防護中心正調查事件。食物環境衞生署已派人到該食肆調查，認為其衞生情況尚可，已抽取環境樣本作化驗。炑八韓烤表示，當日有客人訂購超過100份蛋包飯，不知悉客人運送方法和時間，但強調會配合食安中心指示。<br />\n<br />\n涉及食肆位於軒尼詩道502號黃金廣場的「炑八韓烤」，在本港有多間分店，主要提供韓國菜包括韓燒。防護中心發言人表示，事件涉及2宗個案，首宗個案涉及3名介乎38至48歲的女子。她們在本月20日，到該食肆購買奄列和鰻魚返辦公室進食，約13至26小時後出現發燒、腹痛、腹瀉和嘔吐等症狀。3人已向私家醫生求診。第2宗個案涉及2男2女，介乎25至34歲。他們於同日進食該食肆同一的外賣食物，約9至30小時後感不適。當中有2人分別向私家醫生及東區醫院急症室求診。全部病人情況穩定，毋須住院。<br />\n<br />\n食環署表示，接獲防護中心通知事件後，已派員到有關食肆調查，包括抽取環境樣本作化驗，並向食肆的負責人和員工提供衞生教育。另建議有關食肆暫停供應相關食物，並進行徹底清潔消毒。調查仍然繼續。<br />\n<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"c5b4fbeb371d7b2e61d963826771d638049a68dc","tid":1096813,"uid":153427,"like":183,"dislike":1,"score":182,"citedBy":1,"replyTime":"2019-04-08T04:27:30.000Z","msg":"真係好好食<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/wWzvKb5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwWzvKb5.png&h=d2706d23&s={SIZE}\" />"},{"pid":"d065bca9690c1aec40653060fe38213e5899c7e5","tid":1096813,"uid":19621,"like":33,"dislike":1,"score":32,"citedBy":0,"replyTime":"2019-04-08T04:29:47.000Z","msg":"上次食到腸胃炎<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8b176b1dc2c484575bb3bacfa08b1360d8e5a2a5","tid":1096813,"uid":125431,"like":8,"dislike":8,"score":0,"citedBy":0,"replyTime":"2019-04-08T04:32:26.000Z","msg":"咁多巴打出過事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n睇黎係小弟死好命 食咗咁多次乜事都冇<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1995ec8b0261da4df2b92af79fff437c5a6fb075","tid":1096813,"uid":35587,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd6b9bea14d3047f3b137a1b3d9623ca1cd5f9eb","tid":1096813,"uid":125431,"like":39,"dislike":1,"score":38,"quote":{"pid":"e1ee362f2105478ce4b00bdfee73729c8fead962","tid":1096813,"uid":35587,"like":18,"dislike":0,"score":18,"quote":{"pid":"f62372e804bb9870678d65b4affdd09069012069","tid":1096813,"uid":56701,"like":20,"dislike":2,"score":18,"citedBy":1,"replyTime":"2019-04-08T04:00:48.000Z","msg":"下午茶叫佢俾多碟泡菜都無詐型<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-04-08T04:01:18.000Z","msg":"唔係無限?"},"citedBy":2,"replyTime":"2019-04-08T04:02:25.000Z","msg":"你食到嘅話你食十碟都仲得<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-08T07:38:03.000Z","msg":"食幾碟都胃痛<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"38644332b9ea8670905eb26ee9284c6d69f99be5","tid":1096813,"uid":240250,"lik