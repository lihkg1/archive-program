3Dtrue&d=ruuHvkpDPTXA%2B6q4k3%2F6Ta3e3GGuF%2FCnRpDBLK0zENU%3D&h=ef60631b\" data-auto-link target=\"_blank\">https://www.worldjournal.com/6257025/article-港媒：你不知道的習近平是美劇迷/?ismobile=true</a>"},{"pid":"1b6c1dc3753ae3acc06b59742ab8ad3d29da553b","tid":1165001,"uid":14503,"like":2,"dislike":0,"score":2,"quote":{"pid":"175c5ddc00bd34482968b7154658fe190e9abf6c","tid":1165001,"uid":73340,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-05-21T13:24:16.000Z","msg":"屌女"},"citedBy":1,"replyTime":"2019-05-21T13:27:00.000Z","msg":"青頭先會咁講"},{"pid":"01b21b5aa93843bb4db7ab77e5651095a331c389","tid":1165001,"uid":113626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-21T13:27:41.000Z","msg":"你地平時接觸得多上網果d先會重視呢類娛樂<br />\nd有錢佬同權貴唔係玩你地平民既野 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"628cec7ded2a7ea20c3c5acac8eaa09f228afff2","tid":1165001,"uid":1067,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-05-21T13:27:47.000Z","msg":"睇侵侵Twitter"},{"pid":"569645b109b39a1cca69ea75f3234d3c5c36e506","tid":1165001,"uid":73340,"like":0,"dislike":1,"score":-1,"quote":{"pid":"1b6c1dc3753ae3acc06b59742ab8ad3d29da553b","tid":1165001,"uid":14503,"like":2,"dislike":0,"score":2,"quote":{"pid":"175c5ddc00bd34482968b7154658fe190e9abf6c","tid":1165001,"uid":73340,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-05-21T13:24:16.000Z","msg":"屌女"},"citedBy":1,"replyTime":"2019-05-21T13:27:00.000Z","msg":"青頭先會咁講"},"citedBy":0,"replyTime":"2019-05-21T13:28:06.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />唔屌女唔通自己打飛機呀"},{"pid":"9930c97e4d24b86cb9a02617feb7a17f3843f3c7","tid":1165001,"uid":112551,"like":2,"dislike":0,"score":2,"quote":{"pid":"5b6a5d5632271b2ce65c7376e35d8defb0062f1a","tid":1165001,"uid":14503,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-21T13:23:47.000Z","msg":"其實佢打開電視睇中國d新聞自己有咩感覺？"},"citedBy":0,"replyTime":"2019-05-21T13:29:04.000Z","msg":"好似有無形之手幫佢打飛機咁爽"},{"pid":"0a0ef793bdb3