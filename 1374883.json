slike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T17:39:49.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"036032208ddb8d1f26b8c37877a397ffef178149","tid":1374883,"uid":25164,"like":0,"dislike":0,"score":0,"quote":{"pid":"06e9623c30181e8b0da4e2e887381e0ab1dd8936","tid":1374883,"uid":29979,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-28T04:24:16.000Z","msg":"善用起底功能， 負皮，封鎖，上一頁"},"citedBy":0,"replyTime":"2019-07-28T17:41:49.000Z","msg":"負左<br />\n<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}