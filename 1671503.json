網上有好多惡毒嘅人抹黑我地<br />\n其實只要肯畀些少時間畀6萬蚊<br />\n擺1-2年時間浸下<br />\n掂咗嘅咪知事實係點囉<br />\n唔掂嘅最多咪出去打返工<br />\n當畀個機會自己試下囉<br />\n唔試過又點知得唔得呢？<br />\n我諗都唔諗就即刻擺低咗6萬蚊<br />\n因為我知道呢盤生意一定有得做<br />\n信我！"},{"pid":"306ad9a3e7b78404392544fdbb19b36562af7afc","tid":1671503,"uid":169676,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-10-24T06:29:51.000Z","msg":"推一推幫下大家"},{"pid":"35e538d900b7e3cc1e1439a2ebe21106167d80e3","tid":1671503,"uid":35487,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-24T08:02:17.000Z","msg":"屌你老母含撚啦傳銷狗"},{"pid":"c0251484f9953efb25d4463924bc8a5605bf1a55","tid":1671503,"uid":169676,"like":0,"dislike":1,"score":-1,"quote":{"pid":"35e538d900b7e3cc1e1439a2ebe21106167d80e3","tid":1671503,"uid":35487,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-24T08:02:17.000Z","msg":"屌你老母含撚啦傳銷狗"},"citedBy":1,"replyTime":"2019-10-24T08:10:47.000Z","msg":"係咪有咩誤會？"},{"pid":"347b5c90830acd4720cab8c19771212ccce8ae52","tid":1671503,"uid":35487,"like":1,"dislike":0,"score":1,"quote":{"pid":"c0251484f9953efb25d4463924bc8a5605bf1a55","tid":1671503,"uid":169676,"like":0,"dislike":1,"score":-1,"quote":{"pid":"35e538d900b7e3cc1e1439a2ebe21106167d80e3","tid":1671503,"uid":35487,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-24T08:02:17.000Z","msg":"屌你老母含撚啦傳銷狗"},"citedBy":1,"replyTime":"2019-10-24T08:10:47.000Z","msg":"係咪有咩誤會？"},"citedBy":1,"replyTime":"2019-10-24T08:12:01.000Z","msg":"搵食過主啦"},{"pid":"f6a1806c8a0115c679dd7ae7ded2f671783aee85","tid":1671503,"uid":169676,"like":0,"dislike":1,"score":-1,"quote":{"pid":"347b5c90830acd4720cab8c19771212ccce8ae52","tid":1671503,"uid":35487,"like":1,"dislike":0,"score":1,"quote":{"pid":"c0251484f9953efb25d4463924bc8a5605bf1a55","tid":1671503,"uid":169676,"like":0,"dislike":1,"score":-1,"quote":{"pid":"35e538d900b7e3cc1e1439a2ebe21106167d80e3","tid":1671503,"uid":35487,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-24T08:02:17.000Z","msg":"屌你老母含撚啦傳銷狗"},"citedBy":1,"replyTime":"20