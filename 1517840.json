/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"ffd9d28a315e293905db297b8ca3bf0d0898d249","tid":1517840,"uid":22585,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-08-30T07:28:23.000Z","msg":"<img src=\"https://na.cx/i/LLVpWkT.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLLVpWkT.gif&h=09e1a977&s={SIZE}\" />"},{"pid":"a5d5861c31a859ab5462deef0195d1cd29760286","tid":1517840,"uid":33620,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T07:31:05.000Z","msg":"lm"},{"pid":"e45b5b1b750d708656661e764f50a25f02cf54a7","tid":1517840,"uid":182207,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T07:32:10.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"654f784ddf2f57112c58483ceeb752043b338ca6","tid":1517840,"uid":23046,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T07:32:51.000Z","msg":"lm"},{"pid":"247d9b7e42e96aa36ff1fc40510184cb507fe25b","tid":1517840,"uid":190315,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T07:33:25.000Z","msg":"多謝"},{"pid":"48e9a76e225f8c67f9ca4596d5df87ecfaf11cb6","tid":1517840,"uid":3456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T07:34:04.000Z","msg":"留名"},{"pid":"418cbeeaeead5137190a001f62ec7d6cd6c31ccd","tid":1517840,"uid":253978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T07:34:30.000Z","msg":"拎錢啊<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"e7e81171054f236899a47d9c6560ccd45b3d3a2c","tid":1517840,"uid":241297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T07:41:12.000Z","msg":"大dodo<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"fc2b16ff7140d94c608e52d64a5cb772dddb3fe9","tid":1517840,"uid":98795,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019