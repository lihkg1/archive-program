By":0,"replyTime":"2019-11-26T05:38:45.000Z","msg":"推"},{"pid":"fc2203b25dcaffc24d9230fcdca9662c5f993227","tid":1755801,"uid":262340,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T05:38:58.000Z","msg":"推"},{"pid":"faadfd87fdfb147ea552928358f8f18cd9eb7628","tid":1755801,"uid":262340,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T05:39:09.000Z","msg":"推"},{"pid":"515fbd806601face13ce1e3bbbb5c593e34c018d","tid":1755801,"uid":262340,"like":0,"dislike":0,"score":0,"quote":{"pid":"9ec3babfeeec319971f0b429894a879002dcad48","tid":1755801,"uid":132931,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-25T18:47:45.000Z","msg":"怕唔怕變左圍爐大會????<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-26T05:44:10.000Z","msg":"我地會嘗試係唔同渠道宣傳呢個活動，希望可以吸納更多唔同政見嘅人嚟參與<br />\n所以你嘅參與好重要啊<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"6459f48b4355c07fd06d13a034564d6b62884608","tid":1755801,"uid":11520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T10:06:28.000Z","msg":"推"},{"pid":"0679817baf3a5db9e0af73caca78614834d5faf9","tid":1755801,"uid":262340,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T10:13:54.000Z","msg":"推"},{"pid":"f8a055d354ebb652781ebfc758e8563f2e0508dc","tid":1755801,"uid":262340,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T10:14:07.000Z","msg":"推"},{"pid":"f4ea9e20fb3cc12748f6a0b31328c007b3de5439","tid":1755801,"uid":262340,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-26T10:14:18.000Z","msg":"推"}]}