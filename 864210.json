,{"pid":"f06278d175c0bacada71e545fcbdc165cc9ffb4c","tid":864210,"uid":194363,"like":0,"dislike":0,"score":0,"quote":{"pid":"9b5a883d78e5648bd4202980e7d14c8df261fe56","tid":864210,"uid":44559,"like":0,"dislike":1,"score":-1,"quote":{"pid":"c998e716cd3af81b82706b4e90ec9337c500bb7f","tid":864210,"uid":194363,"like":0,"dislike":0,"score":0,"quote":{"pid":"b6f8b708349d82f6f6f674e371b35d06c37416e4","tid":864210,"uid":44559,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-10-16T04:49:26.000Z","msg":"薯容好食，真係舒服<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-16T04:50:15.000Z","msg":"咁加番個長食評啦<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-16T04:50:58.000Z","msg":"好肚餓<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /> <br />\n<br />\n食完先<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-16T04:54:08.000Z","msg":"等你<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" />"},{"pid":"164a65f7802e4700cf96d54111e7a2fa6b39bb85","tid":864210,"uid":44559,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-16T05:11:03.000Z","msg":"長食評<br />\n<br />\n腸有黑椒味，食落無奇怪粒粒，好食<img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" /> <br />\n<br />\n漢堡扒，普通漢堡，好食<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /> ，而家好少餐廳有漢堡扒，可能成本貴<br />\n<br />\n薯容有牛油味，本身打到岩岩好，比kfc靜啲水少少，完美，食落好舒服<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /> <br />\n<br />\n敗筆在於個汁，好水，又無咩味，好似油咁，食薯容果時無可避免要連汁一齊食，破壞左薯容個結構，太水，而且食曬後，因為好多汁，感覺有啲油膩<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /> ，但又未到唔舒服<br />\n<br />\n總結8分，個汁改左佢9分<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n同卓加映，水牛雞翼，同枱叫，聽佢地講，幾辣，個汁係用辣椒仔果隻汁整，聽落應該又酸又辣，應該幾好食<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /> <br />\n<br />\n另外好似有芝士醬跟?"},{"pid":"c26df5cd30caeffd884983539868a841e4d3cbf1","tid":864210,"uid":194363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-16T05:13:46.000Z","msg":"條腸呢？"},{"pid":"4d7287cf51346e544bb854e591e438dada755f91","tid":864210,"uid":33359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-16T05:22:20.000Z","msg":"想食<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},{"pid":"c333daf49a48019493081acca21e57837f6381de","tid":864210,"uid":44559,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-16T05:42:22.000Z","msg":"Btw<br />\n<br />\n岩先出炫果時，原來出邊好多枱，都唔明點解啲人唔坐出邊<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"a47b647dfae9ebc533bbb2b41b55986fc6ef88be","tid":864210,"uid":194363,"like":0,"dislike":0,"score":0,"quote":{"pid":"c333daf49a48019493081acca21e57837f6381de","tid":864210,"uid":44559,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-16T05:42:22.000Z","msg":"Btw<br />\n<br />\n岩先出炫果時，原來出邊好多枱，都唔明點解啲人唔坐出邊<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-16T05:47:58.000Z","msg":"熱囉<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"63bbc4d6a3ab6f8215a133a5ef3bd3d3524f6339","tid":864210,"uid":44559,"like":0,"dislike":0,"score":0,"quote":{"pid":"a47b647dfae9ebc533bbb2b41b55986fc6ef88be","tid":864210,"uid":194363,"like":0,"dislike":0,"score":0,"quote":{"pid":"c333daf49a48019493081acca21e57837f6381de","tid":864210,"uid":44559,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-16T05:42:22.000Z","msg":"Btw<br />\n<br />\n岩先出炫果時，原來出邊好多枱，都唔明點解啲人唔坐出邊<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy"