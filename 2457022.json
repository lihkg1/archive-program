hkg.com/link?u=https%3A%2F%2Fwww.cna.com.tw%2Fnews%2Ffirstnews%2F202103225007.aspx&d=VfnGJYDpQhHIir2SHpwXXJUrr29XULmfQ5XcAAvzh4c%3D&h=0d5b8f06\" data-auto-link target=\"_blank\">https://www.cna.com.tw/news/firstnews/202103225007.aspx</a>"},"citedBy":2,"replyTime":"2021-03-22T10:42:25.000Z","msg":"台灣d機太舊了&hellip;樣樣都manual control, 加上零件老化"},"citedBy":0,"replyTime":"2021-03-22T10:45:14.000Z","msg":"F-5太舊，其他還好"},{"pid":"89f308ff420fc9c5ee06ae4a6ac12c46837a466b","tid":2457022,"uid":292499,"like":0,"dislike":0,"score":0,"quote":{"pid":"834b4da5adb1e8fdbb02fe84b194029d93b58efd","tid":2457022,"uid":196924,"like":0,"dislike":0,"score":0,"quote":{"pid":"7e47b72976034f7c8d08c8b2fdc9914afb5905d9","tid":2457022,"uid":292499,"like":0,"dislike":0,"score":0,"quote":{"pid":"72bee9849e2b171d92aef46b5e13603449e23a5e","tid":2457022,"uid":19126,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-22T10:40:29.000Z","msg":"呢排台灣啲戰機成日出事<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-22T10:44:29.000Z","msg":"又係F-5出事"},"citedBy":2,"replyTime":"2021-03-22T10:45:12.000Z","msg":"大佬F-5E 50年前嘅design<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-22T10:45:38.000Z","msg":"台灣果啲係80年代初生產"},{"pid":"a9d10ed59b4fc862ecccca66af51005ed0add2fe","tid":2457022,"uid":1327,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-03-22T10:45:40.000Z","msg":"未打就已經一年死幾個... 咁落去真係唔掂"},{"pid":"3b661d2ebbeb4408b222662d9eb56525cdb4776d","tid":2457022,"uid":363963,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-03-22T10:46:58.000Z","msg":"罹難飛官朱冠甍的母親，激動地說，「再有下一個，我會替他去跳台東的海！」。資料照片<br />\n我空軍2架F-5E戰鬥機驚傳今天（22日）下午3時10分疑似擦撞墜海，2名飛官中尉羅尚樺搶救後宣告不治，上尉潘穎諄仍在搜救中，去（2020）年10月29日台東志航基地就有一架F-5E戰鬥機墜海，飛官朱冠甍第一時間跳機逃生，救起後卻仍傷重不治，當時朱冠甍母親就曾說悲痛地說，「再有下一個，我會替他去跳台東的海！」<br />\n<br />\n朱冠甍母親當天下午趕抵台東殯儀館見兒子最後一面，悲痛地表示，孩子之前曾經說過：「媽媽！F5早晚會出事！」「今天這責任他扛了，我的孩子爭氣，可是軍方給我的是什麼？國家給我的是什麼？一定要等到出問題才有人重視？」、「他明知那麼破舊、老舊，他竟然還要每天承受這壓力，他有孩子有老婆，爸媽沒關係，我們老了，大海在那邊等著我，跳下去就好了」朱母說到激動處，還說「再有下一個，我會替他去跳台東的海！」言猶在耳，不料才時過數月，竟又發生意外憾事，令人不剩唏噓。<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"fd09698ab5a796fd6fb78c1bd5a9f2b4bbe6825a","tid":2457022,"uid":292499,"like":1,"dislike":0,"score":1,"quote":{"pid":"a9d10ed59b4fc862ecccca66af51005ed0add2fe","tid":2457022,"uid":1327,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-03-22T10:45:40.000Z","msg":"未打就已經一年死幾個... 咁落去真係唔掂"},"citedBy":0,"replyTime":"2021-03-22T10:47:51.000Z","msg":"今次無端端相撞，應該同機件冇乜關係，可能係編隊飛行訓練，編隊編得唔好"},{"pid":"8975c42f50964904071f9266bca7af8b72e42f68","tid":2457022,"uid":292499,"like":0,"dislike":0,"score":0,"quote":{"pid":"3b661d2ebbeb4408b222662d9eb56525cdb4776d","tid":2457022,"uid":363963,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-03-22T10:46:58.000Z","msg":"罹難飛官朱冠甍的母親，激動地說，「再有下一個，我會替他去跳台東的海！」。資料照片<br />\n我空軍2架F-5E戰鬥機驚傳今天（22日）下午3時10分疑似擦撞墜海，2名飛官中尉羅尚樺搶救後宣告不治，上尉潘穎諄仍在搜救中，去（2020）年10月29日台東志航基地就有一架F-5E戰鬥機墜海，飛官朱冠甍第一時間跳機逃生，救起後卻仍傷重不治，當時朱冠甍母親就曾說悲痛地說，「再有下一個，我會替他去跳台東的海！」<br />\n<br />\n朱冠甍母親當天下午趕抵台東殯儀館見兒子最後一面，悲痛地表示，孩子之前曾經說過：「媽媽！F5早晚會出事！」「今天這責任他扛了，我的孩子爭氣，可是軍方給我的是什麼？國家給我的是什麼？一定要等到出問題才有人重視？」、「他明知那麼破舊、老舊，他竟然還要每天承受這壓力，他有孩子有老婆，爸媽沒關係，我們老了，大海在那邊等著我，跳下去就好了」朱母說到激動處，還說「再有下一個，我會替他去跳台東的海！」言猶在耳，不料才時過數月，竟又發生意外憾事，令人不剩唏噓。<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-22T10:48:53.000Z","msg":"今次睇落唔似機件問題，上次就唔知，今次係無端端4機編隊撞，似係操作出錯"},{"pid":"7e417f187ee5736c15f6c4d198c66d7821f9dcdb","tid":2457022,"uid":61547,"like":0,"dislike":0,"score":0,"quote":{"pid":"9db02fd123eef24e6e8bbe91c0b70c5cffe7070f","tid":2457022,"uid":292499,"like":0,"dislike":0,"score":0,"quote":{"pid":"a3bd2c1d3c7faacea8fab3f1e9cde694c6ef8bfc","tid":2457022,"uid":291921,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2021-03-22T10:40:05.000Z","msg":"RIP<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgm