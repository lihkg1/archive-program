/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ea14d696fd73d0939bcd58e92e219f4e98b37648","tid":54544,"uid":1402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T16:56:24.000Z","msg":"<img src=\"https://na.cx/i/g4i3Fa.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fg4i3Fa.gif&h=7f52b0c1&s={SIZE}\" /> <img src=\"https://na.cx/i/g4i3Fa.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fg4i3Fa.gif&h=7f52b0c1&s={SIZE}\" /> <img src=\"https://na.cx/i/g4i3Fa.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fg4i3Fa.gif&h=7f52b0c1&s={SIZE}\" /> 早洩"},{"pid":"2331e7796497115a10054718a523441f8529d017","tid":54544,"uid":60239,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T16:56:31.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6e8fccd860f3920f0fcab2f4a8104dd9b09f9733","tid":54544,"uid":9003,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T16:56:31.000Z","msg":"Dr. Jim<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"b6e914af1384489ee881952eb5053a263467ad9f","tid":54544,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T16:59:44.000Z","msg":"以前上hkgolden真係學到野<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"c6e7586221fbc47169efaf5d02c41faaea8e6b10","tid":54544,"uid":47523,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T16:59:54.000Z","msg":"都幾認同，以前用winmix逐隻歌down，之後去到bt成集碟黎，然後開始用寄存網站貪佢唔洗等seed，後來再懶啲用jdownloader一次過down晒，而最後去到streaming出左就用到呢家<br />\n洗唔洗錢雖然係一個重要因素，但最重要其實都係方便同快，冇人估到之後會點發展，但就一定會有野取代你，如icq/msn、nokia/moto等結果有眼睇，而好似高登咁玩左十年先死，其實早洩都算好命<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7e18f3c206ed74a39eee57b430f5e3c4b823d0f0","tid":54544,"uid":11980,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T16:59:56.000Z","msg":"上面個件柒頭連drjim都唔識  睇起底仲要似係五毛打手<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7bccd7e170a9575418eb638d77cf56ad41aad9c1","tid":54544,"uid":3659,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T17:01:30.000Z","msg":"奶共占今次又講得有道理嘅<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"0edd470b795520700f524eeaec648aee40729c4d","tid":54544,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T17:03:21.000Z","msg":"唔係有Dr jim搞高登，早洩現在可能食緊$32.5 IT屎工"},{"pid":"5323e57aa0ac4b57664de056e51665366ef5b0a4","tid":54544,"uid":26156,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T17:31:36.000Z","msg":"此回覆已被刪除"},{"pid":"8d91368009184836a6d92db938dc8fec3bba0936","tid":54544,"uid":13663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T17:33:28.000Z","msg":"藍屍乃共jim"},{"pid":"e1d71502444fc8488b06d68e007f02f46cfb8366","tid":54544,"uid":32756,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T17:33:45.000Z","msg":"Dr.Jim <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"451c04f846a777895250fca3135efcae29723025","tid":54544,"uid":34676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T17:33:54.000Z","msg":"<blockquote>幾有point<br />\n呢個人講野有料過林早洩</blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"18c1a9192c19ff9f1cf1cba4813c6fca418215db","tid":54544,"uid":26156,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-25T17:35:52.000Z","msg":"此回覆已被刪除"},{"pid":"4a79b2080f18de82808d0462eb3553514374d5ad","tid":54544,"uid":30807,"