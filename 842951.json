42951,"uid":79877,"like":16,"dislike":0,"score":16,"quote":{"pid":"a5103ebfb40ade9006024a32249889a96cdd5e1b","tid":842951,"uid":137188,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-30T17:18:23.000Z","msg":"借account !<br />\n<br />\n話說我朋友早幾年同屋企關係唔好 諗住買私樓搬出去住 點知佢呀媽抑鬱發作 佢要照顧呀媽就好多時間留係公屋 掉空左層私樓 同時佢都同佢老豆講要除名 叫佢老豆搞<br />\n<br />\n去到2017年 房署有信要求報資產 佢先發現佢老豆無幫佢除名 係個陣佢呀媽個病都未好 加上掉空左係到就諗住賣樓 留番係公屋照顧老母 所以無報 怕比人收番間公屋 其實有埋私樓 佢地入息同埋資產都唔過<br />\n<br />\n到近期 收到房署信要求就私樓無報上去會面<br />\n<br />\n咁我朋友就好驚收番佢層公屋 因為私樓係2017 10月已經賣左 賣完個資產都唔過 同埋驚比房署告<br />\n<br />\n大家有無咩睇法 我朋友可以點做？"},"citedBy":0,"replyTime":"2018-09-30T18:08:58.000Z","msg":"唔洗諗<br />\n佢叫得你會面<br />\n已經有晒證據<br />\n告就好大機會，事實你朋友亦有虛報<br />\n諗定求情好過<br />\n<br />\n另外<br />\n市面有咩樓係會賣完都唔過資產上限？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cd24afb15e57ff0c19089e99b6d0fd531e1b0a50","tid":842951,"uid":155732,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-09-30T18:11:26.000Z","msg":"公屋富戶想人幫<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"2418f8efae637cdf6b95852b75cf7c2d86f6861d","tid":842951,"uid":125688,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-09-30T18:38:31.000Z","msg":"係咪刑事要坐監留案底？"},{"pid":"e763f6301ade441b0ebb4c4318e44d7e25e54a4c","tid":842951,"uid":340,"like":4,"dislike":0,"score":4,"quote":{"pid":"2418f8efae637cdf6b95852b75cf7c2d86f6861d","tid":842951,"uid":125688,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-09-30T18:38:31.000Z","msg":"係咪刑事要坐監留案底？"},"citedBy":0,"replyTime":"2018-09-30T18:40:58.000Z","msg":"係 如果告既話"},{"pid":"7f48d4c3fd08da4a0f68285fbce1d1d316ffb9ff","tid":842951,"uid":56999,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-09-30T18:41:31.000Z","msg":"有冇交過假文件<br />\n<br />\n有就好大罪<br />\n<br />\n無就話報漏  交返間屋比房署"},{"pid":"afd7b432ba2f046faf29d12e9ffad1679e146ee7","tid":842951,"uid":125654,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-09-30T18:45:22.000Z","msg":"一個post連戴兩個頭盔<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"eed95850ce67e19e10e735f24c9922958b20dc83","tid":842951,"uid":35656,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-09-30T19:16:45.000Z","msg":"收番公屋小事，如果你之前曾經交過一D文件或簽過一D聲明作假入息證明係會衰刑事，不過到時都仲係政府包你食宿，不過係赤柱咁解囉"},{"pid":"1c3d35e12643d0941cc30d078636953d97301546","tid":842951,"uid":21558,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2018-09-30T19:38:54.000Z","msg":"叫得上去會面<br />\n一定有哂證據<br />\n你有乜心願未了好快啲做<br />\n到時候食皇家飯就冇咁自由<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /> 好多人話用報漏做抗辯理由<br />\n不過老老實實，正常人都唔會唔記得自己曾經有層私樓啦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"99bcf143402856c20133675cef3d28eaeb37e77a","tid":842951,"uid":108762,"like":13,"dislike":0,"score":13,"citedBy":0,"replyTime":"2018-09-30T19:49:36.000Z","msg":"全文咪就係 公屋富户買樓投資 虛報資產呃公屋住<br />\n中間作咁多情節做乜 邊個care你咩原因買樓買完又住公屋 就算係唔記得除名 都唔代表你可以唔報資產<br />\n仲想利用老母精神病做理由搵着數 佢有抑鬱搞到你隱瞞資產？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"3a31250cedc5f41e8892bfdbc354c416a6211cb0","tid":842951,"uid":213730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-30T20:06:50.000Z","msg":"你的朋友就是你<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"36420eef4afb204a0f473ad4951a5f635c6716de","tid":842951,"uid":93321,"like":0,"dislike":0,"score":0,"quote":{"pid":"2e07ece453a492eaed113566b99a584734a3e643","tid":842951,"uid":42817,"like":37,"dislike":1,"score":36,"citedBy":2,"replyTime":"2018-09-30T17:24:02.000Z","msg":"你自首啦。<br />\n一開始又話你借account，到最後又問你朋友可以點做<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-30T21:52:22.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> failed"},{"pid":"5ddeb895634df424e0e3d9b34912731cd0d513ac","tid":842951,"uid":15948,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-09-30T22:35:26.000Z","msg":"發夢夢見 <br />\n啊媽情緒病如有醫生證明 <br />\n冇人敢搞你 <br />\n<br />\n利申9up當秘笈"},{"pid":"33233e12817ca6d7f0f8a27cb37cc7212cab7322","tid":842951,"uid":130365,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-30T22:38:16.000Z","msg":"有個朋友類似你呢個case<br />\n佢地有齊証明先會叫你會面, 傾返收返層私樓<br />\n就算你話筆錢無左佢地都唔會信, 始終可以資產轉移"},{"pid":"33f37bad16fe8ddd5eec9a54aafb1cb0f15c2e25","tid":842951,"uid":130365,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-30T22:38:44.000Z","msg":"<blockquote>有個朋友類似你呢個case<br />\n佢地有齊証明先會叫你會面, 傾返收返層<span style=\"color: red;\">公屋</span><br />\n就算你話筆錢無左佢地都唔會信, 始終可以資產轉移</blockquote>"},{"pid":"98af8cfeb0c52104b24f20a19e706db7ba27cb40","tid":842951,"uid":42283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-30T22:40:44.000Z","msg":"收到信比人叫報資產都可以唔報 係咪想死<br />\n作故仔作得好D啦"},{"pid":"44108ac314b96003cc4d3b62ac3839b7b8b39daa","tid":842951,"uid":33878,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-01T00:02:36.000Z","msg":"坐監啦on9"},{"pid":"fca0c4f7b954f829589880732077f9bf7900fb0d","tid":842951,"uid":122377,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-01T01:19:44.000Z","msg":"即刻買埋層公屋 試下得唔得 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n還返間公屋比政府啦"}]}