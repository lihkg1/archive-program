a05f798bede1bbfb9","tid":2498722,"uid":44826,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-21T10:56:56.000Z","msg":"比支那射沉左?<img src=\"/assets/faces/dog/discover.gif\" class=\"hkgmoji\" />"},{"pid":"2994aedbf383c09bc02e98c989c03a3f516348e4","tid":2498722,"uid":25424,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2021-04-21T10:56:58.000Z","msg":"快啲叫美國佬救<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"4e2ca4f8b957bd3895f7b23f77086abc1bd68ec2","tid":2498722,"uid":62226,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2021-04-21T10:57:58.000Z","msg":"MH370之後，終於又可以玩海底尋寶"},{"pid":"8db609ad4d11d122b44b6a2f0beb9ed02388c06a","tid":2498722,"uid":391580,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-21T10:58:11.000Z","msg":"失蹤嘅應該係韓國仔呢部潛艇<br />\n<br />\n印尼海軍得兩種潛艇，另外一種係德國嘅209型，70年代產品，不過係小型潛艇最多可以坐三十幾個<br />\n<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmbSQfkScJxL1C5WCUrpgcxoGtnvRW9HmHssFfg7KNeGmU?filename=PwfudVo.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPwfudVo.jpg&h=2da71c21&s={SIZE}\" />"},{"pid":"ffd0de2f118a28ff8d9c71d8463c7f21dea164cd","tid":2498722,"uid":106290,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-04-21T10:58:16.000Z","msg":"Airtag有用啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"74d8aeb3ad82b532571c728b1c724d50faab9d0b","tid":2498722,"uid":369320,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-21T10:58:52.000Z","msg":"舊到同台灣隻F5一樣<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8acb1ac52b5e9fb3b68dc9b55bd720e491c38654","tid":2498722,"uid":303898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-21T11:00:11.000Z","msg":"潛水艇做秘密任務又話你知<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"34cbd8d4233ee2258ad567e513e5ef308b190ecd","tid":2498722,"uid":391580,"like":8,"dislike":0,"score":8,"citedBy":3,"replyTime":"2021-04-21T11:00:59.000Z","msg":"潛艇都超載<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n印尼海軍4月21日表示，一艘載有53人的潛艇在峇里（Bali）海域參加訓練後失去聯絡，軍方已經向鄰國澳洲和新加坡求助。<br />\n<br />\n海軍發言人表示，涉事的潛艇為「南伽拉」號（KRI Nanggala, 402），在1981於於德國建造，航行速度達每小時21.5海哩。<br />\n<br />\n「南伽拉」號事發前在峇里北部海域參與魚雷演習，當地傳媒報道，「南伽拉」號可能在距離峇里大約96公里的水域失去聯絡。路透社報道，<span class=\"x-large\"><span class=\"red\">該艘潛艇最多可載34人，但事發時則載有53人。</span></span>"},{"pid":"852950bf6223d67d7b142b16d5f3bab522112c6f","tid":2498722,"uid":358542,"like":1,"dislike":0,"score":1,"quote":{"pid":"34cbd8d4233ee2258ad567e513e5ef308b190ecd","tid":2498722,"uid":391580,"like":8,"dislike":0,"score":8,"citedBy":3,"replyTime":"2021-04-21T11:00:59.000Z","msg":"潛艇都超載<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n印尼海軍4月21日表示，一艘載有53人的潛艇在峇里（Bali）海域參加訓練後失去聯絡，軍方已經向鄰國澳洲和新加坡求助。<br />\n<br />\n海軍發言人表示，涉事的潛艇為「南伽拉」號（KRI Nanggala, 402），在1981於於德國建造，航行速度達每小時21.5海哩。<br />\n<br />\n「南伽拉」號事發前在峇里北部海域參與魚雷演習，當地傳媒報道，「南伽拉」號可能在距離峇里大約96公里的水域失去聯絡。路透社報道，<span class=\"x-large\"><span class=\"red\">該艘潛艇最多可載34人，但事發時則載有53人。</span></span>"},"citedBy":1,"replyTime":"2021-04-21T11:02:08.000Z","msg":"印尼學咗印度？"},{"pid":"d9f35d7f8a85d6e6388a49247b4e169452da8c9b","tid":2498722,"uid":391580,"like":0,"dislike":0,"score":0,"quote":{"pid":"34cbd8d4233ee2258ad567e513e5ef308b190ecd","tid":2498722,"uid":391580,"like":8,"dislike":0,"score":8,"citedBy":3,"replyTime":"2021-04-21T11:00:59.000Z","msg":"潛艇都超載<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=