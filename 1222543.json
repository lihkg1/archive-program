g":"港豬太睇少習大大稱霸世界嘅決心<img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" />"},{"pid":"efec673ff77f3532bf297bfd5b267a7cb8b766ce","tid":1222543,"uid":183758,"like":0,"dislike":0,"score":0,"quote":{"pid":"c7654a897e4d2a0f0f5bdcb2ac34e68b35228286","tid":1222543,"uid":51665,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-14T13:20:25.000Z","msg":"港豬太睇少習大大稱霸世界嘅決心<img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-14T13:21:16.000Z","msg":"小學雞真係小學雞<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"47b204dc9a9e29b02125c8c606eae6b4c37e3bcb","tid":1222543,"uid":182061,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T16:22:17.000Z","msg":"裝甲車行條橋冧咗點算"},{"pid":"52f8f955c096bc42eb24ed56fc6237a0bb4db06f","tid":1222543,"uid":10672,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T16:24:51.000Z","msg":"點算"}]}