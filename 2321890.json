pid":"81b0f4aa0acf5c73260b08a7a08e58ff7c44fbb3","tid":2321890,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-12T03:31:36.000Z","msg":"<img src=\"/assets/faces/dog/treat.gif\" class=\"hkgmoji\" />"},{"pid":"e8e1765ecab8eee793e9ee77d39a11790f682f45","tid":2321890,"uid":156130,"like":1,"dislike":0,"score":1,"quote":{"pid":"9a0b5858bf94e38a06b5bdae3e17c53d26dded1f","tid":2321890,"uid":80834,"like":145,"dislike":0,"score":145,"citedBy":5,"replyTime":"2020-12-12T01:30:44.000Z","msg":"中國疫苗一到港即場拆即場打<br />\n叫埋大公文滙live"},"citedBy":0,"replyTime":"2020-12-12T03:34:09.000Z","msg":"即場拆...........疫苗<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"d13b89a8439a42ce693988385397633d88800aee","tid":2321890,"uid":27432,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-12T03:34:13.000Z","msg":"3萬個警察咁辛苦<br />\n應該比佢地打先"},{"pid":"b90de3d7745d2f39425fc32a4bceb689dc8d0fb3","tid":2321890,"uid":156130,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-12T03:35:46.000Z","msg":"咪同鉛水事件一樣囉<br />\n死都話d水冇問題<br />\n但記者叫高官試飲就話不了<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><br />\n話侮辱官員"},{"pid":"0c3f4139db5af254cd48961f4183cc7ab7ebb639","tid":2321890,"uid":302423,"like":0,"dislike":0,"score":0,"quote":{"pid":"d73729198c13cec533205cee5af55cda24e51eb3","tid":2321890,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-12-12T01:28:55.000Z","msg":"本月22日起由海外返港人士必須入住指定的36間檢疫酒店，有報道指，部分指定酒店坐地起價，食物及衞生局局長陳肇始說，逾8成指定酒店房價在1000元以下，相信價格具競爭力。<br />\n<br />\n陳肇始在本台節目《星期六問責》表示，如果返港人士覺得預訂的房價不合理，可以有其他選擇，目前指定酒店房價「有平有貴」，相信具競爭力。被問到指定檢疫酒店計劃是否太遲推出，陳肇始解釋，這只是各項外防輸入的措施之一，落實安排前要與航空公司及酒店業界商討，酒店業在疫情初期對病毒亦不太認識，未必願意接收相關人士，她說今次安排是不容易傾來，隨著外地疫情大流行越來越嚴峻，相信指定酒店需求會越來越高，政府會加強相關措施。<br />\n<br />\n另外，首批新冠肺炎疫苗下月到港，被問到政府官員會否帶頭接種令市民安心，陳肇始表示，如可讓市民有信心，帶頭打針絕對沒有問題，但不用列為優先接種群組。<br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1564925-20201212.htm?spTabChangeable=0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1564925-20201212.htm%3FspTabChangeable%3D0&d=gjdgNhcllSDI%2FgTZdT0hmlgnvSLZGSqUYyTYHJNLWIM%3D&h=0b26f715\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1564925-20201212.htm%3FspTabChangeable%3D0&h=eff0e21e\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1564925-20201212.htm?spTabChangeable=0</a><br />\n<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-12T03:37:53.000Z","msg":"等睇暴斃live"},{"pid":"3c7ff02b69a3e29a142cfc6eefa3af6fa0d9356f","tid":2321890,"uid":292544,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-12T03:48:53.000Z","msg":"佢好驚"},{"pid":"73fd86a1c05ddcf3da4829172a28cfbeaa6f9eb7","tid":2321890,"uid":209126,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-12T03:51:25.000Z","msg":"佢請乜嘢<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"f96597d5b161057e3ee666025312ec4fd03daec3","tid":2321890,"uid":364767,"like":1,"dislike":0,"score":1,"quote":{"pid":"e2ec26db39eb1282015e903a5f93a1dc4029e9e0","tid":2321890,"uid":99733,"like":4,"dislike":0,"score":4,"quote":{"pid":"9a0b5858bf94e38a06b5bdae3e17c53d26dded1f","tid":2321890,"uid":80834,"like":145,"dislike":0,"score":145,"citedBy":5,"replyTime":"2020-12-12T01:30:44.000Z","msg":"中國疫苗一到港即場拆即場打<br />\n叫埋大公文滙live"},"citedBy":1,"replyTime":"2020-12-12T02:32:59.000Z","msg":"係叫埋太公文滙一齊打"},"citedBy":0,"replyTime":"2020-12-12T03:56:48.000Z","msg":"記得叫埋 \u001a\u001a\u001a689，老董，阿鼎，愛屍，大口珠，何妖，落惠零......"},{"pid":"5686fe24a25d85d923001af7d175478ce222d56e","tid":2321890,"uid":227699,"like":1,"dislike":0,"score":1,"quote":{"pi