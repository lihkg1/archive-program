bnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2FIMG_5262_yY83U_lAYPs_1200x0.png&h=b1f14814&s={SIZE}\" /><br />\n97民煮回歸開心事黎<br />\n有驚過<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"31bb3635b4164adac4c86b8b3243c06459d7f0a8","tid":2030972,"uid":158806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-24T05:13:53.000Z","msg":"97前十幾年有幾十萬人移民"},{"pid":"96e38e307e8041539b69245a4959c9652bc418a3","tid":2030972,"uid":304769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-24T05:33:29.000Z","msg":"驚西咩<br />\n沉著應戰啦<br />\n<br />\n<span style=\"font-size: x-large;\">借個位，連登黑色五毛風向警告</span><br />\n正視聽，<span style=\"color: red;\">國安法唔係攬炒，美國做野先係</span><br />\n<br />\n大家<span style=\"color: red;\">唔好比五毛帶風向去支持國安法，否則會比對家spin成香港人支持國安法</span>。只有<span style=\"color: red;\">香港人強烈反對下通過，美國才有做野的理由</span>。大家小心。<br />\n<br />\n借個位<br />\n連登一向錯曬風向，<span style=\"color: red;\">英國點日落都好，香港問題上都係重要持分者</span>，必須engage。<br />\n我地唔係要拉攏政府班奶共狗（例如Dominic Rabb），而係要<span style=\"color: red;\">拉攏英國民意</span>啊。英國係民主國家，民意最重要。英國民意決定stand with Hong Kong/Boycott China，BJ以至成個政府都無得唔跟。<span style=\"color: red;\">宜家武肺英國死左就三萬幾人，正是推動報仇民意好機會</span>。<br />\n<br />\n另外要借助美國向英國施壓，因為<span style=\"color: red;\">美國有動機（報武肺之仇）同拳頭，加英國有理由（聯合聲明），兩個加埋先容易嚮香港問題做野</span><br />\n<br />\n再借個位<br />\n唔想香港淪為支那賤畜之境，大家必須肅清中資，整頓&ldquo;港漂&rdquo;<br />\n<a href=\"https://lih.kg/1902243\" data-auto-link target=\"_blank\">https://lih.kg/1902243</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n最後想請大家簽一簽以下聯署<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://www.change.org/p/uk-govt-uk-govt-introduce-alistair-carmichael-s-private-members-bill-on-hong-kong\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.change.org%2Fp%2Fuk-govt-uk-govt-introduce-alistair-carmichael-s-private-members-bill-on-hong-kong&d=Ii3GHnPqKzd0SLaHQS96CMtxnk%2BhbBpP3j1S%2FgfPRD4%3D&h=12a6025f\" data-auto-link target=\"_blank\">https://www.change.org/p/uk-govt-uk-govt-introduce-alistair-carmichael-s-private-members-bill-on-hong-kong</a>"},{"pid":"c673991e198f05acb87312a4d1ee8cf9f7f05924","tid":2030972,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-25T07:36:27.000Z","msg":"lm"}]}