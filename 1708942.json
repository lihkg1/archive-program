faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-11T18:35:42.000Z","msg":"<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"11105f621b328e710d359afcfbd6caa3519e2ff2","tid":1708942,"uid":170297,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-11-11T18:37:22.000Z","msg":"唉"},{"pid":"5e5c74f81e70fe18cc64f65fe8df70792ea9840a","tid":1708942,"uid":26333,"like":0,"dislike":0,"score":0,"quote":{"pid":"34086dd9c135840746911002f6a4b9f6dfa97e4d","tid":1708942,"uid":128117,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-11-11T18:25:41.000Z","msg":"<blockquote>甚至向親政府支持者發射催淚彈驅趕民眾。</blockquote><br />\n<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-11T18:57:29.000Z","msg":"<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"420b0009a1016e75e6be0554db766c2fdf157bce","tid":1708942,"uid":126782,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-11-11T19:09:11.000Z","msg":"//軍方至今未忘記2003年社會騷亂時，當局派兵鎮壓反而激化衝突，導致平民死傷，有軍人被控違反人權及被起訴。//<br />\n<br />\n其實係軍人做過一次condom後就發現幫政府無用<br />\n<br />\n而家鎮壓左 之後都會倒台 換人上台<br />\n<br />\n幫手鎮壓嘅人終究要變condom先可以徹底完左件事<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n可惜我們的毅進仔讀得書少 看不透走狗烹的道理<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c3f5572c12ab099a6e605d7b6650c9