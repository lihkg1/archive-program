x8jbkw2p\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fx8jbkw2p&h=bfe8b16c&s={SIZE}\" /><br />\n<img src=\"https://holland.pk/pifd7jo8\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fpifd7jo8&h=b6b8aee2&s={SIZE}\" /><br />\n<br />\n希望各位fans可以多D係度為Boanne打氣，祝福呢位TVB女新星仕途順利<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"009e61cfd6f3ebf32c60555243c2ee3ae9599bd2","tid":495954,"uid":57835,"like":18,"dislike":1,"score":17,"citedBy":0,"replyTime":"2017-12-11T08:33:57.000Z","msg":"唔靚喎"},{"pid":"6d19f95e37f6efe3fd1b2ee28d24f0b16d85bfb3","tid":495954,"uid":154756,"like":2,"dislike":4,"score":-2,"citedBy":0,"replyTime":"2017-12-11T08:35:08.000Z","msg":"正過家姐<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"27ca8617dcce3694f229c7aec7c2d22191bb9f91","tid":495954,"uid":108894,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-12-11T08:37:03.000Z","msg":"<blockquote>唔靚喎</blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bd49052e75b28ff442576336a5746735e8e12a87","tid":495954,"uid":108894,"like":1,"dislike":3,"score":-2,"citedBy":0,"replyTime":"2017-12-11T08:37:30.000Z","msg":"<blockquote>正過家姐<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /></blockquote><br />\nyes<br />\n比家姐sweet好多<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"be39d5c716d97a936cd8ededdcac55745d543596","tid":495954,"uid":92376,"like":17,"dislike":1,"score":16,"citedBy":0,"replyTime":"2017-12-11T10:54:22.000Z","msg":"寶欣佳績全面睇<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\nBBC最受歡迎香港小姐數據分析<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/09/04/024412_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F09%2F04%2F024412_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=257bb87e&s={SIZE}\" /><br />\n根據mytv個時間 17:42個陣10號個累積數量係704990<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/09/04/024504_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F09%2F04%2F024504_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=deb3a36e&s={SIZE}\" /><br />\n19:13個陣10號個累積數量係757943<br />\n<br />\n總時間長度=19:13-17:42=91秒<br />\n數量增長=757943-704990=52953<br />\n增長速率=52953/91=582/秒<br />\n<br />\n根據賽前BBC記錄 10號同9號有明顯差距<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/09/04/024922_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F09%2F04%2F024922_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=c861a540&s={SIZE}\" /><br />\n<br />\n10號同9號差距=1768205-698644=1069561<br />\n<br />\n假設10號一直保持同一個速率去追<br />\n假設9號當晚完全冇增長<br />\n<span style=\"color: red;\">10號超越9號所需時間=1069561/582=1838秒=31分鐘</span><br />\n<br />\n成個環節頭尾應該冇30分鐘 仲要未計9號當晚個增長 <br />\n完全睇唔到10號會贏個可能性<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n----------------------<br />\n<strong>蘋果日報--【唔公平?】超專業分析 網友 : 最受歡迎港姐無可能係張寶欣</strong><br />\n<a href=\"https://is.gd/bBrel3\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fis.gd%2FbBrel3&d=OZLboJ8a3aGlrRIfUsiPBP%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=375b0765\" target=\"_blank\">https://is.gd/bBrel3</a><br />\n<br />\n今年香港小姐競選決賽不斷Hard Sell大台直播App，就連友誼小姐一獎都改做「big big channel最受歡迎香港小姐」。此獎項以直播App上網友給的心心作標準，稱以最高心心數量的佳麗奪得，最後獎項由10號張寶欣獲得。先不論有大量網友投訴直播App在比賽其間完全不能開啟，既然這麼多人未能連線，那心心從哪裡來可說是個迷。賽前被網友極力支持的9號金美黎，不但三甲不入，就連「BBC最受歡迎港姐」都拿不到令他們心心不忿。有網友製作圖表加上超專業的數據分析指出獎項根本不應由10號張寶欣獲得，獲獎的該是9號金美黎，指比賽有不公之嫌。 <br />\n<br />\n延伸閱讀: <strong>香港01【港姐2017】張寶欣Big Big Channel心心疑造假　金美黎輸得唔抵</strong><br />\n<a href=\"http://www.hk01.com/娛樂/116762/-港姐2017-張寶欣Big-Big-Channel心心疑造假-金美黎輸得唔抵\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.hk01.com%2F%E5%A8%9B%E6%A8%82%2F116762%2F-%E6%B8%AF%E5%A7%902017-%E5%BC%B5%E5%AF%B6%E6%AC%A3Big-Big-Channel%E5%BF%83%E5%BF%83%E7%96%91%E9%80%A0%E5%81%87-%E9%87%91%E7%BE%8E%E9%BB%8E%E8%BC%B8%E5%BE%97%E5%94%94%E6%8A%B5&d=OZLboJ8a3aGlrRIfUsiPBP%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=9b29cc85\" target=\"_blank\">http://www.hk01.com/娛樂/116762/-港姐2017-張寶欣Big-Big-Channel心心疑造假-金美黎輸得唔抵</a><br />\n<br />\n同場加映: TVB高層余詠珊最權威回應<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<strong>有網民質疑網上投票「最受歡迎香港小姐」，賽前是⑨金美黎累積最多心心，但最後是⑩張寶欣奪獎？余詠珊稱張寶欣賽前累積加臨場獲200多萬心心，<span style=\"font-size: x-large;\">絕對不能造假</span>。</strong>"},{"pid":"b3367e2615b8c805faccac3475e766532b89ca53","tid":495954,"uid":139396,"like":4,"dislike":2,"score":2,"citedBy":0,"replyTime":"2017-12-11T11:21:10.000Z","msg":"張寶兒正好多"},{"pid":"ee34418674b4fe6ef880d2966c10f7ec15ec93e2","tid":495954,"uid":108894,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2017-12-11T11:31:15.000Z","msg":"<blockquote>張寶兒正好多</blockquote><br />\n論academic achievement肯定係<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"08bbf36444a1afc1847ea32a8472a9b80d820091","tid":495954,"uid":108894,"like":0,"dislike":6,"score":-6,"citedBy":0,"replyTime":"2017-12-11T11:32:42.000Z","msg":"<blockquote>寶欣佳績全面睇<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\nBBC最受歡迎香港小姐數據分析<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/09/04/024412_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F09%2F04%2F024412_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=257bb87e&s={SIZE}\" /><br />\n根據mytv個時間 17:42個陣10號個累積數量係704990<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/09/04/024504_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F09%2F04%2F024504_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=deb3a36e&s={SIZE}\" /><br />\n19:13個陣10號個累積數量係757943<br />\n<br />\n總時間長度=19:13-17:42=91秒<br />\n數量增長=757943-704990=52953<br />\n增長速率=52953/91=582/秒<br />\n<br />\n根據賽前BBC記錄 10號同9號有明顯差距<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/09/04/024922_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F09%2F04%2F024922_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=c861a540&s={SIZE}\" /><br />\n<br />\n10號同9號差距=1768205-698644=1069561<br />\n<br />\n假設10號一直保持同一個速率去追<br />\n假設9號當晚完全冇增長<br />\n<span style=\"color: red;\">10號超越9號所需時間=1069561/582=1838秒=31分鐘</span><br />\n<br />\n成個環節頭尾應該冇30分鐘 仲要未計9號當晚個增長 <br />\n完全睇唔到10號會贏個可能性<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n----------------------<br />\n<strong>蘋果日報--【唔公平?】超專業分析 網友 : 最受歡迎港姐無可能係張寶欣</strong><br />\n<a href=\"https://is.gd/bBrel3\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fis.gd%2FbBrel3&d=OZLboJ8a3aGlrRIfUsiPBP%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=375b0765\" target=\"_blank\">https://is.gd/bBrel3</a><br />\n<br />\n今年香港小姐競選決賽不斷Hard Sell大台直播App，就連友誼小姐一獎都改做「big big channel最受歡迎香港小姐」。此獎項以直播App上網友給的心心作標準，稱以最高心心數量的佳麗奪得，最後獎項由10號張寶欣獲得。先不論有大量網友投訴直播App在比賽其間完全不能開啟，既然這麼多人未能連線，那心心從哪裡來可說是個迷。賽前被網友極力支持的9號金美黎，不但三甲不入，就連「BBC最受歡迎港姐」都拿不到令他們心心不忿。有網友製作圖表加上超專業的數據分析指出獎項根本不應由10號張寶欣獲得，獲獎的該是9號金美黎，指比賽有不公之嫌。 <br />\n<br />\n延伸閱讀: <strong>香港01【港姐2017】張寶欣Big Big Channel心心疑造假　金美黎輸得唔抵</strong><br />\n<a href=\"http://www.hk01.com/娛樂/116762/-港姐2017-張寶欣Big-Big-Channel心心疑造假-金美黎輸得唔抵\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.hk01.com%2F%E5%A8%9B%E6%A8%82%2F116762%2F-%E6%B8%AF%E5%A7%902017-%E5%BC%B5%E5%AF%B6%E6%AC%A3Big-Big-Channel%E5%BF%83%E5%BF%83%E7%96%91%E9%80%A0%E5%81%87-%E9%87%91%E7%BE%8E%E9%BB%8E%E8%BC%B8%E5%BE%97%E5%94%94%E6%8A%B5&d=OZLboJ8a3aGlrRIfUsiPBP%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=9b29cc85\" target=\"_blank\">http://www.hk01.com/娛樂/116762/-港姐2017-張寶欣Big-Big-Channel心心疑造假-金美黎輸得唔抵</a><br />\n<br />\n同場加映: TVB高層余詠珊最權威回應<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<strong>有網民質疑網上投票「最受歡迎香港小姐」，賽前是⑨金美黎累積最多心心，但最後是⑩張寶欣奪獎？余詠珊稱張寶欣賽前累積加臨場獲200多萬心心，<span style=\"font-size: x-large;\">絕對不能造假</span>。</strong></blockquote><br />\n召喚連尼住"},{"pid":"fc0ad2489b5b5a70c82fe7536c7554cc05a3a5eb","tid":495954,"uid":98386,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-11T12:39:42.000Z","msg":"一言堂<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"a87cc35b4d882c9d6640e07c912bd73ed8f82541","tid":495954,"uid":108894,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2017-12-11T12:51:49.000Z","msg":"<blockquote>一言堂<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n之前有個香港小姐tracking但係個樓豬同幾個活躍巴打都反張寶欣<br />\n一留言十卜即刻被人當五毛咁攻擊<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n為求和平我先決條定咁樣分開<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"25fbfb8baff5a84a40672830ed416a933ddcccd5","tid":495954,"uid":108894,"like":0,"dislike":5,"score":-5,"citedBy":0,"replyTime":"2017-12-11T12:55:19.000Z","msg":"係澳門嘅巴打你地可以見到Boanne <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://holland.pk/amnj0pl9\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Famnj0pl9&h=e68fa77f&s={SIZE}\" /><br />\n<img src=\"https://holland.pk/1o2fi4hc\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2F1o2fi4hc&h=2ab9a053&s={SIZE}\" /><br />\n<img src=\"https://holland.pk/6u2o1efh\" data-thumbnail-src=\"https://i.lih.kg/thumbnai