.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiJvKsH2.jpg&h=71254207&s={SIZE}\" />"},{"pid":"e70aa1999cc4ea1b0f132cf295a0dd8e74fbff22","tid":2160131,"uid":323228,"like":1,"dislike":0,"score":1,"quote":{"pid":"b5a8b10ee9446f7840448730b2a9267ad598ae1f","tid":2160131,"uid":253301,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7388a08b25c375c6bfe527a54f34373a246e5e2","tid":2160131,"uid":164163,"like":0,"dislike":0,"score":0,"quote":{"pid":"f07056912cc92a5a43a02245f976f27bd6739b6c","tid":2160131,"uid":253301,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-16T18:30:33.000Z","msg":"主要想識啲基本功 樂理同睇譜 <br />\n第時可以玩下咁<br />\n想問下有冇話邊到學好定係搵私人<br />\nThx<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-16T23:35:04.000Z","msg":"其實自學都ok<br />\n<br />\n利申:自學咗5個月 已經識彈3首歌"},"citedBy":2,"replyTime":"2020-08-16T23:36:42.000Z","msg":"有諗過自學<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />但除左細個個陣學過幾堂就冇再接觸過 驚好難入手"},"citedBy":0,"replyTime":"2020-08-17T14:51:58.000Z","msg":"其實有的初步野係可以自學，但係老師既作用係矯正你手勢。所以一係唔搵，一搵老師就要搵個年紀大少少經驗好少少，琴行果的唔得，唔會執你手勢。<br />\n<br />\n我開頭係自學既，彈得到歌，但係呢隻手型唔合格，彈既時候手型係塔左落黎，跟住搵左個年紀大既老師教我，佢教左我一的好基本既手力練習，要我日日練同要我練scale，跟住就有好大進步。手型係可以包住隻雞蛋，唔再塔落黎，之前自己點試都唔係好得。<br />\n<br />\n所以睇你要求的咩。"},{"pid":"76e915ec63dd4215ccd36e7340e08a8197a63665","tid":2160131,"uid":255175,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-22T20:42:26.000Z","msg":"<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"eb76491f84848bd91c0191de249df5a62ee9e8ed","tid":2160131,"uid":135040,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-26T06:40:19.000Z","msg":"推<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><br />\n想學，不過同自己講過要做野先准學"},{"pid":"8559a853d54309f79290784aeec14cdadf639107","tid":2160131,"uid":133051,"like":0,"dislike":0,"score":0,"quot