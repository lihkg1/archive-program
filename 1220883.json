220883,"uid":146864,"like":0,"dislike":0,"score":0,"quote":{"pid":"bd5773c3d224968122fbd414d0da1cf9ff27c97f","tid":1220883,"uid":237753,"like":14,"dislike":0,"score":14,"citedBy":1,"replyTime":"2019-06-14T07:56:17.000Z","msg":"有 生理鹽水/清水一定幫到手<br />\n中胡椒 千奇不好就咁用水沖 先找紙巾/緊急就毛巾印走，再用生理鹽水沖水，再用水。<br />\n不是就會好拿。<br />\n入眼的記緊打側頭沖洗，小心不好沖入另一隻眼<br />\n<br />\n水 見到催淚 可以用水淋濕毛巾掩鼻 沒毛巾就用水淋佢地件衫<br />\n果日太多人沒毛巾 都是淋佢地衫 必要時拿高都減低少少傷害"},"citedBy":1,"replyTime":"2019-06-14T07:57:52.000Z","msg":"我個日叫人開著眼俾我淋其實啱唔啱？<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-14T07:58:20.000Z","msg":"利申發夢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-14T14:14:49.000Z","msg":"我都是夢到架咋 不過見個夢咁真 咪分享下咋<br />\n有個外國記者教我地緊急時都可用水沖 先印走是避免將更多細菌推入眼"},{"pid":"d30e07048062324e2ba770332a0bfdc1c14fc86a","tid":1220883,"uid":237753,"like":12,"dislike":0,"score":12,"citedBy":0,"replyTime":"2019-06-14T14:18:34.000Z","msg":"要多謝的是一班前線 佢地保護埋我地first Aid <br />\n係危急情況下除安全帽俾我地<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"df19327964215da2292744f06242050366659cb7","tid":1220883,"uid":161990,"like":17,"dislike":0,"score":17,"citedBy":1,"replyTime":"2019-06-14T14:18:50.000Z","msg":"唔洗同班狗講法律 佢地只係<span style=\"font-size: xx-large;\">毅進仔</span><br />\n<br />\n入學堂前只係周圍都可以見到既<span style=\"font-size: xx-large;\">MK爛仔</span>"},{"pid":"d75fa7924dfa4fab87376338a6f1fbf9aaea04ef","tid":1220883,"uid":161990,"like":8,"dislike":0,"score":8,"quote":{"pid":"df19327964215da2292744f06242050366659cb7","tid":1220883,"uid":161990,"like":17,"dislike":0,"score":17,"citedBy":1,"replyTime":"2019-06-14T14:18:50.000Z","msg":"唔洗同班狗講法律 佢地只係<span style=\"font-size: xx-large;\">毅進仔</span><br />\n<br />\n入學堂前只係周圍都可以見到既<span style=\"font-size: xx-large;\">MK爛仔</span>"},"citedBy":0,"replyTime":"2019-06-14T14:20:15.000Z","msg":"<span style=\"font-size: xx-large;\">警員手冊都唔知背唔背得出</span> <br />\n<span style=\"font-size: xx-large;\">仲話基本法？日內瓦公約？</span>"},{"pid":"ab2dfc9eef79d726f6be22aa4003acec697a483a","tid":1220883,"uid":83934,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-14T14:21:25.000Z","msg":"唔好意思 阻阻大家 入面已經有巴打整咗兩條片 大家幫幫手推po同埋like條片等條片上到熱門 最好留埋言 但保持隊形<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /> 比多啲人睇到 同埋有巴絲有時間又識整嘅幫幫手 我地要分享比我地嘅長輩 佢地最鍾意睇呢啲唔洗用腦嘅片 又入晒佢地腦<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n除咗長輩圖 youtube係其中一個方法<br />\n<a href=\"https://lih.kg/1221927\" target=\"_blank\">https://lih.kg/1221927</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"5a7167e4d50f68e5bacbad4136e869957a7e6d69","tid":1220883,"uid":47565,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T14:39:46.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"430cabb93a05cd15c804c8f68d7499f4e36296a2","tid":1220883,"uid":160537,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-14T14:45:15.000Z","msg":"感謝你！<br />\n你已經做得好好！<br />\n當時情況好混亂 <br />\n但我哋係非常團結！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"1b7e8a1028106f0c31202545265438e0f386ddf0","tid":1220883,"uid":7081,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T14:45:31.000Z","msg":"大家要加油"},{"pid":"e1ca6e4158e71f3a9f7ba65aec20ec96087248a5","tid":1220883,"uid":60764,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-06-14T20:06:19.000Z","msg":"此回覆已被刪除"},{"pid":"ea47ca1ec4de8f234d03cd459d6b1a3bd89aa4b6","tid":1220883,"uid":237753,"like":2,"dislike":0,"score":2,"quote":{"pid":"e1ca6e4158e71f3a9f7ba65aec20ec96087248a5","tid":1220883,"uid":60764,"like":3,"dislike":0,"score":3,"quote":{"pid":"0e7ddcbe789ced1662ba34029b0061a856fc23e2","tid":1220883,"uid":237753,"like":2,"dislike":0,"score":2,"quote":{"pid":"af0b17dd29f7e7e546c22e1c18467daabedab076","tid":1220883,"uid":60764,"like":24,"dislike":0,"score":24,"citedBy":3,"replyTime":"2019-06-14T08:00:46.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-06-14T14:11:27.000Z","msg":"係呢到<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 負責呢邊個first aid 話咩物資都拎不返"},"citedBy":1,"replyTime":"2019-06-14T20:06:19.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-06-15T00:10:48.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />多謝你呀 巴打"},{"pid":"b1d615bcfb4ee927dbec7bc8e54b95452d832419","tid":1220883,"uid":155180,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-15T00:24:37.000Z","msg":"<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"},{"pid":"98edba0ce7b7c56b92046317f7a3408c589a8b5e","tid":1220883,"uid":77740,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T00:50:11.000Z","msg":"多謝你<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"1da315b53058d50327f905c6b1ef4cafffa038c5","tid":1220883,"uid":95097,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T01:17:44.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"2784ee01e3350df53b478c92b58a0482154be400","tid":1220883,"uid":237753,"like":0,"dislike":0,"score":0,"quote":{"pid":"b1d615bcfb4ee927dbec7bc8e54b95452d832419","tid":1220883,"uid":155180,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-15T00:24:37.000Z","msg":"<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-15T01:21:38.000Z","msg":"呢個夢好真<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />  希望不好再發呢d夢 多謝你"},{"pid":"132d5dd99b52d104c397244a37d6f18b5abe8c05","tid":1220883,"uid":143499,"like":0,"dislike":0,"score":0,"quote":{"pid":"e46624550928abf065fcf1b3c6e51908a76f50c9","tid":1220883,"uid":237753,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-14T05:44:13.000Z","msg":"考慮左好耐，決定要寫出來。因為我真是好痛<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 直到今日都喊到訓不到。<br />\n<br />\n小妹是自發去急救的，不關任何政黨/機構。不想有人命傷亡。特別是學生。<br />\n第一個接到的就是中橡膠彈<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n12.6 在準備物資中突然爆催淚彈，慌亂中，有個男仔俾幾個人放低，佢一見到我，同我講中槍。佢就是中橡膠彈那個男仔。<br />\n我當下清晰知道手上的物資是絕對不足以應付中槍的處理。<br />\n只可以做基本急救，清洗傷口，施壓。<br />\n我一睇個傷口，血是一層層咁滲出來，好似印仔咁，一個圈，清理完上紗布施壓時，血又滲出來。<br />\n未處理完，後面又放第2個催淚。只可以喊同佢講： 你一定要禁住禁實個傷口，call 白車。<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n然後就要退。<br />\n<br />\n慌忙中我盡晒力去拉身邊的學生走，個個中<br />\n到應，行不到跪係地下。睇住前排救不到的就俾差佬打。<br />\n仆街，係一棍棍咁打。<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n拖到幾多個就幾多個。身邊班男仔好團結，一個扯住一個。係幾個催淚連續爆緊，都堅持：慢慢退 不好人踩人 不好亂 等傷者行先。<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n下午有人見我地First Aid, 塞個頭盔俾我，上面貼實2張貼紙：急救人員。又叫我地帶眼罩。叫我地抖下。女仔小心d/有咩事退左先呀，<br />\n不好勉強/<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><br />\n<br />\n最大獲是3點幾果段，在立會到退到上草地。<br />\n係半個鐘入面食左4-5粒，狂扔的催淚彈<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我睇住一大班人喊晒，那到塊面紅腫，對眼睇不到。一停就俾差佬扯去打。<br />\n你知不知是好痛，當你聞到陣酸味，已經入左肺，以為沒咩，下一秒一呼吸就燒緊個肺。我完全明係好能痛，果班是學生。<br />\n<br />\n要受要衝就算俾差佬打都應該是大人頂，果班是學生。而且人群開始退。根本沒必要連續放4個。🔥<br />\n<br />\n退到海富天橋，見到另外first Aid , 喊晒口：佢地祚左個First Aid,果個過的物資沒晒。<br />\n<br />\nFirst Aid 已經不多，係咪痴x 9左線。<br />\n<br />\n我真是在一個戰場入面。<br />\n<br />\n我地喊住咁係地下執物資，驚不夠用。一個女仔塞爆晒書包，拎住一大袋重的，手持生理鹽水/清水<br />\n背得重又驚走不快，拉扯不切班學生，背得少又驚不夠物資。<br />\n<br />\n都未執完，海富下面就又爆幾粒，係突然一大堆人狂喊好痛。企係人海入面，手上得2枝，根本不夠用。只可以選最嚴重的處理左先。<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />果種感覺是好恐怖，要選俾邊個沖洗先。😰<br />\n班男仔是扯我走，你地女仔退呀，走呀。我地後面頂住。<br />\n不識架，真是不知佢邊個，但可以為個陌生人頂催淚同俾差佬打呀。<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />果日有好多義士，好人。<br />\n<br />\n<br />\n我都堅持留多一陣，因為真是不夠First Aid。但，我勸班學生走。你地做左你地能力以內的野，姐姐都同你地一齊受催淚彈，知道你地承受不起更多。<br />\n果班學生中3/4到，係咁同我講對不住。佢地沒一齊留。<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n佢地做錯咩<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n今日，你地竟然定義為暴動，仲叫有參與的人執自首。<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n日內瓦公約是清楚列明醫務人員，人道救援是受保障。<br />\n你地係咪食左屎個腦？<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n我好嬲，好氣憤，更多的是驚，果種一幕幕俾人打，扯人走，中槍，全部人係我身邊圍住都是慘叫緊好痛。眼/面傷晒。<br />\n我不敢講，驚害到人，屋企人不知，不知點表達到呢種情緒，個心好重好痛。<br />\n<br />\n有沒人影到First Aid 站被炸的相/片？不可以咁樣當無件事。人道救援來架。<br />\n<br />\n<br />\n我沒辦法當不記得，因為我確確實實咁經歷左。<br />\n希望有巴絲有人影到First Aid 站被炸的相/片<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-15T01:31:26.000Z","msg":"屌你發夢就講清楚啲啦"},{"pid":"f3ed850f465643251963de4d9d58e2d881bbb124","tid":1220883,"uid":43553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T01:35:01.000Z","msg":"Push"},{"pid":"751039039803cda1659ebad2b81d9368191149fb","tid":1220883,"uid":140570,"like":0,"dislike":0,"score":0,"quote":{"pid":"af0b17dd29f7e7e546c22e1c18467daabedab076","tid":1220883,"uid":60764,"like":24,"dislike":0,"score":24,"citedBy":3,"replyTime":"2019-06-14T08:00:46.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-06-15T01:48:10.000Z","msg":"鄭松泰收集緊依單野資料，準備交比國際組織<br />\n有更多資料就dm佢啦"},{"pid":"ab76afcf6e91a0579e4db53b65bf64641c65ba6b","tid":1220883,"uid":37220,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T02:33:40.000Z","msg":"MEDIC!"},{"pid":"84ccf90d23361c19ecbee5fbe167a145762713df","tid":1220883,"uid":56063,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T05:00:36.000Z","msg":"下次發夢戴go pro<br />\n一有咩就影晒落嚟"},{"pid":"fc07936dc7fff3db0c00a96ada2032c5de4f1e6f","tid":1220883,"uid":192754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T05:06:10.000Z","msg":"多謝你<br />\n黑警死全家<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"bc8d64e561de3649b92e06cd1de5a09389952782","tid":1220883,"uid":237753,"like":0,"dislike":0,"score":0,"quote":{"pid":"132d5dd99b52d104c397244a37d6f18b5abe8c05","tid":1220883,"uid":143499,"like":0,"dislike":0,"score":0,"quote":{"pid":"e46624550928abf065fcf1b3c6e51908a76f50c9","tid":1220883,"uid":237753,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-14T05:44:13.000Z","msg":"考慮左好耐，決定要寫出來。因為我真是好痛<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 直到今日都喊到訓不到。<br />\n<br />\n小妹是自發去急救的，不關任何政黨/機構。不想有人命傷亡。特別是學生。<br />\n第一個接到的就是中橡膠彈<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n12.6 在準備物資中突然爆催淚彈，慌亂中，有個男仔俾幾個人放低，佢一見到我，同我講中槍。佢就是中橡膠彈那個男仔。<br />\n我當下清晰知道手上的物資是絕對不足以應付中槍的處理。<br />\n只可以做基本急救，清洗傷口，施壓。<br />\n我一睇個傷口，血是一層層咁滲出來，好似印仔咁，一個圈，清理完上紗布施壓時，血又滲出來。<br />\n未處理完，後面又放第2個催淚。只可以喊同佢講： 你一定要禁住禁實個傷口，call 白車。<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n然後就要退。<br />\n<br />\n慌忙中我盡晒力去拉身邊的學生走，個個中<br />\n到應，行不到跪係地下。睇住前排救不到的就俾差佬打。<br />\n仆街，係一棍棍咁打。<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n拖到幾多個就幾多個。身邊班男仔好團結，一個扯住一個。係幾個催淚連續爆緊，都堅持：慢慢退 不好人踩人 不好亂 等傷者行先。<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n下午有人見我地First Aid, 塞個頭盔俾我，上面貼實2張貼紙：急救人員。又叫我地帶眼罩。叫我地抖下。女仔小心d/有咩事退左先呀，<br />\n不好勉強/<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><br />\n<br />\n最大獲是3點幾果段，在立會到退到上草地。<br />\n係半個鐘入面食左4-5粒，狂扔的催淚彈<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我睇住一大班人喊晒，那到塊面紅腫，對眼睇不到。一停就俾差佬扯去打。<br />\n你知不知是好痛，當你聞到陣酸味，已經入左肺，以為沒咩，下一秒一呼吸就燒緊個肺。我完全明係好能痛，果班是學生。<br />\n<br />\n要受要衝就算俾差佬打都應該是大人頂，果班是學生。而且人群開始退。根本沒必要連續放4個。🔥<br />\n<br />\n退到海富天橋，見到另外first Aid , 喊晒口：佢地祚左個First Aid,果個過的物資沒晒。<br />\n<br />\nFirst Aid 已經不多，係咪痴x 9左線。<br />\n<br />\n我真是在一個戰場入面。<br />\n<br />\n我地喊住咁係地下執物資，驚不夠用。一個女仔塞爆晒書包，拎住一大袋重的，手持生理鹽水/清水<br />\n背得重又驚走不快，拉扯不切班學生，背得少又驚不夠物資。<br />\n<br />\n都未執完，海富下面就又爆幾粒，係突然一大堆人狂喊好痛。企係人海入面，手上得2枝，根本不夠用。只可以選最嚴重的處理左先。<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />果種感覺是好恐怖，要選俾邊個沖洗先。😰<br />\n班男仔是扯我走，你地女仔退呀，走呀。我地後面頂住。<br />\n不識架，真是不知佢邊個，但可以為個陌生人頂催淚同俾差佬打呀。<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />果日有好多義士，好人。<br />\n<br />\n<br />\n我都堅持留多一陣，因為真是不夠First Aid。但，我勸班學生走。你地做左你地能力以內的野，姐姐都同你地一齊受催淚彈，知道你地承受不起更多。<br />\n果班學生中3/4到，係咁同我講對不住。佢地沒一齊留。<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n佢地做錯咩<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n今日，你地竟然定義為暴動，仲叫有參與的人執自首。<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n日內瓦公約是清楚列明醫務人員，人道救援是受保障。<br />\n你地係咪食左屎個腦？<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n我好嬲，好氣憤，更多的是驚，果種一幕幕俾人打，扯人走，中槍，全部人係我身邊圍住都是慘叫緊好痛。眼/面傷晒。<br />\n我不敢講，驚害到人，屋企人不知，不知點表達到呢種情緒，個心好重好痛。<br />\n<br />\n有沒人影到First Aid 站被炸的相/片？不可以咁樣當無件事。人道救援來架。<br />\n<br />\n<br />\n我沒辦法當不記得，因為我確確實實咁經歷左。<br />\n希望有巴絲有人影到First Aid 站被炸的相/片<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-15T01:31:26.000Z","msg":"屌你發夢就講清楚啲啦"},"citedBy":0,"replyTime":"2019-06-15T18:46:22.000Z","msg":"呢個夢好真 真到驚<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"71402fba77b3cb54d1afcb085b89a0188409caf0","tid":1220883,"uid":253045,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T18:48:26.000Z","msg":"好想喊 多謝你"},{"pid":"9237bc1e2f96e367349dfa4c5702b79a27fa25d0","tid":1220883,"uid":245126,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-15T18:50:40.000Z","msg":"有急救證但冇實戰經驗 好想幫手"},{"pid":"bf83bb40fd6a66e719fc94a5f70b369c71536fe9","tid":1220883,"uid":237753,"like":0,"dislike":0,"score":0,"quote":{"pid":"9237bc1e2f96e367349dfa4c5702b79a27fa25d0","tid":1220883,"uid":245126,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-15T18:50:40.000Z","msg":"有急救證但冇實戰經驗 好想幫手"},"citedBy":0,"replyTime":"2019-06-15T18:53:26.000Z","msg":"多謝你 夢到果日都有幾個RN 自發來幫手 佢地都帶左急救用品<br />\n多一個人就多一個幫手 <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n有緣夢中見"},{"pid":"a05a944897508f8b86af717ba1fb8557e7088154","tid":1220883,"uid":195350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T18:53:53.000Z","msg":"推"},{"pid":"5f07e1175c7397bdeb8f2bc6c7eb8adce2af885b","tid":1220883,"uid":136987,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-06-15T18:56:32.000Z","msg":"睇到眼喊喊<br />\n個日無一齊留守到最尾<br />\n都無膽上前線<br />\n對唔住"},{"pid":"f426f733af2dfdd0b08cf99c5230dd4cb13711d2","tid":1220883,"uid":136987,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f07e1175c7397bdeb8f2bc6c7eb8adce2af885b","tid":1220883,"uid":136987,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-06-15T18:56:32.000Z","msg":"睇到眼喊喊<br />\n個日無一齊留守到最尾<br />\n都無膽上前線<br />\n對唔住"},"citedBy":0,"replyTime":"2019-06-15T18:56:57.000Z","msg":"字都打錯<br />\n係睇濕濕"},{"pid":"f6af7035bd9a5819e84bb66045336b9458953bee","tid":1220883,"uid":79325,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-15T18:59:15.000Z","msg":"First aid站被炸，我瀝瀝在目"},{"pid":"855660ccb0e726e9bdcfecbb725c8175ad088e1f","tid":1220883,"uid":237753,"like":1,"dislike":0,"score":1,"quote":{"pid":"5f07e1175c7397bdeb8f2bc6c7eb8adce2af885b","tid":1220883,"uid":136987,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-06-15T18:56:32.000Z","msg":"睇到眼喊喊<br />\n個日無一齊留守到最尾<br />\n都無膽上前線<br />\n對唔住"},"citedBy":0,"replyTime":"2019-06-15T19:04:23.000Z","msg":"千奇不好咁想 多謝你都係夢到行出來<br />\n自從發左呢個夢 到今日都係咁喊 訓又訓不到 <br />\n但係呢個夢入面 我夢到自己已經是下一代學生的牆<br />\n更加一定要頂住 <br />\n<br />\n訓得差成日都發夢 睇來聽日都會發 不知見不見到你<br />\n加油<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"e686c685f1f8a253698cee960b555a0a58a183e0","tid":1220883,"uid":138051,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T19:08:50.000Z","msg":"淨係得st John 急救 想去幫手"},{"pid":"959854f8242c27fdc064ac0594e76302f59221e6","tid":1220883,"uid":233367,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T19:09:45.000Z","msg":"多謝你<br />\n辛苦了"},{"pid":"7ff86a16fa7b877c178071401bf1db35769cb28c","tid":1220883,"uid":254456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T19:10:52.000Z","msg":"pish"},{"pid":"522945e4723ead36ae86b2e9393a09e048693bb7","tid":1220883,"uid":237753,"like":0,"dislike":0,"score":0,"quote":{"pid":"f6af7035bd9a5819e84bb66045336b9458953bee","tid":1220883,"uid":79325,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-15T18:59:15.000Z","msg":"First aid站被炸，我瀝瀝在目"},"citedBy":1,"replyTime":"2019-06-15T19:11:44.000Z","msg":"巴打見到？有沒片/相？ 感謝樓上有位巴打幫手推左出公海<br />\n<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"f959eeb5ccd34162e4b9aaa201ccba4db1cafc96","tid":1220883,"uid":79325,"like":0,"dislike":0,"score":0,"quote":{"pid":"522945e4723ead36ae86b2e9393a09e048693bb7","tid":1220883,"uid":237753,"like":0,"dislike":0,"score":0,"quote":{"pid":"f6af7035bd9a5819e84bb66045336b9458953bee","tid":1220883,"uid":79325,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-15T18:59:15.000Z","msg":"First aid站被炸，我瀝瀝在目"},"citedBy":1,"replyTime":"2019-06-15T19:11:44.000Z","msg":"巴打見到？有沒片/相？ 感謝樓上有位巴打幫手推左出公海<br />\n<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-15T19:13:12.000Z","msg":"無相<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />但我親眼睇住龍匯道急救站被炸，痴線㗎"},{"pid":"bca67d10c96f8f6bfe89549d4a8b93403889b18c","tid":1220883,"uid":254456,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-15T19:15:44.000Z","msg":"有冇考慮揾D正規急救團隊幫手(E.G. St John)"},{"pid":"b27825dd5fee0db0004c0e8e9b5cade73fc9282d","tid":1220883,"uid":237753,"like":1,"dislike":0,"score":1,"quote":{"pid":"f959eeb5ccd34162e4b9aaa201ccba4db1cafc96","tid":1220883,"uid":79325,"like":0,"dislike":0,"score":0,"quote":{"pid":"522945e4723ead36ae86b2e9393a09e048693bb7","tid":1220883,"uid":237753,"like":0,"dislike":0,"score":0,"quote":{"pid":"f6af7035bd9a5819e84bb66045336b9458953bee","tid":1220883,"uid":79325,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-15T18:59:15.000Z","msg":"First aid站被炸，我瀝瀝在目"},"citedBy":1,"replyTime":"2019-06-15T19:11:44.000Z","msg":"巴打見到？有沒片/相？ 感謝樓上有位巴打幫手推左出公海<br />\n<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-15T19:13:12.000Z","msg":"無相<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />但我親眼睇住龍匯道急救站被炸，痴線㗎"},"citedBy":0,"replyTime":"2019-06-15T19:19:12.000Z","msg":"夢入面，果個站的女仔一撞返，就攬住我狂喊：佢地成個First Aid 站炸左，扔幾個催淚落去<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />好嬲 根本痴X線，果所謂first aid 站其實好細，攤位遊戲咁大到。使不X使一次過扔幾粒催淚 <br />\n根本就想殺人，不是驅趕"},{"pid":"92151a241b5d93ea6c313a8d5535a551ce4089ef","tid":1220883,"uid":254456,"like":0,"dislike":0,"score":0,"quote":{"pid":"bca67d10c96f8f6bfe89549d4a8b93403889b18c","tid":1220883,"uid":254456,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-15T19:15:44.000Z","msg":"有冇考慮揾D正規急救團隊幫手(E.G. St John)"},"citedBy":1,"replyTime":"2019-06-15T19:19:47.000Z","msg":"一來正規嘅First Aid 裝備齊啲，<br />\n二來有正規急救團隊，可以做擋箭牌 (狗仔唔咁打正規佢地 )"},{"pid":"bbc8a05b91b77472c1ddbee2598f911dcdd84d3e","tid":1220883,"uid":261913,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T19:25:15.000Z","msg":"呢班細路第時一定可以做大事"},{"pid":"f3c1c90511c2fc444c98b1011f5738c3aced224a","tid":1220883,"uid":237753,"like":3,"dislike":0,"score":3,"quote":{"pid":"92151a241b5d93ea6c313a8d5535a551ce4089ef","tid":1220883,"uid":254456,"like":0,"dislike":0,"score":0,"quote":{"pid":"bca67d10c96f8f6bfe89549d4a8b93403889b18c","tid":1220883,"uid":254456,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-15T19:15:44.000Z","msg":"有冇考慮揾D正規急救團隊幫手(E.G. St John)"},"citedBy":1,"replyTime":"2019-06-15T19:19:47.000Z","msg":"一來正規嘅First Aid 裝備齊啲，<br />\n二來有正規急救團隊，可以做擋箭牌 (狗仔唔咁打正規佢地 )"},"citedBy":0,"replyTime":"2019-06-15T19:28:11.000Z","msg":"<img src=\"https://na.cx/i/yQv44h5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyQv44h5.png&h=a04c5e5a&s={SIZE}\" /><br />\n<br />\n隔離post 睇到<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n同埋 今日有條蒙撚8婆 定性暴動，參加者都會入到<br />\n而日內瓦公約下 是指戰爭 保障醫生/人道救援組織<br />\n呢個夢有爭議點<br />\n所以不知發左first aid 夢的人會不會上身<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"60b38da2105df74ff9cf7f33678b66e5709578d9","tid":1220883,"uid":144871,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-15T19:32:58.000Z","msg":"對唔住絲打<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n我地team 係草地，只能夠聽住你地比人炸<br />\nTeam leader 去左救鄺神<br />\n我地被命令守住個到附近<br />\n<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"5dd438b136bb404a1c940aa0e928c4f38f53de62","tid":1220883,"uid":30991,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-15T19:34:08.000Z","msg":"<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> 發夢果日我都幫物資站分First Aid 同其他物品 因為見到佢地得幾個人分大量物資， 仲有我而家個袋仲有幾支生理鹽水因為我都想同大家講， 自己拎住幾支係身真係好有用。 因為上次經過個男仔又係比煙霧彈整到好那 佢想衝入廁所果一刻 我比左支生理鹽水佢， 當時佢真係那到個樣好痛好痛咁樣。 所以我建議大家如果下次再一齊發夢 唔該自己身上都有啲First Aid 係身會好好多<img src=\"/assets/faces/fs/wink.gif\" class=\"hkgmoji\" />"},{"pid":"1fcb13f1751c56794426417f809b9fb1dc9b84fa","tid":1220883,"uid":22231,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-15T19:34:48.000Z","msg":"<img src=\"https://na.cx/i/Gv2frzz.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FGv2frzz.png&h=fc9427f8&s={SIZE}\" />"},{"pid":"b6d8b5869fa64af3ec1cf3a987afc1738691f03a","tid":1220883,"uid":149435,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T19:35:15.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"}]}