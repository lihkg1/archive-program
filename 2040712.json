12,"uid":120308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T18:27:28.000Z","msg":"pish"},{"pid":"8e36c29fecc065db125257c67bf5530586029ee5","tid":2040712,"uid":81113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T18:29:06.000Z","msg":"推"},{"pid":"a3c6941ce1830332bb34d4927d8c811cf05e6dbc","tid":2040712,"uid":120308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T18:33:21.000Z","msg":"pish"},{"pid":"2e0f12b7da843d4172a1588ceefc298225d409e5","tid":2040712,"uid":120308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T18:35:53.000Z","msg":"pish"},{"pid":"40dabc6076d03ff65beb202ef418c07938160d0d","tid":2040712,"uid":35097,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-05-28T19:06:15.000Z","msg":"呢個要推  d物管好撚垃圾"},{"pid":"6bf7f81f744abef0f16055d69296883afa2f33fa","tid":2040712,"uid":279616,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-05-28T19:16:26.000Z","msg":"最難搞既係《建築物管理條例》可以話無罰則，所以大家要搞既話，跟法例去搞只係基本動作，唔可以唔做，但要成功/入肉，一定要用其他方法。<br />\n<br />\n如果你視法團/管理公司為敵人，你就一定要將個單位拆細成「主席個人」、「委員個人」、「座頭保安個人」、「物業經理個人」、「工程公司個人」、「分區民政專員個人」<br />\n<br />\n最後，提醒大家，所有做左超過3屆以上既區議員，無分顏色，都一定同法團、管理公司、中標/入標/日常保養既工程公司都有「或多或少」利益關係。"},{"pid":"9fbf165364ec34ca91e93db22da5b7fd64aac723","tid":2040712,"uid":165683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T19:17:49.000Z","msg":"Push"},{"pid":"36d6a181c7f7d8f5c08f83e8bb4622c598c31edb","tid":2040712,"uid":78184,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T19:23:03.000Z","msg":"Pish"},{"pid":"a16619108efc5989762d68e01b36dbb81646705e","tid":2040712,"uid":165683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T20:25:59.000Z","msg":"Push"},{"pid":"31cd3714c2a4bd900b0d75c330cdd187645a76c0","tid":2040712,"uid":219635,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T20:56:48.000Z","msg":"難啲<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n藍絲都有錢，業主都多數藍/唔想搞咁多嘢。<br />\n我地手足好多都學生/工都冇/飯都唔夠錢食/屋企都比老母趕出門口。<br />\n點光復<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"537b4fd3ef2ddfbb6e41cbc45e280f160019cefc","tid":2040712,"uid":73563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T20:59:26.000Z","msg":"岩"},{"pid":"ddaeccc82dc1bc89e4a0c5aef665f362554e5bd7","tid":2040712,"uid":61032,"like":1,"dislike":0,"score":1,"quote":{"pid":"e5f66ff63473fbe4ceeed181f09c46e7decc6c51","tid":2040712,"uid":120308,"like":5,"dislike":0,"score":5,"quote":{"pid":"4fd5f3f5982d5cb723ee61f71bfd8c46c9074d5e","tid":2040712,"uid":135408,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-05-28T18:21:14.000Z","msg":"光復互委會好過啦<br />\n成班建制餘孽"},"citedBy":1,"replyTime":"2020-05-28T18:24:15.000Z","msg":"一齊光復都得架，切斷佢地所有資金"},"citedBy":0,"replyTime":"2020-05-28T20:59:58.000Z","msg":"互委會同錢無關係<br />\n但可以阻斷到佢地做宣傳"},{"pid":"6647816d7ed372523ff62c3b00e688152dfd4904","tid":2040712,"uid":318505,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T21:09:05.000Z","msg":"之前都有人講，幫p牌推<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n個個法團做到將軍澳廣明邨咁嘅話就最好<br />\n雖然最後阻止唔到啲狗話入就入<br />\n但至少獻世擺咩站、借用乜柒都可以say no"},{"pid":"08f1023b855ee7365aa1949fac334ddb30933831","tid":2040712,"uid":167326,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T21:16:02.000Z","msg":"推"},{"pid":"baa761cf0bbbe2dabba9e9a93bf6c7f3e553f9c7","tid":2040712,"uid":109262,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-05-28T21:17:45.000Z","msg":"我記得睇過有篇文幾似嘅<br />\n就係話區議會會就冇權力反而就係業主立案法團重大權力過佢"},{"pid":"989fae55f2b561c9b19463a58de5cd60bfe911ae","tid":2040712,"uid":46906,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-05-28T21:42:07.000Z","msg":"光復左都無咩黃既物管可以揀<br />\n係less devil咁解"},{"pid":"0ea8290e72dd4ce71802c42e30a6daa42db142b2","tid":2040712,"uid":46906,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-28T21:42:43.000Z","msg":"<blockquote>光復左都無咩黃既物管可以揀<br />\n係less <span style=\"color