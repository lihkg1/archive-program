t/2710000/2713278/taobao_thumb_20200803_ch_1024.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic02-proxy.hket.com%2Fres%2Fv3%2Fimage%2Fcontent%2F2710000%2F2713278%2Ftaobao_thumb_20200803_ch_1024.jpg&h=f9d0aed6&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-08-03T11:56:13.000Z","msg":"Diu <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"4cd13dd776ec097c71c0acb8dc6b2366890fe959","tid":2137833,"uid":279357,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-03T12:05:41.000Z","msg":"家長死撚咗定係文盲<br />\n喔！大陸無人管你死你賤<br />\n有事穩商家嘈政府鎖鳩你<br />\n係中國唔係權貴只能忍受"},{"pid":"d750c0ccda0e97c9a0004fee8d0c30cfad6b8004","tid":2137833,"uid":60635,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-03T12:08:13.000Z","msg":"正正經經打波唔得，係要玩呢D垃圾<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" />"},{"pid":"234eb8ea3a8d742b19f35af766c50fd99d2beeed","tid":2137833,"uid":237143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-03T12:12:48.000Z","msg":"個B大個左後會唔會憎父母憎一世"},{"pid":"07ee85c97389b6e89cd4e33d59c5d81acaf2f37a","tid":2137833,"uid":133399,"like":1,"dislike":0,"score":1,"quote":{"pid":"31ac4cdbef4abe9c06996c37d4121cd51540a26c","tid":2137833,"uid":295602,"like":90,"dislike":2,"score":88,"citedBy":4,"replyTime":"2020-08-03T08:35:10.000Z","msg":"乒乓波對著牆就識彈番轉頭, 款玩具都多鳩餘<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n個概念係將個波隊落把刺劍度?<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-03T12:13:22.000Z","msg":"3 歲會唔會接到反彈個下<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n我諗款玩具都係俾依d 冇技術嘅細路專心玩波唔洗淨係執波"},{"pid":"861fe423017ed78cecd96a59151af64932b329ff","tid":2137833,"uid":237300,"like":1,"dislike":0,"score":1,"quote":{"pid":"52f4174