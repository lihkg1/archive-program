c2aca7&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/Y2dc5Ph.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FY2dc5Ph.jpg&h=a622cc2b&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/4qoD1nG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4qoD1nG.jpg&h=8c393ba6&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/4EpGY9p.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4EpGY9p.jpg&h=f79c9acc&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n跟住就俾人半昆左去睇falcon show 雖然個男人都幾好笑 但係佢企個位極度背光眼都盲撚埋呀屌你<img src=\"/assets/faces/dog/fight2.gif\" class=\"hkgmoji\" /> 結論都係正面嘅，完全冇興趣就skip否則都不妨一睇8usd<br />\n<img src=\"https://na.cx/i/tvOXAiR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FtvOXAiR.jpg&h=aa5d90e5&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/FFeovSf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFFeovSf.jpg&h=247c1e5f&s={SIZE}\" /><br />\n<br />\n對唔住時間線有啲亂, 唔係全部上到網<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"12e87fd29047dd444bc177674c72feb81b1f8fdf","tid":1174263,"uid":237901,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d40653089a86751893866542161768bf8bfa3a9","tid":1174263,"uid":1139,"like":0,"dislike":0,"score":0,"quote":{"pid":"948f12e5c8ef6b64952ee890d8852eee6aab0765","tid":1174263,"uid":237901,"like":0,"dislike":0,"score":0,"quote":{"pid":"325ea5baf51e0657e6b6ca53a769e23bc88191aa","tid":1174263,"uid":17142,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-27T18:32:54.000Z","msg":"留名睇點入土庫曼"},"citedBy":1,"replyTime":"2019-05-28T01:45:02.000Z","msg":"搭飛機入<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-01T05:34:08.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-06-04T03:10:36.000Z","msg"