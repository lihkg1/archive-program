f41c54af&s={SIZE}\" />"},{"pid":"d62c9ff133ea407776892989911e54b9267a3a5d","tid":101192,"uid":80311,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-31T04:45:31.000Z","msg":"搵個西醫食西藥<br />\n自己就要忌口 牛羊奶生冷野唔好食<br />\n沖涼用微暖水 沖完同每朝都塗潤膚膏<br />\n平日做運動出汗去濕<br />\n濕疹斷唔到尾 以上生活習慣跟一世<br />\n利申：個人經驗 曾經生到想死 依家未大發過"},{"pid":"585fe1f2a55322b9c8d86816035118914c0f890a","tid":101192,"uid":43912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-31T05:33:17.000Z","msg":"試過睇中醫冇咩用 所以都係慣睇西醫 好彩發係腳到都遮到"},{"pid":"6b8bca9cf2ae0d054942a68c6b0d38f6d135b334","tid":101192,"uid":9290,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-31T05:45:06.000Z","msg":"青衣長發花園果個好WORK 我幾年前睇過佢兩次 到依家都冇事"},{"pid":"5d77aeb197da32603aa4c0c35e6af026fc139e1d","tid":101192,"uid":9290,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-31T05:47:31.000Z","msg":"<blockquote>青衣長發花園果個好WORK 我幾年前睇過佢兩次 到依家都冇事</blockquote><br />\n自膠 係美景果個鄒業宏醫生"},{"pid":"623262ca9e21d5ffeaad509807f64821c18610a5","tid":101192,"uid":38461,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T04:32:36.000Z","msg":"<blockquote>西醫冇撚用，治標唔治本<br />\n朋友介紹一個中醫睇，三個禮拜好咗九成，冇乜再甩皮<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /></blockquote><br />\n咩名<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"6b4248f758e77fad88925b079194677bb8043dc5","tid":101192,"uid":17723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T08:01:26.000Z","msg":"<blockquote><img src=\"https://holland.pk/uap7n0q6\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fuap7n0q6&h=f41c54af&s={SIZE}\" /></blockquote><br />\n<br />\n巴打識野喎<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"90910e5a7ba83656be655937fb32c7ec814a5a96","tid":101192,"uid":4139,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T08:06:33.000Z","msg":"認真問 邊到有死海鹽買"},{"pid":"5783cb9bfa72403fa22305ef30469ca53a32c2ef","tid":101192,"uid":17723