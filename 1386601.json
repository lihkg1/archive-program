x%2Fi%2FB0YEa3X.png&h=261accaf&s={SIZE}\" />"},{"pid":"7364494a6ac8ecbdda5f380b372f37834714b138","tid":1386601,"uid":195252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:03:53.000Z","msg":"推上熱門"},{"pid":"4f83b5e61a54d21e540f00ab7402fc1aec6b1542","tid":1386601,"uid":236925,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:06:21.000Z","msg":"push"},{"pid":"3eda0bb9474269d0fd63dc9e5b1f1a6dd75be2d7","tid":1386601,"uid":4738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:08:05.000Z","msg":"push"},{"pid":"9c287306ac1333dbbb1f692ed9c910b116549c7a","tid":1386601,"uid":195252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:08:42.000Z","msg":"推上熱門"},{"pid":"eae9088e1091c8ce072ab541eb3f3567399ffb06","tid":1386601,"uid":191926,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:09:08.000Z","msg":"85一定罷  <br />\n<br />\n看下果日有無咩野做到😡"},{"pid":"7913735001e6e5af97b75adc1b6a7cd3d667af46","tid":1386601,"uid":242527,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:17:36.000Z","msg":"Push"},{"pid":"a4e30375ec142bb59172634918015f7cb0adac6c","tid":1386601,"uid":195252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:18:44.000Z","msg":"我願意罷工"},{"pid":"8e6b28a692c5eb7ac23e4143682bf1580156bf60","tid":1386601,"uid":6528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:19:18.000Z","msg":"全民8月5曰大罷工！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n五大訴求，缺一不可！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n雙普選應要排最頭！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n全民黑衫、口罩同頭盔，返工返學行街，唔擺工既日子一齊做，將抗爭帶入生活，保護示威者<br />\n<a href=\"https://lih.kg/1379839\" data-auto-link target=\"_blank\">https://lih.kg/1379839</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n光復香港，時代革命！<br />\n－－－－－－－－－－－－－－－－－－－－－－－－－－－－－<br />\n想比更多人知道其實而家呢一刻基本上得番香港獨立呢條路，<br />\n我知好多人未準備好，我知而家急唔黎。<br />\n但係想大家思考下，種下一個思想，唔好屌我住。<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n而家就算有真普選其實都係under中共！！<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><br />\n咁唔通去到2047再抗爭過咩，西方國家都出唔到手幫你地。<br />\n因為白紙黑字寫明50年，西方國家唔好話出手，連發聲既正當性都冇啊<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n可能好多前人都係到諗點解英國當時唔寫999年！<br />\n可能好多我地呢代既諗點解上一代冇去抗爭！<br />\n可能好多下一代係2047係到諗點解我地唔直接爭取獨立！！！<br />\n<br />\n2047到時只會都係變返中國，仲要一下子就變，一定好多人接受唔到。<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n<br />\n所有問題去到最後只會追究到主權問題，希望大家思考下。<br />\n今次搞到咁大真係最後一次反擊同最大力量。<br />\n<br />\nBTW，五大訴求，缺一不可！<br />\n雙普選應要排最頭"},{"pid":"520796fac84700528c50346bd0b3beb2908f26f3","tid":1386601,"uid":254383,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:21:25.000Z","msg":"85罷工"},{"pid":"d4e3fbffb9f2d06ffc64e3b7c03ad63d910f01d3","tid":1386601,"uid":195252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:21:56.000Z","msg":"我願意罷工"},{"pid":"64c806006d6c69ca19112db0b7efd6b27dbc1d75","tid":1386601,"uid":144733,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:23:15.000Z","msg":"推"},{"pid":"10ca807d92c0516bf2674826f4ad415ec3776fe7","tid":1386601,"uid":195252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:23:34.000Z","msg":"我願意罷工"},{"pid":"001a68356a0e1da01c7d47e97c1d1c1b761486de","tid":1386601,"uid":79507,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-30T13:27:15.000Z","msg":"請各位係ig fb 明確地表明罷工支持<br />\n比人地知罷工並非少眾 <br />\n一傳十 十傳百 就會多人肯企出黎"},{"pid":"265922dfbc8d6cd1d6b85b37c57621c33477cad1","tid":1386601,"uid":195252,"like":0,"dislike":0,"score":0,"quote":{"pid":"001a68356a0e1da01c7d47e97c1d1c1b761486de","tid":1386601,"uid":79507,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-30T13:27:15.000Z","msg":"請各位係ig fb 明確地表