\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"dd376ba1ee57d7cabae4c0606da03e281aab1c43","tid":2423672,"uid":174120,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2021-02-26T05:02:37.000Z","msg":"蘋果呢張相真係不得了"},{"pid":"6ad57a63354789019b11c42ac0d4e976d27129d1","tid":2423672,"uid":27122,"like":0,"dislike":0,"score":0,"quote":{"pid":"0b8d527dfe44606998d934282bbf23e80e58ec0c","tid":2423672,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"b4c5533f7f49ba5a0a5777ed67da2dcc728f762f","tid":2423672,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-26T05:02:02.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-26T05:02:31.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-26T05:03:57.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4a0916bb1c6fd739f979dcecb768379bd19caa1e","tid":2423672,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T05:07:14.000Z","msg":"前年「616大遊行」前夕，身穿黃色雨衣的反修例示威者梁凌杰，在金鐘太古廣場外牆墮下不治。死因裁判官高偉雄早前決定為梁淩杰召開死因研訊，今早於西九龍裁判法院以非公開形式進行研訊前檢討。然而死者家屬今早未有到庭，原本律師亦終止代表，死因庭多次聯絡家屬不果，並得悉死者家屬早已搬離報稱住址。死因庭最後暫訂5月10日至26日召開其死因研訊，為期12日，惟若家屬缺席下，研訊或受影響。死因研訊主任葉志康於聆訊後公開呼籲死者家屬致電39166201聯絡死因庭書記李小姐，或致電39166204死因庭熱線。<br />\n<br />\n據悉研訊暫訂將設有陪審團，會傳召逾30名證人作供，包括現場消防員、警員包括談判專家及調查警員、太古廣場職員、法醫等，當日在場的前立法會議員鄺俊宇則不在其列，死因庭並𣎴抗拒任何能提供有用資訊的人士主動聯絡法庭出庭作供。研訊又將警務處處長、消防處處長、太古廣場、太古廣場保險公司友邦保險（AIA）及於梁凌杰墮樓處正進行維修工程的利景工程公司列為有利害關係人士。而死因研訊屆時將運用更多科技以視像形式協助公眾理解，但不會如周梓樂的死因研訊使用虛擬實景（VR）。死因裁判官高偉雄早前曾主理15歲少女陳彥霖浮屍海面以及22歲科大生周梓樂墮樓身亡的死因研訊，同樣與反修例示威有關。"},{"pid":"43e6fefc55d6c9d2410d93cc93a14b7e35e4fd57","tid":2423672,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T05:08:33.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6d4e823a8ad12c3aeeb846b3e30d5b86bc33cb80","tid":2423672,"uid":152476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T05:10:55.000Z","msg":"<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"d0e3a6aa89acf2e453e540dcf866192bb2588073","tid":2423672,"uid":113000,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-02-26T05:11:00.000Z","msg":"被失踨<img src=\"/assets/faces/lm2lny/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"8a0b4a42a2eed80bf737ad2d696e8f33f2166f92","tid":2423672,"uid":51271,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2021-02-26T05:14:37.000Z","msg":"咁奇怪，擒日先話父母支持開庭"},{"pid":"84b81ff8a54d0d6e266911668048cc9910cb01fd","tid":2423672,"uid":28195,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2021-02-26T05:15:12.000Z","msg":"希望兩老已回祖國，現於英倫某小鎮生活，遠離核突共產黨。"},{"pid":"1a0ec4d2ff9af882937780620a36af77986ed782","tid":2423672,"uid":268519,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T05:15:24.000Z","msg":"<img src=\"/assets/faces/mouse/what.gif\" class=\"hkgmoji\" />"},{"pid":"fa3b646e1518dd9d9d84f43ceef21529e97bbdd3","tid":2423672,"uid":51271,"like":0,"dislike":0,"score":0,"quote":{"pid":"8a0b4a42a2eed80bf737ad2d696e8f33f2166f92","tid":2423672,"uid":51271,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2021-02-26T05:14:37.000Z","msg":"咁奇怪，擒日先話父母支持開庭"},"citedBy":0,"replyTime":"2021-02-26T05:16:30.000Z","msg":"反送中運動首名犧牲者梁凌杰 死因庭將展開研訊<br />\n<a href=\"https://lih.kg/2422643\" data-auto-link target=\"_blank\">https://lih.kg/2422643</