3544c544bb9f66b1cc36fdc1072fb02f1","tid":1467104,"uid":275278,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:10:42.000Z","msg":"推818post"},{"pid":"13466f13dbf16f175e0c1fd3d4638aeb1e2a25aa","tid":1467104,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:10:51.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"733dce225b03ac4e3eb238a2b1ac3efc0df846e1","tid":1467104,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:13:28.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"487102fa4e9f5806eb33240dde506840e7186ec3","tid":1467104,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:14:21.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"bc76d731b3fa389c5f4161fdeda6410e381b42c2","tid":1467104,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:14:55.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"3b224e70c831a783b5a1cb81af14be51ab69f0eb","tid":1467104,"uid":5205,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-08-13T17:15:03.000Z","msg":"必須保護100%和理非行動 <br />\n<br />\n我地可以提早決定100%和理非定 有後續 <br />\n<br />\n<br />\n警察風向 破壞連登 咩淪陷 唔好信<br />\n<br />\n信左就中警察計<br />\n<br />\n<br />\n<br />\n和理非 取消黑衫行動 勇武就無左保護 鬼亦無咁多機會滲透<br />\n<br />\n<br />\n一定要支持 勇武就無左保護 自然要勇武休息下<br />\n咁鬼既滲透亦無左機會。<br />\n<br />\n<br />\n但係 講到明有下場既就全民黑衫 （例如免費過海之類）<br />\n<br />\n機場只宣傳 同控制人流 有人搞事就 比泛民 等泛民開記者會<br />\n<br />\n幫手講佢係鬼 <br />\n<br />\n另外唔建議帶口罩 和理非活動係要一家大細都可以參與"},{"pid":"c2edd318d5b15667dcc99bf1e2e57e6af9a66522","tid":1467104,"uid":69314,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:16:01.000Z","msg":"[置頂] 和理飛814<br />\n<a href=\"https://lih.kg/1466833\" data