:297119,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-16T02:26:43.000Z","msg":"出左無人機同忍者飛彈再話我知"},{"pid":"2b8b52fb128e9883f3a7955453a2eeed1fff6a20","tid":2368101,"uid":294518,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-16T02:52:52.000Z","msg":"<img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" />"},{"pid":"a1369552db0a4d4fa90deb525df37d45d6b75ae0","tid":2368101,"uid":49329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-16T02:58:28.000Z","msg":"Genocide, 遲D到香港"},{"pid":"55f423636eb86e67a4c5f59491f0a6bdb82d1878","tid":2368101,"uid":71564,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-16T03:15:37.000Z","msg":"唔係諗住用飯民個招又傾又砌呀話<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ae67265cc7154788d7cae5dc6bfc183a53414e94","tid":2368101,"uid":19527,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-16T03:17:16.000Z","msg":"左膠：WFC，最緊要侵快啲死"}],"pinned":{"pid":"28a4590b52621acc25f8a687fa7b462391e72808","tid":2368101,"uid":294518,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-01-16T01:52:20.000Z","msg":"原文<br />\n<a href=\"https://www.cecc.gov/publications/annual-reports/2020-annual-report\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.cecc.gov%2Fpublications%2Fannual-reports%2F2020-annual-report&d=urW02bDNsyUCiNuSwPhOyGyprV%2B6HEKZLwhfW4p%2FhGU%3D&h=16b7629a\" data-auto-link target=\"_blank\">https://www.cecc.gov/publications/annual-reports/2020-annual-report</a>"}}