y":0,"replyTime":"2019-10-08T09:19:03.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"fd45950eb24e4e00476d58ae3e1b9171592c8be8","tid":1638162,"uid":92476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T09:19:48.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"84370be77cd1af19e668c85092bdbea76d20f8d7","tid":1638162,"uid":92476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T09:21:29.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"c435deb3193a2a1954d62aee405fb3b4bbe0f60b","tid":1638162,"uid":92476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T09:25:32.000Z","msg":"推"},{"pid":"88470d0901d2b4e784ee40a8c6afbab0fa15a62f","tid":1638162,"uid":26770,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-08T09:44:51.000Z","msg":"屯門都見到大量監控鏡<br />\n個鏡頭仲曉轉<br />\n<br />\n盈豐商場"},{"pid":"1ec1c5e3b04c6492badff97b33391cb927e46451","tid":1638162,"uid":92476,"like":0,"dislike":0,"score":0,"quote":{"pid":"88470d0901d2b4e784ee40a8c6afbab0fa15a62f","tid":1638162,"uid":26770,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-08T09:44:51.000Z","msg":"屯門都見到大量監控鏡<br />\n個鏡頭仲曉轉<br />\n<br />\n盈豐商場"},"citedBy":0,"replyTime":"2019-10-08T13:22:24.000Z","msg":"所有地方都係<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n樓下門口多到零死角<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"530a2bc3c4fb505ac3d8bd4cc573763b037d4801","tid":1638162,"uid":92476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T14:22:12.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"c26c8846a2a0c57876dfe9c280760e24bd6f6f2c","tid":1638162,"uid":92476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T14:43:10.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"6a00185b001c26c4e2f6576e6c93fe1300fbc22a","tid":1638162,"uid":283494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-09T11:38:30.000Z","msg":"早前，美國商務部亦宣布制裁中國政府機構及企業，把20個中國公安機關及8間科技公司列入貿易管制黑名單，這批科技公司主要從事監控設備、人臉識別等人工智能技術(AI)，包括港產「獨角獸」商湯科技、正申請在港交所(00388)上市的曠視科技、深圳上市的海康威視(Hikvision)及科大訊飛等。美商務部稱，被列入實體清單(Entity List)的政府機關及公司，有份參與中國政府在新疆對維吾爾族及其他少數民族穆斯林的侵犯人權活動。<br />\n<br />\n(信報)"}]}