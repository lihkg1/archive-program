f9ac989e7c99cd3a0bcc7a3","tid":1824422,"uid":7043,"like":2,"dislike":1,"score":1,"citedBy":2,"replyTime":"2020-01-14T12:21:29.000Z","msg":"點解你覺得殺完人一定會影響心理<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"e09b70e9364e610a6a7816ca96ccaf1a735ffc98","tid":1824422,"uid":48234,"like":1,"dislike":1,"score":0,"quote":{"pid":"c907872829a0a50f1f9ac989e7c99cd3a0bcc7a3","tid":1824422,"uid":7043,"like":2,"dislike":1,"score":1,"citedBy":2,"replyTime":"2020-01-14T12:21:29.000Z","msg":"點解你覺得殺完人一定會影響心理<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-14T12:28:30.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">老鳳只希望香港人可以殺敵後毫冇創傷</span></span>"},{"pid":"e3d3e471284f82aa743bc35208311b8bfee057e6","tid":1824422,"uid":48234,"like":1,"dislike":0,"score":1,"quote":{"pid":"cb9159dc71bcffb01275b02a67831283cf1440bd","tid":1824422,"uid":29983,"like":2,"dislike":2,"score":0,"citedBy":2,"replyTime":"2020-01-14T12:15:10.000Z","msg":"都冇希望，生存仲有乜意義"},"citedBy":0,"replyTime":"2020-01-14T12:29:03.000Z","msg":"老鳳覺得而家生存就係為咗殺敵<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"9b38668242314aa50c2cbdc46b21975f6f844ca5","tid":1824422,"uid":27882,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-01-14T12:30:23.000Z","msg":"大陸佬有咩ptsd,佢地見到bb俾車車死都冇反應"},{"pid":"9832de5e14b49e25c39f7221dc1a00eb388fd3fc","tid":1824422,"uid":313615,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-01-14T12:31:30.000Z","msg":"1、國安嘅團隊單位<br />\n國安團隊整體高效拍檔。一個細團隊，有6名以上嘅人員，擁有自己嘅車同秘密據點，團隊裏面有兩名女性。四人同時外勤，各有分工。個個都冇工作固定時間，可以高強度續航一日到幾日。<br />\n秘密據點通常係一個位於市區嘅政府基礎設施附近嘅大樓。為咗保密，非固定人員唔常見，連衛生都自己打掃，監控個體、去廁所同抄身都親自睇住。<br />\n2、與其他部門有天然沖突。<br />\n國安畀厭惡、反感程度遠超警察、國保。國安會提醒妳唔好喺其他部門提到佢哋。<br />\n3、乘虛而入係慣用手段。<br />\n目標人群：冇經驗嘅新人同後生仔、生活做嘢有嚴重困難嘅人、家庭關系有嚴重矛盾嘅人。（國安提前摣手，國保都好嫻熟）<br />\n4、精心揀目標個體<br />\n國安同妳見面之前都係有充分準備嘅。意識形態模糊、易畀同化、國保維穩有等。妳最近一年網絡言論、呢排幾年與親友言論畀納入考量範圍。<br />\n國安最低限預咗幾月到數年對妳嘅工作生活秘密布局，提前布局安排會面。<br />\n5、處心積慮安排會面<br />\n國安發展線人嘅動機同特長強於辦緊案，偽裝嚟搭訕妳。<br />\n電話約妳見面，有偽裝係片警約談見面後擺明身份嘅。安排親友（提前好耐）畀一定暗示，勸說個體接觸。精心安排好&ldquo;邂逅&rdquo;場景。<br />\n秘密傳喚，就有可能會畀帶到秘密據點。<br />\n國保嘅秘密據點喺郊區、軍事基地附近嘅設施；<br />\n國安秘密據點分布喺市區。<br />\n6、秘密據點度嘅套路<br />\n&ldquo;畀認為野性難馴&rdquo;，唔易畀征服嘅人。酷刑，敲腦、腳、膝、骱。<br />\n國安程式上冇法律制約，手段過國保更加冇底線，更加靈活。人著斯斯文文，面彬彬有禮，玩陰嘅。<br />\n國保和警察因為有時間同空間監管，中途會有間歇、適可而止。<br />\n國安並無約束，酷刑可以喺幾個鐘到幾日，唔間歇唔閘住。呢一切為咗測試，評估同側寫。<br />\n<br />\n<br />\n7、私隱係突破口<br />\n妳冇私隱，妳嘅一切國家都應該知。國安扮好認真嘅傾案情，實際更關心妳私隱。透過傾計了解妳嘅工作、生活、家庭，仲有朋友圈同工作圈，獲取信息。<br />\n8、借國家之名光環自己、迷惑人<br />\n國安嚴肅同禮貌，話自己完全代表國家，神聖、神秘、無所不能，有心傾偈同「唔經意」提到妳行蹤，以顯示對妳嘅一切了如指掌。畀妳恐懼、緊張。<br />\n9、常見要求<br />\n答問題、保密、繼續再見面、做線人<br />\n國安盡量但唔會強求妳自願配合，妳可以唔願意，可以勉強。戰略層面唔求速成，&ldquo;按部就班&rdquo;、&ldquo;循序漸進&rdquo;逐漸令妳深陷其中，佢哋駕輕就熟。<br />\n10、保密要求<br />\n強調保密同下次聯系要及時應答。國安度辦緊案結束後，會要求妳簽章保密。<br />\n國安對妳強調自己代表國家、代表法律、代表組織，強調妳有義務配合要求、配合保密。對配偶、屋企人、朋友、同事、對手、國保等任何人保密。保密內容包對會面、所傾全部內容嘅保密。次次見面都會畀洗腦。直至妳隨叫隨到、應承嘅要求越嚟越多，徹底淪陷。<br />\n簽章保密條款中規定，唔保密嘅嚴重罰係拘留十五日。<br />\n喺人少嘅地方，畀個體戴上頭套、推進車度、到秘密基地酷刑。但國安係絕對理性嘅，噉嘅處罰唔係理性，泄憤並非佢哋嘅愛好。<br />\n<br />\n佢哋唔會將個體作為招聘對象，最多係策反妳當線人。而線人陷入兩個身份嘅壓力中，不得善終。<br />\n<br />\n有時會殺人滅口。"},{"pid":"4bd2574ce8bd8c5d225260ffa8ac8e09b02fb718","tid":1824422,"uid":291921,"like":1,"dislike":0,"score":1,"quote":{"pid":"c907872829a0a50f1f9ac989e7c99cd3a0bcc7a3","tid":1824422,"uid":7043,"like":2,"dislike":1,"score":1,"citedBy":2,"replyTime":"2020-01-14T12:21:29.000Z","msg":"點解你覺得殺完人一定會影響心理<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-14T12:35:12.000Z","msg":"人地都無人性，何來因為殺人而覺得內疚不安後悔等負面情緒<br />\n<br />\n定係覺得希特拉殺咁多人就會有PTSD?"},{"pid":"ecb419513a8327d375e3cbf7a2f8286dbfd7147c","tid":1824422,"uid":48234,"like":2,"dislike":0,"score":2,"quote":{"pid":"4bd2574ce8bd8c5d225260ffa8ac8e09b02fb718","tid":1824422,"uid":291921,"like":1,"dislike":0,"score":1,"quote":{"pid":"c90