.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-19T10:25:30.000Z","msg":"即係不停拳打腳踢，逼你食屎，沖涼得10秒，罰企成日的生活<br />\n但無案底<br />\n坐幾耐視乎阿頭心情"},{"pid":"2f76e166fc468b872fbdc53b17f1c859d8aa1420","tid":1979241,"uid":40542,"like":0,"dislike":0,"score":0,"quote":{"pid":"c30d1b7f74be0eed255180104a2b8643e82618f1","tid":1979241,"uid":228437,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-04-19T10:08:19.000Z","msg":"其實咩係勞教中心<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-19T10:25:58.000Z","msg":"有無睇過同囚<br />\n<br />\n<strong><ins>【同囚・上】徒手洗廁、捧糞 前少年犯憶勞教生活：第二晚已想死</ins></strong><br />\n<a href=\"https://www.hk01.com/社區專題/98516/同囚-上-徒手洗廁-捧糞-前少年犯憶勞教生活-第二晚已想死\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%E7%A4%BE%E5%8D%80%E5%B0%88%E9%A1%8C%2F98516%2F%E5%90%8C%E5%9B%9A-%E4%B8%8A-%E5%BE%92%E6%89%8B%E6%B4%97%E5%BB%81-%E6%8D%A7%E7%B3%9E-%E5%89%8D%E5%B0%91%E5%B9%B4%E7%8A%AF%E6%86%B6%E5%8B%9E%E6%95%99%E7%94%9F%E6%B4%BB-%E7%AC%AC%E4%BA%8C%E6%99%9A%E5%B7%B2%E6%83%B3%E6%AD%BB&d=BjPUJoueJJBj8huYKMWPWmhNlLB%2BLbsdBqu6cuXqlDc%3D&h=009c9e2c\" target=\"_blank\">https://www.hk01.com/社區專題/98516/同囚-上-徒手洗廁-捧糞-前少年犯憶勞教生活-第二晚已想死</a><br />\n<br />\n<ins>《同囚》預告片</ins><br />\n<a href=\"https://www.youtube.com/watch?v=kdb1chbnwwc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3Dkdb1chbnwwc&d=BjPUJoueJJBj8huYKMWPWmhNlLB%2BLbsdBqu6cuXqlDc%3D&h=27286eae\" target=\"_blank\">https://www.youtube.com/watch?v=kdb1chbnwwc</a><br />\n<br />\n<strong><ins>勞教中心</ins></strong><br />\n勞教中心是代替監禁的其中一種刑罰，但只適用於14至24歲的男性犯人。勞教中心著重透過嚴格紀律及勞動工作，在短時間內為犯人帶來沖擊，從而提醒他們不可再犯案。勞教中心令不適用於曾經被判監禁或判入教導所的犯人。<br />\n<br />\n懲教署署長會考慮犯人在勞教中心的紀律，決定犯人的羈留時期。14至20歲的犯人，最少會被羈留 1 個月、最多則可被羈留6個月； 21至24歲的犯人，可被羈留3個月至12個月。<br />\n<br />\n犯人獲釋後，可能要再接受為期一年的監管，期間要遵守某些規限，例如在晚上某個時間過後，必須要留在家中。犯人若不遵從監管條件，可能會再被送入勞教中心。"},{"pid":"49eb1e33e4056bc45d25d2735c015b5fb7ffb4bf","tid":1979241,"uid":250948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T10:27:46.000Z","msg":"多謝你"},{"pid":"e3f71159098121c77b11b15e7d1abc886f77b2fc","tid":1979241,"uid":40542,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T10:28:07.000Z","msg":"手足需要大家，請聽審聲援手足"},{"pid":"beced78fdd598778c7a12b2e7dc0999ba327ff02","tid":1979241,"uid":40542,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T10:29:05.000Z","msg":"手足需要大家，請聽審聲援手足"},{"pid":"95bebcd6d86c8cce869e91c0169447d14ed844c8","tid":1979241,"uid":40542,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T10:30:00.000Z","msg":"手足需要大家，請聽審聲援手足"},{"pid":"c0b34e11b1ec2e0d19137afd3c1d9f383bfa21d6","tid":1979241,"uid":105976,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-19T10:31:20.000Z","msg":"辛苦你整理"},{"pid":"e3bee72a71c69badfcc6d727b9f84d78da3b5804","tid":1979241,"uid":113155,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-04-19T10:35:42.000Z","msg":"被判入獄<br />\n1. 羅(23) - 判監10個月 - 管有伸縮棍、摺刀等 #1117尖沙咀 #理大事件<br />\n<br />\n有冇詳情？<br />\n點解咁都入到？<br />\n手足會上訴？"},{"pid":"b1e1ee3c9e1e1f80909dd0cb585f34fe8b9cfdfa","tid":1979241,"uid":40542,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T10:35:57.000Z","msg":"手足需要大家，請聽審聲援手足"},{"pid":"a33060b289995715fd532ca524b6b62722819c61","tid":1979241,"uid":51621,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T10:37:11.000Z","msg":"推"},{"pid":"92a546f116d2b7a5156a43aca6048dab17d17eee","tid":1979241,"uid":40542,"like":0,"dislike":0,"score":0,"quote":{"pid":"c0b34e11b1ec2e0d19137afd3c1d9f383bfa21d6","tid":1979241,"uid":105976,"like":0,"dislike":0