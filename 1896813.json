材相當凹凸有緻</span>，正在細心的幫客人洗頭"},"citedBy":0,"replyTime":"2020-02-25T11:39:15.000Z","msg":"咁撚樣洗頭有乜嘢意思"},{"pid":"55480104335a3ee38d8d784c15ed657ae324fa90","tid":1896813,"uid":224657,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T11:39:22.000Z","msg":"拉"},{"pid":"65b702bed87fcece6b854de335f8909ba1d5cce9","tid":1896813,"uid":4322,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-02-25T11:39:49.000Z","msg":"拉"},{"pid":"e991db53e95d07e5887b82b3b727428ed0641759","tid":1896813,"uid":224657,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T11:39:51.000Z","msg":"pull"},{"pid":"e7cc977d19da6b929250c79092303b8654489bea","tid":1896813,"uid":4322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T11:40:00.000Z","msg":"拉"},{"pid":"e19ac5c8fe88ab070a30d3108c25c78adf329c3b","tid":1896813,"uid":224657,"like":0,"dislike":0,"score":0,"quote":{"pid":"72ebd6ae3e2b0cc9d9724c12251edcc78714f482","tid":1896813,"uid":136973,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-02-25T11:35:49.000Z","msg":"啲相愈後愈<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-25T11:40:22.000Z","msg":"拉"},{"pid":"c0d9a2d35d31530bf626338d10c430426ab8fd48","tid":1896813,"uid":228868,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T11:40:28.000Z","msg":"一般般"},{"pid":"8c2aa5eed19440df1778d44d821b6876039f39eb","tid":1896813,"uid":192776,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-02-25T11:41:05.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"b95d91978a25940850cdd9b783b74843e99e45ba","tid":1896813,"uid":192776,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-02-25T11:41:21.000Z","msg":"拉"},{"pid":"0e8bec34380c06dae418d21d129bbb9850985272","tid":1896813,"uid":192776,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T11:41:32.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /