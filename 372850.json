=\"hkgmoji\" />"},{"pid":"df77bd5cca3b666951aca2ffc02027969d4e72ee","tid":372850,"uid":25676,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-08-24T15:27:54.000Z","msg":"<a href=\"https://img.eservice-hk.net/upload/2017/08/24/232722_ff3714a74d510dfedf990195d03f6d57.jpg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F24%2F232722_ff3714a74d510dfedf990195d03f6d57.jpg&d=xA2EguRediyPwB3WMkcVYm6kGZraZVKwHE52VSkiKoI%3D&h=c6646f61\" target=\"_blank\">https://img.eservice-hk.net/upload/2017/08/24/232722_ff3714a74d510dfedf990195d03f6d57.jpg</a><br />\n個傷口<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1284ca9e02cd9db7d4c780f56f45331d982a3185","tid":372850,"uid":62064,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-08-24T15:28:07.000Z","msg":"貓撚會答你 拆左個鈴鐺先"},{"pid":"7243a501f917ede25ee68b6608eeec6795310a5c","tid":372850,"uid":25676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-24T15:29:58.000Z","msg":"<blockquote>貓撚會答你 拆左個鈴鐺先</blockquote><br />\n個鈴空心，啱啱撚貓嘅時候撚過下"},{"pid":"3a806d8a2379789d98580d29c46112910998fbb4","tid":372850,"uid":25676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-24T15:34:13.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/08/24/233321_2928190afe7d59c183dbebb9b2d7f07e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F24%2F233321_2928190afe7d59c183dbebb9b2d7f07e.jpg&h=64aa273c&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/08/24/233325_959c14cb80ac31d461bc04ed079f1e55.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F24%2F233325_959c14cb80ac31d461bc04ed079f1e55.jpg&h=0d50a5d0&s={SIZE}\" /><br />\n<br />\n隻貓咁得意，傷口應該唔會細菌感染掛<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"7d41c7dc2d65937b3b6f8cffe7453517e3a9a20f","tid":372850,"uid":1858,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-08-24T15:36:20.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2017/08/24/233321_2928190afe7d59c183dbebb9b2d7f07e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F24%2F233321_2928190afe7d59c183dbebb9b2d7f07e.jpg&h=64aa273c&s={SIZE}\" /><br />\n<br />\n隻貓咁得意，傷口應該唔會細菌感染掛<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n你老味，睇下幾時殺左你個冧家產<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"},{"pid":"a3dbcc5f612b0b8874ac942176910e56e2d5399b","tid":372850,"uid":73945,"like":0,"dislike":6,"score":-6,"citedBy":0,"replyTime":"2017-08-24T15:39:05.000Z","msg":"沒藥醫，下世投胎做隻貓啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n認真，哺乳類口水有消毒作用，係人類先退化到沒咗，所以貓會奶自己傷口<br />\n沒發燒沒發炎應該沒事，有就要即刻睇醫生<br />\n<br />\n試過畀貓無端端抓傷，即時掉咗佢出去，都唔知d 指甲收埋幾多菌<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"83089eb5f78df86c3a312ed2bd5e2b2408d72036","tid":372850,"uid":619,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-08-24T15:40:30.000Z","msg":"屋企貓唔怕"},{"pid":"94fbee12c31d46a35cdddc8768e7fc5faa0bb786","tid":372850,"uid":3976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-24T15:41:31.000Z","msg":"咬返佢隻手"},{"pid":"17f0fe800b7543555db02c80f4a2ecd0e8342cdc","tid":372850,"uid":129039,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-24T15:45:35.000Z","msg":"對佢講番對唔住，消毒你隻手先好比佢咬呀<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"f39a79fc374d5d7e8275e87feee03315902227cf","tid":372850,"uid":48796,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2017-08-24T15:45:44.000Z","msg":"要點處理<br />\n<br />\n1. 跪低講對唔住，係奴才抵死<br />\n2. 奉上雞雞罐罐<br />\n3. 退下"},{"pid":"9bf4fce249ab2ae09089f7596db5a63cd3df5980","tid":372850,"uid":21526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-24T15:50:39.000Z","msg":"前兩個月試過<br />\n咬完即刻洗手<br />\n樓主唔洗驚<br />\n最多一個月後有條疤痕<br />\n死唔去既<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"843841d5bac012eb98dcdd24fcfcfd3737bbec2e","tid":372850,"uid":25676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-24T15:53:11.000Z","msg":"多謝咁多位<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n諗住落街買罐比貓貓謝罪<br />\n點知無supermarket <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f00f7599110faf33d0cb3f3099de787605cd5014","tid":372850,"uid":37389,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-24T15:53:14.000Z","msg":"除左復原慢之外無乜問題 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3ae771d8ad7597f781cf39c05c86dea8b524048e","tid":372850,"uid":65931,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-25T03:27:30.000Z","msg":"咬番佢"}]}