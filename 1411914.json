 <br />\n<a href=\"https://drive.google.com/open?id=1xhWT9g5Ab9-H3u8sK-6mWEsyCHKVjPHr&amp;usp=sharing\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdrive.google.com%2Fopen%3Fid%3D1xhWT9g5Ab9-H3u8sK-6mWEsyCHKVjPHr%26usp%3Dsharing&d=UCNXK7Cjp0Jh61Qt1camEGHyg7b2nkJB6fx123wLmsI%3D&h=4bd39ec5\" data-auto-link target=\"_blank\">https://drive.google.com/open?id=1xhWT9g5Ab9-H3u8sK-6mWEsyCHKVjPHr&amp;usp=sharing</a><br />\n金鐘:<br />\n <a href=\"https://drive.google.com/open?id=1A8V3jeqXl6AQIM1Wv7w4_tO5I6adJNxD&amp;usp=sharing\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdrive.google.com%2Fopen%3Fid%3D1A8V3jeqXl6AQIM1Wv7w4_tO5I6adJNxD%26usp%3Dsharing&d=UCNXK7Cjp0Jh61Qt1camEGHyg7b2nkJB6fx123wLmsI%3D&h=2540d668\" data-auto-link target=\"_blank\">https://drive.google.com/open?id=1A8V3jeqXl6AQIM1Wv7w4_tO5I6adJNxD&amp;usp=sharing</a>"},{"pid":"b6795c78a51f60173a72409c106dc07c1afa2753","tid":1411914,"uid":12630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T05:12:11.000Z","msg":"<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"196f79bbe5c2b292ffcabb343cf60a7040a01407","tid":1411914,"uid":113953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T05:19:38.000Z","msg":"Push"},{"pid":"8744beaebdd20610e861bbb0fc2ca37acbe89d83","tid":1411914,"uid":113953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T05:45:37.000Z","msg":"Push"},{"pid":"0954f5ea216a5f86caf175dbb714b29e4bb235b6","tid":1411914,"uid":113953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T07:13:18.000Z","msg":"Push"},{"pid":"a88270656c84d76362f9c6e2b397931f1ceb5ffd","tid":1411914,"uid":272569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T08:34:31.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"e5d2df7cab9b943b3a865f36c8b63b1ce87d9731","tid":1411914,"uid":113953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T13:02:59.000Z","msg":"推"},{"pid":"a1d87371cb43e030e9cdf3fc81b43f4de645224e","tid":1411914,"uid":276555,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T17:52:58.000Z","msg":"推"},{"pid":"047eedb5655c95ff42e0abb8e9973bd4525e9321","tid":1411914,"uid":77803,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T17:57:36.000Z","msg":"寫緊戰略map app<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"7b086d6e00f5b43d5513c0b828ba4797a884cd0b","tid":1411914,"uid":208156,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T18:31:53.000Z","msg":"推！"}]}