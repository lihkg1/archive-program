/www.youtube.com/watch?v=Q5fu9LH8NIk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DQ5fu9LH8NIk&d=h8K6dYNnEA4rSgnLcindhWmu51%2BDyw7Majob2ybULac%3D&h=d59d00cb\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=Q5fu9LH8NIk</a>"},"citedBy":0,"replyTime":"2021-01-01T06:30:54.000Z","msg":"自己冇料就摺撚埋一邊啦<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />學人唱愛是懷疑<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5a0d49fddb1d5c560e8916b4cb01293ed1793eef","tid":2348671,"uid":32410,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2021-01-01T06:32:22.000Z","msg":"點解依家連登咁多大陸show 大陸vedio討論<img src=\"/assets/faces/mousexm/awake.gif\" class=\"hkgmoji\" /><br />\n你依家上台做歌手wor！職業歌手？<img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" /> 咩叫咁已經算好 咁都收貨？ 大陸人食開屎姐<br />\n利申：聽慣以前啲歌"},{"pid":"83df8c2de6610a5691d994bd63ca9016517dcd75","tid":2348671,"uid":80203,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2021-01-01T06:35:10.000Z","msg":"深女的花 我上邀戴你回架"},{"pid":"df7e3326d6c58816b4c73cbb18c339894a322810","tid":2348671,"uid":177313,"like":0,"dislike":1,"score":-1,"quote":{"pid":"4272f935b45e0eef22e08065166cc057bac4d58e","tid":2348671,"uid":98507,"like":11,"dislike":1,"score":10,"citedBy":3,"replyTime":"2021-01-01T05:07:37.000Z","msg":"<a href=\"https://youtu.be/UITzWlYD8v8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FUITzWlYD8v8&d=h8K6dYNnEA4rSgnLcindhWmu51%2BDyw7Majob2ybULac%3D&h=0bde5c15\" data-auto-link target=\"_blank\">https://youtu.be/UITzWlYD8v8</a><br />\n<br />\n呢段正d"},"citedBy":0,"replyTime":"2021-01-01T06:36:02.000Z","msg":"唔開心睇觀感真係一流<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"bc64d955dd3d3b5833e1d5fd74c710f16882b255","tid":2348671,"uid":171786,"like":0,"dislike":1,"score":-1,"quote":{"pid":"87be9b1d1ef45265bc43f2d4f26e824b3ebdfc5e","tid":2348671,"uid":78039,"like":112,"dislike":6,"score":106,"citedBy":4,"replyTime":"2021-01