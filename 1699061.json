m/breaking/realtime/article/20191108/60242635\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20191108%2F60242635&d=6wykgBqlsxypO2QI0oCEUrP2tejZlako6KwT%2FyznMNw%3D&h=a6127a1d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20191108%2F60242635&h=36618650\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/breaking/realtime/article/20191108/60242635</a>"},"citedBy":0,"replyTime":"2019-11-08T02:49:01.000Z","msg":"呢啲先係做警察應帶嘅使命感<br />\n望下而家班黑警<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"c72669c105bfe8dd66e75b37b1d117ebf6a92702","tid":1699061,"uid":192848,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-08T02:52:17.000Z","msg":"多謝所有急救員"},{"pid":"4174b48e1ddd7449fb278e0e9cd2777c62d28f98","tid":1699061,"uid":228868,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-08T02:55:53.000Z","msg":"<img src=\"/assets/faces/lm2/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/adore.gif\" class=\"hkgmoji\" />"},{"pid":"682dcb542ef471aea5a5eda104107619e9842e86","tid":1699061,"uid":49669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-08T03:00:20.000Z","msg":"早日康復<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f9e68b9871b5717864baa148e3676c725b06b1a8","tid":1699061,"uid":55089,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-08T03:04:14.000Z","msg":"<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"28e443c11548ba638b45f8348fbc94ae85788937","tid":1699061,"uid":58584,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-08T03:05:48.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid