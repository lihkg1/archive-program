rget=\"_blank\">https://www.youtube.com/watch?v=CsjiZD2E6h0</a><br />\n<br />\n<a href=\"https://youtu.be/YSUtmDHOIPI\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FYSUtmDHOIPI&d=qWNbGjuqVnVY%2B89Bav9Y1CL1bdbhbSvxCnYHZ8iA0HE%3D&h=78693326\" data-auto-link target=\"_blank\">https://youtu.be/YSUtmDHOIPI</a><br />\n<br />\n將呢d translate左佢得唔得?"},{"pid":"4cec007ccf1c425ba0ed21c863c7862f520e93b5","tid":1481103,"uid":26972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T15:46:16.000Z","msg":"818 <img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"34022e3e5d07f90b360b6e4f66eaa7b33e960397","tid":1481103,"uid":26972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T15:46:32.000Z","msg":"818 <img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"d569b0c4e319a5d9e8d6086f19ecb1fc6719afb4","tid":1481103,"uid":26972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T15:49:06.000Z","msg":"818 <img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"050ca129a7ea0f978c9516fa107ff1f1a47dbfdb","tid":1481103,"uid":26972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T17:28:25.000Z","msg":"818<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"878f58779c315523d769ea38e1775c15b177dbba","tid":1481103,"uid":26972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T17:28:35.000Z","msg":"818<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"e76f03807e568657e57e0b5cabf0a5353ec539da","tid":1481103,"uid":26972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T17:28:45.000Z","msg":"818<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"db26a5f546440b3ecde2b444a7c18f28ed120cd2","tid":1481103,"uid":26972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T17:29:23.000Z","msg":"818<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":