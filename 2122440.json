員要制服疑人，但質疑警員無留意壓住疑人頸部的做法很危險。<br />\n救護員在警車內為一名男子檢查，發現他當時沒有呼吸脈搏後進行急救<br />\n<a href=\"https://hk.appledaily.com/local/20200511/NLLG6DNWTNJP4YZEEI6FXMPT24/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200511%2FNLLG6DNWTNJP4YZEEI6FXMPT24%2F&d=7JJHJI7m8dwGfBTVwC1i6MdEKmWGZzYthIwftZf8Bt0%3D&h=812a1205\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200511%2FNLLG6DNWTNJP4YZEEI6FXMPT24%2F&h=44875bc1\" target=\"_blank\">https://hk.appledaily.com/local/20200511/NLLG6DNWTNJP4YZEEI6FXMPT24/</a>"},{"pid":"8714b360f0102d9bc8e3509ccdc6ebbef87b0e84","tid":2122440,"uid":145273,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-24T04:10:42.000Z","msg":"推"},{"pid":"7f851a738b656bdb98532e4533dc10fd935afaa2","tid":2122440,"uid":64337,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-24T04:10:44.000Z","msg":"推<img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" />"},{"pid":"e347da7281d75bd8a415950c11fd5521f50cddf7","tid":2122440,"uid":285371,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-24T04:10:46.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"222487e58758cf2aaed0b353cc7777cd57e606af","tid":2122440,"uid":210755,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-24T04:10:54.000Z","msg":"會唔會有議員跟進下....雖然有啲好多年前"},{"pid":"5e70c543254e91f43e0779d22eed6bdbf22b3376","tid":2122440,"uid":70888,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-24T04:11:00.000Z","msg":"推"},{"pid":"a37226473de5e83751d997416b3c7c1be565c217","tid":2122440,"uid":230104,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-24T04:11:44.000Z","msg":"個個都係犯罪專家"},{"pid":"c9814b12a9567a8864debd299e97b159f9fab3d3","tid":2122440,"uid":78060,"like":0,"dislike":1,"score":-1,"citedBy":0,"re