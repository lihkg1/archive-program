":"d8d6657eab4993218a46514b18c61f45e5157df1","tid":1476622,"uid":106851,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T01:20:46.000Z","msg":"推"},{"pid":"d81b20a430c34a9f9cf1b3869915235494dbd4a4","tid":1476622,"uid":51271,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-08-16T01:20:53.000Z","msg":"<a href=\"https://hk.on.cc/hk/bkn/cnt/news/20190816/bkn-20190816082904816-0816_00822_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20190816%2Fbkn-20190816082904816-0816_00822_001.html&d=veK8Cd5y3rx0%2F3TK36JPErccVloK1XwbfTGMhSGe0oU%3D&h=d2b3cc90\" data-auto-link target=\"_blank\">https://hk.on.cc/hk/bkn/cnt/news/20190816/bkn-20190816082904816-0816_00822_001.html</a><br />\n<br />\n警方本周日(11日)在港鐵葵芳站內施放催淚彈，做法惹來抨擊。有網民今早(16日)發起到葵芳站進行月台清潔行動，以示不滿警方做法，又要求港鐵譴責警方，及封站進行徹底清潔，並由第三方機構證明站內環境安全。早上7時許，葵芳站內有人戴上口罩，帶同抹布及水桶清潔牆壁。至近9時，參與清潔行動人士由2人增至約7人，他們用抹布清潔售票機及風扇等位置。<br />\n<br />\n有人在站內一塊告示牌上，貼上一張模仿港鐵告示的海報，稱葵芳站因受催淚彈攻擊暫緩服務，引來大批市民圍觀。有港鐵職員其後撕走海報，澄清非由港鐵發布。<br />\n<br />\n居於油麻地的陳先生響應網上呼籲，帶同掃把及抹布前來清潔。有港鐵職員一度上前與他交涉，向其解釋港鐵已進行清潔，但未有阻撓其行動。陳表示，作為乘客亦希望確保港鐵環境安全，雖然知道港鐵有清潔，相信他們自發可清潔得更仔細，「可能好多老人家、小朋友健康會受影響，要為佢哋着想」。<br />\n<br />\n他又對警方在站內發射催淚彈，罔顧市民安全表示不滿，「如果你真係覺得安全，一係就叫警方幾位阿sir出嚟，用手摸吓又好，掂吓又好，真係要落區睇囉」！ <br />\n<br />\n<img src=\"https://hk.on.cc/hk/bkn/cnt/news/20190816/photo/bkn-20190816082904816-0816_00822_001_01b.jpg?20190816090221\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20190816%2Fphoto%2Fbkn-20190816082904816-0816_00822_001_01b.jpg%3F20190816090221&h=873dcc85&s={SIZE}\" /><br />\n<br />\n<img src=\"https://hk.on.cc/hk/bkn/cnt/news/20190816/photo/bkn-20190816082904816-0816_00822_001_02b.jpg?20190816090221\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20190816%2Fphoto%2Fbkn-20190816082904816-0816_00822_001_02b.jpg%3F20190816090221&h=df2365ad&s={SIZE}\" /><br />\n<br />\n<img src=\"https://hk.on.cc/hk/bkn/cnt/news/20190816/photo/bkn-20190816082904816-0816_00822_001_03b.jpg?20190816090221\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20190816%2Fphoto%2Fbkn-20190816082904816-0816_00822_001_03b.jpg%3F20190816090221&h=5e06008a&s={SIZE}\" />"},{"pid":"01f59ba61140cef0070dee77ee2cdf9dd473be38","tid":1476622,"uid":13581,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T01:22:31.000Z","msg":"辛苦曬各位遍民<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/DMh70kj.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDMh70kj.jpg&h=2feb58bc&s={SIZE}\" /><br />\n<br />\n<img src=\"https://na.cx/i/PcjRHyE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPcjRHyE.jpg&h=932bd70a&s={SIZE}\" /><br />\n<br />\n齊來參與instagram同facebook嘅 #全城㩒美元 #USDchallenge 啦<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n一齊把愛傳出去，令更多人係ig同fb見到，之後㩒美元<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n［突發］有人起ig搞左個「#全城㩒美元」挑戰<br />\n<a href=\"https://lih.kg/1476098\" target=\"_blank\">https://lih.kg/1476098</a>"},{"pid":"fe1efe7ed72685cca32e63c365c2426da249a358","tid":1476622,"uid":62164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T01:23:35.000Z","msg":"辛苦晒各位巴絲<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"1b8ade7a6ea0c054ada97f95c32106e53547d704","tid":1476622,"uid":176121,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c166959bf659c4ed2eae7b6d62e06b2384de0ff","tid":1476622,"uid":51271,"like":1,"dislike":0,"score":1,"quote":{"pid":"f36a6589c065f75e73da901a9aed744c08220307","tid":1476622,"uid":176121,"like":0,"dislike":2,"scor