mal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"7889e7ac628bd2933ca9b1bc467b82df511724c4","tid":616761,"uid":85056,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd1ebd0dd0bda92730770457ab83eb536169338b","tid":616761,"uid":214,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T14:08:26.000Z","msg":"56 .2 啦 包你唔會後悔"},"citedBy":1,"replyTime":"2018-04-04T14:29:16.000Z","msg":"巴打唔好介意我新手想問下<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> :<br />\n56.2係咪就係56mm f1.2?"},{"pid":"85a06dc6bbc3f76f07092c8e39f4bdaa6c55567a","tid":616761,"uid":125752,"like":0,"dislike":0,"score":0,"quote":{"pid":"7889e7ac628bd2933ca9b1bc467b82df511724c4","tid":616761,"uid":85056,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd1ebd0dd0bda92730770457ab83eb536169338b","tid":616761,"uid":214,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T14:08:26.000Z","msg":"56 .2 啦 包你唔會後悔"},"citedBy":1,"replyTime":"2018-04-04T14:29:16.000Z","msg":"巴打唔好介意我新手想問下<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> :<br />\n56.2係咪就係56mm f1.2?"},"citedBy":0,"replyTime":"2018-04-04T15:10:39.000Z","msg":"係<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"52f5aa12dec0ab4b5a09c05c51eda1629a7feb34","tid":616761,"uid":85056,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T17:27:01.000Z","msg":"用左巴打個網<br />\n直接入部機model去睇<br />\n我用平時影同被影者距離3-4米左右咁計<br />\n影全身要得呢兩隻OK:<br />\nXF23mmF1.4 R<br />\nXF35mmF1.4 R<br />\n<br />\n但咁多巴打推薦56mm F1.2<br />\n個網顯示要起碼5.8米先影到全相<br />\n係咪有咩我冇考慮到<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"dea62ebaff7b15b0827cba7faa4223b57855e1cd","tid":616761,"uid":214,"like":0,"dislike":0,"score":0,"quote":{"pid":"52f5aa12dec0ab4b5a09c05c51eda1629a7feb34","tid":616761,"uid":85056,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T17:27:01.000Z","msg":"用左巴打個網<br />\n直接入部機model去睇<br />\n我用平時影同被影者距離3-4米左右咁計<br />\n影全身要得呢兩隻OK:<br />\nXF23mmF1.4 R<br />\nXF35mmF1.4 R<br />\n<br />\n但咁多巴打推薦56mm F1.2<br />\n個網顯示要起碼5.8米先影到全相<br />\n係咪有咩我冇考慮到<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-04T17:39:05.000Z","msg":"其實你企既範圍好細定點<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /> 我買56之前都有諗35 不過我知道我買咗35過一排又會諗下支56 所以最後都係直接買56算 加上比我朋友借我打咗兩三張 即刻中毒 再無諗35<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f86f4750cb6c287af118dcae87d5bf9ef5cafff5","tid":616761,"uid":85056,"like":0,"dislike":0,"score":0,"quote":{"pid":"dea62ebaff7b15b0827cba7faa4223b57855e1cd","tid":616761,"uid":214,"like":0,"dislike":0,"score":0,"quote":{"pid":"52f5aa12dec0ab4b5a09c05c51eda1629a7feb34","tid":616761,"uid":85056,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T17:27:01.000Z","msg":"用左巴打個網<br />\n直接入部機model去睇<br />\n我用平時影同被影者距離3-4米左右咁計<br />\n影全身要得呢兩隻OK:<br />\nXF23mmF1.4 R<br />\nXF35mmF1.4 R<br />\n<br />\n但咁多巴打推薦56mm F1.2<br />\n個網顯示要起碼5.8米先影到全相<br />\n係咪有咩我冇考慮到<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-04T17:39:05.000Z","msg":"其實你企既範圍好細定點<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /> 我買56之前都有諗35 不過我知道我買咗35過一排又會諗下支56 所以最後都係直接買56算 加上比我朋友借我打咗兩三張 即刻中毒 再無諗35<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-04T17:47:33.000Z","msg":"因為以前用開機仔同佢影開都係企3-4米左右<br />\n有時studio主要影佢D動作, 距離都係差唔多, <br />\n但有時喺街去到某D位有FEEL想快影<br />\n我係幻想拿拿臨叫佢企好<br />\n以用最少既地方影完就走<br />\n諗如果要企後成6米<br />\n可能要搞一輪又或者阻到人/俾人阻<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n我考慮點係:<br />\n短焦 (23mm) 我想影多D人最多行近, 全身就行到3-4米已經得<br />\n但長焦 (55mm) 我想影全身要行到差唔多6米<br />\n<br />\n真係未玩過定焦機, 所以全屬估計<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 唔知有冇諗漏<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"55fc40a4ebcd0a1530b043f89ea409cc42d76b02","tid":616761,"uid":214,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T17:49:06.000Z","msg":"同埋支35 .4 對焦好似係慢啲 同好似會向前向後（係咪叫拉風箱<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /> ）好似唔夠smooth 咁 <br />\n你話企前企後個個問題我又唔係好介意 你長插一支好快慣 除非你話你影yoga可能地方有限 但買咗支56之後我先知啲人話咩鏡重要個body 我終於都明 (之前用kit )<br />\n利申：我都係新手"},{"pid":"9a09d5b8b8f3c9b66227adb7241ce2013ed4a8c1","tid":616761,"uid":11116,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T18:14:31.000Z","msg":"35mm(23) 50mm(35) 85mm(56) <br />\n大光圈鏡頭都好常用<br />\n各有各好，對面形、背景壓縮感影響<br />\n<br />\n如果香港地百答應該35mm(23)會好d，室內 室外<br />\n但背景壓縮放大+散景應該 量85(56)好d"},{"pid":"50eb91673412d67357ddb04a1b953f34353a01e6","tid":616761,"uid":85056,"like":0,"dislike":0,"score":0,"quote":{"pid":"55fc40a4ebcd0a1530b043f89ea409cc42d76b02","tid":616761,"uid":214,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T17:49:06.000Z","msg":"同埋支35 .4 對焦好似係慢啲 同好似會向前向後（係咪叫拉風箱<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /> ）好似唔夠smooth 咁 <br />\n你話企前企後個個問題我又唔係好介意 你長插一支好快慣 除非你話你影yoga可能地方有限 但買咗支56之後我先知啲人話咩鏡重要個body 我終於都明 (之前用kit )<br />\n利申：我都係新手"},"citedBy":0,"replyTime":"2018-04-04T18:25:33.000Z","msg":"Thanks巴打! 我會再比較下<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"94d860d23f0834332d34bc0b40c757ef3c0a4a94","tid":616761,"uid":85056,"like":0,"dislike":0,"score":0,"quote":{"pid":"9a09d5b8b8f3c9b66227adb7241ce2013ed4a8c1","tid":616761,"uid":11116,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T18:14:31.000Z","msg":"35mm(23) 50mm(35) 85mm(56) <br />\n大光圈鏡頭都好常用<br />\n各有各好，對面形、背景壓縮感影響<br />\n<br />\n如果香港地百答應該35mm(23)會好d，室內 室外<br />\n但背景壓縮放大+散景應該 量85(56)好d"},"citedBy":1,"replyTime":"2018-04-04T18:27:42.000Z","msg":"35mm(23) 50mm(35) 85mm(56)<br />\n<br />\n巴打呢度後面括號係咪 鏡標出黎個焦距, 前面數字係實際出黎既?<br />\n想問係咪所有無反機都係 鏡標出黎個焦距 X 1.5 就係實際焦距? <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4e6f2fd738317fabb3f5234fba6650bc3b96eabb","tid":616761,"uid":85056,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04