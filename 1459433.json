03bbaf8f841f8","tid":1459433,"uid":169079,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-12T18:08:17.000Z","msg":"過幾日就會有炸彈"},"citedBy":3,"replyTime":"2019-08-12T18:09:44.000Z","msg":"放炸彈依招好大機會用，屈示威者放."},"citedBy":1,"replyTime":"2019-08-12T18:12:33.000Z","msg":"之後又多幾十國家放旅遊警示、信貸評級降、股市直插。。。"},{"pid":"b68d731d582279bd533113e4a61d2e81dacd2b82","tid":1459433,"uid":285371,"like":0,"dislike":0,"score":0,"quote":{"pid":"377f60b0caf36df99cf3a90492de287d62f18d51","tid":1459433,"uid":189695,"like":1,"dislike":0,"score":1,"quote":{"pid":"448f534c6c1fdce03fde8b098f4f8cfef32dd7f6","tid":1459433,"uid":140335,"like":7,"dislike":0,"score":7,"citedBy":2,"replyTime":"2019-08-12T17:44:57.000Z","msg":"又係混入之後帶頭搞事<br />\n<br />\n有機會係搵狗扮旅客落去推住行李<br />\n之後出到接機大堂<br />\n叫佢地啲臥狗係前面舉牌<br />\n之後旅狗就同佢哋啲臥狗嘈交<br />\n「屌你班人搞亂香港！」等等標準藍絲字句<br />\n互屌之後互相打架<br />\n製造混亂 之後叫埋其他人黎幫手<br />\n<br />\n當其他人上到黎之後<br />\n臥狗就混入人群當中退後<br />\n之後人群當中向旅客扔野<br />\n<br />\n之後機場特狗或防暴犬見到有人扔野<br />\n就即刻衝過黎<br />\n前面同旅狗嘈緊嘅人就被防暴犬同特狗互兇<br />\n<br />\n呢個時候 旅狗只要一拳打落其中一個和理非到<br />\n再派特狗同防暴犬保護帶走<br />\n在場和理非就會即刻衝上次理論<br />\n<br />\n特狗同防暴犬就可以順理成章話<br />\n「示威者衝擊警方防線」<br />\n而係機場入面為左「保護市民及旅客安全」<br />\n就用近身武器同拘捕<br />\n聽日記者會就話<br />\n「昨天大量示威者聚集機場，及與警方發生衝突，由於事件影響到香港國際機場入面嘅市民同旅客，機管局已經應警方安排，將離境同入境大堂暫時停止開放給予公眾人士，如要前往該區，必須出示24小時內有效登機證；接機人士，必須提供接機者航班編號及姓名，以只準一名接機者前往接機大堂，而等候時間不能超過3小時。如未能提供有效登機證或接機證明，則未能安排進入機場範圍。」<br />\n<br />\n啲狗知道玩混入好有效<br />\n而且混入完行動 唔需要同你班底等賤民交待<br />\n一定會有排用呢招<br />\n大家一定要做和理非咁去機場「和你飛」！<br />\n<br />\n<img src=\"https://na.cx/i/iuZJUoS.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiuZJUoS.jpg&h=350b0f7c&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-08-12T17:52:01.000Z","msg":"巴打好詳細，相信好快會發生。<br />\n<br />\n<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-12T18:13:13.000Z","msg":"坐定定有人帶風向/有警察黎都唔好起哄, 警察最多捉你起身，鏡頭會影曬<br />\n記得委任證通例係20 章14 節"},{"pid":"eebe22a0b6dae2bdfc254578127c1ff17399467f","tid":1459433,"uid":36089,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T18:13:21.000Z","msg":"求求大家，盡快去換美元現鈔！<br />\n<a href=\"https://lih.kg/1429581\" data-auto-link target=\"_blank\">https://lih.kg/1429581</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"3fe70a1a10c944fee93f89ed55e8706be60b9f57","tid":1459433,"uid":189695,"like":2,"dislike":0,"score":2,"quote":{"pid":"09a612dcb221a54952b4c6f7deb522281f4e8df7","tid":1459433,"uid":38804,"like":0,"dislike":0,"score":0,"quote":{"pid":"1de8e3636ab56af4c3bd4c9b53c03bbaf8f841f8","tid":1459433,"uid":169079,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-12T18:08:17.000Z","msg":"過幾日就會有炸彈"},"citedBy":3,"replyTime":"2019-08-12T18:09:44.000Z","msg":"放炸彈依招好大機會用，屈示威者放."},"citedBy":0,"replyTime":"2019-08-12T18:13:59.000Z","msg":"今日記者會話臥底唔會做犯法野架！<br />\n<br />\n<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"9737eb7699bc8cfc9c498ad55658f0a8b7242f85","tid":1459433,"uid":189695,"like":0,"dislike":0,"score":0,"quote":{"pid":"9f3fca811953703795e8137350af2f85f68437f0","tid":1459433,"uid":238745,"like":0,"dislike":0,"score":0,"quote":{"pid":"09a612dcb221a54952b4c6f7deb522281f4e8df7","tid":1459433,"uid":38804,"like":0,"dislike":0,"score":0,"quote":{"pid":"1de8e3636ab56af4c3bd4c9b53c03bbaf8f841f8","tid":1459433,"uid":169079,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-12T18:08:17.000Z","msg":"過幾日就會有炸彈"},"citedBy":3,"replyTime":"2019-08-12T18:09:44.000Z","msg":"放炸彈依招好大機會用，屈示威者放."},"citedBy":1,"replyTime":"2019-08-12T18:12:33.000Z","msg":"之後又多幾十國家放旅遊警示、信貸評級降、股市直插。。。"},"citedBy":0,"replyTime":"2019-08-12T18:15:20.000Z","msg":"好過分....<br />\n<br />\n<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"13ba7a57fb3ed6ec72f91f55f5e389ddf7f8790a","tid":1459433,"uid":102732,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-12T18:15:52.000Z","msg":"我認為, 唔會係機場出手<br />\n<br />\n好大機會又玩帶風向, 引你地出返去市區再捉<br />\n<br />\n機場好大機會係冷處理"},{"pid":"e08a6909d4ee03651828ac429066b5e4fa7111ce","