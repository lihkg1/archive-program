8e76e063af454f6704e9af509d8","tid":1418041,"uid":34742,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-05T18:36:35.000Z","msg":"此回覆已被刪除"},{"pid":"19db26649dfbea62811fd3072dcff044a95bdee3","tid":1418041,"uid":206284,"like":0,"dislike":0,"score":0,"quote":{"pid":"169eadcd950488e76e063af454f6704e9af509d8","tid":1418041,"uid":34742,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-05T18:36:35.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-08-05T18:50:29.000Z","msg":"見到有互diu post<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n有啲似928後期自我分化既感覺<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><br />\n<br />\n所以先想大家入黎傾下兩邊係點睇近幾次既行動<br />\n同想大家冷靜下<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n自己尋晚同今朝都好嬲嫁<br />\n但咁既時候真係要更冷靜<img src=\"/assets/faces/fs/fozen_smile.gif\" class=\"hkgmoji\" /><br />\n返去理性討論而唔係互屌"},{"pid":"a72fc101df0d34ba5a70e8de6dcf29ba8ff276d5","tid":1418041,"uid":206284,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T04:58:55.000Z","msg":"推<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><br />\n咪撚到開post互屌"}]}