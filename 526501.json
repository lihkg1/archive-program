ts/faces/lomoji/29.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-12T00:07:00.000Z","msg":"好奇  香港波都有人開盤<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"c88d366129298e222c16ea6a0c1b4ce46287065b","tid":526501,"uid":124899,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-12T00:17:09.000Z","msg":"拉得"},{"pid":"e31ab8a29ddb8b2509ef34548cd97b77982c12d4","tid":526501,"uid":85984,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-12T00:29:01.000Z","msg":"屌d大陸佬，返大陸啦，打假波，大陸狗改不了食屎"},{"pid":"a5c91ee15957ee94956a9d1bf81fbd6509569ca5","tid":526501,"uid":124899,"like":0,"dislike":0,"score":0,"quote":{"pid":"6fd18a25515f1bb18c69fccd9bd0996c57163120","tid":526501,"uid":6347,"like":2,"dislike":3,"score":-1,"citedBy":2,"replyTime":"2018-01-11T18:57:04.000Z","msg":"唔係好明，沒拿香港身份咁點剪身份證？"},"citedBy":0,"replyTime":"2018-01-12T00:30:17.000Z","msg":"香港身份響大陸人眼中係永久居民吧<br />\n佢都無「證」字，身份，唔係身份證"},{"pid":"b97e7a40cc8ff54b9bd1153226ebd13cfd9921e1","tid":526501,"uid":16147,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-12T00:31:58.000Z","msg":"有無人搵到佢微博之類叫佢返香港自首?"},{"pid":"f8e6df5fc1ae1be64bdd80c0ec38f1e6893bd9cd","tid":526501,"uid":54424,"like":1,"dislike":0,"score":1,"quote":{"pid":"732786c428a900e3f14c87eaa5b9fbeb8e91c80d","tid":526501,"uid":5195,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-11T16:18:02.000Z","msg":"<img src=\"https://cdn.thestandnews.com/media/photos/cache/laui23_w6pNF_1200x0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2Flaui23_w6pNF_1200x0.png&h=3c11d296&s={SIZE}\" /><br />\n<br />\n來自內地的前港超聯賽球員劉松偉，繼批評港隊及港隊教練金判坤之後，在Instagram上載一張剪爛的香港身份證、往來港澳通行證的相片，並寫上「一群不懂足球又要發洩的可憐球迷 慢慢吠吧 沒拿香港身份是這輩子做的最正確的決定 沒有之一」，結果引起不少香港網民留言辱罵。<br />\n<br />\n劉松偉早前在中國隊擊敗韓國隊後於Instagram留言，問「你香港要過多少年才做到」，又說港隊教練金判坤「只配給後人留笑話」，以「中國牛逼！香港傻逼！」作結，結果惹來過百名網民辱罵，事件再次被牽扯到中港矛盾。<br />\n<br />\n今年28歲的後衛劉松偉，效力流浪足球會多年，上年在「標準流浪」球風勇悍，表現令人印像深刻。但現時流浪足球會的足總網站專頁上，擁有球衣號碼的大軍名單上，已不見劉松偉的名字。<br />\n<br />\n早前有香港足球代表隊成員白鶴宣佈退出港隊，更表示不會歸隊，直到「香港代表隊不再由（韓國人金教練）帶領為止」，他事後解釋是「尊重」問題，「不存在政治」。"},"citedBy":0,"replyTime":"2018-01-12T00:33:32.000Z","msg":"剪得好 千祈咪再黎香港"},{"pid":"23759e47f45202fae305166e36bf4858c3f9b77c","tid":526501,"uid":77196,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-12T00:42:23.000Z","msg":"死監躉冇拎香港身份，對香港係最正確嘅決定 <img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" />"},{"pid":"a81241c8d689468c0a36b54845a47de3cb8b0297","tid":526501,"uid":44525,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-01-12T00:44:02.000Z","msg":"沒拿香港身份是這輩子做的最正確的決定 沒有之一<br />\n冇拎又點會有張身份證俾佢剪呢"},{"pid":"387fcb1c914d8d76f54d192329a908b7dabdff54","tid":526501,"uid":60187,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-01-12T00:46:17.000Z","msg":"當中國隊威威贏南韓<br />\n香港又不屬於中國了<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"bd10cba8ba9827fac084d70b4a27ba0843738860","tid":526501,"uid":72827,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-12T00:54:03.000Z","msg":"乜水？"},{"pid":"86041ab4d03a0cd6541856a77ae716937cf89b30","tid":526501,"uid":14918,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-12T01:05:34.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"75279d80e2937e8a0b0614518f807a2097aea777","tid":526501,"uid":24607,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-01-12T01:08:12.000Z","msg":"言下之意係Hong Kong is not China"},{"pid":"765453c3930f80943cf484b569d439344ec50763","tid":526501,"uid":1977,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-12T01:12:11.000Z","msg":"好野<br />\n又一件垃圾躝返中國😂"},{"pid":"386acc3c8b4d5e9a033b62839e77a942c3820a74","tid":526501,"uid":29167,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-12T01:18:00.000Z","msg":"要潛逃 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/a