id":"e4fb8b833dd137e581a047e7e2dc2cfa5a5574a0","tid":2454920,"uid":240861,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-23T09:10:45.000Z","msg":"高汁post<br />\n細過有諗過無端 係咪類似廣東話無端端 既一個類似方向<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"96a0c1c02f38f393601586e0b8f33dc2d03761fd","tid":2454920,"uid":17335,"like":0,"dislike":0,"score":0,"quote":{"pid":"0150026984bcc828080a83653c212eaedf02133a","tid":2454920,"uid":347176,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-21T16:22:18.000Z","msg":"高汁<br />\n多謝花時間分享<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-23T15:48:13.000Z","msg":"<img src=\"/assets/faces/cow/plan.gif\" class=\"hkgmoji\" />小事<br />\n多謝巴打G持"},{"pid":"eb8ed855c2ecc2c862a3641e8344a44f88632d00","tid":2454920,"uid":17335,"like":0,"dislike":0,"score":0,"quote":{"pid":"02d0393340a52ff48b2aeffe02f9be1f4e2a7ba2","tid":2454920,"uid":7721,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-22T02:27:29.000Z","msg":"推咗先睇<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-23T16:17:14.000Z","msg":"<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />睇完未"},{"pid":"dce9f66d3de75f3b16e9714b114b2a49361a0aa1","tid":2454920,"uid":12661,"like":1,"dislike":0,"score":1,"quote":{"pid":"9aa06f30edf227af8bebbd3222b43fe1361830f0","tid":2454920,"uid":39459,"like":2,"dislike":31,"score":-29,"citedBy":3,"replyTime":"2021-03-20T15:39:36.000Z","msg":"歷史上咁多大文豪都解唔通嘅詩，垃圾連登仔開 post 教人讀<br />\n唔知邊度來嘅自信"},"citedBy":0,"replyTime":"2021-03-23T19:20:46.000Z","msg":"大文豪解唔通，咁就唔好再去解？呢啲係咩邏輯？<br />\n<br />\n一句＂垃圾連登仔＂，唔知論據何在？呢位巴打有冇追開樓主嘅po？我又可唔可以斗膽講句：呢位巴打垃圾都不如？<br />\n<br />\n樓主已經開宗明義話，呢首名作有好多唔同嘅分析，甚至舉出梁啓超嘅不可解論，喺咁嘅前提下，提出一己之見俾其他巴打多一個欣賞嘅角度，有咩問題？<br />\n<br />\n喺戈登探長巴打嘅po，留言同人嘈，我都自覺失禮，不過實在不吐不快，罪過罪過&hellip;"},{"pid":"e4ef61bc9688fdff9e4f0fd84e2b05defc68b1f3","tid":2454920,"uid":17335,"like":1,"dislike":0,"score":1,"quote":{"pid":"07bec00aaf49bd2e53e57ebfdb330c45ac15d50c","tid":2454920,"uid":258903,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-03-22T02:51:16.000Z","msg":"呢首詩讀完唔知想講乜<br />\n但就句句都覺得靚到不得了<br />\n中間四句都有向上一個維度突破既感覺<br />\n望住首詩就好似1905 年既人第一次見到相對論咁<br />\n好空靈<br />\n<br />\n個人認為唐詩中既第一，沒有之一"},"citedBy":1,"replyTime":"2021-03-24T15:59:03.000Z","msg":"李商隱開拓唐詩華麗隱約嘅詩境<br />\n單以無題論，已經係一絕，好多首都正<br />\n除咗個人才華，古典詩文化傳統都好重要<br />\n無咗佢引嘅幾個典故故事，首詩就無咁厚實<br />\n詩人既係天才，天才亦要返文化配合<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"7966526e26cd98bd8c4e01cff4bc8a931e2689ef","tid":2454920,"uid":258903,"like":0,"dislike":0,"score":0,"quote":{"pid":"e4ef61bc9688fdff9e4f0fd84e2b05defc68b1f3","tid":2454920,"uid":17335,"like":1,"dislike":0,"score":1,"quote":{"pid":"07bec00aaf49bd2e53e57ebfdb330c45ac15d50c","tid":2454920,"uid":258903,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-03-22T02:51:16.000Z","msg":"呢首詩讀完唔知想講乜<br />\n但就句句都覺得靚到不得了<br />\n中間四句都有向上一個維度突破既感覺<br />\n望住首詩就好似1905 年既人第一次見到相對論咁<br />\n好空靈<br />\n<br />\n個人認為唐詩中既第一，沒有之一"},"citedBy":1,"replyTime":"2021-03-24T15:59:03.000Z","msg":"李商隱開拓唐詩華麗隱約嘅詩境<br />\n單以無題論，已經係一絕，好多首都正<br />\n除咗個人才華，古典詩文化傳統都好重要<br />\n無咗佢引嘅幾個典故故事，首詩就無咁厚實<br />\n詩人既係天才，天才亦要返文化配合<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-24T16:24:45.000Z","msg":"話係開拓，但真正後無來者~<br />\n<br />\n以寫詩技巧同修辭而言，佢應該同杜甫並列第一，遠遠抛離其他詩人<br />\n當年上lecture,  呢首錦瑟，lecturer 用N個角度講呢首詩，個半鐘都未講完，無題中最深最廣既一首"},{"pid":"ed70b857d7eb9d7c7bc89c2a8eaccc1c3c9f904f","tid":2454920,"uid":49057,"like":0,"dislike":0,"score":0,"quote":{"pid":"7966526e26cd98bd8c4e01cff4bc8a931e2689ef","tid":2454920,"uid":258903,"like":0,"dislike":0,"score":0,"quote":{"pid":"e4ef61bc9688fdff9e4f0fd84e2b05defc68b1f3","tid":2454920,"uid":17335,"like":1,"dislike":0,"score":1,"quote":{"pid":"07bec00aaf49bd2e53e57ebfdb330c45ac15d50c","tid":2454920,"uid":258903,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime"