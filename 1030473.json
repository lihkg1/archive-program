030473,"uid":73269,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-21T05:10:30.000Z","msg":"日日說慌"},{"pid":"cece676c26b8bb95e7e65b12c2d0e7ee9fb2f243","tid":1030473,"uid":213597,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-21T05:10:49.000Z","msg":"此回覆已被刪除"},{"pid":"8dc11562997a159a46c8d81eb1a1e84b6f3a97aa","tid":1030473,"uid":59283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-21T05:13:11.000Z","msg":"但係中國會攞你料<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}