ps://na.cx/i/NQFFFnr.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNQFFFnr.jpg&h=035382dd&s={SIZE}\" />"},{"pid":"7d2ceb085b46e97ace73981ae93926dc85fc6707","tid":1951232,"uid":57597,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-31T01:00:28.000Z","msg":"大家準備好硬食啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"269b978fb9af97eec3e032619bc3d42c8dc1cacc","tid":1951232,"uid":288979,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-31T01:02:26.000Z","msg":"香港真係唔係人人屋企都森美咁大空間隔離"},{"pid":"7c22728c2eeed7c7c6e3745f7bcd66c99b64aa0c","tid":1951232,"uid":50041,"like":1,"dislike":0,"score":1,"quote":{"pid":"afaf1961d8510a8bab7cc29c2cc7fe8f8654cf3c","tid":1951232,"uid":57597,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-03-31T00:58:31.000Z","msg":"<img src=\"https://na.cx/i/NQFFFnr.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNQFFFnr.jpg&h=035382dd&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-03-31T01:02:58.000Z","msg":"成堆後生仔留學生<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"58cdf8592d399fee417fe9aa2d9aaafc9bf6077b","tid":1951232,"uid":346806,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-31T01:03:22.000Z","msg":"新屋嶺又唔用？？？<br />\n狗屎正苦"},{"pid":"2ae4d8b632a8cf5fdd689e548f93a2ee55a42527","tid":1951232,"uid":346806,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-03-31T01:05:46.000Z","msg":"P佢個k<br />\n有樣嘢黃世澤講得岩<br />\n留學生根本唔應該返嚟<br />\n留喺原地好過返嚟攬炒<br />\n不過班留學生返嚟十成又係d直升機家長搞出嚟啦<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e178588c6a4513a1369f92a0812672df7b3c17e2","tid":1951232,"uid":57597,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-03-31T01:08:59.000Z","msg":"其實唔送院都可以送一個集中處理確診病人嘅地方先 <br />\n將病人留係係社區係咩玩法啊"},{"pid":"855b0d6ecc828eaffe67fc7733771e35114d4bc6","tid":1951232,"uid":57597,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-31T01:11:52.000Z","msg":"Push 想大家知道呢個事實"},{"pid":"8655d3cae4b3ca2d2e838697d1e9e905bf45b322","tid":1951232,"uid":57597,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-31T01:12:35.000Z","msg":"唔好出街喇 隨時收皮"},{"pid":"4023c4713e71acc3166b4aa8af52609bfd76895b","tid":1951232,"uid":219244,"like":0,"dislike":0,"score":0,"quote":{"pid":"fda64db46a90083d1f0a10c25c55b9da8cd83c54","tid":1951232,"uid":57597,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-03-31T00:53:52.000Z","msg":"政府想同市民攬炒 直情唔送院"},"citedBy":0,"replyTime":"2020-03-31T01:12:45.000Z","msg":"借位<br />\n依家係時候舉報鋪頭，齊齊攬炒<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />(當然黃店例外)<br />\n<br />\n手足們講左攬炒幾耐？<br />\n<span style=\"color: red;\"><strong>聖誕新年有幾多手足喺商場攬炒而被捕</strong></span>？<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n依家咁難得有一個機會，可<span style=\"color: gold;\"><strong><span style=\"font-size: xx-large;\">以零成本令商界攬炒</span></strong></span>，咁都唔做嘅話對唔對得着手足？<br />\n<br />\n每一區有幾多黃店？有幾多鋪頭反送中時不聞不問冷眼旁觀？如果你係跟足黃店list食實心知肚明<br />\n既然香港處於危難之秋嘅時候佢哋可以<span style=\"color: green;\"><strong>袖手旁觀</strong></span>，咁點解要放過佢哋？？<br />\n就係為咗食飯多啲選擇？？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n你可能覺得我好極端，但攬炒嘅目的唔係為咗報復社會<br />\n純粹係懲罰商界令佢哋同我哋企係同一陣線向政府施加壓力，抗爭左半年你咁都唔明？<br />\n<br />\n1）依家難得商家將矛頭指向政府，set左一條on9 rule<br />\n2）再者少啲鋪頭就變相減少黃店嘅競爭者，增加黃點嘅生意<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n3）亦都係一個好時機定鋪頭變黃<br />\n<br />\n零成本點解唔做？係咪下下要被捕先肯做？<br />\n過咗半年都未有心理準備攬炒？咁獄中手足點算？等待被清算嘅手足點算？<span style=\"color: red;\">你放軟手腳但係中共會放軟手腳</span>"},{"pid":"2f93640dbc0106f45d0ca3a157bd29eb410a8407","tid":1951232,"uid":107405,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ae4d8b632a8cf5fdd689e548f93a2ee55a42527","tid":1951232,"uid":346806,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-03-31T01:05:46.000Z","msg":"P佢個k<br />\n有樣嘢黃世澤講得岩<br />\n留學生根本唔應該返嚟<br />\n留喺原地好過返嚟攬炒<br />\n不過班留學生返嚟十成又係d直升機家長搞出嚟啦<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-31T02:15:20.000Z","msg":"返黎都得 去狗屋參觀下都好<br />\n但依家返黎剩係增加醫護壓力 兼累鳩其他香港人<br />\n擺明唔係真香港人 一係就離地垃圾"},{"pid":"8824215bd4cb1ea99a0a75fbadc28360c7f1adb3","tid":1951232,"uid":346806,"like":0,"dislike":0,"score":0,"quote":{"pid":"2f93640dbc0106f45d0ca3a157bd29eb410a8407","tid":1951232,"uid":107405,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ae4d8b632a8cf5fdd689e548f93a2ee55a42527","tid":1951232,"uid":346806,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-03-31T01:05:46.000Z","msg":"P佢個k<br />\n有樣嘢黃世澤講得岩<br />\n留學生根本唔應該返嚟<br />\n留喺原地好過返嚟攬炒<br />\n不過班留學生返嚟十成又係d直升機家長搞出嚟啦<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-31T02:15:20.000Z","msg":"返黎都得 去狗屋參觀下都好<br />\n但依家返黎剩係增加醫護壓力 兼累鳩其他香港人<br />\n擺明唔係真香港人 一係就離地垃圾"},"citedBy":0,"replyTime":"2020-03-31T03:04:09.000Z","msg":"哈哈，問班pk香港舊年6月開始發生咩事呀？<br />\n佢地應該會答我係英國蒲唔撚知喎sor9ry<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"afaf1961d8510a8bab7cc29c2cc7fe8f8654cf3c","tid":1951232,"uid":57597,"like":2,"dislike":0,"score":2,"citedBy":1,