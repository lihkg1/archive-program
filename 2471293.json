id":"e9c6016927ec45b6665ca6f86daeebe1b784813a","tid":2471293,"uid":137291,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-04-02T03:27:25.000Z","msg":"Hero's Friday"},{"pid":"94e24bcab1d1337233076ac4c8813b446bd0a4ed","tid":2471293,"uid":191843,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-02T04:02:15.000Z","msg":"Honbo"},{"pid":"320d51a234c0ac271243820f7cd30002714c67ae","tid":2471293,"uid":51064,"like":0,"dislike":0,"score":0,"quote":{"pid":"9b44364dd1aeb70814f7155bf10707d4eff48767","tid":2471293,"uid":119810,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2021-04-01T21:51:41.000Z","msg":"<span class=\"xx-large\">cool cousins<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /></span>"},"citedBy":1,"replyTime":"2021-04-02T04:06:32.000Z","msg":"呢間好好食 個人推薦佢個豬腩burger <img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"90fe0c0921ee278e1976523f34e551777fb8963b","tid":2471293,"uid":58975,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-04-02T04:52:07.000Z","msg":"Oh my dog"},{"pid":"934b336dc3fb6c5426af37ca5727594320d8aca8","tid":2471293,"uid":8836,"like":0,"dislike":0,"score":0,"quote":{"pid":"a2196e9f925ab9d9c0543d1d043f10194b072d94","tid":2471293,"uid":220794,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-04-01T12:05:51.000Z","msg":"最近睇劉浩龍同埋Eric Kwok 介紹漢堡包，<br />\n睇完心思思都想食，於是乎就揀左 鄰居。<br />\n<br />\n<img src=\"https://na.cx/i/7r7UH2M.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7r7UH2M.png&h=6afa4dac&s={SIZE}\" /><img src=\"https://na.cx/i/ZFaWbWb.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZFaWbWb.png&h=73ea5442&s={SIZE}\" /><br />\n<br />\n雖然外賣個樣難睇左少少🤏但係味道依然好好，整體保留到8成。<br />\n<br />\n蕃薯整嘅薯條，應該係乜幾多間，雖然外賣關係軟腍左，但都食得出好新鮮，蕃薯味好甜。而真薯條就不過不失，個人愛蕃薯比較多。<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n個包牛味十足，整體上唔會有違和感，可以一口食到所有材料，大細岩岩好。<br />\n我叫果個係大菇牛堡，入口你會食到好重嘅牛味，之後啡菇嘅甜味不經意慢慢中和牛味，再揮發出菇嘅甜香味，中和左和牛嘅油膩感。<br />\n口感上塊牛排唔會太散，又唔會好似麥記咁假，無加任何黏合劑，之後就係菇同菜嘅爽脆，加上幾滴汁水滲出來，味覺猶如高潮般衝突。<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n以劉浩龍嘅標準，絕對係一個食完會掛住嘅漢堡包<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<br />\n可惜嘅係可能太好生意太忙，幫襯左幾次感覺佢地話事人都唔太有禮貌，但做街坊生意要求唔太高。<br />\n<br />\n埋單80蚊，接受到<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-02T04:53:28.000Z","msg":"堂食好正啵"},{"pid":"870daa820d9df6dd684f281eb916631f0fb981d5","tid":2471293,"uid":285405,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-02T04:58:15.000Z","msg":"Burgeroom"},{"pid":"54792399058733e45a19bcd272a4d061982203ff","tid":2471293,"uid":7405,"like":3,"dislike":0,"score":3,"quote":{"pid":"47bfe5479eb99f41bef3c8159053a7290f48357e","tid":2471293,"uid":339805,"like":5,"dislike":71,"score":-66,"citedBy":4,"replyTime":"2021-04-01T16:04:50.000Z","msg":"Shake shack<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-02T05:00:19.000Z","msg":"美心 不了"},{"pid":"886185807b450ce25a744fa8ba21a5b31121a520","tid":2471293,"uid":11237,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-04-02T05:14:14.000Z","msg":"Oh my dog<br />\n大大份，料又靚<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},{"pid":"aae1e5237effd1d8ca016e835672559de0e5b460","tid":2471293,"uid":182229,"like":1,"dislike":0,"score":1,"quote":{"pid":"320d51a234c0ac271243820f7cd30002714c67ae","tid":2471293,"uid":51064,"like":0,"dislike":0,"score":0,"quote":{"pid":"9b44364dd1aeb70814f7155bf10707d4eff48767","tid":2471293,"uid":119810,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2021-04-01T21:51:41.000Z","msg":"<span class=\"xx-large\">cool cousins<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /></span>"},"citedBy":1,"replyTime":"2021-04-02T04:06:32.000Z","msg":"呢間