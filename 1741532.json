67,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T14:27:59.000Z","msg":"push <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"36b0dd00f9a87a2aae42d9755e7f2e5cea773b65","tid":1741532,"uid":48667,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T14:28:16.000Z","msg":"捐錢啦香港人"}]}