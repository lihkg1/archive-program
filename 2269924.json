//i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkt1-2.xx.fbcdn.net%2Fv%2Ft1.0-9%2F123263683_10159586145427448_3401505815589832273_o.jpg%3F_nc_cat%3D108%26ccb%3D2%26_nc_sid%3D8bfeb9%26_nc_ohc%3DXfmwOEkIpx0AX891QEe%26_nc_ht%3Dscontent-hkt1-2.xx%26oh%3D59e0c19f6737cf661668b4662b29cca5%26oe%3D5FC7255B&h=f2c6bf36&s={SIZE}\" /><br />\n<br />\n【#A1頭條】去年元朗7.21襲擊事件警察「唔見人」被指勾結鄉黑，擔任港台《鏗鏘集》編導、有份採訪「還原7.21真相」的記者蔡玉玲，昨遭重案組上門拘捕，指她涉查冊車牌時作虛假陳述，再利用所得資料報道，控以兩項違反《道路交通條例》罪名，下周二提堂。各界譴責當局以「莫須有」罪名打壓傳媒，報復記者調查事件，製造寒蟬效應。蔡玉玲昨晚獲保釋後，呼籲同業信守無畏無私價值，「繼續做我們應做的事」。<br />\n<br />\n<a href=\"https://www.facebook.com/hk.nextmedia/photos/a.10150161306277448/10159586145422448/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fhk.nextmedia%2Fphotos%2Fa.10150161306277448%2F10159586145422448%2F&d=AZYGjn5ll7vy7cK20AVbo83u7Zzj2Sx3DhCMrptFZ9w%3D&h=29712951\" data-auto-link target=\"_blank\">https://www.facebook.com/hk.nextmedia/photos/a.10150161306277448/10159586145422448/</a>"},"citedBy":0,"replyTime":"2020-11-03T23:39:15.000Z","msg":"721"},{"pid":"9c2da0450f7c544e52a373277a00abb6cd28e18a","tid":2269924,"uid":39710,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-03T23:46:56.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />黑狗"},{"pid":"ac4cf33de8e6fa8cd787b9be1fd7d3d471b2bb16","tid":2269924,"uid":115579,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-03T23:47:20.000Z","msg":"推"},{"pid":"51609e9aed93eebbcc9df7432b6d58d0341fef44","tid":2269924,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-03T23:47:52.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"79cfbac0f3dcd38e200e15899d39ed70c3ee0c7a","tid":2269924,"uid":51820,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-04T00:08:09.000Z","msg":"推"}]}