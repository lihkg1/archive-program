/faces/lomoji/37.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-14T07:31:23.000Z","msg":"中意 唔係 鍾意(喜歡) 但 鍾的確係別字"},{"pid":"64be18224bb2a41f7fa08e7136fc5e3e2d2cec7e","tid":779063,"uid":197157,"like":1,"dislike":5,"score":-4,"quote":{"pid":"262c976921b7b3f39b3ce60da531815f1db07efc","tid":779063,"uid":78166,"like":2,"dislike":0,"score":2,"quote":{"pid":"af9e5005174977803aa48ea5ef9adcd4b34c5bca","tid":779063,"uid":197157,"like":1,"dislike":5,"score":-4,"quote":{"pid":"7be62c3604e293f22da17d5ccc01d6060611cd02","tid":779063,"uid":78166,"like":8,"dislike":1,"score":7,"citedBy":1,"replyTime":"2018-08-14T07:22:57.000Z","msg":"以前 鍾意 鐘意 都算<br />\n連登個個都打 中意 無人屌<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-14T07:25:42.000Z","msg":"上網查嘅話，中意先係正字"},"citedBy":2,"replyTime":"2018-08-14T07:29:45.000Z","msg":"<blockquote><br />\n「鍾意」是廣東話, 意思是喜歡, 愛. 書面語無此詞語. 但查辭典(台灣教育部國語辭典 http://140.111.1.22/mandr/clc/dict): <br />\n<br />\n「鍾愛」 = 特別疼愛。[北史˙卷十二˙隋煬帝本紀：上美姿儀，少敏慧，高祖及后於諸子中，特所鍾愛。三國演義˙第十六回：惟嚴氏生一女，布最鍾愛。] <br />\n<br />\n「鍾情」 = 專情愛慕。如：一見鍾情。 <br />\n<br />\n<br />\n<br />\n至於「中意」, 也是一個正確的書面語, 意思係合意、滿意。[漢書˙卷四十五˙江充傳：奉法不阿，所言中意。初刻拍案驚奇˙卷三：老身虛心冷氣，看他眉頭眼後，常是不中意，受他凌辱的。] <br />\n<br />\n<br />\n<br />\n意思類似「o岩聽」. <br />\n<br />\n所以要真的要寫的話, 「鍾意」比較正確. 而且「中意」的「中」讀「種」音(同「中獎」「中傷」, 「中規中距」等情況), 不是讀「鍾」音. <br />\n2006-05-22 19:11:02 補充 <br />\n以上只適用於口語廣東話, 考試不可以真的寫「鍾意」. 而且如果是考辨認錯別字, 「鍾意」是別字,「中意」才是正確. <br />\n<br />\n來源:<a href=\"http://hk.knowledge.yahoo.com/question/question?qid=7006052201558\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.knowledge.yahoo.com%2Fquestion%2Fquestion%3Fqid%3D7006052201558&d=ZKH8qiq0938nELvGat%2FllBOFz4pMHIf1Ti9x7C0XgVU%3D&h=e50c2ec6\" data-auto-link target=\"_blank\">http://hk.knowledge.yahoo.com/question/question?qid=7006052201558</a> <br />\n<br />\n<a href=\"https://forum.hkgolden.com/view.aspx?message=4642817&amp;page=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforum.hkgolden.com%2Fview.aspx%3Fmessage%3D4642817%26page%3D1&d=ZKH8qiq0938nELvGat%2FllBOFz4pMHIf1Ti9x7C0XgVU%3D&h=ac231f69\" data-auto-link target=\"_blank\">https://forum.hkgolden.com/view.aspx?message=4642817&amp;page=1</a><br />\n</blockquote><br />\n唔同意思<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-14T07:32:42.000Z","msg":"意思係有唔同，但其實好相近吓<br />\n要講嘅話係睇唔慣中意，個感覺似錯別字<br />\n真係要講錯別字，鐘意先係一定錯<br />\n反而鍾意同中意都講得通"},{"pid":"ff793c1719f027d10f98fa6dc15fd7de131d87a8","tid":779063,"uid":55130,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-08-14T07:46:25.000Z","msg":"最接受唔到係 將玩打做挽<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5f00632c8bcbb23d6ca2012d87a9b83a326c5973","tid":779063,"uid":21423,"like":9,"dislike":1,"score":8,"citedBy":2,"replyTime":"2018-08-14T08:06:44.000Z","msg":"此回覆已被刪除"},{"pid":"b8863e829e3ce68d7d7f504af43fd68c559ca86d","tid":779063,"uid":197157,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f00632c8bcbb23d6ca2012d87a9b83a326c5973","tid":779063,"uid":21423,"like":9,"dislike":1,"score":8,"quote":{"pid":"64be18224bb2a41f7fa08e7136fc5e3e2d2cec7e","tid":779063,"uid":197157,"like":1,"dislike":5,"score":-4,"quote":{"pid":"262c976921b7b3f39b3ce60da531815f1db07efc","tid":779063,"uid":78166,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2018-08-14T07:29:45.000Z","msg":"<blockquote><br />\n「鍾意」是廣東話, 意思是喜歡, 愛. 書面語無此詞語. 但查辭典(台灣教育部國語辭典 http://140.111.1.22/mandr/clc/dict): <br />\n<br />\n「鍾愛」 = 特別疼愛。[北史˙卷十二˙隋煬帝本紀：上美姿儀，少敏慧，高祖及后於諸子中，特所鍾愛。三國演義˙第十六回：惟嚴氏生一女，布最鍾愛。] <br />\n<br />\n「鍾情」 = 專情愛慕。如：一見鍾情。 <br />\n<br />\n<br />\n<br />\n至於「中意」, 也是一個正確的書面語, 意思係合意、滿意。[漢書˙卷四十五˙江充傳：奉法不阿，所言中意。初刻拍案驚奇˙卷三：老身虛心冷氣，看他眉頭眼後，常是不中意，受他凌辱的。] <br />\n<br />\n<br />\n<br />\n意思類似「o岩聽」. <br />\n<br />\n所以要真的要寫的話, 「鍾意」比較正確. 而且「中意」的「中」讀「種」音(同「中獎」「中傷」, 「中規中距」等情況), 不是讀「鍾」音. <br />\n2006-05-22 19:11:02 補充 <br />\n以上只適用於口語廣東話, 考試不可以真的寫「鍾意」. 而且如果是考辨認錯別字, 「鍾意」是別字,「中意」才是正確. <br />\n<br />\n來源:<a href=\"http://hk.knowledge.yahoo.com/question/question?qid=7006052201558\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.knowledge.yahoo.com%2Fquestion%2Fquestion%3Fqid%3D7006052201558&d=ZKH8qiq0938nELvGat%2FllBOFz4pMHIf1Ti9x7C0XgVU%3D&h=e50c2ec6\" data-auto-link target=\"_blank\">http://hk.knowledge.yahoo.com/question/question?qid=7006052201558</a> <br />\n<br />\n<a href=\"https://forum.hkgolden.com/view.aspx?message=4642817&amp;page=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforum.hkgolden.com%2Fview.aspx%3Fmessage%3D4642817%26page%3D1&d=ZKH8qiq0938nELvGat%2FllBOFz4pMHIf1Ti9x7C0XgVU%3D&h=ac231f69\" data-auto-link target=\"_blank\">https://forum.hkgolden.com/view.aspx?message=4642817&amp;page=1</a><br />\n</blockquote><br />\n唔同意思<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-14T07:32:42.000Z","msg":"意思係有唔同，但其實好相近吓<br />\n要講嘅話係睇唔慣中意，個感覺似錯別字<br />\n真係要講錯別字，鐘意先係一定錯<br />\n反而鍾意同中意都講得通"},"citedBy":2,"replyTime":"2018-08-14T08:06:44.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-08-14T08:13:37.000Z","msg":"好似你啱<br />\n但中學個中字又係講位置？唔係解程度咩？<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"}]}