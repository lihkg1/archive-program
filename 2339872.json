ail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSj6oZOS.jpg&h=76f4398e&s={SIZE}\" /><br />\n<br />\nsearch from google<img src=\"/assets/faces/pigxm/wail2_r.gif\" class=\"hkgmoji\" />"},{"pid":"553a8b53c53705ca2e304df7b20236fdcaf8ecfc","tid":2339872,"uid":3167,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-25T10:07:22.000Z","msg":"支持係天安門公開斬左佢刁大大都敢辱<img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b988decc4fb98135955126eaf583814aada3c14c","tid":2339872,"uid":361247,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-25T10:10:23.000Z","msg":"好快支那内戰,佢有後台先夠膽鬧"},{"pid":"68b124ba7cc86f706d293c2b3e30ceed71ca9832","tid":2339872,"uid":171506,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-25T10:12:45.000Z","msg":"淘寶依家算唔算黃？"},{"pid":"72f5b5b7bf289f52df0e24fe1df09fd6e59595cd","tid":2339872,"uid":24696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-25T10:17:06.000Z","msg":"佢有冇講過唔係重點啦<br />\n重點係中國而家要收你皮 明割你韭菜"},{"pid":"8f010ba13afe055853c4ca2b3cee75a7b65e694e","tid":2339872,"uid":236171,"like":2,"dislike":0,"score":2,"quote":{"pid":"15f75186c9fbeae63b7cc10a61aaa8fdaaeb3da7","tid":2339872,"uid":55913,"like":126,"dislike":0,"score":126,"citedBy":3,"replyTime":"2020-12-25T06:17:46.000Z","msg":"誠哥既時代已經過去<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n不過你仲早死過誠哥"},"citedBy":0,"replyTime":"2020-12-25T10:25:32.000Z","msg":"正常爛船都有三斤釘<br />\n不過國產船偷工減料<img src=\"/assets/faces/pigxm/wail2_r.gif\" class=\"hkgmoji\" />"},{"pid":"ee10570b84c006ff41e9ced0936bfcfd920fee68","tid":2339872,"uid":271130,"like":1,"dislike":0,"score":1,"quote":{"pid":"edb52dda03fc09bb5e175d0f863b5757e5e25db9","tid":2339872,"uid":282637,"like":2,"dislike":17,"score":-15,"citedBy":7,"replyTime":"2020-12-25T07:48:02.000Z","msg":"馬雲係人才,但可惜生係中國"},"citedBy":0,"replyTime":"2020-12-25T10:28:28.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 佢自資拍果功夫電影入邊既佢就真係人材喇 係厚面皮方面"},{"pid":"d1fd5eef92e232be21d9c863fffde36c9106004f","tid":2339872,"uid":79563,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-25T10:32:41.000Z","msg":"<a href=\"https://www.youtube.com/watch?v=AJqqNyQk3Oc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DAJqqNyQk3Oc&d=z%2FAKp4ZZwI77wMFl%2FSXGt2jFlCc76q8eB7f9T8a%2Fn1E%3D&h=97d68a32\" target=\"_blank\">https://www.youtube.com/watch?v=AJqqNyQk3Oc</a><br />\n<br />\n<strong><span class=\"xx-large\"><span class=\"red\">馬雲豪言指李嘉誠年代已經過去</span></span></strong><br />\n<br />\n馬雲說：&ldquo;這是互聯網的時代，不再屬於李嘉誠了。李嘉誠在他那個時代，真的很不錯，但現在已不可能出現另一個李嘉誠&hellip;&hellip;10年之間4大家族（李嘉誠的長和系、郭氏家族的新鴻基地產、鄭裕彤的新世界及李兆基的恆基兆業），市值都不及騰訊加上阿里。&rdquo;<br />\n<br />\n今年晉身福布斯中國富豪榜第8位、身家545億港元的馬雲，以一身粉藍素服與記者輕鬆交談。對於今年以來阿里巴巴爭議傳聞不斷，馬雲在短短個半小時內，向全港作出多次道歉，承認在溝通上不足，亦坦承在香港上市已畫上句號，&ldquo;分手後重新了解&rdquo;，希望大家可反思今次事件。<br />\n<br />\n但記者似乎更有興趣了解他對香港&ldquo;舊時代&rdquo;4大家族的看法。馬雲說：&ldquo;不是馬化騰（騰訊創辦人）特別厲害，我更沒什麼，而是時代厲害，我們只是順應互聯網的潮流而崛起&rdquo;。現時四大家族上市旗艦市值接近9000億港元，但光是騰訊的市值已達8000億港元，馬雲並無虛言。<br />\n<br />\n馬化騰目前持有騰訊約10%，情況與馬雲連同管理層持有阿里巴巴約一成股權非常相似，有記者問馬雲為何阿里巴巴不願參考騰訊模式在港上市，馬雲回應說：&ldquo;你問Pony（馬化騰洋名），如果騰訊現在才上市，他一樣會遇到這個問題。騰訊2004年以每股3.7港元上市，現在超過400元，南非大股東很滿意，但誰敢擔保以後沒有問題，現在沒有，不等於將來沒有。&rdquo;<br />\n<br />\n馬雲對互聯網世界的急促發展深有感觸，&ldquo;這世界誰也沒把握你能紅5年，解決你不敗、不老、不糊塗的唯一辦法，就是相信年輕人&rdquo;。他指今天的世界是一個變化的世界，變化是每個人的機會。"},{"pid":"29346d259cfe4fa8b24e03c64b43f0fd4d2deb82","tid":2339872,"uid":184022,"like":0,"dislike":0,"score":0,"quote":{"pid":"15f75186c9fbeae63b7cc10a61aaa8fdaaeb3da7","tid":2339872,"uid":55913,"like":126,"dislike":0,"score":126,"citedBy":3,"replyTime":"2020-12-25T06:17:46.000Z","msg":"誠哥既時代已經過去<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n不過你仲早死過誠哥"},"citedBy":0,"replyTime":"2020-12-25T10:34:23.000Z","msg":"某程度啱，香港已經唔係誠哥時代，因為人地已經去咗英國<img src=\"/assets/faces/pigxm/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/mock.gif\" class=\"hkgmoji\" />"},{"pid":"5d1aaf161be63dcd12706f3f06ef3f9b798153d2","tid":2339872,"uid":165361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-25T10:36:22.000Z","msg":"建議留国....<br />\n佢有選擇權咩<img src=\"/assets/faces/dogxm/play.gif\" class=\"hkgmoji\" />"},{"pid":"264ca7ac7acb280736196d673cbaf33345d22b56","tid":2339872,"uid":120070,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-12-25T10:39:36.000Z","msg":"<span class=\"red\">馬雲對互聯網世界的急促發展深有感觸，&ldquo;這世界誰也沒把握你能紅5年，解決你不敗、不老、不糊塗的唯一辦法，就是相信年輕人&rdquo;。他指今天的世界是一個變化的世界，變化是每個人的機會。<br />\n</span><br />\n咁其實佢都深明呢個道理既  有革命本質係到"},{"pid":"9420767c5d70f04152904361db261e34883c9e04","tid":2339872,"uid":4957,"like":1,"dislike":0,"score":1,"quote":{"pid":"3ed7ab753e75781bb54eb02aed6565da5df3503d","tid":2339872,"uid":205684,"like":1,"dislike":0,"score":1,"quote":{"pid":"f1fc2e1c4c452e413617fc6f1e7a8126676dc6f3","tid":2339872,"uid":46120,"like":20,"dislike":3,"score":17,"citedBy":2,"replyTime":"2020-12-25T08:08:27.000Z","msg":"2013年10月18日，馬雲來港出席記者會語錄<br />\n<br />\n「李嘉誠時代已過去」依句唔駛解釋 <img src=\"/assets/faces/pigxm/smile.gif\" class=\"hkgmoji\" />，不過補充，李嘉誠私人持有Horizons Ventures，喺馬雲不停發表偉論前，已低調投資Skype, Deepmind, Siri, Facebook, Spotify, Zoom, Impossible Food。佢嘅時代或者真係已經過去，但係佢一直喺時代入面發揮力量；而有人，好大機會因為得罪黨，得罪當今聖上，可能淹沒於時代之中<img src=\"/assets/faces/pigxm/bye.gif\" class=\"hkgmoji\" />。<br />\n<br />\n「不是馬化騰（騰訊創辦人）特別厲害，我更沒甚麼，而是時代厲害，我們只是順應互聯網的潮流而崛起」」<br />\n<br />\n前兩句非常正確，後兩句錯晒。唔係時代厲害，係「時代革命」。同埋，崛起唔係順應時代，而係黨幫你哋擋晒外國企業，製造環境等你哋可以玩晒成隻公雞市場，壯大咗實力先出去世界打天下幫黨做嘢。<br />\n<br />\n試吓當年一開始唔禁唔設限制，俾ICQ, Twitter, eBay, PayPal, MySpace, Facebook, Amazon 自由進入。睇吓崇洋嘅生物會點選擇？佢哋會去Amazon 買外國勢力奶粉定去淘寶買。<br />\n<br />\n馬化騰就一直都好清醒，所以一直極低調。"},"citedBy":2,"replyTime":"2020-12-25T09:46:14.000Z","msg":"馬化騰一直都跟足規距玩，所以到最後佢唔會比中共煮<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-25T10:43:33.000Z","msg":"咪傻啦 下一個到佢"},{"pid":"b84b6d97ef02abd0c5eb4b6d4e402424d09106d3","tid":2339872,"uid":200882,"like":1,"dislike":0,"score":1,"quote":{"pi