 src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"32a90b57287d7dee83ef8c6145d205a56fc6f221","tid":1371831,"uid":93080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T12:15:42.000Z","msg":"警黑同黑警都係果兩個字，所以冇分別<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"5b00ff993250c82d43eebff9eae93fef5bb4b906","tid":1371831,"uid":89462,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-27T12:16:46.000Z","msg":"對黑社會就攬頭攬頸，對反黑既示威者就出動哂催淚彈，橡膠子彈。警察職責係要無分彼此咁保護市民。你係村口築起人鏈唔畀人入去搞事ok, 做乜又要出動你啲殺人武器。呢種不公平對待唔應該係文明社會出現。<br />\n要求徹查究竟警察同黑幫既關係去到咩程度。"},{"pid":"77c249e9fa2530086ed99a3666cd6e26450ad39a","tid":1371831,"uid":117679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T12:16:50.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"d8b5cf7f488421fd1c720cffe1c9f505398ebe16","tid":1371831,"uid":210031,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T12:17:18.000Z","msg":"黑同警一樣，唔駛分咁細"},{"pid":"851aaa17f38a1cecf1bdc3c935409d32683e87b0","tid":1371831,"uid":6864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T12:19:10.000Z","msg":"屌佢老母，黑白夾攻<br />\n<br />\n而我分唔到黑同白講緊邊班 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"05bb75ed67e6f3d981ce79e3fffe08728b3cca8f","tid":1371831,"uid":70894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T12:19:22.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"d10d8f90482ae25ccc092eba70e2ad96d7e53f4b","tid":1371831,"uid":65865,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T12:23:32.000Z","msg":"做狗仲要做黑社會隻狗<img src=\"/assets/faces/dog/beg.gif\" class=\"hkgmoji\" />"},{"pid":"e8d00f483b8638ba3e6b0df95ea6acc3da447803","tid":1371831,"uid":278765,"like":0,"dislike":0,"score":0,"citedBy":