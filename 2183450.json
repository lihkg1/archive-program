normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"2aede9ea15a6c57322f72114bc86ed64fb812c41","tid":2183450,"uid":120729,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-09-01T06:05:00.000Z","msg":"出返去先<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9f015f9e7005ae38e0a18e394213df1e0725829b","tid":2183450,"uid":42879,"like":15,"dislike":3,"score":12,"citedBy":0,"replyTime":"2020-09-01T06:28:55.000Z","msg":"靚唔靚仔其實影響唔大，除非你係去到一堆靚仔之中都比較靚仔既級數<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />根本依堆人佔好小數。<br />\n<br />\n出街見根本大部份男仔都係普通樣或者樣衰都拖囡，你自己廢溝唔到女唔好瀨東瀨西啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1fca42e4e11463e3413e5d81fcb09429c34f7b9f","tid":2183450,"uid":19215,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-01T07:21:02.000Z","msg":"唔小心入咗嚟"},{"pid":"9e682c75d463f207eb7d6998d7318fb86a9d1ff1","tid":2183450,"uid":66921,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-09-01T15:06:18.000Z","msg":"小學嘅時候愚人節表白<br />\n比個男仔直接話：你好柒<br />\n第二日返到學校全級都知<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n直到升中學有d 同校小學同學仲講緊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"acbb7eba74c896ac14a0461eb254181d8e99538d","tid":2183450,"uid":125898,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-09-01T15:21:56.000Z","msg":"此回覆已被刪除"},{"pid":"919c79817c4c821dd8be316d9b6766bbcd6a85f1","tid":2183450,"uid":325757,"like":0,"dislike":0,"score":0,"quote":{"pid":"79f39fca436c5781caeff9ddb60a5ab194dd5a96","tid":2183450,"uid":261592,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-09-01T04:04:01.000Z","msg":"原本有個細路好開心同佢老母玩 我咁岩行過 佢見到我即刻無晒笑容 然後喊埋出黎<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-01T15:49:54.000Z","msg":"有無咁誇張啊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f8c162d21fb7af6d655b5689e7e40b332abb56a4","tid":2183450,"uid":170057,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-09-01T16:05:27.000Z","msg":"以前小學初中戴眼鏡<br />\n初中嗰陣有次除咗眼鏡同前面個男仔對到眼<br />\n佢個樣好嫌棄講咗句: 哇好豬啊 <br />\n嗰陣班房仲要好靜<br />\n個個同學望住我<br />\n我好尷尬<br />\n同埋初中成日俾人話樣衰<br />\n搞到我對自己個樣真係好冇自信<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"e3b11b1bbd4b2922f192d07b269453f13220f0fb","tid":2183450,"uid":176657,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-01T16:39:54.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"690b045d714b8e9f585dc83f522b2566eb8e51c2","tid":2183450,"uid":5649,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-09-01T16:41:50.000Z","msg":"女朋友同我扑野從來都唔mark大眼&amp;叫我熄燈"},{"pid":"df844e2a45ee1d99b24996e57c407c24e7c5da77","tid":2183450,"uid":274452,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-01T16:56:34.000Z","msg":"此回覆已被刪除"},{"pid":"f7625b127729d15b6f0b7c3ec2888bb0bc785e80","tid":2183450,"uid":272424,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-01T17:04:13.000Z","msg":"此回覆已被刪除"}]}