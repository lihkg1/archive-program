:0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:29:51.000Z","msg":"Lm"},{"pid":"c30340166ef964740f3af855a54f77670e12c5d5","tid":1933603,"uid":244368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:30:01.000Z","msg":"tui"},{"pid":"5fb0908152176ba221555e9cc0a60ec854c42efd","tid":1933603,"uid":199689,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:30:02.000Z","msg":"Push"},{"pid":"c99364939f5c7c2b6bfbcfe2d2c20168512a85f1","tid":1933603,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:30:04.000Z","msg":"民間記者會"},{"pid":"a6aa7918bf628cce51fbdbc296d088cfd01391ad","tid":1933603,"uid":83582,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:30:16.000Z","msg":"push"},{"pid":"1dd4bf13bc9a636df93676dbda467becb3b5eaae","tid":1933603,"uid":58160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:30:18.000Z","msg":"推"},{"pid":"9fb32b42f4b6113b83bfecc4438a39042b5833f4","tid":1933603,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:30:32.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"ad69c27e466a73fec186352708f73e7f2b59aa89","tid":1933603,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:30:41.000Z","msg":"live starting"},{"pid":"e1cda19fea8e6485411b997158338aa395ce9de9","tid":1933603,"uid":2436,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:30:51.000Z","msg":"此回覆已被刪除"},{"pid":"93ae4d3539104e0b8a82a2799e6a62bde025cdf2","tid":1933603,"uid":199689,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:32:05.000Z","msg":"Push"},{"pid":"4a5d31193f3b9e74b80002d44bea85bc9a374fda","tid":1933603,"uid":36592,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:32:51.000Z","msg":"push"},{"pid":"0ada8a4456d7770f7d136bb57c9f89a3d1b1b22e","tid":1933603,"uid":29726,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:32:54.000Z","msg":"推"},{"pid":"05363757ad262f995afdc5800dbf5056a0c3acd3","tid":1933603,"uid":83910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:33:22.000Z","msg":"push"},{"pid":"ae76bd535bde559f82facb44e0787c1acdb86070","tid":1933603,"uid":21057,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:33:38.000Z","msg":"推"},{"pid":"35afd0eb58ad3ff6eed1fe7ccf9a69f1df5ec968","tid":1933603,"uid":38757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:34:42.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"1b12e5131563415dfab58f6283b2cd30458d3e84","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:36:40.000Z","msg":"革命未竟、疫情未定，政權依舊冥頑不靈，對民意視若無睹，置民生不顧，只繼續極盡殘害港人能事。近日反民主派議員頻出頭獻媚，冀推動「廿三條」立法，謊稱能維護他國安全。廿三條於香港人是夢魘，言論是我們敢於以死相搏的一項自由，袁國勇教授昨早在明報上敢於批評，同日卻在深圳衛視中低頭認錯及撤稿，判若兩人。"},{"pid":"b9430108aeff8bd556151c4aad43a17e253e5a04","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:38:01.000Z","msg":"不禁令人寒心，廿三條未正式立法，卻已能達致噤聲之用。極權面前，連公義和科學都只能夠奴顏婢膝，讓路予橫蠻與愚昧。十七年前我們守過一仗，十七年後，即使惡法重臨，相信港人亦有足夠智慧及勇氣將惡法推倒。可怕的是，「廿三條」除了可以以單一條例形式立法，亦可以透過強行解釋、扭曲現行不同條例「僭建式立法」。種種舊時惡法可被援引作為對極權眼中「危害國家安全的行為」而借屍還魂，迫害抗爭者。"},{"pid":"f5a19e13ccf21f96c398936dc3845156a78d027c","tid":1933603,"uid":189650,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:39:23.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"9b32d36ca709f6512c0013d533fdf70e56f5efe5","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:40:30.000Z","msg":"港共政權早於六年前，已援引過條文粗疏的「沉睡」惡法訴控並污名化抗爭者。14年「雨革」以《公安條例》 起訴黄之鋒等人「非法集結」及煽動行為；16年「魚革」以《公安條例》中的「暴動及煽惑暴動」等罪名首次起訴梁天琦及一眾義士；其後以《社團條例》禁止「香港民族黨」運作。過去大半年，魔警連同律政司，濫用「暴動」罪名控訴數百名抗爭者，逼使抗爭者在未經判罪下接受嚴苛的保釋條件，侵犯其人生自由。"},{"pid":"f9aa3946f8e2934599a04dbf72e5772d75eecd69","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:41:20.000Z","msg":"《公安條例》擬於1967年，為使策動六七暴動的共產暴徒更易入罪，條例取消了「共同目的」作重要控罪元素，即不論行過路過，一旦「出現在現場」皆能控以此罪。以平定政治風波而修定的舊法，成為政權打壓異見者最方便的工具。另外，《公安條例》關於「非法集結」以及「暴動」的條文詞性含糊不清，控罪所謂的「破壞社會安寧」沒有指涉實質舉動或暴動行為，只淪為政治濫告的手段，含糊不清的條文造成寬鬆的指引，給予警方過高權力執法。"},{"pid":"87ac83c9046f8010053175f03e29317303f057fd","tid":1933603,"uid":325953,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-19T11:43:28.000Z","msg":"<span style=\"font-size: x-large;\">不但如此，政權去年為繞過立法程序，援引了殖民統治時期制定的《緊急法》，以行政手段啟用「禁蒙面法」，不擇手段打壓抗爭，雖最後被判違憲推倒法例，但以行政手段左右司法系統的舉止，創下極壞先例。</span>"},{"pid":"9931fbebd5c2181f4bd6139c1bde523ceadd0df6","tid":1933603,"uid":24131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:43:28.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />睇"},{"pid":"89f888b99c61988fa5e3eda91ee966a392ab4167","tid":1933603,"uid":89517,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:43:40.000Z","msg":"<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" />"},{"pid":"a1656bf77a9163f8fb8112799b583e2d7c34e816","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:43:43.000Z","msg":"政權現時繼續以上述的過時舊例，以中國式「法治」的幌子，在欠缺現代人權考慮及真正法治的修訂下，繼續濫告抗爭者，以法例之名目 ，行「維護國安」之際。在現時濫用暴動罪名之下，有無辜的市民被還押逾兩個半月才因證據不足獲撤銷控罪，重獲自由。足見種種舊例不但讓無數人的自由受限、在收押所白白虛度大好年華，更令本應獨立的司法機關淪為政權爪牙。"},{"pid":"dce0c5fa18dae34ff4f383cc31966658b26e5d35","tid":1933603,"uid":89517,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:43:52.000Z","msg":"<img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"},{"pid":"7428a8cfb81fddbebacf7348f25b7c04d38a7860","tid":1933603,"uid":21817,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:44:28.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"27d3e2a8fac559b24b0a6e306139ae0b32155eea","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:44:33.000Z","msg":"日前，鄧柄強曾高調受訪，稱或以《聯合國（反恐怖主義措施）條例》檢控早前的爆炸品案被告，若此言成真，將會是此例成立十八年來首次提告。是次手段明顯是極權政府再一步對內打壓港人，對外污名化香港人追求民主的意念。按現時的《反恐條例》，政權一旦鎖定你是目標犯人，皆能以極高的權限作出控罪及禁制。若被懷疑作所謂「恐佈分子」或持有「指明目的」作出、籌劃、籌備或參與一項或多於一項「所謂」恐怖主義行為(即使實際上沒有發生)，條例中給予執法者權力凍結市民財產、禁止市民出入境等。"},{"pid":"c0a645210e6d5092692823a2900ee86addb6862e","tid":1933603,"uid":67479,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:45:00.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"4a28be24fd311deb0e9f301e8177d6c542243b68","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:45:07.000Z","msg":"但現行法例足見詞義的粗疏，「即使實際上沒有恐怖主義行為發生」，開宗明義讓政權砌詞造假，連「莫須有」的罪證都「慳返」，以恐怖主義的名義，合理化魔警禁錮異己等惡行。立法會曾作出報告，香港受恐襲的威脅評估被評為&quot;中度&quot;級別，沒有具體情報顯示香港可能成為襲擊目標。在客觀情況下，動用《反恐條例》控告示威者，純粹是赤裸而卑劣的政治打壓。再者，控罪本身應由律政司提告，鄧柄強高調受訪已經證明香港法治最高權力已經交予黑警，香港確實已淪為警察國家。"},{"pid":"1a243d51a08301957b1594eafeee57c6cd4ab7be","tid":1933603,"uid":24131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:45:36.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"745d94784e9b656f3a3c931d7ea1e974e7e4c5a5","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:45:40.000Z","msg":"近日，警方亦派出代表到聯合國顛倒是非，為過去的暴行砌詞狡辯。警謊密謀打鼓的「洗白」及近月來「恐佈主義」的言論，不難令人猜想政權圖以公權力向外國政府及公民抹黑港人的抗爭運動，意圖令香港人失去「追求公義、民主」的形象，影響國際輿論。"},{"pid":"f0659ddc597306fe8dadda45d1070a4e41c853c8","tid":1933603,"uid":146737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:46:02.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"9c1678292b1851dbc06697dc07cfd0c5ba983bf8","tid":1933603,"uid":115579,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:46:21.000Z","msg":"推"},{"pid":"5ab86393e65818be77b4e79d33d7884ee4c8ae93","tid":1933603,"uid":87985,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-19T11:46:23.000Z","msg":"今次跟得幾貼<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"5746d12b37bc85f241644d46db1baa216c05619c","tid":1933603,"uid":140538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:48:03.000Z","msg":"push"},{"pid":"d29ab62bc430396d1cb87585c116e101cf341110","tid":1933603,"uid":189650,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:48:07.000Z","msg":"推"},{"pid":"1026daba9fcf9d9b45d2b38b3fa07dca25d30dc4","tid":1933603,"uid":87985,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:48:45.000Z","msg":"英文絲<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"03d5114a7ac19b9bb0b63eef5c095e85fce542e9","tid":1933603,"uid":76922,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-19T11:48:59.000Z","msg":"電視冇播了。。"},{"pid":"6972ff3f2d086eb7425e1aee5c7ea641996d66d2","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:49:11.000Z","msg":"同時，按《反恐條例》的17年修訂版，政權能隨時禁止相關人士離境，不但禁錮其人身自由，更影響香港人出國參與國際會議、進行游說等工作，打擊表達自由及國際戰線。警方借用國際社會熟悉的字眼，污衊港人行徑，意圖在外國執法部門面前爭取認同，合理化打壓暴行。即使在國際公民雪亮的雙眼面前，警方此舉或未能啟效，但仍需港人多加提防及反擊，盡量在社交平台上澄清及道出真相。"},{"pid":"230af7979b92eb17474c623313c36ec5672497b8","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:49:25.000Z","msg":"中共自古以來就污名民主、賤視人權，新疆西藏，前車可鑑。面對人民爭取合法權益，充耳不聞；人民不滿，就動輒「扣帽子反恐」，以反恐製造恐怖，以人民的怨懟痛苦，換就權貴的紙醉金迷。回顧香港，現行法例上有不少「舊例」因時移勢易塵封已久，但港共傀儡隨時以修訂、解讀等伎倆，「舊例新用」，殘民後快。抗疫的2003年和抗命的2003年，香港人都不敢遺忘。"},{"pid":"9283d5a7c15ed9dd3904b4258e322d2e9e729a90","tid":1933603,"uid":134744,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:49:32.000Z","msg":"推"},{"pid":"7a2ad2a748d7e15a22dc3d2df38df47f89f49c44","tid":1933603,"uid":325953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:49:40.000Z","msg":"議事廳堂早就淪為港共的屠房，磨刀霍霍，在魔警、律政的配合下，不惜一切打壓抗爭。但香港人早已不一樣，我們不再懦弱，我們絕不屈服，縱使花果凋零，我們也不會忘卻革命的義務。無論是文土戰線、議會戰線，還是文宣戰線、國際戰線，都仍然會繼續有我們的脈搏，抗擊暴政，光復香港。"},{"pid":"32b4d60c48fc4135c1a989c052d0a6d3fcac0a17","tid":1933603,"uid":22832,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:49:53.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"4790899719ee72549e9d4a818198fbdf413e3ec0","tid":1933603,"uid":22832,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:50:04.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"3dc2056329898278fabe931ab8e93e1ff76e57db","tid":1933603,"uid":140538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:50:57.000Z","msg":"push"},{"pid":"5e4a410321ab49f4ecc382f9e387982ca06b9414","tid":1933603,"uid":19095,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:56:17.000Z","msg":"Push"},{"pid":"2ec3f40c516a5ef68ebfddba899ca790dff3042f","tid":1933603,"uid":76922,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T11:59:16.000Z","msg":"Push...."},{"pid":"d5a7aa88e9158bfd70cde40058145b14de7d8fef","tid":1933603,"uid":140538,"like":0,"dislike":0,"score":0,"quote":{"pid":"03d5114a7ac19b9bb0b63eef5c095e85fce542e9","tid":1933603,"uid":76922,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-19T11:48:59.000Z","msg":"電視冇播了。。"},"citedBy":0,"replyTime":"2020-03-19T12:00:53.000Z","msg":"rthk..."},{"pid":"2c356a9a255e8699ce28e999cc99e73e7a749ce8","tid":1933603,"uid":140538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T12:01:13.000Z","msg":"香港人權監察代表葉寬柔小姐<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},{"pid":"62b9d9397b6e818ce610da50d98fd2adc064d05b","tid":1933603,"uid":189046,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T12:02:15.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"08f972c4677d595fb93b92ac3aaf48314355767c","tid":1933603,"uid":189650,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-19T12:03:07.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"3daba432632853b9f74d02190c493724eed162