 />"},"citedBy":2,"replyTime":"2020-11-10T01:37:06.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"16cb7693df2fe0d7bb851f230cceabe9d68aeec7","tid":2279572,"uid":210612,"like":1,"dislike":0,"score":1,"quote":{"pid":"09b0046fd4118497e37aae576b1cb272a0842b98","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"quote":{"pid":"f51756a5528d5afb54c392d3c32792f5d7e92311","tid":2279572,"uid":210612,"like":14,"dislike":0,"score":14,"citedBy":2,"replyTime":"2020-11-10T01:20:10.000Z","msg":"咁睇你係用手臨摹定係用腦臨摹"},"citedBy":2,"replyTime":"2020-11-10T01:31:52.000Z","msg":"兩者有咩差別<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-10T01:37:07.000Z","msg":"喺臨摹嗰時諗點解佢係咁落筆<br />\n打個比喻佢左胸前既陰影同反光<br />\n你畫嗰時都唔太理解佢嗰塊色塊存在既目的<br />\n光線邊度黎 陰影又喺邊度出黎<br />\n所以缺咗一忽 同陰影方向錯咗<br />\n臨摹仲可以學習<br />\n線條分析<br />\n光影<br />\n構圖<br />\n人物骨架/五官<br />\n顏色運用 等等<br />\n情況好似學外文嗰時聽當地人講嘢咁"},{"pid":"9fe4168d9cd245406857bede435797eb290d392f","tid":2279572,"uid":210612,"like":0,"dislike":0,"score":0,"quote":{"pid":"ebffe79e8c13dc1440c99e2ff869abd327ad15a3","tid":2279572,"uid":25250,"like":10,"dislike":0,"score":10,"quote":{"pid":"09b0046fd4118497e37aae576b1cb272a0842b98","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"quote":{"pid":"f51756a5528d5afb54c392d3c32792f5d7e92311","tid":2279572,"uid":210612,"like":14,"dislike":0,"score":14,"citedBy":2,"replyTime":"2020-11-10T01:20:10.000Z","msg":"咁睇你係用手臨摹定係用腦臨摹"},"citedBy":2,"replyTime":"2020-11-10T01:31:52.000Z","msg":"兩者有咩差別<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-11-10T01:37:06.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-10T01:37:45.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"b077b425e5e89b0e6113e00023139b70ce7e15c7","tid":2279572,"uid":23023,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-11-10T02:27:05.000Z","msg":"唔臨人地既畫點會學得到野<br />\n不過臨既過程之中一定要思考<br />\n點解要咁做同咁畫<br />\n不過畫海無涯 技術野都係要浸出黎<br />\n畫板既野 咩都得啦<br />\n練左技術先再算"},{"pid":"3fe4c45f3bc795c7e119f165d44520dc9e706b04","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"quote":{"pid":"ebffe79e8c13dc1440c99e2ff869abd327ad15a3","tid":2279572,"uid":25250,"like":10,"dislike":0,"score":10,"quote":{"pid":"09b0046fd4118497e37aae576b1cb272a0842b98","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"quote":{"pid":"f51756a5528d5afb54c392d3c32792f5d7e92311","tid":2279572,"uid":210612,"like":14,"dislike":0,"score":14,"citedBy":2,"replyTime":"2020-11-10T01:20:10.000Z","msg":"咁睇你係用手臨摹定係用腦臨摹"},"citedBy":2,"replyTime":"2020-11-10T01:31:52.000Z","msg":"兩者有咩差別<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-11-10T01:37:06.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-10T02:46:06.000Z","msg":"<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"019fcba018c14b482eb11f95e9fbcade04515f03","tid":2279572,"uid":165996,"like":0,"dislike":0,"score":0,"quote":{"pid":"e6405764c10faa6ecc581773a0162014bdfe50b4","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"quote":{"pid":"2c8b1e187b7c6493d2656b7222f7ac1171c5a198","tid":2279572,"uid":69071,"like":0,"dislike":4,"score":-4,"citedBy":2,"replyTime":"2020-11-10T01:21:49.000Z","msg":"識畫畫要講創作，臨幕叻只可以講你畫畫水平高。<img src=\"/assets/faces/pig/bye.gif\" class=\"hkgmoji\" />比啲信心自己畫吓心目中理想嘅角色，久而久之就會創作到<img src=\"/assets/faces/pig/champagne.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-10T01:33:31.000Z","msg":"咁都有個方向點開始練/畫?<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-10T02:48:15.000Z","msg":"最簡單就<br />\nSet下個theme比自己先 <br />\n再搵多返啲reference"},{"pid":"c6cba928c423dac8abdb4f08f24505626940ead0","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"quote":{"pid":"16cb7693df2fe0d7bb851f230cceabe9d68aeec7","tid":2279572,"uid":210612,"like":1,"dislike":0,"score":1,"quote":{"pid":"09b0046fd4118497e37aae576b1cb272a0842b98","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"quote":{"pid":"f51756a5528d5afb54c392d3c32792f5d7e92311","tid":2279572,"uid":210612,"like":14,"dislike":0,"score":14,"citedBy":2,"replyTime":"2020-11-10T01:20:10.000Z","msg":"咁睇你係用手臨摹定係用腦臨摹"},"citedBy":2,"replyTime":"2020-11-10T01:31:52.000Z","msg":"兩者有咩差別<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-10T01:37:07.000Z","msg":"喺臨摹嗰時諗點解佢係咁落筆<br />\n打個比喻佢左胸前既陰影同反光<br />\n你畫嗰時都唔太理解佢嗰塊色塊存在既目的<br />\n光線邊度黎 陰影又喺邊度出黎<br />\n所以缺咗一忽 同陰影方向錯咗<br />\n臨摹仲可以學習<br />\n線條分析<br />\n光影<br />\n構圖<br />\n人物骨架/五官<br />\n顏色運用 等等<br />\n情況好似學外文嗰時聽當地人講嘢咁"},"citedBy":1,"replyTime":"2020-11-10T02:51:34.000Z","msg":"<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"2f44736c32d3b6b15a7de6a2a1371bb1a1594599","tid":2279572,"uid":310297,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-11-10T02:58:15.000Z","msg":"畫畫喺透過雙眼對光影 <br />\n形態既理解<br />\n透過手眼協調將哩啲野<br />\n由立體轉化為平面既點線面<br />\n<br />\n即使係想象裡嘅野<br />\n都需要由平日既觀察<br />\n經驗累積組合而成<br />\n正如：天使＝人＋鳥翼<br />\n<br />\n而臨摹就只係執人口水尾<br />\n如果諗著臨摹可以倒轉頭<br />\n去理解作者點解咁畫<br />\n咁前提喺你都需要有足夠既<br />\n觀察經驗先會明點解作者<br />\n最後會決定用如此嘅一個方法來呈現<br />\n<br />\n但如果只係想畫得靚<br />\n臨摹可以令你掌握到<br />\n各種平面視覺元素嘅表現方法<br />\n就結果而言 臨摹又未嘗不可<br />\n<img src=\"/assets/faces/lm2/eating.gif\" class=\"hkgmoji\" />"},{"pid":"13df646b755da110d65106e89ae0504b311f1c97","tid":2279572,"uid":25250,"like":2,"dislike":0,"score":2,"quote":{"pid":"3fe4c45f3bc795c7e119f165d44520dc9e706b04","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"quote":{"pid":"ebffe79e8c13dc1440c99e2ff869abd327ad15a3","tid":2279572,"uid":25250,"like":10,"dislike":0,"score":10,"quote":{"pid":"09b0046fd4118497e37aae576b1cb272a0842b98","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-11-10T01:31:52.000Z","msg":"兩者有咩差別<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-11-10T01:37:06.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-10T02:46:06.000Z","msg":"<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-10T03:08:05.000Z","msg":"唔⋯⋯睇你係想畫黑白漫畫定彩色插畫囉<br />\n好深入咁講，線係可以控制圖整體既感覺，例如粗線條可以表現強桿<br />\n幼線可以表達柔和，但暫時未係你需要既程度<br />\n黑白黎講陰影主要係用黎表現立體調（當然最重要係表達色調）<br />\n陰影通常係塊狀唔會係線狀<br />\n如果你則目標係畫彩色插畫，陰影既明度（即係幾黑）係你既必修課<br />\n不過你而家首先要學排線先，你陰影D線幾撩下"},{"pid":"4f891b121fd85e54bf90f6db8f1c688ed90cd7fc","tid":2279572,"uid":44815,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-11-10T03:31:36.000Z","msg":"加油，臨摹應該練到技巧野。同影相差唔多，有時試下跟人地d相黎影先學到點影一樣（好似係）<br />\n<br />\nBtw 唔識畫畫"},{"pid":"d7153ba552b860cfcae793de486ee8d342091227","tid":2279572,"uid":25250,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-11-10T03:47:30.000Z","msg":"不過講漫畫角色，我覺得畫風重要過技術"},{"pid":"7a0f97205bccb8e5d9f30c70d9dff84561aab993","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"quote":{"pid":"13df646b755da110d65106e89ae0504b311f1c97","tid":2279572,"uid":25250,"like":2,"dislike":0,"score":2,"quote":{"pid":"3fe4c45f3bc795c7e119f165d44520dc9e706b04","tid":2279572,"uid":137768,"like":0,"dislike":0,"score":0,"quote":{"pid":"ebffe79e8c13dc1440c99e2ff869abd327ad15a3","tid":2279572,"uid":25250,"like":10,"dislike":0,"score":10,"citedBy":2,"replyTime":"2020-11-10T01:37:06.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-10T02:46:06.000Z","msg":"<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-10T03:08:05.000Z","msg":"唔⋯⋯睇你係想畫黑白漫畫定彩色插畫囉<br />\n好深入咁講，線係可以控制圖整體既感覺，例如粗線條可以表現強桿<br />\n幼線可以表達柔和，但暫時未係你需要既程度<br />\n黑白黎講陰影主要係用黎表現立體調（當然最重要係表達色調）<br />\n陰影通常係塊狀唔會係線狀<br />\n如果你則目標係畫彩色插畫，陰影既明度（即係幾黑）係你既必修課<br />\n不過你而家首先要學排線先，你陰影D線幾