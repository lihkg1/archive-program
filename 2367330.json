faces/mouse/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/bye.gif\" class=\"hkgmoji\" />"},{"pid":"b1b29e3745b63607cca81e51bddc55cc62a52767","tid":2367330,"uid":37351,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-01-15T10:14:47.000Z","msg":"留名<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />"},{"pid":"43ee45b6a8e60f31102192b157112308afc5dff7","tid":2367330,"uid":223799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-15T10:23:13.000Z","msg":"push"},{"pid":"3dc6ca27fb75b48f47e018cc53a53ac90026eb1f","tid":2367330,"uid":223799,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-01-16T03:34:36.000Z","msg":"pusg"},{"pid":"dad4e25825a653768d1ed5b9f3c8fc8ef6106659","tid":2367330,"uid":223799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-16T03:40:14.000Z","msg":"push"},{"pid":"216e164a06eaa1c32b82deade2969596403ea35c","tid":2367330,"uid":336565,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-16T03:44:12.000Z","msg":"有冇自學source<br />\n出面上梗夜校都係感覺好basic 兼唔係咁學到code logic"},{"pid":"e7302d1f1b9acf8a1847be38534e4463e2e5e02a","tid":2367330,"uid":223799,"like":0,"dislike":1,"score":-1,"quote":{"pid":"216e164a06eaa1c32b82deade2969596403ea35c","tid":2367330,"uid":336565,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-16T03:44:12.000Z","msg":"有冇自學source<br />\n出面上梗夜校都係感覺好basic 兼唔係咁學到code logic"},"citedBy":1,"replyTime":"2021-01-16T05:17:12.000Z","msg":"自學可以由codecademy 開始 幾好"},{"pid":"768133eeb909caca9142b13c9f90d86bf90c066e","tid":2367330,"uid":167574,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-16T06:13:23.000Z","msg":"樓主個教學menu好cs<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\nLoop event, marco, esm 對於designer新手知黎做乜<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n學完基本js 學oo 就直接react再上typescript啦<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"5399527a0f4378c92f22936ce384db844036ffb3","tid":2367330,"uid":92566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-16T06:28:40.000Z","msg":"Lm"},{"pid":"c888dca25a8c648598c6cde6b14c45a11b868433","tid":2367330,"uid":336565,"like":0,"dislike":0,"score":0,"quote":{"pid":"e7302d1f1b9acf8a1847be38534e4463e2e5e02a","tid":2367330,"uid":223799,"like":0,"dislike":1,"score":-1,"quote":{"pid":"216e164a06eaa1c32b82deade2969596403ea35c","tid":2367330,"uid":336565,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-16T03:44:12.000Z","msg":"有冇自學source<br />\n出面上梗夜校都係感覺好basic 兼唔係咁學到code logic"},"citedBy":1,"replyTime":"2021-01-16T05:17:12.000Z","msg":"自學可以由codecademy 開始 幾好"},"citedBy":1,"replyTime":"2021-01-16T07:56:03.000Z","msg":"其實係玩XCODE砌APP code卡住左<br />\n簡單MAINPAGE 三個title 禁入去有介紹有圖<br />\n睇人地同學又幾句array 過DATA打到 我要用3 個LAYOUT砌<br />\n成日要開咁多variables 包一個variables <br />\n好慘連上Google 想抄野都打SEARCH WORD 1999<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8dd850e0f6287184fe992c15cf50d19a756ce05a","tid":2367330,"uid":167574,"like":2,"dislike":3,"score":-1,"citedBy":1,"replyTime":"2021-01-16T16:51:16.000Z","msg":"睇完樓主既github<br />\n做designer完全浪費左你既才能<br />\nnon cs零底可以做到咁講真你應該係天才"},{"pid":"945a6d799748a68492b012169cad33025dc65ce0","tid":2367330,"uid":167574,"like":1,"dislike":0,"score":1,"quote":{"pid":"c888dca25a8c648598c6cde6b14c45a11b868433","tid":2367330,"uid":336565,"like":0,"dislike":0,"score":0,"quote":{"pid":"e7302d1f1b9acf8a1847be38534e4463e2e5e02a","tid":2367330,"uid":223799,"like":0,"dislike":1,"score":-1,"quote":{"pid":"216e164a06eaa1c32b82deade2969596403ea35c","tid":2367330,"uid":336565,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-16T03:44:12.000Z","msg":"有冇自學source<br />\n出面上梗夜校都係感覺好basic 兼唔係咁學到code logic"},"citedBy":1,"replyTime":"2021-01-16T05:17:12.000Z","msg":"自學可以由codecademy 開始 幾好"},"citedBy":1,"replyTime":"2021-01-16T07:56:03.000Z","msg":"其實係玩XCODE砌APP code卡住左<br />\n簡單MAINPAGE 三個title 禁入去有介紹有圖<br />\n睇人地同學又幾句array 過DATA打到 我要用3 個LAYOUT砌<br />\n成日要開咁多variables 包一個variables <br />\n好慘連上Google 想抄野都打SEARCH WORD 1999<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-16T17:00:40.000Z","msg":"真心 如果你係完全零底走去坊間個d教寫apps course完全係哂氣<br />\n第一 零底學寫app完全係學壞手勢 會比個錯覺你原來係xcode拉d component出黎就叫識打code<br />\n<br />\n第二 就算你跟得足個寫apps course 你都只會係識寫一舊work到既垃圾出黎 出面真係落場做係要求你有能力寫到個maintainable 既code base出黎<br />\n<br />\n最正確真係要打好個底學javascript 寫到react<br />\n再諗下學寫app定backend"},{"pid":"7777a384309fbbc3f48dbcfb417d646a057f6dd7","tid":2367330,"uid":232594,"like":7,"dislike":0,"score":7,"quote":{"pid":"8dd850e0f6287184fe992c15cf50d19a756ce05a","tid":2367330,"uid":167574,"like":2,"dislike":3,"score":-1,"citedBy":1,"replyTime":"2021-01-16T16:51:16.000Z","msg":"睇完樓主既github<br />\n做designer完全浪費左你既才能<br />\nnon cs零底可以做到咁講真你應該係天才"},"citedBy":1,"replyTime":"2021-01-16T18:44:17.000Z","msg":"其實就算你讀cs好多野你都係要自學，咁就話人天才就真係好打手feel了"},{"pid":"b0a8cfd31e5015ce5feb09c4cef5b643ead31ccc","tid":2367330,"uid":232594,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2021-01-16T18:49:15.000Z","msg":"除非佢想轉行做web programmer, 唔係既話教designer web dev 係冇乜用，因為根本唔會有人搵designer做埋frontend dev, 一黎唔係佢地專長，應該搵專業frontend programmer黎做，二黎designer工作已經夠繁重，仲邊有時間做埋frontend dev"}]}