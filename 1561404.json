g src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" />"},{"pid":"0d5e78d78e99619f377983d398859d7e9daa7eb1","tid":1561404,"uid":225100,"like":0,"dislike":0,"score":0,"quote":{"pid":"439de869695c4ae39f2ac8a5261e1130d2e421a5","tid":1561404,"uid":123991,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-11T14:52:14.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: x-large;\"><strong><div style=\"text-align: center;\"> <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />出黎呀 自由閪！ <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /></div></strong></span></span><br />\n<strong><div style=\"text-align: center;\"><span style=\"font-size: x-large;\"><span style=\"color: gold;\"> <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />五大訴求 缺一不可 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /></span></span></div></strong><br />\n<div style=\"text-align: center;\"><img src=\"https://na.cx/i/aPJ3iwW.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaPJ3iwW.png&h=bd74ec1d&s={SIZE}\" /></div>"},"citedBy":0,"replyTime":"2019-09-11T15:03:36.000Z","msg":"915大合唱<br />\n成個港島都要企滿佢<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b83e33eca75f8facece213346101739d6e1a57f3","tid":1561404,"uid":225100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T15:04:27.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d02507661acd557e30928ba2a0b18a0daa86116f","tid":1561404,"uid":225100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T15:04:52.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"3b2e9a03534fb7f98cea2cdd545daca09f66016c","tid":1561404,"uid":225100,"like":0,"dislike":0,"score":0,"citedBy":0,"rep