ad/2018/01/16/231331_b964f4f7fea40061cb7281c6e807091c.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F16%2F231331_b964f4f7fea40061cb7281c6e807091c.png&h=1bae3590&s={SIZE}\" />"},{"pid":"574d9715d194bf9efdca39a3f4c4dd60cd44479a","tid":531264,"uid":157697,"like":19,"dislike":1,"score":18,"citedBy":2,"replyTime":"2018-01-16T15:28:45.000Z","msg":"利申：自諗<br />\n<br />\n分開4組數睇<br />\n第1組：1，3，2，<br />\n第2組：5，7，6，<br />\n第3組13，19，14，<br />\n第4組：33，？，？<br />\n<br />\n<br />\n每組第3個字：來自第1個字+1，就如第1組1+1=2，第2組5+1=6，第3組13+1=14<br />\n<br />\n而每組第1個字：來自前一組第3個字+第4個字，就如第1組3+2=5，第2組7+6=13，第3組19+14=33<br />\n<br />\n最後係每組第2個字：來自第1個字+前一組第3個字，就如第2組5+2=7，第3組6+13=19<br />\n<br />\n因此，第4組應該係33，47，34............."},{"pid":"8f180809a09ec9248564f108dd8383eef9082854","tid":531264,"uid":67399,"like":2,"dislike":0,"score":2,"quote":{"pid":"574d9715d194bf9efdca39a3f4c4dd60cd44479a","tid":531264,"uid":157697,"like":19,"dislike":1,"score":18,"citedBy":2,"replyTime":"2018-01-16T15:28:45.000Z","msg":"利申：自諗<br />\n<br />\n分開4組數睇<br />\n第1組：1，3，2，<br />\n第2組：5，7，6，<br />\n第3組13，19，14，<br />\n第4組：33，？，？<br />\n<br />\n<br />\n每組第3個字：來自第1個字+1，就如第1組1+1=2，第2組5+1=6，第3組13+1=14<br />\n<br />\n而每組第1個字：來自前一組第3個字+第4個字，就如第1組3+2=5，第2組7+6=13，第3組19+14=33<br />\n<br />\n最後係每組第2個字：來自第1個字+前一組第3個字，就如第2組5+2=7，第3組6+13=19<br />\n<br />\n因此，第4組應該係33，47，34............."},"citedBy":1,"replyTime":"2018-01-16T15:34:50.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"822fc8f8a82789bffeadacb3f32dd277ea5f7ce3","tid":531264,"uid":55375,"like":0,"dislike":2,"score":-2,"quote":{"pid":"8f180809a09ec9248564f108dd8383eef9082854","tid":531264,"uid":67399,"like":2,"dislike":0,"score":2,"quote":{"pid":"574d9715d194bf9efdca39a3f4c4dd60cd44479a","tid":531264,"uid":157697,"like":19,"dislike":1,"score":18,"citedBy":2,"replyTime":"2018-01-16T15:28:45.000Z","msg":"利申：自諗<br />\n<br />\n分開4組數睇<br />\n第1組：1，3，2，<br />\n第2組：5，7，6，<br />\n第3組13，19，14，<br />\n第4組：33，？，？<br />\n<br />\n<br />\n每組第3個字：來自第1個字+1，就如第1組1+1=2，第2組5+1=6，第3組13+1=14<br />\n<br />\n而每組第1個字：來自前一組第3個字+第4個字，就如第1組3+2=5，第2組7+6=13，第3組19+14=33<br />\n<br />\n最後係每組第2個字：來自第1個字+前一組第3個字，就如第2組5+2=7，第3組6+13=19<br />\n<br />\n因此，第4組應該係33，47，34............."},"citedBy":1,"replyTime":"2018-01-16T15:34:50.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-16T15:40:15.000Z","msg":"wow much solution very logic"},{"pid":"4925b5c734d9b6faffcfac9f58bcb6d036649f5d","tid":531264,"uid":92230,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-16T15:43:12.000Z","msg":"14 同 33 係答案? 定你估"},{"pid":"5bb23a3a49aca493b58ace19a2408f9de1293f6b","tid":531264,"uid":44073,"like":0,"dislike":7,"score":-7,"citedBy":0,"replyTime":"2018-01-16T15:44:51.000Z","msg":"此回覆已被刪除"},{"pid":"877f7bb83ca22b24cb1297438ea859773a6a2900","tid":531264,"uid":65598,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-01-16T15:46:22.000Z","msg":"18,37 ? 9估"},{"pid":"e4ecc1a57dcad695df56ebae9ef382c7e45e19d3","tid":531264,"uid":92230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-16T15:47:00.000Z","msg":"<blockquote>18,37 ? 9估</blockquote><br />\n我都覺係 18, 37, 55..."},{"pid":"387324ec4fb667a925614dbcf9fc995047e3c59c","tid":531264,"uid":100412,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-01-16T15:48:18.000Z","msg":"<a href=\"https://oeis.org/search?q=1%2C3%2C2%2C5%2C7%2C6%2C13%2C19&amp;language=english&amp;go=Search\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Foeis.org%2Fsearch%3Fq%3D1%252C3%252C2%252C5%252C7%252C6%252C13%252C19%26language%3Denglish%26go%3DSearch&d=DwHQS8vmyL0yqodkq4OyuzPUa9iY%2BpOmOVTB4fMSqaQ%3D&h=3948340b\" target=\"_blank\">https://oeis.org/search?q=1%2C3%2C2%2C5%2C7%2C6%2C13%2C19&amp;language=english&amp;go=Search</a>"},{"pid":"cce6ea2636c90df95f4a3defe14d0d12abe65c3f","tid":531264,"uid":92230,"like":16,"dislike":0,"score":16,"citedBy":2,"replyTime":"2018-01-16T15:56:18.000Z","msg":"f(x) = -19x^7/2520+49x^6/240-1553x^5/720+179x^4/16-20981x^3/720+4033x^2/120-808x/105-5<br />\n<br />\nf({1,2,3,4,5,6,7,8}) = {1,3,2,5,7,6,13,19}<br />\n<br />\nf(9) = -119<br />\nf(10) = -911<br />\n<br />\n<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /> <br />\n<br />\n<a href=\"https://www.wolframalpha.com/input/?i=-19x%5E7%2F2520%2B49x%5E6%2F240-1553x%5E5%2F720%2B179x%5E4%2F16-20981x%5E3%2F720%2B4033x%5E2%2F120-808x%2F105-5;+x%3D9\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.wolframalpha.com%2Finput%2F%3Fi%3D-19x%255E7%252F2520%252B49x%255E6%252F240-1553x%255E5%252F720%252B179x%255E4%252F16-20981x%255E3%252F720%252B4033x%255E2%252F120-808x%252F105-5%3B%2Bx%253D9&d=DwHQS8vmyL0yqodkq4OyuzPUa9iY%2BpOmOVTB4fMSqaQ%3D&h=a59ba138\" data-auto-link target=\"_blank\">https://www.wolframalpha.com/input/?i=-19x%5E7%2F2520%2B49x%5E6%2F240-1553x%5E5%2F720%2B179x%5E4%2F16-20981x%5E3%2F720%2B4033x%5E2%2F120-808x%2F105-5;+x%3D9</a>"},{"pid":"e59ec4673d1234e1b4139b2391aab1e029de3cad","tid":531264,"uid":12580,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-16T16:05:53.000Z","msg":"咁分開睇？<br />\n<br />\n1（獨立數字）<br />\n<br />\n3 -1  （減獨立數字）<br />\n2 +3 （加之前個數字）<br />\n5 +2 （加之前個數字）<br />\n<br />\n7 -1 （減獨立數字）<br />\n6 +7 （加之前）<br />\n13 +6 （加之前）<br />\n<br />\n19 -1<br />\n<br />\nSo...<br />\n18? +19<br />\n37? +18<br />\n<br />\n55 ?"},{"pid":"98fdf6eefcea8217504a62a9ce9b09f83906ba20","tid":531264,"uid":29983,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-16T16:26:29.000Z","msg":"1 3 2 5 7 6 13 19<br />\n--------------<br />\n                  1<br />\n                  3<br />\n(1+3)/2 = 2<br />\n2 + 3      = 5<br />\n5 + 2      = 7<br />\n--------------<br />\n(7+5)/2 = 6<br />\n6 + 7      = 13<br />\n13 + 6    = 19<br />\n--------------<br />\n(13 + 19)/2 = <span style=\"color: red;\">16</span><br />\n16 + 19        = <span style=\"color: red;\">25</span>"},{"pid":"e58f36710d2d6a2d46e5daeb2161b23908d751db","tid":531264,"uid":29983,"like":0,"dislike":1,"score":-1,"quote":{"pid":"98fdf6eefcea8217504a62a9ce9b09f83906ba20","tid":531264,"uid":29983,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-16T16:26:29.000Z","msg":"1 3 2 5 7 6 13 19<br />\n--------------<br />\n                  1<br />\n                  3<br />\n(1+3)/2 = 2<br />\n2 + 3      = 5<br />\n5 + 2      = 7<br />\n--------------<br />\n(7+5)/2 = 6<br />\n6 + 7      = 13<br />\n13 + 6    = 19<br />\n--------------<br />\n(13 + 19)/2 = <span style=\"color: red;\">16</span><br />\n16 + 19        = <span style=\"color: red;\">25</span>"},"citedBy":0,"replyTime":"2018-01-16T16:27:32.000Z","msg":"尻估<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"4e4878f35592ce07562821527a2f12c30ee92f29","tid":531264,"uid":118463,"like":8,"dislike":0,"score":8,"quote":{"pid":"cce6ea2636c90df95f4a3defe14d0d12abe65c3f","tid":531264,"uid":92230,"like":16,"dislike":0,"score":16,"citedBy":2,"replyTime":"2018-01-16T15:56:18.000Z","msg":"f(x) = -19x^7/2520+49x^6/240-1553x^5/720+179x^4/16-20981x^3/720+4033x^2/120-808x/105-5<br />\n<br />\nf({1,2,3,4,5,6,7,8}) = {1,3,2,5,7,6,13,19}<br />\n<br />\nf(9) = -119<br />\nf(10) = -911<br />\n<br />\n<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /> <br />\n<br />\n<a href=\"https://www.wolframalpha.com/input/?i=-19x%5E7%2F2520%2B49x%5E6%2F240-1553x%5E5%2F720%2B179x%5E4%2F16-20981x%5E3%2F720%2B4033x%5E2%2F120-808x%2F105-5;+x%3D9\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.wolframalpha.com%2Finput%2F%3Fi%3D-19x%255E7%252F2520%252B49x%255E6%