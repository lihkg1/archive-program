normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6ad7331dca5f11e1a1263582485d6ec9eb6c6c4d","tid":1969250,"uid":267494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-12T10:55:34.000Z","msg":"麻煩仲有桂民海<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"be4253fd898f62cb37bd3fc6816f5ae5ae961167","tid":1969250,"uid":51230,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-04-12T10:56:18.000Z","msg":"推！！！！"},{"pid":"fbcd77343b0d3e2ea6e227aa1815b5941e366c53","tid":1969250,"uid":59460,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-12T10:56:23.000Z","msg":"要數既話點止9個tweet咁少<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"d268e46827a319d5815842ddaa89bf29adba60fd","tid":1969250,"uid":173207,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec73b865d2095867547cd9f4635765c1b3cd6950","tid":1969250,"uid":40267,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-04-12T09:41:35.000Z","msg":"是咁的, 早兩日含春瑩「邀請」美國高官到支那「享受自由」<br />\n話「隨時歡迎到中國，你可以跟街上任何一人交談，享受自由」咁喎<br />\n仲攞羅斯福號事件船長crozier被炒嚟寸美國<br />\n<br />\n華春瑩邀請美國高官到中國享受自由<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1967666\" data-auto-link target=\"_blank\">https://lih.kg/1967666</a><br />\n<br />\n今日，美國聯邦通信委員會共和黨委員 Brendan Carr怒寸含春瑩<br />\n尋日起連發9條推文，稱讚含春瑩的邀請『太棒了』，隨即提出要求：<br />\n<br />\n1. 首先，我想與艾芬醫生交談。她在武漢市中心醫院工作，曾試圖對病毒發出預警。你<br />\n能讓她現身，我能和她說說話嗎？<br />\n<br />\n2. 接下來，我想與陳秋實和方斌聊聊，這兩位視頻博主試圖讓世界瞥見不被過濾的武漢<br />\n。你能讓他們現身，讓我們可以說說話嗎？<br />\n<br />\n3. 接下來，我想與李澤華談談。他在武漢做新聞記者，拒絕對Covid19保持沉默。他上一<br />\n次直播了自己被逮捕的過程。你能讓他現身，我和他說說話嗎？<br />\n<br />\n4. 然後，我想和許志永談談。在就疫情爆發批評你的黨魁之後，他被捕了。你能讓他現<br />\n身，我能和他說說話嗎？<br />\n<br />\n5. 他們都不能出來說話嗎？真奇怪。那讓我跟任志強談一談。他因為撰文批評你的政權<br />\n掩蓋中共病毒爆發，而犯下重罪。你能讓他現身，我能和他說說話嗎？<br />\n<br />\n6. 英雄醫生李文亮又遭遇了什麼？他在半夜被拖到派出所，被迫撤回他希望全世界聽到<br />\n的預警。<br />\n<br />\n7. 我可以和徐章潤談談嗎？他是北京的法學教授，寫了一篇題為&ldquo;病毒警報&rdquo;的文章。<br />\n它說出了世界所知道的：你的專制政權和審查制度阻礙了延緩冠狀病毒傳播的努力。你能<br />\n讓他現身嗎？<br />\n<br />\n8. 然後，我想和在武漢協和醫院工作的謝琳卡談一談。她與其他武漢市醫生一起，試圖<br />\n敲響中共病毒的警鐘，然後被官員申斥，被噤聲。我可以和她說話嗎？<br />\n<br />\n最後，卡爾圈了華春瑩，問她，你的邀請是否還算數？還是也像其它在中國的事一樣，突<br />\n然就消失了？<br />\n<br />\n每條推文都獲得大量點贊。」<br />\n<br />\n<a href=\"https://twitter.com/BrendanCarrFCC/status/1248442812414201866\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2FBrendanCarrFCC%2Fstatus%2F1248442812414201866&d=6Nb1RK4hIZDTz%2Fb962Zoj4HZfmY0V3SDPlGVafywHRI%3D&h=e329f063\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftwitter.com%2FBrendanCarrFCC%2Fstatus%2F1248442812414201866&h=678d1137\" data-auto-link target=\"_blank\">https://twitter.com/BrendanCarrFCC/status/1248442812414201866</a><br />\n<br />\n台仔原文翻譯: <a href=\"https://www.ptt.cc/bbs/Gossiping/M.1586683023.A.11D.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ptt.cc%2Fbbs%2FGossiping%2FM.1586683023.A.11D.html&d=6Nb1RK4hIZDTz%2Fb962Zoj4HZfmY0V3SDPlGVafywHRI%3D&h=f6104783\" data-auto-link target=\"_blank\">https://www.ptt.cc/bbs/Gossiping/M.1586683023.A.11D.html</a><br />\n<br />\n想點回應呀支那狗<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n點想講以上人仕全部唔存在呀<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-12T11:00:41.000Z","msg":"話唔定可能揀推佢哋入去同啲肺炎人士一齊困獸鬥 已經病死咗"},{"pid":"fd1c0675a12e806591b3113e4c0f33ff1cd66c70","tid":1969250,"uid":4840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-12T11:02:37.000Z","msg":"推"},{"pid":"57712836ab77bb7649c95e4afd95eaa3d7ab3a00","tid":1969250,"uid":33874,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-12T11:03:12.000Z","msg":"春：死鬼佬唔識英文？街上任何人呀！死哂嘅點出街呀"},{"pid":"7e6d402ee713023ddf676f1277099266ddbe9e9b","tid":1969250,"uid":297997,"li