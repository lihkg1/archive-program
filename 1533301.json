pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"1596c874a65212ff49a67dddad7814d228ef1cfd","tid":1533301,"uid":13099,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-09-02T17:05:24.000Z","msg":"今日梁秋雲惡行<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><br />\n第一：有學生喺前面 仲特登加油 學生走慢啲都差啲俾佢撞<br />\n第二：扮對話，表面就扮曬野話想解決件事，其實佢背後就打電話call狗。啲狗一嚟到，佢就拿拿聲開車走人，剩低啲仲著住校服嘅學生同啲狗對侍，啲狗上曬gear，舉曬旗，好彩大埔啲街坊及時落街支援學生。"},{"pid":"1e0e637762e27b5558b9fe84d8ab73756225d33a","tid":1533301,"uid":103262,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T17:08:43.000Z","msg":"推"},{"pid":"0d56c1ce0619953fa28f38f94f4aac5ae390a6fb","tid":1533301,"uid":13099,"like":0,"dislike":0,"score":0,"quote":{"pid":"1596c874a65212ff49a67dddad7814d228ef1cfd","tid":1533301,"uid":13099,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-09-02T17:05:24.000Z","msg":"今日梁秋雲惡行<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><br />\n第一：有學生喺前面 仲特登加油 學生走慢啲都差啲俾佢撞<br />\n第二：扮對話，表面就扮曬野話想解決件事，其實佢背後就打電話call狗。啲狗一嚟到，佢就拿拿聲開車走人，剩低啲仲著住校服嘅學生同啲狗對侍，啲狗上曬gear，舉曬旗，好彩大埔啲街坊及時落街支援學生。"},"citedBy":0,"replyTime":"2019-09-02T17:10:47.000Z","msg":"補充第一點，梁秋雲嘗試渣車離開學校，有同學係佢架車前面，佢見到，而且仲加油向前<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"c30f3d6e09822e10fd39b854de9a09017e63e340","tid":1533301,"uid":103262,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T17:15:51.000Z","msg":"推"},{"pid":"8450fddc10642aebbe39af4ff42d39f00661487a","tid":1533301,"uid":142312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T17:24:03.000Z","msg":"推"},{"pid":"04dee88a4274513597354bef5ef7a3b53680980b","tid":1533301,"uid":80528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T17:24:58.000Z","msg":"九月三日 三罷<br />\n<img src=\"https://na.cx/i/UWRbToz.png\" data-