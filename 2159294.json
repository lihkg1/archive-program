tw/article/breakingnews/3262061\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fec.ltn.com.tw%2Farticle%2Fbreakingnews%2F3262061&d=lmKMjREij7Lxzb1c6qtKJCZO8jd1M6XCUNMtuDfdPZA%3D&h=7ccb3244\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fec.ltn.com.tw%2Farticle%2Fbreakingnews%2F3262061&h=f65ac48f\" target=\"_blank\">https://ec.ltn.com.tw/article/breakingnews/3262061</a>"},"citedBy":0,"replyTime":"2020-08-16T09:20:47.000Z","msg":"乜野小規模？"},{"pid":"c9a9be831ed1aafb1b4e87aa8e9bdf70917c79ca","tid":2159294,"uid":269712,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-08-16T09:23:20.000Z","msg":"郭文貴又露底<img src=\"/assets/faces/lm2/donno.gif\" class=\"hkgmoji\" />, 講咩[政治暴亂] 跟哂支共口敏<img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" /><br />\n<br />\n係支持嘅實有其他詞語代替<img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" /><br />\n<br />\n支共最睇重文字嘅意義, 郭文貴就跟到足 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> 撐邊就唔洗講啦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"8985b1506dfcf4773565d3ba49933968f29e6660","tid":2159294,"uid":59511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-16T09:23:26.000Z","msg":"流浮山299刀手到咗未？"},{"pid":"ac530b6d9112ef65b02d1e0dfe93e550440230a6","tid":2159294,"uid":59511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-16T09:23:45.000Z","msg":"<blockquote>流浮山200刀手到咗未？</blockquote>"},{"pid":"419ece7c481e978cc04cb72aa27bfea9f05cf958","tid":2159294,"uid":294518,"like":1,"dislike":0,"score":1,"quote":{"pid":"c10388a6275e7426403e90b8f8a132305d45ee25","tid":2159294,"uid":251732,"like":1,"dislike":1,"score":0,"quote":{"pid":"e575353e870bbb972bece35c9daa6fb2ce3c7fd1","tid":2159294,"uid":250888,"like":1,"dislike":0,"score":1,"quote":{"pid":"ec6bd8d3c1974fc5c78e8b6a259e47607abffb36","tid":2159294,"uid":269533,"like":5,"dislike":2,"score":3,"citedBy