lockquote>點解勁近射條友都可以一D血都唔扣,係件甲超勁定外掛<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n點射法<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 有分重甲 輕甲 重甲減多D 同呢隻GAME 要描頭打唔係射唔死人架"},{"pid":"88885315a8c7fd3e6994512044b9c4a63733a403","tid":250753,"uid":39087,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-31T05:47:45.000Z","msg":"[run] 有巴士搭"},{"pid":"97172851103cdc906b573db5983e892fb555f692","tid":250753,"uid":39087,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-05T13:02:01.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"7833e4f1549ab443fe0fff8748e8d116594bdfe8","tid":250753,"uid":39087,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-06T04:44:24.000Z","msg":"可以入RC搵我地"}]}