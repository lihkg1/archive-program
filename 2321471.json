=\"hkgmoji\" />"},{"pid":"0e93935aca0cab0f150cda948b87d6db68cfafcb","tid":2321471,"uid":77905,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T14:41:27.000Z","msg":"以為係台灣新聞會誇飾，原來係樓主譯 <img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"1e9ea0a1fda408dc6d0b97d3446e1b4810db950a","tid":2321471,"uid":301820,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-11T14:42:14.000Z","msg":"雖然日本搞過中國人<br />\n但打爆共匪係世人責任<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"89e39533dd76c2ea163da0a96eabfe5799bcb9f9","tid":2321471,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T14:52:14.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"94fe04b8b393dab517d5d89b909643fa73755ae7","tid":2321471,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T15:01:25.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}