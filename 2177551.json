d":37054,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-27T20:42:40.000Z","msg":"波係白色定米色，唔想減肥先減波"},"citedBy":1,"replyTime":"2020-08-27T20:47:56.000Z","msg":"波好大部份肯定是由白色脂肪組成，但減肥先減波依樣嘢我就唔太清楚<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />。"},{"pid":"9673f43a7ec0d4b01ac5725ff65ea5d4209957af","tid":2177551,"uid":369920,"like":0,"dislike":1,"score":-1,"quote":{"pid":"8b15996fc6c15b9ec3708f1eb25899f43bb3f4dc","tid":2177551,"uid":38861,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0485b304a340306e66b86739bc8915fd8a175ae4","tid":2177551,"uid":146055,"like":7,"dislike":1,"score":6,"citedBy":1,"replyTime":"2020-08-27T20:16:52.000Z","msg":"Ching好勤力<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-27T20:37:17.000Z","msg":"一日一篇長遠應該頂得順<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-27T21:08:34.000Z","msg":"加油呀"},{"pid":"8fd2286828116ea13ef29148f4c34fb9f2ce501d","tid":2177551,"uid":25170,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-27T21:12:49.000Z","msg":"LM<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"8242b37363bec3c193be04535e50fd699b28d804","tid":2177551,"uid":155238,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-27T21:27:10.000Z","msg":"我淨係知我成身都係g肪<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" />"},{"pid":"96352e0ecb0deb3247fa1bda0550a43c1c8ba4eb","tid":2177551,"uid":78429,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-27T22:14:01.000Z","msg":"樓主整埋動畫就可以變港版ted ed"},{"pid":"813dbf1849b5f62e2da42a7c69c10af09532407f","tid":2177551,"uid":103981,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-27T22:18:36.000Z","msg":"lm"},{"pid":"5832534f0a1428387cdda9d0523cb81ab38ff174","tid":2177551,"uid":198467,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-27T22:22:10.000Z","msg