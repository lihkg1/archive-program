e":0,"dislike":1,"score":-1,"quote":{"pid":"0da86127ae05e719d15c1fe2a4f3fd11b6ec688d","tid":1323413,"uid":28831,"like":14,"dislike":0,"score":14,"citedBy":3,"replyTime":"2019-07-16T08:41:50.000Z","msg":"香港會閪咩<br />\n佢夠膽查真係比黑警反佢枱"},"citedBy":1,"replyTime":"2019-07-16T08:42:44.000Z","msg":"(今日) 信報：中央研設獨立調查委員會<br />\n<a href=\"https://lihkg.com/thread/1322482/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1322482/page/1</a>"},"citedBy":0,"replyTime":"2019-07-16T08:45:33.000Z","msg":"真係整先再講啦<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><br />\n塞幾個泛民議員入去就信佢"},{"pid":"1371ed66ba71a0bea389a3035748518a79a2c17d","tid":1323413,"uid":134071,"like":0,"dislike":0,"score":0,"quote":{"pid":"4777f10086f87f2cda9438a4a97efeed5bd3363f","tid":1323413,"uid":79182,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2019-07-16T08:41:35.000Z","msg":"支持香港政府根據國際標準制定委員會<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-16T08:46:26.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"bb84b5fccc444f0a40b0be1a393aca9056651263","tid":1323413,"uid":254594,"like":3,"dislike":0,"score":3,"quote":{"pid":"3572d465acb2c83ff388426086f9a690880bbac1","tid":1323413,"uid":211461,"like":16,"dislike":0,"score":16,"citedBy":2,"replyTime":"2019-07-16T08:41:49.000Z","msg":"林鄭：絕不出賣黑警"},"citedBy":0,"replyTime":"2019-07-16T08:46:33.000Z","msg":"佢保得住自己先算啦<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"c6e715d5095a05ac36f0139ee7b36a2804cb107e","tid":1323413,"uid":119729,"like":0,"dislike":0,"score":0,"quote":{"pid":"0da86127ae05e719d15c1fe2a4f3fd11b6ec688d","tid":1323413,"uid":28831,"like":14,"dislike":0,"score":14,"citedBy":3,"replyTime":"2019-07-16T08:41:50.000Z","msg":"香港會閪咩<br />\n佢夠膽查真係比黑警反佢枱"},"citedBy":1,"replyTime":"2019-07-16T08:48:45.000Z","msg":"交d中下層出去有咩所謂<br />\n到時要挽民心"},{"pid":"6b3a46093e8d57f7563fbe262fa436c7c47e80e8","tid":1323413,"uid":134071,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-16T08:49:05.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/daily/article/20190619/20707887\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20190619%2F20707887&d=FVRAyOQFEUVrsg2I2pbTeSC3g8rst4cc2NZsp7q1N1o%3D&h=abb06911\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20190619%2F20707887&h=0decb805\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20190619/20707887</a><br />\n<br />\n 2019年06月19日<br />\n黃背心運動 法專家查警暴 <br />\n<br />\n警務處處長盧偉聰及特首林鄭月娥先後以現時已有既定程序處理投訴警察事宜為由，拒絕成立獨立委員會，調查警方在6.12鎮壓示威的手法。<strong>類似濫用武力事件在最近的法國黃背心示威浪潮中也有發生，在各界壓力之下，法國政府亦有成立專門小組調查警方。 </strong><br />\n<br />\n2,448名示威者受傷<br />\n<br />\n法新社周一報道，法國內政部已成立一個由15名專家組成的小組，檢討警方在鎮壓黃背心連串示威中的手法。專家包括檢控官、社會學家及保安專家，法國內政部長卡斯塔內表示，政府期望聆聽專家對警方採取的鎮壓手段的意見，包括警方使用的武器。<br />\n<br />\n去年底開始爆發的黃背心運動中，法國警方出動過橡膠子彈及「刺痛防暴手榴彈」（Sting Ball Grenades），造成23名示威者眼部視力損失、5人手部傷殘、1人睾丸傷殘。據內政部數字，至5月中止，黃背心運動造成2,448名示威者受傷、1,797名警察等保安部隊人員受傷。<br />\n<br />\n<strong>聯合國在今年3月要求法國對警方鎮壓黃背心運動手法進行調查</strong>，聯合國人權事務高級專員Michelle Bachelet指出，黃背心示威者視運動為爭取經濟權益及參與公共事務，法國政府應與示威者保持對話，並徹查所有濫用武力的個案。<br />\n<br />\n法新社"},{"pid":"9d7bbeddb0f1622777ce44a198044a54330fef02","tid":1323413,"uid":134071,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-16T08:50:06.000Z","msg":"要send呢個post比「撐警群組」 <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4bcc3ce6d77a8db8440b459db4e2f2aab64c9058","tid":1323413,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-16T08:51:20.000Z","msg":"<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"6028f20c33134fb57529fd199a674278b1137546","tid":1323413,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-16T09:16:24.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}