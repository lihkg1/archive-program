s=\"hkgmoji\" />"},{"pid":"edf3d63de44121f6bd1552f236578e4e849cde9d","tid":932142,"uid":72009,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-12-15T00:52:40.000Z","msg":"我老豆70年代已是中產，當時已住千呎住宅，後來80年代初股市大瀉，企錯邊破產，債主上門，老豆走佬，一家7口最後住公屋，我哥及家姐中三後就出來打工，全家無怨佢，成王敗寇，有甚麼好怨！<br />\n<br />\n而且我們細時，老豆真錫我們"},{"pid":"c40d17917512d0e707943966be4869e699cf0870","tid":932142,"uid":2471,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-15T00:53:22.000Z","msg":"你矮唔關你窮事 唔好賴"},{"pid":"0ea67543c70121f2467dd2e54c9f772454d88068","tid":932142,"uid":79869,"like":3,"dislike":0,"score":3,"quote":{"pid":"0c00c0591f47d90f624ed15d3e919a001b2f730a","tid":932142,"uid":31215,"like":36,"dislike":3,"score":33,"citedBy":2,"replyTime":"2018-12-07T13:49:43.000Z","msg":"建議樓主睇下小老闆創辦人故事<br />\n阿爸窮j冇錢留俾佢，仲去埋外地<br />\n但佢經歷左一啲事之後<br />\n奮鬥之下開左個攤檔仔賣紫菜<br />\n之後阿爸爭人好多錢<br />\n做攤檔仔賣極都唔夠還<br />\n之後佢先諗方法說服seven 俾佢上架<br />\n呢個過程又係充滿困難<br />\n最後到而家世界各地都有得賣<br />\n<br />\n佢做呢啲野嘅時候廿幾歲<br />\n而家都好似三十左右"},"citedBy":0,"replyTime":"2018-12-15T00:54:22.000Z","msg":"Good suggestion <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n可以多D睇傳記<br />\n每個人既人生都唔同，唔係人人都一帆風順<br />\n香港起碼唔係戰亂地區<br />\n但我想信逆境可以創造英雄<br />\n生於憂患，死於安樂"},{"pid":"f881b5c6f3c33a3e8877e8253ea446d511c900b9","tid":932142,"uid":878,"like":6,"dislike":1,"score":5,"citedBy":0,"replyTime":"2018-12-15T01:04:39.000Z","msg":"人窮唔係最慘<br />\n最慘係思想窮 <br />\n唔好畀環境局限咗自己嘅心態"},{"pid":"173e85f7ef99eaf237c9eed5c5efa7c1f34983e4","tid":932142,"uid":196922,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T01:13:25.000Z","msg":"此回覆已被刪除"},{"pid":"91711f781aa2947d66afa8aedea873ba6a3879fa","tid":932142,"uid":154783,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-15T01:18:24.000Z","msg":"有時都會咁諗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 但都係唉一聲就算<br />\n有咩計 靠自己囉 唔通日日怨咩"},{"pid":"0c39409744d8d4e63b2c80b0606d1b9a8e48d5cd","tid":932142,"uid":54593,"like":2,"dislike":1,"score":1,"quote":{"pid":"9dcd7ac77c3fab019f0cd61444698f2e67815df3","tid":932142,"uid":37475,"like":0,"dislike":1,"score":-1,"quote":{"pid":"82b9d832a76d9cbc2393d9cc1597722fdd834f9d","tid":932142,"uid":54593,"like":11,"dislike":0,"score":11,"quote":{"pid":"0c00c0591f47d90f624ed15d3e919a001b2f730a","tid":932142,"uid":31215,"like":36,"dislike":3,"score":33,"citedBy":2,"replyTime":"2018-12-07T13:49:43.000Z","msg":"建議樓主睇下小老闆創辦人故事<br />\n阿爸窮j冇錢留俾佢，仲去埋外地<br />\n但佢經歷左一啲事之後<br />\n奮鬥之下開左個攤檔仔賣紫菜<br />\n之後阿爸爭人好多錢<br />\n做攤檔仔賣極都唔夠還<br />\n之後佢先諗方法說服seven 俾佢上架<br />\n呢個過程又係充滿困難<br />\n最後到而家世界各地都有得賣<br />\n<br />\n佢做呢啲野嘅時候廿幾歲<br />\n而家都好似三十左右"},"citedBy":3,"replyTime":"2018-12-07T14:09:37.000Z","msg":"除左泰國, 有冇香港例子參考下"},"citedBy":1,"replyTime":"2018-12-14T23:06:40.000Z","msg":"參考人係唔會發達架 on9 仔<br />\n自己用下個腦啦"},"citedBy":1,"replyTime":"2018-12-15T01:22:44.000Z","msg":"你都戇撚鳩<br />\n冇人話過參考人就一定會發達<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n但係睇人地既故事至少可以調整自己心態<br />\n要知道每人面對既困難都唔同 未必同金錢相關<br />\n學下點樂觀積極面對問題<br />\n起碼唔會好似樓主咁自怨自艾"},{"pid":"cfce7e8c4f16b94e2789c18684ebc9aaf052aa73","tid":932142,"uid":109560,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T01:26:07.000Z","msg":"我屋企都窮 窮無所謂<br />\n最仆街係無咩放時間同花心機係自己身上<br />\n細個話好愛我 但放假都無帶過我去玩<br />\n最多行街 係陪佢<br />\n我唔介意窮 自己都好慳<br />\n但窮得黎又唔理我真係好仆街<br />\n到依家我都記得我細個佢無認真聽過我講一句野<br />\n其實到依家我都好憎我呀媽<br />\n但大個左覺得屋企人係無可取替<br />\n個心情好矛盾"},{"pid":"b0ad29608de5d472b4a92919e6c44f4f9eebbd09","tid":932142,"uid":119361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T01:28:08.000Z","msg":"<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"30d75b8d8171d496f768b56c100a16d2b14e1b28","tid":932142,"uid":188279,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T02:02:28.000Z","msg":"有，但好開心，冇後悔"},{"pid":"61cd582728926e9a0a20854ddb6600d6e047b17c","tid":932142,"uid":52595,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-15T02:09:44.000Z","msg":"此回覆已被刪除"},{"pid":"bd6138697d2935b99fcfdcb3fcbd9c772010d8ad","tid":932142,"uid":72009,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T02:10:58.000Z","msg":"點衰都好，但你長病，係你身邊只剩家人，朋友，初頭咪間中探下你，之後fb ig見。<br />\n<br />\n至於改變命運，靠自己啦"},{"pid":"40bd2cc2784f7b967e8745e7eb773bf79f6a87e4","tid":932142,"uid":225347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T02:14:37.000Z","msg":"咪同人比，唔生都生左你出黎，成日望住其他人盞自卑，窮就唔好諗發圍，窮唔止令你冇錢，窮係包埋見識少，心胸狹窄，智識缺乏，所以乖乖地安守本份，都總會食到餐安樂茶飯。<br />\n越望其他人只會令自己唔開心，試下搵下啲錢以外既生存意義"},{"pid":"f6cebd7933227f5d57800b17588d0632f8d06d8a","tid":932142,"uid":221490,"like":0,"dislike":0,"score":0,"quote":{"pid":"d3ed6a4a34aeac5f23a87ebef6723da989956ffd","tid":932142,"uid":197852,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2018-12-07T13:37:59.000Z","msg":"由細到大<br />\n一比同學知我住公屋<br />\n要用呀哥既二手衫二手書<br />\n就笑我窮<br />\n因為屋企無野好食<br />\n搞到我營養不良好矮<br />\n啲同學暑假去旅行<br />\n我暑假就要翻工<br />\n<br />\n世界公平咩？<br />\nsem break啲同學又去澳洲啦<br />\n我呢？<br />\n翻工"},"citedBy":0,"replyTime":"2018-12-15T02:17:13.000Z","msg":"有時唔係睇現在 你比同期人早左出社會<br />\n咁到大家真正出社會果時你會優勝好多"},{"pid":"c7c39407740be7d2a2a5f31049ef89e726880559","tid":932142,"uid":122570,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T02:19:01.000Z","msg":"建議樓主唔好上咁多連登，因為連登仔係痴撚線，就算班窮撚都會扮自己有幾層樓係網路世界笑返窮撚<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"df02e69ef62d68bcb9d917f5602c5a33f631fc19","tid":932142,"uid":225347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T02:33:15.000Z","msg":"樓上班友一味話成功就應該點點點，事實係大把人努力完都係失敗，窮人成功佔極少數，不如改變下自己心態，喺你有限既資源下尋找屬於你既樂趣<br />\n連登仔最叻就係用錢黎衡量人，建議自問係容易受人影響既，上少啲連登啦。<br />\n冇錢真係問題不大，冇錢都可以有女，收入少都可以去旅行，係細個冇得去咁解"},{"pid":"03f23f3a0c2824cf3e07e9b462d345a1268f8ba0","tid":932142,"uid":74824,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-12-15T02:38:27.000Z","msg":"比來比去的話 一定會有人比你更好<br />\n雖然自己有時都會鑽牛角尖<br />\n但試下係你生活現有嘅嘢搵下滿足感啦<br />\n又或者花時間係愛好或者學習某樣技能上分下心<br />\n雖然人地玩樂更易到手 但對你講得來不易 反而更會珍惜<br />\n靠你自己手得到嘅更值得滿足 比其他人簡單得到嘅更有意義<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"57104d0726c4e8290692198e4e88a20472e21adc","tid":932142,"uid":72009,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T02:39:46.000Z","msg":"如果太自卑，建議樓主去叫下高鍾雞"},{"pid":"057baa81387ab5531bfdcbdf770c906793e1144c","tid":932142,"uid":37475,"like":0,"dislike":2,"score":-2,"quote":{"pid":"0c39409744d8d4e63b2c80b0606d1b9a8e48d5cd","tid":932142,"uid":54593,"like":2,"dislike":1,"score":1,"quote":{"pid":"9dcd7ac77c3fab019f0cd61444698f2e67815df3","tid":932142,"uid":37475,"like":0,"dislike":1,"score":-1,"quote":{"pid":"82b9d832a76d9cbc2393d9cc1597722fdd834f9d","tid":932142,"uid":54593,"like":11,"dislike":0,"score":11,"citedBy":3,"replyTime":"2018-12-07T14:09:37.000Z","msg":"除左泰國, 有冇香港例子參考下"},"citedBy":1,"replyTime":"2018-12-14T23:06:40.000Z","msg":"參考人係唔會發達架 on9 仔<br />\n自己用下個腦啦"},"citedBy":1,"replyTime":"2018-12-15T01:22:44.000Z","msg":"你都戇撚鳩<br />\n冇人話過參考人就一定會發達<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n但係睇人地既故事至少可以調整自己心態<br />\n要知道每人面對既困難都唔同 未必同金錢相關<br />\n學下點樂觀積極面對問題<br />\n起碼唔會好似樓主咁自怨自艾"},"citedBy":0,"replyTime":"2018-12-15T02:44:59.000Z","msg":"唔好浪費時間啦垃殺,<br />\n聽你講兩句都知你睇黎都多奇餘<br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"c6d76cf239dd5e45ae3070e1728525cd1fb85a00","tid":932142,"uid":214534,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-12-15T02:50:17.000Z","msg":"<span style=\"font-size: x-large;\">2018年喇<br />\n窮撚讀完大學就可以發達咩，唔好同我講神科，窮撚讀完神科一千個有冇一個？<br />\n窮撚讀完書得到既只不過係一份舒服少少既工咋<br />\n仲要求神拜佛兩老身體健康<br />\n唔係諗住可以同有家底既人比下話</span>"}]}