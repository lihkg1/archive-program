{"tid":859183,"cid":5,"subCid":0,"title":"гҖҗеҮ¶е®…жӢҚиіЈгҖ‘зӣ§еҮұеҪӨдјҸеұҚе№іеҸ°жҲ¶жӢҚиіЈ дҪҺеёӮеғ№3жҲҗ","createTime":"2018-10-12T10:24:00.000Z","updateTime":"2018-11-12T16:39:20.000Z","uid":184679,"like":48,"dislike":6,"uniUserReply":38,"replies":[{"pid":"e3486d8851d95a099c67b3d3fba013df1f8d3948","tid":859183,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-12T10:24:00.000Z","msg":"еҘіжӯҢжүӢзӣ§еҮұеҪӨ8жңҲж–јдҪҸжүҖеўңжЁ“иә«дәЎпјҢдјҸеұҚе–®дҪҚж—ҘеүҚж–јжӢҚиіЈиЎҢжӢҚиіЈпјҢеҸ«еғ№дҪҺеёӮеғ№3жҲҗгҖӮ<br />\n<br />\nз’°дәһзү©жҘӯжӢҚиіЈиЎҢиіҮж–ҷйЎҜзӨәпјҢи·‘йҰ¬ең°жҲҗе’ҢйҒ“еҳүйҖёи»’5жЁ“Bе®ӨйҖЈе№іеҸ°жҲ¶пјҢеҜҰз”Ёйқўз©Қ602ж–№е‘ҺпјҢе№іеҸ°йқўз©Қ1,274ж–№е‘ҺпјҢ2жҲҝй–“йҡ”пјҢе°Үж–јжң¬жңҲ23ж—ҘйҖІиЎҢжӢҚиіЈпјҢеә•еғ№1,050иҗ¬е…ғгҖӮз’°дәһи‘ЈдәӢзёҪз¶“зҗҶеҸҠжӢҚиіЈеё«жӣҫеӮ‘дҝҠиЎЁзӨәпјҢе–®дҪҚзӮәдәӢж•…е–®дҪҚпјҢзҸҫжҷӮеёӮеғ№1,600иҗ¬е…ғпјҢиӢҘзӮәеҮ¶е®…еүҮзҙ„1,200иҗ¬е…ғпјҢжҳҜж¬Ўй–Ӣеғ№ијғеёӮеғ№дҪҺ34%гҖӮжҘӯдё»ж–ј2006е№ҙ6жңҲд»Ҙ580иҗ¬е…ғиІ·е…Ҙе–®дҪҚпјҢеҰӮд»Ҙеә•еғ№е”®еҮәзҚІеҲ©470иҗ¬е…ғпјҢеҚҮеҖј8жҲҗгҖӮ<br />\n<br />\n<a href=\"http://s.nextmedia.com/realtime/a.php?i=20181012&amp;s=7015342&amp;a=58787479\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fs.nextmedia.com%2Frealtime%2Fa.php%3Fi%3D20181012%26s%3D7015342%26a%3D58787479&d=SOIlvL8gMyq5cs67G5zfI54f2li5K%2Fs6EGgmwhpeblA%3D&h=026eedc0\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fs.nextmedia.com%2Frealtime%2Fa.php%3Fi%3D20181012%26s%3D7015342%26a%3D58787479&h=d7736f23\" data-auto-link target=\"_blank\">http://s.nextmedia.com/realtime/a.php?i=20181012&amp;s=7015342&amp;a=58787479</a>"},{"pid":"c872551f2fff87285194e5f4d6e94202c8da32aa","tid":859183,"uid":157362,"like":98,"dislike":4,"score":94,"citedBy":0,"replyTime":"2018-10-12T10:24:49.000Z","msg":"жӯӨеӣһиҰҶе·Іиў«еҲӘйҷӨ"},{"pid":"65e81d4f16f8531ffb503c668d0b8a08265e2a73","tid":859183,"uid":63950,"like":171,"dislike":6,"score":165,"citedBy":0,"replyTime":"2018-10-12T10:25:49.000Z","msg":"жӯӨеӣһиҰҶе·Іиў«еҲӘйҷӨ"},{"pid":"66e3ce71e859ed6b9824c6cc2f9dd81705895c0a","