RvX5t488CyQVPYA</a><br />\neng: <a href=\"https://forms.gle/BmdiqkhX5pBEgZDy5\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2FBmdiqkhX5pBEgZDy5&d=1ClhXrEf11pGEOLLd6ameN%2BR0LtvndqJ8lr%2BzYsHiyM%3D&h=1658d6ba\" data-auto-link target=\"_blank\">https://forms.gle/BmdiqkhX5pBEgZDy5</a><br />\n<br />\n工會Facebook：<a href=\"https://www.facebook.com/HKFUnion/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FHKFUnion%2F&d=1ClhXrEf11pGEOLLd6ameN%2BR0LtvndqJ8lr%2BzYsHiyM%3D&h=09967255\" data-auto-link target=\"_blank\">https://www.facebook.com/HKFUnion/</a><br />\n工會Telegram channel：<a href=\"https://t.me/HKFIEGU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FHKFIEGU&d=1ClhXrEf11pGEOLLd6ameN%2BR0LtvndqJ8lr%2BzYsHiyM%3D&h=0a53575b\" data-auto-link target=\"_blank\">https://t.me/HKFIEGU</a><br />\n<br />\n#特別會員大會<br />\n<br />\n<img src=\"https://na.cx/i/gi401GS.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fgi401GS.jpg&h=ece6740d&s={SIZE}\" />"},{"pid":"204776f9502be815448b346ee4ad4e9e748a02e9","tid":1743504,"uid":3677,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-21T08:57:44.000Z","msg":"見到呢啲標題都唔想推啦"},{"pid":"77594c3aa06ae49c2b15b49dce788daa4c2b491d","tid":1743504,"uid":28435,"like":0,"dislike":0,"score":0,"quote":{"pid":"204776f9502be815448b346ee4ad4e9e748a02e9","tid":1743504,"uid":3677,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-21T08:57:44.000Z","msg":"見到呢啲標題都唔想推啦"},"citedBy":0,"replyTime":"2019-11-21T08:59:05.000Z","msg":"我想喎"},{"pid":"52b59344fb8d36ab733121b5e6dfc373abb2d584","tid":1743504,"uid":100714,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T09:00:07.000Z","msg":"Diu<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{