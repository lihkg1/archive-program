al/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e7f905b23dc77464ec826abb5883c5f8293770ba","tid":2273760,"uid":195248,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-11-06T04:05:07.000Z","msg":"屌你老母成班閱讀理解係咪u?<br />\n標題寫到明<br />\n男子襲擊<span class=\"xx-large\"><strong><span class=\"red\">清理連儂牆</span></strong></span>女子<br />\n廢老撕紙狗比手足私了<br />\n手足判緩刑啊<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5ce5d47dab14cea424cba1037ba69ff521a9305a","tid":2273760,"uid":55317,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-06T04:06:33.000Z","msg":"咁多人唔睇清楚<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"fe68f00c050914ee12d443edaaad7fe0aa460d74","tid":2273760,"uid":34410,"like":0,"dislike":0,"score":0,"quote":{"pid":"dce08271a176e2d5b4ab6c75c9ef2caf6ece2e2f","tid":2273760,"uid":68261,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-11-06T03:36:43.000Z","msg":"之前已經緩刑過，而家再俾佢緩刑算唔算鬆手<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-06T04:06:38.000Z","msg":"算好 如果換做鄭乜乜應該即坐"},{"pid":"9d656d7174030e99d3a0a4f99748513d86e64cdf","tid":2273760,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"5ce5d47dab14cea424cba1037ba69ff521a9305a","tid":2273760,"uid":55317,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-06T04:06:33.000Z","msg":"咁多人唔睇清楚<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-06T04:08:23.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"130374e636fc489c6b4545