edBy":0,"replyTime":"2018-08-27T15:55:42.000Z","msg":"此回覆已被刪除"},{"pid":"b2690574cc096bc2b5c06af739fa700fce0806ea","tid":796214,"uid":44171,"like":0,"dislike":0,"score":0,"quote":{"pid":"8e956e0f25bb32c324c71b69d0c0a37121c99efb","tid":796214,"uid":82243,"like":0,"dislike":1,"score":-1,"quote":{"pid":"4481ca667300c875fd37cb550552f56e20ae4b58","tid":796214,"uid":44171,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-27T15:33:42.000Z","msg":"你用咩system, php config都要set right"},"citedBy":1,"replyTime":"2018-08-27T15:44:30.000Z","msg":"Centos 7"},"citedBy":0,"replyTime":"2018-08-27T16:00:49.000Z","msg":"有冇要行fpm? 太夜腦塞晒, 去set 個fpm right"},{"pid":"fc6d07e804d727899954823c2929b3b2e22db7f4","tid":796214,"uid":9248,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-08-27T16:18:10.000Z","msg":"LAMP就跟足digital ocean d tutorial啦<br />\n<br />\n同埋唔知你咩機啦<br />\nDebian based唔使乜叉FileZilla wget㗎喎<br />\n你用到root就即係自己機啦<br />\nSsh過去用package manager (apt/yum)整<br />\n<br />\n我自己用raspbian都有distro版 （不過用ngnix)<br />\n唔使自己down binary 搞....."},{"pid":"161eec0cf43f511057771c6031398fe93e5d93d7","tid":796214,"uid":116953,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-08-30T03:34:48.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> wordpress 就 wordpress 連登仔仲識咩 cms<br />\n<br />\n同埋搞咩 LAMP<br />\n唔同 linux 又要唔同 set 法<br />\n用 docker set 少好多野<br />\n<a href=\"https://hub.docker.com/_/wordpress/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhub.docker.com%2F_%2Fwordpress%2F&d=W4EWNGLU8kWabEt6zhMsOf755KD0hvcRsprRlRVhNBc%3D&h=bbc74990\" target=\"_blank\">https://hub.docker.com/_/wordpress/</a><br />\n<br />\n<pre><code data-type=\"\">version: '3.1'\n\nservices:\n\n  wordpress:\n    image: wordpress\n    restart: always\n    ports:\n      - 8080:80\n    environment:\n      WORDPRESS_DB_PASSWORD: example\n\n  mysql:\n    image: mysql:5.7\n    restart: always\n    environment:\n      MYSQL_ROOT_PASSWORD: example</code></pre><br />\n<br />\n一張 docker-compose.yml 搞掂<br />\n跟住 <code>sudo docker-compose up -d</code> 起左<br />\n完"},{"pid":"fa42e879ff0b5f254835ff2218f740187b94c351","tid":796214,"uid":45332,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-31T00:20:43.000Z","msg":"懶人用Lnmp一鍵安裝咪算囉<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"49dcd8456e623c27e6c4f1c47ae56cb282c0940f","tid":796214,"uid":105553,"like":2,"dislike":0,"score":2,"quote":{"pid":"ca74fb122e567a77eb52901a4a63f8e07942fff7","tid":796214,"uid":23094,"like":12,"dislike":1,"score":11,"citedBy":2,"replyTime":"2018-08-27T15:22:27.000Z","msg":"<code>sudo chmod -R 777 /</code>"},"citedBy":0,"replyTime":"2018-08-31T03:48:50.000Z","msg":"唔好老點人。<br />\n<br />\nsudo chmod -R 777 / 全部file都可以俾任何人寫。"},{"pid":"3302a9ab55759c9a7cfcdcd8713de41bfaca2595","tid":796214,"uid":141441,"like":0,"dislike":0,"score":0,"quote":{"pid":"a4a42a8bf8eed71697aa28cbbf1949caa6cd0e17","tid":796214,"uid":82243,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-27T15:16:52.000Z","msg":"有冇巴打有玩開linux<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <br />\n小弟fg 最近整緊個project<br />\n開左個sever 用apache+php+mysql<br />\n整好晒啦諗住裝個cms系統落去<br />\n一入到去就話我/var/www/html冇寫入限權<br />\n明明我已經chmod -R 777 左<br />\n因為個安裝file我係經filezilla掉上去<br />\n掉左上去之後show左個owner同group係新user黎<br />\n除左個個新user可以係filezilla郁到之外，我轉左root:root係改permission都係permission denied<br />\n有冇巴打可以解答到我<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /><br />\n岩岩del晒成個用wget重黎 <br />\n都係唔得<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n已經全部都係drwxrwxrwx 但係system都係話我冇寫入權限"},"citedBy":0,"replyTime":"2018-09-07T02:48:31.000Z","msg":"用 webmin 包你滿意"},{"pid":"2af8138fbab464d12c86415f6f95cb70cbecaef6","tid":796214,"uid":14476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-07T10:09:16.000Z","