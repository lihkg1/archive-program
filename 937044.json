{"tid":937044,"cid":5,"subCid":0,"title":"學生動源丶學生獨立聯盟今日前往美國駐港領事館遞交請願信","createTime":"2018-12-11T08:47:53.000Z","updateTime":"2018-12-11T12:04:57.000Z","uid":153615,"like":10,"dislike":1,"uniUserReply":4,"replies":[{"pid":"20b9ed3593d960c74be9a489c790d194fd0e9707","tid":937044,"uid":153615,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-12-11T08:47:53.000Z","msg":"<img src=\"https://na.cx/i/ahG8548.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FahG8548.png&h=107cbfe6&s={SIZE}\" /><br />\n<br />\n【聯繫國際】<br />\n<br />\n下午三時正，敝組織學生動源與 學生獨立聯盟 - Students Independence Union前往美國駐港領事館遞交請願信促請美國政府就《香港人權與民主法案》進行立法並遞交DQ朱凱迪村代表選舉資格之選舉主任資料，望未來美國《香港人權與民主法案》立法後制裁有關人士。<br />\n<br />\n<a href=\"https://www.facebook.com/1033983876676696/posts/2329891990419205/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F1033983876676696%2Fposts%2F2329891990419205%2F&d=VsC9aI3sO9H7xHrCPdzk6J7TfgnX9jywtYe9GXZmhCU%3D&h=64563da6\" data-auto-link target=\"_blank\">https://www.facebook.com/1033983876676696/posts/2329891990419205/</a>"},{"pid":"e8b914e6416d9db0ff033c1bd31b5f9f2e60223d","tid":937044,"uid":10292,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-11T10:17:26.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d56049943f671a7b743bdfbaed240d993d349f4b","tid":937044,"uid":18251,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-11T10:24:31.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"a0a63318704c0f881040cd87f90e1183da96cb94","tid":937044,"uid":192517,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-11T12:04:57.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}