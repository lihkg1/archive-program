34ff46ca5bbf62d12f900388e44","tid":917921,"uid":5475,"like":1,"dislike":0,"score":1,"quote":{"pid":"a0caf53aeb0a04a82a3f948f942cc1b9fbd83928","tid":917921,"uid":64191,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2018-11-27T01:27:35.000Z","msg":"反正連登仔唔諗住有下一代或未來，而未來亦唔屬於香港人，不如索性摧毀佢<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-27T02:03:33.000Z","msg":"終極魚蛋論<img src=\"/assets/faces/lm2/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"028658a36514aca003a6b5af1dc6667d9fb90e58","tid":917921,"uid":97451,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-11-27T02:05:40.000Z","msg":"此回覆已被刪除"},{"pid":"73450337cfcb6cd1a994cb20fcdd0755866433e1","tid":917921,"uid":55739,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-11-27T02:14:13.000Z","msg":"仲記得果陣睇過條片係講一個故事<br />\n係講香港有隕石飛落黎 仲有3年就要比隕石飛落黎滅亡<br />\n所以好多人走晒<br />\n但仲有一部分既人唔想走定唔知點<br />\n佢地開好多特色既店鋪 搞到香港吸引到好多外國人遊客黎<br />\n3年之後隕石冇跌 政府就一直話隕石下人就會跌每年都講<br />\n之後成個香港就變返以前甘<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"04ce6a11dcde367f1b7d674fa79020c8bfbb34b1","tid":917921,"uid":203983,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-11-27T02:15:07.000Z","msg":"此回覆已被刪除"},{"pid":"a73a87e078119e743244b221c8873908d13571e3","tid":917921,"uid":64191,"like":0,"dislike":1,"score":-1,"quote":{"pid":"028658a36514aca003a6b5af1dc6667d9fb90e58","tid":917921,"uid":97451,"like":0,"dislike":1,"score":-1,"quote":{"pid":"a0caf53aeb0a04a82a3f948f942cc1b9fbd83928","tid":917921,"uid":64191,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2018-11-27T01:27:35.000Z","msg":"反正連登仔唔諗住有下一代或未來，而未來亦唔屬於香港人，不如索性摧毀佢<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-27T02:05:40.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-11-27T02:24:20.000Z","msg":"等大陸洗血就冇工返了，但