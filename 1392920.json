%2Fi%2FyjwB93D.jpg&h=d5501502&s={SIZE}\" />"},"citedBy":2,"replyTime":"2019-08-01T02:12:01.000Z","msg":"將來每把刀都係物聯網一部份，可以追蹤"},"citedBy":0,"replyTime":"2019-08-01T03:10:06.000Z","msg":"你睇佢係一把刀<br />\n<br />\n原來，佢係一個router"},{"pid":"1acd437cd058671221e99e5348c5ac669f71c36c","tid":1392920,"uid":84633,"like":4,"dislike":0,"score":4,"quote":{"pid":"dd1396aee8601bb534ac3aacc18df1164d867591","tid":1392920,"uid":191926,"like":73,"dislike":2,"score":71,"citedBy":1,"replyTime":"2019-08-01T03:07:25.000Z","msg":"深圳好快會開完<br />\n<br />\n創新，科研甚至經濟<br />\n同開放環境 其實有好大關係<br />\n<br />\n新疆依家唔好講維族人<br />\n連班支那人自己都頂唔順要外逃 <br />\n<br />\n一個咩都管的地方  點搞矽谷<br />\n已經唔搞華為等代工廠已經大倒閉中"},"citedBy":0,"replyTime":"2019-08-01T03:10:13.000Z","msg":"開完？玩完？"},{"pid":"6e2a9c487d77ab7c0d230247192f83480eea1fa6","tid":1392920,"uid":84633,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-01T03:10:50.000Z","msg":"水貨客要落香港買刀了"},{"pid":"52eebef38d8d943f763828e5bd6bb8e14a77b3a3","tid":1392920,"uid":37069,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-08-01T03:14:19.000Z","msg":"人面辯識功能菜刀<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"146d3fe39ad1cca8d3b81c352d6adcdf424a9f63","tid":1392920,"uid":6528,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2019-08-01T03:17:41.000Z","msg":"全民8月5日大罷工！五大訴求，缺一不可！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n雙普選一定要排最頭，仲要好似美國咁設時限係2020年之前落實<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n全民黑衫、口罩同頭盔，返工返學行街，唔擺工既日子一齊做，將抗爭帶入生活，保護示威者<br />\n<a href=\"https://lih.kg/1379839\" data-auto-link target=\"_blank\">https://lih.kg/1379839</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n當新移民夠多，雙普選自然會落實，港共明顯會用偽民主反真港人<br />\n（雖然係舊post，但都想人諗下，一定要止左血先）<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1328467\" data-auto-link target=\"_blank\">https://lih.kg/1328467</a><br />\n<br />\n光復香港，時代革命！<br />\n－－－－－－－－－－－－－－－－－－－－－－－－－－－－－－－－<br />\n想比更多人知道其實而家呢一刻基本上得番<span style=\"color: gold;\">香港獨立</span>呢條路，<br />\n我知好多人未準備好，我知而家急唔黎。<br />\n但係想大家思考下，種下一個思想，唔好屌我住。<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n而家就算有真普選其實都係under中共！！<br />\n咁唔通去到2047再抗爭過咩，西方國家都出唔到手幫你地。<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n因為白紙黑字寫明50年，西方國家唔好話出手，連發聲既正當性都冇啊<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n可能好多前人都係到諗點解英國當時唔寫999年！<br />\n可能好多我地呢代既諗點解上一代冇去抗爭！<br />\n可能好多下一代係2047係到諗點解我地唔直接爭取獨立！！！<br />\n<br />\n我地唔可以好似上一代咁，計好哂數50年後都死左啦，唔好理啦。<br />\n我地唔可以再咁自私啦，過埋2047都嗰頭近啦，之後再算啦。<br />\n我想我地既下一代唔需要再為呢啲事再受苦啦，我只係希望下一代可以係呼吸住自由既空氣出世係呢個地球上。<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n所有既問題，所有既恩怨，係我地呢代到解決哂啦，好嗎？<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n所有問題去到最後只會追究到主權問題，希望大家思考下。<br />\n今次搞到咁大真係最後一次反擊同最大力量。<br />\n<br />\nBTW，五大訴求，缺一不可！<br />\n雙普選應要排最頭，仲要設時限，最好2020年之前！"},{"pid":"c9763f1ee4b5114dea34c7819cb00879fee7137b","tid":1392920,"uid":8880,"like":19,"dislike":0,"score":19,"citedBy":0,"replyTime":"2019-08-01T03:19:14.000Z","msg":"一個連買刀都要實名登記嚟維穩既國家<br />\n一對外打杖就會內戰 所以一定要鼓吹解放軍出動<br />\n不停侮辱中共同解放軍 迫佢地失控"},{"pid":"5352d816c7ca9c3fcf7de947dff620112da79858","tid":1392920,"uid":241349,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-01T03:21:40.000Z","msg":"<img src=\"https://na.cx/i/mqNxE0n.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmqNxE0n.png&h=7a168f52&s={SIZE}\" /><img src=\"https://na.cx/i/rp2NtTH.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Frp2NtTH.png&h=cf9ec118&s={SIZE}\" /><img src=\"https://na.cx/i/FFLn2dK.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFF