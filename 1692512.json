al/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6ebfd116f0e4a879da5cc08d8dd067a842f83a34","tid":1692512,"uid":279722,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-04T07:57:55.000Z","msg":"推呀 推到有TEMPLATE 呀"},{"pid":"95cff38bb4e61edf9688f3fd0c571df780ee7abc","tid":1692512,"uid":86774,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d368340840c0af66a26adeee3b9573cd293cc05","tid":1692512,"uid":220045,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-04T07:26:36.000Z","msg":"想問如果申請左去公聽會，係咪就要照讀我自己交既果份意見書？"},"citedBy":5,"replyTime":"2019-11-04T08:03:33.000Z","msg":"參考王永平的文章，意見書如下：<br />\n<br />\n本人反對禁止蒙面法。原因如下：<br />\n<br />\n第一，此法違反《基本法》27條：「香港居民享有言論、新聞、出版的自由，結社、集會、遊行、示威的自由，組織和參加工會、罷工的權利和自由」。政府將《禁蒙面法》適用於合法遊行集會，令人質疑此舉的真正目的是阻嚇一般市民和學生不要上街抗議，否則承擔被秋後算帳的後果。𣎴少市民害怕在集會露面會影響其工作或私隱，例如公司的政治立場與員工不符，員工擔心參加合法集會會被公司䜔責；同志遊行的參與者希望爭取平權，但礙於社會歧視和壓力，暫時未能露面表態等。因此，此法嚴重損害市民無畏無懼地行使言論自由的權利。<br />\n<br />\n第二，此法對警員及香港市民雙重標準。<br />\n《禁蒙面法》生效後，一方面是警員依然遮蓋其委任證，甚至戴黑口罩雙重隱瞞身份。另一方面，普通市民連戴衛生口罩出外也隨時被警員截停查問。例如，不少記者被警員扯下其防催淚彈的面罩。（註一）有患癌症的市民展示其醫生紙卻被警員視為偽造文件等。（註二）法例通過後的穩定社會成效未見，但市民對政府和警方的不滿卻再創新高！<br />\n<br />\n因此，禁蒙面法只會增加民憤，完全無法做到預期的止暴制亂的效果。希望政府能順應民意，取消惡法。<br />\n<br />\n香港市民 你個名上<br />\n<br />\n<br />\n註一：-記者遭警強扯面罩<br />\n<a href=\"https://www.hk01.com/社會新聞/391108/禁蒙面法-記者遭警強扯面罩-黃定光-記者無特權違反警方指示\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%E7%A4%BE%E6%9C%83%E6%96%B0%E8%81%9E%2F391108%2F%E7%A6%81%E8%92%99%E9%9D%A2%E6%B3%95-%E8%A8%98%E8%80%85%E9%81%AD%E8%AD%A6%E5%BC%B7%E6%89%AF%E9%9D%A2%E7%BD%A9-%E9%BB%83%E5%AE%9A%E5%85%89-%E8%A8%98%E8%80%85%E7%84%A1%E7%89%B9%E6%AC%8A%E9%81%95%E5%8F%8D%E8%AD%A6%E6%96%B9%E6%8C%87%E7%A4%BA&d=yqGHcbR114BEm%2FDIyWJWfsFcVrLE0QCYyCuC44%2F36M0%3D&h=65bf9988\" data-auto-link target=\"_blank\">https://www.hk01.com/社會新聞/391108/禁蒙面法-記者遭警強扯面罩-黃定光-記者無特權違反警方指示</a><br />\n<br />\n註二：癌漢戴口罩　警屈偽造醫生紙<br />\n<a href=\"https://hk.news.appledaily.com/local/20191104/GHUMTYKXLOJXF6YRET3ZKZN4RI/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20191104%2FGHUMTYKXLOJXF6YRET3ZKZN4RI%2F&d=yqGHcbR114BEm%2FDIyWJWfsFcVrLE0QCYyCuC44%2F36M0%3D&h=d8db2474\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20191104%2FGHUMTYKXLOJXF6YRET3ZKZN4RI%2F&h=1c50dcfa\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/20191104/GHUMTYKXLOJXF6YRET3ZKZN4RI/</a>"},{"pid":"34915cfdfd28927fb35c108ac0a82f258b24eee9","tid":1692512,"uid":220045,"like":0,"dislike":0,"score":0,"quote":{"pid":"95cff38bb4e61edf9688f3fd0c571df780ee7abc","tid":1692512,"uid":86774,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d368340840c0af66a26adeee3b9573cd293cc05","tid":1692512,"uid":220045,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-04T07:26:36.000Z","msg":"想問如果申請左去公聽會，係咪就要照讀我自己交既果份意見書？"},"citedBy":5,"replyTime":"2019-11-04T08:03:33.000Z","msg":"參考王永平的文章，意見書如下：<br />\n<br />\n本人反對禁止蒙面法。原因如下：<br />\n<br />\n第一，此法違反《基本法》27條：「香港居民享有言論、新聞、出版的自由，結社、集會、遊行、示威的自由，組織和參加工會、罷工的權利和自由」。政府將《禁蒙面法》適用於合法遊行集會，令人質疑此舉的真正目的是阻嚇一般市民和學生不要上街抗議，否則承擔被秋後算帳的後果。𣎴少市民害怕在集會露面會影響其工作或私隱，例如公司的政治立場與員工不符，員工擔心參加合法集會會被公司䜔責；同志遊行的參與者希望爭取平權，但礙於社會歧視和壓力，暫時未能露面表態等。因此，此法嚴重損害市民無畏無懼地行使言論自由的權利。<br />\n<br />\n第二，此法對警員及香港市民雙重標準。<br />\n《禁蒙面法》生效後，一方面是警員依然遮蓋其委任證，甚至戴黑口罩雙重隱瞞身份。另一方面，普通市民連戴衛生口罩出外也隨時被警員截停查問。例如，不少記者被警員扯下其防催淚彈的面罩。（註一）有患癌症的市民展示其醫生紙卻被警員視為偽造文件等。（註二）法例通過後的穩定社會成效未見，但市民對政府和警方的不滿卻再創新高！<br />\n<br />\n因此，禁蒙面法只會增加民憤，完全無法做到預期的止暴制亂的效果。希望政府能順應民意，取消惡法。<br />\n<br />\n香港市民 你個名上<br />\n<br />\n<br />\n註一：-記者遭警強扯面罩<br />\n<a href=\"https://www.hk01.com/社會新聞/391108/禁蒙面法-記者遭警強扯面罩-黃定光-記者無特權違反警方指示\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%E7%A4%BE%E6%9C%83%E6%96%B0%E8%81%9E%2F391108%2F%E7%A6%81%E8%92%99%E9%9D%A2%E6%B3%95-%E8%A8%98%E8%80%85%E9%81%AD%E8%AD%A6%E5%BC%B7%E6%89%AF%E9%9D%A2%E7%BD%A9-%E9%BB%83%E5%AE%9A%E5%85%89-%E8%A8%98%E8%80%85%E7%84%A1%E7%89%B9%E6%AC%8A%E9%81%95%E5%8F%8D%E8%AD%A6%E6%96%B9%E6%8C%87%E7%A4%BA&d=yqGHcbR114BEm%2FDIyWJWfsFcVrLE0QCYyCuC44%2F36M0%3D&