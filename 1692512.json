XF6YRET3ZKZN4RI%2F&d=yqGHcbR114BEm%2FDIyWJWfsFcVrLE0QCYyCuC44%2F36M0%3D&h=d8db2474\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20191104%2FGHUMTYKXLOJXF6YRET3ZKZN4RI%2F&h=1c50dcfa\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/20191104/GHUMTYKXLOJXF6YRET3ZKZN4RI/</a>"},"citedBy":0,"replyTime":"2019-11-04T08:09:23.000Z","msg":"THANKS!"},{"pid":"1dc9855186e3b2b6bf2e8919f92074065395cf3b","tid":1692512,"uid":80352,"like":0,"dislike":0,"score":0,"quote":{"pid":"cd9ee76b4fe2ebc438c4228ac9472f25ae993afa","tid":1692512,"uid":147376,"like":0,"dislike":0,"score":0,"quote":{"pid":"e34cf5fb38ead8a79938b72c072cbf465b8661c1","tid":1692512,"uid":264915,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-04T06:11:09.000Z","msg":"[邀請各界就《禁止蒙面規例》提交意見書]<br />\n勁急！！好似冇乜人知！！<br />\n見到即刻幫推pls!!!!! <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://app3.legco.gov.hk/ors/chinese/List.aspx\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fapp3.legco.gov.hk%2Fors%2Fchinese%2FList.aspx&d=yqGHcbR114BEm%2FDIyWJWfsFcVrLE0QCYyCuC44%2F36M0%3D&h=d7db7d6b\" data-auto-link target=\"_blank\">https://app3.legco.gov.hk/ors/chinese/List.aspx</a><br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">明日下午5點前！！！</span></span><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">明日下午5點前！！！</span></span><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">明日下午5點前！！！</span></span><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n#政府又出賤招<br />\n#完全唔宣傳<br />\n#鬼鬼鼠鼠"},"citedBy":1,"replyTime":"2019-11-04T06:56:12.000Z","msg":"<span style=\"font-size: x-large;\"><strong>提交意見書link</st