f9f1e576bf3","tid":1675430,"uid":146221,"like":0,"dislike":0,"score":0,"quote":{"pid":"9ead69831b4fdeb7d0773b284d34d606fceb1e83","tid":1675430,"uid":266668,"like":1,"dislike":0,"score":1,"quote":{"pid":"1a67281fa69dc99505e2e2c3238267043d278f5e","tid":1675430,"uid":146221,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-26T02:59:49.000Z","msg":"樓主有冇介茶介酒先"},"citedBy":1,"replyTime":"2019-10-26T03:52:16.000Z","msg":"好耐冇酒 茶有飲小小"},"citedBy":0,"replyTime":"2019-10-26T04:16:41.000Z","msg":"茶同酒要完全介<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"4de723c0f4f707f274551d92e384184c0369dda8","tid":1675430,"uid":82918,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-26T04:26:59.000Z","msg":"聽下醫生話啦 冇去小便實出事"},{"pid":"9ede6a2b6446a17d8b9002b1a1478a42b60d6376","tid":1675430,"uid":264871,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-26T04:29:31.000Z","msg":"我之前都係唔飲水復發過2次，迫自己飲水同唔好忍尿就冇翻發過"},{"pid":"7a46252e1be8194908936ce91206333e3288bb96","tid":1675430,"uid":59014,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-10-26T05:43:54.000Z","msg":"尿道炎係咪好易出水"},{"pid":"69ab9f6d9d2cdde2b57abd7a9d0cdb1fb6fb0b1c","tid":1675430,"uid":151928,"like":0,"dislike":0,"score":0,"quote":{"pid":"feb9cbf0b79840e2e7cc371f1741b8d5d44cfb95","tid":1675430,"uid":266668,"like":1,"dislike":0,"score":1,"quote":{"pid":"9c1a71c466069070192161e559277139a652845f","tid":1675430,"uid":151928,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-26T03:34:51.000Z","msg":"我之前都試過兩個月內返發第二次，不過自從我改變咗自己既飲水習慣，就冇再復發。<br />\n我之前係勁唔中意飲水 但每日逼自己飲多啲水 去多啲小便，就冇再返發。"},"citedBy":1,"replyTime":"2019-10-26T03:56:57.000Z","msg":"我以前一日飲得一杯，有時得幾啖<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />依家唔敢唔飲 不過都係少"},"citedBy":1,"replyTime":"2019-10-26T05:46:21.000Z","msg":"咁你真係想斷尾既話，就真係要將飲水變成一個習慣喇<br />\n宜家我每日起身刷完牙會即刻飲返杯水 至少250ml,<br />\n飲完會覺得個胃好漲（that&rsquo;s why我都唔中意飲水）但keep住呢個習慣 不單止冇返發尿道炎，皮膚都好咗（因為我有啲敏感濕疹）"},{"pid":"64391fd74e2164a270c3cb8b05b3d06d07ceb791","tid":1675430,"uid":74933,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-26T06:20:28.000Z","msg":"飲多啲水<br />\n唔好忍尿<br />\n著棉底褲 多分泌就用護墊但要換密啲<br />\n去完廁所小心啲抹 可能抹太後 將啲菌由屎忽帶返上妹妹<br />\n抹尿唔好用拖拉 試下用印既方式<br />\n性行為前沖涼 後屙尿<br />\n洗乾淨啲條撚 同埋由病開始到好返唔好即刻就搞<br />\n係街去廁所用自己紙巾唔好用街外紙巾<br />\n飲紅莓汁要飲好大量先有用 如果想食不如買啲紅莓supplements 食<br />\n<br />\n做晒上樣既野睇下有冇幫助先"},{"pid":"2378e14d66b26a4f71605f0e295bb44655a12379","tid":1675430,"uid":191107,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-26T06:24:02.000Z","msg":"綠帽佳幫到你"},{"pid":"5537171c6a847c13265732856d7f8ca2414e2e9c","tid":1675430,"uid":266668,"like":1,"dislike":0,"score":1,"quote":{"pid":"64391fd74e2164a270c3cb8b05b3d06d07ceb791","tid":1675430,"uid":74933,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-26T06:20:28.000Z","msg":"飲多啲水<br />\n唔好忍尿<br />\n著棉底褲 多分泌就用護墊但要換密啲<br />\n去完廁所小心啲抹 可能抹太後 將啲菌由屎忽帶返上妹妹<br />\n抹尿唔好用拖拉 試下用印既方式<br />\n性行為前沖涼 後屙尿<br />\n洗乾淨啲條撚 同埋由病開始到好返唔好即刻就搞<br />\n係街去廁所用自己紙巾唔好用街外紙巾<br />\n飲紅莓汁要飲好大量先有用 如果想食不如買啲紅莓supplements 食<br />\n<br />\n做晒上樣既野睇下有冇幫助先"},"citedBy":0,"replyTime":"2019-10-26T06:26:53.000Z","msg":"好啊唔該曬<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"31e10c703eefaa4db6a903593f8c31ddeacc9daf","tid":1675430,"uid":74933,"like":0,"dislike":0,"score":0,"quote":{"pid":"423c4efe0fb3b1669cfa097eb11c49a83d6c69ae","tid":1675430,"uid":266668,"like":0,"dislike":0,"score":0,"citedBy":5,"replyTime":"2019-10-26T01:13:38.000Z","msg":"一年都翻發過好多次，次次都係食藥等佢好翻<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />好彩嘅就兩日，呢次就快一星期都未好<br />\n食抗生素同小便會變深色嗰隻尿道炎藥(試過兩種)都覺得冇用<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />真係得個等字 等佢好翻，隔一排又黎過<br />\n<br />\n同埋女仔嘅話 啲醫生會同你講做完之後要去小便，沖身反而會沖左啲菌入尿道 膀胱<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我雖然冇去小便，但過幾日先會 甚至冇做都會翻發<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />所以都唔知邊到出問題<br />\n<br />\n第一次有事係得尿急感 但小便唔痛，所以醫生話唔係尿道炎<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />照左超聲波驗過幾次小便都check 唔到究竟邊到出問題，淨係講唔關我身體結構事"},"citedBy":1,"replyTime":"2019-10-26T06:34:51.000Z","msg":"同埋補充返<br />\n抗生素係一定要食晒 唔好覺得冇用就唔食<br />\n小便變深色隻藥係舒緩不適<br />\n通常開兩日比你 因為抗生素殺緊菌<br />\n所以道理上一日比盡兩日之後去廁所就唔會痛<br />\n如果食左兩日停藥屙尿仲痛 代表抗生素做唔到野<br />\n就要再睇醫生"},{"pid":"c223e60cdf543603c2cf372299be15a5fbb24d9e","tid":1675430,"uid":266668,"like":1,"dislike":0,"score":1,"quote":{"pid":"31e10c703eefaa4db6a903593f8c31ddeacc9daf","tid":1675430,"uid":74933,"like":0,"dislike":0,"score":0,"quote":{"pid":"423c4efe0fb3b1669cfa097eb11c49a83d6c69ae","tid":1675430,"uid":266668,"like":0,"dislike":0,"score":0,"citedBy":5,"replyTime":"2019-10-26T01:13:38.000Z","msg":"一年都翻發過好多次，次次都係食藥等佢好翻<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />好彩嘅就兩日，呢次就快一星期都未好<br />\n食抗生素同小便會變深色嗰隻尿道炎藥(試過兩種)都覺得冇用<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />真係得個等字 等佢好翻，隔一排又黎過<br />\n<br />\n同埋女仔嘅話 啲醫生會同你講做完之後要去小便，沖身反而會沖左啲菌入尿道 膀胱<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我雖然冇去小便，但過幾日先會 甚至冇做都會翻發<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />所以都唔知邊到出問題<br />\n<br />\n第一次有事係得尿急感 但小便唔痛，所以醫生話唔係尿道炎<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />照左超聲波驗過幾次小便都check 唔到究竟邊到出問題，淨係講唔關我身體結構事"},"citedBy":1,"replyTime":"2019-10-26T06:34:51.000Z","msg":"同埋補充返<br />\n抗生素係一定要食晒 唔好覺得冇用就唔食<br />\n小便變深色隻藥係舒緩不適<br />\n通常開兩日比你 因為抗生素殺緊菌<br />\n所以道理上一日比盡兩日之後去廁所就唔會痛<br />\n如果食左兩日停藥屙尿仲痛 代表抗生素做唔到野<br />\n就要再睇醫生"},"citedBy":0,"replyTime":"2019-10-26T08:46:04.000Z","msg":"我可能啲菌勁啲 食左4日抗生素都小痛haha<br />\n不過我會記得食晒thx<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />好細心打咁多字"},{"pid":"d2a018aa63037d54848da537f53ee41a8b5ea639","tid":1675430,"uid":257567,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-26T12:10:10.000Z","msg":"我龜頭發炎都難斷尾呀<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"6ef60c9f4ab15e3bf3066675aeafb2cf8aecc729