":0,"quote":{"pid":"e0f3d48b52559f5b7155dc81f610fd4e86a08024","tid":648702,"uid":5445,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-05-08T15:58:51.000Z","msg":"成件事都好鬼<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-12T10:26:08.000Z","msg":"<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-12T12:24:53.000Z","msg":"有個committee俾人拉左又未必關個會事既"},"citedBy":1,"replyTime":"2018-05-12T15:58:59.000Z","msg":"問題係之前佢有分負責執法<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e0ce5737bc9e319635d3c332d6ee5526fc214a63","tid":648702,"uid":72280,"like":0,"dislike":0,"score":0,"quote":{"pid":"e87d79b563240c1dcb5d47ca28e6e40e2916819c","tid":648702,"uid":72280,"like":0,"dislike":0,"score":0,"quote":{"pid":"90e2b943011c6cc43bf2081823841f347bccc833","tid":648702,"uid":52972,"like":0,"dislike":0,"score":0,"quote":{"pid":"ea775f0a8e2c08c161c6ed4bdbf9da9a2b75e797","tid":648702,"uid":72280,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-12T10:26:08.000Z","msg":"<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-12T12:24:53.000Z","msg":"有個committee俾人拉左又未必關個會事既"},"citedBy":1,"replyTime":"2018-05-12T15:58:59.000Z","msg":"問題係之前佢有分負責執法<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-12T16:00:48.000Z","msg":"政府係味應該搵人去 review 下佢地處理個的案件呢"},{"pid":"6102e4c405456e79ea0368e18e1181dd8dd8da8e","tid":648702,"uid":65789,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-12T16:36:57.000Z","msg":"會計師公會 自己都搞唔掂<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"977a2114fb42d8cdf0cf856aac0a91d7aff2224f","tid":648702,"uid":72280,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6102e4c405456e79ea0368e18e1181dd8dd8da8e","tid":648702,"uid":65789,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-12T16:36:57.000Z","msg":"會計師公會 自己都搞唔掂<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-13T02:08:52.000Z","msg":"人治係咁架 la<br />\n如果唔係靠食學挍條水<br />\n<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"cb90da90d1312825e8da7f65a01c475ffe614515","tid":648702,"uid":72280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-13T02:28:26.000Z","msg":"會計師公會不知所謂<br />\n劉山青2018/3/20 &mdash; 12:05<br />\n<a href=\"https://thestandnews.com/society/會計師公會不知所謂/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fthestandnews.com%2Fsociety%2F%E6%9C%83%E8%A8%88%E5%B8%AB%E5%85%AC%E6%9C%83%E4%B8%8D%E7%9F%A5%E6%89%80%E8%AC%82%2F&d=uWXdQhWoVnubLJeAKiDwLkbWhtBCnEJYRTWbVbFBOac%3D&h=0d4a69a5\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fsociety%2F%E6%9C%83%E8%A8%88%E5%B8%AB%E5%85%AC%E6%9C%83%E4%B8%8D%E7%9F%A5%E6%89%80%E8%AC%82%2F&h=fcbfcd83\" data-auto-link target=\"_blank\">https://thestandnews.com/society/會計師公會不知所謂/</a><br />\n<br />\n德勤會計師事務所在2013年9月所發佈的一分報告。報告：<a href=\"http://www.frc.org.hk/pdf_20131010/FRC%20Chi.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.frc.org.hk%2Fpdf_20131010%2FFRC%2520Chi.pdf&d=uWXdQhWoVnubLJeAKiDwLkbWhtBCnEJYRTWbVbFBOac%3D&h=aea062b3\" data-auto-link target=\"_blank\">http://www.frc.org.hk/pdf_20131010/FRC%20Chi.pdf</a><br />\n<br />\n指出：<br />\n<br />\n&ldquo;歐洲委員會批准了十個國家的審計機構視為等效,七個國家的過渡期獲得延長。惟香港,印度及以色列過渡期未獲延長。&rdquo;<br />\n<br />\n其主要差距為：<br />\n<br />\n香港會計師公會的管治架構－香港會計師公會理事會現時約三分之一的成員為執業會計師。<br />\n<br />\n歐洲委員會規定公眾監管制度須主要由非執業會計師管冶；及獨立審計監管機構國際論壇規定審計監管機構於行使其職能及權力時應獨立運作，不受外界政治干擾及不存在商業或其他經濟利益，包括其管治不受執業會計師控制。<br />\n<br />\n當中涉及獨立審計監管機構國際論壇的：<br />\n<br />\n第二條：不受核數師及會計師事務所影響的穩定資金來源、<br />\n<br />\n第四條原則：有否執行處分，如罰款及撤銷審計牌照的權力。<br />\n<br />\n香港會計師公會的問題<br />\n<br />\n香港會計師公會的管治架構－香港會計師公會理事會現時約三分之一的成員（22名非執行理事中有8名）為執業會計師。餘下成員現時並非執業會計師，惟香港會計師公會理事會的章程並無規定「非執業」理事會成員須於過往三年並無進行法定審計、並無於會計師事務所持有投票權、並非會計師事務所的行政或管理部門成員、並無受僱於會計師事務所或與會計師事務所有其他聯繫。這表示於某特定時間，香港會計師公會理事會的大部份成員實際為「非執業會計師」，<br />\n<br />\n但任何理事會成員變動都可能導致其不再符合此項要求（即大部份成員為非執業會計師）－例如一名近期退休的審計合夥人被委任為理事會成員。<br />\n<br />\n香港會計師公會的資金來源<br />\n<br />\n香港會計師公會的資金來源未能符合獨立審計監管機構國際論壇及歐洲委員會所規定，資金來源必須不受核數師及會計師事務所的任何可能不當影響。<br />\n<br />\n立法會討論不知所謂<br />\n<br />\n現在，政府提出修例，目的是&ldquo;提高現行上市實體核數師規管制度的獨立性，加強對投資者的保 障 ， 並符合國際標準 。&rdquo;但議事廳內的議事者只會講錢，要政府著數，即納稅人埋單，又說這不公道，那不合理。<br />\n<br />\n其實冰非一日之寒，整件事由2008年已出現。應屆的會計畢業生被大行無情欺壓，女孩子要凌晨放工，月入不過二萬，更重要的是香港的會計業沒有前途。四大深明刮得幾多就幾多。他們的主要收入來源是為大陸公司上市和核數。咁，楝係越少監管越好，拖得越耐越好。<br />\n<br />\n歐盟最不滿的是，香港生意照做，又唔跟進歐盟要求，甚至不回覆歐盟的信函！那班議員最應該追問L 163/26文件，為何香港政府不理歐盟的知會？"},{"pid":"73201cae05f84d23834f4e748a3374bf8f3e9663","tid":648702,"uid":72280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-13T02:29:37.000Z","msg":"<blockquote>會計師公會不知所謂<br />\n劉山青2018/3/20 &mdash; 12:05<br />\n<a href=\"https://thestandnews.com/society/%E6%9C%83%E8%A8%88%E5%B8%AB%E5%85%AC%E6%9C%83%E4%B8%8D%E7%9F%A5%E6%89%80%E8%AC%82/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fthestandnews.com%2Fsociety%2F%25E6%259C%2583%25E8%25A8%2588%25E5%25B8%25AB%25E5%2585%25AC%25E6%259C%2583%25E4%25B8%258D%25E7%259F%25A5%25E6%2589%2580%25E8%25AC%2582%2F&d=uWXdQhWoVnubLJeAKiDwLkbWhtBCnEJYRTWbVbFBOac%3D&h=3d48f84a\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fsociety%2F%25E6%259C%2583%25E8%25A8%2588%25E5%25B8%25AB%25E5%2585%25AC%25E6%259C%2583%25E4%25B8%258D%25E7%259F%25A5%25E6%2589%2580%25E8%25AC%2582%2F&h=2c72c95d\" target=\"_blank\">https://thestandnews.com/society/%E6%9C%83%E8%A8%88%E5%B8%AB%E5%85%AC%E6%9C%83%E4%B8%8D%E7%9F%A5%E6%89%80%E8%AC%82/</a><br />\n德勤會計師事務所在2013年9月所發佈的一分報告。報告：<a href=\"http://www.frc.org.hk/pdf_20131010/FRC%20Chi.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.frc.org.hk%2Fpdf_20131010%2FFRC%2520Chi.pdf&d=uWXdQhWoVnubLJeAKiDwLkbWhtBCnEJYRTWbVbFBOac%3D&h=aea062b3\" target=\"_blank\">http://www.frc.org.hk/pdf_20131010/FRC%20Chi.pdf</a><br />\n<br />\n指出：<br />\n<br />\n&ldquo;歐洲委員會批准了十個國家的審計機構視為等效,七個國家的過渡期獲得延長。惟香港,印度及以色列過渡期未獲延長。&rdquo;<br />\n<br />\n其主要差距為：<br />\n<br />\n香港會計師公會的管治架構－香港會計師公會理事會現時約三分之一的成員為執業會計師。<br />\n<br />\n歐洲委員會規定公眾監管制度須主要由非執業會計師管冶；及獨立審計監管機構國際論壇規定審計監管機構於行使其職能及權力時應獨立運作，不受外界政治干擾及不存在商業或其他經濟利益，包括其管治不受執業會計師控制。<br />\n<br />\n當中涉及獨立審計監管機構國際論壇的：<br />\n<br />\n第二條：不受核數師及會計師事務所影響的穩定資金來源、<br />\n<br />\n第四條原則：有否執行處分，如罰款及撤銷審計牌照的權力。<br />\n<br />\n香港會計師公會的問題<br />\n<br />\n香港會計師公會的管治架構－香港會計師公會理事會現時約三分之一的成員（22名非執行理事中有8名）為執業會計師。餘下成員現時並非執業會計師，惟香港會計師公會理事會的章程並無規定「非執業」理事會成員須於過往三年並無進行法定審計、並無於會計師事務所持有投票權、並非會計師事務所的行政或管理部門成員、並無受僱於會計師事務所或與會計師事務所有其他聯繫。這表示於某特定時間，香港會計師公會理事會的大部份成員實際為「非執業會計師」，<br />\n<br />\n但任何理事會成員變動都可能導致其不再符合此項要求（即大部份成員為非執業會計師）－例如一名近期退休的審計合夥人被委任為理事會成員。<br />\n<br />\n香港會計師公會的資金來源<br />\n<br />\n香港會計師公會的資金來源未能符合獨立審計監管機構國際論壇及歐洲委員會所規定，資金來源必須不受核數師及會計師事務所的任何可能不當影響。<br />\n<br />\n立法會討論不知所謂<br />\n<br />\n現在，政府提出修例，目的是&ldquo;提高現行上市實體核數師規管制度的獨立性，加強對投資者的保 障 ， 並符合國際標準 。&rdquo;但議事廳內的議事者只會講錢，要政府著數，即納稅人埋單，又說這不公道，那不合理。<br />\n<br />\n其實冰非一日之寒，整件事由2008年已出現。應屆的會計畢業生被大行無情欺壓，女孩子要凌晨放工，月入不過二萬，更重要的是香港的會計業沒有前途。四大深明刮得幾多就幾多。他們的主要收入來源是為大陸公司上市和核數。咁，楝係越少監管越好，拖得越耐越好。<br />\n<br />\n歐盟最不滿的是，香港生意照做，又唔跟進歐盟要求，甚至不回覆歐盟的信函！那班議員最應該追問L 163/26文件，為何香港政府不理歐盟的知會？</blockquote>"},{"pid":"f2edcddbf3af80c24367efc5c5560b918b9a630f","tid":648702,"uid":72280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-15T03:07:38.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"76248a88dc72b04eecc510523665a5801c5bb3e3","tid":648702,"uid":72280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-20T16:20:33.000Z","msg":"<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"}]}