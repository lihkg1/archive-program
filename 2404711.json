ink?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DTZ9xljj6bgs%26ab_channel%3DSulaimanGu&d=fMmZVRBh8JxXvfCabRklGZMi8MJ45PejcSMOUziyDL0%3D&h=1ccdf7bc\" target=\"_blank\">https://www.youtube.com/watch?v=TZ9xljj6bgs&amp;ab_channel=SulaimanGu</a>"},{"pid":"55e88808c8236e69f537e7b5ce32889e04dbf140","tid":2404711,"uid":76710,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-12T07:45:58.000Z","msg":"我祖國係大英"},{"pid":"588742be56b2c3bc4956865884cad56f35f3c720","tid":2404711,"uid":301989,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-12T07:46:41.000Z","msg":"祖國只有一個 就係英國<img src=\"/assets/faces/cow/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"67a1a3bce32031e81f3fd57bfb05972e25f96314","tid":2404711,"uid":301989,"like":0,"dislike":0,"score":0,"quote":{"pid":"86e433a076268bba51ec14e268b8b6fd58c2529d","tid":2404711,"uid":69221,"like":7,"dislike":2,"score":5,"citedBy":4,"replyTime":"2021-02-12T01:36:05.000Z","msg":"<img src=\"https://na.cx/i/S9Cbdr6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FS9Cbdr6.jpg&h=8486e203&s={SIZE}\" /><br />\n<br />\n黃絲根本就自認中國人<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<img src=\"https://na.cx/i/c4oUVGA.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fc4oUVGA.png&h=a7be4920&s={SIZE}\" /><img src=\"https://na.cx/i/f0jtfGB.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Ff0jtfGB.png&h=da69ef07&s={SIZE}\" />"},"citedBy":0,"replyTime":"2021-02-12T07:47:01.000Z","msg":"泛狗真係賤種嚟<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"01199259bf32fec19c5fd88519b578f35897e4fb","tid":2404711,"uid":333752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-12T07:51:48.000Z","msg":"我都係叫開支那架喎"},{"pid":"7b88cd67a9132e6fd06218f76ee36f0c30417f45","tid":2404711,"uid":15205,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-12T08:01:53.000Z","msg":"我祖國係英國喎"},{"p