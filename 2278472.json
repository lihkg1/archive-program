slike":0,"score":2,"quote":{"pid":"969ac037e79494b9d5fa2f7f1913503bc9235d0c","tid":2278472,"uid":305269,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2020-11-09T07:41:57.000Z","msg":"<img src=\"https://na.cx/i/sD0ypoA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsD0ypoA.jpg&h=bf668a97&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-11-09T07:51:38.000Z","msg":"係香港居民<br />\n唔係香港永久性居民<img src=\"/assets/faces/pig/fan.gif\" class=\"hkgmoji\" />"},{"pid":"22bae946d4a6dda37bcdffd187fe7dcb87054552","tid":2278472,"uid":167597,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-11-09T07:52:34.000Z","msg":"佢地死都死返香港睇病，口裏愛國，身體很誠實"},{"pid":"c9f727ecc875fa3d372bde6438f2aed84180a659","tid":2278472,"uid":305269,"like":0,"dislike":0,"score":0,"quote":{"pid":"22bae946d4a6dda37bcdffd187fe7dcb87054552","tid":2278472,"uid":167597,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-11-09T07:52:34.000Z","msg":"佢地死都死返香港睇病，口裏愛國，身體很誠實"},"citedBy":0,"replyTime":"2020-11-09T08:01:02.000Z","msg":"無實力同智慧嘅人一世都係寄生蟲，只係唔同時間點寄生喺唔同人身上。<br />\n好聽叫適時務，難聽叫騎牆。<br />\n支那嘅文化培養咗呢一班垃圾出嚟，受害嘅偏偏得香港<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"aed45f9e03e99371c76bcef138c15cb79dab0624","tid":2278472,"uid":21470,"like":0,"dislike":0,"score":0,"quote":{"pid":"0a4bc063a9825bba28e78735498e0ead197c5ca6","tid":2278472,"uid":127905,"like":0,"dislike":0,"score":0,"quote":{"pid":"cf4cb105e436612add34d475592796dd2fbe45e8","tid":2278472,"uid":63113,"like":1,"dislike":3,"score":-2,"citedBy":1,"replyTime":"2020-11-09T07:37:06.000Z","msg":"<img src=\"https://na.cx/i/4z3wa1Z.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4z3wa1Z.png&h=6dd59a9e&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-11-09T07:39:30.000Z","msg":"有冇內文睇下<br />\n想知 每年2000 定每月2000"},"citedBy":0,"replyTime":"2020-11-09T08:34:26.000Z","msg":"政府為居粵醫管局慢性病患者提供疫情期間診症服務<br />\n＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊<br />\n  香港特別行政區政府明日（十一月十日）推出特別支援計劃，為身在廣東省的醫院管理局（醫管局）慢性病患者，在2019冠狀病毒病疫情期間提供受資助的診症服務。<br />\n   <br />\n  在現時的強制檢疫措施下，部分身在廣東省的港人無法如常來港前往醫管局門診覆診及之後返回內地。為使這些患者的健康狀況得到持續、妥善及協調的監察及照顧，政府委託香港大學深圳醫院（港大深圳醫院）為已預約醫管局指定專科門診或普通科門診覆診的患者提供受資助的跟進診症服務。<br />\n   <br />\n<span class=\"gold\">  特別支援計劃涵蓋醫管局提供的主要專科及普通科門診服務，包括麻醉科（只包括痛症科門診）、心胸外科、臨床腫瘤科、耳鼻喉科、眼科、婦科、內科、神經外科、產科、矯形及創傷外科（骨科）、兒科及外科。偶發性疾病、需要住院或日間住院及急症室服務則不包括在內。</span><br />\n   <br />\n  如病人於上述醫管局專科門診或普通科門診的覆診期介乎二○二○年二月十七日至二○二一年七月三十一日，可向港大深圳醫院提出申請，並提交所需證明文件。醫管局會在得到病人同意下，協助港大深圳醫院核實病人的身分，醫管局在過程中會確保病人私隱得到充分保障。另外，為確保病人得到適切的治療，病人可委託港大深圳醫院向電子健康紀錄統籌處申請登記香港電子健康紀錄互通系統，向電子健康紀錄統籌處提出查閱資料要求，並授權港大深圳醫院代為收取及使用有關的電子健康紀錄的複本，讓相關醫護人員為病人提供合適的醫護服務。<br />\n   <br />\n  <span class=\"gold\">合資格病人每次接受港大深圳醫院指定門診診症服務需繳付人民幣100元診金（經醫管局核實的指定享有豁免醫療費用人士除外），餘下費用差額則由支援計劃資助。每位病人可受資助上限總額為人民幣2,000元。</span><br />\n   <br />\n<span class=\"gold\">  特別支援計劃明日起在港大深圳醫院接受申請，合資格人士可於二○二一年七月三十一日或香港與內地的檢疫安排失效之前</span>（以較早者為準）於港大深圳醫院接受診症服務。港大深圳醫院將優先為已逾期覆診的患者安排應診。有關計劃旨在為現時身處廣東省、受到疫情影響未能回港的病人提供另外的醫療服務選擇。病人是否參與有關計劃，純屬病人的個人決定，而有關決定不會影響病人原本在醫管局已預約的覆診服務。<br />\n   <br />\n  有關計劃詳情，請參閱醫管局網頁（<a href=\"http://www.ha.org.hk/goto/sss/tc\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.ha.org.hk%2Fgoto%2Fsss%2Ftc&d=FEHxtXJUwAnPMx50BANU%2BSvt59O44HeJS3%2BtxtDyp5g%3D&h=57633ebb\" data-auto-link target=\"_blank\">www.ha.org.hk/goto/sss/tc</a>）或港大深圳醫院網頁（<a href=\"http://www.hku-szh.org/index.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.hku-szh.org%2Findex.html&d=FEHxtXJUwAnPMx50BANU%2BSvt59O44HeJS3%2BtxtDyp5g%3D&h=00f0590a\" data-auto-link target=\"_blank\">www.hku-szh.org/index.html</a>）。如有查詢，可致電醫管局（電話：2300 7070；星期一至五上午九時至下午六時，星期六、日及公眾假期除外）或港大深圳醫院（電話：（+86）0755-86913101；星期一至五上午八時至下午十二時半及下午二時至五時半，星期六、日及公眾假期除外）。<br />\n <br />\n完<br />\n2020年11月9日（星期一）<br />\n香港時間15時20分"},{"pid":"bd31405a4d12525cf3c507413d79155e27c35af4","tid":2278472,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-09T08:37:59.000Z","msg":"香港醫院不嬲爆到咁, 加得少少資源, 仲要幫大灣區奶袋底"},{"pid":"aa116bc53af03319a3b7240a87057235e98720b8","tid":2278472,"uid":1086,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-09T12:39:36.000Z","msg":"會唔會冇人去大陸佬都每年照屈你香港佬幾億補助<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"08e78b11c9cd58c2242923e87af39e02a52306df","tid":2278472,"uid":71092,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-09T12:40:42.000Z","msg":"大陸醫護唔搵 黎香港搵黑醫護<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />"}]}