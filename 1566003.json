ss=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/Trzyi1f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTrzyi1f.jpg&h=f89f6e65&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-09-13T22:43:14.000Z","msg":"<a href=\"https://www.facebook.com/groups/LamCheng/permalink/835464876849353?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fgroups%2FLamCheng%2Fpermalink%2F835464876849353%3Fsfns%3Dmo&d=sKkpDxzP%2F%2Fasg9kKOzx88t8yddZnhMmQMHU13Um27G0%3D&h=b2940e8c\" data-auto-link target=\"_blank\">https://www.facebook.com/groups/LamCheng/permalink/835464876849353?sfns=mo</a><br />\n<br />\n證據終於流出！<br />\n<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"1353cd6458de80bf53e7439c395041a194e8c28d","tid":1566003,"uid":323799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-18T09:56:40.000Z","msg":"我願榮光歸香港 英文版 Glory be Unto HK<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1578172\" data-auto-link target=\"_blank\">https://lih.kg/1578172</a>"}]}