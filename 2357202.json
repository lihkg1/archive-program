25AA%25E4%25BA%25A4%25E5%2587%25BA%25E6%2597%2585%25E9%2581%258A%25E8%25AD%2589%25E4%25BB%25B6-%25E6%25B6%2589%25E5%258F%258A%25E9%259D%259E%25E6%25B3%2595%25E9%259B%2586%25E7%25B5%2590%25E6%25A1%2588&d=vTNdr7lgiRBdtcQZ4wg6zwmr2u8Aa6r9E8tiWteYAjM%3D&h=476888f8\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhd.stheadline.com%2Fnews%2Frealtime%2Fhk%2F1969503%2F%25E5%258D%25B3%25E6%2599%2582-%25E6%25B8%25AF%25E8%2581%259E-%25E5%25A4%25A7%25E6%258B%2598%25E6%258D%2595-%25E8%25AD%25A6%25E6%2590%259C%25E5%25B1%258B%25E6%258F%25AD%25E8%2583%25A1%25E5%25BF%2597%25E5%2581%2589%25E6%259C%25AA%25E4%25BA%25A4%25E5%2587%25BA%25E6%2597%2585%25E9%2581%258A%25E8%25AD%2589%25E4%25BB%25B6-%25E6%25B6%2589%25E5%258F%258A%25E9%259D%259E%25E6%25B3%2595%25E9%259B%2586%25E7%25B5%2590%25E6%25A1%2588&h=c5c7e3bf\" data-auto-link target=\"_blank\">https://hd.stheadline.com/news/realtime/hk/1969503/%E5%8D%B3%E6%99%82-%E6%B8%AF%E8%81%9E-%E5%A4%A7%E6%8B%98%E6%8D%95-%E8%AD%A6%E6%90%9C%E5%B1%8B%E6%8F%AD%E8%83%A1%E5%BF%97%E5%81%89%E6%9C%AA%E4%BA%A4%E5%87%BA%E6%97%85%E9%81%8A%E8%AD%89%E4%BB%B6-%E6%B6%89%E5%8F%8A%E9%9D%9E%E6%B3%95%E9%9B%86%E7%B5%90%E6%A1%88</a>"},"citedBy":1,"replyTime":"2021-01-07T09:17:30.000Z","msg":"痴撚線 點解會知 點解會有人畀"},"citedBy":4,"replyTime":"2021-01-07T09:20:18.000Z","msg":"好似話喺車自爆話屋企仲有本BNO... 啱啱有線講嘅..."},"citedBy":0,"replyTime":"2021-01-07T09:38:48.000Z","msg":"據了解，警方昨日搜查胡志偉寓所時發現一本BNO護照，涉違反保釋條件要即時上庭。"},{"pid":"33d580cec6740cbd0893c17ee45d914a3eeb10c9","tid":2357202,"uid":320575,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-07T09:41:22.000Z","msg":"#西九龍裁判法院第一庭 <br />\n#羅德泉主任裁判官 #違反保釋條件<br />\n👤胡志偉🛑因指違反港區國安法而被拘留調查中 <br />\n<br />\n被告被指未有遵從 #20200604維園 的保釋條件，即交出所有旅遊證件，被告在家中藏有一本有效的BNO。<br />\n<br />\n背景：<br />\n在2020年12月17日提堂後，當時被告被要求交出所有旅遊證件，但由於當晚辨事處已關閉，故被告在翌日到法庭交出旅遊證件，在法庭第一次提問被告是否已交出所有旅遊證件時，被告指已全部交出。但在昨天被告因國安法而被拘捕後，警方在車上向被告確認交出甚麼旅遊證件時，被告向警方表示交了特區護照及回鄉證，卻沒有交BNO。因此警方聯繫被告太太要求把被告的BNO交到警署，但不知原因下，該BNO在2小時侯由另一位區議員交到警署。<br />\n<br />\n由於辯方剛收到錄影會面光碟，需時處理，故把案件押後至明天1030西九龍裁判法院第4庭再處理。<br />\n<br />\n🛑期間被告需還押懲教看管🛑"},{"pid":"8a66c34264b62d6605bdfc295eb2a4b0f79e342b","tid":2357202,"uid":2757,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2021-01-07T09:42:58.000Z","msg":"前立法會議員胡志偉連同7名民主派人士涉嫌與去年6月30日終審法院外遊行及7月1日灣仔遊行有關，被控舉行或組織、煽惑他人明知而參與未經批准集結3罪，案件已押後至下月8日再訊，以轉介區域法院。胡志偉原獲准保釋，惟昨因涉去年民主派初選被捕時，警方發現其未有按要求交出英國國民（海外）護照（BNO），違反保釋條件，今午由囚車押送到庭應訊。控方庭上申請撤銷其保釋，裁判官羅德泉押後申請至明早10時半處理，以待辯方審視控方申請理據及文件，期間胡志偉須還押懲教署看管。<span class=\"red\">據悉胡志偉被押解至觀塘辦公室途中，警員查問下接獲回覆指「重有本BNO喺屋企」，BNO有效日期為2019年9月至2029年9月。</span><br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1b84b5a8839d1ed88eed842e4bad1e74922a3554","tid":2357202,"uid":182197,"like":0,"dislike":0,"score":0,"quote":{"pid":"8a66c34264b62d6605bdfc295eb2a4b0f79e342b","tid":2357202,"uid":2757,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2021-01-07T09:42:58.000Z","msg":"前立法會議員胡志偉連同7名民主派人士涉嫌與去年6月30日終審法院外遊行及7月1日灣仔遊行有關，被控舉行或組織、煽惑他人明知而參與未經批准集結3罪，案件已押後至下月8日再訊，以轉介區域法院。胡志偉原獲准保釋，惟昨因涉去年民主派初選被捕時，警方發現其未有按要求交出英國國民（海外）護照（BNO），違反保釋條件，今午由囚車押送到庭應訊。控方庭上申請撤銷其保釋，裁判官羅德泉押後申請至明早10時半處理，以待辯方審視控方申請理據及文件，期間胡志偉須還押懲教署看管。<span class=\"red\">據悉胡志偉被押解至觀塘辦公室途中，警員查問下接獲回覆指「重有本BNO喺屋企」，BNO有效日期為2019年9月至2029年9月。</span><br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-07T09:43:52.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"8fb8e3cfd1bce00c4c58830ccf7062280daa5c1b","tid":2357202,"uid":267167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T09:44:05.000Z","msg":"？中共唔係話唔承認bno咩？"},{"pid":"10c6d1332ffd21ccd3814b20c25f9c296eb994d5","tid":2357202,"uid":82938,"like":3,"dislike":1,"score":2,"quote":{"pid":"8a66c34264b62d6605bdfc295eb2a4b0f79e342b","tid":2357202,"uid":2757,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2021-01-07T09:42:58.000Z","msg":"前立法會議員胡志偉連同7名民主派人士涉嫌與去年6月30日終審法院外遊行及7月1日灣仔遊行有關，被控舉行或組織、煽惑他人明知而參與未經批准集結3罪，案件已押後至下月8日再訊，以轉介區域法院。胡志偉原獲准保釋，惟昨因涉去年民主派初選被捕