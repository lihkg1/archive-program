.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-27T13:07:13.000Z","msg":"林鄭， I come to protest.<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"2907bdfaafcb5c26c73bd859d588adf7f8bcba24","tid":1510220,"uid":35104,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T13:08:32.000Z","msg":"<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"2e9298fa193797226a652fe1f263f4e159aeb1b0","tid":1510220,"uid":25164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T14:01:04.000Z","msg":"Remember <br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=sNuDGV0eNRY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DsNuDGV0eNRY&d=9rGlslGXeLGLpJWMZA8bi0oInKkgZqzseva8eQDkMF8%3D&h=7821fde0\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=sNuDGV0eNRY</a>"},{"pid":"2e41926ddfd2bcd4a210acd5d54918d6a80ad7d0","tid":1510220,"uid":25164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T14:01:15.000Z","msg":"Remember"},{"pid":"4c3e5549d1eefd4c1c1aab5f64e436b2680dcf67","tid":1510220,"uid":25164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T14:01:56.000Z","msg":"<img src=\"/assets/faces/dog/itdog3.gif\" class=\"hkgmoji\" />"},{"pid":"014902228e49cd3371ff6929ed8361b1f70b7916","tid":1510220,"uid":39653,"like":0,"dislike":0,"score":0,"quote":{"pid":"4fe59028cfbb5a0f0f44df83fc5ef6f8168fcf69","tid":1510220,"uid":161457,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2019-08-27T06:40:22.000Z","msg":"師父講得岩 原來幪面之後真係咁好打<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-27T14:04:14.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"ea87dacb8a482e3b25e13dd3bdc6ae31cc537d09","tid":1510220,"uid":25164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T15:17:52.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"263730c28e0804cb8ee630829ad0516aecf75229","tid":1510220,"uid":25164,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-28T02:11:40.000Z","msg":"新屋嶺16歲抗爭者 成隻手只剩一層皮連住<br />\n<br />\n <br />\n【Now新聞台】在811警民衝突中，被捕五十多人被送到文錦渡的新屋嶺拘留中心，警方指三十多人及後送院，當中六人骨折，強調傷勢是被捕反抗時造成。有北區醫院護士透露，部分被捕人骨折情況嚴重。<br />\n<br />\n警方811分別在銅鑼灣及尖沙咀拘捕大批示威者，有五十幾人送到新屋嶺拘留中心，部分轉送北區醫院治療。<br />\n<br />\n化名的Judy是北區醫院護士，她說接收的被捕人個別只有16、17歲，全身有不尋常的瘀傷，甚至有嚴重骨折。她說被捕人在急症室觀察病房期間，大約五名警員看守一人，並要求監視所有治療過程。<br />\n<br />\n警方指，811拘捕中，有三十人要求醫，當中六人骨折，只有一人在現場已送院，其他是送到新屋嶺再送院，指他們的傷勢都是被捕反抗造成。<br />\n<br />\n警方又說，除了按傷勢分流送院，還要視乎保安安排，安排兩至三名警員陪同一個被捕人去醫院。<br />\n<br />\n唔好再話有好警察 白警<br />\n唔好話佢哋人到中年 依家辭職 搵唔到工<br />\n如果仲有良知 根本唔會做得出<br />\n香港人 打 香港人<br />\n或者去傷害一個16 17歲嘅年青人<br />\n<br />\n當我求下你哋<br />\n就算最後抗爭完咗 不論邊一邊贏<br />\n大家依一世都唔好願諒佢哋<br />\n佢哋嘅行為 根本拍得住日本皇軍 同 納粹蓋世太保<br />\n我睇完 真係嬲到 一滴眼淚流<br />\n點解可以咁傷害同一地方長大嘅人<br />\n<br />\n黎明前嘅黑暗係最撚黑暗<br />\n政權要對準<br />\n但依班人 依一世我都唔會願諒<br />\n<br />\n最後多謝記者 醫護 無言感激"},{"pid":"50cacd02e0c988afe49a15b0773e723905656ab5","tid":1510220,"uid":25164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T16:16:47.000Z","msg":"<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" />"},{"pid":"25cf598e523cff0582955f947b56eacecbe08b8f","tid":1510220,"uid":195252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T16:23:03.000Z","msg":"831遊行"},{"pid":"9a204ad0f92d9cf9f232b3887786f3634638e1dd","tid":1510220,"uid":297811,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-28T16:26:46.000Z","msg":"<span style=\"font-size: x-large;\">／／最強的人，不是不會畏懼以強欺弱的人，而是充滿恐懼卻還是鼓起勇氣面對恐懼的人。真正的強，源自人類的內心。／／</span> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: x-large;\">香港人加油<br />\n光復香港<br />\n時代革命</span>"},{"pid":"79d295a868ac4d4eaa994520389c4b29713a9097","tid":1510220,"uid":25164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T07:28:21.000Z","msg":"<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" />"},{"pid":"a93e0bb302d8df473f86c88aaff5a819099401ab","tid":1510220,"uid":92836,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-29T08:45:27.000Z","msg":"毋忘聽日830香港重光紀念日。<br />\n<span style=\"color: green;\"><em>830中環見<br />\n830中環見<br />\n830中環見</em></span><br />\n<img src=\"https://na.cx/i/96PXdYs.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F96PXdYs.jpg&h=2d869ee7&s={SIZE}\" /><br />\n<br />\n<img src=\"https://na.cx/i/4KF8LYC.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4KF8LYC.gif&h=64c0bd73&s={SIZE}\" /><br />\n<br />\n［行動Post］ 830 感謝勇武暨重光紀念日行動<br />\n<a href=\"https://lih.kg/1511085\" data-auto-link target=\"_blank\">https://lih.kg/1511085</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"2aa386b58ff06216fe5b4b17498c3e124dc14d37","tid":1510220,"uid":25164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T14:35:44.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"bfc1c1d7a3eecc128e6d91d202da1640d87af778","tid":1510220,"uid":122059,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T14:38:35.000Z","msg":"91 機場 9293大罷工"},{"pid":"1b67a84e6c7ae64461e1aa6a81caa0499cbee569","tid":1510220,"uid":1102,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T14:39:17.000Z","msg":"好文大推"},{"pid":"dd576c9e42aec4f39480d3f718ceecaecb7b5845","tid":1510220,"uid":283972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T14:46:05.000Z","msg":"<img src=\"/assets/faces/pig/peanut.gif\" class=\"hkgmoji\" /><img sr