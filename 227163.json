assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f855ac141ac8a31946f0988dae101e31015c949b","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-05T05:13:51.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"14b53a5eaab7cc39bad1bea873796537f09522ab","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-05T10:40:23.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"ff7e08c1bc0298a8a8f0604cf82d2cc8f74cfcc3","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-06T10:42:01.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"f9be307388a1450c125326088c1e6d152d473c0c","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-08T21:54:00.000Z","msg":"<img src=\"https://holland.pk/mi47dlpb\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fmi47dlpb&h=d6b34559&s={SIZE}\" /><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">五毛狗不知廉恥，係連登橫行。<br />\n<br />\n利用「假事實」愚弄／分化大眾，變相去支持中共繼續統治香港。</span></span><br />\n<br />\n「當年英國開頭諗住 英方,港方,中方一齊傾...當時叫'三腳凳' ,可惜俾支那ban左<br />\n<br />\n所以而家既情況仲可以伶上去聯合國,國際法庭去仲裁.....因為當年既香港人 係冇權話事,冇認受性<br />\n」<br />\n<br />\n事實：<a href=\"http://hk.apple.nextmedia.com/news/art/20140205/18615630\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.apple.nextmedia.com%2Fnews%2Fart%2F20140205%2F18615630&d=t9lvrop9ljT%2F%2Fon6qZ%2B%2FxhOFz4pMHIf1Ti9x7C0XgVU%3D&h=3b6ce8d6\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fhk.apple.nextmedia.com%2Fnews%2Fart%2F20140205%2F18615630&h=ef738c84\" target=\"_blank\">http://hk.apple.nextmedia.com/news/art/20140205/18615630</a><br />\n【本報訊】聯合國致力保障殖民地人民的自決權（self determination），卻遺漏了香港。英國解封檔案揭露中英雙方在聯合國就香港問題的角力，英方拒絕承認人民自決是一項權利，中方則堅稱香港是其領土，令聯合國在殖民地名單上剔除香港，變相剝奪港人自決權。<br />\n<br />\n英拒承認自決權<br />\n聯合國50年代起因應殖民地問題而草議公約，保障人民自決權。解密檔案披露，英方一直盤算如何應付聯合國，擔心殖民地問題成為國際社會話柄。英國以自決權的定義缺乏國際共識為由，只肯承認自決是一項「原則」，而非法定「權利」。<br />\n聯合國成員國須按殖民地名單，定期匯報如何保障人民自決甚至獨立的權利。中國1971年重返聯合國，翌年即去信要求在名單上剔除香港，獲聯合國接納。其後英國向聯合國匯報時，多次強調不能以同一方法處理所有殖民地，須按經濟及人口等因素考慮，確保解殖後不會出現經濟或政治動盪，又以新界必須歸還中國為由，表明香港獨立不可行。許多殖民地最終透過公投自決命運。<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">聯合國已經被中共利益所操控。<br />\n國際法庭不嬲係無牙老虎，絕對無執行能力。</span></span>"},{"pid":"d3dba839c604af667423cf3fa71af89fdae25124","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-09T22:18:46.000Z","msg":"<img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" />"},{"pid":"585acae3994dccdb698013c8eb8b29e85e4060e4","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-09T22:33:07.000Z","msg":"<img src=\"https://holland.pk/qkb51ic6\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fqkb51ic6&h=77c8deed&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">人工島，咪仍然係度？邊個執行國際法庭嘅結論？答案係無！<br />\n</span></span>"},{"pid":"09b9e62621cebf28db347472098f2eac5b526975","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-10T02:20:50.000Z","msg":"<img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" />"},{"pid":"0363da02702d8539e6a9daafbdfa10570f2fbe66","tid":227163,"uid":48157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-10T06:51:15.000Z","msg":"此回覆已被刪除"},{"pid":"0cc94e8e599d7a113f82a402150ca856ec1b03f7","tid":227163,"uid":48157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-10T06:56:33.000Z","msg":"此回覆已被刪除"},{"pid":"a516218bc93eb8f874b8378bc296a982cde3fd0a","tid":227163,"uid":91835,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-10T07:48:08.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">行過路過入黎睇下啦喂</span><img src=\"/assets/faces/big/bomb.gif\" class=\"hkgmoji\" /> <span style=\"font-size: xx-large;\">繼指大後又一垃圾學店</span><img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> </span><br />\n<br />\n（各位DSE雞唔該入一入黎）<br />\n<a href=\"https://lihkg.com/thread/224550/page/7?ref=ios\" target=\"_blank\">https://lihkg.com/thread/224550/page/7?ref=ios</a>"},{"pid":"7dc92cbc95c375bb8879c449df4050a758464d1d","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-10T22:27:48.000Z","msg":"<blockquote><span style=\"color: red;\"><span style=\"font-size: xx-large;\">行過路過入黎睇下啦喂</span><img src=\"/assets/faces/big/bomb.gif\" class=\"hkgmoji\" /> <span style=\"font-size: xx-large;\">繼指大後又一垃圾學店</span><img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> </span><br />\n<br />\n（各位DSE雞唔該入一入黎）<br />\n<a href=\"https://lihkg.com/thread/224550/page/7?ref=ios\" target=\"_blank\">https://lihkg.com/thread/224550/page/7?ref=ios</a></blockquote>"},{"pid":"8994705c281c56bb29d1dde7b7707d4a9f230605","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-11T07:56:55.000Z","msg":"<blockquote><blockquote><span style=\"color: red;\"><span style=\"font-size: xx-large;\">行過路過入黎睇下啦喂</span><img src=\"/assets/faces/big/bomb.gif\" class=\"hkgmoji\" /> <span style=\"font-size: xx-large;\">繼指大後又一垃圾學店</span><img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> </span><br />\n<br />\n（各位DSE雞唔該入一入黎）<br />\n<a href=\"https://lihkg.com/thread/224550/page/7?ref=ios\" target=\"_blank\">https://lihkg.com/thread/224550/page/7?ref=ios</a></blockquote></blockquote>"},{"pid":"c875c2c63dc98051a3bf785f8c51eecbaf63f82d","tid":227163,"uid":8000,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-11T08:01:37.000Z","msg":"笑"},{"pid":"caf52ddc2c859ac12501ee8c705b1a868bc82964","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-11T08:31:21.000Z","msg":"<blockquote>笑</blockquote><br />\n多謝幫推"},{"pid":"8c34af684060cb09e5c0c02e7bf3134ba88925bb","tid":227163,"uid":48157,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-05-11T14:07:05.000Z","msg":"此回覆已被刪除"},{"pid":"90acdec3c95a9b4434ab6c8cf2e4c6de1030f015","tid":227163,"uid":4493,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-05-11T14:26:47.000Z","msg":"<blockquote>昨日（4月22日），香港《明報》刊發獨家消息，稱中共中央近日下達到各地的一份中央文件，對各地領導人提出新要求，要求對&ldquo;權威&rdquo;表述要全面、準確、規範，並不得使用&ldquo;習大大&rdquo;這樣的稱呼。<br />\n*本台（法廣）得知， 中央政法委至少在4月20日之前，就對旗下媒體傳達了上述通知，當時，政法系媒體人透露，&ldquo;接上級指示，政法系統各媒體包括新媒體，不要再稱呼總書記為習大大&rdquo;。<br />\n此外，本台得知，昨天新華社系統開會傳達了中共中央的上述指示，其中也明確提出，不得再使用&ldquo;習大大&rdquo;這樣的稱呼。<br />\n據《明報》的這篇報道，各地方媒體已陸續接到中宣部指令，要求今後在報道中不再稱呼習近平為&ldquo;習大大&rdquo;，但記者詢問了多家地方媒體，均稱尚未接到類似的通知，可能與層層傳達需要時間有關。<br />\n《明報》報道說，中共中央這份文件提出，對&ldquo;以習近平同志為總書記的黨中央&rdquo;等官方說法不得隨意增加、更改，對&ldquo;核心&rdquo;的用法不要泛化，要按照中央政治局&ldquo;三嚴三實&rdquo;民主生活會公開報道的通稿表述。<br />\n去年12月28日、29日，中共中央政治局召開專題民主生活會，話題是對照檢查踐行&ldquo;三嚴三實&rdquo;情況&mdash;&mdash;&mdash;&mdash;所謂&ldquo;三嚴三實&rdquo;是指習近平提出的&ldquo;既嚴以修身、嚴以用權、嚴以律己；又謀事要實、創業要實、做人要實&rdquo;。<br />\n當時新華社報道說，習近平在講話中則要求政治局成員&ldquo;必須有很強的看齊意識，經常、主動向黨中央看齊，向黨的理論和路線方針政策看齊&rdquo;。<br />\n《明報》強調，通稿中並無&ldquo;權威&rdquo;、&ldquo;核心&rdquo;等提法。<br />\n隨後的1月11日，以四川省委書記王東明、天津市委代理書記黃興國公開講話為首，多個省份在傳達在中央政治局&ldquo;三嚴三實&rdquo;專題民主生活會講話時，提出要維護習近平總書記這個&ldquo;核心&rdquo;。<br />\n隨後跟進的有安徽王學軍、廣西彭清華、湖北李鴻忠、西藏陳全國、內蒙王君、江蘇羅志軍、海南羅保銘等至少九名省委書記在公開會議上擁護習&ldquo;核心&rdquo;。<br />\n1月26日，《星島日報》發表題為《重現核心 十九大分曉》的文章，稱習近平&ldquo;權勢跨越江胡，直逼毛鄧，已被視為&lsquo;不是核心的核心&rsquo;&rdquo;，只差&ldquo;正名&rdquo;而已。<br />\n所謂&ldquo;習大大&rdquo;，最早是在半官方背景的微信公號&ldquo;學習粉絲團&rdquo;開始使用，隨後又有&ldquo;彭麻麻&rdquo;的說法，很快，人民日報的官方微信公號、甚至新華社的報道中都經常可見這一稱呼。<br />\n&ldquo;大大&rdquo;在中國西北和華北地區，一般是對父親或者比父親年長的長輩如伯父的稱呼，加上&ldquo;彭麻麻&rdquo;作為對應，似乎只能理解為父親。<br />\n中共前領袖鄧小平曾有&ldquo;我是中國人民的兒子&rdquo;的自述，官方媒體把新任政治領袖習近平稱為中國人民的&ldquo;父親&rdquo;，頗有輩分錯亂之感，不少中國網友覺得不適，斥之為&ldquo;五行缺爹&rdquo;。<br />\n官方此番自我修正，背後有多少博弈不得而知，但仍可贊其為政治倫理的些許進步。</blockquote><br />\n<img src=\"/assets/faces/lomoji/29.png\" class=\"hkgmoji\" />"},{"pid":"39fca78ac8d3c1abb20764930557aec6275032dc","tid":227163,"uid":105995,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-11T14:52:06.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"593a63ac38fbf107128bb0a91c20a5f6a292210f","tid":227163,"uid":48157,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-05-11T15:38:50.000Z","msg":"此回覆已被刪除"},{"pid":"66a788b2542e6f92a66cf55a8f9736139cb4be10","tid":227163,"uid":50616,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-05-11T23:15:02.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">咁點解釋大陸傳媒仲用「習大大」？<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> </span></span><br />\n<br />\n<a href=\"http://finance.sina.com.cn/stock/y/2017-04-26/doc-ifyetwsm0490871.shtml\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ffinance.sina.com.cn%2Fstock%2Fy%2F2017-04-26%2Fdoc-ifyetwsm0490871.shtml&d=t9lvrop9ljT%2F%2Fon6qZ%2B%2FxhOFz4pMHIf1Ti9x7C0XgVU%3D&h=635f239e\" target=\"_blank\">http://finance.sina.com.cn/stock/y/2017-04-26/doc-ifyetwsm0490871.shtml</a><br />\n2017-04-26<br />\n<br />\n<br />\n<a href=\"http://cppcc.china.com.cn/2017-04/12/content_40604898.htm\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fcppcc.china.com.cn%2F2017-04%2F12%2Fcontent_40604898.htm&d=t9lvrop9ljT%2F%2Fon6qZ%2B%2FxhOFz4pMHIf1Ti9x7C0XgVU%3D&h=5f5f5444\" target=\"_blank\">http://cppcc.china.com.cn/2017-04/12/content_40604898.htm</a><br />\n<img src=\"https://holland.pk/bn8uelhs\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fbn8uelhs&h=34597b6f&s={SIZE}\" /><br />\n2017-04-12"},{"pid":"778ced4bfc4a3cb08e0f79c40abc93591e40b8ad","tid":227163,"uid":50616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-11T23:20:20.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">現實同所謂「新聞」報道有衝突，所以「新聞」就係FAKE NEWS。<br />\n<br />\n五毛狗鍾意用FAKE NEWS。</span></span>"},{"pid":"60eb73ac3dc5b0fbfc26cfc7caf99247f8477b35","tid":227163,"uid":48157,"like":0,"dislike":0,"score":0,"citedBy":0,"re