-04T09:17:51.000Z","msg":"記得要搵埋散仔會報告<br />\n佢地仲大過政務司司長架<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" />"},{"pid":"da1de46ca3d81493ddf3a034d984b5b5fa1f0412","tid":1909722,"uid":269470,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-04T09:25:00.000Z","msg":"推"},{"pid":"002ed329bb1651c3dcd3dd899e80f23e9b6ec9d3","tid":1909722,"uid":118888,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-04T09:25:18.000Z","msg":"炒就梗<br />\n睇怕中左 佢都唔敢報"},{"pid":"daf66747f0e825acb9b0d17de04c152974006157","tid":1909722,"uid":283418,"like":0,"dislike":0,"score":0,"quote":{"pid":"b047b9591f342546fc67aff1406e719ea19e6b55","tid":1909722,"uid":114360,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-04T07:17:32.000Z","msg":"【武漢肺炎】專家料首批包機最多25人湖北返港後確診<span style=\"font-size: large;\"><span style=\"color: red;\">惟隨行官員毋須檢疫</span></span><br />\n<br />\n港府今（4日）派首2架包機，接載首批在湖北的200多名港人返港隔離，當中有11位原獲接載的港人拒絕乘坐。惟外界更關注隨行官員由「疫區」返港後，毋須如平民般檢疫，不少與其共事的公務員均擔心官員有播毒風險。有份到當地的政制及內地事務局局長聶德權在出發前見記者，聲稱徵詢過4名公共衞生專家意見，並評估風險，<strong><span style=\"color: red;\">所有高員回港後只需醫學監測，不需檢疫。</span></strong>港大感染及傳染病中心總監何栢良指，按當地感染人口比例，估計首批530名回港人士中，約有5至25人返港後會被驗出確診感染武漢肺炎。<br />\n<br />\n多謝手足，唔該快小小同林鄭佢哋開會，唔該晒<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\nsource：【武漢肺炎】專家料首批包機最多25人湖北返港後確診 惟隨行官員毋須檢疫 <a href=\"https://hk.feature.appledaily.com/wars/article/1_60670052\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.feature.appledaily.com%2Fwars%2Farticle%2F1_60670052&d=VxC68O7S0S1nNKmf4pYeIajD3B6m7wr0JF9t5bmmazk%3D&h=077f7a97\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.feature.appledaily.com%2Fwars%2Farticle%2F1_60670052&h=ccaed532\" data-auto-link target=\"_blank\">https://hk.feature.appledaily.com/wars/article/1_60670052</a>"},"citedBy":0,"replyTime":"2020-03-04T09:27:24.000Z","msg":"這次係接大陸香港人，位位講蝗語，咁喜歡大陸，留低支持抗炎啦！浪費公帑！永遠攞着數！<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angr