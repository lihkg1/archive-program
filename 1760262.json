aces/lm2/diu.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-28T07:16:02.000Z","msg":"個logic突然啱哂<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"a8d1ae600348fcb51f8b61bc76d5ede83ef78f2c","tid":1760262,"uid":70313,"like":1,"dislike":0,"score":1,"quote":{"pid":"9e292b8d0049197fd9abee4478ebcb819053f388","tid":1760262,"uid":41771,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-11-28T06:19:36.000Z","msg":"有冇人留意到支共條底線不斷退緊?<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n人權法開始時就話聽證會係一派胡言，叫美國唔好信。<br />\n當有議員提出審議法案果時就叫唔畀交上國會。<br />\n交上國會後就叫國會停止立法程序。<br />\n立左法之後就叫侵哥唔好簽名。<br />\n簽左之後就叫唔畀實施。<br />\n<br />\n點解可以咁柒<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-28T07:17:04.000Z","msg":"因為佢哋已經冇棋<br />\n隨時連自己都比美國制裁埋<img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"28f328c0b1e1a7e423fb56144f2f07cbb120dc8c","tid":1760262,"uid":68746,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-28T07:17:11.000Z","msg":"你班支那人真係又煩又無型<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},{"pid":"c061210ce5ddc998a2f14fe2b3a49d57184d6cb1","tid":1760262,"uid":8257,"like":0,"dislike":0,"score":0,"quote":{"pid":"370fce8c9046718961a7475c45404a4ec9f16aad","tid":1760262,"uid":158067,"like":51,"dislike":0,"score":51,"citedBy":3,"replyTime":"2019-11-28T05:51:57.000Z","msg":"一個上晝都譴責左10次<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-28T07:18:51.000Z","msg":"有合集？"},{"pid":"97743582bd0beaabcaf962721ab4d1196d5dfdee","tid":1760262,"uid":54295,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-28T07:19:19.000Z","msg":"可唔可以改下啲字眼呀<br />\n好悶<img src=\"/assets/f