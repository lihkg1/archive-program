01013235559&h=77538f63&s={SIZE}\" /><br />\n<img src=\"https://cdn.hk01.com/di/media/images/5137332/org/c4fd39ec658b4bfec4b0d6aff3f11b9f.png/v1hjIKVXEF3F3t8jSGSLea51nrfmtmee2BmV_9gZlf8?v=w1920\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F5137332%2Forg%2Fc4fd39ec658b4bfec4b0d6aff3f11b9f.png%2Fv1hjIKVXEF3F3t8jSGSLea51nrfmtmee2BmV_9gZlf8%3Fv%3Dw1920&h=17304fd9&s={SIZE}\" /><br />\n<img src=\"https://hk.on.cc/hk/bkn/cnt/news/20201027/photo/bkn-20201027192216228-1027_00822_001_01p.jpg?20201027202558\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20201027%2Fphoto%2Fbkn-20201027192216228-1027_00822_001_01p.jpg%3F20201027202558&h=4ce33b21&s={SIZE}\" /><br />\n<img src=\"https://static.stheadline.com/stheadline/inewsmedia/20200715/_2020071508234275414.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.stheadline.com%2Fstheadline%2Finewsmedia%2F20200715%2F_2020071508234275414.jpg&h=155dd654&s={SIZE}\" /><br />\n<img src=\"https://cdn.hk01.com/di/media/images/4048663/org/132e63d17c5a18f8d982d7c14cbc5e58.jpg/FzmOlXhMWkIxHZQnqK5gGW1K_-Ivsjur78Xe2O_F3tg?v=w1920\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F4048663%2Forg%2F132e63d17c5a18f8d982d7c14cbc5e58.jpg%2FFzmOlXhMWkIxHZQnqK5gGW1K_-Ivsjur78Xe2O_F3tg%3Fv%3Dw1920&h=104814ec&s={SIZE}\" />"},{"pid":"9ea3ce11c5ddc302f9b8d7b922814ef941ebd303","tid":2364643,"uid":7439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-13T07:05:08.000Z","msg":"2021年1月<br />\n(截至 1月11日)<br />\n平均最高氣溫16.8 &deg;C<br />\n平均氣溫14.1 &deg;C<br />\n平均最低氣溫11.7 &deg;C<img src=\"/assets/faces/mouse/what.gif\" class=\"hkgmoji\" /><br />\n月雨量0.0 毫米"}],"pinned":{"pid":"9ea3ce11c5ddc302f9b8d7b922814ef941ebd303","tid":2364643,"uid":7439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-13T07:05:08.000Z","msg":"2021年1月<br />\n(截至 1月11日)<br />\n平均最高氣溫16.8 &deg;C<br />\n平均氣溫14.1 &deg;C<br />\n平均最低氣溫11.7 &deg;C<img src=\"/assets/faces/mouse/what.gif\" class=\"hkgmoji\" /><br />\n月雨量0.0 毫米"}}