8D%25E7%25B1%25B2%25E7%258D%25A8%25E7%25AB%258B%25E5%25A7%2594%25E5%2593%25A1%25E6%259C%2583%25E6%259F%25A5%25E7%259C%259F%25E7%259B%25B8-%25E5%25BE%2585%25E6%259C%2589%25E5%259F%25BA%25E7%25A4%258E%25E7%2589%25B9%25E9%25A6%2596%25E5%258F%25AF%25E8%2580%2583%25E6%2585%25AE%25E7%2589%25B9%25E8%25B5%25A6&h=6ffda154\" target=\"_blank\">https://m.mingpao.com/ins/%E6%B8%AF%E8%81%9E/article/20190823/s00001/1566538736816/%E3%80%8C%E5%92%8C%E7%90%86%E5%90%8C%E8%A1%8C%E3%80%8D%E7%B1%B2%E7%8D%A8%E7%AB%8B%E5%A7%94%E5%93%A1%E6%9C%83%E6%9F%A5%E7%9C%9F%E7%9B%B8-%E5%BE%85%E6%9C%89%E5%9F%BA%E7%A4%8E%E7%89%B9%E9%A6%96%E5%8F%AF%E8%80%83%E6%85%AE%E7%89%B9%E8%B5%A6</a><br />\n和理同行"},"citedBy":0,"replyTime":"2019-08-24T16:36:36.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"7e48ffec9339b6979151f25d3ae7d6a305564629","tid":1502492,"uid":224479,"like":3,"dislike":0,"score":3,"quote":{"pid":"c1056e5fcbd2491280a53858aeef641294ef1f9a","tid":1502492,"uid":8441,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-24T16:35:04.000Z","msg":"godfather <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-24T16:38:17.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"63ef5706eff6a54cfe26e4dd48b0a739962cc7ea","tid":1502492,"uid":2748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:38:37.000Z","msg":"<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"3d4a30d6f4efe8217fecb1e6e393075dfbc3018a","tid":1502492,"uid":2748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:41:29.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"97503e98acedb50f564c713714ec5adf399c47d0","tid":1502492,"uid":103960,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-24T16:41:31.000Z","msg":"推"},{"pid":"9cc5497742a31085efa1398c7ec0e36e49e1a3e1","tid":1502492,"uid":48083,"like":2,"dislike":11,"score":-9,"citedBy":0,"replyTime":"2019-08-24T16:41:53.000Z","msg":"賣國賊名單<br />\n另加90%嗰200萬出嚟遊行既人<br />\n<br />\n‧大律師公會<br />\n<br />\n政府應立刻成立獨立調查委員會作出全面調查，特別是檢討警方在過去數星期的管理，並提出建議措施避免同類事情再次發生。<br />\n<br />\n另外，一批法律界人士發聲明，促請特首根據《調查委員會條例》（香港法例第86章）成立調查委員會。<br />\n<br />\n‧香港總商會<br />\n<br />\n促請立刻成立獨立調查委員會，審視連串事件。<br />\n<br />\n‧職工盟公務員工會<br />\n<br />\n要求政府成立獨立調查委員會，調查近兩個月一連串的衝突。<br />\n<br />\n‧香港電影製作行政人員協會<br />\n<br />\n成立獨立調查委員會，調查真相。<br />\n<br />\n‧政務主任（AO）<br />\n<br />\n呼籲警務人員支持成立獨立調查委員會，以重建警民互信。<br />\n<br />\n‧前高官議員<br />\n<br />\n成立獨立調查委員會，職權包括修例引起社會廣泛反對的成因和情況。<br />\n<br />\n‧基本法委員會委員陳弘毅<br />\n<br />\n陳弘毅認為，政府應研究是否要擴展監警會專責小組的調查範圍，並考慮尋求其他渠道，調查6月中以來連串衝突事件，包括成立獨立調查委員會。<br />\n<br />\n‧天主教香港教區宗座署理湯漢樞機、香港基督教協進會主席蘇成溢牧師<br />\n<br />\n盡速成立獨立調查委員會，持平地查找真相。<br />\n<br />\n‧立法會議員鍾國斌<br />\n<br />\n鍾國斌認為，市民希望社會能回復正常，他相信成立獨立調查委員會是社會的共識。<br />\n<br />\n‧立法會議員陳凱欣<br />\n<br />\n陳凱欣說，若獨立調查委員會是作全面調查，而非針對某個部門，值得考慮。<br />\n<br />\n‧社聯行政總裁蔡海偉<br />\n<br />\n設立獨立調查委員會，還原事件真相，又呼籲社會各界「齊上齊落、相扶同行」。<br />\n<br />\n‧環保界人士<br />\n<br />\n成立獨立調查委員會，以釐清近月種種暴力事件的緣由。<br />\n<br />\n相關報道：<br />\n<br />\n逾百AO發聲明 促特首用心聆聽 設獨立調查委員會 (2019年7月26日)<br />\n<br />\n導演編劇兩會促「撤回」修例 「成立獨立調查委員會刻不容緩」(2019年7月25日)<br />\n<br />\n石永泰：獨立調查委員會具獨特性 (2019年7月24日)<br />\n<br />\n陳弘毅促政府考慮設獨立調查委員會 (2019年7月24日)<br />\n<br />\n34前高官議員再發聯署信　強烈要求成立獨立調查委員會 (2019年7月23日)<br />\n<br />\n促獨立調查 點名李國能參與 梁家傑：具公信力 (2019年7月22日)<br />\n<br />\n高永文憂獨立調查令警不敢執法 (2019年7月21日)<br />\n<br />\n35前官員及社會人士聯署　籲各方放下敵意　促成立獨立調查委員會 (2019年7月19日)<br />\n<br />\n社聯總裁倡設獨立調查委員會 (2019年7月13日)<br />\n<br />\n李國能倡撤回修例獨立調查 (2019年7月9日)<br />\n<br />\n謝偉俊同意成立獨立調查委員會 (2019年7月5日)<br />\n<br />\n李明逵：可設獨立調查委員會全面查衝突　不應只針對警察 (2019年6月29日)<br />\n<br />\n張炳良倡成立獨立調查委員會查衝突事件 (2019年6月17日)<br />\n<br />\n更多報道：【逃犯條例】有議員團體反對成立獨立調查委員會 憂針對警方（列表不斷更新）<br />\n<br />\n<a href=\"https://m.mingpao.com/ins/港聞/article/20190726/s00001/1564126660759/【逃犯條例】各界促成立獨立調查委員會（列表不斷更新）\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%E6%B8%AF%E8%81%9E%2Farticle%2F20190726%2Fs00001%2F1564126660759%2F%E3%80%90%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B%E3%80%91%E5%90%84%E7%95%8C%E4%BF%83%E6%88%90%E7%AB%8B%E7%8D%A8%E7%AB%8B%E8%AA%BF%E6%9F%A5%E5%A7%94%E5%93%A1%E6%9C%83%EF%BC%88%E5%88%97%E8%A1%A8%E4%B8%8D%E6%96%B7%E6%9B%B4%E6%96%B0%EF%BC%89&d=BZKFieMwLRuYRu3HtqC84ktrSvVb5AcF94AlmVXjqEc%3D&h=e76867c0\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%E6%B8%AF%E8%81%9E%2Farticle%2F20190726%2Fs00001%2F1564126660759%2F%E3%80%90%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B%E3%80%91%E5%90%84%E7%95%8C%E4%BF%83%E6%88%90%E7%AB%8B%E7%8D%A8%E7%AB%8B%E8%AA%BF%E6%9F%A5%E5%A7%94%E5%93%A1%E6%9C%83%EF%BC%88%E5%88%97%E8%A1%A8%E4%B8%8D%E6%96%B7%E6%9B%B4%E6%96%B0%EF%BC%89&h=9308ed73\" target=\"_blank\">https://m.mingpao.com/ins/港聞/article/20190726/s00001/1564126660759/【逃犯條例】各界促成立獨立調查委員會（列表不斷更新）</a>"},{"pid":"e64a5917bcec21bb527ef1b4ce70986e281dccfc","tid":1502492,"uid":103960,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2019-08-24T16:43:29.000Z","msg":"每當大家想接受政府引誘<br />\n諗返犧牲左嘅同伴啦"},{"pid":"73b82bf6b433c2d2942e14004c8638cd1d244f60","tid":1502492,"uid":2748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:47:35.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"97859341d9e7079583fac95ad731b930cccde895","tid":1502492,"uid":57081,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-24T16:51:15.000Z","msg":"駁唔到"},{"pid":"f62c911036a4df938844dc424e474942fed0ccf2","tid":1502492,"uid":277263,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:53:30.000Z","msg":"陳帆呼籲市民：寧願參加其他活動都好過堵塞機場<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1498684\" data-auto-link target=\"_blank\">https://lih.kg/1498684</a>"},{"pid":"214f8c9a29a851c181cd11172de8f09c1f23e9cd","tid":1502492,"uid":2748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:54:51.000Z","msg":"