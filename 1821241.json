 src=\"https://na.cx/i/3u6eB2z.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3u6eB2z.jpg&h=585d012f&s={SIZE}\" /><br />\n好羨慕呀有守門犬睇住"},"citedBy":0,"replyTime":"2020-01-12T07:26:00.000Z","msg":"唔講仲以為班人好似放狗咁<br />\n<br />\n又幾岩形象喎... 狗黎架嘛要放出籠行下"},{"pid":"8006ae06fbe4d4febdbe27a2ebf27353d5c5ee74","tid":1821241,"uid":296369,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T07:32:43.000Z","msg":"呢啲大陸人唔係元朗人"},{"pid":"8d91455b88de4442b4b175ddd9043568c2fce9e4","tid":1821241,"uid":223741,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T07:32:53.000Z","msg":"呢度成班都係大陸狗？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0be72dd9fe3688b1044d9c977a4722bbef32e984","tid":1821241,"uid":85822,"like":0,"dislike":0,"score":0,"quote":{"pid":"3a0dc573d941e2c380bfb4e9921792a366291a24","tid":1821241,"uid":142195,"like":48,"dislike":0,"score":48,"citedBy":5,"replyTime":"2020-01-12T06:31:49.000Z","msg":"攻擊性武器又唔理 屌你老母<img src=\"https://na.cx/i/c53kxre.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fc53kxre.jpg&h=0cd6357e&s={SIZE}\" /><br />\n懷疑有手足叫支持林卓廷<br />\n前面條長髮佬就上前手指指同影大頭<br />\n左手邊個後生啲就拎住行山拐杖惗住兇人"},"citedBy":0,"replyTime":"2020-01-12T07:33:25.000Z","msg":"大家睇住"},{"pid":"36583fd407a98d35e731353d74bc4b1ddc9f4e85","tid":1821241,"uid":85822,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-01-12T07:35:31.000Z","msg":"借個位宣傳吸引火力黎推post<br />\n<br />\n<br />\nfor 想健康升級/心態體力提升手足參考<br />\n<br />\n入黎補補正能量調整心態<img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" /><br />\n個人夠正能量先頂到落去<br />\n<br />\n<br />\n自衞隊身體質素＆勇氣全世界都大有必要<br />\n香港人 only you can change yourself<br />\n未來嘅希望由我地做起<br />\n<br />\nStep 10.心存希望 管理情緒<br />\nHeal yourself🌱<br />\nFree yourself 🈵<br />\nFree the emotion🎉<br />\n無論咩時間 心存希望<br />\n我的使命係帶希望比大家<br />\n我地一齊行落去 <br />\n沒有處理不到的事<br />\n只有處理不到的心情<br />\n管理好情緒 有助我地做得更好<br />\n⚡️減少重複接觸影響自己的負面人事<br />\n🍎每日練習 突破舒適圈 比自己進步一下<br />\n🔥要增肌/提神/搵工/調理身體想心情更好歡迎黎搵我運動<br />\n<br />\n<br />\n<br />\n利申：健康教練<br />\n啱嘅就聽下幫自己再幫人<br />\n 唔啱聽我都唔會覆你 <br />\n重點係大家Build up自信＋能耐做更強嘅自己 <br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">We can do it</span></span> <br />\n香港人團結 正能量<br />\n呢個世界唔係我地影響人<br />\n就係人地影響緊我地<br />\n我地要內在夠強 大返佢地<br />\n<br />\n永續健康身心 成功致勝<br />\n營養/心態歡迎搵我幫手<br />\n教完大家要做<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><br />\n香港需要大家<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\nTG ME幫你Case Study <br />\n教你點飲食點運動打仗飲食法<br />\n20％運動 80％營養<br />\n學完再善用Budget 搞好自己體能<br />\n支持升級黃圈 培訓人才人人出資資助小朋友就業<br />\n免費簡單健康分析<br />\n收費嘅跟進我都做 <br />\n支持黃圈返正價出錢幫人<br />\nNothing is free for granted <br />\nIf you Learn, do help more ppl<br />\n得閒係屋企/搵我做下運動放鬆<br />\nBuild up 自己自信 無狗敢搞你<br />\n如果你期望唔出付就會有結果<br />\n請你離開<br />\n<br />\nMy TG<br />\n<a href=\"https://t.me/TreeHoIsGood\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FTreeHoIsGood&d=uClJ75VMDgyJ2T8QnpTVXWhNlLB%2BLbsdBqu6cuXqlDc%3D&h=cd522971\" data-auto-link target=\"_blank\">https://t.me/TreeHoIsGood</a><br />\nChannel<br />\n<a href=\"https://t.me/treehoHealthAdvice\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FtreehoHealthAdvice&d=uClJ75VMDgyJ2T8QnpTVXWhNlLB%2BLbsdBqu6cuXqlDc%3D&h=1be75b79\" data-auto-link target=\"_blank\">https://t.me/treehoHealthAdvice</a><br />\n討論區<br />\n<a href=\"https://t.me/THHATalk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FTHHATalk&d=uClJ75VMDgyJ2T8QnpTVXWhNlLB%2BLbsdBqu6cuXqlDc%3D&h=0c65f204\" data-auto-link target=\"_blank\">https://t.me/THHATalk</a><br />\n長期戰爭 齊上齊落<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n對抗白色恐怖 <br />\n反共抗中 我地勢不兩立<br />\nWe Shall Never Surrender<br />\n<br />\nUnited, We can win the fight