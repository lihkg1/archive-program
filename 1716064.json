 />\n</ins>"},{"pid":"41475605a90b8c3daf8d399c8a82e74e7bdc67ba","tid":1716064,"uid":81560,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T09:24:48.000Z","msg":"有冇聽過工賊呢個詞語"},{"pid":"c5c02707d861f3ae595dfdb253b633091bb1a812","tid":1716064,"uid":105817,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-11-13T09:31:09.000Z","msg":"有工會。<br />\n工會除左主持罷工之外，仲會禁止會員返工<br />\n由於工會本身都係為左保障勞工權益而存在，所以本質上好少人會選擇唔入工會，亦所以唔會有人罷工，有人返工咁吊詭嘅情況出現"}]}