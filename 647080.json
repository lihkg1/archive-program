rc=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n喺度祝咁多位快啲好返<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"}]}