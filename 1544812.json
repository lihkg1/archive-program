cx%2Fi%2FJXMrzU3.jpg&h=4fd76574&s={SIZE}\" />"},{"pid":"3c8c7501cf5844f830244f1d50fde5172b10d7dd","tid":1544812,"uid":4174,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-09-05T16:37:34.000Z","msg":"認真 日日返工都未見過"},{"pid":"99cb7fec95b80bdb0ad703e1217a674f61e8ae29","tid":1544812,"uid":315773,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-05T16:38:22.000Z","msg":"有跳!! 真跳!!"},{"pid":"e1755032ba04ae6bf5968e0cb95289cf7cbce23f","tid":1544812,"uid":199911,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T16:39:00.000Z","msg":"有撞"},{"pid":"79fe46def3ec21562c1310b464a9bac7cbf0230a","tid":1544812,"uid":224916,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-05T16:39:07.000Z","msg":"連黃衫都驚，但又話唔怕攬炒，唔怕共產黨"},{"pid":"59da8d529be1d351c8325808dcf72bdb580929d8","tid":1544812,"uid":161985,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T16:39:33.000Z","msg":"綠卡"},{"pid":"3f2efadb2a2206704eb7316edbd06c786efe3016","tid":1544812,"uid":138978,"like":0,"dislike":0,"score":0,"quote":{"pid":"08fd012a45dc4f3339a5e0ba4f3c27e1f188815c","tid":1544812,"uid":5271,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2019-09-05T16:36:56.000Z","msg":"我覺得要改口做撞閘<br />\n撞閘比起跳閘冇咁大動作<br />\n而且smooth 好多"},"citedBy":0,"replyTime":"2019-09-05T16:40:07.000Z","msg":"真 可以循序漸進"},{"pid":"9bc7b67b2946e52b3074d7aa06726d59eb4e9a0c","tid":1544812,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T16:40:41.000Z","msg":"全民跳閘"},{"pid":"9d853bdc7c3fb3f8efc5d74e592adefa3ec0ee54","tid":1544812,"uid":287220,"like":4,"dislike":0,"score":4,"quote":{"pid":"08fd012a45dc4f3339a5e0ba4f3c27e1f188815c","tid":1544812,"uid":5271,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2019-09-05T16:36:56.000Z","msg":"我覺得要改口做撞閘<br />\n撞閘比起跳閘冇咁大動作<br />\n而且smooth 好多"},"citedBy":2,"replyTime":"2019-09-05T16:41:09.000Z","msg":"唔知係咪我撞錯 撞到手斷都唔撚開<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n跳左佢算<img src=\"/asse