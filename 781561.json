/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"8302052418af6a3f5526bd219c36859c7f3c66e6","tid":781561,"uid":71508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-16T14:43:17.000Z","msg":"邊到買多"},{"pid":"f804a16496d9774b9b05d4430e0a2bf326fbb2c8","tid":781561,"uid":36497,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-18T13:42:08.000Z","msg":"樓主講得hao"},{"pid":"3b8143766500fda75a6df39c72c2f8302f667c44","tid":781561,"uid":45068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-18T16:47:45.000Z","msg":"樓主on9仔<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"7cc419ad158160d0e091ecd217f33fa99157039c","tid":781561,"uid":68094,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T03:30:24.000Z","msg":"此回覆已被刪除"},{"pid":"e68f198ee4d72adb7657be80f8eb7e68a3b3eb25","tid":781561,"uid":128882,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T03:32:02.000Z","msg":"<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" /> 戰地記者"},{"pid":"b8e53b23ed758007f5a03fe21621155fd78e9233","tid":781561,"uid":1482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T03:38:46.000Z","msg":"有次個fd去旅行發生意外 住左起個邊1個星期醫院 特登買機位返香港 再抖左半個月先返到工 跟住物理治療多半年 個度好似7-8萬 冇買旅遊保險就gg了"},{"pid":"d4fce70c72c750aa1e7344e9ea2fc714012434cb","tid":781561,"uid":6777,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T03:43:38.000Z","msg":"大至死亡，住院做手術<br />\n小至撞爛喼，delay, 天氣因素，旅遊警示 都有得賠<br />\n<br />\n而你只係比百幾蚊二百蚊<br />\n<br />\n基本上去得旅行多 好難唔遇到上面其中一樣<br />\n<br />\n中一次已經夠cover 你比過既保險費<br />\n<br />\n應該係無乜點旅行，on99既學生仔先會覺得買黎無用<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b1bcf8ed7c9175fdf6ad927facbd1eb18c91bfc7","tid":781561,"uid":78212,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T03:48:00.000Z","msg":"<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"},{"pid":"03e3418b08834910535b40cec287172a9f694492","tid":781561,"uid":86940,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T04:19:41.000Z","msg":"百幾二百都慳<br />\n條路自己素揀,仆術唔好喊"},{"pid":"1bcc9f19f15ae596aaedc1b893f1a380e5938bbb","tid":781561,"uid":18444,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T05:36:38.000Z","msg":"覺唔覺去旅行唔買旅遊保險既人好撚on9?"},{"pid":"cfe4a904b90a168e76e26829b0378c226b239f5d","tid":781561,"uid":89931,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T05:58:18.000Z","msg":"冇錯 所以我通常都唔帶套 又要驚 又要做真係<img src=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" />"},{"pid":"baafbd4d19b4d1566d7058c1068baced5f8b5d77","tid":781561,"uid":68993,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-19T06:25:39.000Z","msg":"旅遊保 <br />\n<br />\n成日出差， 一出個幾兩星期， 一年幾次， 其實抵買<br />\n<br />\n有時真係病 q左 定意外整親<br />\n係當地睇左醫生<br />\n番到香港再 follow up都有得 claim <br />\n<br />\n講緊千幾蚊保費， cover全年， 一有事閒閒地就 claim幾千 ga la <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a68b547881759c2b048c65461cacd2ed0dd6214a","tid":781561,"uid":133959,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-19T06:52:05.000Z","msg":"【A1頭條】遊沖繩食牛舌 女子鯁喉命危<br />\n<br />\n三十七歲的玩具採購員陳愛玲上月中赴日本沖繩度歲，年初一品嚐日式燒牛舌時鯁喉昏迷，送院期間心跳曾停頓三分鐘，在當地醫院持續救治二十一天，現時情況危殆。<span style=\"color: blue;\">由於她無購買旅遊保險，當地住院醫療開支高達每天一萬港元，家人支付十萬元醫療費後已山窮水盡</span>，正四處求助，盼盡早將她接返港治療。七十二歲的陳母哀痛地說：「希望善心人幫幫忙，等妹妹可以快啲返嚟香港。」<br />\n「援助愛玲」捐款編號：C3872<br />\n<br />\n又係時候貼堂<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"42c1b652d93de8279430880e5b7088baab3f0bde","tid":781561,"uid":91720,"like":0,"dislike":0,"score":0,"quote":{"pid":"1fe742082587e3e45927c6114c75b35adc5b208f","tid":781561,"uid":12609,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-16T09:10:11.000Z","msg":"唔買保險果班通常出事就會搵蘋果<br />\n講自己幾慘醫療幾貴<br />\n希望香港人籌旗接佢返黎 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-19T07:31:46.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/daily/article/20150312/19073128\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20150312%2F19073128&d=mvgydw%2BwIV3EwqjE35xrrL%2BHiWCy6q6AsXO%2BLNmzhis%3D&h=6f4037f5\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20150312%2F19073128&h=867a854b\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20150312/19073128</a><br />\n<br />\n以上為典型例子<br />\n<br />\n意外啲野好難講， 百幾蚊保險可以慳番幾十萬點解唔買"}]}