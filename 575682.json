=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"05d6ae0142295340002018a082d736de32ab5fc7","tid":575682,"uid":52727,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-28T10:52:11.000Z","msg":"google 都懶"},{"pid":"13fdc3d78451116ea9fb0d5401b1bb3f9dbefc17","tid":575682,"uid":30169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-28T10:54:27.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"989f5bdac76e363ab2be5e6bac55c591cad19c10","tid":575682,"uid":73915,"like":0,"dislike":0,"score":0,"quote":{"pid":"29d95b1eb27f7db7b715d4766f6dbd93d58fdb34","tid":575682,"uid":21035,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2018-02-28T10:50:19.000Z","msg":"香港海洋公園位於香港香港島南區黃竹坑黃竹坑道180號，佔地逾91.5公頃，是一座集海陸動物展覽、機動遊戲和大型表演於一身的主題公園，於1971年成立，於1972年7月動工，於1977年1月10日[4]開幕，<span style=\"color: red;\">為一個由香港政府全資擁有的非牟利機構管理</span>。<br />\n<br />\n<a href=\"https://zh.m.wikipedia.org/zh-hant/香港海洋公園\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wikipedia.org%2Fzh-hant%2F%E9%A6%99%E6%B8%AF%E6%B5%B7%E6%B4%8B%E5%85%AC%E5%9C%92&d=AHdw2UL%2B6RWn7xXxvaw3T0%2Fk3Pi4b370HO%2BLvdN%2BZCE%3D&h=7c0c2ec7\" target=\"_blank\">https://zh.m.wikipedia.org/zh-hant/香港海洋公園</a>"},"citedBy":0,"replyTime":"2018-02-28T10:54:43.000Z","msg":"海洋公園網頁，冇講股權，馬會出資<br />\n<br />\n海洋公園於1977年1月在港督麥理浩爵士主禮下正式開幕。公園由香港賽馬會資助以及政府免費撥地，工程耗資1.5億港元。在1982 至1984 年間，香港賽馬會再次撥款2.4億港元進行公園第二期發展工程，增建大樹灣遊樂設施及山上機動遊戲，令設施更趨多元化。擴展工程令公園更受歡迎，帶來更大的經濟效益，同時能更充份利用土地資源。"},{"pid":"c126f31acf3e50bf45c98a26666e02611a08fa1d","tid":575682,"uid":25148,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-28T10:54:49.000Z","msg":"而家唔貼海馬 過幾年邊有藉口貼高鐵啊"},{"pid":"a23856f09f197975c7d528a59a46fbf5e2a05f88","tid":575682,"uid":73915,"like":0,"dislike":0,"score":0,"quote":{"pid":"c126f31acf3e50bf45c98a26666e02611a08fa1d","tid":575682,"uid":25148,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-28T10:54:49.000Z","msg":"而家唔貼海馬 過幾年邊有藉口貼高鐵啊"},"citedBy":0,"replyTime":"2018-02-28T10:58:00.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"c2b34a6e3bf093726dc47523d4c8827331e0feb0","tid":575682,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-28T11:00:33.000Z","msg":"高鐵三跑同問<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d1e4f530db1b1ad28e348713c0c87f29b713e4f9","tid":575682,"uid":127123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-28T11:04:14.000Z","msg":"海洋公園於1977年由香港賽馬會捐款興建，並由馬會管理。1987年7月1日，港英政府通過海洋公園條例，由馬會撥款2億港元成立信託基金，<span style=\"font-size: xx-large;\">公園脫離馬會獨立</span>，成為法定非牟利機構，需要自負盈虧，可儘量以商業手法經營。 <br />\n<br />\n寫明全資擁有仲講股權...<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cc964e543454d8889e816e1ea5f7fd5f09527072","tid":575682,"uid":30836,"like":1,"dislike":0,"score":1,"quote":{"pid":"f2c8f5633802c014dfec0b59e4c1c755556c796c","tid":575682,"uid":73915,"like":0,"dislike":2,"score":-2,"quote":{"pid":"8abbf548f71084f59cc98936f966ebc3ab6fd67b","tid":575682,"uid":9193,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-28T10:48:56.000Z","msg":"政府有份 好似係"},"citedBy":2,"replyTime":"2018-02-28T10:50:12.000Z","msg":"有冇資料？"},"citedBy":1,"replyTime":"2018-02-28T17:24:22.000Z","msg":"Wiki 寫得鳩下鳩下咁 啲人又照拎出嚟做reference <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"http://www.hktdc.com/mis/ires/tc/s/ocean-park.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.hktdc.com%2Fmis%2Fires%2Ftc%2Fs%2Focean-park.html&d=AHdw2UL%2B6RWn7xXxvaw3T0%2Fk3Pi4b370HO%2BLvdN%2BZCE%3D&h=4334f86c\" target=\"_blank\">http://www.hktdc.com/mis/ires/tc/s/ocean-park.html</a><br />\n<br />\n建議睇呢個"},{"pid":"2c014a612eea2ce214b167b441c348461e5591c3","tid":575682,"uid":47674,"like":1,"dislike":0,"score":1,"quote":{"pid":"cc964e543454d8889e816e1ea5f7fd5f09527072","tid":575682,"uid":30836,"like":1,"disli