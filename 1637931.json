,"replyTime":"2019-10-08T07:08:46.000Z","msg":"其實仲有壽司郎"},{"pid":"61d3f8c27cfe4df9750ddba9376839366774e73c","tid":1637931,"uid":202798,"like":0,"dislike":0,"score":0,"quote":{"pid":"8073fa3b5a7febcef1a4a9b7f806055de2600bc8","tid":1637931,"uid":202798,"like":1,"dislike":0,"score":1,"quote":{"pid":"a8affea4e19a10f497cc8b8e26be7ee4b3e9d973","tid":1637931,"uid":144492,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-10-08T07:00:01.000Z","msg":"爭氣啦<br />\n一街食肆都唔肯揀間偏黃嘅"},"citedBy":1,"replyTime":"2019-10-08T07:08:46.000Z","msg":"其實仲有壽司郎"},"citedBy":0,"replyTime":"2019-10-08T08:44:41.000Z","msg":"Push"},{"pid":"01ae4ca24edbcee198bfba39aa54ab55a096ec13","tid":1637931,"uid":45788,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T11:58:27.000Z","msg":"<img src=\"/assets/faces/dog/stop.gif\" class=\"hkgmoji\" />"},{"pid":"12218180a4510ed56be9bafcba24d37de78b15bc","tid":1637931,"uid":45788,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T12:20:48.000Z","msg":"<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />"},{"pid":"5f5509084345681d2cf1883cada3fa3fc4929536","tid":1637931,"uid":45788,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-08T12:21:03.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c86faf4ef6b095748ba09eaee4f4dacf2cc0c5c3","tid":1637931,"uid":202798,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f5509084345681d2cf1883cada3fa3fc4929536","tid":1637931,"uid":45788,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-08T12:21:03.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-08T15:00:35.000Z","msg":"<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"6c70407ba0f1061084710669dd89c9ef25a252f9","