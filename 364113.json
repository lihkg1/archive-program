c5f38706716fcdd0fb221dffb530015","tid":364113,"uid":26451,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-08-18T07:14:57.000Z","msg":"此回覆已被刪除"},{"pid":"2c3184807a29147bdab30da2b41d1a2d249c698f","tid":364113,"uid":23707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-18T09:39:44.000Z","msg":"屌"},{"pid":"285ba09990e69160186efedce6a69696c99e6741","tid":364113,"uid":90704,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-18T09:41:54.000Z","msg":"心動不如行動啦<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"eb9c1c01311a7661dc89063143ca4a6720324bcd","tid":364113,"uid":23707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-18T13:46:29.000Z","msg":"屌"},{"pid":"d74d94fa73b45c3acfe330c7d2cfa81b924bd006","tid":364113,"uid":23707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-18T23:25:33.000Z","msg":"屌"},{"pid":"a84311ae938184f1809773046cf37234777d4fcd","tid":364113,"uid":40628,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-18T23:26:55.000Z","msg":"<blockquote>近期，連登有好多自稱<span style=\"color: red;\">  中国人</span> 嘅會員<br />\n<br />\n製造分化，互相指罵，冷嘲熱諷，散播失敗悲觀言論，甚至用舊聞洗版<br />\n<br />\n令反對派唔能有正常議事討論<br />\n<br />\n<br />\n呢班人以往被標籤為 <span style=\"color: blue;\">五毛</span> 就會迅速以屈毛論反駁<br />\n<br />\n但只要你標籤佢地為<span style=\"color: red;\"> 中国人</span> ，佢地就唔敢否認，因為佢地唔想造到網絡世界有否認做<span style=\"color: red;\"> 中国人</span> 嘅風氣。<br />\n<br />\n暫時，佢地多數先自認做中国人，然後再問做中国人有咩問題，繼而想拉所有人落水齊齊做中国人 <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <br />\n<br />\n希望各位反對派同路人，由今日起，將連登入面嘅 <span style=\"color: red;\">中囯人</span>會員逐個辨認出嚟，一 可令真香港人重新聚集討論，亦唔需要再為五毛屈毛拗嚟拗去。<br />\n<br />\n同埋見到<span style=\"color: red;\">中国人</span>唔使 Block ，因為無論你點標籤佢做 <span style=\"color: red;\">中国人</span> 佢都唔會否認，所以將其歪理或者醜態同時歸入做<span style=\"color: red;\">中国人特質</span>佢地就要花更多時間為中国人呢個身份辯護，亦唔能夠話你<span style=\"color: red;\">屈人做中国人</span>，因為呢一句係非常負面，中共唔想見到。一般會員亦更容易分辨<span style=\"color: red;\">中国人</span>。<br />\n<br />\n<br />\n<br />\n睇下今日捉到幾多連登<span style=\"color: red;\">中国人</span>先<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"843138a38e34ea5e88813cf171893dcef1f0ab74","tid":364113,"uid":25858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-19T00:06:05.000Z","msg":"<blockquote>美軍來了我帶路<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f825edcaa296a5b421b1bb8ee5ef2fd9950af4ff","tid":364113,"uid":22858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-19T00:36:38.000Z","msg":"<strong><span style=\"font-size: xx-large;\">美國政客屌少一日侵，屌多幾下支那就好好</span></strong>"},{"pid":"e93df33b52559bfd53c975d6708c65ac33724eb1","tid":364113,"uid":116711,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-19T00:45:56.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"1ac386828a3190e936f64542202118292a7e8b09","tid":364113,"uid":52671,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-19T01:03:28.000Z","msg":"佩洛西好大波"},{"pid":"b10b7e84cd0967c28a0f544b8d329198ccd207bd","tid":364113,"uid":7632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-19T04:42:57.000Z","msg":"Pelosi 從政以黎第一次講下人話！"}]}