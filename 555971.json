e3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fpic.qiantucdn.com%2F01%2F31%2F02%2F86bOOOPICe3.jpg&h=d51b0bb6&s={SIZE}\" /><br />\n<br />\n<img src=\"https://cdn.hk01.com/media/images/563476/xlarge/60d921fd987b84682f66d43d2451df84.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fmedia%2Fimages%2F563476%2Fxlarge%2F60d921fd987b84682f66d43d2451df84.jpg&h=a0a4a562&s={SIZE}\" />"},{"pid":"61dc6246771dce1b5430d820529a0d31708c705e","tid":555971,"uid":147467,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-10T05:31:49.000Z","msg":"中國人特登黎香港打疫苗架<br />\n係fb講仲多香港傻西信 素人父母乜鳩<br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"80d1a8662678d60d94172694175eb5bbd0b1fb12","tid":555971,"uid":79563,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-02-10T05:33:47.000Z","msg":"無謝安琪呢D文科豬, 世間又點會有騙財數億既健康產品？<br />\n<br />\n<span style=\"color: orange;\"><strong>JAPAN LIFE港業務疑停運 逾百長者損失逾億</strong></span><br />\n<br />\n<img src=\"http://media.zenfs.com/zh-Hant-HK/homerun/onccinstantnews.com/ac6686e125f0527ae445e31daf7f6cd4\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fmedia.zenfs.com%2Fzh-Hant-HK%2Fhomerun%2Fonccinstantnews.com%2Fac6686e125f0527ae445e31daf7f6cd4&h=3d4ee195&s={SIZE}\" /><br />\n<br />\n【<a href=\"http://on.cc\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fon.cc&d=h3oADuDJK3jSendkQNSAcXIou9iuErJt32EjuWI86Zw%3D&h=6fb08be6\" data-auto-link target=\"_blank\">on.cc</a>東網專訊】出售「健康產品」的日本公司「JAPAN LIFE」疑停運香港業務，逾百長者累計損失逾億元！有政黨今日(9日)召開記者會，指近日收到逾100名市民求助，指該公司聲稱購買「健康產品」後，會協助他們出租產品，並派發每月6至10厘利息回報，遂決定作出投資，投資金額由數十萬至數千萬港元不等。不過，有受影響客戶指，該公司於日本的總部近日因日本政府執法而停止運作，香港各分店亦陸續停止運作，沒有再派息及發還本金，擔心會血本無歸。據了解，整件事件牽涉超過2000名香港人受害，超過4億港元投資額。<br />\n<br />\n灣仔警署今日接獲報案，指有市民向一間公司購買產品作投資用途後，自去年底起未能收到相關的投資回報，懷疑受騙，案件暫列作「以欺騙手段取得財產」，由灣仔警區刑事調查隊第3隊跟進，暫時無人被捕。<br />\n<br />\n油尖旺區區議員余德寶指，根據受影響市民的資料，「JAPAN LIFE」會提供不同磁力健康產品讓事主購買，例如「元氣背心」、「健康離子枕」等，價錢由5萬元至50萬不等，且必須一筆過購入產品，然後由該公司會將產品「租出」，定期發放利息予客戶。而客戶亦可以選擇短期或長期投資計劃，息率由6至10厘不等。<br />\n<br />\n余又指，翻查外地傳媒早前的報道，JAPAN LIFE日本總部因採用「物主騙局」及「層壓式推銷」手法，在去年12月26日，第4次被日本消費者廳命令停業，並遭凍結銀行戶口處分，最後宣布清盤。現時日本愛知縣警方已着手進行刑事調查。他續指，香港分部於11月開始陸續關閉分店，沒有再派發利息，更有香港員工被公司欠薪，事件因而被揭發，又指今早與數名受影響客戶到灣仔警察總部報案。"},{"pid":"397b26b193b4f860027ff46925d7484c5bec11bd","tid":555971,"uid":79563,"like":2,"dislike":0,"score":2,"quote":{"pid":"61dc6246771dce1b5430d820529a0d31708c705e","tid":555971,"uid":147467,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-10T05:31:49.000Z","msg":"中國人特登黎香港打疫苗架<br />\n係fb講仲多香港傻西信 素人父母乜鳩<br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-10T05:35:11.000Z","msg":"支那人就黎搶疫苗打<br />\n<br />\n文科港豬老母就睇完CONTENT FARM, 鳩吹66%無用叫人唔好打<br />\n<br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"b57bd9b2eb7ce371f08c49fe7b5a4acdfdbc05bf","tid":555971,"uid":79563,"like":0,"dislike":0,"score":0,"quote":{"pid":"15aa9dd21b52dda266b4de9b4668a0ccead60e57","tid":555971,"uid":3241,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-10T05:28:04.000Z","msg":"支那人咁蠢， 我睇雙氧水會缺貨"},"citedBy":0,"replyTime":"2018-02-10T05:36:26.000Z","msg":"等睇文科港豬老母謝安琪買10箱返屋企飲都得啦"},{"pid":"ab63f0e4bd42624872d12d35323b54760646fcf9","tid":555971,"uid":27359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-10T05:38:22.000Z","msg":"文科豬快撚啲死<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"}]}