=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},{"pid":"d485b2c10f0d88b61913a380e05918cf76454361","tid":681703,"uid":180459,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-30T06:14:12.000Z","msg":"點解人哋要請你過去先做嘢？要請的話點解唔請返台灣人呢？"},{"pid":"c3571f3041e8ac06a5ca69f8e2afaa88c7968900","tid":681703,"uid":61396,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-30T06:16:41.000Z","msg":"去ptt 睇下台灣人工先<br />\n台灣人 想住點出去搵食"},{"pid":"1497224cd82b530bd0f895ad602888513a0c92a0","tid":681703,"uid":165359,"like":0,"dislike":0,"score":0,"quote":{"pid":"937aaf5cb7ce9cdd24b070f5fe9c987e28aaf7d4","tid":681703,"uid":128340,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-05-28T09:09:02.000Z","msg":"有冇巴絲打係台灣工作/發展?<br />\n我考慮過畢業後去台灣發展<br />\n<br />\n想問問各位巴絲 要點樣申請工作簽證之類?要搵咗嘢做先申請定點?<br />\n<br />\n利申 讀accounting, 為咗女友去台灣"},"citedBy":0,"replyTime":"2018-05-30T06:22:23.000Z","msg":"去台灣做會計? 食得屎架喎"},{"pid":"ebc5afc544bc3f859b5033518a9281ad0fe2102f","tid":681703,"uid":76216,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-30T06:26:13.000Z","msg":"唔洗諗<br />\n香港人工係台灣3倍<br />\n<br />\n法律系master畢業 都係28K 起跳<br />\n當係出去租屋 10K 唔計水電<br />\n得返18K   未計食飯交通<br />\n<br />\n夠你用D咩<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n台灣生活佐快7年 9月就讀完master返澳門"},{"pid":"0e6fea2dffd5301810594492d6e082e493944aef","tid":681703,"uid":178317,"like":0,"dislike":0,"score":0,"quote":{"pid":"49305d12b9fabe8226568232f34836d6e0f9edce","tid":681703,"uid":128340,"like":0,"dislike":0,"score":0,"quote":{"pid":"007b02dd7424bb2edaed6c7b3f2c3588ae0534d4","tid":681703,"uid":178317,"like":0,"dislike":0,"score":0,"quote":{"pid":"762548708f89cc54cde92b1c850ca7bdb28b79c7","tid":681703,"uid":128340,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-05-30T04:07:53.000Z","msg":"我同女友一齊4年幾啦 可以算係同居咗4年幾 可以叫做穩定。最近因為long D 同埋未來喺邊到定居/發展 而出現咗問題 女友有想分手嘅意思 佢覺得如果有男女朋友關係 但唔能夠生活一齊 咁倒不如分開"},"citedBy":1,"replyTime":"2018-05-30T04:53:43.000Z","msg":"老實講，如果你係係香港或者外國畢業既真係無謂一出黎就去台灣做野，淨係講收入已經差天共地。<br />\n去台灣發展唔係問題，但你起碼係香港做下野拎下經驗先。account依行我唔熟唔知台灣有咩大公司，但你要人地幫你搞visa，都一定要大公司請你先會做到，你仲要問下自己究竟有咩bargain power，點解人地要搞一大輪野去幫你搞visa請你過黎做，最重要你係白紙一張。不過如果你係台灣畢業既就無依個問題，但收入同物質生活會同你係香港一定會有好大分別。<br />\n<br />\n其實如果真係感情好又穩定既話，係應該一齊諗下點解決問題，而唔係好似你女友咁有分手既諗頭<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 可能你地仲細，不過真係要諗清楚你自己既前途問題<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-30T05:23:31.000Z","msg":"感謝巴打提供意見。我都有諗過如果真喺放低一切 走去台灣 到最後被分手 我會一無所有 但依段感情唔喺話放就放得低 <br />\n我唔想後悔 亦唔想有遺憾咁走過一生<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-30T06:37:15.000Z","msg":"<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"5cc4a1c49df98f24f5ca9a4ca2e5231963191c96","tid":681703,"uid":76216,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-30T06:40:16.000Z","msg":"講少佐樣野 係台灣做會計師要考國家考試<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n香港野未必岩用<br />\n<br />\n有種叫記帳士 唔洗考 但人工低"},{"pid":"3db0ec59c56d34ba1ff7d74b1c5353b4b2db07fb","tid":681703,"uid":64699,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-30T07:07:26.000Z","msg":"此回覆已被刪除"},{"pid":"9930c11ababb95f33ae2ca905327f00c5c9e01cd","tid":681703,"uid":3112,"like":1,"dislike":0,"score":1,"quote":{"pid":"3db0ec59c56d34ba1ff7d74b1c5353b4b2db07fb","tid":681703,"uid":64699,"like":0,"dislike":0,"score":0,"quote":{"pid":"1c1e855ff9e60c80d0313c30fe55c429366b3aa5","tid":681703,"uid":128340,"like":0,"dislike":0,"score":0,"quote":{"pid":"041ff1d3171d4a5abb0a05a4a36c27695a52e02b","tid":681703,"uid":154421,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-30T05:47:03.000Z","msg":"放棄啦,我都係會計,都諗過去台灣<br />\n不過我女朋友唔係台灣人,<br />\n但佢好鍾意台灣,係果邊住過一排<br />\n我係啲人力網試過好多原全無回音<br />\n開4萬台幣都會回音<br />\n點生活"},"citedBy":1,"replyTime":"2018-05-30T05:50:06.000Z","msg":"巴打 你女朋友香港人? 如果喺 都叫做比較容易處理 畢竟唔洗異地"},"citedBy":1,"replyTime":"2018-05-30T07:07:26.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-05-30T08:00:26.000Z","msg":"果d係父幹撚黎<br />\n台灣經濟早過香港起飛,當年果代人勁既搵埋搵埋買起半條街都得,出國移民呢D當食生菜,一般中產一年去十次八次歐美國家旅行係好撚正常,經濟又好,有手有腳就請,台北工專(宜家既台科大)畢業出黎已經無撚敵,更加唔洗講大學生啦<br />\n<br />\n宜家? 冇返個5大master degree就最多35k ntd,不論行業,而且人地碩士一入職就職級/升職前景高你幾班,學士有幾多經驗都冇撚用,唔讀埋兩年master就成世係低層員工<br />\n<br />\n我身邊d business撚個個都係一邊努力洗GPA洗到靚一靚,另一邊準備台政entrance exam/GRE讀master,到入左master先再算,反正係唔係都要讀個master先搵到正常工(even台政)<br />\n<br />\n想靠香港果套經驗主義響台灣搵食既可以準備收皮了<br />\n<br />\n<a href=\"https://www.ptt.cc/bbs/studyabroad/M.1522836825.A.B3B.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ptt.cc%2Fbbs%2Fstudyabroad%2FM.1522836825.A.B3B.html&d=LJrlrQnCPRTkRTA%2FSLTgpTCdMQr7etzq9tFbjrA%2B72k%3D&h=a3fbfa38\" target=\"_blank\">https://www.ptt.cc/bbs/studyabroad/M.1522836825.A.B3B.html</a>"},{"pid":"123e1e37098138d31b766957290f1b9d4a07c1d4","tid":681703,"uid":3112,"like":0,"dislike":0,"score":0,"quote":{"pid":"31f34fc3f24e135dfbd896867796a83ce6084268","tid":681703,"uid":67551,"like":1,"dislike":0,"score":1,"quote":{"pid":"59fb2a931659f130c94868e08b85cb497986499b","tid":681703,"uid":3112,"like":1,"dislike":5,"score":-4,"quote":{"pid":"4dde29ccea1157dfecc1e3ce13eaa08cb1ae826a","tid":681703,"uid":134431,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2018-05-29T08:17:17.000Z","msg":"有fd NTU Account Master 畢業<br />\n所有Paper 係Master Course 已經考哂<br />\n一入去小綠點做Accountant 1 定 2 <br />\n四年前都係得39800 一個月"},"citedBy":2,"replyTime":"2018-05-29T09:40:59.000Z","msg":"咪1皮hkd咁上下<br />\n離開左大城市就好難拎返呢個人工,變相走唔到出去<br />\n<br />\n都係果句,你唔諗住出國,成世屈響台灣咪冇問題lor<br />\n但台灣既大城市發展同市容似足80 90年代,非大城市好撚似70年代<br />\n治安同乾淨程度又唔係日本果皮<br />\n大家人工都係走唔到出去,我就寧願揀日本,就算同歐洲比,日本都先進過大部分歐洲國家,舊既野又識maintenance,邊似得台灣由佢融融爛爛"},"citedBy":2,"replyTime":"2018-05-30T05:32:16.000Z","msg":"喺台中<br />\n唔睇人工，覺得ok wor<br />\n市容好兩極<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 靚起嚟可以比香港好，尤其綠化方面<br />\n同埋乾淨過香港，環保意識亦比香港人好<br />\n不過當然唔