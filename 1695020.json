s/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-05T11:47:35.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"4dcbd23f2a8429577754d9781a980327ea76d8cc","tid":1695020,"uid":30647,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T11:51:24.000Z","msg":"推, <br />\n呢D 資料好緊要, 一定要 追究班狗阻礙"},{"pid":"80224b4409de2af34471bb09e89be6953bb10425","tid":1695020,"uid":56381,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T11:51:42.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"80cf15d84c3fd65bf83f9b48fc4f302c0011b9f7","tid":1695020,"uid":19178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T11:52:26.000Z","msg":"推"},{"pid":"0a1b81bf8926b27f2cfac2293f219f00c45eb7af","tid":1695020,"uid":309045,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T11:52:29.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"536c9d57815f554044b2943a6c64b713d93a5b6f","tid":1695020,"uid":158438,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T11:52:37.000Z","msg":"推<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"5821d701a485c9b7c579487ab55a8a9be4a3bf28","tid":1695020,"uid":333470,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T12:00:01.000Z","msg":"推"},{"pid":"cd4fb7a5b13d6ce572d282b6cdf0f9611c6146e6","tid":1695020,"uid":40250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T12:13:04.000Z","msg":"有無人去過停車埸現埸，睇下有無邊枝cam影住3樓個位？"},{"pid":"4f2081c47ce3507e0a17360ef88673c30b7d8f8f","tid":1695020,"uid":56381,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T16:09:42.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"d90f8c1e0fc830e7081c03eba7ce9ee00cd4f85b","tid":1695020,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T16:10:47.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"f1aef1f749bc089922f1dac52368378bf2fde192","tid":1695020,"uid":165840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T16:13:03.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b11716d65fc813368401f6d43ede26b929b730a0","tid":1695020,"uid":332608,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T16:13:44.000Z","msg":"毋忘義士獻身、不屈氣概！<br />\n<br />\n致眾義士：《不屈進行曲》試續新詞&mdash;危牆無完卵、威武不能屈<br />\n<a href=\"https://lihkg.com/thread/1686517/\" target=\"_blank\">https://lihkg.com/thread/1686517/</a><br />\n<br />\n光復香港 時代革命<br />\n五大訴求 缺一不可"},{"pid":"79a8ccc27292d188ccbbc74ab96c54310fb767e9","tid":1695020,"uid":270778,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T16:49:31.000Z","msg":"根本就係黑警想謀殺<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"}]}