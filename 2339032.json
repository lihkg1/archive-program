2-24T11:41:44.000Z","msg":"咩名堂<img src=\"/assets/faces/lm2xm/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-24T12:24:54.000Z","msg":"呢把叫kukri, 通常叫啹咯刀，係尼泊爾傳統武器，因啹咯兵用要聞名，據說要軍隊畢業先會派發。<br />\n<br />\n本身係一行山刀，刀厚重心近刀刃，適合砍木；刀刃斬長，適合斬荊棘開路；單手大小，所以生活、煮食都可以，雖然唔係最適合砍木，唔係最適合斬荊棘，唔係最適合生活，唔係最適合對人，但行軍時一把氾用途刀，方便又減輕負重，非常方便。<br />\n<br />\n傳說福克蘭戰役中，阿根廷軍一見到啹咯兵就會逃走。"},{"pid":"531554ee0ff9eaa869f27be1eb6f74f3a6fe2cc8","tid":2339032,"uid":215794,"like":0,"dislike":8,"score":-8,"quote":{"pid":"75d42766e7d001b249a8dadd6fcf6a4b0c933862","tid":2339032,"uid":67500,"like":0,"dislike":8,"score":-8,"quote":{"pid":"f862cebcb5cb1f2a609c3fddcd85ae8f8aa4ee42","tid":2339032,"uid":371558,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2020-12-24T10:59:59.000Z","msg":"此回覆已被刪除"},"citedBy":3,"replyTime":"2020-12-24T11:41:44.000Z","msg":"咩名堂<img src=\"/assets/faces/lm2xm/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-24T12:26:30.000Z","msg":"Machete"},{"pid":"4f41f684d065b948d9ed027985173d1b4673e870","tid":2339032,"uid":215794,"like":3,"dislike":0,"score":3,"quote":{"pid":"13837f10711d7c1bfbac97dfe6ae30958b8ac559","tid":2339032,"uid":312758,"like":13,"dislike":0,"score":13,"citedBy":2,"replyTime":"2020-12-24T12:13:26.000Z","msg":"騎槍<br />\n<img src=\"https://na.cx/i/DVzNzNg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDVzNzNg.jpg&h=c3921b84&s={SIZE}\" /><br />\n標準貴族兵器<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-24T12:28:43.000Z","msg":"好似要用好多材料同好重"},{"pid":"f303eb009e7e2a746965783604f47ce8ce04205d","tid":2339032,"uid":63426,"like":10,"dislike":3,"score":7,"citedBy":0,"replyTime":"2020-12-24T12:28:47.000Z","msg":"<img src=\"https://na.cx/i/ajo6QqJ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fajo6QqJ.jpg&h=e38af01c&s={SIZE}\" /><br />\n伊斯蘭彎刀"},{"pid":"e40e54727d215ac986b3e8ef4e4f01e7c5968315","tid":2339032,"uid":40,"like":1,"dis