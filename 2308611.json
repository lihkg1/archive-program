/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"4b506b2999e8948595699a69aca6bc628d64ff16","tid":2308611,"uid":340081,"like":0,"dislike":0,"score":0,"quote":{"pid":"364e33ad4e70f582be0e5c53b9cad009c1197dc8","tid":2308611,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-02T04:27:22.000Z","msg":"<a href=\"https://t.me/youarenotalonehk_info/4518\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fyouarenotalonehk_info%2F4518&d=TN93oS71akEChVkkxtef2dey%2FoW3U1ZMpR7BmJTbZh4%3D&h=8fb12c36\" data-auto-link target=\"_blank\">https://t.me/youarenotalonehk_info/4518</a><br />\n<br />\n譚得志案件 控方申請交國安法指定法官處理<br />\n<br />\n【Now新聞台】人民力量譚得志被控發表煽動文字等14項控罪，區域法院處理控方申請，要求將案件交由國安法指定法官處理 。<br />\n<br />\n控方指，國安法第44條強制要求危害國家安全的案件要由指定法官審理，若由非指定法官審理，其所作的裁決或決定屬越權，亦有機會被司法覆核；又指，指定法官本身可審理非涉及國家安全的案件，不認為對被告造成任何不公。<br />\n<br />\n辯方指，國安法下並非要設立一個新法庭，所有裁判官或法官的司法管轄權並無改變。若一名非指定法官亦有能力去處理涉及國安法的案件，其所作決定不會被司法覆核。<br />\n<br />\n<strong><span class=\"red\">區域法院決定交由國安法指定法官，決定案件是否涉國安法，要由指定法官審理。</span></strong>（全文 (<a href=\"https://news.now.com/mobile/local/player?newsId=415052\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.now.com%2Fmobile%2Flocal%2Fplayer%3FnewsId%3D415052&d=TN93oS71akEChVkkxtef2dey%2FoW3U1ZMpR7BmJTbZh4%3D&h=cd1d07ab\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.now.com%2Fmobile%2Flocal%2Fplayer%3FnewsId%3D415052&h=e13aed13\" data-auto-link target=\"_blank\">https://news.now.com/mobile/local/player?newsId=415052</a>)）<br />\n<br />\n#20201202新聞"},"citedBy":0,"replyTime":"2020-12-02T05:19:15.000Z","msg":"你愈禁聲<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"183af796399758e310122164528c6c9daf01ef51","tid":2308611,"uid":52228,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-02T05:20:24.000Z","msg":"唔係告國安法都可以咁<br />\n痴撚線"},{"pid":"72ffa43b83c4c76f29fdfa0dc223cd3d64106b23","tid":2308611,"uid":255162,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-02T05:21:24.000Z","msg"