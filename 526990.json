e%2Fdaily%2Farticle%2F20180111%2F20271313&d=aeR6LJvgMoWyvzS47HCOyS7PofNJLCAwyGXsi6MH%2FEQ%3D&h=a7452857\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.finance.appledaily.com%2Ffinance%2Fdaily%2Farticle%2F20180111%2F20271313&h=230a15fd\" target=\"_blank\">https://hk.finance.appledaily.com/finance/daily/article/20180111/20271313</a>"},"citedBy":1,"replyTime":"2018-01-12T08:53:52.000Z","msg":"都其一一種支付方式，吾同情况用吾同支付方法，好正常既事，我又吾會好似你甘因為支付寶係中國既就抹黑佢啦"},"citedBy":1,"replyTime":"2018-01-12T08:59:36.000Z","msg":"吾你老味<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n甘你老味<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-12T09:02:10.000Z","msg":"有無d有意義d既回覆？"},{"pid":"58262c534cd653466374b81feb0835e6b15fae91","tid":526990,"uid":1159,"like":1,"dislike":2,"score":-1,"quote":{"pid":"ebb6bf7e6daec532d5d155544e8684ebee4f8686","tid":526990,"uid":47359,"like":25,"dislike":4,"score":21,"citedBy":1,"replyTime":"2018-01-12T08:10:19.000Z","msg":"<span style=\"font-size: xx-large;\">QR code打手list<br />\n1 D wade<br />\n2 姐打羅夫<br />\n3 群龍共舞<br />\n4 上坂堇<br />\n5 人生鍾嘉欣<br />\n6 賈雨村</span>"},"citedBy":0,"replyTime":"2018-01-12T09:06:02.000Z","msg":"<span style=\"font-size: xx-large;\">關囝以為ig入面有QR code payment 功能添啦</span><img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <br />\n<br />\n<span style=\"font-size: xx-large;\">唔知QR code 點玩法就話人打手</span><img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"05779896e54eb9733968131cf6123ea14d3c314f","tid":526990,"uid":166438,"like":0,"dislike":8,"score":-8,"quote":{"pid":"c35e173e701842109d47185b40bb70f9592bc592","tid":526990,"uid":22114,"like":0,"dislike":8,"score":-8,"citedBy":2,"replyTime":"2018-01-12T08:43:37.000Z","msg":"其實大陸人出信用卡好易 有二代身份證基本就批<br />\n果個公關友應該係香港人所以申請唔到 <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <br />\n<br />\n利申：我都申請唔到"},"citedBy":1,"replyTime":"2018-01-12T09:09:08.000Z","msg":"係好易，我見d人一大堆，大陸，一般信用卡好似都無