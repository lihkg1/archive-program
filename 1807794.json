c56289164cc050","tid":1807794,"uid":241543,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T04:57:09.000Z","msg":"講得好"},{"pid":"2786e40403e3b05cc10d7b60124837494cd0a626","tid":1807794,"uid":69395,"like":0,"dislike":0,"score":0,"quote":{"pid":"dacf1ebfff6c5b7ee3aa2d683b57742ed1487853","tid":1807794,"uid":5649,"like":7,"dislike":0,"score":7,"citedBy":3,"replyTime":"2020-01-02T04:27:53.000Z","msg":"你唔會見到有狗著住軍裝搭車返屋企<br />\n佢地一定換左裝先<br />\n手足醒水啦"},"citedBy":0,"replyTime":"2020-01-02T04:59:58.000Z","msg":"我真心笑咗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"838376770295ad32a441ffec8823c8e3a3fae709","tid":1807794,"uid":69395,"like":0,"dislike":0,"score":0,"quote":{"pid":"0d52c917f1b118209054af30908b7d978363d3ad","tid":1807794,"uid":274722,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-01-02T04:35:11.000Z","msg":"變裝地方難搵呢<img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-02T05:02:15.000Z","msg":"所以唔好遲到啦<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"12ab4284feccb5113da533ae506f6201e086c844","tid":1807794,"uid":188035,"like":0,"dislike":0,"score":0,"quote":{"pid":"b31b81127e31c09ea71085ba56f64a3dd1facc0c","tid":1807794,"uid":69395,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-02T04:03:06.000Z","msg":"(尋日搭車嗰陣見到唔少手足black bloc上車去港島，有感而發)<br />\n以下有幾點想講，<strong><span style=\"color: red;\">主要係想提醒各位和理非，尤其係負擔唔起被捕嗰啲手足。</span></strong><br />\n<br />\n<span style=\"font-size: large;\"><strong>1. 幾時black bloc，幾時做平民？</strong></span><br />\n遊行集會要black bloc保護自己同身邊手足嘅身分，呢點我相信已經係常識，在此不贅。<br />\n但係咁唔代表你要black bloc出門口、搭車、離場呀大佬......<br />\n<br />\n<strong><span style=\"color: red;\">請緊記，一日未到目的地附近，一日都唔好black bloc住。<br />\n出門搭車時平民look，離場後盡量平民look。<br />\n融入環境，切忌做人群中顯眼嗰個。<br />\n唔係話咁做會絕對冇事，只係盡量減低你無故被咬嘅機會。</span></strong><br />\n<br />\n搭一架出老銅嘅車可以有好多原因，行街睇戲食飯又得，你搭去中環北角落車都得，車上唔會有人知。但係你black bloc咁搭同一架車，係人都知你去發夢啦。誇張少少講句，難保車上/巴士站有隻便衣狗，甚至係藍絲痴線佬吊住你尾喎係咪先。<br />\n<br />\n離場亦然，最好上車前做返平民，因為最危險嘅位置就係示威現場同附近一帶，咁做可以減低喺示威地區同屋企附近落單被咬嘅機會。打個比喻，假設你係綠狗，喺示威地點附近見到一個black bloc人士同一個平民，你會咬邊個先？<br />\n<br />\n下面呢啲應該大部分人都知，我順便講埋。<br />\n<br />\n<strong><span style=\"font-size: large;\">2. 我要落場啦，喺邊度變身好呢？</span></strong><br />\n當然要喺附近搵一啲冇CCTV嘅地方啦，例如後巷、公園等等。個人麻麻哋去廁所換，尤其商場廁所，因為出入口多數有cam。好耐之前有張示意圖好正，我再post多次畀大家睇睇：<br />\n<img src=\"https://na.cx/i/Ke0ETeo.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKe0ETeo.jpg&h=5415c2ee&s={SIZE}\" /><br />\n記住細心望清楚有冇CCTV先好變身 (最好就有同伴幫手睇水啦)，如果唔係變咗都冇咩意思，一樣track到你。<br />\n<br />\n<strong><span style=\"font-size: large;\">3. 點先係black bloc？</span></strong><br />\n標準答案：全身黑色<br />\n做唔到唔緊要，起碼要有：<br />\n黑衫黑褲 (冬天強烈推介風褸，有頭笠更佳，勁方便) <br />\n覆蓋頭部所有特徵 (黑超遮眼、黑cap遮頭髮及cam、頭笠+口罩/面巾遮口耳鼻)<br />\n最好有埋黑鞋黑背囊，有多一套用作離場更佳 (可能有手足經濟所限，明白的)<br />\n<strong><span style=\"color: red;\">記住，要保護到自己身分，先可以發揮black bloc保護其他手足嘅用途！</span></strong><br />\n<br />\n<strong><span style=\"color: red;\">正確示範：</span></strong><br />\n<img src=\"https://na.cx/i/GHSzHpO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FGHSzHpO.jpg&h=4c5f7d64&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/vxtOMRv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FvxtOMRv.jpg&h=98c7c997&s={SIZE}\" /><br />\n<br />\n<strong><span style=\"color: red;\">錯誤示範：</span></strong><br />\n<img src=\"https://na.cx/i/fpWD88n.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfpWD88n.jpg&h=9e8bc7a2&s={SIZE}\" /><br />\n<br />\n希望所有和理非以後發夢都要black bloc，越多人咁做先可以將black bloc嘅作用變得最大。保護他人之前，先保護好自己。小心駛得萬年船，冇事先做到世界冠軍！<br />\n<br />\n最後我喺度擺低一啲有用嘅posts，有興趣不妨睇睇：<br />\na. Black Bloc教學：<br />\n<a href=\"https://lih.kg/dgakqS\" data-auto-link target=\"_blank\">https://lih.kg/dgakqS</a><br />\n<a href=\"https://lih.kg/1309156\" data-auto-link target=\"_blank\">https://lih.kg/1309156</a><br />\nb. 點解要black bloc：<br />\n<a href=\"https://lih.kg/1295638\" data-auto-link target=\"_blank\">https://lih.kg/1295638</a><br />\nc. 變身及隱藏身分教學：<br />\n<a href=\"https://lih.kg/1379149\" data-auto-link target=\"_blank\">https://lih.kg/1379149</a><br />\n<a href=\"https://lih.kg/1327279\" data-auto-link target=\"_blank\">https://lih.kg/1327279</a>"},"citedBy":0,"replyTime":"2020-01-02T05:04:43.000Z","msg":"Push"},{"pid":"561d1a183bd0e2f2fd3f9175b191da029cc25ddc","tid":1807794,"uid":66202,"like":0,"dislike":0,"score":0,"quote":{"pid":"db135ed3c6d8dca3f308ed84186b21548b2a2c8b","tid":1807794,"uid":314509,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-02T04:29:16.000Z","msg":"變咗身之後 見幾個人拎住長遮都知係手足<br />\n但呢點無得避免<br />\n<img src=\"/assets/faces/pigxm/arrested.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-02T05:12:02.000Z","msg":"和理非幫收回收物資<img src=\"/assets/faces/lm2xm/adore.gif\" class=\"hkgmoji\" />"},{"pid":"4e2f1992902035a75044b5e3e128014ead6acc95","tid":1807794,"uid":56945,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T05:20:41.000Z","msg":"推"},{"pid":"2c1f78194e40bf6a6081c06c5e756f20930e922e","tid":1807794,"uid":117509,"like":0,"dislike":0,"score":0,"quote":{"pid":"0d52c917f1b118209054af30908b7d978363d3ad","tid":1807794,"uid":274722,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-01-02T04:35:11.000Z","msg":"變裝地方難搵呢<img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-02T05:27:42.000Z","msg":"去冇CCTV既位置(樓梯、後巷）<br />\n出入口搵人睇水"},{"pid":"eb320958a4de0288a4e14759f0c4437249995dcf","tid":1807794,"uid":269578,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-02T05:34:08.000Z","msg":"7個月啦...<img src=\"/assets/faces/pigxm/angry.gif\" class=\"hkgmoji\" />"},{"pid":"81b379b3748d29b400ea484497e07ae67cdc1d2d","tid":1807794,"uid":107663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T06:34:17.000Z","msg":"<img src=\"/assets/faces/pigxm/peanut.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/cook.gif\" class=\"hkgmoji\" />"},{"pid":"3c0251bed4b6feddaa68bd38021ac02b9ff4ffa4","tid":1807794,"uid":5649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T06:35:47.000Z","msg":"推下拉"},{"pid":"15d1e7ef8f7a6eafa45abc3030ae5c1c63f6209d","tid":1807794,"uid":154872,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T06:36:36.000Z","msg":"樓主好好球！"},{"pid":"bff3ec216dfcce9e80407c75f8ecd23b140fb2aa","tid":1807794,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T06:42:49.000Z","msg":"<img src=\"/assets/faces/pigxm/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5001db8971756fdc36defb616ac0c84bf8c89a6d","tid":1807794,"uid":258611,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T06:54:15.000Z","msg":"推"},{"pid":"6237cc931ec36e2e31bae14b8382f555424a3c09","tid":1807794,"uid":212119,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T08:04:26.000Z","msg":"<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" />"},{"pid":"0477c1c7986a4c1d20342f7a88cb317aabbc6517","tid":1807794,"uid":136116,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-01-02T08:13:21.000Z","msg":"分化 拉"},{"pid":"38b87ac0d23283e3b348aa078e2168083ae3fda8","tid":1807794,"uid":53870,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T08:15:13.000Z","msg":"<img src=\"/assets/faces/pigxm/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/cook.gif\" class=\"hkgmoji\" />"},{"pid":"6c2f0f909aab282f3a347fd8ac997642c1bd3b25","tid":1807794,"uid":60658,"like":0,"dislike":0,"score":0,"quote":{"pid":"0477c1c7986a4c1d20342f7a88cb317aabbc6517","tid":1807794,"uid":136116,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-01-02T08:13:21.000Z","msg":"分化 拉"},"citedBy":0,"replyTime":"2020-01-02T09:37:24.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"23d56a2cfc5d381