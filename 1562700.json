rc=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"bad3a397b684c03ba7a9cdf5711960f85413b446","tid":1562700,"uid":254860,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T07:07:33.000Z","msg":"翻譯俾外國睇，等外國了解多啲港共<br />\n<br />\n721<br />\n811<br />\n831"},{"pid":"5881efa1e7b0943d5684245bee5f3b913e856afc","tid":1562700,"uid":185022,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T07:08:34.000Z","msg":"咁中國政府呢<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"37c1e72452e8cb7a4fe283b6cae74ffbcb6a0ed2","tid":1562700,"uid":66810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T07:08:45.000Z","msg":"係咪可以叫埋中共收聲"},{"pid":"264c4f938970a6839d04561d2bf8a74dd44300a3","tid":1562700,"uid":12720,"like":0,"dislike":0,"score":0,"quote":{"pid":"ebb21e31ad838d85ad3d910c9934602ec6486a08","tid":1562700,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-12T06:19:07.000Z","msg":"美國國會將審議《香港人權及民主法案》，提出根據香港實施一國兩制的情況，審視美國給予香港的特殊待遇。商務及經濟發展局局長邱騰華表示，<span style=\"color: red;\">香港經貿地位由《基本法》賦予，包括獨立關稅區地位，並非任何國家單方面施予，個別國家不會影響香港的經貿地位</span>。<br />\n<br />\n邱騰華說，不評論美國方面的工作，指美國對本港的待遇，反映美國在港利益，認為香港做好一國兩制的工作，<span style=\"color: red;\">不需要其他政府給予意見</span>，相信其他政府的香港政策，首要基於有關他們自身利益。<br />\n<br />\n他表示，在本港舉行的第四屆一帶一路高峰論壇，吸引5000名來自60個國家的政商代表參與，認為論壇成功舉行，反映國際正面回應本港於一帶一路的角色。他又指，香港近期的展覽或國際會議均如期舉行，基本上參展者數字與去年相若，參加者則略為減少。<br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1480187-20190912.htm?spTabChangeable=0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1480187-20190912.htm%3FspTabChangeable%3D0&d=duP9xtlDTMOxgFFwFRXy%2FW6H7LaHGbUBdoVXdg05ZHE%3D&h=1e57e9f6\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1480187-20190912.htm%3FspTabChangeable%3D0&h=1c0b8d55\" target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1480187-20190912.htm?spTabChangeable=0</a>"},"citedBy":0,"replyTime":"2019-09-12T07:09:14.000Z","msg":"好大個官威<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5760a5e05fadee24aa028a50ae803c81e5197efb","tid":1562700,"uid":213812,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T07:09:48.000Z","msg":"咁大反應嘅，驚驚豬？"},{"pid":"eb4bbea0f6cad2c44c7bf390c61ed7ef9dd1b916","tid":1562700,"uid":171058,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T07:09:54.000Z","msg":"<span style=\"font-size: x-large;\">有請翻譯組!</span>"},{"pid":"c2cec4942fd24e2ed8217d3f57011809151d2b6a","tid":1562700,"uid":92433,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T07:09:57.000Z","msg":"成個政府班底都係咁撚柒<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"ef288356b482e4078b38b69e37dda5b6e8e4e087","tid":1562700,"uid":48315,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T07:09:59.000Z","msg":"係咪想封港 講咪得"},{"pid":"827b988c9d8e80a6ca007d0c989852a2a0283d87","tid":1562700,"uid":256503,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T07:10:48.000Z","msg":"係咪想駁提名<img src=\"/assets/faces/mf/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"198a129613daf256c11d5396b5ab94b0aff0bc50","tid":1562700,"uid":276293,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T07:11:13.000Z","msg":"香港做好一國兩制的工作<br />\n就係做唔好囉 屌！"},{"pid":"046cda4b2a49befae26524eb9609c4d361b534d8","tid":1562700,"uid":283449,"like":0,"dislike":0,