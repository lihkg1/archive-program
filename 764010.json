rc=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-02T00:56:18.000Z","msg":"工時唔第一，老闆那有錢買樓租畀你地香港人繼續幫我搵錢買樓呀"},{"pid":"ccb7cc6ea1156b4ac7a54dc1cd87ac686eda6236","tid":764010,"uid":22535,"like":0,"dislike":0,"score":0,"quote":{"pid":"d380c1788d7fed6bf00d985988683fbd5964f823","tid":764010,"uid":39200,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-02T00:45:14.000Z","msg":"香港核爆都升"},"citedBy":0,"replyTime":"2018-08-02T00:57:14.000Z","msg":"大亞灣<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"95d546a4b8fb611f3bfce626e6138779c540f54c","tid":764010,"uid":47202,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-08-02T00:57:17.000Z","msg":"應該要跌啦，升左咁多年"}]}