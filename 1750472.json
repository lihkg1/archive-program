ets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"b687943fc933317facc12733a6185def21d697e6","tid":1750472,"uid":82540,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T12:33:59.000Z","msg":"自推"},{"pid":"e9b331afb71ba2582f6cfbef20ad28d0a73f28fa","tid":1750472,"uid":82540,"like":1,"dislike":0,"score":1,"quote":{"pid":"c7ef288502e64c43a0b3e09e0120fe39ade9e170","tid":1750472,"uid":208817,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-11-24T12:14:40.000Z","msg":"但係要通宵？"},"citedBy":0,"replyTime":"2019-11-24T12:34:31.000Z","msg":"通宵算係咩<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"98537bc6bed8e28a868dc3c5ad671abb3c64eb95","tid":1750472,"uid":82540,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T12:37:18.000Z","msg":"再推"},{"pid":"4eecb5907a6958ea36af34b2251aa458dbbc0f91","tid":1750472,"uid":321999,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T12:47:23.000Z","msg":"推"},{"pid":"17c7df9b8fd6c4f7e62830f0b6cb1a96f9a3a380","tid":1750472,"uid":307619,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T12:51:30.000Z","msg":"【區議會選舉2015】真實案例<br />\n<br />\n<ins>第一單</ins><br />\n耀安選區初步點票出現大量問題票<br />\n沙田區耀安選區，經初步點票後出現高達757張問題票。據現場消息指，<span style=\"color: red;\">有不少選票上蓋印與一般剔號印章的形狀有異，懷疑印章出現問題</span>。<br />\n<br />\n<ins>另一單</ins><br />\n2015年馬鞍山頌安陳震夏中學點票站，發生遺失選票箱鎖匙事件。凌晨零時，該點票站原定對4個票箱進行點票程序，<span style=\"color: red;\">惟發現其中一個票箱的鎖匙遺失了</span>，票箱打不開，票站主任向上級請示，獲律政司指示可以用工具將鎖頭撬開，職員決定用鐵鎚將票箱鎖頭鑿開，並會<span style=\"color: red;\">連同其餘選票一併點算</span>。<br />\n<br />\n<ins>再另一單</ins><br />\n2015年石籬南選區點票出錯，多出一千張選票，足以左右選舉結果。<br />\n<br />\n葵青石籬南選區候選人梁國華表示，<span style=\"color: red;\">點票前選舉主任公佈當日全日累積有7182張選票，惟封箱之後，票站工作人員發現實際票站全日只發出6182張選票</span>，估計每一個投票時段的票數皆有錯漏，造成累積選票誤報1000張選票。<span style=\"color: red;\">梁國華表示當時向票站主任要求封箱</span>，將發出的選票與石籬南的選民登記名冊作比對，並延請選舉委員會及候選人的法律顧問核實結果。<span style=\"color: red;\">惟票站主任拒絕</span>，稱此做法為程序之外。<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: x-large;\">所以大家一定要去監票！！！</span></span>"},{"pid":"30166cd3de1f345bfab04eeaf535906979631b73","tid":1750472,"uid":82540,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T12:57:50.000Z","msg":"三推<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"82f4e0467dd7822887314a3b57c624c0e6fab8bd","tid":1750472,"uid":112748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T12:58:10.000Z","msg":"推！"},{"pid":"dadb8a79ea1705461c030bb529176bbeb164d7e1","tid":1750472,"uid":120978,"like":0,"dislike":0,"score":0,"quote":{"pid":"6b33b3b36ed086740d0a97535d803210be5b5c16","tid":1750472,"uid":82540,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-11-24T11:58:05.000Z","msg":"各位10:30pm 後要去監票<br />\n<br />\n一定要去<br />\n<br />\n曾經試過無啦啦多咗一個票箱<br />\n<br />\n令到民建聯贏左<br />\n<br />\nP.S. 大家記得ready 手機電筒<br />\n<br />\n<img src=\"https://na.cx/i/k6Txynd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fk6Txynd.jpg&h=8007ba0e&s={SIZE}\" />"},"citedBy":0,"replyTime":