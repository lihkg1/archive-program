sets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"4e8802c7ba08364067803a6fbbe4d978a078b288","tid":1456533,"uid":123713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T10:30:50.000Z","msg":"叫人走啊！"},{"pid":"8df0a52a3b8be1afe502e61cd77cbac75cb791b6","tid":1456533,"uid":123713,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-08-12T10:31:28.000Z","msg":"1.成個機場都係狗同防暴<br />\n2.機管局被逼停飛所有航班<br />\n3.好可能旅客清晒就會封場<br />\n4.仲要機場冇路走 一封出東涌條橋就收皮！<br />\n5.今日入得機場既 全部都係追post追得最貼既深黃 唔好犧牲啊！"},{"pid":"4a0dca72f6dfbffefdcda7c0a7335bd4a2225da8","tid":1456533,"uid":299008,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T10:32:09.000Z","msg":"我知大家都唔係鬼<br />\n但係今晚真係不宜久留<br />\n唔好話多元聲音就係鬼<br />\n班狗而家癲撚左唔好同佢哋夾硬嚟"},{"pid":"984c230d0c1413156e9ffbbb5dd051d07c797a75","tid":1456533,"uid":49246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T10:49:58.000Z","msg":"大家留係度都有衡量風險<br />\n現場check in counter仲有部份遊客係度 <br />\n如果黑警真係照入黎清場 到時畫面會好震撼"},{"pid":"7e0288c6e8ff62f86fe60cfb26ac31b6059bbf38","tid":1456533,"uid":49246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T10:50:08.000Z","msg":"幫手推呀"},{"pid":"ab3191a0985ec4132b475d1219185c15b21d9301","tid":1456533,"uid":49246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T10:50:59.000Z","msg":"努力推"}]}