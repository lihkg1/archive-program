003,"uid":34334,"like":0,"dislike":0,"score":0,"quote":{"pid":"8be0089b489d07232fedc58919b9253c228b0f7d","tid":1618003,"uid":2429,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-04T05:23:56.000Z","msg":"做好思想滲透工作先。<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-10-04T05:32:56.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-10-04T06:10:48.000Z","msg":"鍵盤都唔做唔通發夢會上山打遊擊？<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-04T06:34:10.000Z","msg":"劉用過一個比喻，蜜糖流過嘅地方自然會有蟻岀現<br />\n<br />\n正如上一個post#186所講，需要大義名份嘅，係強力部門大佬，唔係普通民運<br />\n做好自己可以做嘅事就ok"},{"pid":"f16ef3759aa63644a0026fd82f4f0a0a5b338335","tid":1618003,"uid":74155,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T06:34:32.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">兵貴神速 今晚就要先聲奪人！</span></span>"},{"pid":"523457878fb273ab383f4871466cfca5bd19e766","tid":1618003,"uid":164263,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T10:04:26.000Z","msg":"留名"},{"pid":"573b516ab392bf0f42a228478f15096366f1bb66","tid":1618003,"uid":66784,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T10:59:12.000Z","msg":"Push"},{"pid":"05c664ec243f8502a987e69369216f4972761be9","tid":1618003,"uid":250951,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T11:03:26.000Z","msg":"睇唔明&hellip;&hellip;"},{"pid":"24504e7c5907918412810b527813f14bbd4bbfbc","tid":1618003,"uid":66784,"like":0,"dislike":0,"score":0,"quote":{"pid":"05c664ec243f8502a987e69369216f4972761be9","tid":1618003,"uid":250951,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T11:03:26.000Z","msg":"睇唔明&hellip;&hellip;"},"citedBy":1,"replyTime":"2019-10-06T11:18:05.000Z","msg":"佢文筆係比較隱晦，巴打有咩唔明？我嘗試解比你聽"},{"pid":"91f6763d90d54f93e6688ebf3df843baa60dd452","tid":1618003,"uid":250951,"like":0,"dislike":0,"score":0,"quote":{"pid":"24504e7c5907918412810b527813f14bbd4bbfbc","tid":1618003,"uid":66784,"like":0,"dislike":0,"score":0,"quote":{"pid":"05c664ec243f8502a987e69369216f4972761be9","tid":1618003,"uid":250951,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T11:03:26.000Z","msg":"睇唔明&hellip;&hellip;"},"citedBy":1,"replyTime":"2019-10-06T11:18:05.000Z","msg":"佢文筆係比較隱晦，巴打有咩唔明？我嘗試解比你聽"},"citedBy":1,"replyTime":"2019-10-06T11:25:53.000Z","msg":"第二段已經開始唔明"},{"pid":"dfadd0b9fd0feb94551133f056ba7779a9f61e8b","tid":1618003,"uid":66784,"like":1,"dislike":0,"score":1,"quote":{"pid":"91f6763d90d54f93e6688ebf3df843baa60dd452","tid":1618003,"uid":250951,"like":0,"dislike":0,"score":0,"quote":{"pid":"24504e7c5907918412810b527813f14bbd4bbfbc","tid":1618003,"uid":66784,"like":0,"dislike":0,"score":0,"quote":{"pid":"05c664ec243f8502a987e69369216f4972761be9","tid":1618003,"uid":250951,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T11:03:26.000Z","msg":"睇唔明&hellip;&hellip;"},"citedBy":1,"replyTime":"2019-10-06T11:18:05.000Z","msg":"佢文筆係比較隱晦，巴打有咩唔明？我嘗試解比你聽"},"citedBy":1,"replyTime":"2019-10-06T11:25:53.000Z","msg":"第二段已經開始唔明"},"citedBy":0,"replyTime":"2019-10-06T11:56:45.000Z","msg":"第二段指，只有滇粵陷入混亂，香港先會安全，但呢個安全係需要武力維持。<br />\n香港已經排除最差嘅情況(布拉格1948)，姐係溫水煮蛙成功。但布達佩斯1956仍然有可能發生，姐係西方國家願意接收香港難民，但唔會軍事介入，中國鎮壓成功。<br />\n<br />\n香港人要敢於對親中派使用武力(貝魯特1982)，再進一步就係香港1925，姐係自發產生正規團體維持秩序(我喺之前個post #87- #91 簡介過香港同上海20世紀初嘅不同，可以睇下)<br />\n<a href=\"https://lih.kg/afAGOeV\" target=\"_blank\">https://lih.kg/afAGOeV</a><br />\n<br />\n後兩段係講中國主義嘅敗亡"},{"pid":"f68daf92e6d8d6ad7b4f6b3a63d169dcb9d8130a","tid":1618003,"uid":66784,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T02:39:37.000Z","msg":"Push"},{"pid":"7afa69fb81255ba2c5576bba2d93efb246c53277","tid":1618003,"uid":74355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T11:43:51.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}