data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Ftz4v2mX.gif&h=09555a22&s={SIZE}\" />"},{"pid":"b297e7b48d23c85748ac24ce2644703e79f55fa3","tid":2124800,"uid":270889,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c0830459c2442c6de2c4af8ae7244e8f6f316ec","tid":2124800,"uid":65747,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2020-07-25T16:16:59.000Z","msg":"<img src=\"https://na.cx/i/tz4v2mX.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Ftz4v2mX.gif&h=09555a22&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-07-25T16:17:42.000Z","msg":"CLS <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"0355b5e96431c89af54561ef42b983461699111b","tid":2124800,"uid":173002,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-25T16:23:36.000Z","msg":"God save our gracious Queen, Frustrate their knavish tricks.  <img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"0042b3cf247a4f46b488ce10b3da57fff89605ba","tid":2124800,"uid":31215,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-25T16:25:26.000Z","msg":"有個中國專家好似話一定唔會禁華為<br />\n而家禁到咁盡<br />\n匯豐有冇好驚"},{"pid":"57b3255b497daab594b6b540c65409087dbc98d1","tid":2124800,"uid":25468,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0042b3cf247a4f46b488ce10b3da57fff89605ba","tid":2124800,"uid":31215,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-25T16:25:26.000Z","msg":"有個中國專家好似話一定唔會禁華為<br />\n而家禁到咁盡<br />\n匯豐有冇好驚"},"citedBy":0,"replyTime":"2020-07-25T16:36:07.000Z","msg":"<strong><span class=\"xx-large\">滙豐：對華為沒有惡意 不存編造證據</span></strong><br />\n<br />\n<img src=\"https://upload.cc/i1/2020/07/26/9jpbCD.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2020%2F07%2F26%2F9jpbCD.png&h=df89f452&s={SIZE}\" /><br />\n<br />\n<br />\n人民網發表評論文章，批評滙豐銀行在孟晚舟案中惡意做局、捏造罪證，滙豐銀行回應指對華為沒有惡意，不存在編造證據。<br />\n<br />\n滙豐在官方微信發文，指沒有參與美國司法部關於華為展開調查的決定，強調美國對華為的詳細調查在滙豐2016年末被捲入之前早已存在，滙豐對華為沒有惡意，也沒有「構陷」及「置陷阱誘捕」華為，集團向美國司法部提供的材料，是應官方正式要求提供，並只是提供事實性信息，沒有編造證據或隱瞞事實，也不會歪曲事實或為了自身的利益傷害任何客戶。"},{"pid":"468d875ff78046c75dd1759bba736695fa1da17f","tid":2124800,"uid":3149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-25T17:03:30.000Z","msg":"Push <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"43ab21ffed540b8596fd663cc6579043b0ac3baa","tid":2124800,"uid":356914,"like":0,"dislike":0,"score":0,"quote":{"pid":"5688891d9caaf45e42de8a763055d589335d02bb","tid":2124800,"uid":56819,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-25T16:16:27.000Z","msg":"日落國居然變到咁積極"},"citedBy":0,"replyTime":"2020-07-25T17:07:42.000Z","msg":"要改口了"}]}