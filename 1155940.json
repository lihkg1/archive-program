ke":0,"dislike":0,"score":0,"quote":{"pid":"4d51575176c5ea108f792725d78ff986fa11f944","tid":1155940,"uid":36435,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-15T15:21:39.000Z","msg":"點教"},"citedBy":1,"replyTime":"2019-05-15T15:24:04.000Z","msg":"打得少？？"},"citedBy":1,"replyTime":"2019-05-15T15:27:44.000Z","msg":"係咩 教我打 點打呀"},"citedBy":1,"replyTime":"2019-05-15T15:31:03.000Z","msg":"俾你激撚死"},{"pid":"b3e63a82d7d428fa804474fb343fa1c19a3bc013","tid":1155940,"uid":3893,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-15T15:31:32.000Z","msg":"諗起有朋友老豆<br />\n唔小心用左佢支洗閪水嚟洗頭仲話好香<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e779f09cfa7c2a83c10eaa033823bc91813a429f","tid":1155940,"uid":36435,"like":0,"dislike":0,"score":0,"quote":{"pid":"a09248ccb95d683bb83e1fc4890cad7c1cd355c1","tid":1155940,"uid":431,"like":0,"dislike":0,"score":0,"quote":{"pid":"6700208c7ed18de55e05bc859bcced25879f8bdc","tid":1155940,"uid":36435,"like":0,"dislike":0,"score":0,"quote":{"pid":"d50df09b108ff82334d7548633f8194150e620bf","tid":1155940,"uid":431,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-15T15:24:04.000Z","msg":"打得少？？"},"citedBy":1,"replyTime":"2019-05-15T15:27:44.000Z","msg":"係咩 教我打 點打呀"},"citedBy":1,"replyTime":"2019-05-15T15:31:03.000Z","msg":"俾你激撚死"},"citedBy":0,"replyTime":"2019-05-15T15:38:31.000Z","msg":"Haha教我激"},{"pid":"89d9358eb25d859b65e5d78c7414c4d81d4645a6","tid":1155940,"uid":61543,"like":2,"dislike":1,"score":1,"quote":{"pid":"27b9cfe960c5dac19aaec58d5cb59f2ad69a03a4","tid":1155940,"uid":56475,"like":0,"dislike":0,"score":0,"quote":{"pid":"76af4d4c8cac79accff925edf7f264bb03cf1575","tid":1155940,"uid":45120,"like":7,"dislike":1,"score":6,"citedBy":1,"replyTime":"2019-05-15T15:20:29.000Z","msg":"好過我男朋友用我鬚刨剃pat毛<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-15T15:26:15.000Z","msg":"剃完自摸屁眼，感覺太正"},"citedBy":0,"replyTime":"2019-05-15T15:42:45.000Z","msg":"最近我犯下了人生中最大的一個錯誤！！！！<br />\n<br />\n現在把經驗告訴大家，希望大家能從中吸取教訓！！！<br />\n<br />\n這一切都要從我拉便便的問題開始說起！！！<br />\n<br />\n不，你想錯了，實際上，我並沒有便秘！！！<br />\n<br />\n只是在技術上的排便問題而已！！<br />\n<br />\n我的肛毛太長太濃密了，每次拉便便總有一些沾在毛上面！！！<br />\n<br />\n這些殘便粘的很牢，這讓我非常不爽！！！！！！<br />\n<br />\n我必須用紙清理我的肛毛！！！<br />\n<br />\n但這是個技術活！！！<br />\n<br />\n因為看不見我的屁屁，清理肛毛的時候經常會把屁屁其他地方弄髒！！<br />\n<br />\n還有一個方法是用很多紙把整個屁囗股仔細擦一遍！！！！<br />\n<br />\n這樣做的後果是紙用得太多我家馬桶經常會被廁紙堵住！！！！<br />\n<br />\n這個問題困擾我很久！！！！！<br />\n<br />\n經過深思熟慮以後，我想到了一個好點子！！！！<br />\n<br />\n這是的屁囗股的肛毛！！！我的地盤我做主！！！！<br />\n<br />\n為什麼不把肛毛刮了呢????<br />\n<br />\n這樣我的大便不就可以流暢排放了嗎！！！！<br />\n<br />\n我腦子裡不禁浮現出金黃色的啤酒從酒桶裡潺潺流出的美麗景象！！！！！<br />\n<br />\n但後來的事實證明，這是一個非常錯誤的傻囗B想法！！！<br />\n<br />\n那天晚上，我坐在毛巾上，開始用廉價的一次性剃刀刮我的肛毛！！！！<br />\n<br />\n我要小心翼翼地把屁囗股分開，從屁囗眼到臀部，從內向外刮！！！！<br />\n<br />\n時不時的我還要用毛巾清理刀片上的毛！！！！<br />\n<br />\n還有沾在刀片上面的不明粘液！！<br />\n<br />\n漸漸的，我的屁囗股和屁溝，就像小寶寶那樣光滑細嫩了！！！<br />\n<br />\n<br />\n<br />\n終於完成了！！！我放下剃刀，開始檢查我的成果！！！！<br />\n<br />\n哦耶！！！！我整個屁囗股現在就像象牙一般光滑！！！<br />\n<br />\n感覺真是小！！清！！新！！！！<br />\n<br />\n我的煩惱再也沒有了！！！<br />\n<br />\n望著毛巾上剃下來的那堆毛，我欣慰而自豪地地笑了！！！<br />\n<br />\n但我後來才知道，這個世界上的所有事物，都有它存在的原因！！！！！<br />\n<br />\n失去以後才懂得珍惜！！！當刮掉肛毛以後！！！！我才感受到肛毛的寶貴！！！！<br />\n<br />\n刮完肛毛的第二天,是一個陽光明媚的日子！！！<br />\n<br />\n我高高興興地唱著歌兒去上學了！！！<br />\n<br />\n爬了幾個樓梯以後我開始出汗！！！然後覺得有點不對勁！！！！<br />\n<br />\n因為沒有肛毛！！！屁囗股上的汗都留到屁囗眼那裡去了！！！<br />\n<br />\n我下面都濕透了！！！！<br />\n<br />\n<br />\n<br />\n走路的時候我的兩瓣屁囗股因為汗液而滑來滑去！！！！<br />\n<br />\n本來我想去廁所弄乾，但是要上課來不及了！！！<br />\n<br />\n只能等它自然晾乾！！！！<br />\n<br />\n沒想到！！！屁囗股晾乾以後，屁囗眼附近卻留下了一層大便一樣殘留物！！<br />\n<br />\n把我的屁股都粘在一起了！！！<br />\n<br />\n最坑爹的是！！！屁囗眼開始癢了！！！<br />\n<br />\n我?！！就好像一萬隻螞蟻在屁股上爬來爬去！！！！<br />\n<br />\n我很想把手伸到褲子裡去抓我的屁股！！！！好好爽一下！！！<br />\n<br />\n但是旁邊人太多！！！我忍住了！！！！<br />\n<br />\n就這樣我一路跑回了宿舍！！！<br />\n<br />\n不幸的是，因為是跑回來的，我又開始出汗了！！！<br />\n<br />\n我的屁股又開始滑來滑去！！！<br />\n<br />\n於是！！！我脫下褲子，拿出了電風扇！！！！<br />\n<br />\n把屁股對準電風扇，準備吹乾！！！<br />\n<br />\n但是！！！當我掰開我的兩瓣屁股以後！！！<br />\n<br />\n從我的胯間！！！猛烈地散發出！！！！<br />\n<br />\n一！！股！！！惡！！！臭！！！<br />\n<br />\n味道散發得很快！！！<br />\n<br />\n附近的狗，馬上開始汪汪狂叫了！！！<br />\n<br />\n我自己最慘了！！！！<br />\n<br />\n大便的惡臭一出來，就被電風扇吹到了我的臉上！！！<br />\n<br />\n我都快吐了！！！<br />\n<br />\n更沒想到的是，掰開沒一會，我的屁股開始流湯了！！！！<br />\n<br />\n我掰著屁股吹著風扇，感受著自己大便味道的風吹拂在臉上！！<br />\n<br />\n心裡湧起了一股淡淡的悲傷！！！！<br />\n<br />\n，看來要這樣過幾個星期了！！！<br />\n<br />\n直到新的肛毛長出來為止！！！我?！！！！<br />\n<br />\n沒過多久，我又發現了肛毛另一個重要的作用！！！<br />\n<br />\n我想要放屁！！！但是放不出來！！！<br />\n<br />\n沒有肛毛以後！！！屁囗眼閉合得很緊！！！就好像真空包裝那樣！！！<br />\n<br />\n就這樣屁放不出來，在我屁股裡竄來竄去！！！<br />\n<br />\n像一隻迷了路的老鼠！！！<br />\n<br />\n更糟糕的還在後面！！<br />\n<br />\n過了幾天！！又粗又硬的肛毛茬長出來了！！！！<br />\n<br />\n想像一下你屁囗眼坐在釘板上的感覺吧！！！！<br />\n<br />\n有時候，我望著窗外沉思，為什麼我不跳下去呢！！！！！<br />\n<br />\n摔成一個肉餅也比受這樣的折磨好得多啊！！！<br />\n<br />\n所以說！！！！<br />\n<br />\n我親愛的朋友們！！！！<br />\n<br />\n千！萬！不！要！刮！肛！毛！啊"}]}