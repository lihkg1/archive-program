5:36.000Z","msg":"咁其實個日有無人係維園放氣油彈?...."},{"pid":"db5e607702d6235c16cb5b0907b4426b47892cf7","tid":1530380,"uid":39503,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T01:37:15.000Z","msg":"手足好勇<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />下次要捉實佢哋手腳唔俾佢哋攞槍"},{"pid":"86d365ca48efaed0aa9e465264e9ccbdab2d39a6","tid":1530380,"uid":160176,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T01:38:31.000Z","msg":"Push"},{"pid":"d9a8bd936b21c440d5145414f9a886c6cdda1b76","tid":1530380,"uid":51057,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-04T01:59:28.000Z","msg":"第一時間應該索帶綁手先<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"c306d0851fcbf08b50c40d8e4668b70b370fbe79","tid":1530380,"uid":37350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T02:02:51.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b89578752c43f4e2a81e5a06766b1d23e7401808","tid":1530380,"uid":23046,"like":0,"dislike":0,"score":0,"quote":{"pid":"8cae217602ebe57a67bc353a6a21eb13a45e3163","tid":1530380,"uid":164043,"like":0,"dislike":2,"score":-2,"quote":{"pid":"d1ac269cf37379384d4349974bfdefc16d2fbc36","tid":1530380,"uid":5967,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-09-04T01:01:33.000Z","msg":"放佢地走做乜撚野<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-04T01:05:36.000Z","msg":"如果係道具點算先<br />\n<br />\n一定要仔細檢查"},"citedBy":1,"replyTime":"2019-09-04T02:04:48.000Z","msg":"道具都係殺錯姐，係道具先放囉<br />\n咁係真既點算先<br />\n一早講左唔好帶氣槍airsoft玩具槍啦"}]}