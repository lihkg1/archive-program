 src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"fededcd823ed5ccf780a8cbf4835f2e4c9130ef4","tid":1297814,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-08T16:52:02.000Z","msg":"希望大家可以幫推<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"ada60f4a7f7d926f728adb7ee1968caa7694d386","tid":1297814,"uid":67332,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-08T16:52:11.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"ca8f7c303ebd36e4fec7329aa354ff4730c5c7a7","tid":1297814,"uid":35474,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-08T16:52:12.000Z","msg":"認真 我覺得場運動愈來愈失焦 明明係五大訴求 依家出面d post全部都係針黑警 針tvb <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"cd743e3aa766401a025dab58d27f99c8a5a40f41","tid":1297814,"uid":42350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-08T16:54:38.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"da7b5b2fbd94d39043dea76eb905af5e40bafd20","tid":1297814,"uid":131767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-08T16:54:38.000Z","msg":"出面話出咗去發現無人嗰啲就一定係假膠<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e9efe7d5f8abacf08e2c4a42fe1dfccaab3eaca6","tid":1297814,"uid":226955,"like":0,"dislike":0,"score":0,"quote":{"pid":"ca8f7c303ebd36e4fec7329aa354ff4730c5c7a7","tid":1297814,"uid":35474,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-08T16:52:12.000Z","msg":"認真 我覺得場運動愈來愈失焦 明明係五大訴求 依家出面d post全部都係針黑警 針tvb <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-08T16:56:02.000Z","msg":"唔緊要，只要可以keep住「5+x」訴求我諗都可以（x係指臨時增加嘅目標），例如如果要反紅媒遊行，大家亦可以keep住嗌五大目標，我地文宣方面亦要喺事前加緊宣傳<br />\n<br />\n<br />\n<br />\n<bloc