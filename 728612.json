":{"pid":"b36d0db02d8324d90556768a0ee94014c51d87c4","tid":728612,"uid":184679,"like":28,"dislike":0,"score":28,"citedBy":3,"replyTime":"2018-07-04T01:50:45.000Z","msg":"<img src=\"http://cms-bucket.nosdn.127.net/catchpic/B/B3/B34CE6A3D8DF1B3DB20D0856FAA42845.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcms-bucket.nosdn.127.net%2Fcatchpic%2FB%2FB3%2FB34CE6A3D8DF1B3DB20D0856FAA42845.png&h=b125f4f0&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-07-04T05:41:04.000Z","msg":"屌你只係相差五年 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ae17e01ef89e4c2ace4702fdc0a58814cc5a91b2","tid":728612,"uid":46947,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-04T05:46:14.000Z","msg":"學習&ldquo;謙虛&rdquo;兩隻字仲未做到，<br />\n仲要死撐想做大佬？<br />\n我話你聽，你未夠班呀！"},{"pid":"98fb8e20827245f128e1ab6fff4d4310875c262f","tid":728612,"uid":30169,"like":0,"dislike":0,"score":0,"quote":{"pid":"b36d0db02d8324d90556768a0ee94014c51d87c4","tid":728612,"uid":184679,"like":28,"dislike":0,"score":28,"citedBy":3,"replyTime":"2018-07-04T01:50:45.000Z","msg":"<img src=\"http://cms-bucket.nosdn.127.net/catchpic/B/B3/B34CE6A3D8DF1B3DB20D0856FAA42845.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcms-bucket.nosdn.127.net%2Fcatchpic%2FB%2FB3%2FB34CE6A3D8DF1B3DB20D0856FAA42845.png&h=b125f4f0&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-07-04T05:49:32.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"be3bd04b014a3438cc152c557e2616905b1579d7","tid":728612,"uid":9019,"like":2,"dislike":0,"score":2,"quote":{"pid":"9581943e36a14940b3ded332a14aab571a2e7cc4","tid":728612,"uid":83906,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-07-04T05:24:47.000Z","msg":"文章認為文章指出文章提出<br />\n<br />\n睇到我爭啲以為文章係一個人嚟"},"citedBy":0,"replyTime":"2018-07-04T05:49:46.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/07/04/134939_37dcc5d5fd34ee0fea1