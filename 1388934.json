es/fs/angel.gif\" class=\"hkgmoji\" />"},{"pid":"164cee72178330f1157280ff9bd57ef63d41fde1","tid":1388934,"uid":9435,"like":0,"dislike":5,"score":-5,"quote":{"pid":"67be3aa1f7befa1a8126af8ba3e67a85b856de99","tid":1388934,"uid":16311,"like":1,"dislike":0,"score":1,"quote":{"pid":"a3398d9ac83e6936e36e7355df761248fd532c96","tid":1388934,"uid":9435,"like":0,"dislike":11,"score":-11,"citedBy":1,"replyTime":"2019-07-31T00:14:48.000Z","msg":"9月都未必得啦<br />\n仲講十月<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-31T00:17:03.000Z","msg":"點解？可以有好多方法繼續個運動會<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-31T00:20:25.000Z","msg":"前線越來越少人 <br />\n9月開學又冇左一班最拉攏民心既學生<br />\n出黎抗爭唔夠人就好難繼續"},{"pid":"85414dd73d78f2ae4794dd3dd61fe930427dea30","tid":1388934,"uid":16311,"like":5,"dislike":0,"score":5,"quote":{"pid":"164cee72178330f1157280ff9bd57ef63d41fde1","tid":1388934,"uid":9435,"like":0,"dislike":5,"score":-5,"quote":{"pid":"67be3aa1f7befa1a8126af8ba3e67a85b856de99","tid":1388934,"uid":16311,"like":1,"dislike":0,"score":1,"quote":{"pid":"a3398d9ac83e6936e36e7355df761248fd532c96","tid":1388934,"uid":9435,"like":0,"dislike":11,"score":-11,"citedBy":1,"replyTime":"2019-07-31T00:14:48.000Z","msg":"9月都未必得啦<br />\n仲講十月<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-31T00:17:03.000Z","msg":"點解？可以有好多方法繼續個運動會<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-31T00:20:25.000Z","msg":"前線越來越少人 <br />\n9月開學又冇左一班最拉攏民心既學生<br />\n出黎抗爭唔夠人就好難繼續"},"citedBy":1,"replyTime":"2019-07-31T00:26:07.000Z","msg":"所以大家都要清楚要捱到10月呢樣野<br />\n至於夠唔夠人，14年9月都有場好多人既運動會捱到12月<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />仲要講緊係不停地進行<br />\n我地首先要防止有手足比人拉，再接力用唔同方式延長佢<br />\n上次都捱左3個月 今次冇可能唔得"},{"pid":"651c1e6e48013f04c4dc3c14fa9218dc8107780e","tid":1388934,"uid":147892,"like":9,"dislike":0,"score":9,"quote":{"pid":"234150e39720fbf6ed3d0bae77cecc1a2ca5d1ee","tid":1388934,"uid":43204,"like":6,"dislike":26,"score":-20,"citedBy":4,"replyTime":"2019-07-30T19:41:26.000Z","msg":"10 手1應該係出大绝啦<br />\n仲checkpoint<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-31T00:28:10.000Z","msg":"咁都無人屌殘體字<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"97331660e9241d41084b76c21ed0bdd4ed620c41","tid":1388934,"uid":6528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T00:28:25.000Z","msg":"全民8月5日大罷工！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n五大訴求，缺一不可！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n雙普選應要排最頭！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n全民黑衫、口罩同頭盔，返工返學行街，唔擺工既日子一齊做，將抗爭帶入生活，保護示威者<br />\n<a href=\"https://lih.kg/1379839\" data-auto-link target=\"_blank\">https://lih.kg/1379839</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n光復香港，時代革命！<br />\n－－－－－－－－－－－－－－－－－－－－－－－－－－－－－<br />\n想比更多人知道其實而家呢一刻基本上得番香港獨立呢條路，<br />\n我知好多人未準備好，我知而家急唔黎。<br />\n但係想大家思考下，種下一個思想，唔好屌我住。<br />\n<br />\n而家就算有真普選其實都係under中共！！<br />\n咁唔通去到2047再抗爭過咩，西方國家都出唔到手幫你地。<br />\n因為白紙黑字寫明50年，西方國家唔好話出手，連發聲既正當性都冇啊<br />\n<br />\n可能好多前人都係到諗點解英國當時唔寫999年！<br />\n可能好多我地呢代既諗點解上一代冇去抗爭！<br />\n可能好多下一代係2047係到諗點解我地唔直接爭取獨立！！！<br />\n<br />\n所有既問題，所有既恩怨，係我地呢代到解決哂啦，好嗎？<br />\n我地唔可以好似上一代咁，計好哂數50年後都死左啦，唔好理啦。<br />\n我地唔可以再咁自私咁，過埋2047都死左啦。<br />\n我想我地既下一代唔需要再為呢啲事再受苦啦，我只係希望下一代可以係呼吸住自由既空氣出世係呢個地球上。<br />\n<br />\n所有問題去到最後只會追究到主權問題，希望大家思考下。<br />\n今次搞到咁大真係最後一次反擊同最大力量。<br />\n<br />\nBTW，五大訴求，缺一不可！<br />\n雙普選應要排最頭"},{"pid":"631a43336c29745f7938e586453d924c25da7ae9","tid":1388934,"uid":50483,"like":1,"dislike":0,"score":1,"quote":{"pid":"85414dd73d78f2ae4794dd3dd61fe930427dea30","tid":1388934,"uid":16311,"like":5,"dislike":0,"score":5,"quote":{"pid":"164cee72178330f1157280ff9bd57ef63d41fde1","tid":1388934,"uid":9435,"like":0,"dislike":5,"score":-5,"quote":{"pid":"67be3aa1f7befa1a8126af8ba3e67a85b856de99","tid":1388934,"uid":16311,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-31T00:17:03.000Z","msg":"點解？可以有好多方法繼續個運動會<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-31T00:20:25.000Z","msg":"前線越來越少人 <br />\n9月開學又冇左一班最拉攏民心既學生<br />\n出黎抗爭唔夠人就好難繼續"},"citedBy":1,"replyTime":"2019-07-31T00:26:07.000Z","msg":"所以大家都要清楚要捱到10月呢樣野<br />\n至於夠唔夠人，14年9月都有場好多人既運動會捱到12月<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />仲要講緊係不停地進行<br />\n我地首先要防止有手足比人拉，再接力用唔同方式延長佢<br />\n上次都捱左3個月 今次冇可能唔得"},"citedBy":0,"replyTime":"2019-07-31T00:30:31.000Z","msg":"當年都係罷課 同埋9月基本上都係啲活動<br />\n未正式返學 再加上啲活動基本上都係星期六日<br />\n前線點會越來越小 雖然唔想被捕<br />\n但有人被捕就有人頂上"},{"pid":"1d1b3ed4e8012e64a71b539b8a54c5b251235c5e","tid":1388934,"uid":271900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T00:30:56.000Z","msg":"推"},{"pid":"b828c70b6ec71c8a417589e1d5c93126894715be","tid":1388934,"uid":261137,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T00:33:08.000Z","msg":"推"},{"pid":"8087bfbc5a918f61b1802ebf8e3e95cdd4df9416","tid":1388934,"uid":246884,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T01:29:09.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"15e428ffd8010c26278faa6e667c73b7fe17eb86","tid":1388934,"uid":35790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T01:38:48.000Z","msg":"十月前支共一定會設法擺平<br />\n就算被迫出老解"},{"pid":"e