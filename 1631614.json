:"8f50f018003a58a2cf56dd49376df5c70364e17b","tid":1631614,"uid":34241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:24:37.000Z","msg":"[道德撚、左膠黑色警告] 邊有人咁撚戇鳩, 有黑警臥底呢張皇牌都唔用, 乜鳩都主動攬撚哂上身<br />\n<a href=\"https://lih.kg/1630990\" data-auto-link target=\"_blank\">https://lih.kg/1630990</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"cad1a37472ae407efa612bb515d89381cd4d4a1c","tid":1631614,"uid":13343,"like":0,"dislike":0,"score":0,"quote":{"pid":"425ceafb5bcb72ed537abfa542e0f4ed3cbf49cc","tid":1631614,"uid":55198,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T16:23:35.000Z","msg":"真係好多0.5 互割"},"citedBy":0,"replyTime":"2019-10-06T16:25:15.000Z","msg":"我地唔可以重蹈 2014 年嘅錯誤<br />\n<br />\n我5 年最遺憾就係睇住高登失效"},{"pid":"4cb2fc55d8d59950383ae7e4d8d82be9eaaeb771","tid":1631614,"uid":49336,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:26:30.000Z","msg":"推"},{"pid":"5ee1a43212c2cb538591806823119f7fe29934d5","tid":1631614,"uid":157411,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T16:27:16.000Z","msg":"推, 做得好手足"},{"pid":"480d9c058009184caf9bf33ed264d3579210bd9b","tid":1631614,"uid":49316,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:27:51.000Z","msg":"大把on9開post話勇武搞到港島遊行  唔set RB無事<br />\n<br />\n跟本港共唔會俾我地再有百萬遊行出現"},{"pid":"87e3612d4a4807d1c7ccec6948dbeaca39b51716","tid":1631614,"uid":13343,"like":0,"dislike":0,"score":0,"quote":{"pid":"5ee1a43212c2cb538591806823119f7fe29934d5","tid":1631614,"uid":157411,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T16:27:16.000Z","msg":"推, 做得好手足"},"citedBy":0,"replyTime":"2019-10-06T16:28:31.000Z","msg":"Thanks bro<br />\n大家係手足<br />\n一齊為運動做多d嘢"},{"pid":"411fb9850ef22ba9fb53940e035bb09482d04aa0","tid":1631614,"uid":15259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:29:10.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">對店舖:記住唔需要次次硬裝修</span></strong></span><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">1.打電話、EMAIL、無限FAX</span></span></strong><br />\n想同職員談心又得，講咩都得，幫阿SIR叫下外賣又得<img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" />總知JAM到佢線就得。有EMAIL既就SEND EMAIL查詢下，有FAX機既可以用下無限FAX大法<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">2.MEMO紙</span></span></strong><br />\n有開門就入去叫杯水慢慢坐<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n無開門既咪留張紙起度寫低自己有咩問或者有咩訴求囉<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">3.善用1823</span></span></strong><br />\n食完野集體食物中毒呀，消防設備唔合符規格呢D無理由唔投訴呀？<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><br />\n留意返打完1823之後，佢係要起限期內比返回覆你架<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n呢招長玩長有，大家打之前要謹慎少少呀<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">4.蟲系魔法師</span></span></strong><br />\n知道好多巴絲打鐘意養蟲蟲，但係入店一定要小心唔好倒瀉D寶貝呀(特別起食肆)<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">對人(限影大頭相/沒有攻擊性/非主攻類):</span></strong></span><br />\n記住召喚神獸唔係唔得，必須記住係<span style=\"font-size: xx-large;\"><strong><span style=\"color: pink;\">對家首先用武力/拎住武器先可以召喚</span></strong></span><br />\n但係對住非攻擊形對手都召喚既話觀感就唔係太好睇，仲比左機會對家有煲大<br />\n對住非攻擊形既我地可以幫佢<strong><span style=\"color: limegreen;\"><span style=\"font-size: xx-large;\">飛個靚髮</span></span></strong>或者<strong><span style=\"font-size: xx-large;\"><span style=\"color: violet;\">化下妝</span></span></strong>就夠，唔一定要下下爆哂缸先叫成功架<br />\n<span style=\"color: red;\"><strong><span style=\"font-size: xx-large;\">*要記住中年人著緊自己把頭髮仲多過條命</span></strong></span><br />\n<br />\n呢場抗爭要贏一定要學識剛柔並用<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/ejjnAS\" data-auto-link target=\"_blank\">https://lih.kg/ejjnAS</a>"},{"pid":"049cf9b09252a6c37bcd307cc671586377c788ef","tid":1631614,"uid":13343,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:29:51.000Z","msg":"推"},{"pid":"87a58ec55efcbbcb90612e3c096112a04f8d2f41","tid":1631614,"uid":157411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:31:41.000Z","msg":"幫推<br />\n風向由10月5號凌晨到依家<br />\n唔好中五毛/黑警風向呀<br />\n唔係上得連登既, 都係真手足架"},{"pid":"29b6003f20ecd76685e06f5859cd258d4aae0e38","tid":1631614,"uid":103235,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:32:48.000Z","msg":"推"},{"pid":"d709172cd2972f53c361e450cc4bd101217f0186","tid":1631614,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:33:14.000Z","msg":"推"},{"pid":"d879ef7ee450ea36e40547d776407e76386f16c2","tid":1631614,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:33:50.000Z","msg":"無勇武我地一早入曬集中營"},{"pid":"5b5bd25d6b8f4b13a775914e995822adf67deffe","tid":1631614,"uid":40996,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:37:16.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"56f0899aa2e4f8e36f1132586d8ea3573b2b8387","tid":1631614,"uid":157411,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T16:37:30.000Z","msg":"edci<br />\n#59618<br />\n手足已經失晒控（內有九龍塘鶳經過）<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1631012\" data-auto-link target=\"_blank\">https://lih.kg/1631012</a><br />\n<br />\n先不論樓主係咪作故仔<br />\n但此POST COMMENT 極度危險<br />\n呢個POST 簡直就係例子"},{"pid":"def891a3abd36e8a02a2a36b6951e7479791d16a","tid":1631614,"uid":294083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T16:38:07.000Z","msg":"<a href=\"https://lihkg.com/thread/1631437/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/163