50:56.000Z","msg":"所以<br />\n奧巴馬同拜登根本係兩個垃圾<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n果次係要利用手上情報令中共內部出現混亂<br />\n兩班人係度鬼打鬼"},"citedBy":3,"replyTime":"2020-10-01T04:56:32.000Z","msg":"奧巴馬有一段時間幾受香港人支持<br />\n特別左膠，文青班人追捧<br />\n(呢班人好多後來支持希拉利)<br />\n<br />\n大量出現果堆<br />\n奧巴馬演講技巧，跟奧巴馬學英文之類的書&nbsp;"},"citedBy":0,"replyTime":"2020-10-01T07:33:21.000Z","msg":"左膠而加都仲講緊obama"},{"pid":"514f4e972ab5336482385555178d70ae08729969","tid":2224631,"uid":50275,"like":0,"dislike":0,"score":0,"quote":{"pid":"33da95c04d5d5b1539f4c1be15bdc6909455f9e5","tid":2224631,"uid":34140,"like":3,"dislike":0,"score":3,"quote":{"pid":"c1659e6306000de1de0c199497c6a486f0e9d0f5","tid":2224631,"uid":191926,"like":10,"dislike":1,"score":9,"citedBy":2,"replyTime":"2020-10-01T04:50:56.000Z","msg":"所以<br />\n奧巴馬同拜登根本係兩個垃圾<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n果次係要利用手上情報令中共內部出現混亂<br />\n兩班人係度鬼打鬼"},"citedBy":1,"replyTime":"2020-10-01T06:01:05.000Z","msg":"奧巴馬2009年上任，一年前高登仔仲喺度我係中國人呀hi"},"citedBy":0,"replyTime":"2020-10-01T07:33:59.000Z","msg":"咁高登仔有無人做左總統？"},{"pid":"ec231c139fcb1a08f7b9891ff73306caac045724","tid":2224631,"uid":29188,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-01T07:55:38.000Z","msg":"美國全球主義者和奧巴馬政府赤膊上陣狙擊薄熙來，在體制內並不是新聞。他們認為習近平是一個可以控制的過渡人物，理由跟布哈林李科夫和幾乎全部蘇聯支持過渡人物斯大林阻止危險人物托洛茨基及其世界革命和超工業化一樣充分。習近平和斯大林在當時都是匪內殺人最少，為人最忠厚老實，虛榮心和野心最小，一貫是會幹活而不懂政治的人。自由派知識份子普遍認為習仲勛的兒子會執行和平演變，根本原因在於他們不過是美國戰略家及其代理人改革開放集團的尾巴而已。他們如果以為自己是獨立的，其實原因不過是他們的地位太低，連體制內重要人物的情報都沒有資格分享而已。習近平這個當時公認的傻瓜居然在五年內把美國於黨內代理人全部廢掉，從改革開放集團手中挽救了黨，但改革開放集團的羽翼不經過斯大林式清洗是消滅不了的，習近平實際上採用的袁世凱式清洗留下了無數隱患。如果希拉里和全球主義者執政，或者拜登重新執政，勢必有利於美國的帝國化和腐化，但對習近平的清洗工作反而是減輕了負擔。川普或麥卡錫主義者執政，實際上就是啟用了一個沒有外交經驗的班底，粗枝大葉的方向不會有問題，許多黑箱操作的孵蛋工程都免不了雞飛蛋打。改革開放集團兩頭不是人，只能坐以待斃。<br />\n和平演變變成核平演變，已經無法避免。川普並沒有開戰的準備，改革開放集團零成本垮台，結果必然使極左派中國人發大財，民族英雄習近平順利走向偉大復興。2024年的美國人民面對中國的世界性擴張，必然責備川普過於張伯倫。習近平為了肅清反黨集團，必須大開殺戒，因此反而會在動盪的2023年損失更多資源。美國人民在2024年面對全球主義的失敗，照樣會斷定拜登過於張伯倫。所以2020年大選關係不大。"},{"pid":"547eaa4503262c32b942d2f6adba0d16209a11b0","tid":2224631,"uid":277702,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2020-10-01T08:12:22.000Z","msg":"其實而家全世界都等緊拜登當選..."},{"pid":"af63f3cd82c400285aea0fffd513f34e4b9e2c20","tid":2224631,"uid":190579,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2020-10-01T08:31:22.000Z","msg":"Source?<br />\n又話得10個人知？<br />\n咁點解連登仔會知？"},{"pid":"f9ebc95745b4403c186f28f76d6bbaa358f178c5","tid":2224631,"uid":155095,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-01T14:33:43.000Z","msg":"push"},{"pid":"23c452b4d30c80dee58bbc8227070cb48c8b3794","tid":2224631,"uid":155095,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-02T01:09:55.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c7f62eb348fc7a3232ccb9837d575d8c2cab8aba","tid":2224631,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-02T01:16:06.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2824e711f389d990d58b464881e4fd51ec101ac0","tid":2224631,"uid":61280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-02T01:41:12.000Z","msg":"<strong><span class=\"xx-large\"><span class=\"xx-large\"><span class=\"red\">又黎&quot;我被逼架乍！！！&quot;甩身故？？？<img src=\"/assets/faces/big/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/z.gif\" class=\"hkgmoji\" /></span></span></span></strong>"}]}