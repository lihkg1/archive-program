2F2017%2F05%2F30%2F131950_49051d92d5c8463a5bba62950585fc32.jpg&h=8d4fe4ce&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/30/131951_49051d92d5c8463a5bba62950585fc32.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F30%2F131951_49051d92d5c8463a5bba62950585fc32.jpg&h=6558746f&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/30/131951_04a691251e7ff86c9b3a2ac3a78be2bc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F30%2F131951_04a691251e7ff86c9b3a2ac3a78be2bc.jpg&h=e833a3d9&s={SIZE}\" /></blockquote><br />\n去到其實係咪唔洗計劃咁多，有哂路牌有哂資料，洗唔洗拎手機gps或地圖，</blockquote><br />\n<br />\n<br />\n有啲地圖仔既  亦有指示"},{"pid":"c35ced67b8056501c79b168a6b4391f0c0aef517","tid":263120,"uid":79502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T05:26:34.000Z","msg":"可以留Tg傾下？<a href=\"https://t.me/wbc123wong\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fwbc123wong&d=XHnYWkiZIwOO3qOg8qC8sW6tz0R9Svbxs0EcWe5CwMI%3D&h=20a64566\" data-auto-link target=\"_blank\">https://t.me/wbc123wong</a>"},{"pid":"4331876b37abe44cb3103093ecb1484684b017d3","tid":263120,"uid":12426,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T05:27:16.000Z","msg":"<img src=\"http://img.eservice-hk.net/upload/2017/05/30/132707_9aba48c07c2cf677762c36083de6c18c.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F30%2F132707_9aba48c07c2cf677762c36083de6c18c.jpg&h=814f6629&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n地圖仔"},{"pid":"bce14d4bc6f113e15d3b09dc40e4187d5f792784","tid":263120,"uid":79023,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T05:27:36.000Z","msg":"果陣買站票上西安百幾蚊，好似搭左幾十個鐘"},{"pid":"6a37c27dd520fc94251c295ead8dc241eccb1b01","tid":263120,"uid":12426,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T05:29:30.000Z","msg":"btw 我西安有去埋龍門石fuk <br />\n高鐵去  即日  幾快下"},{"pid":"012d7f9640dfbfe9288aad01691128fdc1706e07","tid":263120,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T05:53:29.000Z","msg":"以前做過嘅即日來回行法，唔知啲路有冇改，北峰上北峰落嘅走法。<br />\n<br />\n<img src=\"https://holland.pk/8z6o2hpq\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2F8z6o2hpq&h=22cea8cb&s={SIZE}\" />"},{"pid":"bfa7d76da64fde6c418f725f8f49b54473cd7b64","tid":263120,"uid":79502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T07:15:16.000Z","msg":"加加埋埋成個旅程洗左幾錢"},{"pid":"5fd93901dd1a764eb85a2655a86227274b6af458","tid":263120,"uid":16697,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T08:02:12.000Z","msg":"咁撚易去都問咁撚多問題<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n去到傻既都識行了，有晒指示牌"},{"pid":"19ad412e199831407d90fd71cfb77c15ebb3acf6","tid":263120,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T09:54:45.000Z","msg":"<blockquote>咁撚易去都問咁撚多問題<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n去到傻既都識行了，有晒指示牌</blockquote><br />\n<br />\n佢應該係想行長空棧道跳降傘<br />\n<img src=\"https://holland.pk/weotkf5x\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fweotkf5x&h=2fa71070&s={SIZE}\" />"},{"pid":"80b97482fb7e67137cc6f0a7aa8123442eba8612","tid":263120,"uid":13025,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T09:59:20.000Z","msg":"唔少人係夜晚行上去睇日出 <br />\n我就坐吊車上落 住一晚 同行有女仔行就不了"},{"pid":"7ddc5b17b83119e5a6f513a848e5c71af16e17a9","tid":263120,"uid":13025,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T10:01:14.000Z","msg":"我去果時有個老和尚唔用安全帶行棧道 仲要扶都唔扶條威也"},{"pid":"6015b55bdfd82e0d9050c2215b924ecb67a5a1a5","tid":263120,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T10:04:26.000Z","msg":"<blockquote>我去果時有個老和尚唔用安全帶行棧道 仲要扶都唔扶條威也</blockquote><br />\n<br />\n唔用仲安全，啲人話每次轉扣仲驚。"},{"pid":"286960da046c5e6eb8b7b90a3e8d5b92047e6d18","tid":263120,"uid":79502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T10:22:25.000Z","msg":"<blockquote>我去果時有個老和尚唔用安全帶行棧道 仲要扶都唔扶條威也</blockquote><br />\n你果陣都係夜行？由邊個峰開始？"},{"pid":"3d86daa928bec4a330dc99257efa03b3d6d48b03","tid":263120,"uid":70946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T10:28:10.000Z","msg":"西安坐高鐵去華山落車，係華山山腳住一晚，第二朝一早出發最好，上華山坐吊車去北峰&mdash;中鋒&mdash;東峰&mdash;南峰&mdash;西峰&mdash;中峰&mdash;北峰再坐返吊車走，黃昏左右可行晒"},{"pid":"2fbf18f43be6d44a2bb0f6c1d04b877b6db38581","tid":263120,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T10:44:05.000Z","msg":"<blockquote>西安坐高鐵去華山落車，係華山山腳住一晚，第二朝一早出發最好，上華山坐吊車去北峰&mdash;中鋒&mdash;東峰&mdash;南峰&mdash;西峰&mdash;中峰&mdash;北峰再坐返吊車走，黃昏左右可行晒</blockquote><br />\n<br />\n老實講，依家梗係西峰索道上，北峰落，唔走回頭路，除非老人家，落樓梯慘過上樓梯，咁就會揀北峰上。"},{"pid":"cc045fff54d8c021a2849188a2a00dbe54db446c","tid":263120,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T10:45:43.000Z","msg":"<blockquote><blockquote>我去果時有個老和尚唔用安全帶行棧道 仲要扶都唔扶條威也</blockquote><br />\n你果陣都係夜行？由邊個峰開始？</blockquote><br />\n<br />\n自己望上上面啲圖啦，你以為個個峰都可以由山下面直接上到去咩？<br />\n<br />\n你係假膠定真膠呀！<br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"0630753734cf96c4bd87ac8ec649b28c8d1b52e4","tid":263120,"uid":70946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T11:03:37.000Z","msg":"<blockquote><blockquote>西安坐高鐵去華山落車，係華山山腳住一晚，第二朝一早出發最好，上華山坐吊車去北峰&mdash;中鋒&mdash;東峰&mdash;南峰&mdash;西峰&mdash;中峰&mdash;北峰再坐返吊車走，黃昏左右可行晒</blockquote><br />\n<br />\n老實講，依家梗係西峰索道上，北峰落，唔走回頭路，除非老人家，落樓梯慘過上樓梯，咁就會揀北峰上。</blockquote><br />\n落樓梯慘過上樓梯<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n最長最斜條梯係北峰上中峰中間，如果西峰上，中峰落北峰係行另一條易啲嘅路落，最大挑戰性條路唔行去黎做咩<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n一係北峰上西峰落都還可以"},{"pid":"70b09243e470a6b23e97f307e26e130f4037a12c","tid":263120,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T11:13:17.000Z","msg":"<blockquote><blockquote><blockquote>西安坐高鐵去華山落車，係華山山腳住一晚，第二朝一早出發最好，上華山坐吊車去北峰&mdash;中鋒&mdash;東峰&mdash;南峰&mdash;西峰&mdash;中峰&mdash;北峰再坐返吊車走，黃昏左右可行晒</blockquote><br />\n<br />\n老實講，依家梗係西峰索道上，北峰落，唔走回頭路，除非老人家，落樓梯慘過上樓梯，咁就會揀北峰上。</blockquote><br />\n落樓梯慘過上樓梯<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n最長最斜條梯係北峰上中峰中間，如果西峰上，中峰落北峰係行另一條易啲嘅路落，最大挑戰性條<br />\n路唔行去黎做咩<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n一係北峰上西峰落都還可以</blockquote><br />\n<br />\n你見到樓主咁撚廢，乜都唔撚查就淨係識問問問，一睇就知係跛架啦，西峰上北峰落就啱佢啦。<br />\n<br />\n落樓梯慘過上樓梯，睇你幾多歲同幾重囉，上兩次北峰我都只覺得上去慘過落。<br />\n<br />\n當然你要行中間條路就另計，我上面幅圖都有晒上落路線。"},{"pid":"78f35eaef54797af78d580be36af5c474cfb2277","tid":263120,"uid":16697,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T11:26:33.000Z","msg":"似垃圾齋問唔撚去果d傻鳩，咁既智商學人番大陸玩，蠢撚過隻豬"},{"pid":"57a27c7acc497c41a74e3e9c1da01a750b784b43","tid":263120,"uid":13025,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T12:30:26.000Z","msg":"<blockquote>似垃圾齋問唔撚去果d傻鳩，咁既智商學人番大陸玩，蠢撚過隻豬</blockquote><br />\n居然有d咁ge人"},{"pid":"fc7118d67f1e5d7b8002fd84406ec088d48f2691","tid":263120,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T12:34:23.000Z","msg":"<blockquote><blockquote>似垃圾齋問唔撚去果d傻鳩，咁既智商學人番大陸玩，蠢撚過隻豬</blockquote><br />\n居然有d咁ge人</blockquote><br />\n<br />\n連登不嬲大撚把，開 post 問地方，以為佢有晒計劃去，問佢幾時去，佢話諗着後年可能去。<br />\n<br />\n唔撚知以為佢準備登陸月球！<br />\n<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"9c6a9c11c9f3dab51e8b1648ff4a6074cb97584b","tid":263120,"uid":13025,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T12:47:27.000Z","msg":"<blockquote><blockquote><blockquote>似垃圾齋問唔撚去果d傻鳩，咁既智商學人番大陸玩，蠢撚過隻豬</blockquote><br />\n居然有d咁ge人</blockquote><br />\n<br />\n連登不嬲大撚把，開 post 問地方，以為佢有晒計劃去，問佢幾時去，佢話諗着後年可能去。<br />\n<br />\n唔撚知以為佢準備登陸月球！<br />\n<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n