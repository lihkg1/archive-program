hkgmoji\" />"},{"pid":"e0e38acdfddfdb8b39c505af901758e088883eac","tid":1641184,"uid":60470,"like":0,"dislike":0,"score":0,"quote":{"pid":"a3ae7e597ec0d1d76dfb2b903dfd994a636babf5","tid":1641184,"uid":224510,"like":0,"dislike":0,"score":0,"quote":{"pid":"292b501ba350d6e25ab2fb87a4d108da139327d1","tid":1641184,"uid":32583,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-09T14:23:21.000Z","msg":"有沒有高達模型買<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-10-10T04:21:53.000Z","msg":"呢間好少量模型<br />\n但係皆旺本身都有幾間賣模型<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><br />\n<br />\n再唔係同一條街千里達， 英明<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-10T05:24:43.000Z","msg":"老闆係真係專賣工具同參考書<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><br />\n同條街我比較推薦千里達"},{"pid":"2c4814acd4426853e28386cd8f4a10813543492f","tid":1641184,"uid":44243,"like":0,"dislike":6,"score":-6,"citedBy":0,"replyTime":"2019-10-10T05:26:09.000Z","msg":"幫佢裝修"},{"pid":"f390ef57201bb4b5aee089033ddc70cc2691e6d9","tid":1641184,"uid":72253,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T06:09:21.000Z","msg":"推"},{"pid":"9c586c1657554292eff50c9f1ec0bf86d5903985","tid":1641184,"uid":42435,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-12T01:56:38.000Z","msg":"有去開買料<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"dd4f60d06453ad8dc50db0be142fb0d3ffca2716","tid":1641184,"uid":55761,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-14T05:07:55.000Z","msg":"不嬲支持開，簡直係模型工具天堂"},{"pid":"a7007f3463454a01ea1fbbd72bae2