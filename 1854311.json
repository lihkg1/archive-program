=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-31T12:04:27.000Z","msg":"係喎<br />\n食返枝定下驚<img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" />"},{"pid":"152ab098576f8d104be702b829132ed1b0800a15","tid":1854311,"uid":33373,"like":0,"dislike":0,"score":0,"quote":{"pid":"f7e0e4cb0b1c30687b17d97c8816a21718853bc4","tid":1854311,"uid":302061,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-31T11:58:33.000Z","msg":"真心問 <img src=\"/assets/faces/lm2lny/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-31T12:05:02.000Z","msg":"霧化仲危險<br />\n<br />\n同之前講嗰啲加濕器中咗退伍軍人 菌 一樣"},{"pid":"1693bcac0c502e25705250ad252d4fceb0a89636","tid":1854311,"uid":99700,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-31T12:06:09.000Z","msg":"肺炎》肺癌"},{"pid":"c7b3bb539fc68604578b506a6fa283afc88f12d9","tid":1854311,"uid":344033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-31T12:18:15.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">請廣傳</span></span><br />\n<br />\n手足裝備抗沙士：防毒面具/濾罐 (型號/分析/用法/清潔全齊）<br />\n<br />\n<a href=\"https://lih.kg/1848447\" data-auto-link target=\"_blank\">https://lih.kg/1848447</a><br />\n<br />\n<br />\n整體分析圖：<a href=\"https://www.facebook.com/112357283631796/posts/116690396531818/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F116690396531818%2F%3Fd%3Dn&d=6xH2G4nGFyEJ53rX7DpuMT2x7fSflbdxuct7bsFM5Qs%3D&h=cf2ee459\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/116690396531818/?d=n</a><br />\n個別仔細分析：<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\"><span style=\"font-size: xx-large;\">護目鏡</span>：<a href=\"https://lih.kg/1845419\" data-auto-link target=\"_blank\">https://lih.kg/1845419</a></span></span> / <a href=\"https://m.facebook.com/112357283631796/posts/117867026414155/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2F112357283631796%2Fposts%2F117867026414155%2F%3Fd%3Dn&d=6xH2G4nGFyEJ53rX7DpuMT2x7fSflbdxuct7bsFM5Qs%3D&h=f5b64eeb\" data-auto-link target=\"_blank\">https://m.facebook.com/112357283631796/posts/117867026414155/?d=n</a><br />\n<br />\nVPN 大踢爆：<a href=\"https://m.facebook.com/story.php?story_fbid=112386483628876&amp;id=112357283631796&amp;__tn__=%2As-R\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2Fstory.php%3Fstory_fbid%3D112386483628876%26id%3D112357283631796%26__tn__%3D%252As-R&d=6xH2G4nGFyEJ53rX7DpuMT2x7fSflbdxuct7bsFM5Qs%3D&h=0d51ff54\" data-auto-link target=\"_blank\">https://m.facebook.com/story.php?story_fbid=112386483628876&amp;id=112357283631796&amp;__tn__=%2As-R</a><br />\n<br />\n請大家幫手正評，避免沉底<br />\n<br />\n最近口罩同N95 都賣曬，部分手足屋企口罩已經就黎用盡，今日同大家介紹下可以防沙士+TG嘅濾罐同濾棉。第一，係for 用曬/買唔到口罩嘅手足，第二係希望方便大家一次過買齊發夢+出街嘅裝備，就算沙士完左，自用送禮都可以繼續名貴大方。<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n濾罐/棉<br />\n<br />\nN95/R95/P95 口罩基本上係particulate respirator, 外科口罩防嘅係飛沫粒子，即係我地用防毒面具代替，就要裝particulate filter，換言之，就係濾棉！<br />\n<br />\n600X系列罐只防氣體，不防病毒！<br />\n<br />\n濾棉最高級別就係P100，防油性+非油性粒子，即係TG（油性）同埋病毒都可以防<br />\n<br />\n型號包括2091, 2097, 2297, 6035（只有英國製）,7093 等等！<br />\n6035(P100)&gt;7093(P100)&gt;2097(P100)&gt;2091(P100)&gt; 5n11cn(N95)&gt;單罐(N94)<br />\n<br />\n60926等等嘅6092X 系列濾罐，內置P100 濾棉，但係依種罐入面嘅棉比較少，壽命較短<br />\n<br />\n防水：6035/7093<br />\n表面有盒：60926<br />\n<br />\n壽命：6035/7093&gt;2091&gt;60926<br />\n<br />\n有強國人做過測試，係北京霧霾毒氣之下，3M 2091 用左十一日過濾能力都係跌左1%，手足請自行考慮幾耐換一次。<br />\n<br />\nAmazon 大log買亦有便，大家可以組團買。<br />\n<br />\n<a href=\"https://www.3m.com.au/3M/en_AU/company-au/all-3m-products/~/3M-Particulate-Filter-6035-P2-P3/?N=5002385+8711017+3294471754&amp;rt=rud\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.3m.com.au%2F3M%2Fen_AU%2Fcompany-au%2Fall-3m-products%2F~%2F3M-Particulate-Filter-6035-P2-P3%2F%3FN%3D5002385%2B8711017%2B3294471754%26rt%3Drud&d=6xH2G4nGFyEJ53rX7DpuMT2x7fSflbdxuct7bsFM5Qs%3D&h=50ca39b7\" data-auto-link target=\"_blank\">https://www.3m.com.au/3M/en_AU/company-au/all-3m-products/~/3M-Particulate-Filter-6035-P2-P3/?N=5002385+8711017+3294471754&amp;rt=rud</a><br />\n<a href=\"https://www.3m.com/3M/en_US/company-us/all-3m-products/~/3M-Particulate-Filter-7093-P100-60-EA-Case/?N=5002385+3294776429&amp;rt=rud\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.3m.com%2F3M%2Fen_US%2Fcompany-us%2Fall-3m-products%2F~%2F3M-Particulate-Filter-7093-P100-60-EA-Case%2F%3FN%3D5002385%2B3294776429%26rt%3Drud&d=6xH2G4nGFyEJ53rX7DpuMT2x7fSflbdxuct7bsFM5Qs%3D&h=4ffda13e\" data-auto-link target=\"_blank\">https://www.3m.com/3M/en_US/company-us/all-3m-products/~/3M-Particulate-Filter-7093-P100-60-EA-Case/?N=5002385+3294776429&amp;rt=rud</a><br />\n<br />\n2003 年沙士，淘大嘅清理人員就係用2091棉+600X 罐（罐理論上唔洗，應該係防佢地嘅清潔同消毒藥水）。<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n清潔<br />\n如何清潔防毒面具可參考以下，有教disinfection，主要都係漂白水同消毒劑<br />\n<a href=\"https://youtu.be/dE5IweYn3T4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FdE5IweYn3T4&d=6xH2G4nGFyEJ53rX7DpuMT2x7fSflbdxuct7bsFM5Qs%3D&h=cd2007f1\" data-auto-link target=\"_blank\">https://youtu.be/dE5IweYn3T4</a><br />\n<br />\n<a href=\"http://www.3m.co.uk/intl/uk/ohes/segments/healthcare/(9666a\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.3m.co.uk%2Fintl%2Fuk%2Fohes%2Fsegments%2Fhealthcare%2F%289666a&d=6xH2G4nGFyEJ53rX7DpuMT2x7fSflbdxuct7bsFM5Qs%3D&h=47660d7e\" data-auto-link target=\"_blank\">http://www.3m.co.uk/intl/uk/ohes/segments/healthcare/(9666a</a>)OH_ReusableTechBulletin_lft.pdf<br />\n<br />\n清潔步驟：<br />\n入到屋企唔好除裝備住，用酒精紙巾抹左面具同濾棉/罐表面先，跟住洗手，跟住除面罩，再跟番教學清潔，都係稀釋漂白水/酒精<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n防毒面具<br />\n<br />\n建議大家買Full Face 豬嘴，咁樣就唔洗帶眼罩，一舊野保護曬成塊面，最安全。因為你戴半面+眼罩，咁就多舊野清潔，同埋部分眼罩封唔曬，冇咁安全。<br />\n<br />\n型號方面，Full Face嘅建議大家買6800，順便擋埋橡膠子彈，半面嘅就買7502比較舒服，體力勞動嘅建議買6502QL，快拆，方便飲水<br />\n<br />\n7500同6500系列最主要就係一個完全用用矽膠造，一個只係一部分係矽膠，7500<br />\n會比較舒服同耐用<br />\n<br />\n<span style=\"color: red;\"><a href=\"https://www.facebook.com/112044766987392/posts/119490526242816/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112044766987392%2Fposts%2F119490526242816%2F%3Fd%3Dn&d=6xH2G4nGFyEJ53rX7DpuMT2x7fSflbdxuct7bsFM5Qs%3D&h=88b8fd52\" data-auto-link target=\"_blank\">https://www.facebook.com/112044766987392/posts/119490526242816/?d=n</a><br />\n酒精搓手液 vs 洗手梘液</span><br />\n<br />\n<a href=\"https://www.cdc.gov/niosh/npptl/topics/respirators/factsheets/respsars.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.cdc.gov%2Fniosh%2Fnpptl%2Ftopics%2Frespirators%2Ffactsheets%2Frespsars.html&d=6xH2G4nGFyEJ53rX7DpuMT2x7fSflbdxuct7bsFM5Qs%3D&h=91a82dfa\" data-auto-link target=\"_blank\">https://www.cdc.gov/niosh/npptl/topics/respirators/factsheets/respsars.html</a><br />\nSARS 時期CDC 對N95 同防毒面具嘅指引<br />\n（僅供參考！WARS 嘅傳染性係SARS 嘅一倍以上！）<br />\n五金舖地圖<br />\nshorturl.at/fwxIQ"},{"pid":"3822d05a5a2b669f1b6507f0b56bd29bfb7bda4b","tid":1854311,"uid":249317,"like":0,"dislike":0,"score":0,"quote":{"pid":"c779b418fa5c04da144520b1779fd0d455355b7f","tid":1854311,"uid":317233,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-31T12:01:30.000Z","msg":"焦油防肺炎<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-31T12:59:19.000Z","msg":"照你咁講，吸咗入佢個啲病毒會噴返出嚟？"},{"pid":"446f8e9c22141c9fcc432aed436c009bb62ed64b","tid":1854311,"uid":317233,"like":0,"dislike":0,"score":0,"quote":{"pid":"3822d05a5a2b669f1b6507f0b56bd29bfb7bda4b","tid":1854311,"uid":249317,"like":0,"dislike":0,"score":0,"quote":{"pid":"c779b418fa5c04da144520b1779fd0d455355b7f","tid":1854311,"uid":317233,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-31T12:01:30.000Z","msg":"焦油防肺炎<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-31T12:59:19.000Z","msg":"照你咁講，吸咗入佢個啲病毒會噴返出嚟？"},"citedBy":1,"replyTime":"2020-01-31T13:16:54.000Z","msg":"唔係 啲焦油會