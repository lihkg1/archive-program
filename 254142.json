ormal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n都唔諗下自己後生咪又係追求戀愛自由<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"726e3a03f5d8977ea8efef668bf39ecc45759d33","tid":254142,"uid":14703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-23T05:56:08.000Z","msg":"<blockquote><blockquote><blockquote>呀大師父好撚傳統 好封建 一就係一 二就係二 唔識變通<br />\n<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n咪同神鵰個郭靖一樣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n結婚就一定要父母之命 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n都唔諗下自己後生咪又係追求戀愛自由<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n無錯<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n個感覺就好似而家d阿爸阿媽級，後生其實都係食煙飲酒講粗口。<br />\n但係亦都唔會準自己仔女咁做<br />\n諗諗下，都係一種佢對楊過既愛黎既<br />\n雖然我地站在楊過立場一定會覺得佢好慘<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e413d468517efa0582ebd0528410c6754533099b","tid":254142,"uid":30604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-23T05:56:50.000Z","msg":"最撚憎呢條廢佬 老屈我蓉兒"},{"pid":"2f28e9d8dbd5970562c34380a4fe9ae2ba19865a","tid":254142,"uid":99906,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-05-23T05:57:39.000Z","msg":"<blockquote>點解瑛姑可以一剎那黑髮變白髮<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n因為佢係喰種"},{"pid":"39c6455ff3d57fcb1993a106c54e323629ddd3c9","tid":254142,"uid":34080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-23T06:02:56.000Z","msg":"此回覆已被刪除"},{"pid":"06b3156b47bb19065867174f2399a13176750fdd","tid":254142,"uid":21249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-23T06:07:47.000Z","msg":"<blockquote><blockquote>垃圾廢老<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n終日無所事事指手劃腳，屌鳩郭靖楊過係廢青<br />\n攤手板攞綜援，住桃花島痴飲痴食<img src=\"/assets/faces/big/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n係出面賭輸錢先匿去桃花島 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"21bc779656e630189712ba9a7043c9b91602053c","tid":254142,"uid":14703,"like":0,"dislike":0,"score":0,"