2:A2,A2)<br />\ndouble click, apply to all row<br />\n<br />\n第二步整一個a-z既table<br />\nexample:<br />\nH2 I2<br />\n1 A<br />\n2 B<br />\n3 C<br />\n...<br />\n26 Z<br />\n<br />\n將數字轉變成英文字<br />\n=VLOOKUP(<span style=\"color: red;\">B2</span>, $H$2:$I$27,2,0)<br />\n<br />\nalternative:<br />\n=INDEX(J:J,MATCH(<span style=\"color: red;\">B2</span>,I:I,0))<br />\n<br />\n兩條式合併：<br />\n上面紅色字replace做第一條式<br />\n=VLOOKUP(COUNTIF($A$2:A2,A2), $H$2:$I$27,2,0)"},{"pid":"fbcd3de3dfdad68abd57d994c31f442557052bf6","tid":1775964,"uid":298736,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-09T08:23:32.000Z","msg":"vlookup(countif($A$1:A1,A1) , table, 2,0)<br />\n<br />\ntable就係1 = A, 2 = B, etc.   咁ABCDE就可以自己隨意定"},{"pid":"023a069ccdd7ca4f2e8e8c50006788b94dc05223","tid":1775964,"uid":109712,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-09T08:23:58.000Z","msg":"個POST REPLY唔到?"},{"pid":"147b95efccc536831f71d7603117a0c8f04095af","tid":1775964,"uid":109712,"like":0,"dislike":0,"score":0,"quote":{"pid":"023a069ccdd7ca4f2e8e8c50006788b94dc05223","tid":1775964,"uid":109712,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-09T08:23:58.000Z","msg":"個POST REPLY唔到?"},"citedBy":0,"replyTime":"2019-12-09T08:24:59.000Z","msg":"如果COUNT大過27就睇你想點<br />\nＣＨＡＲ(64+ＣＯＵＮＴＩＦ($A:$A,$A2))"},{"pid":"a66b73a24f0077002cc8bfe83b1bd75cf88a4ba8","tid":1775964,"uid":1049,"like":0,"dislike":0,"score":0,"quote":{"pid":"59e5a6cb242cce841d84d7cefacfbfa1867d94f8","tid":1775964,"uid":24378,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-12-09T08:10:02.000Z","msg":"Cell B2=SUBSTITUTE(ADDRESS(1,COUNTIF(A$2:A2,A2),4),&rdquo;1&rdquo;,&rdquo;&rdquo;)"},"citedBy":0,"replyTime":"2019-12-09T08:30:50.000Z","msg":"學到野<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"69dc9d9892c5da3b091029c71e0b06183b60c21f","tid":1775964,"uid":301125,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-12-09T09:05:25.000Z","msg":"<img src=\"https://na