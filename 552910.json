d":552910,"uid":27643,"like":0,"dislike":1,"score":-1,"quote":{"pid":"a5838c79edd8460c8ef14fd95eac556188743936","tid":552910,"uid":72581,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-02-07T07:09:46.000Z","msg":"巴打由香港去美國先去得4日？<br />\n覺得呢點都好可疑"},"citedBy":0,"replyTime":"2018-02-07T07:19:06.000Z","msg":"係呀 4-5 日掛<br />\n<br />\n始終要夾女友返學"},{"pid":"6d43656b296f34d2907736974318e993372b7f2b","tid":552910,"uid":6833,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-02-07T07:35:30.000Z","msg":"真係睇運<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fbc8816af30f71fab82f2a13b6536ef9cbbffa7b","tid":552910,"uid":27643,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6d43656b296f34d2907736974318e993372b7f2b","tid":552910,"uid":6833,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-02-07T07:35:30.000Z","msg":"真係睇運<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-07T07:41:23.000Z","msg":"好多人都話係 彩數<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />  驚"},{"pid":"f58316d1ef70e6bc4754e851aeb3a9000cbca3fd","tid":552910,"uid":161502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-07T07:57:20.000Z","msg":"你最緊要講明去美國既目的<br />\n佢地最驚你去完唔走 非法逗留<br />\n所以interview一定要搞清楚 去幾多日 幾時去 幾時走<br />\n無需要任何技巧 照直講就得<br />\ninterview 3mins 3-4個問題 左右<br />\n成功既話 佢會即時收你護照，話7日後送返比你<br />\n<br />\n利申 上年搞完"},{"pid":"7839d1108fe91780cd73f9a3c83ee9c339a23f76","tid":552910,"uid":632,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-02-07T09:31:24.000Z","msg":"Fresh grad同埋無咁多存款都好難過<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n除非你證明自己返黎會繼續返工<br />\n有工作證明<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n如果唔係都幾難批<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n你同佢講到同女朋友去又去咩都好佢都字<br />\n未必信你<br />\n最緊要有封工作證明到你唔會一去無回頭就得<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n或者master有無證明文件個啲<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n個個一聽到我讀緊大學就問我鍾唔鍾意自己間大學 跟住連我要去邊都無問<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},{"pid":"a8ec046bc8f6f51a8147ce6647b3b61a340d882a","tid":552910,"uid":19728,"like":0,"dislike":0,"score":0,"quote":{"pid":"fbc8816af30f71fab82f2a13b6536ef9cbbffa7b","tid":552910,"uid":27643,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6d43656b296f34d2907736974318e993372b7f2b","tid":552910,"uid":6833,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-02-07T07:35:30.000Z","msg":"真係睇運<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-07T07:41:23.000Z","msg":"好多人都話係 彩數<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />  驚"},"citedBy":0,"replyTime":"2018-02-07T09:50:32.000Z","msg":"其實我嗰陣都係<br />\n我跟學校去summer program<br />\n全團十六人得我一個畀人狂問問題<br />\n最後仲將我個申請擺去administrative processing <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n拖咗成個禮拜先批"},{"pid":"33820412e092657ad70825b21fe396c1a69cca38","tid":552910,"uid":10189,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-02-07T10:27:44.000Z","msg":"其實wikitravel都有講過<br />\n美帝10年B1B2簽證<br />\n佢係會首先懷疑你有移民既企圖<br />\n你去apply簽證係要show比簽證官睇<br />\n你同原居地有強烈既連結<br />\n譬如工作或者投資<br />\n你怕就出定封工司信<br />\n<br />\n你去apply簽證<br />\n唔撚好同佢講去4日<br />\n佢一定懷疑你<br />\n因為太撚多大陸人台灣人做壞個市<br />\n你可以9plan個concrete d既travel plan<br />\n譬如話會去美國西岸玩10日<br />\n會去SF, LA, Las Vegas<br />\n會同女朋友去咁<br />\n大概預20000蚊<br />\nd錢係返工儲返黎咁<br />\n<br />\n至於帶咩野就有咩帶咩<br />\n我嗰陣個官信我就一分鐘搞掂<br />\n乜都無睇"},{"pid":"1ac9a56e4fef69d1ab1252c0d0c0daab6cafeaa1","tid":552910,"uid":85722,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-07T10:34:01.000Z","msg":"冇技巧架，我記得呢度都有學生問過點解唔批（背景：大學生未畢業，買左機票，聖誕節去）最記得問佢啲錢點黎，佢話自己幫人補習搵，唯一呢點係唔批原因。"},{"pid":"f1cacfb1ff0f1e27e5cb729e8b93032821691ec2","tid":552910,"uid":71860,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2018-02-08T04:57:48.000Z","msg":"點解得4日仲要去美國<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n十幾粒鐘機去到時差都未過又要搭10幾粒鐘機返<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c2f907e2e1e6c72f9d3a77212592b2526f4f4c19","tid":552910,"uid":27643,"like":0,"dislike":5,"score":-5,"quote":{"pid":"f1cacfb1ff0f1e27e5cb729e8b93032821691ec2","tid":552910,"uid":71860,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2018-02-08T04:57:48.000Z","msg":"點解得4日仲要去美國<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n十幾粒鐘機去到時差都未過又要搭10幾粒鐘機返<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-08T07:05:39.000Z","msg":"其實去結婚 <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"6d2ab9632371abf2ffff44e530b5faa2d031066a","tid":552910,"uid":27643,"like":0,"dislike":1,"score":-1,"quote":{"pid":"f1cacfb1ff0f1e27e5cb729e8b93032821691ec2","tid":552910,"uid":71860,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2018-02-08T04:57:48.000Z","msg":"點解得4日仲要去美國<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n十幾粒鐘機去到時差都未過又要搭10幾粒鐘機返<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-08T07:05:56.000Z","msg":"不過可能會去5-6日既"},{"pid":"d45715bf6ddc70665afa7eb34392faccfcddb292","tid":552910,"uid":27643,"like":0,"dislike":1,"score":-1,"quote":{"pid":"1ac9a56e4fef69d1ab1252c0d0c0daab6cafeaa1","tid":552910,"uid":85722,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-07T10:34:01.000Z","msg":"冇技巧架，我記得呢度都有學生問過點解唔批（背景：大學生未畢業，買左機票，聖誕節去）最記得問佢啲錢點黎，佢話自己幫人補習搵，唯一呢點係唔批原因。"},"citedBy":0,"replyTime":"2018-02-08T07:06:22.000Z","msg":"我都有睇 我講老豆比會唔會好啲"},{"pid":"dbe34ac0e4f4278a9ffaf5f7486015c4027ad144","tid":552910,"uid":27643,"like":0,"dislike":1,