bRGk5TlA8%2FYPnv0dhPX6nNrjY8iteK6A9FjwF0%3D&h=f767fd2f\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fs.nextmedia.com%2Frealtime%2Fa.php%3Fi%3D20190627%26s%3D10829391%26a%3D59764109&h=69d1847d\" target=\"_blank\">http://s.nextmedia.com/realtime/a.php?i=20190627&amp;s=10829391&amp;a=59764109</a>"},{"pid":"631cd4cebd18cfa18bc6b87a7d4390696b542082","tid":1261691,"uid":265192,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-27T11:01:58.000Z","msg":"身在曹營"},{"pid":"8e7b35477ca54b05a68a27ba27ae161fba4060b8","tid":1261691,"uid":103156,"like":0,"dislike":0,"score":0,"quote":{"pid":"dbde2a4858c6439ad07d7b4ecbabf78aa8549897","tid":1261691,"uid":103156,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-06-27T10:59:28.000Z","msg":"跑馬地城巴發現可疑物品 EOD到場調查<br />\n <a href=\"http://s.nextmedia.com/realtime/a.php?i=20190627&amp;s=10829391&amp;a=59764109\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fs.nextmedia.com%2Frealtime%2Fa.php%3Fi%3D20190627%26s%3D10829391%26a%3D59764109&d=F8rBtbRGk5TlA8%2FYPnv0dhPX6nNrjY8iteK6A9FjwF0%3D&h=f767fd2f\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fs.nextmedia.com%2Frealtime%2Fa.php%3Fi%3D20190627%26s%3D10829391%26a%3D59764109&h=69d1847d\" data-auto-link target=\"_blank\">http://s.nextmedia.com/realtime/a.php?i=20190627&amp;s=10829391&amp;a=59764109</a><br />\n<a href=\"http://s.nextmedia.com/realtime/a.php?i=20190627&amp;s=10829391&amp;a=59764109\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fs.nextmedia.com%2Frealtime%2Fa.php%3Fi%3D20190627%26s%3D10829391%26a%3D59764109&d=F8rBtbRGk5TlA8%2FYPnv0dhPX6nNrjY8iteK6A9FjwF0%3D&h=f767fd2f\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fs.nextmedia.com%2Frealtime%2Fa.php%3Fi%3D20190627%26s%3D10829391%26a%3D59764109&h=69d1847d\" target=\"_blank\">http://s.nextmedia.com/realtime/a.php?i=20190627&amp;s=10829391&amp;a=59764109</a>"},"citedBy":0,"replyTime":"2019-06-27T11:02:03.000Z","msg":"下午5時許，一部城巴駛至跑馬地大坑道近司徒拔道時，有乘客發現車廂內有一箱可疑物品，通知車長報案。警方接報後，派出爆炸品處理課（EOD）專家到場調查。<br />\n<br />\n受事件影響，大坑道來回方向介乎藍塘道與司徒拔道迴旋處之間的全線現已封閉。現時在大坑道往司徒拔道方向的車龍龍尾已到大坑道近畢拉山道；司徒拔道往大坑道方向的車龍龍尾已到司徒拔道近肇輝臺；黃泥涌峽道往司徒拔道方向的車龍龍尾已到黃泥涌峽道近香港木球會。運輸署呼籲駕駛人士考慮改用其他道路。"},{"pid":"29ba611c4663176d9635bfece25ca6004640d19d","tid":1261691,"uid":44289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-27T11:05:10.000Z","msg":"原來比卡超係我哋嘅陳永仁<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},{"pid":"ff55efce4554b0bf95b4c8c3c3c2f895a18c96ea","tid":1261691,"uid":247454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-27T11:06:29.000Z","msg":"此回覆已被刪除"},{"pid":"c17d93600d0105e4e626936245c3f87ba60faafd","tid":1261691,"uid":256014,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-28T03:48:05.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><br />\n　　講乜都無用，乜都唔做，<span style=\"color: brown;\">如果</span>這班所謂<span style=\"color: green;\">高官</span><span style=\"color: red;\">有心</span><span style=\"color: orange;\">與</span><span style=\"color: green;\">香港市民</span><span style=\"color: red;\">修補關係，</span><span style=\"color: brown;\">應該</span>不追究<span style=\"color: limegreen;\">２０１９０６１２</span><span style=\"color: green;\">被捕人士</span><span style=\"color: limegreen;\">（這是</span><span style=\"color: green;\">我個人</span><span style=\"color: red;\">想法，</span><span style=\"color: brown;\">因為</span><span style=\"color: green;\">警方</span>開槍，<span style=\"color: brown;\">所以</span><span style=\"color: red;\">引起民憤），</span>不知道<span style=\"color: red;\">其他</span><span style=\"color: green;\">香港市民</span><span style=\"color: violet;\">是否</span><span style=\"color: orange;\">與</span><span style=\"color: green;\">我</span><span style=\"color: red;\">一樣想法，</span><br />\n<br />\n<span style=\"color: green;\">　　我自己</span><span style=\"color: brown;\">就</span>不妥協、不認輸、<span style=\"color: red;\">戰鬥到底，勢不兩立。</span></strong></span>"}]}