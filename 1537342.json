br />\n<br />\n我做咗幾日已經多咗好多外國人睇，甚至開始有支那打手過黎留言。<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6b3b8014df7b2c621cb87d1db948de85e507d1fb","tid":1537342,"uid":149357,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T10:06:59.000Z","msg":"<a href=\"https://www.facebook.com/117540932243292/posts/386346788696037?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F117540932243292%2Fposts%2F386346788696037%3Fsfns%3Dmo&d=8FXSm2SwW1drj%2BZzPONh3BZmCTjK%2FM6Kxb2TK%2FvXQ0I%3D&h=84e8e8fe\" data-auto-link target=\"_blank\">https://www.facebook.com/117540932243292/posts/386346788696037?sfns=mo</a>"},{"pid":"3b7f2984467c1b707490ace81bb8f004202084ca","tid":1537342,"uid":149357,"like":0,"dislike":0,"score":0,"quote":{"pid":"6b3b8014df7b2c621cb87d1db948de85e507d1fb","tid":1537342,"uid":149357,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T10:06:59.000Z","msg":"<a href=\"https://www.facebook.com/117540932243292/posts/386346788696037?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F117540932243292%2Fposts%2F386346788696037%3Fsfns%3Dmo&d=8FXSm2SwW1drj%2BZzPONh3BZmCTjK%2FM6Kxb2TK%2FvXQ0I%3D&h=84e8e8fe\" data-auto-link target=\"_blank\">https://www.facebook.com/117540932243292/posts/386346788696037?sfns=mo</a>"},"citedBy":0,"replyTime":"2019-09-04T10:07:50.000Z","msg":"sor 呢個唔係831"},{"pid":"8c1a8ac37689494dbb7f8552086929e4f2a33236","tid":1537342,"uid":50457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-29T20:22:56.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"}]}