d59af2fa2dff39e40","tid":775341,"uid":49689,"like":16,"dislike":0,"score":16,"quote":{"pid":"addb9c52bed31ca695dad80888f340b35d652bf1","tid":775341,"uid":67208,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2018-08-11T08:18:36.000Z","msg":"用手腕力 即係擊球一刻<br />\n順勢屈埋手腕用力? <br />\n<br />\n好似好唔自然<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />  手腕好似好驚屈親"},"citedBy":1,"replyTime":"2018-08-12T01:20:25.000Z","msg":"其實隻手唔駛點用力，連貫動作係全身既力來，直到球拍面擊球前手都唔駛點用力。好似人落鞭咁，落果下先抓緊個handle等全身既力傳到去最遠端。腳向邊個方向基本決定球既軌道方向。<br />\n<br />\n先搞清楚點「用力」，識用力就打咩球類都可以用正確動作少少力做到大大力既效果，好似全力原地跳，收腹鎖住核心肌肉跳同無收腹鬆晒咁跳係明顯差好遠。搞清楚，進步係突飛猛進。<br />\n<br />\n知道有種教法係擊球一刻少少扭手腕，但果個已經係針對修正個出球日，唔係力既傳遞。一步一步來。明白「點用力」玩所有運動都會易理解同上手。"},{"pid":"6111566dc1918262b24d6f9c65cf9cd913198a06","tid":775341,"uid":67208,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d927113bff8b1c99f957dfd59af2fa2dff39e40","tid":775341,"uid":49689,"like":16,"dislike":0,"score":16,"quote":{"pid":"addb9c52bed31ca695dad80888f340b35d652bf1","tid":775341,"uid":67208,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2018-08-11T08:18:36.000Z","msg":"用手腕力 即係擊球一刻<br />\n順勢屈埋手腕用力? <br />\n<br />\n好似好唔自然<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />  手腕好似好驚屈親"},"citedBy":1,"replyTime":"2018-08-12T01:20:25.000Z","msg":"其實隻手唔駛點用力，連貫動作係全身既力來，直到球拍面擊球前手都唔駛點用力。好似人落鞭咁，落果下先抓緊個handle等全身既力傳到去最遠端。腳向邊個方向基本決定球既軌道方向。<br />\n<br />\n先搞清楚點「用力」，識用力就打咩球類都可以用正確動作少少力做到大大力既效果，好似全力原地跳，收腹鎖住核心肌肉跳同無收腹鬆晒咁跳係明顯差好遠。搞清楚，進步係突飛猛進。<br />\n<br />\n知道有種教法係擊球一刻少少扭手腕，但果個已經係針對修正個出球日，唔係力既傳遞。一步一步來。明白「點用力」玩所有運動都會易理解同上手。"},"citedBy":1,"replyTime":"2018-08-12T01:48:46.000Z","msg":"多謝指教"},{"pid":"a648d267cee67b9ae7be8f871ad5fb97f85f309a","tid":775341,"uid":130901,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-12T01:57:10.000Z","msg":"其實左手打大肶"},{"pid":"701db31832a0913e2d28ee608143f7b864e0559f","tid":775341,"uid":45285,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-12T02:29:37.000Z","msg":"拍拉重磅d，打幾球高遠球自然有聲<img src=\"/assets/faces/