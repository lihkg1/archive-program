faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5a3359b27f48372802fcadbcf5124116f3055f64","tid":785802,"uid":147721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T17:17:23.000Z","msg":"以牛頓力學既框架去睇 PV=nRT"},{"pid":"6acd03c3b2158179fc330b1e1de24ec374dea6cd","tid":785802,"uid":130897,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-19T18:25:25.000Z","msg":"熱能用ir既形式散開去 <br />\n所以個粒子已經無哂能量<br />\n係到隨機運動"},{"pid":"735c812da91e25efba5eac8f1bc143deb98db113","tid":785802,"uid":199211,"like":0,"dislike":0,"score":0,"quote":{"pid":"6acd03c3b2158179fc330b1e1de24ec374dea6cd","tid":785802,"uid":130897,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-19T18:25:25.000Z","msg":"熱能用ir既形式散開去 <br />\n所以個粒子已經無哂能量<br />\n係到隨機運動"},"citedBy":2,"replyTime":"2018-08-19T18:26:29.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />  粒子直線飛仲點散能量"},{"pid":"cde5ec03d9064ff9b645b055fd1c9e5b02649e8e","tid":785802,"uid":112551,"like":0,"dislike":0,"score":0,"quote":{"pid":"735c812da91e25efba5eac8f1bc143deb98db113","tid":785802,"uid":199211,"like":0,"dislike":0,"score":0,"quote":{"pid":"6acd03c3b2158179fc330b1e1de24ec374dea6cd","tid":785802,"uid":130897,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-19T18:25:25.000Z","msg":"熱能用ir既形式散開去 <br />\n所以個粒子已經無哂能量<br />\n係到隨機運動"},"citedBy":2,"replyTime":"2018-08-19T18:26:29.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />  粒子直線飛仲點散能量"},"citedBy":0,"replyTime":"2018-08-19T18:35:59.000Z","msg":"輻射散熱<br />\n另外，外太空有好多宇宙射線，粒子起太空都唔係直射"},{"pid":"77582ab968aa2e1e709c3ead0fadf1cd3e0f4180","tid":785802,"uid":41243,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-19T18:38:43.000Z","msg":"Real gas會有KE同PE, 因為氣體粒子之間個bond係attraction, 所以PE&lt;0<br />\n當氣體粒子喺vacuum之中擴散, 粒子平均距離遠咗 =&gt; PE less negative (increased) =&gt; KE decrease<br />\n所以氣體應該會冷卻咗<br />\n粒子唔會以直線飛行, 你假設咗粒子之間冇interaction, 呢樣只有喺idealized咗既ideal gas情況先係咁"},{"pid":"5dc3ad6efccfd6027cb91c2bf2a40236fed8dcc9","tid":785802,"uid":41243,"like":0,"dislike":0,"score":0,"quote":{"pid":"735c812da91e25efba5eac8f1bc143deb98db113","tid":785802,"uid":199211,"like":0,"dislike":0,"score":0,"quote":{"pid":"6acd03c3b2158179fc330b1e1de24ec374dea6cd","tid":785802,"uid":130897,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-19T18:25:25.000Z","msg":"熱能用ir既形式散開去 <br />\n所以個粒子已經無哂能量<br />\n係到隨機運動"},"citedBy":2,"replyTime":"2018-08-19T18:26:29.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />  粒子直線飛仲點散能量"},"citedBy":0,"replyTime":"2018-08-19T19:59:17.000Z","msg":"粒子係many body motion ，因為佢哋之間有potential ，軌跡係chaotic<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bd0ae1f2e7f26a52e80fbbee7f5ed45ffe0d8379","tid":785802,"uid":41243,"like":0,"dislike":0,"score":0,"quote":{"pid":"77582ab968aa2e1e709c3ead0fadf1cd3e0f4180","tid":785802,"uid":41243,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-19T18:38:43.000Z","msg":"Real gas會有KE同PE, 因為氣體粒子之間個bond係attraction, 所以PE&lt;0<br />\n當氣體粒子喺vacuum之中擴散, 粒子平均距離遠咗 =&gt; PE less negative (increased) =&gt; KE decrease<br />\n所以氣體應該會冷卻咗<br />\n粒子唔會以直線飛行, 你假設咗粒子之間冇interaction, 呢樣只有喺idealized咗既ideal gas情況先係咁"},"citedBy":1,"replyTime":"2018-08-20T09:05:43.000Z","msg":"另外仲有em radiation<br />\n氣體粒子一係就係dipole一係就charged particles<br />\nAccelerated dipole/charged particles會有em radiation 散走能量<br />\nIdeal gas的確應該冇溫度變化"},{"pid":"02ddef25f4e298144efefda0f66d3b464f042e93","tid":785802,"uid":41243,"like":0,"dislike