aces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4d70483fbd706510aea4ddf0ac7ca0ec979bc647","tid":1492582,"uid":62409,"like":15,"dislike":0,"score":15,"citedBy":0,"replyTime":"2019-08-21T02:59:34.000Z","msg":"姐係人地識得快必都唔識c君<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"267e5ecaa9f8ae9f95ab121909f325eeeef77263","tid":1492582,"uid":90601,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T03:00:19.000Z","msg":"影武者 <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"69d576a7a0824612ec76b6b78709fcdd3608c598","tid":1492582,"uid":206812,"like":8,"dislike":0,"score":8,"quote":{"pid":"997c489a5d1b792c8c1c043926f2b83ac75f7e47","tid":1492582,"uid":76098,"like":128,"dislike":2,"score":126,"citedBy":9,"replyTime":"2019-08-21T02:16:47.000Z","msg":"果晚同男朋友嗌完交唔見咗銀包 入去差館落個包<br />\n點知有幾個警察包抄 問我乜事乜事我話係急事急事<br />\n但係呢啲小事最後轉介比警署入面其中一個CID<br />\n幾日後去High-tea 岩岩好放低筷子<br />\n佢打黎叫我快啲乖啲 過黎警署認領番個ID<br />\n仲借啲意岩岩好夠鐘放工<br />\n不如落去樓下個酒吧放一放鬆<br />\n我當時無為意六神無主 <br />\n點會估到呢個便衣原來係一個騙子<br />\n加上隔離係警署有關二哥頂住 <br />\n一杯兩杯猜下枚猜下枚終於不醒人事<br />\n到我醒返果時 哎 我望見我既身體<br />\n啲衫褲係我隔離 個警察食緊煙仔<br />\n我係咪要報警 我就係去報警<br />\n所以結果攪到今日係差館衣衫不整<br />\n以前有警察保護市民 今日有警察侵犯証人<br />\n到底邊一個敢對邊一個差人以後都咁信任 <br />\n當警察都唔可信試問"},"citedBy":2,"replyTime":"2019-08-21T03:00:56.000Z","msg":"仲有十年人事<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"9ed4fee156ff69df9de63cfa19b7040b7b85c7fa","tid":1492582,"uid":265192,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T03:01:59.000Z","msg":"<img src=\"https://na.cx/i/6U5imtL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6U5imtL.jpg&h=42781caa&s={SIZE}\" /><br />\n<br />\n<img src=\"https://na.cx/i/BqKvczp.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBqKvczp.jpg&h=3660ce63&s={SIZE}\" /> <br />\n<br />\n<img src=\"https://na.cx/i/MPz3xzq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FM