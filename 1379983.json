r />\n真正攪抄其實喺老解"},{"pid":"29b4c320b23ceb6c5fe132ad45c607768f31bf34","tid":1379983,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T04:50:12.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"048b6a6a20799258c2bd2d2ec92c76aa0d062909","tid":1379983,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T07:17:12.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"fef9065d9053e0ebae93bd0f5b43e51bbf4b7bc1","tid":1379983,"uid":208452,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T07:17:52.000Z","msg":"<span style=\"font-size: large;\"><span style=\"color: red;\">WFC </span></span><br />\n<br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">今日(7月29)1500-1830</span></span>會有義工係<span style=\"color: red;\"><span style=\"font-size: large;\">旺角東天橋</span></span>擺街站等無上連登的市民都可以寫底感受比我地,希望大家支持<br />\n<span style=\"color: red;\"><span style=\"font-size: x-large;\">【眾籌】 已集合超過1000名巴絲感想 香港編年史</span></span><br />\n<a href=\"https://lihkg.com/thread/1379634/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1379634/page/1</a>"}]}