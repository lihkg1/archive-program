ces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-06T08:48:00.000Z","msg":"十一之後先泡制香港"},"citedBy":1,"replyTime":"2019-09-06T09:15:19.000Z","msg":"十月二凌晨即出一萬武警加一萬解放軍"},"citedBy":0,"replyTime":"2019-09-06T09:20:23.000Z","msg":"快手啲<br />\n手足返屋企睇新聞啦<br />\n攬炒成功"},{"pid":"ef7fe493ea16395cb15002ea67b425342312cb78","tid":1546240,"uid":162954,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-09-06T09:20:51.000Z","msg":"我地要繼續高調 唔好俾佢停"},{"pid":"af96c82f08b3e2a3cb4463d0e16b8b3e2b412cf8","tid":1546240,"uid":60562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T09:21:10.000Z","msg":"早幾日港澳扮先開完會 邊度低呀"},{"pid":"ad554330862f50afaf2a8ed33dec706d952c472c","tid":1546240,"uid":61280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T09:22:03.000Z","msg":"<blockquote><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><span style=\"color: gold;\"><span style=\"font-size: xx-large;\">2 </span></span><br />\n<br />\n👉🏻<strong><span style=\"color: gold;\"><ins>中英聯合聲明的謬誤</ins></span></strong><br />\n<br />\n若果一件物件是從來未曾擁有過，拿到手上是談不上「恢復」及「收回」的。同樣道理，1997年前中華人民共和國從來未曾對香港行使過主權，如何談得上「恢復行使主權」？中華人民共和國的漢族（即「中國人民」）從來也沒有擁有過香港，試問又如何「收回」香港？<br />\n<br />\n因此，中華人民共和國取得香港的土地應該形容為「兼併」或「呑併」。<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><span style=\"color: gold;\"><span style=\"font-size: xx-large;\">3 </span></span><br />\n<br />\n👉🏻<strong><span style=\"color: gold;\"><ins>不平等條約無效論是謊言</ins></span></strong><br />\n<br />\n如兩國以和平條約（Peace Treaty）終止戰爭，而某些領土由一國割讓予另一國，則在國際法中亦被視為透過割讓（Cession）而取得主權。過去的國際法觀點認為，以戰爭解決國與國之間的爭議屬國家的權利，而「和平條約」的作用是令交戰雙方以某些條款（包括部份領土的轉讓）為代價以終止戰爭。因此，按照「時空性原則」，1842年及1860年割讓香港島及九龍半島均符合當時的國際法。<br />\n<br />\n國際法中，領土的轉讓只有是否合法，而沒有平等不平等。<br />\n<br />\n在中華人民共和國成為國家之前，英國已經從清帝國手中符合國際法地取得香港的主權。另一方面，中華人民共和國亦從來沒有繼承過清帝國的仼何權益。因此，《中英聯合聲明》中所謂「對香港恢復行使主權」的「恢復」根本無從談起，並且只是一個猜想。</blockquote><br />\n<blockquote><img src=\"https://na.cx/i/Cbwr6sW.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCbwr6sW.png&h=7ee87500&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/tPAHEN9.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FtPAHEN9.png&h=e166e8fb&s={SIZE}\" /><br />\n知情不報者 你地都係半個兇手！<br />\n你唯一可以做就係站出黎 講個真相比全香港市民聽！ ！ 還死者一個清白！</blockquote><br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">肛犬：<img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fuck.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n別再喱係電視後面，敢就走出黎攞出CCTV之類証據黎証明831冇人死冇人重傷囉仆街共狗！！！</span></span></strong></span><br />\n<img src=\"https://img.eservice-hk.net/upload/2019/09/05/104231_3a6ab00f3ec1c5387f321c23ffcf1893.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F09%2F05%2F104231_3a6ab00f3ec1c5387f321c23ffcf1893.jpg&h=7d68f7dd&s={SIZE}\" /><br />\n<br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\">必問：<br />\n<br />\n<br />\n有幾倍OT收，係咪仲要&quot;好合理要屌埋女示者&quot;咁辛苦？？？<img src=\"/assets/faces/big/love.gif\" class=\"hkgmoji\" /></span></span></span></strong><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>民主訴求，缺一不可；<br />\n<br />\n以眼還眼，鷹犬全鎖；<br />\n<br />\n有錯企定，即決勿拖！<br />\n<br />\n民主斬件，仲當我傻！<br />\n<br />\n屌你老母，未贏收科？<br />\n<img src=\"/assets/faces/big/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><br />\n</strong></span></span></span></span><br />\n<strong><strong><span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\"><span style=\"color: blue;\"><span style=\"font-size: xx-large;\">除非你係個班那埋護照旁身嘅扮民霸權，永續利益獨賣囉！！！</span></span></span></span></strong></strong>"},{"pid":"39c7e4cff622efd3120c3df4d296f81e9cb594ae","tid":1546240,"uid":180124,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T09:22:47.000Z","msg":"好撚驚人權法案"},{"pid":"b3a42b2b0c31bc6e33c28fbf4086f6a263d768fb","tid":1546240,"uid":264992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T09:23:04.000Z","msg":"咪就係俾美國揸春袋，又無條件鎮壓香港所以咪要死狗<br />\n<br />\n我估佢下一步會清算黑警再測試民情"},{"pid":"0e0fc8ce79350abe0115ce965c6fe259c70a7289","tid":1546240,"uid":25601,"like":1,"dislike":0,"score":1,"quote":{"pid":"e8159eefc4c04dc92b822686f4515658b8f25001","tid":1546240,"uid":183758,"like":0,"dislike":0,"score":0,"citedBy":6,"replyTime":"2019-09-06T08:11:04.000Z","msg":"會唔會有咩陰謀<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-06T09:24:03.000Z","msg":"因為十一就快到 佢要用兩星期時期黎清理現場<br />\n<br />\n仲有無論十月一點都好 中共對反抗者一向不手軟"},{"pid":"ff7437cca14aaec24fb674901660b364d0e8083c","tid":1546240,"uid":51665,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T09:24:40.000Z","msg":"唔低姿態股市點升 股市唔升點派貨<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ccdaf20c6c117961cc4bb885a3903018d48e526a","tid":1546240,"uid":10402,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-06T09:25:19.000Z","msg":"理閪得佢，繼續做我地應該要做嘅野，支那任何野都係呃鳩人，一係氹你一係嚇鳩你。"},{"pid":"95b5ca6fd30a4ba85af35b61fa1b91d033aec9f3","tid":1546240,"uid":3149,"like":0,"dislike":0,"s