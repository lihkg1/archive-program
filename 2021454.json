,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-18T01:30:48.000Z","msg":"佢得三十歲"},{"pid":"38bcb638dffb0fd0180cfc11bdff12ce633f8f53","tid":2021454,"uid":25771,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-18T02:21:56.000Z","msg":"今年好多助攻"},{"pid":"34707c671b313ac468a87e8625b1450fe42cf604","tid":2021454,"uid":84259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-18T02:54:45.000Z","msg":"梅拿<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"}]}