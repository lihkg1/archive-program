塊前沒有把玻璃瓶抹乾淨，使瓶外殘餘的汽油燃燒起來，導致投擲者手部燒傷。<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>此外，用作引信的布塊來封住玻璃瓶也是錯誤的作法。</strong></span></span>"},{"pid":"15625275b3dbb268c307e68e94a7242c78dbae45","tid":1573661,"uid":35456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T06:49:57.000Z","msg":"此回覆已被刪除"},{"pid":"0aac5bd5ef1e5a6ba501fa2e5228e26a60a59ed0","tid":1573661,"uid":62025,"like":0,"dislike":0,"score":0,"quote":{"pid":"20bec507fed36cd149e53e2eb06204865b5077f2","tid":1573661,"uid":142686,"like":0,"dislike":0,"score":0,"quote":{"pid":"b1cb6c2908f25b83c1c0ece4ff1a41ad15c3c0b2","tid":1573661,"uid":142686,"like":1,"dislike":0,"score":1,"quote":{"pid":"7315d27719d510e60f7c769e07c7f0fe74cd4fda","tid":1573661,"uid":62025,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2019-09-21T06:12:00.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-21T06:48:41.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-09-21T06:49:26.000Z","msg":"有*"},"citedBy":1,"replyTime":"2019-09-21T06:50:04.000Z","msg":"<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"768851ea3f6e23083ca19796c239a4da1303b360","tid":1573661,"uid":20933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T06:51:14.000Z","msg":"推"},{"pid":"510e33aa1c1f23ef5ccd4c07264eaa10f0b01e81","tid":1573661,"uid":262043,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-21T06:52:18.000Z","msg":"員佐級真係比毅進仔再低一個層次既生物黎<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"fbcd41f01f06711fd044659f2f8f6f312741db89","tid":1573661,"uid":209140,"like":0,"dislike":0,"score":0,"quote":{"pid":"0aac5bd5ef1e5a6ba501fa2e5228e26a60a59ed0","tid":1573661,"uid":62025,"like":0,"dislike":0,"score":0,"quote":{"pid":"20bec507fed36cd149e53e2eb06204865b5077f2","tid":1573661,"uid":142686,"like":0,"dislike":0,"score":0,"quote":{"pid":"