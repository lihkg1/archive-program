\" /> <br />\n<br />\n但點解要揀支那呢種垃圾人種<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"27ff704f39736790be5732c949d8a60a5ba93f13","tid":400534,"uid":11254,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-15T01:05:58.000Z","msg":"<img src=\"http://a1.att.hudong.com/02/33/01200000028610136323337395770.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fa1.att.hudong.com%2F02%2F33%2F01200000028610136323337395770.jpg&h=6183c95d&s={SIZE}\" />"},{"pid":"afe6c3715fd6b3eb493dc7f8321b4bb7fcce6d22","tid":400534,"uid":23833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-15T01:06:58.000Z","msg":"<span style=\"color: green;\">帽</span>"}]}