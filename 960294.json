\" />"},{"pid":"24d0b2d8f0b4bca19c9b2350b884aca2eb943fc5","tid":960294,"uid":155197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-31T10:53:26.000Z","msg":"即刻屌佢老母啦，人善被狗恰"},{"pid":"2ebf9c09ae2ba72ac43e72571de1dd3432eefb43","tid":960294,"uid":26451,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-31T10:54:48.000Z","msg":"此回覆已被刪除"},{"pid":"653d32ca90bb3799e76495407df53ee66bdab147","tid":960294,"uid":18772,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-12-31T10:56:36.000Z","msg":"將杯汽水掉去炸薯條果度炸撚死佢<img src=\"/assets/faces/lm2xm/haha.gif\" class=\"hkgmoji\" />"},{"pid":"f475ad89ffd3442ce5192297cafd495b491a8da5","tid":960294,"uid":181829,"like":4,"dislike":1,"score":3,"quote":{"pid":"c65619dddbb5725bf13fb219f320bf35fc51fc78","tid":960294,"uid":740,"like":3,"dislike":2,"score":1,"citedBy":1,"replyTime":"2018-12-31T06:03:43.000Z","msg":"講到尾都係啲海龜貪玩，suck啲飲筒入鼻哥窿<img src=\"/assets/faces/xm/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-31T11:38:51.000Z","msg":"你重點搞撚錯曬喎sis<br />\n個問題係點解d飲管會最後流左入海度<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <br />\n到頭來咪又係d大公司on99處理不善，垃圾唔係放入堆填區，而係省個少少外判比無良垃圾處理商搞到海洋受污染，所以先令到海龜受傷<br />\n所以依家對於大企業來講，公又係佢，字又係佢，仲有環保左膠幫佢護航，佢玩撚曬啦<img src=\"/assets/faces/xm/tongue.gif\" class=\"hkgmoji\" /> <br />\n仲有個環保光環拎，過多排可能cut埋薯條盒、漢堡包盒<img src=\"/assets/faces/lm2xm/smile.gif\" class=\"hkgmoji\" />"},{"pid":"cdae0d529bbd5c222d418b203f4b9023eacfff12","tid":960294,"uid":133375,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-12-31T12:06:13.000Z","msg":"on9<br />\n成杯野車落佢塊面<br />\n同佢講：今次都唔飲喇，抹地啦傻鳩<br />\n<img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" />"},{"pid":"dde996391b8a4b605196548484d6b7c1706b524d","tid":960294,"uid":1251,"like":0,"dislike":0,"score":0,"quote":{"pid":"8f5f01e605d5fb63df37d0373071b3d09c3f646b","tid":960294,"uid":200132,"like":104,"dislike":4,"score":100,"citedBy":3,"replyTime":"2018-12-29T10:22:54.000Z","msg":"我自問好有禮貌，唔串唔大聲無講粗口<br />\n駛唔駛咁對我丫？"},"citedBy":0,"replyTime":"2018-12-31T12:09:01.000Z","msg":"佢一開始西面你就應該屌柒佢啦"},{"pid":"f10dc33b66712c55d01a078c15793b853186d4c2","tid":960294,"uid":180515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-31T12:38:58.000Z","msg":"晒鳩氣根本係慳錢攞光環，大快活畀紙飲筒，其他快餐店點解唔撚跟。"},{"pid":"8d7a14bb99e8234af626fc8155c68fb0f7078464","tid":960294,"uid":45189,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-31T13:19:58.000Z","msg":"下次講英文 <br />\nPlease give me a straw <br />\n全程用英文<img src=\"/assets/faces/xm/wink.gif\" class=\"hkgmoji\" />"},{"pid":"805fc43d4f77e42db487ef3aa0391a4a44b50a83","tid":960294,"uid":1643,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-12-31T14:44:10.000Z","msg":"すみません、ストローはありますか。"},{"pid":"feea077071f3eb00d7b785d915015c04a2c35634","tid":960294,"uid":147079,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-01-01T16:14:19.000Z","msg":"此回覆已被刪除"},{"pid":"fced16c9c18b54bd676bd097efa34c363f517a99","tid":960294,"uid":147079,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-01T16:14:39.000Z","msg":"此回覆已被刪除"},{"pid":"df0bfaa00362b6d8753f568b98dc99dfa7afb4e7","tid":960294,"uid":102514,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-01T17:48:33.000Z","msg":"試過上次去叫左杯奶昔外賣，飲管都唔俾點飲呀大佬"},{"pid":"0f418a39c222fd4a9b033f7179aaad2a6c89ac4c","tid":960294,"uid":12412,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-01T17:55:01.000Z","msg":"下年你連個餐盤都無埋呀。想叫外賣？你連紙袋都唔比呀。遲早薯條無盒就咁比你"},{"pid":"16cb7c0fb4b1bfeb26e691fb9f222fed6ea0d8e5","tid":960294,"uid":117032,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-01T18:02:53.000Z","msg":"你試下拍撚哂枱又屌老母咁仲卑唔卑<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <br />\n佢嚇到瀨屎啦仲卑串返轉頭"},{"pid":"4f9980c8c314f45067079520e33e7606d418093f","tid":960294,"uid":122570,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-01T18:05:46.000Z","msg":"你咪自己帶囉<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"}]}