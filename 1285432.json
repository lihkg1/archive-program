d826254f33f44faf12cf158fc06f8139d","tid":1285432,"uid":3020,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2019-07-04T17:28:52.000Z","msg":"佢自認無屈"},{"pid":"1fca7c9ec1a2f4769669a570d7d5b7fdd9404ada","tid":1285432,"uid":134665,"like":1,"dislike":0,"score":1,"quote":{"pid":"670a814d826254f33f44faf12cf158fc06f8139d","tid":1285432,"uid":3020,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2019-07-04T17:28:52.000Z","msg":"佢自認無屈"},"citedBy":1,"replyTime":"2019-07-04T17:29:55.000Z","msg":"冇認咪屈"},{"pid":"0971182f8e066c56c4ec646c4baccdcc22c16403","tid":1285432,"uid":1402,"like":0,"dislike":0,"score":0,"quote":{"pid":"1fca7c9ec1a2f4769669a570d7d5b7fdd9404ada","tid":1285432,"uid":134665,"like":1,"dislike":0,"score":1,"quote":{"pid":"670a814d826254f33f44faf12cf158fc06f8139d","tid":1285432,"uid":3020,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2019-07-04T17:28:52.000Z","msg":"佢自認無屈"},"citedBy":1,"replyTime":"2019-07-04T17:29:55.000Z","msg":"冇認咪屈"},"citedBy":0,"replyTime":"2019-07-04T18:25:30.000Z","msg":"原來你識連狗.............依家先知 <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\nrepost番個得到牙井認證既回覆先 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n<blockquote>奈亞子咪開nacx果個 jaga 咁都唔識  <br />\n不過以我所知，奈亞子冇理nacx好耐<br />\n唔好問我點解知 因為我真係知 <img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /><br />\n<br />\nlihkg有自己既image cache server <br />\n可以同時刪埋2邊既圖仲有邊個?  <br />\n或者咁講啦  <br />\n<strong>可以郁得lihkg image cache server仲有邊個?</strong><br />\n<br />\n另外，你唔好成日spin黎spin去啦 <img src=\"/assets/faces/husky/haha.gif\" class=\"hkgmoji\" /><br />\n一時又話admin唔做野 一時又話同奈亞子有關 <br />\n明明自己開post講緊ebb 依家一野spin撚左去大西洋咁遠 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n回應番D圖先 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<code>用明朝嘅劍斬清朝嘅官</code>  <br />\n當時既圖區 <br />\nACG貼圖區(27) 我要成為只屬於櫻的正義夥伴<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/gOOwHMX\" target=\"_blank\">https://lih.kg/gOOwHMX</a><br />\n<br />\n1.  <br />\nadmin一次過bam柒晒有份貼既人<br />\n再加一句  <code>警告：管理團隊已收到有關本主題之大量投訴，在此提醒會員請勿直接張貼色情圖片。如情況持續，違規之會員將被永久封鎖。</code> <br />\n無論我地之前post幾多bam圖都好，都係呢次bam左就算<br />\n亦都係admin對我地既最後一次警告<br />\n錯就企定 我地比其他人周到正 打死無怨啦 <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n2.  而你為左清除異己  走去report晒之前既舊post 務求置我地於死地<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\nLIHKG動漫台ACG區ban圖精華有露點,繪畫兒童露點圖<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/cwvOKT\" target=\"_blank\">https://lih.kg/cwvOKT</a><br />\n<br />\n好啦 又再返去1到<br />\n即係admin都已經處理左呢單野，所以選擇刪圖處理<br />\n因admin管理不善，發現唔到，但admin佢地又已經做左野啦喎<br />\n咁即係再bam多次係冇需要既(?)<br />\n而呢堆圖既時間點係Post27之前既 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n如果當時admin選擇bam多次/永久<br />\n我地都會接受 我地都尊重佢地既決定 <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n基於佢地刪圖既決定<br />\n我地除左講多謝之外 搵唔到野講 <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n講完</blockquote><br />\n<br />\nfyi: 成日都話我錯，你地私怨扮咩正義？ <br />\n- 分享自 LIHKG 討論區 <br />\n<a href=\"https://lih.kg/iFvQgnX\" target=\"_blank\">https://lih.kg/iFvQgnX</a>"},{"pid":"3df02a104253a8d822ecb0065b53118e913e0eb9","tid":1285432,"uid":134665,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-04T18:27:21.000Z","msg":"咪屈"},{"pid":"42062bbfc7941666e6301b2e82108309891ebea3","tid":1285432,"uid":1402,"like":0,"dislike":0,"score":0,"quote":{"pid":"3df02a104253a8d822ecb0065b53118e913e0eb9","tid":1285432,"uid":134665,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-04T18:27:21.000Z","msg":"咪屈"},"citedBy":1,"replyTime":"2019-07-04T18:29:13.000Z","msg":"真係識人好過識字 ging ar ching <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"f844a7e2f3944990a729a687c958cc15fa0e2715","tid":1285432,"uid":134665,"like":0,"dislike":0,"score":0,"quote":{"pid":"42062bbfc7941666e6301b2e82108309891ebea3","tid":1285432,