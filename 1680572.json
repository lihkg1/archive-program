 src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f1f86870006355b82d872a3dfca7f9e8265ab187","tid":1680572,"uid":254594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-29T04:05:13.000Z","msg":"蚹蛤蟈蜻<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"3f037b866cc6f6ee0206d231bc900993a76266f2","tid":1680572,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-30T00:59:49.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"98226369f4dadecd7c4baf7b9418286019a2e56d","tid":1680572,"uid":202464,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b0fbef08af1410402a603e677b0d4b0f72117af","tid":1680572,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-29T02:21:57.000Z","msg":"<span style=\"font-size: x-large;\">連登仔 : 死者家屬朋友去咗邊? </span>"},"citedBy":0,"replyTime":"2019-10-30T01:02:50.000Z","msg":"連登仔：要fc左先可以推"}]}