.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKC2Lznw.jpg&h=ac6771fc&s={SIZE}\" />"},{"pid":"00f18d74b4cc3d35d7e97cf94349cb6040bd3da2","tid":2414780,"uid":70487,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-19T16:21:08.000Z","msg":"DJ Trump<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"a2a5e9cd7de98504f5eef513b137dfacf5fee0be","tid":2414780,"uid":231480,"like":5,"dislike":3,"score":2,"citedBy":1,"replyTime":"2021-02-19T16:21:46.000Z","msg":"唔好當人均GDP高係代表啲人真係有錢咗 <br />\n利申愛侵力"},{"pid":"cfa232b11cd8fe84cbecbf1881e600eb5072b454","tid":2414780,"uid":23810,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-19T16:21:57.000Z","msg":"樓主本書邊度有得買？"},{"pid":"74c5800bef54e574429667b6142e8ff9dd8ef429","tid":2414780,"uid":112581,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-19T16:24:10.000Z","msg":"美國唔衰落?<br />\n你問過支那祖未？"},{"pid":"2c2cfd4d7efb1449d6d4e1c435a384feb9a6bc01","tid":2414780,"uid":55458,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-19T16:24:56.000Z","msg":"美國有啲政策幫助喎<br />\n你睇吓香港啲政策點樣玩鳩自己啲人"},{"pid":"2b620395d05716c386fecd71100b7bd694214953","tid":2414780,"uid":254165,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-19T16:25:33.000Z","msg":"想買本書<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b97fb84a702c91dffaefecb46d112615ec2b2181","tid":2414780,"uid":156090,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-19T16:26:05.000Z","msg":"呢d野都唔關窮人事啦，到到都貧富懸殊咁鬼勁 無限qe窮人地獄"},{"pid":"b04a03bfef35f9238869574aa2c326198f94ab53","tid":2414780,"uid":7369,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-19T16:27:15.000Z","msg":"香港就快收皮啦，得donki支撐大局咋<img src=\"/assets/faces/lny/cry.gif\" class=\"hkgmoji\" />"},{"pid":"c4bf51618dee5e73bf9fad55769a133a9c9905d5","tid":2414780,"uid":52658,"like":0,"dislike":0,"score":0,"quote":{"pid":"cfa232b11cd8fe84cbecbf1881e600eb5072b454","tid":2414780,"uid":23810,"like":0,"dislike":0,"score":0,"cite