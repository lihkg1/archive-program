ets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"019097b95ce8b45c981b0f1a2a8b6cb345577d3c","tid":1013272,"uid":35746,"like":0,"dislike":0,"score":0,"quote":{"pid":"7ea07524a337a7b52a1ee932f833be313033c3b9","tid":1013272,"uid":222136,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-02-11T08:42:04.000Z","msg":"如果自己一個跟團<br />\n真係未試過<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-02-14T08:29:00.000Z","msg":"我試過，最後問我同唔同領隊同房，我話ok<br />\n個導遊好後生2x，勁好傾<br />\n<br />\n你包房都得，但貴d"},{"pid":"1ac95c0873940f1d7c3a4c0f15878de38d456d32","tid":1013272,"uid":57802,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2019-02-14T08:35:40.000Z","msg":"自己單拖去過兩星期<br />\n<br />\n單拖去要有大心臟<br />\n你預去左十幾廿年前既大陸咁<br />\n<br />\n周街既人都會望實你<br />\n你唯一可以靠既就係Hostel老板或者其他Backpackers<br />\n<br />\n我去果陣基本上唔敢出夜街<br />\n太陽落山就番Hostel <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n<br />\n交通唔方便<br />\n城市城市之間得火車大巴郵輪<br />\n<br />\n去到其實都係join local tour<br />\n<br />\n自己去唯一好處係玩埋其他國家<br />\n<br />\n你淨係去埃及跟團會比較好"},{"pid":"31573a1e35868be41922b7ef1132ff8c51a55103","tid":1013272,"uid":33939,"like":0,"dislike":1,"score":-1,"quote":{"pid":"019097b95ce8b45c981b0f1a2a8b6cb345577d3c","tid":1013272,"uid":35746,"like":0,"dislike":0,"score":0,"quote":{"pid":"7ea07524a337a7b52a1ee932f833be313033c3b9","tid":1013272,"uid":222136,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-02-11T08:42:04.000Z","msg":"如果自己一個跟團<br />\n真係未試過<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-02-14T08:29:00.000Z","msg":"我試過，最後問我同唔同領隊同房，我話ok<br />\n個導遊好後生2x，勁好傾<br />\n<br />\n你包房都得，但貴d"},"citedBy":1,"replyTime":"2019-02-14T08:39:05.000Z","msg":"女？"},{"pid":"88725092a919299f4ee9af9530135b8daaad934b","tid":1013272,"uid":35746,"like":1,"dislike":0,"score":1,"quote":{"pid":"31573a1e35868be41922b7ef1132ff8c51a55103","tid":1013272,"uid":33939,"like":0,"dislike":1,"score":-1,"quote":{"pid":"019097b95ce8