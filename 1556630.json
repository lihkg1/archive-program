ss%2BeERvjOeOk%3D&h=60be045d\" data-auto-link target=\"_blank\">https://t.me/WallPaperENews</a>"},{"pid":"fdef8f6e47dc597d355b51c3642f49fee9467bc0","tid":1556630,"uid":91397,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T02:04:44.000Z","msg":"推"},{"pid":"e62e430ade102e0cc6cc9c923cff58e4e4736bbd","tid":1556630,"uid":91397,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T02:05:03.000Z","msg":"推"},{"pid":"91e0c3c41488a6f9f84c99635c8aed42c7cd65dc","tid":1556630,"uid":91397,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T02:05:13.000Z","msg":"推"},{"pid":"7da4b66d6bf70e741c96a2d88e36aa28ae470bf0","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"quote":{"pid":"7eaa1258c243911005f309f0fcdbeb65b4f8e5db","tid":1556630,"uid":228894,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-09-10T01:54:01.000Z","msg":"傳媒要配合<br />\n同埋要有啲公認係社會有影響力嘅人加入<br />\n咁先有用..."},"citedBy":0,"replyTime":"2019-09-10T02:07:15.000Z","msg":"可能之後會有<br />\n但目前都要議會面世先"},{"pid":"a45faf354866848897be4a43d828a19ae46b2361","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T02:56:52.000Z","msg":"推"},{"pid":"2e1067ee83e28b0a7c7794f5ceaa4148a2a29cba","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T03:57:39.000Z","msg":"推"},{"pid":"5a4bac7f502afd80681039301fe20f764ecb4878","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T04:08:21.000Z","msg":"推"},{"pid":"cc4f8372a7f33fca5565ea589657aaceb4e3a761","tid":1556630,"uid":3822,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T04:09:33.000Z","msg":"幫推"},{"pid":"5878545d4a170f26b7c8a23dd224cb3910fdda5c","tid":1556630,"uid":111908,"like":1,"dislike":0,"score":1,"quote":{"pid":"12ded1b2cfac49ae8702bacb7e74ee182951301e","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"quote":{"pid":"2535a7f3d3127d90492722a7a4dc028a6592eca5","tid":1556630,"uid":111908,"like":1,"dislike":0,"score":1,"quote":{"pid":"e6500fcc598ac90db74cbdd20fddc9c08aa7db91","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-09T22:04:16.000Z","msg":"上一次post<br />\n[ 召喚IT人 ] 成立人民議會既可行方法<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/dNBffS\" data-auto-link target=\"_blank\">https://lih.kg/dNBffS</a><br />\n<br />\n經過第一次post，好高興有唔少人都有興趣，一齊組左一隊team。經過一輪討論同埋開會之後，有以下進展。<br />\n<br />\n進展：<br />\n更新左議會流程（目前仲有問題）<br />\n揾到一部分人加入develop team, 目前back-end team有四人（但人手仲係嚴重唔夠）<br />\n認證方式有更多既建議<br />\n<br />\n目的：<br />\n建立民意直接影響立法的渠道<br />\n削弱現有政府既認受性, 權威<br />\n抗衡現有政府<br />\n更方便收集民意<br />\n<br />\n目前計劃：<br />\n建構一個完善既民間議會制度<br />\n目前決定一開始整responsive web, 之後視乎情況再整App.<br />\n有計劃眾籌，用途為支付web hosting fee, cloudflare plan<br />\n<br />\n建立議會既建議：<br />\n<a href=\"https://docs.google.com/document/d/1ttK3ALnYkOKI9e8cCoMlVLiCwLQy9Xzqv61NeZbBh_g/edit?usp=sharing\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdocs.google.com%2Fdocument%2Fd%2F1ttK3ALnYkOKI9e8cCoMlVLiCwLQy9Xzqv61NeZbBh_g%2Fedit%3Fusp%3Dsharing&d=e21%2BqJk643s04YHbVA6HNlT2VSzVBU3ss%2BeERvjOeOk%3D&h=9daeb253\" target=\"_blank\">https://docs.google.com/document/d/1ttK3ALnYkOKI9e8cCoMlVLiCwLQy9Xzqv61NeZbBh_g/edit?usp=sharing</a><br />\n<br />\n因為時間同埋成本既關係，我地打算起一個初始版本，再視乎大家反映<br />\nMVP (Minimum Viable Product) （初始版本）<br />\n提議 -&gt; 和議 -&gt; 公投 -&gt; 通過<br />\n每一個議案就有一個telegram group,可以讓大家討論<br />\n電郵認證只可以和議議案<br />\nSMS認證後，則可以參與公投議案<br />\n<br />\n招募人手 (目前嚴重缺人)<br />\nBack-end team (Node.js)<br />\nFront-end team<br />\nUI/UX designer<br />\n其他想幫手既巴絲打<br />\n<br />\n有興趣可以tg我<br />\n<a href=\"https://t.me/nameless200\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fnameless200&d=e21%2BqJk643s04YHbVA6HNlT2VSzVBU3ss%2BeERvjOeOk%3D&h=9d051d15\" data-auto-link target=\"_blank\">https://t.me/nameless200</a><br />\n<br />\n民間議會公海Group<br />\n<a href=\"https://t.me/hkparliament\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fhkparliament&d=e21%2BqJk643s04YHbVA6HNlT2VSzVBU3ss%2BeERvjOeOk%3D&h=040bda80\" data-auto-link target=\"_blank\">https://t.me/hkparliament</a><br />\n<br />\n題外話<br />\n其實我都好想見到民間議會出世。可能好多人都覺得，民間議會無乜用，根本影響唔到個政府，最多都係無約束力既動議，單純只係一班人圍爐自high。但試諗下，如果有一百萬人支持呢個動議，咁個影響力一定好大，第二日都可以上報紙；如果有一百萬人唔滿意政府表現，決定罷交稅，咁對政府既影響都好大。<br />\n主權在民，或者一個人既力量影響唔到乜，但如果能夠集合大家既力量，賦予議會權力，咁就可以制衡成個政府。將來政府做決策，或者立法會審議議案，都要顧慮到議會既立場。<br />\n我好希望，能夠係咁絕望既時刻，能夠做返d野，令到大家對將來仲抱有希望。我唔知道將來會點樣，之後議會能唔能夠成功建立，係咪可以發揮到原本既功能，甚至可能會中途夭折（唔係壽終正寢）. But we won&rsquo;t know if we don&rsquo;t give a try.<br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">香港人，加油！</span></strong></span><br />\n<br />\n<img src=\"https://na.cx/i/2BtnmJs.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F2BtnmJs.jpg&h=aa4387be&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-09-09T22:26:15.000Z","msg":"有冇人寫會章？<br />\n<br />\n推下"},"citedBy":1,"replyTime":"2019-09-09T23:07:00.000Z","msg":"有啊，目前有team人幫手寫"},"citedBy":0,"replyTime":"2019-09-10T04:28:41.000Z","msg":"真正做實事，正評"},{"pid":"6e0b8d8bea7d06caa21174fa17962cbd590c0804","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T06:16:04.000Z","msg":"推"},{"pid":"b1eb7240d05c369600e28eceb0547e007b998d00","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T08:36:02.000Z","msg":"push"},{"pid":"0a5b92e7c61edc52c78ce239a8c00df78bd9c931","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T08:38:31.000Z","msg":"好灰，原來唔多人支持<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4c5eeb2df97f305d8ea2a35d78b2f4e425ee6bb7","tid":1556630,"uid":303840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T08:44:42.000Z","msg":"推唔郁"},{"pid":"101a60dc74fd4940bebdbfa21a33d8ed1ad666ad","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T08:50:09.000Z","msg":"標題唔吸引？"},{"pid":"641becd8c7f7638613988bc710980d83266c6ca1","tid":1556630,"uid":167340,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T08:53:57.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0a712e48838e074d9c6fb6694c826784defdfc46","tid":1556630,"uid":51057,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2019-09-10T09:03:23.000Z","msg":"唔係想潑大家冷水, 但係想知道以下問題應該點解決.<br />\n//但試諗下，如果有一百萬人支持呢個動議，咁個影響力一定好大，第二日都可以上報紙；如果有一百萬人唔滿意政府表現，決定罷交稅，咁對政府既影響都好大。<br />\n主權在民，或者一個人既力量影響唔到乜，但如果能夠集合大家既力量，賦予議會權力，咁就可以制衡成個政府。將來政府做決策，或者立法會審議議案，都要顧慮到議會既立場。//<br />\n你上面講既, 其實同而家200萬人不滿政府然後走出黎遊行,罷工咁, 分別係不大. 就算去到你講既100萬人罷交稅, 其實我覺得對政府既影響係有限, 而且要受法律制裁. 一日未有一股可以抗衡黨衛軍既力量, 我覺得好難靠呢樣野比到壓力政府<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"31e7e2f18c3edfdf810321486c55e718e7f1d80d","tid":1556630,"uid":208456,"like":1,"dislike":0,"score":1,"quote":{"pid":"0a712e48838e074d9c6fb6694c826784defdfc46","tid":1556630,"uid":51057,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2019-09-10T09:03:23.000Z","msg":"唔係想潑大家冷水, 但係想知道以下問題應該點解決.<br />\n//但試諗下，如果有一百萬人支持呢個動議，咁個影響力一定好大，第二日都可以上報紙；如果有一百萬人唔滿意政府表現，決定罷交稅，咁對政府既影響都好大。<br />\n主權在民，或者一個人既力量影響唔到乜，但如果能夠集合大家既力量，賦予議會權力，咁就可以制衡成個政府。將來政府做決策，或者立法會審議議案，都要顧慮到議會既立場。//<br />\n你上面講既, 其實同而家200萬人不滿政府然後走出黎遊行,罷工咁, 分別係不大. 就算去到你講既100萬人罷交稅, 其實我覺得對政府既影響係有限, 而且要受法律制裁. 一日未有一股可以抗衡黨衛軍既力量, 我覺得好難靠呢樣野比到壓力政府<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-10T10:30:29.000Z","msg":"Agree<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n但都要搵人去做"},{"pid":"aafad8ae56e8ec1102f19667bfb645743b80eb6a","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T12:11:37.000Z","msg":"推"},{"pid":"d3b71dcb04a96071d6c5ae9fc5935ed88650cae0","tid":1556630,"uid":224249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T12:57:48.000Z","msg":"推"},{"pid":"9df83d613388b1cf22c4b711de4170d95b67489d","tid":155