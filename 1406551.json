knews.cc%2Fpsychology%2Fpxazaae.html&d=8tXbBdGphLRwD8DFuLHjuIgmK84TLJm0fByd7TIP4s4%3D&h=724d41c8\" data-auto-link target=\"_blank\">https://kknews.cc/psychology/pxazaae.html</a>"},{"pid":"05c404949b4aa22be9b6da143e89cebbb5b041da","tid":1406551,"uid":27605,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-08-04T13:48:47.000Z","msg":"條女好似唔錯 對腳幾正"},{"pid":"3d98aef56371c4ab583a8211a8cde7efa32cbfe2","tid":1406551,"uid":27605,"like":0,"dislike":1,"score":-1,"quote":{"pid":"05c404949b4aa22be9b6da143e89cebbb5b041da","tid":1406551,"uid":27605,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-08-04T13:48:47.000Z","msg":"條女好似唔錯 對腳幾正"},"citedBy":0,"replyTime":"2019-08-04T13:49:23.000Z","msg":"btw佢個背似收埋左野"},{"pid":"df03f896cfd2d56e057a4c6f1de1019479fe01a2","tid":1406551,"uid":164374,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T13:52:55.000Z","msg":"有無手足去招呼佢地 <img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"a660ffd6619ddd5fc4c403466fe739fefe418b40","tid":1406551,"uid":291868,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T13:55:36.000Z","msg":"推呀"},{"pid":"8152896ccaff1157ef2f9e05677300207a3ff5b4","tid":1406551,"uid":6152,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T13:55:41.000Z","msg":"推"},{"pid":"fb98232437e9bbc25beb0f6d39bdffa6e3d50d5d","tid":1406551,"uid":249187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T13:56:26.000Z","msg":"推啊<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"7f3241c97402899f134fcfde9dc268f05871f686","tid":1406551,"uid":228897,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T13:56:49.000Z","msg":"十成係狗"},{"pid":"d69f74f90a3061d11ffb79bd8ada971277ef9197","tid":1406551,"uid":279525,"like":2,"dislike":0,"scor