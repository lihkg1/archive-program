15f5c7","tid":2496054,"uid":1249,"like":0,"dislike":0,"score":0,"quote":{"pid":"62dca6008bedcca86ff2744cc36dfe3d90e8f8b5","tid":2496054,"uid":324018,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-19T14:49:52.000Z","msg":"問題係未來係難以預測到。同埋好多人都會曾經有想死既念頭，如果個個想死就即刻死，分分鐘今晚就死撚曬60億人"},"citedBy":1,"replyTime":"2021-04-19T14:53:54.000Z","msg":"現實根本唔會發生<br />\n正如我所講「求生」係寫喺基因入面<br />\n真正做到「求死」嘅人唔多"},"citedBy":3,"replyTime":"2021-04-19T15:00:48.000Z","msg":"咁咪係lor，你點分到一個想死既人係真心想死定一時衝動，分唔到咪唯有叫佢求生，有咩問題？"},"citedBy":1,"replyTime":"2021-04-19T15:59:23.000Z","msg":"咁如果你分到佢係真心想死呢 你仲會唔會叫佢求生"},{"pid":"4f15be316af80424c82a37a9cb08a42b4279ee8a","tid":2496054,"uid":4672,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-19T16:11:03.000Z","msg":"自殺比生存更需要勇氣<br />\n<br />\n生活去到某一個點時候 生同死已經冇分別<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},{"pid":"a40f79c97f46b7a131e5051539a433920b6ae176","tid":2496054,"uid":4672,"like":1,"dislike":0,"score":1,"quote":{"pid":"4f15be316af80424c82a37a9cb08a42b4279ee8a","tid":2496054,"uid":4672,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-19T16:11:03.000Z","msg":"自殺比生存更需要勇氣<br />\n<br />\n生活去到某一個點時候 生同死已經冇分別<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-19T16:13:33.000Z","msg":"呢個時候  生存比自殺更需要勇氣<br />\n<br />\n但絕大部分人從來未遭遇到呢個極點（99%人）"},{"pid":"8d000735e716b156c123ff90ff8112c0da741d8d","tid":2496054,"uid":324018,"like":0,"dislike":2,"score":-2,"quote":{"pid":"13b21b8ad3f9702f3efac110040bd83b5596c5b2","tid":2496054,"uid":287475,"like":0,"dislike":0,"score":0,"quote":{"pid":"4b5b8d3a73d0b4908e2ff2970643f7c883b32aec","tid":2496054,"uid":324018,"like":0,"dislike":0,"score":0,"quote":{"pid":"e953063a9974e1e717cda229bc76810a4115f5c7","tid":2496054,"uid":1249,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-19T14:53:54.000Z","msg":"現實根本唔會發生<br />\n正如我所講「求生」係寫喺基因入面<br />\n真正做到「求死」嘅人唔多"},"citedBy":3,"replyTime":"2021-04-19T15:00:48.000Z","msg":"咁咪係lor，你點分到一個想死既人係真心想死定一時衝動，分唔到咪唯有叫佢求生，有咩問題？"},"citedBy":1,"replyTime":"2021-04-19T15:59:23.000Z","msg":"咁如果你分到佢係真心想死呢 你仲會唔會叫佢求生"},"citedBy":1,"replyTime":"2021-04-19T16:26:35.000Z","msg":"咁佢咪要對死後有影響既人解釋點解佢要死，佢死後冇影響到人咪ok。但如果佢死左會令其他人有負面影響，佢有責任去生存落去"},{"pid":"1f8045da6b2416d131b3ec5962a23f84b8f0fb11","tid":2496054,"uid":201552,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-04-19T16:33:26.000Z","msg":"同意<br />\n生存=每日繼續受苦<br />\n自殺=提早結束受苦<br />\n<br />\n自殺其實唔洗勇氣，只係需要有喱個念頭就夠，生存就真係要好大勇氣，面對解決唔到嘅事，釋放唔到嘅壓力，試問可以有幾大勇氣呢？<br />\n<br />\n最反智嘅係會有人同你講：個個都係咁㗎啦，又唔見人哋去死？睇開啲啦！唔好諗咁多<br />\n<br />\n我做到就唔洗諗自殺啦，就係做唔到吖嘛。正能量其實鼓勵唔到人，反而要比對方知道有人喺佢身邊支持佢先係重要，佢哋唔係想聽人生建議，心靈雞湯，真係有用嘅，自己睇書都解決到。"},{"pid":"470956ea1cdd167a63b56abb1208ac0e7e01ff6d","tid":2496054,"uid":100145,"like":0,"dislike":0,"score":0,"quote":{"pid":"fb704b93edf2477a895b3f79e4d23ce4fc715cca","tid":2496054,"uid":324018,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2021-04-19T14:37:30.000Z","msg":"如果你簡單咁睇係一個人面對緊一條選擇題<br />\nA or B<br />\n當你面對一條選擇題既時候當然會有人支持A有人支持B。<br />\n<br />\n但去到自殺既時候<br />\n生存 or 死亡<br />\n呢個唔再係普通既選擇題，因為你揀左死就end game，自不然大部分人都會叫你唔好死"},"citedBy":0,"replyTime":"2021-04-19T17:01:31.000Z","msg":"死左又冇得後悔，既然冇後悔又何來endgame"},{"pid":"b4f07d9a60a4f8498a9f15356d5d2473a89b56c5","tid":2496054,"uid":100145,"like":2,"dislike":0,"score":2,"quote":{"pid":"28daf8efbd31de726d598970d6119137bbd2269e","tid":2496054,"uid":80902,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-04-19T14:47:38.000Z","msg":"咁啱睇到篇野講呢個話題<br />\n<img src=\"https://na.cx/i/HvkRcwS.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHvkRcwS.jpg&h=31e6b7ef&s={SIZE}\" />"},"citedBy":1,"replyTime":"2021-04-19T17:05:42.000Z","msg":"只要影響唔到其他人其實自殺係冇問題"}],"pinned":{"pid":"061b6e87f1ea02594caaaf750336d1e57eeaba6f","tid":2496054,"uid":1249,"like":12,"dislike":0,"score":12,"citedBy":0,"replyTime":"2021-04-19T14:34:17.000Z","msg":"人生嘅意義根本由自己定義<br />\n你覺得有就自然有<br />\n無就自然無"}}