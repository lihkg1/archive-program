faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"90fc8df9c9bee5b0751309e00e066c651fbb4a8b","tid":1821923,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T17:01:40.000Z","msg":"社區<br />\n民建聯做騷派揮春稱繼續服務 街坊高呼光復香港贈慶<br />\n<br />\n民建聯做騷派揮春稱繼續服務 街坊高呼光復香港贈慶週日 2020-01-12 獨媒報導<br />\n<br />\n廣告<br />\n（獨媒特約報導）民建聯早上舉行「不忘初心 繼續服務&mdash;&mdash;全港服務日」，稱要表達服務市民、建設香港的信念和決心。民建聯主席李慧琼繼續抱病，她發言時稱新一年會一如既往服務市民，「初心不變，我哋嘅火無熄滅，無嘢難倒我哋。」有街坊多次在旁高呼「光復香港」贈慶，更有街坊怒稱「服咩務呀，收皮啦。」"},{"pid":"4f3c126d13f87268e472c54c7c44b606c6a33b73","tid":1821923,"uid":300719,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T17:07:42.000Z","msg":"<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"d75ac87da1a52b84a94da95625e8179e4a91d366","tid":1821923,"uid":231583,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T17:10:02.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e8933f5d447adaf5bbf7ba4a15feeadfb3d40b72","tid":1821923,"uid":210727,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T17:10:10.000Z","msg":"此回覆已被刪除"},{"pid":"b2098e02d825845fa28063de4a9cf0d1c79f2b3f","tid":1821923,"uid":30453,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T17:11:15.000Z","msg":"<img src=\"/assets/faces/lm2/sosick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosick.gif\" class=\"hkgmoji\" />"},{"pid":"f07c078b2ddd87afbd0984eac99b473a7310af0c","tid":1821923,"uid":221265,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-12T17:11:58.000Z","msg":"<a href=\"https://bit.ly/2FGKxjw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F2FGKxjw&d=uClJ75VMDgyJ2T8QnpTVXUB1UtkZy1G9%2FYekDAkGV2Y%3D&h=258eaec2\" target=\"_blank\">https://bit.ly/2FGKxjw</a><br />\n<br />\n有個日本妹作咗首歌叫習近平咪嚟日本<br />\n唔使旨意受國賓式招待<br />\n好洗腦<br />\n<br />\n中譯tweet<br />\n<img src=\"https://na.cx/i/LHcadF3.png\" data-t