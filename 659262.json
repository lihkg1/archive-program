_43f88381302798b61261eac380058541.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F04%2F205806_43f88381302798b61261eac380058541.png&h=7108e4e3&s={SIZE}\" />"},{"pid":"d9dcd17d6fa5b2b6e47adfa4c4c141fcbb259790","tid":659262,"uid":2429,"like":1,"dislike":4,"score":-3,"quote":{"pid":"fa9c390f079d9fdcb57ee4edee91e101fbcad6e3","tid":659262,"uid":44730,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2018-05-09T17:31:57.000Z","msg":"<a href=\"https://www.instagram.com/p/BiZdK9wHR9C/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fp%2FBiZdK9wHR9C%2F&d=wapzj4paykHaBJyKCXJ%2FoTA5unq%2FSd9ZKvr75NUD1%2F0%3D&h=5aafa460\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.instagram.com%2Fp%2FBiZdK9wHR9C%2F&h=8477fbe3\" target=\"_blank\">https://www.instagram.com/p/BiZdK9wHR9C/</a>"},"citedBy":1,"replyTime":"2018-05-09T17:40:40.000Z","msg":"近親相姦<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"2af7190fe42d76c616e18e8ac6956f6aa0fdbdb6","tid":659262,"uid":44730,"like":0,"dislike":5,"score":-5,"citedBy":0,"replyTime":"2018-05-09T17:40:50.000Z","msg":"曾華倩兒子林浩賢兩米高好有型　游泳港隊讀喇沙簡直男神級別<br />\n<br />\n撰文：黃梓恒<br />\n<br />\n2018-05-09 22:00<br />\n<br />\n最後更新日期：2018-05-09 21:55<br />\n<br />\n<br />\n<br />\n曾華倩在今年開始正式復出幕前工作，在上年年尾11月的時候，好友吳雨邀請她為同樣是復出的亞洲電視做開幕禮主持。當然不只開幕禮如此簡單，之後每個星期三，曾華倩便會與樂瞳和朱慧敏主持《今晚見》及《今晚夜D見》這些綜藝節目，曝光率大增。但究竟她之前為甚麼會暫時退出幕前工作呢？原因就是要照顧兒子林浩賢，但她的兒子明明已經19歲，點解仲要媽媽咁貼身照顧呢？"},{"pid":"bfda67f2f949bca489133532030dd33dd5740cc5","tid":659262,"uid":44730,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2018-05-09T17:41:39.000Z","msg":"原來中學就讀名校喇沙書院的囝囝林浩賢（Martin）是一名游泳健將，更代表港隊周遊列國參加比賽，為了照顧囝囝到國外、國內參加各種游泳比賽，於是曾華倩決定暫時放低自己的演藝事業，全力支持囝囝追夢！就好像剛剛在馬來西亞吉隆坡舉行的「第61屆馬來西亞公開游泳錦標賽」Martin就代表港隊參加4x100米自由式接力賽，而且成功奪金而回，為港爭光！"},{"pid":"89fc874c43425d54af6bae9b3a08867653ccc2e1","tid":659262,"uid":50595,"like":10,"dislike":1,"score":9,"citedBy":0,"replyTime":"2018-05-09T17:42:59.000Z","msg":"屌佢老母"},{"pid":"79747e4e183d38707b71e1c5978dc8267d90bfd5","tid":659262,"uid":87757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-09T17:53:50.000Z","msg":"人生贏家"},{"pid":"df4ea1210ebb45dac6c8322c7a2845df9b8b3ef2","tid":659262,"uid":44730,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2018-05-09T18:04:07.000Z","msg":"而Martin除了游水叻，身高都一樣咁突出，事關早前曾華倩post了一張合照，入面除了他們兩母子之外，還有吳家樂和袁文傑。大家都知道，袁文傑是相當之高，有成189cm，但Martin拍埋去還要高出他半個頭左右，相信身高直逼2米，在香港算是相當誇張了！"},{"pid":"b8ae698f3ec99017acb46aa7aa5bb9e6e379bcb9","tid":659262,"uid":44730,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-05-09T18:11:28.000Z","msg":"<blockquote>人生贏家</blockquote><br />\n點解會過亞視<img src=\"https://img.eservice-hk.net/upload/2018/02/14/105309_dc4d89861da876a3fb8154d45d96f0b1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F14%2F105309_dc4d89861da876a3fb8154d45d96f0b1.png&h=696d470f&s={SIZE}\" /> 而家唔係仲有兩個台揀咩"},{"pid":"7a7e655a1904484443dbbaaf6f10e86a7a3cb37b","tid":659262,"uid":29938,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-09T18:21:13.000Z","msg":"<a href=\"https://www.instagram.com/martinlamhy/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fmartinlamhy%2F&d=wapzj4paykHaBJyKCXJ%2FoTA5unq%2FSd9ZKvr75NUD1%2F0%3D&h=adba30c2\" data-auto-link target=\"_blank\">https://www.instagram.com/martinlamhy/</a>"},{"pid":"7554170b6894b173c6cd3808166077d0ec0c78cd","tid":659262,"uid":44730,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-05-09T18:28:17.000Z","msg":"<blockquote><a href=\"https://www.instagram.com/martinlamhy/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fmartinlamhy%2F&d=wapzj4paykHaBJyKCXJ%2FoTA5unq%2FSd9ZKvr75NUD1%2F0%3D&h=adba30c2\" data-auto-link target=\"_blank\">https://www.instagram.com/martinlamhy/</a></blockquote><br />\n<a href=\"https://www.instagram.com/p/tz_ixlPRPP/\" data-sr-url=\"https://r