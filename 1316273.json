,"tid":1316273,"uid":106870,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-14T17:05:18.000Z","msg":"勇 武 已 成 民 心 所 向<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/diDfNS\" data-auto-link target=\"_blank\">https://lih.kg/diDfNS</a>"},{"pid":"f87d95a8a116f8d137deca0ffdf9f22e260e1aea","tid":1316273,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T09:31:07.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"61dd2e390c4a3186e562bea8d2d7c85730eaea42","tid":1316273,"uid":126730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T09:39:24.000Z","msg":"推"}]}