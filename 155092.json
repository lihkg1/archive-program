normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"ba3b928f5f6788e299b85a41a3e3e26d95131fba","tid":155092,"uid":82391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-16T06:29:11.000Z","msg":"老豆老母接受我同我條女<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"8189a544e5d6b9a9faafba20c012186aa71d6bb8","tid":155092,"uid":34047,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-16T06:55:02.000Z","msg":"<blockquote><blockquote><blockquote>搵倒一個真心愛我嘅人</blockquote><br />\n要相信 你自己有冇target</blockquote><br />\n有 但唔覺個target會鐘意我<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n點解咁覺得呀 而家你地咩野關係"},{"pid":"be9f060d856c850c7db53c5bb7e7f1bbadee20cd","tid":155092,"uid":34047,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-16T06:55:15.000Z","msg":"<blockquote>老豆老母接受我同我條女<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n集佢地因咩野未接受"},{"pid":"dd2a6b326c7aa0ae85e06a181aea0b8974a9a7ef","tid":155092,"uid":91326,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-16T07:06:59.000Z","msg":"<blockquote><blockquote>因為一次小事 同個fd嘈左輪 過後都有問過究竟咩原因嬲咁耐 佢又唔肯講 最後隔一排再搵佢既時候就block埋我 <br />\n<br />\n到而家我都唔知咩原因佢會咁 佢係我最好既朋友<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n會唔會果件事只係觸發點<br />\n之前佢對你都有不滿<br />\n定係果件事對佢既影響比你想像中大？<br />\n或者過一排再試下釋出善意</blockquote><br />\n件事本身好小事，前一晚仲打通宵機，佢份人有話直說，有咩都會屌，唔會收收埋埋，果次嘈完，隔左可能個零禮拜都有搵佢，但佢就都好拒絕同我和好，咁初初我緊係屌佢，咁撚小事味咁小氣，到左後期我都攤開黎講，有咩就講出黎，但始終都冇結果<br />\n<br />\n我唔知係佢立場係諗咩，我突估會唔會中間有咩事令到佢咁憎我，連出黎傾下，打電話都唔聽<br />\n<br />\n我真係好唔開心，為左件事"}]}