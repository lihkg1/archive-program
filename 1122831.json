=\"hkgmoji\" />"},{"pid":"5e920ab2da3493c782fba79980073a8f886f6054","tid":1122831,"uid":215441,"like":0,"dislike":1,"score":-1,"quote":{"pid":"a4701e619390cc9ef59b5f9821f55163984f83cc","tid":1122831,"uid":55712,"like":0,"dislike":1,"score":-1,"quote":{"pid":"bbffaa90e49b1b2fa19ae5fb3ebd17c8488cd085","tid":1122831,"uid":3297,"like":11,"dislike":1,"score":10,"quote":{"pid":"80e0793ab391ed1fb3a01186067a7094a5f8222e","tid":1122831,"uid":116330,"like":2,"dislike":4,"score":-2,"citedBy":2,"replyTime":"2019-04-25T04:42:22.000Z","msg":"點解發夢屙尿就會瀨尿<br />\n發夢屌西又唔會射精<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-25T04:43:57.000Z","msg":"會射"},"citedBy":1,"replyTime":"2019-04-25T05:01:16.000Z","msg":"邊個話唔會...<br />\n早兩日先發夢屌閪完<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-04-25T05:42:28.000Z","msg":"之前如果個人好攰，瞓覺發小緊個閪的夢，到就嚟出嘢嗰時，發覺可能係發緊夢(因為知道係冇可能同條女我唔識佢)，但係都照繼續中出埋佢，嗰種感覺真係正到不得了"},{"pid":"5c3058def57afb2b73adf5710b28eafc5feccc30","tid":1122831,"uid":209600,"like":12,"dislike":1,"score":11,"quote":{"pid":"5325c9e5ef9326bf8b22fd11becaaa910fdcfd70","tid":1122831,"uid":140309,"like":26,"dislike":0,"score":26,"citedBy":1,"replyTime":"2019-04-25T05:27:05.000Z","msg":"我瞓教一急尿，發夢內容會一直圍住急尿情節，痾極都係咁急<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />，起身之後發現原來係急尿"},"citedBy":0,"replyTime":"2019-04-25T05:42:43.000Z","msg":"Same here<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n我發夢急尿，有時會夢見自己瘋狂痾尿，尿頻咁嘅款，或者係企左喺馬桶前面痾左好耐都仲好急，然後就會醒，但未賴過<br />\n但我會賴屎🤦🏻&zwj;♂️仲衰過賴尿<br />\n<br />\n利申：敏感性腸胃，腸胃炎嘅時候，訓覺賴屎機會好高，唔係賴好多果種，係咇屎汁果種，有時喺街攪肚都會忍唔住咇屎汁，有時係以為放屁，一放就有股暖流，咇左屎汁出黎"},{"pid":"fdc857a863ca8b0cf68322153751119cfa9b11af","tid":1122831,"uid":234695,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-04-25T05:46:20.000Z","msg":"人瞓教個陣身體唔係會製造一d野去抑制尿意同便意咩？"},{"pid":"0616b74c414f4b61eb7695abf2aacef5ba936601","tid":1122831,"uid":144466,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-04-25T05:51:10.000Z","msg":"20歲(未瀨夠)"},{"pid":"c4083e043732d0c8db82c1dfcac2f892d371b27f","tid":1122831,"uid":65400,"like":0,"dislike":2,"score":-2,"quote":{"pid":"097c81fceaad66fc002124098ac434d5aa94f408","tid":1122831,"uid":37338,"like":76,"dislike":5,"score":71,"citedBy":2,"replyTime":"2019-04-24T06:58:07.000Z","msg":"肯定開到部冷氣好撚凍"},"citedBy":0,"replyTime":"2019-04-25T06:04:20.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f5de07e4c25143535ac32c5a1997e3a057855808","tid":1122831,"uid":17379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-25T06:07:11.000Z","msg":"發夢去廁所大忌嚟講<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />試過"},{"pid":"86a60f8c73b0b8f6bf6dc08ec0d02548da5f8057","tid":1122831,"uid":173696,"like":8,"dislike":0,"score":8,"quote":{"pid":"f46133723eb9f8857e27c0874415195e8e0ae341","tid":1122831,"uid":162406,"like":4,"dislike":23,"score":-19,"quote":{"pid":"e0c92a7419dcfd21c503bb7c165f997b42094e55","tid":1122831,"uid":48362,"like":3,"dislike":3,"score":0,"citedBy":1,"replyTime":"2019-04-24T06:59:03.000Z","msg":"之前有無類似情況?"},"citedBy":2,"replyTime":"2019-04-24T07:02:01.000Z","msg":"冇，不過我去到二年班先開始唔瀨尿<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-04-25T06:08:16.000Z","msg":"大學二年班?<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"2c328d3dd17ff9fc6174515803d97da764f9fdef","tid":1122831,"uid":64564,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-25T06:15:09.000Z","msg":"瀨屎我都試過啦<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3d135cbb5e65e1c6e099d39367520de68abf4861","tid":1122831,"uid":48702,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-04-25T06:29:18.000Z","msg":"有冇夢遺"},{"pid":"51b7a5ce289d81d3739117d738f64ea19d262d72","tid":1122831,"uid":22560,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-04-25T06:30:22.000Z","msg":"我通常係發夢對住個廁所好耐都痾唔到<br />\n一醒咗就覺得勁急<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n好彩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8e498c4943bd5c103811d0b57542dece8414bd70","tid":1122831,"uid":111930,"like":15,"dislike":2,"score":13,"citedBy":0,"replyTime":"2019-04-25T07:05:21.000Z","msg":"中學果陣試過。<br />\n我屋企有兩個廁所，我間房就近我丫媽個主人廁，所以我夜尿都會去丫媽個廁所。<br />\n有一晚我如常去我丫媽廁所柯夜尿，發現鎖左主人房門，咁我緊係去返客廁柯尿啦。<br />\n屌你老母奇怪既事就發生啦，第二朝我丫哥間房張電腦椅成張都係尿<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n仆你個街我丫哥間房係客廁對面，我應該轉錯彎，轉左入丫哥間房當張電椅椅係屎坑<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n第日醒左我丫哥屌曬鬼，我丫媽又話琴晚度房門鎖左，我先知發生咩事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"853c53cdf568ab5b6db8d3f989938ec9269305a7","tid":1122831,"uid":16272,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-25T07:21:01.000Z","msg":"24時都試過 又係發夢屙緊尿<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />  不過我知道原因係咩 就係我趴左係度訓 成晚壓住個膀胱"},{"pid":"e3719c533a4ebc7b933e998485eb6f8e9b9da621","tid":1122831,"uid":10427,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2019-04-25T07:37:05.000Z","msg":"試過小學果陣放學訓陣教<br />\n<br />\n跟住又係發夢係廁所痾緊尿<br />\n<br />\n點知痾痾下我老豆一巴摑醒我<br />\n<br />\n原來我唔知係咪夢遊企左係房 <br />\n<br />\n係幅牆面前痾尿<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n<br />\n跟住比人鬧到仆街<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"608a3db91d764458c5bc6ad7ce9691389ba3857f","tid":1122831,"uid":23531,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-04-25T08:04:43.000Z","msg":"發夢柯尿，柯完好c服，但係柯完發覺唔對路就醒左，點知真係柯左小小出黎好彩醒得快<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"1895e52fc99c46f80740b1a57ee42ebd36b1c132","tid":1122831,"uid":7699,"like":0,"dislike":1,"score":-1,"quote":{"pid":"51b7a5ce289d81d3739117d738f64ea19d262d72","tid":1122831,"uid":22560,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-04-25T06:30:22.000Z","msg":"我通常係發夢對住個廁所好耐都痾唔到<br />\n一醒咗就覺得勁急<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n好彩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-25T08:05:24.000Z","msg":"我都係 一醒嗰下即刻嚇撚死 摸一摸條褲 好彩次次都冇濕<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"939ddc9c4fd74a017e733336323440b18f104918","tid":1122831,"uid":174191,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-25T08:14:10.000Z","msg":"細個試過發夢急屎急到就瀨衝去廁所爆到成個馬桶都係 好爽 醒返先發現係夢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"e51c7abcb4ed1ab6225d4b48053f4d7b727f1069","tid":1122831,"uid":34571,"like":0,"dislike":0,"score":0,"quote":{"pid":"1895e52fc99c46f80740b1a57ee42ebd36b1c132","tid":1122831,"uid":7699,"like":0,"dislike":1,"score":-1,"quote":{"pid":"51b7a5ce289d81d3739117d738f64ea19d262d72","tid":1122831,"uid":22560,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-04-25T06:30:22.000Z","msg":"我通常係發夢對住個廁所好耐都痾唔到<br />\n一醒咗就覺得勁急<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n好彩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-