ote":{"pid":"170bb9d86684f239b60e10adfbf125b64d9563cc","tid":1211950,"uid":232082,"like":92,"dislike":0,"score":92,"quote":{"pid":"4ffa5b7f8c1da64d7ad672de14abe276889ae2eb","tid":1211950,"uid":20058,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-06-12T16:57:39.000Z","msg":"<a href=\"https://www.facebook.com/128807942654/posts/10156916407532655?s=100001313257075&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F128807942654%2Fposts%2F10156916407532655%3Fs%3D100001313257075%26sfns%3Dmo&d=o1jNmZJj5m3DpFdm5BDgvx9HEPLFM%2Fpg3GuXTgQF%2FE0%3D&h=91cf7110\" data-auto-link target=\"_blank\">https://www.facebook.com/128807942654/posts/10156916407532655?s=100001313257075&amp;sfns=mo</a><br />\n<br />\n昨午（12日）正當警方施放催淚彈驅散示威者時，警方接報有人用車運送汽油彈到金鐘，遂展開追查及兜截，至下午5時05分，警員在告士打道舊灣仔警署外發現該可疑私家車，即時將其截停，期間警員拔槍戒備，將車上4名年齡由22至25歲男子拖出車外，然後搜查車廂。 <br />\n<br />\n警員在車內檢獲1個口罩、25對勞工手襪、5卷保鮮紙、1個鐵鉗及1個不屬該車的車牌，遂以涉嫌藏有工具可作非法用途將4人拘捕。案件已交由灣仔警區反三合會調查組跟進。<br />\n<br />\n<a href=\"https://hk.on.cc/hk/bkn/cnt/news/20190613/mobile/bkn-20190613002859718-0613_00822_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20190613%2Fmobile%2Fbkn-20190613002859718-0613_00822_001.html&d=o1jNmZJj5m3DpFdm5BDgvx9HEPLFM%2Fpg3GuXTgQF%2FE0%3D&h=dac6c340\" data-auto-link target=\"_blank\">https://hk.on.cc/hk/bkn/cnt/news/20190613/mobile/bkn-20190613002859718-0613_00822_001.html</a>"},"citedBy":2,"replyTime":"2019-06-12T17:00:44.000Z","msg":"律師要幫手呀 幫手share 出去"},"citedBy":0,"replyTime":"2019-06-12T18:56:48.000Z","msg":"要咩資料"},{"pid":"9565884bacb4644c87ce4f4353cf8c88239c4db8","tid":1211950,"uid":169079,"like":0,"dislike":0,"score":0,"quote":{"pid":"170bb9d86684f239b60e10adfbf125b64d9563cc","tid":1211950,"uid":232082,"like":92,"dislike":0,"score":92,"quote":{"pid":"4ffa5b7f8c1da64d7ad672de14abe276889ae2eb","tid":1211950,"uid":20058,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-06-12T16:57:39.000Z","msg":"<a href=\"https://w