c=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"befc2283fe2c2d398471fdec472df86b03926fc2","tid":1438732,"uid":108337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T01:05:33.000Z","msg":"<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"f1ff8bec9bffdbfd96f8fa34873243e9387f3ad3","tid":1438732,"uid":2836,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T01:10:00.000Z","msg":"推"},{"pid":"1ccc9b28fc5fc208cba9f24cb9bc623052f90584","tid":1438732,"uid":57647,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T01:11:53.000Z","msg":"今次輸左<br />\n我地對得住咁多位手足咩"},{"pid":"c01f1333c2bb9fb86cdad9061cc7e4ca791d0281","tid":1438732,"uid":94241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T01:13:40.000Z","msg":"推"},{"pid":"42971ef0422cbfe37161c6d23cf8eb4631633b8b","tid":1438732,"uid":146737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T01:15:22.000Z","msg":"<img src=\"https://na.cx/i/fwep1N0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Ffwep1N0.jpg&h=bc59219e&s={SIZE}\" />"}]}