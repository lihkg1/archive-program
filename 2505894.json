75bf3b352f1","tid":2505894,"uid":125168,"like":75,"dislike":1,"score":74,"citedBy":3,"replyTime":"2021-04-27T03:18:34.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},"citedBy":13,"replyTime":"2021-04-27T03:20:28.000Z","msg":"PR響前面救火<br />\n政府響後面淋火水<br />\n點搞<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-27T04:09:36.000Z","msg":"點救啊<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n不如直接hea 做算鳩數，反正點都有錢賺<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fcdc8299d4f3ff3a543bbb5cfa6c9acba1e2998e","tid":2505894,"uid":195136,"like":2,"dislike":0,"score":2,"quote":{"pid":"d39d545aa2b86cf78d2ffdfbaef12dac64a00751","tid":2505894,"uid":125168,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04-27T03:17:36.000Z","msg":"<a href=\"https://tw.appledaily.com/politics/20210426/5PFAWT2JOBHD7G5PIZ6Z243RJE/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.appledaily.com%2Fpolitics%2F20210426%2F5PFAWT2JOBHD7G5PIZ6Z243RJE%2F&d=90j3dNidiaWpDV5wjwn%2B62CvuqnjOb%2FiGpmC2gL%2Fng4%3D&h=be8bb218\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftw.appledaily.com%2Fpolitics%2F20210426%2F5PFAWT2JOBHD7G5PIZ6Z243RJE%2F&h=2324c9d3\" data-auto-link target=\"_blank\">https://tw.appledaily.com/politics/20210426/5PFAWT2JOBHD7G5PIZ6Z243RJE/</a><br />\n<br />\n近日港人發現，從香港伺服器無法登陸台灣基督長老教會網站、民進黨及國防部國軍人才招募中心的網站。陸委會今（26日）表示，我方呼籲相關方面應確保香港民眾「知的權利」，勿一再高築、擴張網路長城，否則終將自損香港的國際形象與世界金融中心地位。<br />\n<br />\n陸委會指出，資訊自由是基本人權，也是香港作為國際城市的重要基石。<span class=\"red\">相關方面閹割香港資訊自由的作為，只會對外釋出香港愈益近似中國大陸之訊號。</span><br />\n<br />\n此前，2月香港多個網路供應商都無法連接促轉會官網，包括數碼通、香港寬頻、香港電訊、3電信及中國移動等網路供應商，均顯示「無法連線至此網站」，只能透過VPN經德國、美國等海外國家的伺服器才能登入。香港保安局當時同樣表示，對任何針對警方執法行動的揣測不作評論。（陳建瑜／台北報導）"},"citedBy":0,"replyTime":"2021-04-27T04:12:49.000Z","msg":"遲啲港股無人玩，會唔會封撚咗美股<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n對任何針對香港股票行動的揣測不作評論"},{"pid":"cf6e96441aa53bc5f1c9ef1aeed95f0614f913ad","tid":2505894,"uid":230146,"like":1,"dislike":0,"score":1,"quote":{"pid":"6bf5fb92254664b18e993f53370b9e2378b67fcd","tid":2505894,"uid":50386,"like":110,"dislike":1,"score":109,"quote":{"pid":"0b15e86f3e586cc9e2a6d52ff90f375bf3b352f1","tid":2505894,"uid":125168,"like":75,"dislike":1,"score":74,"citedBy":3,"replyTime":"2021-04-27T03:18:34.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},"citedBy":13,"replyTime":"2021-04-27T03:20:28.000Z","msg":"PR響前面救火<br />\n政府響後面淋火水<br />\n點搞<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-27T04:17:41.000Z","msg":"其實d PR都係扮救火姐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"5c9342ad6f40098704edbe330c47f39c062c6829","tid":2505894,"uid":64810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-27T04:17:55.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"94dd03debde6a8549b47807f1af55af9ce2eed99","tid":2505894,"uid":53206,"like":1,"dislike":0,"score":1,"quote":{"pid":"0b15e86f3e586cc9e2a6d52ff90f375bf3b352f1","tid":2505894,"uid":125168,"like":75,"dislike":1,"score":74,"citedBy":3,"replyTime":"2021-04-27T03:18:34.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-27T04:36:41.000Z","msg":"<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"c5910c4169303683421a847ce6d7997148ad480f","tid":2505894,"uid":275912,"like":0,"dislike":0,"score":0,"quote":{"pid":"6bf5fb92254664b18e993f53370b9e2378b67fcd","tid":2505894,"uid":50386,"like":110,"dislike":1,"score":109,"quote":{"pid":"0b15e86f3e586cc9e2a6d52ff90f375bf3b352f1","tid":2505894,"uid":125168,"like":75,"dislike":1,"score":74,"citedBy":3,"replyTime":"2021-04-27T0