/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"982302c978a452a418ce46973e4de9d177195c7d","tid":1525251,"uid":308875,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T09:32:34.000Z","msg":"光復香港, 不要支籍<br />\n&ldquo;中國單方面宣稱中英聯合聲明已經失效，香港人該何去何從？&rdquo;<br />\n<br />\n用1分鐘嘅時間簽名，務求收集到10萬簽名將BNO平權議題推上議會討論<br />\n註: 轉BC後可傳俾97後<br />\n為咗你自己，仲有你嘅摯愛，簽名？刻不容緩<br />\n<br />\nPostal Code 請填000000，如果身處英國就填所在地點嘅Code<br />\n<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=LDhKEJhCApGKQi337qR8bwNVisxpnNpADW7ISUiLTyw%3D&h=6ae8278a\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"4a53c9834f133812178cfc16b4ba8f54724dabc8","tid":1525251,"uid":308875,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T10:25:15.000Z","msg":"推"},{"pid":"9f1a4685fa3e3d5d0cc238ca610b1da8d34e2fdb","tid":1525251,"uid":49128,"like":0,"dislike":0,"score":0,"quote":{"pid":"b9448ab9226bf8ccbfedd205cc520e2e925f716f","tid":1525251,"uid":23373,"like":0,"dislike":0,"score":0,"quote":{"pid":"aa2fb530b235b66099e4bb115f9bbf4ed7f4b5e8","tid":1525251,"uid":49128,"like":0,"dislike":0,"score":0,"quote":{"pid":"7ed4f1364bcaa937eafb55712dc8593fdd9fbb8d","tid":1525251,"uid":313498,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-31T21:04:26.000Z","msg":"係呀屌，易咳啲"},"citedBy":1,"replyTime":"2019-09-01T02:29:06.000Z","msg":"好唔舒服"},"citedBy":1,"replyTime":"2019-09-01T06:29:06.000Z","msg":"琴晚又玩放題，入哂通風系統"},"citedBy":0,"replyTime":"2019-09-01T10:56:09.000Z","msg":"轉搭第樣"},{"pid":"91b0a9bf49975831599f7a45256a7de00f765c41","tid":1525251,"uid":253954,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-01T13:00:18.000Z","msg":"係喎屌，我係屋企同公司都無事，一坐黨鐵就咳到仆街"},{"pid":"28c50c9d28d083915120301fa12227a32347c803","tid":1525251,"uid":49128,