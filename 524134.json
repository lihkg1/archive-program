hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"5fd890b5bd4c92fb175f306ca076cc972e7157bf","tid":524134,"uid":91664,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d688ddc2987c12aca8ada6fd14d81272bcd35bb","tid":524134,"uid":117009,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d45004f0e0a66d36dad6c3fe76d444c3ca3a242","tid":524134,"uid":91664,"like":5,"dislike":1,"score":4,"citedBy":1,"replyTime":"2018-01-09T09:38:36.000Z","msg":"依家澳洲一定好多熱褲背心人字拖<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-01-12T11:01:35.000Z","msg":"啲澳洲妹直頭著件比堅尼上身就咁係city行街"},"citedBy":1,"replyTime":"2018-01-12T11:06:48.000Z","msg":"圖<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"60ce04883cb9fe8dc042c4e7e5c267e92b24d6c8","tid":524134,"uid":117009,"like":0,"dislike":0,"score":0,"quote":{"pid":"5fd890b5bd4c92fb175f306ca076cc972e7157bf","tid":524134,"uid":91664,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d688ddc2987c12aca8ada6fd14d81272bcd35bb","tid":524134,"uid":117009,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d45004f0e0a66d36dad6c3fe76d444c3ca3a242","tid":524134,"uid":91664,"like":5,"dislike":1,"score":4,"citedBy":1,"replyTime":"2018-01-09T09:38:36.000Z","msg":"依家澳洲一定好多熱褲背心人字拖<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-01-12T11:01:35.000Z","msg":"啲澳洲妹直頭著件比堅尼上身就咁係city行街"},"citedBy":1,"replyTime":"2018-01-12T11:06:48.000Z","msg":"圖<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-12T11:13:29.000Z","msg":"好難當街影，得閒自己飛黎睇。<br />\n以前讀大學啲鬼妹成日戴個bra身上加件透到好似無著咁嘅衫就咁返學，見慣不怪了。"},{"pid":"3804f26b637d854006dce869c52bdb0a75758984","tid":524134,"uid":17103,"like":4,"dislike":7,"score":-3,"citedBy":0,"replyTime":"2018-01-12T11:34:14.000Z","msg":"單\u001b計暖化唔諗熱島效應同人口增長<br />\n<br />\n鬼佬自己都搵到原因<br />\n<br />\n<a href=\"http://www.smh.com.au/environment/urban-heat-island-effect-encompassing-western-sydney-20160119-gm97ps.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.smh.com.au%2Fenvironment%2Furban-heat-island-effect-encompassing-western-sydney-20160119-gm97ps.html&d=vByXwq9A9S3qxfAYXRYBf9ibCDpHM%2Bj7ejEBwfn5qys%3D&h=f42986f0\" target=\"_blank\">http://www.smh.com.au/environment/urban-heat-island-effect-encompassing-western-sydney-20160119-gm97ps.html</a><br />\n<br />\n關澳洲境外撚事咩, 係近十幾年人口增長同建築物料改變<br />\n<br />\n<img src=\"https://www.fairfaxstatic.com.au/content/dam/images/g/i/w/p/u/j/image.related.articleLeadwide.620x349.gm97ps.png/1453387228505.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.fairfaxstatic.com.au%2Fcontent%2Fdam%2Fimages%2Fg%2Fi%2Fw%2Fp%2Fu%2Fj%2Fimage.related.articleLeadwide.620x349.gm97ps.png%2F1453387228505.jpg&h=5ba1b4d1&s={SIZE}\" /><br />\n<br />\n<img src=\"https://images.theconversation.com/files/119034/original/image-20160418-23606-mjsnwt.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimages.theconversation.com%2Ffiles%2F119034%2Foriginal%2Fimage-20160418-23606-mjsnwt.png&h=de3a0d8e&s={SIZE}\" /><br />\n<br />\n<img src=\"https://newsroom.unsw.edu.au/sites/default/files/styles/full_width/public/thumbnails/image/snipimage_29_1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fnewsroom.unsw.edu.au%2Fsites%2Fdefault%2Ffiles%2Fstyles%2Ffull_width%2Fpublic%2Fthumbnails%2Fimage%2Fsnipimage_29_1.jpg&h=5f7209ea&s={SIZE}\" /><br />\n<br />\n大佬, 我鎖你係一間房當初空氣唔流通無野. 之後慢慢一個一個人放入黎每個人都有體溫. 最後可以過 40 度, 唔通又關房外既事咩. <br />\n<br />\n要 Funding 搵下 D 北極熊就黎死上頭版咪算囉. <br />\n<br />\n<a href=\"http://joannenova.com.au/2012/11/extreme-heat-in-1896-panic-stricken-people-fled-the-outback-on-special-trains-as-hundreds-die/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fjoannenova.com.au%2F2012%2F11%2Fextreme-heat-in-1896-panic-stricken-people-fled-the-outback-on-special-trains-as-hundreds-die%2F&d=vByXwq9A9S3qxfAYXRYBf9ibCDpHM%2Bj7ejEBwfn5qys%3D&h=6cc12766\" target=\"_blank\">http://joannenova.com.au/2012/11/extreme-heat-in-1896-panic-stricken-people-fled-the-outback-on-special-trains-as-hundreds-die/</a><br />\n<br />\n1896 年未有咁多炭排放, 新南威爾士洲 Bourke 呢個地方連續 3 日氣溫過 48.9 度, 夠唔夠極端天氣? 當年熱到周街死人好似末日咁.<br />\n<br />\n<a href=\"https://trove.nla.gov.au/newspaper/article/33121679?zoomLevel=4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftrove.nla.gov.au%2Fnewspaper%2Farticle%2F33121679%3FzoomLevel%3D4&d=vByXwq9A9S3qxfAYXRYBf9ibCDpHM%2Bj7ejEBwfn5qys%3D&h=d1531b57\" target=\"_blank\">https://trove.nla.gov.au/newspaper/article/33121679?zoomLevel=4</a><br />\n<br />\n<a href=\"http://trove.nla.gov.au/ndp/del/article/14033806?zoomLevel=6\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ftrove.nla.gov.au%2Fndp%2Fdel%2Farticle%2F14033806%3FzoomLevel%3D6&d=vByXwq9A9S3qxfAYXRYBf9ibCDpHM%2Bj7ejEBwfn5qys%3D&h=4c21a9b7\" target=\"_blank\">http://trove.nla.gov.au/ndp/del/article/14033806?zoomLevel=6</a><br />\n<br />\n<a href=\"http://trove.nla.gov.au/ndp/del/article/53682260?zoomLevel=6\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ftrove.nla.gov.au%2Fndp%2Fdel%2Farticle%2F53682260%3FzoomLevel%3D6&d=vByXwq9A9S3qxfAYXRYBf9ibCDpHM%2Bj7ejEBwfn5qys%3D&h=ed81a4c5\" target=\"_blank\">http://trove.nla.gov.au/ndp/del/article/53682260?zoomLevel=6</a>"},{"pid":"94bed190f5c95d181a0df4ba06311f47923ab301","tid":524134,"uid":14083,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-01-12T11:36:44.000Z","msg":"<blockquote>做咩一講暖化就冇曬人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n如果我話你知第二日得返20頭度你會唔會收皮，澳洲天氣不嬲都係咁架啦"},{"pid":"e6ec5b464455257d95ddd97a1809cc4e5b87fae4","tid":524134,"uid":49004,"like":4,"dislike":1,"score":3,"citedBy":1,"replyTime":"2018-01-12T11:41:27.000Z","msg":"熱咗 = 全球暖化<br />\n凍咗 = 極端天氣 氣候變化"},{"pid":"c81331c66533a40a9e1b40bbc4f3471c13c3c2f9","tid":524134,"uid":34103,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-01-12T11:44:28.000Z","msg":"此回覆已被刪除"},{"pid":"8329beb