ike":0,"dislike":0,"score":0,"quote":{"pid":"51fd6cefe6d65ddf5a3a23ef5bd3d779b9c39d1e","tid":2490840,"uid":196329,"like":1,"dislike":0,"score":1,"citedBy":4,"replyTime":"2021-04-16T02:14:23.000Z","msg":"喜茶會唔會考慮下搵姜b拍廣告洗底？"},"citedBy":0,"replyTime":"2021-04-16T02:18:15.000Z","msg":"香港未執哂？<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"3c9ffbb62f9bf426f99da833d03acbd0a4943520","tid":2490840,"uid":78039,"like":2,"dislike":2,"score":0,"quote":{"pid":"51fd6cefe6d65ddf5a3a23ef5bd3d779b9c39d1e","tid":2490840,"uid":196329,"like":1,"dislike":0,"score":1,"citedBy":4,"replyTime":"2021-04-16T02:14:23.000Z","msg":"喜茶會唔會考慮下搵姜b拍廣告洗底？"},"citedBy":0,"replyTime":"2021-04-16T02:19:28.000Z","msg":"跟住姜B幫襯藍業主買樓<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n黃藍雙循環<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"8d27456c7b2b11a7da7ac7b5c0683152565d2ea7","tid":2490840,"uid":221530,"like":0,"dislike":0,"score":0,"quote":{"pid":"51fd6cefe6d65ddf5a3a23ef5bd3d779b9c39d1e","tid":2490840,"uid":196329,"like":1,"dislike":0,"score":1,"citedBy":4,"replyTime":"2021-04-16T02:14:23.000Z","msg":"喜茶會唔會考慮下搵姜b拍廣告洗底？"},"citedBy":1,"replyTime":"2021-04-16T02:28:20.000Z","msg":"m 當奴都得啦，連登仔自有分數架啦<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"badd160d2b5a930d4d8f6a7ab8a852c118a7d2fd","tid":2490840,"uid":51752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-16T02:45:25.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"7014cc1da2bbd8a5d98df97e02a1b6420d7f013e","tid":2490840,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-16T03:39:58.000Z","msg":"<img src=\"https://cdn.thestandnews.com/media/photos/cache/Untitled-1-0820copy_2OeCw_1200x0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2FUntitled-1-0820copy_2OeCw_1200x0.png&h=322750c1&s={SIZE}\" /><br />\n<br />\n網民去年 5 月發起多區「和你 SING」，一名16 歲男學生涉闖入沙田新城市廣場 4 樓「喜茶」破壞收銀機等，早前承認刑毀罪，獲署理主任裁判官溫紹明判處 200 小時社會服務令。律政司不服判刑過輕提覆核獲批准，上訴庭法官潘兆初今指，考慮過最新報告及雙方陳詞後，決定改判少年入更生中心。<br />\n<br />\n少年聞判後表現平靜，其到庭旁聽的女親友則激動流淚，並著他「照顧好自己，撐住呀！」<br />\n<br />\n覆核刑期早前提訊時，法官潘兆初指當時的最新報告指少年患有哮喘，體能未能應付判入勞教中心，且法庭首次得知少年患哮喘，原審時相關報告並未提及該事宜，並指少年與校內體能表現突出，曾加入學校足球隊及連續４年於賽跑比賽中奪冠等，法庭對此表達關注，認為需索取進一步報告，押後今日再作判刑，並落令將相關的感化及社會服務令報告交予撰寫進一步報告的職員參閱，期間少年須繼續還押。<br />\n<br />\n法官潘兆初當時又指示答辯方於下次判刑時，提供相關少年患哮喘的醫療證明，包括他求診的醫生及診所資料，以及少最後一次求診的日期及當時的哮喘病情等。案件今提訊時，答辯方遞交了相關的醫療紀錄求情信等資料，並於律政司一方不反對下獲准呈堂。<br />\n<br />\n<a href=\"https://www.thestandnews.com/court/16-%E6%AD%B2%E7%94%B7%E7%94%9F%E8%AA%8D%E5%88%91%E6%AF%80-%E5%96%9C%E8%8C%B6-%E5%88%A4%E7%A4%BE%E6%9C%8D%E4%BB%A4-%E5%BE%8B%E6%94%BF%E5%8F%B8%E8%A6%86%E6%A0%B8%E6%88%90%E5%8A%9F-%E4%B8%8A%E8%A8%B4%E5%BA%AD%E6%94%B9%E5%88%A4%E5%85%A5%E6%9B%B4%E7%94%9F%E4%B8%AD%E5%BF%83/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F16-%25E6%25AD%25B2%25E7%2594%25B7%25E7%2594%259F%25E8%25AA%258D%25E5%2588%2591%25E6%25AF%2580-%25E5%2596%259C%25E8%258C%25B6-%25E5%2588%25A4%25E7%25A4%25BE%25E6%259C%258D%25E4%25BB%25A4-%25E5%25BE%258B%25E6%2594%25BF%25E5%258F%25B8%25E8%25A6%2586%25E6%25A0%25B8%25E6%2588%2590%25E5%258A%259F-%25E4%25B8%258A%25E8%25A8%25B4%25E5%25BA%25AD%25E6%2594%25B9%25E5%2588%25A4%25E5%2585%25A5%25E6%259B%25B4%25E7%2594%259F%25E4%25B8%25AD%25E5%25BF%2583%2F&d=Uh5SjXth0XRRLWSKrhPNwPaDgzkAO6tKN2FhpyhCcE0%3D&h=12af05f6\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F16-%25E6%25AD%25B2%25E7%2594%25B7%25E7%2594%259F%25E8%25AA%258D%25E5%2588%2591%25E6%25AF%2580-%25E5%2596%259C%25E8%258C%25B6-%25E5%2588%25A4%25E7%25A4%25BE%25E6%259C%258D%25E4%25BB%25A4-%25E5%25BE%258B%25E6%2594%25BF%25E5%258F%25B8%25E8%25A6%2586%25E6%25A0%25B8%25E6%2588%2590%25E5%258A%259F-%25E4%25B8%258A%25E8%25A8%25B4%25E5%25BA%25AD%25E6%2594%25B9%25E5%2588%25A4%25E5%2585%25A5%25E6%259B%25B4%25E7%2594%259F%25E4%25B8%25AD%25E5%25BF%2583%2F&h=159e563f\" data-auto-link target=\"_blank\">https://www.thestandnews.com/court/16-%E6%AD%B2%E7%94%B7%E7%94%9F%E8%AA%8D%E5%88%91%E6%AF%80-%E5%96%9C%E8%8C%B6-%E5%88%A4%E7%A4%BE%E6%9C%8D%E4%BB%A4-%E5%BE%8B%E6%94%BF%E5%8F%B8%E8%A6%86%E6%A0%B8%E6%88%90%E5%8A%9F-%E4%B8%8A%E8%A8%B4%E5%BA%AD%E6%94%B9%E5%88%A4%E5%85%A5%E6%9B%B4%E7%94%9F%E4%B8%AD%E5%BF%83/</a>"},{"pid":"af17ef21a3e59fc4502e8a9314dcf826f3ab3ca8","tid":2490840,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-16T04:08:11.000Z","msg":"去年5.13特首生日，網民發起18區「和你唱」，16歲男生在沙田新城市廣場「喜茶」用石頭損壞店內設施，承認一項刑事損壞罪，原判200小時社會服務令。惟律政司不滿刑罰過輕，提出覆核並要求改判拘禁式刑罰，以阻嚇日後破壞店舖的行為。上訴庭上月聽取雙方陳詞後，下令撤銷社服令，男生須還柙以等候多份報告。上訴庭今（16日）考慮報告內容，認為更生中心是最恰當的刑罰，遂改判男生入更生中心。<br />\n<br />\n十多名朋友到庭旁聽，男生離開前，旁聽人士大叫：「讀書呀！」、「照顧自己！」亦有人不禁哭泣。<br />\n<br />\n<a href=\"https://www.inmediahk.net/node/1082054\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1082054&d=Uh5SjXth0XRRLWSKrhPNwPaDgzkAO6tKN2FhpyhCcE0%3D&h=6ce5c06f\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1082054&h=e72e3285\" data-auto-link target=\"_blank\">https://www.inmediahk.net/node/1082054</a>"},{"pid":"ec74a3418619898d6324bf6fbfa7362a038a6838","tid":2490840,"uid":358948,"like":3,"dislike":1,"score":2,"quote":{"pid":"47488445e2e23ca8d6a8fc6def8b5df73a91a20d","tid":2490840,"uid":79793,"like":2,"dislike":12,"score":-10,"citedBy":2,"replyTime":"2021-04-16T02:08:42.000Z","msg":"前線手足就坐監<br />\n點估到幾年後賣藍店廣告都係黃絲<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-16T04:09:39.000Z","msg":"社運大贏家，準備買樓落地生根<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/sJ1P0xE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsJ1P0xE.jpg&h=f1a55df8&s={SIZE}\" />"},{"pid":"2ee5d89992d128c6ad63c16cc6fd06f840badd72","tid":2490840,"uid":230530,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-16T04:11:54.000Z","msg":"半年出唔出到嚟"},{"pid":"64194d3e329eb9fcb770a7b4deced98d9f3bf015","tid":2490840,"uid":196329,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec74a3418619898d6324bf6fbfa7362a038a6838","tid":2490840,"uid":358948,"like":3,"dislike":1,"score":2,"quote":{"pid":"47488445e2e23ca8d6a8fc6def8b5df73a91a20d","tid":2490840,"uid":79793,"like":2,"dislike":12,"score":-10,"citedBy":2,"replyTime":"2021-04-16T02:08:42.000Z","msg":"前線手足就坐監<br />\n點估到幾年後賣藍店廣告都係黃絲<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-16T04:09:39.000Z","msg":"社運大贏家，準備買樓落地生根<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/sJ1P0xE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsJ1P0xE.jpg&h=f1a55df8&s={SIZE}\" />"},"citedBy":1,"replyTime":"2021-04-16T04:15:19.000Z","msg":"賺藍圈錢<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"fc477471f00adef3632ebfd03b3195171085ae16","tid":2490840,"uid":240362,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-04-16T06:52:48.000Z","msg":"<img src=\"https://hk.appledaily.com/resizer/O9lFqP1Ixay4nOJ_-OYBAGupFiw=/802x451/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/DNJEA52OS5FXDEKKELCXQ5IQAM.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FO9lFqP1Ixay4nOJ_-OYBAGupFiw%3D%2F802x451%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FDNJEA52OS5FXDEKKELCXQ5IQAM.jpg&h=4614f06d&s={SIZE}\" /><br />\n<br />\n17歲男生去年5月在沙田新城市廣場「賀」行政長官林鄭月娥生辰，其間參與破壞飲品店「喜茶」，及後承認刑事毀壞罪，被判接受200小時社會服務令。律政司早前成功向上訴庭申請覆核刑期，上訴庭先後兩次索取勞教中心、教導所、更生中心報告，以及男生有關哮喘問題的醫療報告，今日決定改判他入住更生中心。<br />\n<br />\n上訴庭早前已接納律政司一方申請，認為原審裁判官判處案中周姓男生履行社會服務令，屬原則性犯錯，刑罰過輕。上訴庭首次索閱勞教中心、教導所及更生中心報告，協助判刑；惟報告指男生自幼患有哮喘，身體狀況不宜判入勞教中心，故不作此建議。<br />\n<br />\n上訴庭卻認為，有關報告內容與原審時感化報告透露男生在運動方面有出色表現的說法不脗合，當中更提及他是足球校隊成員且賽跑多次獲獎。上訴庭決定再索取進一步報告，並要求男生提供過往醫療紀錄，始作判刑。<br />\n<br />\n代表男生的大律師吳建五向法庭申請將男生醫療紀錄和求情信呈堂，並陳詞要求改判更生中心。上訴庭經商議後，首席法官潘兆初宣判，考慮進一步報告內容及陳詞後，同意改判男生進入更生中心。<br />\n<br />\n<a href=\"https://hk.appledaily.com/local/20210416/QKTZD4XCNBEMRKTPANBIRS4TVA/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210416%2FQKTZD4XCNBEMRKTPANBIRS4TVA%2F&d=Uh5SjXth0XRRLWSKrhPNwPaDgzkAO6tKN2FhpyhCcE0%3D&h=26bb63a9\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210416%2FQKTZD4XCNBEMRKTPANBIRS4TVA%2F&h=d797de60\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20210416/QKTZD4XCNBEMRKTPANBIRS4TVA/</a>"},{"pid":"0838d6ef8308d0488b701625b4682b58d4029444","tid":2490840,"uid":121197,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ee5d89992d128c6ad63c16cc6fd06f840badd72","tid":2490840,"uid":230530,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-16T04:11:54.000Z","msg":"半年出唔出到嚟"},"citedBy":0,"replyTime":"2021-04-16T07:01:59.000Z","msg":"更生中心3-9個月"},{"pid":"c94df9416957b582d72f66618d53b535c38669c9","tid":2490840,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-16T07:04:03.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"67890f029d8574df8b1e6def92a9a19ab6a9c428","tid":2490840,"uid":56115,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-16T10:04:34.000Z","msg":"夾硬還押咁耐, 你扣俾佢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />?"},{"pid":"fa9f98489cbeef87daa64637384a8c3c5bd1389b","tid":2490840,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-16T10:38:21.000Z","msg":"<img src=\"/a