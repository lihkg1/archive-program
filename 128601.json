kgmoji\" />"},{"pid":"c939954cde32c55081a887f93e0d19231d492ce0","tid":128601,"uid":3713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-21T04:12:46.000Z","msg":"帶頭起義啦"},{"pid":"cdbd320906cfae46d74dd2112ac7bf61ecc47372","tid":128601,"uid":34203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-21T04:20:47.000Z","msg":"點解話佢做到野? 例子?<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"6c9996019735a0035a2342cf3746e064bc1627a3","tid":128601,"uid":44646,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-21T04:26:37.000Z","msg":"<blockquote><blockquote>其實泛民策略上應該畀提名佢入<br />\n<br />\n佢同林鄭票源重疊，有機會界票<br />\n而且佢委屈咁耐，入閘實咬住林鄭<br />\n反而送胡、曾，會提高攬炒機會</blockquote><br />\n<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /><br />\n其實呢個小圈子遊戲係無鎅票同攬炒呢樣嘢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n夠600票就當選，無人夠就篩淨兩個再投。<br />\n邊有得鎅票同攬炒？</blockquote><br />\n<br />\n其實有。<br />\n界票未必界死林鄭，但可以令佢低票上任<br />\n<br />\n至於攬炒，如果「泛民可接受」既候選人有2人入，<br />\n而泛民睇來會分散投票<br />\n建制就無動機作反(因為無用)<br />\n<br />\n相反，如果泛民全票支持一人<br />\n而其人又可吸一定建制票<br />\n中間唔喜歡西環既建制就會計數<br />\n不如投佢<br />\n<br />\n反正暗票，事後唔認亦吹佢唔脹"},{"pid":"7cccf94984c19e87023dd4642665253d7e7dbfa1","tid":128601,"uid":32325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-21T04:31:12.000Z","msg":"洗乜理佢係真心定扮嘢駁同情吖<br />\n兩年幾先開始明白已經<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"026beb891362d57a50c25c782a74185468489625","tid":128601,"uid":27909,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-21T04:32:17.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"41bb642a4b18b23651c5d10e3c30008da053cb6d","tid":128601,"uid":40839,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-21T04:33:03.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote>仆街啦<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n<br />\n究竟係我真心定佢真心<br />\n<br />\n我竟然覺得呢舖佢係真心<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n終於明白點解呢個叫小圈子選舉，明白面對極權打壓既感受<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /></blockquote><br />\n而家全香港最想要公民提名既就係佢<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" /></blockquote><br />\n咁又真, 葉劉係公務員聲望好高(聽講佢係少數做到野得黎又唔會高高在上, 同佢個樣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />, public image完全唔同), 有普選佢真係有機會贏</blockquote><br />\n<br />\n4個入面，我覺得葉劉工作能力最高，對下屬又好。不過，唔知點解佢對外人緣咁差。政治岡位唔係話有能力同你想做就做到，可惜</blockquote><br />\n除奶共政策以外 其實葉劉推既政策係好撚正常<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n之前支持香港舉辦國際數學奧林匹克<br />\n再搞左個獎學會每年比100個未去過外國讀書既學生去名校留學<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n如果係泛民 只會鳩up開多啲垃圾bba學位/nursing學位<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bf41d801a76a4d8f056e8daf2571bf21cd1b2117","tid":128601,"uid":1788,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-21T04:36:17.000Z","msg":"佢係跟足指令既人，上面叫到佢一定全力做。<br />\n<br />\n反而自己搞個d，佢無咁盡"},{"pid":"b2a5a574c82e2baf18428110a14a27bee6c988bd","tid":128601,"uid":4312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-21T04:40:23.000Z","msg":"吹奏完曾蔭權呢家連葉劉都吹奏<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7554e83118c1c910145a50478bf28611b6b45dc8","tid":128601,"uid":70368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-21T04:41:16.000Z","msg":"佢計錯數<br />\n<br />\n其實一早向泛民看,佢得到既一定比而家多.,點都好過兩面不討好<br />\n上次已經拎唔到都唔buy佢<br />\n係我就一早睇路,做返個人,叫座不叫好,不如叫好不叫座"},{"pid":"2353dddfa509bca6331936928a20909e08c71380","tid":128601,"uid":54876,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"20