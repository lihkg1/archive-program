aces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n我而家已經迫自己唔好用咁多<br />\n隔住post～唔好比自己咁懶<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8cf1da5cf20d69f1dfe24d2a36921c351c69ac70","tid":336061,"uid":835,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T06:43:55.000Z","msg":"新手留名學野"},{"pid":"1f984e8edd4946677b029ed1d5a850d731334b38","tid":336061,"uid":4525,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T06:48:07.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"ce28077f3552704bc8913fb435a7356ecb29f2e0","tid":336061,"uid":34489,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T07:10:04.000Z","msg":"老娘<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"b82b21a453a3fea79d53c8676cbc009adccdda9e","tid":336061,"uid":73160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T13:19:25.000Z","msg":"無乜人鍾意食羊<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n好想食<img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" />"},{"pid":"4baa92b770c5e598fe3a354248ad2433be257d29","tid":336061,"uid":29675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T13:30:21.000Z","msg":"<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"9712a0cc7957a513784327475148e76c7c746fe0","tid":336061,"uid":30742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T14:37:57.000Z","msg":"<blockquote>新手留名學野</blockquote><br />\n<img src=\"/assets/faces/lomoji/07.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/07.png\" class=\"hkgmoji\" />"},{"pid":"4d540378c797f332355854771a2c75c723f1cf93","tid":336061,"uid":30742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T14:38:07.000Z","msg":"<blockquote>老娘<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"2c72d4bc0a26fc9c6a3b102fb5dfb34d1fb812ca","tid":336061,"uid":30742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T14:38:49.000Z","msg":"<blockquote>無乜人鍾意食羊<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n好想食<img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" /></blockquote><br />\n我身邊都無人嗜羊<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n我好鍾意陣騷味<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"55c72841aa3e4538229142110cb01078eca80e08","tid":336061,"uid":10292,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T14:39:33.000Z","msg":"羊肉正啊"},{"pid":"9c8a7c02d1054603152f0ca9d07877282652a60c","tid":336061,"uid":30742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T14:53:42.000Z","msg":"<blockquote>羊肉正啊</blockquote><br />\n下次整羊架<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"a66de68c5c47dff2b0d1134fb4fb53b2fe3e5cae","tid":336061,"uid":835,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T15:29:19.000Z","msg":"我成日都覺得咁樣咖喱出黎好勁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n同埋終於知道咩材料<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d8bae2aa7b3d696e15003925faf318f4bc2cd32c","tid":336061,"uid":30742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T15:49:23.000Z","msg":"<blockquote>我成日都覺得咁樣咖喱出黎好勁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n同埋終於知道咩材料<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n之前我都以為會好複雜..好麻煩<br />\n原來執齊料又唔係真係好難<br />\n當然我應該唔係好正宗啦<br />\n但咁執料自己磨都幾有趣<br />\n煮完又真係有陣咖哩香<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"51b4e24073253416f1921c3b45277d776c61a00b","tid":336061,"uid":22736,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T16:14:01.000Z","msg":"58度可以煮熟肉類<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"85d3fcdbefc2d893b137ccf960cb8811571564d8","tid":336061,"uid":1249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T16:22:15.000Z","msg":"老娘點睇依款<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> 有無伏<br />\n<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"b1d64999f6adb18b8e29e1b6377a59efd8480744","tid":336061,"uid":30742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T16:42:00.000Z","msg":"<blockquote>58度可以煮熟肉類<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<a href=\"http://winniekitchenwork.blogspot.hk/2016/06/the-science-of-sous-vide.html?m=1\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwinniekitchenwork.blogspot.hk%2F2016%2F06%2Fthe-science-of-sous-vide.html%3Fm%3D1&d=R39rRjhGqRHJV8Ki76lo2r%2BHiWCy6q6AsXO%2BLNmzhis%3D&h=5cee95b9\" target=\"_blank\">http://winniekitchenwork.blogspot.hk/2016/06/the-science-of-sous-vide.html?m=1</a><br />\n<br />\n睇你點睇熟既定義！<br />\n如果係殺死細菌<br />\n每種肉所要求既溫度都唔同！蛋白質分解所需時間都唔同！<br />\n<br />\n慢煮真係科學黎！仲要慢慢研究！"},{"pid":"4d9f3b03a30a3a81f23a60e9de76e11ed1494f5e","tid":336061,"uid":30742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T16:42:37.000Z","msg":"<blo