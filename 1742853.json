g":"行政長官可豁免公佈與特定的司法警察局工作人員的晉升開考的名單、任用等有關的行為。"},{"pid":"120b8e7ec389da62b7967471196d28468918332a","tid":1742853,"uid":149342,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-21T03:32:36.000Z","msg":"美國應該罪尻澳門賭場錢"},{"pid":"a0886f149992e68b088a9344336753c726943628","tid":1742853,"uid":228995,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T03:32:43.000Z","msg":"以前唔得咩"},{"pid":"9bb6bb972f18299f21fd307a05bb307027cd0440","tid":1742853,"uid":54373,"like":0,"dislike":0,"score":0,"quote":{"pid":"120b8e7ec389da62b7967471196d28468918332a","tid":1742853,"uid":149342,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-21T03:32:36.000Z","msg":"美國應該罪尻澳門賭場錢"},"citedBy":0,"replyTime":"2019-11-21T03:33:01.000Z","msg":"支那人都唔敢啦"},{"pid":"83ffcd1f32925a9d89e0e31830b731f2db203d0d","tid":1742853,"uid":74278,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T03:33:40.000Z","msg":"馬交真係好撚垃圾<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ca6b2bd057db0984231c033eda813a8263ae052a","tid":1742853,"uid":113000,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T03:34:12.000Z","msg":"澳門不了"}]}