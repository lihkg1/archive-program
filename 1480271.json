ets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\nGo big or go home<br />\n唔收GCD皮咁多血汗淚水就白出架喇"},{"pid":"48c2c8674d61321c033fd7551625fe9162aba7c7","tid":1480271,"uid":289978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T09:00:48.000Z","msg":"<span style=\"font-size: xx-large;\">聯臺抗共</span>"},{"pid":"6363a0f76336e2568a9e1a7c0b8bc3128c6c99f5","tid":1480271,"uid":89898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T09:03:09.000Z","msg":"<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},{"pid":"f06ce471279f453a31703c61e0b88922611bf13a","tid":1480271,"uid":270871,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T09:05:20.000Z","msg":"同意<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},{"pid":"9848580aa4cb783185baadcb9cce9db882fc47f5","tid":1480271,"uid":89898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T09:17:24.000Z","msg":"818<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}