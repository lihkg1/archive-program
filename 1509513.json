mg src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d2c4dfa9bc31e4b276d49c7abe8d9a7826cddf10","tid":1509513,"uid":4322,"like":0,"dislike":0,"score":0,"quote":{"pid":"e2b29c89b593ad8dfc7f283215e814a0ccd98a0b","tid":1509513,"uid":236368,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-27T01:33:00.000Z","msg":"暗地裡欺凌先得人驚<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-27T01:42:36.000Z","msg":"都得呀"},{"pid":"0b222b26b180043663b616ef06b0fcc0ab23a054","tid":1509513,"uid":4322,"like":0,"dislike":0,"score":0,"quote":{"pid":"1655d1c9fe79b9586a19fb02e7797a7c062eb01a","tid":1509513,"uid":215901,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-08-27T01:41:25.000Z","msg":"笑撚死<br />\n成班人屈鳩番你個仔打人都仲得<br />\n吹咩 哈哈哈哈哈<br />\n犯乜撚法"},"citedBy":0,"replyTime":"2019-08-27T01:42:46.000Z","msg":"唔好屈呀"},{"pid":"22ab30330023f038f50e0dfe995b578a7cf434e7","tid":1509513,"uid":113250,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-27T01:44:42.000Z","msg":"欺凌係已發展地區入面從來都解決唔到的問題<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"e7f83e969e7323721e9b4a17814a7bb7748857a7","tid":1509513,"uid":8830,"like":0,"dislike":0,"score":0,"quote":{"pid":"22ab30330023f038f50e0dfe995b578a7cf434e7","tid":1509513,"uid":113250,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-27T01:44:42.000Z","msg":"欺凌係已發展地區入面從來都解決唔到的問題<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-27T01:52:05.000Z","msg":"唉呀 好擔心狗二代被欺凌添"},{"pid":"70b84caec60f0aa1c0061c9e18f6d46bddb97398","tid":1509513,"uid":52341,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T02:08:00.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"91f2e5a042e7b5aafe31e1fdb31e9f6a1a325dc8","tid":1509513,"uid":4322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T14:17:04.000Z","msg":"Pishhhh"},{"pid":"b94f4811c890be0892dd7ba0572f0803644e01b2","tid":1509513,"uid":156666,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T12:50:31.000Z","msg":"<span style=\"font-size: xx-large;\"><strong>保護警察兒女 你我有責</strong></span><br />\n================================<br />\n各位中小學生 為左保護警察兒女<br />\n如果有確鑿證據證明邊位同學老豆老母係警察既話記得要<br />\n1.搵人放佢大頭相上黎<br />\n2.寫埋住邊區<br />\n3.寫埋讀咩學校<br />\n等市民可以隨時留意住佢地有冇比人欺凌 係有需要既時候可以保護佢地<br />\n<br />\n因為欺凌係唔局限係校園架<br />\n而家市民咁仇警 有人可能會作出自然反應係街上做小動作搞警察兒女<br />\n例如:<br />\n1.唔小心撞佢出馬路<br />\n2.警察兒衝紅燈個陣唔小心女擋住佢唔比佢上行人路<br />\n3.唔小心踼/撞佢落樓梯<br />\n4.係街拍蚊個陣唔小心打中佢<br />\n5.係巴士唔小心擋住佢唔比佢落車<br />\n6.係巴士/小巴唔小心唔讓開比佢入去靠窗位坐<br />\n7.係巴士/小巴唔小心唔讓開比佢離開個靠窗位<br />\n8.係行人路/過馬路個陣唔小心&quot;KICK&quot;跌佢<br />\n9.唔小心擋住LIP口唔比佢入升降機<br />\n10.警察兒女趕返學搭LIP個陣 唔小心撳哂咁多層<br />\n11.係佢要上車/追車個陣唔小心扮健身撚當街捉住佢扮SALE野唔比佢走 <br />\n12.係街上唔小心撞佢落花槽<br />\n13.唔小心撞佢部手機落地<br />\n14.唔小心撞佢手上拎住既其他野落地<br />\n15.唔小心倒瀉野食/野飲落佢地件校服到<br />\n16.唔小心倒瀉野食/野飲「入」佢地個書包到<br />\n17.係鋪頭入面唔小心放左啲未比錢既野入佢個袋到<br />\n18.係佢行過個陣唔小心屋企倒屎水/污糟水落樓<br />\n19.唔小心打開佢書包拉鍊 等佢啲野跌哂出黎 <br />\n20.唔小心放啲蛇蟲鼠蟻入佢書包<br />\nETC.<br />\n<br />\n大家見到有人咁人既話記得要保護佢地 就算啲警察兒女幾忙幾趕時間都要捉住佢地幫佢地報警 唔好比佢地走<br />\n你地知香港警察做野幾有效率架啦 一個人日日等幾次39分鐘都唔係好嘥時間姐<br />\n如果佢地自己打電話想搵人幫手 千祈唔好唔小心轟佢部手機落地然後踢到母雷公咁遠<br />\n<br />\n<a href=\"https://lihkg.com/thread/1516112/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1516112/page/1</a><br />\n<a href=\"https://lihkg.com/thread/1516100/page/1?post=2\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1516100/page/1?post=2</a>"}]}