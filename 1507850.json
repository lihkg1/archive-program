-08-26T12:08:09.000Z","msg":"五大訴求<br />\n缺一不可"},{"pid":"0d7bc8f0bd2a0dfc0030c3440199760288f98676","tid":1507850,"uid":143131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T12:08:26.000Z","msg":"光復香港<br />\n時代革命"},{"pid":"5d078dda20b08327a61a3e91c3f28f60b0632002","tid":1507850,"uid":130471,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T12:09:26.000Z","msg":"推"},{"pid":"fbbd4e51eca19858af0a378e2bcf9dec70a56935","tid":1507850,"uid":143131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T12:14:02.000Z","msg":"推"},{"pid":"5ebbe95b180b1aa5138603083a13dfcfb744617d","tid":1507850,"uid":143131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T12:33:40.000Z","msg":"五大訴求"},{"pid":"267714f26a255b5e624b6fd8b2a3936b90653d79","tid":1507850,"uid":215035,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T12:58:11.000Z","msg":"推"},{"pid":"f2714bb4c4b72577bcaf97260695f6c082273f37","tid":1507850,"uid":233009,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T12:59:11.000Z","msg":"推"},{"pid":"342f281485d14fc0843480d7f8591176e46eb7e8","tid":1507850,"uid":288154,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T14:52:16.000Z","msg":"<span style=\"font-size: x-large;\">聯絡全球外國學生<br />\n中學生聯絡中學生<br />\n大學生聯絡大學生<br />\n講解學生運動需要各國學生支援<br />\n講解全因大陸人治，所以不得引渡</span>"},{"pid":"e36e2c451499bdc86f68f08528555f7672e1f04c","tid":1507850,"uid":52842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T15:18:13.000Z","msg":"推"},{"pid":"c6bf23ec88999404838a8ec8d7da3bbb1add3e16","tid":1507850,"uid":52842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T15:18:27.000Z","msg":"721"},{"pid":"b2db520a7b5cadcca3bb24ae5862e04db80886b4","tid":1507850,"uid":52842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T15:18:49.000Z","msg":"光復香港<br />\n時代革命"},{"pid":"878b24646c3c69356cef685f89b97b022bef26fe","tid":1507850,"uid":52842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T15:19:16.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"8bf7706aafc1d018e15f9728ec491ab5e3694d30","tid":1507850,"uid":18959,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T15:40:25.000Z","msg":"pish"},{"pid":"4018745a24941c937200e37e563e945b8f68d6f4","tid":1507850,"uid":50178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T15:41:18.000Z","msg":"push"},{"pid":"0ac832719420df8bf0bd4b4c312d6ed7b4c65351","tid":1507850,"uid":143131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T19:14:49.000Z","msg":"推"},{"pid":"5f7cd16c562a54a11c8add037fc9aa8ea7c3a2cb","tid":1507850,"uid":143131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T19:15:04.000Z","msg":"推"},{"pid":"ac1aac099232e452242b07fe4e5f12e641b64792","tid":1507850,"uid":143131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T19:32:00.000Z","msg":"推"},{"pid":"dfb584855f03378d4d63e09121a5232f6865326f","tid":1507850,"uid":23098,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-26T19:38:39.000Z","msg":"罷課既繼續去罷課<br />\n同狗仔狗女玩既 繼續去同狗仔狗女玩"},{"pid":"bc1a8716887765ccdf3e7479379bd925b5e5a28c","tid":1507850,"uid":143131,"like":0,"dislike":0,"score":0,"quote":{"pid":"dfb584855f03378d4d63e09121a5232f6865326f","tid":1507850,"uid":23098,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-26T19:38:39.000Z","msg":"罷課既繼續去罷課<br />\n同狗仔狗女玩既 繼續去同狗仔狗女玩"},"citedBy":0,"replyTime":"2019-08-26T19:39:58.000Z","msg":"盡做，最多做到邊一步<br />\n就做邊一步"},{"pid":"7fe31ed590cb8ff5d4560d900e0898569d75a010","tid":1507850,"uid":143131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T19:58:08.000Z","msg":"推唔起<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"d1c95cb8933eaf2ef268ae829c793cce3729