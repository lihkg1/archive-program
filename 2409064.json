21:28.000Z","msg":"加油呀<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"f6ec9cd6abdc80f0c3df975c746debf3056a6b45","tid":2409064,"uid":266041,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-02-15T18:22:03.000Z","msg":"我都識一個舊同事好後生淋巴癌 見住佢有一個大隻後生仔變到非常瘦弱 都知道抗癌既痛苦...<br />\n幸好後尾知道佢都好返！抗癌真係長期鬥爭<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><br />\n樓主要撐過去呀 早日康復！<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"acda4872cb815be138f84b99524d083efd152c41","tid":2409064,"uid":6738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-15T19:54:49.000Z","msg":"加油呀<img src=\"/assets/faces/cow/power.gif\" class=\"hkgmoji\" />"},{"pid":"d29c0d9b4f1a687859cf9a51e0ae0f6f9b2648a1","tid":2409064,"uid":206018,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-02-15T20:40:24.000Z","msg":"祝早日康復<img src=\"/assets/faces/mouse/smile.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" />"},{"pid":"41b9374dde2d6db82515fd037b97c4534fbeee20","tid":2409064,"uid":207900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-15T22:30:19.000Z","msg":"樓主加油！"},{"pid":"cf54f6457eed6cabb6bbf1cd9ad8c31a98bf3c20","tid":2409064,"uid":85578,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-15T23:07:02.000Z","msg":"樓主加油<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />後生應該可以好返晒！加油抗癌！祝你早日康復！"},{"pid":"65a7c8ffab730c868296b3d36d7f996b387ca843","tid":2409064,"uid":125515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-16T00:05:49.000Z","msg":"祝樓主早日康復<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"97414dc4e7fba6fd3f730a4592db2ff4a6e0261e","tid":2409064,"uid":391992,"like":0,"dislike":0,"score":0,"quote":{"pid":"d29c0d9b4f1a687859cf9a51e0ae0f6f9b2648a1","tid":2409064,"uid":206018,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-02-15T20:40:24.000Z","msg":"祝早日康復<img src=\"/assets/faces/mouse/smil