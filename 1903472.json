ormal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"3ae61bd2ed647fb982dc087e273f4d4b2235a7d1","tid":1903472,"uid":147226,"like":1,"dislike":0,"score":1,"quote":{"pid":"5df26bf92cf2c79d8a4a68c100a6553da2eb6946","tid":1903472,"uid":118890,"like":0,"dislike":0,"score":0,"quote":{"pid":"6f7fd4739bdda36f304762c356dba5df0e9e07e8","tid":1903472,"uid":147226,"like":1,"dislike":0,"score":1,"quote":{"pid":"18c738f5dc1001be610cdfff3a6deefec934afc9","tid":1903472,"uid":118890,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2020-02-29T04:17:12.000Z","msg":"點會唔係第九聲<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n七八九聲係韻母/p, t, k/ 收尾<br />\n唔關元音事"},"citedBy":2,"replyTime":"2020-02-29T04:36:18.000Z","msg":"「賊」應該係八聲唔係九聲？"},"citedBy":1,"replyTime":"2020-02-29T05:04:43.000Z","msg":"如果第八聲就會係「策」，即係對應返第三聲嘅有/p, t, k/ as final consonant （caak3)"},"citedBy":1,"replyTime":"2020-02-29T05:48:00.000Z","msg":"「賊」諗落有兩個讀法<br />\n<br />\n「賊仔」 -- 的確係九聲<br />\n「捉賊」 -- 其實呢個係第幾聲？類似「住宅」、「飽魚刷」，諗落其實七、八、九聲都唔係"},{"pid":"b10bb9bac3b8be96e2f1b08a94708602f490dd0a","tid":1903472,"uid":118890,"like":2,"dislike":0,"score":2,"quote":{"pid":"3ae61bd2ed647fb982dc087e273f4d4b2235a7d1","tid":1903472,"uid":147226,"like":1,"dislike":0,"score":1,"quote":{"pid":"5df26bf92cf2c79d8a4a68c100a6553da2eb6946","tid":1903472,"uid":118890,"like":0,"dislike":0,"score":0,"quote":{"pid":"6f7fd4739bdda36f304762c356dba5df0e9e07e8","tid":1903472,"uid":147226,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-02-29T04:36:18.000Z","msg":"「賊」應該係八聲唔係九聲？"},"citedBy":1,"replyTime":"2020-02-29T05:04:43.000Z","msg":"如果第八聲就會係「策」，即係對應返第三聲嘅有/p, t, k/ as final consonant （caak3)"},"citedBy":1,"replyTime":"2020-02-29T05:48:00.000Z","msg":"「賊」諗落有兩個讀法<br />\n<br />\n「賊仔」 -- 的確係九聲<br />\n「捉賊」 -- 其實呢個係第幾聲？類似「住宅」、「飽魚刷」，諗落其實七、八、九聲都唔係"},"citedBy":0,"replyTime":"2020-02-29T06:16:20.000Z","msg":"yes，因為有啲入聲字有變調，都categorize唔到落一三六（七八九）聲，例子有捉「賊」、人「日」，所以而家都有一啲linguists會用十一調system，可參考: <a href=\"https://www.facebook.com/270389769994437/posts/328532710846809/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F270389769994437%2Fposts%2F328532710846809%2F%3Fd%3Dn&d=OftESTy%2BPOS3A4jdltYT2yvt59O44HeJS3%2BtxtDyp5g%3D&h=3dca29e4\" data-auto-link target=\"_blank\">https://www.facebook.com/270389769994437/posts/328532710846809/?d=n</a><br />\n<br />\n第十一聲就似呢個case，final consonant係/p, t, k/，但係唔係tone 136，而係tone 2<br />\n<br />\n廣東話係tonal language，考慮埋變調就真係可以分到好細（<del>or 好複雜</del><img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />），所以而家都多咗人唔考慮入聲字因素，用六聲system做transcription<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n係有啲位有少少debatable 嘅，但正正因為呢個語言咁sophisticated所以更要好好保護佢<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"}]}