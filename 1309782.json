data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdiscord.gg%2FFWnkyd2&d=QCZ5VELzTGqQZzcx9zTUyg9axkDoCoA19ZsVt7gViHY%3D&h=f31c0753\" data-auto-link target=\"_blank\">https://discord.gg/FWnkyd2</a><br />\n<br />\n期待各位的加入<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"1c373730dd0894ed65ce6fcf8dc21074162344aa","tid":1309782,"uid":136737,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-12T12:50:50.000Z","msg":"推"},{"pid":"8c26f59ec14b9f25e04407f5892177aba61f31b8","tid":1309782,"uid":93649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T13:04:02.000Z","msg":"wanna join"},{"pid":"e5bbe793e2ccd56f4c596a6c968a15414af81224","tid":1309782,"uid":215048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T13:17:08.000Z","msg":"留個名<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"31c7d4724d3060e7f2f07b5617820fb7cb47f1b6","tid":1309782,"uid":136737,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-12T14:23:14.000Z","msg":"多謝支持<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"a1785f920390a877dc4ba487f683e0906ada8a3b","tid":1309782,"uid":143241,"like":0,"dislike":8,"score":-8,"citedBy":1,"replyTime":"2019-07-12T14:23:50.000Z","msg":"點睇都係sa好玩啲"},{"pid":"40ec4afbf08729573fb478e4598563c7d9ed53ee","tid":1309782,"uid":136737,"like":1,"dislike":1,"score":0,"quote":{"pid":"a1785f920390a877dc4ba487f683e0906ada8a3b","tid":1309782,"uid":143241,"like":0,"dislike":8,"score":-8,"citedBy":1,"replyTime":"2019-07-12T14:23:50.000Z","msg":"點睇都係sa好玩啲"},"citedBy":0,"replyTime":"2019-07-12T16:28:42.000Z","msg":"兩睇啦 多元化就肯定sa 但講真實同靚一定係GTA5。<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"38dd3f7e61cad31d8a95f3bbd7577649b138e6e8","tid":1309782,"uid":136737,"li