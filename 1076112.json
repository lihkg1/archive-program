rc=\"https://na.cx/i/Wm6zJ0i.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWm6zJ0i.png&h=acae1203&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-03-24T17:16:01.000Z","msg":"果個john講嘅嘢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n台豬<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"015a1f287c49009c7462e755350ae27e2da295a0","tid":1076112,"uid":35790,"like":0,"dislike":0,"score":0,"quote":{"pid":"176e99f8f6b492bf352126ae57cf2912a6a24369","tid":1076112,"uid":226955,"like":4,"dislike":0,"score":4,"quote":{"pid":"4f228359afa9d345e6d2ac1e312825d2ce3b0e1a","tid":1076112,"uid":44788,"like":0,"dislike":5,"score":-5,"citedBy":2,"replyTime":"2019-03-24T17:12:05.000Z","msg":"睇下台灣人點講<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/7ZTRMdD.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7ZTRMdD.png&h=0d5e96dc&s={SIZE}\" /><img src=\"https://na.cx/i/Wm6zJ0i.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWm6zJ0i.png&h=acae1203&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-03-24T17:15:46.000Z","msg":"Yahoo 出名多五毛駐腳<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-24T17:16:51.000Z","msg":"點解唔睇吓ptt"},{"pid":"adb9d0cfd6afa7b5ec9d1f3fd786e93ddb35e330","tid":1076112,"uid":226955,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2019-03-24T17:18:06.000Z","msg":"我係蔡英文就以叛國罪，廢韓國瑜中華民國國籍，兼送返大陸<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />比着以前兩蔣時代，佢已經要打耙啦"}]}