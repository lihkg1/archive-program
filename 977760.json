<br />\n根本就算唔貪生活質素都高過搵多一倍人工既人<br />\n<br />\n所以講習總幾錢人工冇咩意思，根本就反映唔到佢既生活質素"},{"pid":"2ab41bf12f0fe6c704b2db1c1b230d20933e38cc","tid":977760,"uid":19454,"like":0,"dislike":0,"score":0,"quote":{"pid":"b590b43496f945d922142265686fcdc78411060a","tid":977760,"uid":39470,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-01-11T12:16:17.000Z","msg":"工（資）高蓋主<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-11T13:15:09.000Z","msg":"x2"},{"pid":"bb26f9e587a75ed948537c589f82eb086a50f5ec","tid":977760,"uid":19454,"like":1,"dislike":0,"score":1,"quote":{"pid":"9ee4cbd98d4a84ef1943d1814a550fb5bf68b54e","tid":977760,"uid":213441,"like":0,"dislike":0,"score":0,"quote":{"pid":"08c66b8c63cc3644c5e018dd4adae96cdb24c3e4","tid":977760,"uid":7550,"like":1,"dislike":1,"score":0,"quote":{"pid":"b0e7f4d83dc4bf1b83e31d7c2350adf4f0079cfb","tid":977760,"uid":41007,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-01-11T12:14:44.000Z","msg":"年薪高但貪五千萬又係貪<br />\n同年薪低貪 你揀邊樣？"},"citedBy":2,"replyTime":"2019-01-11T12:20:29.000Z","msg":"貪曾咪完美話你知高薪養廉係唔WORK囉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-11T12:30:42.000Z","msg":"支那貪官比例多定香港多"},"citedBy":0,"replyTime":"2019-01-11T13:19:32.000Z","msg":"香港呢方面唔會執輸，全速追趕中<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}