\n<a href=\"http://www.police.gov.hk/ppp_tc/05_traffic_matters/enforcement.html。\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.police.gov.hk%2Fppp_tc%2F05_traffic_matters%2Fenforcement.html%E3%80%82&d=%2FQX5ewQS1riptUQ52WFoKp4f2li5K%2Fs6EGgmwhpeblA%3D&h=2a791a63\" data-auto-link target=\"_blank\">http://www.police.gov.hk/ppp_tc/05_traffic_matters/enforcement.html。</a> <br />\n<br />\n<a href=\"http://www.info.gov.hk/gia/general/201702/03/P2017020300606.htm\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.info.gov.hk%2Fgia%2Fgeneral%2F201702%2F03%2FP2017020300606.htm&d=%2FQX5ewQS1riptUQ52WFoKp4f2li5K%2Fs6EGgmwhpeblA%3D&h=4e0895b6\" data-auto-link target=\"_blank\">http://www.info.gov.hk/gia/general/201702/03/P2017020300606.htm</a><br />\n<br />\n<br />\n原來出埋新聞稿 <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"}]}