gmoji\" />"},{"pid":"1a9210b404669c10bd07d0c5ac00c3dcebd7c4e8","tid":1479914,"uid":94449,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T00:14:40.000Z","msg":"818 2pm"},{"pid":"098add0785a4af55d9c09f9237a6afdf52a2e6ea","tid":1479914,"uid":50904,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T00:15:44.000Z","msg":"正<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"color: red;\">沉迷捉鬼嘅後果，2004年已經有人預言咗</span></strong><br />\n<a href=\"https://lihkg.com/thread/1481358\" target=\"_blank\">https://lihkg.com/thread/1481358</a><br />\n<br />\n呢幾日好多人一有咩意見不合，就互相指責對方係鬼<br />\n沉迷捉鬼只會令我地內部攬炒，咁簡單嘅道理連亞視編劇都明，無理由各位手足會唔明<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><br />\n請用十零分鐘睇下失去互信嘅下場，多謝<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://youtu.be/taWjgiThGr0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FtaWjgiThGr0&d=u3dPEc69Okhs1BcqxCk75WHyg7b2nkJB6fx123wLmsI%3D&h=529bfa38\" target=\"_blank\">https://youtu.be/taWjgiThGr0</a><br />\n<br />\n純文字劇透版:鬼 - 蕭家怡<br />\n<a href=\"https://thestandnews.com/politics/%E9%AC%BC/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%25E9%25AC%25BC%2F&d=u3dPEc69Okhs1BcqxCk75WHyg7b2nkJB6fx123wLmsI%3D&h=f9670949\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%25E9%25AC%25BC%2F&h=5b8a202b\" target=\"_blank\">https://thestandnews.com/politics/%E9%AC%BC/</a>"},{"pid":"3185cf001bd5c528e65d4b8be4843e7fe7cc5b09","tid":1479914,"uid":49359,"like":0,"dislike":0,"score":0,"quote":{"pid":"66e87c4d747b42948fc2f188dd5bcbcc38e214e2","tid":1479914,"uid":103230,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-17T18:51:37.000Z","msg":"<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-18T00:45:31.000Z","msg":"大埔勁好多"},{"pid":"344782363f9406d754b9d02a5632b07ca8dac838","tid":