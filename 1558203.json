天天做緊"},{"pid":"6c1277e910672f3e1b3e117a06a975e80213c732","tid":1558203,"uid":47653,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T00:55:03.000Z","msg":"一齊跳一齊跳"},{"pid":"8db8d17d862148480ce594cf9e25d0e98cf5c6ac","tid":1558203,"uid":42350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T00:55:53.000Z","msg":"推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"52a030ad16c935c3d0a8e41a8f9c807c725c2720","tid":1558203,"uid":42350,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-11T00:57:25.000Z","msg":"有人推無人跳<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5fe21bdffed400879aade8401bbc9850582ce9b2","tid":1558203,"uid":212336,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T00:57:54.000Z","msg":"我返工放工都係極夜極早,次次得我一個表演<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"948f60f5341e59af94d700fe6083f193c59da6f8","tid":1558203,"uid":47659,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-11T00:58:24.000Z","msg":"灰暗巴<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"91c30698fab8e3503cbd2690bbfe206429be4dcb","tid":1558203,"uid":280683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T01:01:52.000Z","msg":"跳閘係表達對黨鐵不滿"},{"pid":"9a68bdfb81147d19f2d4303cc4315c8391a1b9da","tid":1558203,"uid":29514,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T01:22:23.000Z","msg":"好撚多人跳囉"},{"pid":"99e5040b8e707b7da7774d5f3f46cb637a17b421","tid":1558203,"uid":27210,"like":0,"dislike":0,"score":0,"quote":{"pid":"948f60f5341e59af94d700fe6083f193c59da6f8","tid":1558203,"uid":47659,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-11T00:58:24.000Z","msg":"灰暗巴<img src=\"/assets/faces/normal/agree.gi