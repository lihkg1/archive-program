6da2ea4cc","tid":1982413,"uid":82532,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-25T06:16:42.000Z","msg":"世柒都好信<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fdb9c68e17b5ef1cf436ed1e6d52960b943ae92b","tid":1982413,"uid":73012,"like":0,"dislike":0,"score":0,"quote":{"pid":"6398639b1046de102afe48cb59e34906da2ea4cc","tid":1982413,"uid":82532,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-25T06:16:42.000Z","msg":"世柒都好信<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-28T21:11:20.000Z","msg":"唔會再幫襯佢。同路人唔係咁做嘅。呃鳩我呢個學生七百五十蚊五個月。宜家呢個環境我可以挨半個月使費㗎！遲d post個詳細對話紀錄畀大家睇，奉勸大家幫襯佢前三思。"},{"pid":"bc791e9de12cfedc592530e40f7115cdea2a340b","tid":1982413,"uid":244082,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-07T16:13:47.000Z","msg":"今日佢終於收到我個dispute, 然後就係佢個網度過我騙佢，仲公佈我資料。 我其實dispute 佢個時都預左，與其搵佢退錢， 佢都係會公佈人既資料 然後話人地唔岩， 我寧願要佢比人罰。<br />\n<br />\n我都建議大家如果中招，都用dispute, 唔好比條撚樣再借住黃色經濟圈害其他人。<br />\n<br />\n呢個對話係我比佢拖左2個月之後既對話，仲話出貨。<br />\n<img src=\"https://na.cx/i/Vq3qFyb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVq3qFyb.jpg&h=ec645d9a&s={SIZE}\" /> <img src=\"https://na.cx/i/BCHODjR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBCHODjR.jpg&h=cfee0e9d&s={SIZE}\" /> <br />\n<br />\n仲有，受害人真係唔少，我跟據比佢block 既list, send email 問啲受害人， 個個都係被拖 被騙 然後就被公佈資料。 我希望大家可以幫手推上啲呢個post. 起碼要佢受影響"},{"pid":"46c85b4a162503c7d9d08f90ed1c4c3d003c10b3","tid":1982413,"uid":235257,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-07T16:19:40.000Z","msg":"黃世柒都信<br />\n<br />\ntoo young<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"7c90306682716a569c7261456122a30ac235754a","tid":1982413,"uid":48212,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-07T17:09:40.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4292fef78f3e1bc2e8ce49e2