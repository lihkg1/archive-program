170e5d6c44c7","tid":916133,"uid":199687,"like":0,"dislike":0,"score":0,"quote":{"pid":"36d95a64bc8eb329d639d3df6680c55e19f70400","tid":916133,"uid":37890,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-11-25T14:44:12.000Z","msg":"唔想社交唔想同人講野<br />\n人多就想逃避 想&ldquo;呢埋&rdquo;"},"citedBy":1,"replyTime":"2018-11-25T14:49:23.000Z","msg":"Same situation <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n你係由細到大都係咁定大大下先咁？"},{"pid":"c13bd2de45799f2d0c2d66c6c1af2eb55a7e4fba","tid":916133,"uid":63548,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2018-11-25T14:50:03.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <br />\n<br />\n個樣睇落正正常常 <br />\n但其實每一次同人講野 都係出盡曬力去答對方<br />\n仲要扮正常 扮輕鬆 <br />\n<br />\n以前番學都可以好小出聲 當listening其他人既意見 或者比人一種靜既印象 出到黎做野跟本唔可以咁<br />\n<br />\n同唔識或者唔熟既人相處 每一刻都覺得好老尷 如果無得走既話 都會去個toilet 抖下氣 但就好耐都唔出黎 或者到咁上下有得離開時 個人先放鬆番<br />\n<br />\n睇過個節目講 依種算係焦慮 但成個節目無睇曬<br />\n<br />\n有無人救我 我好想可以好似正常人咁傾計<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"8d95759ac2f12725f2516f8532c30f2025d9099c","tid":916133,"uid":37890,"like":0,"dislike":0,"score":0,"quote":{"pid":"d3a8f9149900dfab4fecb10f2674170e5d6c44c7","tid":916133,"uid":199687,"like":0,"dislike":0,"score":0,"quote":{"pid":"36d95a64bc8eb329d639d3df6680c55e19f70400","tid":916133,"uid":37890,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-11-25T14:44:12.000Z","msg":"唔想社交唔想同人講野<br />\n人多就想逃避 想&ldquo;呢埋&rdquo;"},"citedBy":1,"replyTime":"2018-11-25T14:49:23.000Z","msg":"Same situation <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n你係由細到大都係咁定大大下先咁？"},"citedBy":1,"replyTime":"2018-11-25T14:52:30.000Z","msg":"由細到大都係咁，人多就會驚<br />\n扮正常扮無野好辛苦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1f6c5c1ee5c4b3396d659915ed16c79074125b5d","tid":916133,"uid":