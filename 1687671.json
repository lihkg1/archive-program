edBy":0,"replyTime":"2019-11-02T04:04:26.000Z","msg":"支那01唔使貼link<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"ac960497542ed130d4decd6fd815d67d30e646cc","tid":1687671,"uid":91721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-02T04:05:07.000Z","msg":"up"},{"pid":"cd566ea5e3d25af02f5aaad679e66e1ad53b9674","tid":1687671,"uid":180124,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-02T04:06:43.000Z","msg":"係咪痴撚線<br />\n大家有冇諗過煲大佢比美國會係幾咁嚴重既事"}]}