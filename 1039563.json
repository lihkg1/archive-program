098106f2f432636dd8e94e6bfaed3","tid":1039563,"uid":89801,"like":20,"dislike":3,"score":17,"quote":{"pid":"580420d441d7d28ba80af6e73b21f0a72a4528e8","tid":1039563,"uid":19004,"like":1,"dislike":4,"score":-3,"citedBy":1,"replyTime":"2019-02-27T14:19:24.000Z","msg":"就算載人都要坐車頭 只限一個"},"citedBy":1,"replyTime":"2019-02-27T15:15:02.000Z","msg":"唔識法例唔好鳩up<br />\n法例從來無講過個客一定要坐車頭"},{"pid":"44b9a4104870bc97f42ce017ba036e8632368e92","tid":1039563,"uid":19004,"like":30,"dislike":0,"score":30,"quote":{"pid":"e03bc7d1074098106f2f432636dd8e94e6bfaed3","tid":1039563,"uid":89801,"like":20,"dislike":3,"score":17,"quote":{"pid":"580420d441d7d28ba80af6e73b21f0a72a4528e8","tid":1039563,"uid":19004,"like":1,"dislike":4,"score":-3,"citedBy":1,"replyTime":"2019-02-27T14:19:24.000Z","msg":"就算載人都要坐車頭 只限一個"},"citedBy":1,"replyTime":"2019-02-27T15:15:02.000Z","msg":"唔識法例唔好鳩up<br />\n法例從來無講過個客一定要坐車頭"},"citedBy":1,"replyTime":"2019-02-27T15:17:07.000Z","msg":"根據《道路交通駕駛執照條例》第374B章第19條 &ndash; &ldquo;有權駕駛其他種類車輛的規定&rdquo;的條文<br />\n『(1) 任何人如持有令他有權駕駛私家車或輕型貨車的有效駕駛執照，則他憑藉該執照亦有權駕駛的士或小型巴士：但 &ndash;<br />\n(a) 車前須出示紅底白字的字牌，以高度不少於75亳米的正楷字體註有英文字 &ldquo;OUT OF SERVICE&rdquo; 及中文字&ldquo;暫停載客&rdquo;；<br />\n(b) 除司機外，該車輛最多可載人數為1人；及<br />\n(c) 如屬的士，的士計程錶指示器須予掩蓋, 使的士外的人不能看見。(1984年第259號法律公告)』<br />\n<br />\n<br />\n係wo<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"44b641e519009a900a9a39fb4648cbb89e14f678","tid":1039563,"uid":89801,"like":0,"dislike":1,"score":-1,"quote":{"pid":"44b9a4104870bc97f42ce017ba036e8632368e92","tid":1039563,"uid":19004,"like":30,"dislike":0,"score":30,"quote":{"pid":"e03bc7d1074098106f2f432636dd8e94e6bfaed3","tid":1039563,"uid":89801,"like":20,"dislike":3,"score":17,"quote":{"pid":"580420d441d7d28ba80af6e73b21f0a72a4528e8","tid":1039563,"uid":19004,"like":1,"dislike":4,"score":-3,"citedBy":1,"replyTime":"2019-02-27T14:19:24.000Z","msg":"就算載人都要坐車頭 只限一個"},"citedBy":1,"replyTime":"2019-02-27T15:15:02.0