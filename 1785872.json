dBy":0,"replyTime":"2019-12-16T17:59:04.000Z","msg":"<img src=\"/assets/faces/pigxm/smile.gif\" class=\"hkgmoji\" />"},{"pid":"95872740d331141e462c6b33b65b079d54a90679","tid":1785872,"uid":761,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-12-16T18:00:28.000Z","msg":"宣傳<br />\n周圍都係黑警死全家"},{"pid":"41c9c73da500169e8a0e3972e6eb8c2d8d01dcb6","tid":1785872,"uid":146535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T18:02:54.000Z","msg":"推"},{"pid":"9bf6a836bf3ac9cdfd35dca7750b03e99e0f37d4","tid":1785872,"uid":67428,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T18:07:35.000Z","msg":"p"},{"pid":"44470b2b46852794adb58d10111c5a211c40b392","tid":1785872,"uid":35364,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T18:08:56.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"ca3097212fa230c571714061d16737ad816a6f90","tid":1785872,"uid":26441,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T18:11:27.000Z","msg":"push"},{"pid":"2e69efb8ef955e77061749b45f4d82a191b5308b","tid":1785872,"uid":331949,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-16T18:11:51.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"c956834c83cc6d7219cedd1728924eaeae367cd6","tid":1785872,"uid":146535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T18:13:25.000Z","msg":"推"},{"pid":"cbf7b7cb703c4c5b1133ef52875fe136f340f284","tid":1785872,"uid":35364,"like":0,"dislike":0,"score":0,"quote":{"pid":"2e69efb8ef955e77061749b45f4d82a191b5308b","tid":1785872,"uid":331949,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-16T18:11:51.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-12-16T18:14:44.000Z","msg":"「幫襯嘅密度同力度，最好同佢嘅支持度成正比」"},{"pid":"d46b49f0c7ce9ccbd081e64c40410972c9851d13","tid":1785872,"uid":331949,"like":0,"dislike":0,"score":0,"quote":{"pid