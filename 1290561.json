 src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-09T08:13:59.000Z","msg":"林鄭月娥嬌喘一聲倒在習近平嘅懷裏 - 第三話之快來扶我特別版<br />\n<a href=\"https://lih.kg/1299939\" data-auto-link target=\"_blank\">https://lih.kg/1299939</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"151856fb22bb74305f80ae9e31677195209b3e7c","tid":1290561,"uid":60535,"like":0,"dislike":0,"score":0,"quote":{"pid":"7d5ea71318db6b6ac8e3e4f612a82d8f29bdca2d","tid":1290561,"uid":266674,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-09T08:06:08.000Z","msg":"小熊維利！推"},"citedBy":0,"replyTime":"2019-07-09T08:14:15.000Z","msg":"林鄭月娥嬌喘一聲倒在習近平嘅懷裏 - 第三話之快來扶我特別版<br />\n<a href=\"https://lih.kg/1299939\" data-auto-link target=\"_blank\">https://lih.kg/1299939</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"023d703118382eca93356d4f870e97d219b811f4","tid":1290561,"uid":236011,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-09T08:15:22.000Z","msg":"痴撚線<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1cf263ea081582128d03f52096481c09cd738832","tid":1290561,"uid":189875,"like":1,"dislike":0,"score":1,"quote":{"pid":"bbe3a40dc461eae386c2afcbf3e4a552ec4feb5f","tid":1290561,"uid":212626,"like":82,"dislike":0,"score":82,"citedBy":3,"replyTime":"2019-07-06T14:10:49.000Z","msg":"<img src=\"https://na.cx/i/eEpMmEU.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeEpMmEU.gif&h=00fc175a&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-07-09T09:31:17.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/20/081729_bf7bcbe8862a67a4c9abe15c8113897e.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F20%2F081729_bf7bcbe8862a67a4c9abe15c8113897e.gif&h=349176a5&s={SIZE}\" />"},{"pi