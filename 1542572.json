ike":9,"dislike":0,"score":9,"quote":{"pid":"e5a41228d5335a550ecfc21584791b7088c93876","tid":1542572,"uid":119729,"like":55,"dislike":3,"score":52,"citedBy":7,"replyTime":"2019-09-05T01:57:14.000Z","msg":"屌, 一定有藍絲9UP話示威者收唔到錢報復"},"citedBy":1,"replyTime":"2019-09-05T02:07:14.000Z","msg":"咁如果何妖屋企有人縱火...<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" />"},{"pid":"42b30793efbbbade11a573154d7c5d670d5ac273","tid":1542572,"uid":41861,"like":2,"dislike":0,"score":2,"quote":{"pid":"afe8b09d799a5fe08298069b2c5bcbedb9501269","tid":1542572,"uid":191926,"like":7,"dislike":0,"score":7,"citedBy":4,"replyTime":"2019-09-05T01:58:21.000Z","msg":"2名身穿黑衣、黑褲、戴上鴨舌帽的蒙面男子。<br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-05T02:09:15.000Z","msg":"橋裝警通常戴cap帽<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"b85cdf6cf0c445b3f2f951829e4e94deb1b10928","tid":1542572,"uid":137789,"like":0,"dislike":0,"score":0,"quote":{"pid":"b63b6781e00e07d71da0869ef1f83fa6d9975544","tid":1542572,"uid":137789,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-05T02:05:41.000Z","msg":"以為回帶<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-05T02:09:48.000Z","msg":"參考資料<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><br />\n<br />\n出版《蘋果日報》的壹傳媒，位於將軍澳的總部大樓，以及大股東黎智英在何文田的住所，今日凌晨一時許，幾乎同時遭人投擲燃燒彈，無人受傷。<br />\n<br />\n到清晨五時許，近理工大學宿舍的漆咸道南，有警員連開4槍，想制止一客貨車離去，但未能成功。馬路上遺下多份今天出版的《蘋果日報》，一名警員懷疑遭客貨車撞傷腿部。在事件發生前，商業電台指紅磡民泰街一家報紙檔，被偷去一批報紙，警員到場調查。<br />\n<br />\n蘋果日報網站報道，一輛七人車今日凌晨倒車駛至黎智英在嘉道理道的大宅門外，一名戴口罩男子下車，向大閘投擲一個燃燒彈，然後離開。大宅保安員發現後喝止，並用滅火筒將火救熄，事件中無人受傷。<br />\n<br />\n壹傳媒大樓兩個出入口，亦被人駕車駛過時，投擲兩個燃燒彈，無人受傷。<br />\n<br />\n事後警方於石硤尾和長沙灣，先後發現兩輛七人車被縱火燒毀，懷疑和案件有關。約凌晨2時，附近，一輛七人車著火焚燒，該車的前後車牌已被拆走。約半小時後，長沙灣亦有一輛七人車著火焚燒，車牌同被拆走，起火原因有可疑。警方正調查兩宗燒車案，與投擲燃燒彈的案件是否有關。警方早上亦有到黎智英住所調查，亦派人到附近住宅，向住戶調查是否有人目擊事發經過。<br />\n<br />\n<a href=\"https://thestandnews.com/society/%E9%BB%8E%E6%99%BA%E8%8B%B1%E4%BD%8F%E5%AE%85-%E5%A3%B9%E5%82%B3%E5%AA%92%E5%A4%A7%E6%A8%93-%E5%90%8C%E6%99%82%E9%81%AD%E6%93%B2%E7%87%83%E7%87%92%E5%BD%88/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fthestandnews.com%2Fsociety%2F%25E9%25BB%258E%25E6%2599%25BA%25E8%258B%25B1%25E4%25BD%258F%25E5%25AE%2585-%25E5%25A3%25B9%25E5%2582%25B3%25E5%25AA%2592%25E5%25A4%25A7%25E6%25A8%2593-%25E5%2590%258C%25E6%2599%2582%25E9%2581%25AD%25E6%2593%25B2%25E7%2587%2583%25E7%2587%2592%25E5%25BD%2588%2F&d=Fy0o8YzXie14Yexn7W6ruXjCBy0DQDxxpn8JrxrWeYE%3D&h=a8c063f6\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fsociety%2F%25E9%25BB%258E%25E6%2599%25BA%25E8%258B%25B1%25E4%25BD%258F%25E5%25AE%2585-%25E5%25A3%25B9%25E5%2582%25B3%25E5%25AA%2592%25E5%25A4%25A7%25E6%25A8%2593-%25E5%2590%258C%25E6%2599%2582%25E9%2581%25AD%25E6%2593%25B2%25E7%2587%2583%25E7%2587%2592%25E5%25BD%2588%2F&h=3ee9be96\" data-auto-link target=\"_blank\">https://thestandnews.com/society/%E9%BB%8E%E6%99%BA%E8%8B%B1%E4%BD%8F%E5%AE%85-%E5%A3%B9%E5%82%B3%E5%AA%92%E5%A4%A7%E6%A8%93-%E5%90%8C%E6%99%82%E9%81%AD%E6%93%B2%E7%87%83%E7%87%92%E5%BD%88/</a>"},{"pid":"78229f6742025fcce5e351dc6022fed41cfb1d8e","tid":1542572,"uid":810,"like":2,"dislike":0,"score":2,"quote":{"pid":"e5a41228d5335a550ecfc21584791b7088c93876","tid":1542572,"uid":119729,"like":55,"dislike":3,"score":52,"citedBy":7,"replyTime":"2019-09-05T01:57:14.000Z","msg":"屌, 一定有藍絲9UP話示威者收唔到錢報復"},"citedBy":0,"replyTime":"2019-09-05T02:10:42.000Z","msg":"由佢講囉<br />\n依家都唔撚洗佢地支持啦"},{"pid":"e55c35e422c03ee2d7b1365fb2bbe1c107eaa1dc","tid":1542572,"uid":113000,"like":0,"d