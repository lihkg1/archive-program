assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e378a0e1bef2bc90c9f763fde6ba8ae86c9471e6","tid":1218411,"uid":60662,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T12:21:27.000Z","msg":"推！！！"},{"pid":"f30af0194fab34892fc3f141123dc577f78a1a75","tid":1218411,"uid":60662,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T13:51:47.000Z","msg":"<img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" />"},{"pid":"bc5ab3ea7d9ffa79e6d3cd1d60ef91bc7a361ae4","tid":1218411,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T15:38:56.000Z","msg":"<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"2014760b7e6997f84e82ea9593e144b8fd409d53","tid":1218411,"uid":63311,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T15:39:23.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">一日未撤回認錯 一日都要出</span></span>"},{"pid":"fef8aed0d11fecd778d1f7cd4f7a8ce82a84885c","tid":1218411,"uid":222614,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T15:52:17.000Z","msg":"中共陰招：當佢地處於劣勢時就放慢同你玩，畀時間自己扭轉形勢<br />\n<br />\n佢地成功左<br />\n依家香港人已經無理由同無動力再動員組織攻佔立法會去製造太陽花 2.0<br />\n<br />\n再咁落去就有機會畀佢地主導返形勢<br />\n隨時反敗為勝"},{"pid":"e95723379d5965de61a55ac9f5781004e068efb6","tid":1218411,"uid":25183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T16:04:20.000Z","msg":"而且要keep住文宣"},{"pid":"ae9645bb3d1f70bf7102fbb2b028e2dbbdaacf9a","tid":1218411,"uid":53922,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T16:04:59.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">宜加目標只有一個: <br />\n<br />\n反送中, 撤回修例.<br />\n<br />\n星期日出去遊行.<br />\n<br />\n請大力宣傳</span></span>"},{"pid":"8edb1b68663bcea6a2d1e476a197f68320fe19e4","tid":1218411,"uid":196171,"like":0,"dislike":0,"score":0,"quote":{"pid":"8dcda57267039383f68e23255b50b52bffa5924b","tid":1218411,"uid":60662,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-13T15:43:56.000Z","msg":"依家個環境好似風向轉咁，就係會令大家鬆懈。跟住政府拖拖下又會熄左大家團火。<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\"><strong>記住，呢一刻無贏任何野無爭取到任何野，係輸緊！！仲輸左幾百名義士。</strong></span></span><br />\n<br />\n大家保持住團火，難得可以武勇、和理非、教徒團結一齊抗惡法，大家千其唔好篤灰，依家係大是大非既時候，呢兩日既情況已經展示左大家可以互相保護。<br />\n<br />\n我地依家目標應該係：<br />\n１.　撤回惡法，邊日開會就邊日野餐<br />\n２.　要黑警釋放所有因示威而被捕人士<br />\n３.　清算建制派，黑警，ＴＶＢ，偽人<br />\n４.　將琴日發生既圖／片不停轉發出去，等全世界都知<br />\n<br />\n果班被黑警圍嘔拘捕既義士，一定要救佢地，唔好留低佢地"},"citedBy":0,"replyTime":"2019-06-14T16:05:40.000Z","msg":"【血海深仇 不共戴天 政權恣殺 必被正法 － 香港大學學生會告全港市民書 | A hatred of bloodshed that we shall never tolerate A despot of murder that we shall eventually punish - Open Letter from the Hong Kong Unversity Students&rsquo; Union to all Hongkongers】<br />\n <br />\n過百萬市民走上街頭反抗惡法，港共政權依然一意孤行，強推惡法。與其共謀之執法機器甚至向市民開槍，大規模搜捕抗爭者，製造白色恐怖。<br />\n <br />\n港共政權及其警政體系之罪行罊竹難書：對示威者濫施暴力、任意羅織罪名，大肆搜捕示威者、惡意攻擊記者等。本會必須指出，即使港府暫緩修例，甚至撤回草案，我們亦絕不可就此罷休。本會警惕港人切勿鬆懈，必須全面追究政權責任。<br />\n <br />\n本會呼籲全港市民於本週日上街，要求政權：<br />\n <br />\n一、永不重啟送中惡法修訂；<br />\n二、釋放所有政治犯，並絕不秋後算帳；<br />\n三、成立獨立調查委員會，針對調查警察之暴行，提出限制警權之措施並立法執行；<br />\n四、檢控所有向市民、記者、急救人員使用非法武力的警員；<br />\n五、廢除公安條例惡法，保障市民集會自由。<br />\n <br />\n香港人，我們絕不退讓。<br />\n <br />\n香港大學學生會<br />\n二零一九年六月十四日<br />\n<br />\nDespite more than a million Hongkongers took to the streets to stop the Bill from being passed, the Hong Kong Communist regime shamelessly ignored the opposition and insisted on ramming the Bill through. The regime and police shot at citizens and have been attempting to hunt down protesters by any means, spreading white terror in society.<br />\n<br />\nThe slaughtering regime and police have committed countless atrocities: using excessive violence against protesters, arresting and laying charges arbitrarily on the protesters, maliciously attacking the press, etc. The Union must point out that, even if the government announces a temporary suspension or even withdrawal of the Bill, we should clench our fists, and continue to hold the regime to account. <br />\n<br />\nWe hereby urge Hongkongers to take to the streets on Sunday, and demand the following:<br />\n<br />\n1. Never re-initiate amendments to extradition laws;<br />\n<br />\n2. Release of all the political prisoners and bring no further prosecutions;<br />\n<br />\n3. Establish an independent investigation committee responsible for investigating the violent actions of the police, and making recommendations on restricting police power;<br />\n<br />\n4. Prosecute all the police officers who used unlawful force on citizens, journalists and first-aiders; and<br />\n<br />\n5. Abolish the Public Order Ordinance to guarantee freedom of assembly of Hongkongers.<br />\n<br />\nWe shall not yield.<br />\n<br />\nThe Hong Kong University Students&rsquo; Union<br />\n14th June 2019"},{"pid":"53b7d22886e7bcbd96d90cb07e174543dfcf8633","tid":1218411,"uid":124711,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T16:05:58.000Z","msg":"Push"},{"pid":"5d582b04a240bcf65398b9c09c1ce509ac9cad0f","tid":1218411,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T01:06:21.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"e98e007305c313edae00fe997a3bd46162c6e4c8","tid":1218411,"uid":157938,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T01:11:14.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>反送中, 撤回修例.<br />\n<br />\n星期日出去遊行.<br />\n<br />\n星期一出去集會</strong></span></span>"},{"pid":"aa4d70ffc32ac077c97e312bc57febf06a93a802","tid":1218411,"uid":24133,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T05:17:16.000Z"