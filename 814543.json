ets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"11a69cb79a6912a03de569402db8360a73fd13d5","tid":814543,"uid":25028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T11:01:01.000Z","msg":"我已經唔係叮 我直頭開焗爐焗番熱佢 都係好撚難食<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ea7c8fb6c7a06268cc2a5d9b496d27adfea70aeb","tid":814543,"uid":127466,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-09-11T11:09:43.000Z","msg":"人地送既就無所謂, 自己買黎食就太奢侈, 夠去茶樓食20籠流心奶王包 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d830e9205cde0d88e4697c3aa875fc954ba3f633","tid":814543,"uid":6290,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-11T11:17:25.000Z","msg":"上年買過晒黎試啦<br />\n半島個皮雖然夠香<br />\n但美心叮完之後仲好食過半島個隻<br />\n<br />\n依家試緊啲人既home made 月餅<br />\n但都係鐘意美心個隻多啲<br />\nP.s. 唔係流心個隻<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d32972451273d216f6cb143af66bbba64834405c","tid":814543,"uid":72608,"like":1,"dislike":0,"score":1,"quote":{"pid":"ea7c8fb6c7a06268cc2a5d9b496d27adfea70aeb","tid":814543,"uid":127466,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-09-11T11:09:43.000Z","msg":"人地送既就無所謂, 自己買黎食就太奢侈, 夠去茶樓食20籠流心奶王包 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-11T11:47:58.000Z","msg":"YES 茶樓奶皇包就真係流心啦"},{"pid":"d51f1b32b92460cb5a86cf756e2816b02a59f72c","tid":814543,"uid":45206,"like":0,"dislike":0,"score":0,"quote":{"pid":"d830e9205cde0d88e4697c3aa875fc954ba3f633","tid":814543,"uid":6290,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-11T11:17:25.000Z","msg":"上年買過晒黎試啦<br />\n半島個皮雖然夠香<br />\n但美心叮完之後仲好食過半島個隻<br />\n<br />\n依家試緊啲人既home made 月餅<br />\n但都係鐘意美心個隻多啲<br />\nP.s. 唔係流心個隻<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-11T11:56:31.000Z","msg":"美心係真係幾好食<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n話時話 流心奶黃月餅 我到而家都未