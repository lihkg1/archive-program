dog/999.gif\" class=\"hkgmoji\" />"},{"pid":"e89cd6594841942e7b15be4c2fb12bf36fa10ad4","tid":1034844,"uid":147079,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-24T08:34:41.000Z","msg":"此回覆已被刪除"},{"pid":"73a4d518a74a4e901ec0a3d43a2074df61e097e3","tid":1034844,"uid":69841,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-24T08:37:09.000Z","msg":"安已不<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"1b75ddfced5ba5b9a07b5292234803e4b0c5c6eb","tid":1034844,"uid":207792,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-24T08:39:20.000Z","msg":"<img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" />"},{"pid":"54b4c969cdf7fb24dffab1071d09bdff130743d1","tid":1034844,"uid":11301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-24T08:41:20.000Z","msg":"<img src=\"/assets/faces/dog/FBI.gif\" class=\"hkgmoji\" />"},{"pid":"24e2a7454c67e848163501879c58aace18b1e4cb","tid":1034844,"uid":129521,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-02-24T08:41:25.000Z","msg":"巴打攞幾百蚊去叫雞啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"0a01311642c7a85cc8e0f00b212ac2571bd4e721","tid":1034844,"uid":149534,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-02-24T08:41:43.000Z","msg":"轉載<br />\n<br />\n非法處理屍體罪，又名阻止屍體合法埋葬罪。此罪不存在於香港法例中，它的罰則也未被直接列明。但根據《刑事訴訟程序條例》 第101I條，任何的公訴罪行，如無任何條例訂定該罪的刑罰，則可處監禁7年及罰款。 在HKSAR v. Grado Aileen Ongcoy [2017] HKDC 474, 法庭表示此罪行並刑罰指引，但由於此類案件泯滅人性，入獄無可避免。在判刑時，法庭會考慮3個因素：1) 案情嚴重性，2) 被吿有否預謀犯案，3) 被吿的行為會否妨礙死因調查。<br />\n<br />\n任由屍體存放於家中（沒處理，沒妨礙），也會觸犯法律。根據《公眾衞生及市政條例》第122條，任何人的居住內存有人類屍體超過48小時，即屬犯罪，最高可被判監6個月罰款100,000元。"},{"pid":"4dface310e194b162e02629e3716c9567d4ebdc5","tid":1034844,"uid":211976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-24T08:43:41.000Z","msg":"<img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" />"},{"pid":"70a9d9bd315a5aca4d5daad5043b3086cf47ad5d","tid":1034844,"uid":142098,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-24T08:45:08.000Z","msg":"<img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" />"},{"pid":"afd3007161893e800ffc3169c76ff6592ac39cb7","tid":1034844,"uid":5159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-24T08:47:46.000Z","msg":"單係非法處理屍體已經唔得"},{"pid":"2d4e1053329e74a8af9c39331273f631f0061243","tid":1034844,"uid":222907,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-24T08:48:44.000Z","msg":"<img src=\"https://na.cx/i/reSSq5S.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FreSSq5S.jpg&h=415e06ba&s={SIZE}\" />"},{"pid":"d1ca3c15baf5002cff1b734ef0a6e3174d8ae756","tid":1034844,"uid":194606,"like":11,"dislike":2,"score":9,"citedBy":0,"replyTime":"2019-02-24T08:52:43.000Z","msg":"<img src=\"https://na.cx/i/pnmjQyM.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpnmjQyM.gif&h=9edebca5&s={SIZE}\" /><br />\n<img src=\"/assets/faces/dog/FBI.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/FBI.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/FBI.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/FBI.gif\" class=\"hkgmoji\" />"},{"pid":"92cefeddd98bf1bf672e9dbaa93f08cbcf3530db","tid":1034844,"uid":79442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-24T08:57:23.000Z","msg":"犯 起碼有非法處理屍體"},{"pid":"70081628803b16e78922e294971663a28f734389","tid":1034844,"uid":237354,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-24T08:58:56.000Z","msg":"<img src=\"/assets/faces/dog/999.gif\" class=\"hkg