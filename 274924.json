%25B8%25AF%25E8%25B6%25B3%25E9%2599%25B3%25E5%2581%2589%25E8%25B1%25AA3_UP.jpg&h=317078bf&s={SIZE}\" /></blockquote><br />\n<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /></blockquote><br />\n算畫家有心</blockquote><br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"02175ed95077e612d55b97c48f1ed68e0900cbd1","tid":274924,"uid":85163,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-08T06:06:53.000Z","msg":"此回覆已被刪除"},{"pid":"ddf47b585995d9cc5406d10d4f5a87cb6ac7781d","tid":274924,"uid":9193,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-08T06:08:57.000Z","msg":"<blockquote>香港波<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"afede0cce96d33ba03ab9c5ef2dac79c9b294ddb","tid":274924,"uid":91875,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-08T06:10:00.000Z","msg":"如果佢中間無走過去話想做地產佬,就真係<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"}]}