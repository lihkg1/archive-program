5\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fs.nextmag.hk%2Fe%2FBomeAYMc35&d=mbsn9%2Fi9gU9wZYjOUdyYPjv6TERBNTdTd%2BiGQaA%2FLRg%3D&h=72b16c50\" data-auto-link target=\"_blank\">https://s.nextmag.hk/e/BomeAYMc35</a><br />\n<br />\n<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-28T13:06:03.000Z","msg":"下次聲明再加埋話 新聞自由係香港核心價值之一<br />\n無理拘捕新聞工作者會嚴重動搖國際之都既地<br />\n令香港經濟進一步下滑<br />\n更有機會影響國際對中央既信任<br />\n要求狗隊作出正式既交代"},{"pid":"d1546c26170d7c9f9cae631002c07c022d87e4ad","tid":1992814,"uid":63808,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T13:06:57.000Z","msg":"推"},{"pid":"34953d5d0324aa13c5b6c34e19f7ca1935c2a255","tid":1992814,"uid":65074,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-04-28T13:08:43.000Z","msg":"icac係咪都係俾黑警破壞左"},{"pid":"f52b2a16693604a18175ecc50dd20e1588da906b","tid":1992814,"uid":35354,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T13:09:49.000Z","msg":"恐怖份子即係香港警察"},{"pid":"78a07a37e19a96734245f93ba1dc9e0366f630e2","tid":1992814,"uid":171259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T13:10:16.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"9cb7e7fff82d5491cc2cf563777487a7affd7512","tid":1992814,"uid":108987,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T13:15:27.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"126966c718ce155c7f77838cf4674e5dc4310600","tid":1992814,"uid":52946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T13:16:11.000Z","msg":"<img s