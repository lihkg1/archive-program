記者工作，警方便將其釋放。<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">要拉到返狗屋先知兩個記者當時做緊採訪工作？<br />\n咪撚當我哋弱智啦死黑警</span></span>"},{"pid":"1955c9d55d95cd26be56f77988aacbbc268409ee","tid":1992814,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T14:21:09.000Z","msg":"推"},{"pid":"82fbd80174b1eddbcc6d6762770fc3fc4f964d11","tid":1992814,"uid":13318,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T14:22:00.000Z","msg":"推"},{"pid":"50d61c1e1043b6c4a7eff1ffb15d416e7ec1d185","tid":1992814,"uid":53922,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T14:22:10.000Z","msg":"推"},{"pid":"c134614e206e66c7ca67e7c20c7b0d97a13e2fdc","tid":1992814,"uid":1550,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T14:23:17.000Z","msg":"支持即刻爆料<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1362508008028408d70a8c605f36a0c275a652ef","tid":1992814,"uid":85030,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T14:23:41.000Z","msg":"黑狗又衰咩<br />\n好想知"},{"pid":"b1b5560c7cea4e1be22f60bf7de8e366ad144a40","tid":1992814,"uid":13450,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T14:24:02.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"d818d846b85ad237c7a544dc3571363ce4b3ab5a","tid":1992814,"uid":142771,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T14:25:01.000Z","msg":"推"},{"pid":"9927b6ddb085a278376ac8ee00e62e5485580b1a","tid":1992814,"uid":125194,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T14:27:18.000Z","msg":"push"},{"pid":"22a82e19f99d4e45d43b66f1a9343c70d84ccb14","tid":1992814,"uid":218729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T14:28:15.