230e890da909f3b6520","tid":1244760,"uid":44174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T08:50:41.000Z","msg":"推"},{"pid":"1cb86d00b7f901667c46dfc1f4dd0132563d3cd1","tid":1244760,"uid":260035,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T08:56:05.000Z","msg":"Up"},{"pid":"f14179ebe52f571e56c9f78feeb332492515d680","tid":1244760,"uid":6833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T08:58:51.000Z","msg":"幫手推"},{"pid":"760c31879d11952c524897e30a57a1fcd9635c46","tid":1244760,"uid":58841,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T08:59:42.000Z","msg":"推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"12d33f9ae4a776babccf19e59b45f4723e07919b","tid":1244760,"uid":33710,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T09:01:11.000Z","msg":"push<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"909e9e5ce334e581e1020806705b98054ae19c15","tid":1244760,"uid":188176,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T09:02:25.000Z","msg":"陳雲失敗錄<br />\n<br />\n自稱曾為政府要員<br />\n自稱同美國特使聯絡<br />\n自稱同中共特使聯絡<br />\n<br />\n戰績<br />\n1.因多次欠交論文浸大不續其中文系助理教授之合約<br />\n2.立會選舉失敗，連同其聯盟熱普城五名大部分落選<br />\n3.現於政府無任何官職<br />\n4.曾多次抨擊梁天琦為鬼，25仔，包括梁入獄後仍然追擊<br />\n5.與林卓廷於公開論壇不回答提問並叫對方上自己fb查找<br />\n6.與快必於公開論壇交手並稱對手質疑來得太遲<br />\n7.永續基本法提倡者，但至今仍然無法回答人大程序部分<br />\n8.於年宵高價售賣貨源來自淘寶的戰鬥碗並沽清<br />\n9.提倡以行季喼改裝成盾，惜其領導之熱狗和城邦派沒有跟隨使用<br />\n10.與熱普城以外之政治組織不和<br />\n11.與普羅政治學院反目<br />\n12.與手下之三國人反目<br />\n13.曾自言選舉失敗後將寂滅，然而至今仍無意付諸實行<br />\n14.妻離子散，並喜歡嫖妓<br />\n15.前上司何志平為中共石油供應搭路而貪污非洲國家，年前於美國被捕<br />\n16.陳雲於政府任職時推出於晚間新聞前播放中共國歌，以強化年輕人的愛國思想"},{"pid":"24cce693cd7b13eaa6e28e1e274c50a9d4c672af","tid":1244760,"uid":260035,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T09:39:17.000Z","msg":"Up"},{"pid":"36028c2b8199c2ff22f99f3fed67dbd25baa90d2","tid":1244760,"uid":134744,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T09:40:58.000Z","msg":"推"},{"pid":"844c6122230fe6388678c5365e6de858f00d7a1c","tid":1244760,"uid":260035,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T10:49:54.000Z","msg":"就黎六萬<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0c6dfcea04ce04ee69205636b0e49d809d6f534f","tid":1244760,"uid":40142,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T11:56:58.000Z","msg":"Push"},{"pid":"30284019e531683c8f31814432db972c9fedd783","tid":1244760,"uid":40142,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T12:41:28.000Z","msg":"<img src=\"https://na.cx/i/VVmQgJc.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVVmQgJc.png&h=77ab8a8b&s={SIZE}\" /><br />\n【請廣傳】你可以唔鍾意美國，也可能唔鍾意特朗普，但是，你想要習帝定美帝？睇美國隊長定睇吳京做隊長？<br />\n<br />\n你可以認為特朗普唔會理香港，但現在香港事件已成為世界焦點。在Ｇ２０前，做多一點！增加多一個可能性吧！<br />\n請白宮聯署請特朗普總統解放香港吧!!!<br />\n<br />\n只需入去打個名，留下mail. 然後再去自己mailbox confirm便可! <br />\n<br />\n<a href=\"https://petitions.whitehouse.gov/petition/president-trump-please-liberate-hong-kong-communist-chinas-occupation\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fpresident-trump-please-liberate-hong-kong-communist-chinas-occupation&d=ZVysXiw7s3azMdswkJgtbCaGrLhPWbn%2F%2Bskqqi57m1s%3D&h=7966050e\" data-auto-link target=\"_blank\">https://petitions.whitehouse.gov/petition/president-trump-please-liberate-hong-kong-communist-chinas-occupation</a>"},{"pid":"7dd634e999f296ff43c77827d82d8b0a6e0aed5c","tid":1244760,"uid":56248,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T12:42:02.000Z","msg":"Push"},{"pid":"af343c2e32d101b98339fcf985dc917d2f7e319b","tid":1244760,"uid":531,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T12:43:53.000Z","msg":"推"},{"pid":"9ab866a64eff5886aa635bddc3474f5c93f0ebfb",