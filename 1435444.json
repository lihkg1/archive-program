eplyTime":"2019-08-09T05:11:50.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"1e790bb86bbeac7341a14a87760e4fbe761dc030","tid":1435444,"uid":66365,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T05:13:20.000Z","msg":"但係機場唔會出防暴同催淚彈易玩好多<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"9b3a89fa544914885b16d82163fd6a77502c4e5a","tid":1435444,"uid":42431,"like":3,"dislike":2,"score":1,"citedBy":1,"replyTime":"2019-08-09T05:14:29.000Z","msg":"又係你呀？<br />\n又係做你唔啱心水既就三毛呀？<br />\n又係兄弟爬山呀？<br />\n<br />\n一路講兄弟爬山一路屈毛，你班賤種最撚無資格講兄弟爬山<img src=\"/assets/faces/lm2/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"e6f777dcc6209feef8f7ea9397487bf4610f8c9f","tid":1435444,"uid":233009,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T05:15:35.000Z","msg":"Push"},{"pid":"58379f65c2617473f226ccfda774b7ad66a3f406","tid":1435444,"uid":159417,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T05:16:56.000Z","msg":"Pish"},{"pid":"f7957e7214073db00a83fe6eaeb414104ac95c94","tid":1435444,"uid":39838,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T05:17:30.000Z","msg":"正皮"},{"pid":"b1570187a0bd5c96ea9fe30d6bfd360e1cd1f469","tid":1435444,"uid":182802,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-09T05:19:46.000Z","msg":"推<br />\n請好盲目跟正負評<br />\n自己獨立思考"},{"pid":"aa7dac62efe90693b912f5fe67f1a2e2120bd9c9","tid":1435444,"uid":182802,"like":0,"dislike":0,"score":0,"quote":{"pid":"b1570187a0bd5c96ea9fe30d6bfd360e1cd1f469","tid":1435444,"uid":182802,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-09T05:19:46.000Z","msg":"推<br />\n請好盲目跟正負評<br />\n自己獨立思考"},"citedBy":0,"replyTime":"2019-08-09T05:20:06.000Z","msg":"請<span style=\"color: red;\">唔好</span>"},{"pid":"3c9fc96ccd6ec1a5388746119ec41eb7bf1c360b","tid":1435444,"uid":271485,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-08-09T05:22:29.000Z","msg":"我覺得叫人和理非果啲先係五毛鬼"},{"pid":"d54c4d2539dbab79f5b7aac07943d96b62cf419b","tid":1435444,"uid":240372,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-08-09T05:23:19.000Z","msg":"推，機場目前只能和理非"}]}