l.aspx?ItemId=1129328&amp;csid=261_341\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.881903.com%2FPage%2FZH-TW%2Fnewsdetail.aspx%3FItemId%3D1129328%26csid%3D261_341&d=Tc8prIKBo9hF1z3tnQ%2BJRkVeFFKYYtZMgzuY3n553xQ%3D&h=8cabd4e3\" data-auto-link target=\"_blank\">https://www.881903.com/Page/ZH-TW/newsdetail.aspx?ItemId=1129328&amp;csid=261_341</a>"},{"pid":"ff9700686b84bc0adc1ef79a3bdc235a77051713","tid":1294892,"uid":259901,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-08T01:16:47.000Z","msg":"跟住廿蚊張拉大隊走人，自由黨玩完<br />\n完"},{"pid":"e66aefce7b59afd557202bc5028b6b2a2ed8dfb0","tid":1294892,"uid":190101,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-08T01:17:37.000Z","msg":"起碼佢叫講緊人話"},{"pid":"32318c31a0282fb133e390c3ad18fab7703b10b6","tid":1294892,"uid":128923,"like":0,"dislike":0,"score":0,"quote":{"pid":"e47d168a7d84cc05e05a7ef84e9edbc71628eef7","tid":1294892,"uid":6435,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-07-08T01:15:32.000Z","msg":"一早已覺得田大少響豉油黨無晒牙力"},"citedBy":1,"replyTime":"2019-07-08T01:17:42.000Z","msg":"一早比人架空左 經民聯出走一次 自由黨內被人架空第二次<br />\n係建制派做一兩次好人就係咁既結果"},{"pid":"18ed0c29f949579ebc9bb5be7212db125619e575","tid":1294892,"uid":125208,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-08T01:18:17.000Z","msg":"中國賓想玩乜9<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"5e2c60e894a108ad8838c1d3cb9a76bf97d798ff","tid":1294892,"uid":137080,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff9700686b84bc0adc1ef79a3bdc235a77051713","tid":1294892,"uid":259901,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-08T01:16:47.000Z","msg":"跟住廿蚊張拉大隊走人，自由黨玩完<br />\n完"},"citedBy":1,"replyTime":"2019-07-08T01:18:21.000Z","msg":"田大少再令組<img src=\"/assets/faces/normal/hoho.gif\" class=