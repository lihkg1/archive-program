方呎<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"7e0494c4957d1122b3a0f498b62c851abd778401","tid":876252,"uid":155983,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-10-26T01:11:49.000Z","msg":"篇文竟然提到我早幾個月賣嗰間樓。<br />\n跌係事實亦都係預期之内，我係比四成首期，咁都負資產我都無嘢好講。"}]}