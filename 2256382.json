kgmoji\" /><br />\n<br />\n<br />\n<br />\n咁睇有無覺得公平啲，甚至賺咗個試玩?<br />\n<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" />"},{"pid":"b6c0b57c077f599b71e0b5c8e8a02450b00adce6","tid":2256382,"uid":283713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-24T11:55:02.000Z","msg":"我覺得佢試下你有冇心繼續落去姐"},{"pid":"edb89a783869842051b03de5290ac71545fbc401","tid":2256382,"uid":25601,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-24T12:15:42.000Z","msg":"你買啦 買到最後你連人都見唔到"},{"pid":"0c39059772653a0a06a0b548035022bdb4b83f9e","tid":2256382,"uid":66234,"like":1,"dislike":0,"score":1,"quote":{"pid":"6007d681e1d23cf5b94caf1603e34a9a4b6e8e83","tid":2256382,"uid":128120,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2020-10-24T10:45:47.000Z","msg":"唉<br />\n比我靜下<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我接受唔到<br />\n人生第一次接觸女仔<br />\n點解要玩我<br />\n尼個世界公平咩<br />\n<span class=\"red\"><span class=\"xx-large\">公平咩</span></span>"},"citedBy":1,"replyTime":"2020-10-24T12:21:08.000Z","msg":"話唔埋係男人黎呢<br />\n你第一次仲係到"},{"pid":"10122018514b9f997196372d2902336529754231","tid":2256382,"uid":128120,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c39059772653a0a06a0b548035022bdb4b83f9e","tid":2256382,"uid":66234,"like":1,"dislike":0,"score":1,"quote":{"pid":"6007d681e1d23cf5b94caf1603e34a9a4b6e8e83","tid":2256382,"uid":128120,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2020-10-24T10:45:47.000Z","msg":"唉<br />\n比我靜下<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我接受唔到<br />\n人生第一次接觸女仔<br />\n點解要玩我<br />\n尼個世界公平咩<br />\n<span class=\"red\"><span class=\"xx-large\">公平咩</span></span>"},"citedBy":1,"replyTime":"2020-10-24T12:21:08.000Z","msg":"話唔埋係男人黎呢<br />\n你第一次仲係到"},"citedBy":0,"replyTime":"2020-10-24T15:58:10.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n唉"},{"pid":"5c3cd9f84d768726aabff29698b2612fdae74e18","tid":2256382,"uid":296589,"like":0,"dislike":0,"score