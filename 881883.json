ces/lomoji/33.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-30T05:20:44.000Z","msg":"出AC130 gunship啦<br />\n直接轟落去"},{"pid":"135003be67284ec5bbf3243bdb3540b66f383fdc","tid":881883,"uid":19527,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-30T05:23:57.000Z","msg":"民主黨只要係軍隊安排人開槍殺人，侵侵就大撚鑊"},{"pid":"85c6a9ac42775e012e7ddab6120807a130b98328","tid":881883,"uid":79563,"like":3,"dislike":0,"score":3,"quote":{"pid":"135003be67284ec5bbf3243bdb3540b66f383fdc","tid":881883,"uid":19527,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-30T05:23:57.000Z","msg":"民主黨只要係軍隊安排人開槍殺人，侵侵就大撚鑊"},"citedBy":0,"replyTime":"2018-10-30T05:53:23.000Z","msg":"義勇軍有無殺過II?<br />\n<br />\n<a href=\"https://www.facebook.com/712822242120609/posts/由林建明john-lam上尉撰文憶述服役義勇軍期間的點點滴滴皇家香港軍團義勇軍於1979年6月曾被有限度動員協助保安部隊於中港邊境執行反偷渡行動其後更於1980/1050841008318729/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F712822242120609%2Fposts%2F%E7%94%B1%E6%9E%97%E5%BB%BA%E6%98%8Ejohn-lam%E4%B8%8A%E5%B0%89%E6%92%B0%E6%96%87%E6%86%B6%E8%BF%B0%E6%9C%8D%E5%BD%B9%E7%BE%A9%E5%8B%87%E8%BB%8D%E6%9C%9F%E9%96%93%E7%9A%84%E9%BB%9E%E9%BB%9E%E6%BB%B4%E6%BB%B4%E7%9A%87%E5%AE%B6%E9%A6%99%E6%B8%AF%E8%BB%8D%E5%9C%98%E7%BE%A9%E5%8B%87%E8%BB%8D%E6%96%BC1979%E5%B9%B46%E6%9C%88%E6%9B%BE%E8%A2%AB%E6%9C%89%E9%99%90%E5%BA%A6%E5%8B%95%E5%93%A1%E5%8D%94%E5%8A%A9%E4%BF%9D%E5%AE%89%E9%83%A8%E9%9A%8A%E6%96%BC%E4%B8%AD%E6%B8%AF%E9%82%8A%E5%A2%83%E5%9F%B7%E8%A1%8C%E5%8F%8D%E5%81%B7%E6%B8%A1%E8%A1%8C%E5%8B%95%E5%85%B6%E5%BE%8C%E6%9B%B4%E6%96%BC1980%2F1050841008318729%2F&d=gNd%2FZe%2F%2Ffi2rFZVpg4x76Z4f2li5K%2Fs6EGgmwhpeblA%3D&h=3b0accf6\" target=\"_blank\">https://www.facebook.com/712822242120609/posts/由林建明john-lam上尉撰文憶述服役義勇軍期間的點點滴滴皇家香港軍團義勇軍於1979年6月曾被有限度動員協助保安部隊於中港邊境執行反偷渡行動其後更於1980/1050841008318729/</a><br />\n<br />\n<br />\n由林建明（John Lam）上尉撰文，憶述服役義勇軍期間的點點滴滴：<br />\n<br />\n皇家香港軍團(義勇軍)於1979年6月曾被有限度動員，協助保安部隊，於中港邊境，執行反偷渡行動。其後更於1980年10月總動員，以執行政府的「抵壘政策」，堵截非法入境者。自此，皇家香港軍團(義勇軍)每年都會被派駐中港邊界，接替正規英軍，執行反偷渡行動，直至義勇軍解散。<br />\n<br />\n而於1991年間，義勇軍更要兼顧看管滯留香港的越南船民，其間於七月十六日，在石鼓洲島上，為數三百名船民，爆發幫派衝突，駐守島上的義勇軍即時應變，防暴鎮壓，並發射催淚彈，暴動於數小時後受到控制。此次事件，是繼「六七暴動」後，義勇軍再次發射催淚彈鎮壓暴動。<br />\n<br />\n皇家香港軍團(義勇軍)於1995年，慶祝香港重光五十週年後，於九月三日解散，完成一百四十一年的光輝歷史。"},{"pid":"a103bf6badf92e8a6b2cb57958b02e8601edb848","tid":881883,"uid":79563,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-10-30T05:54:32.000Z","msg":"<strong><span style=\"color: red;\">皇家香港軍團（義勇軍）解散前最後一次反偷渡行動 - (鄧梓峰中尉)(1995年)</span></strong><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=r3HsLTai5dQ\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3Dr3HsLTai5dQ&d=gNd%2FZe%2F%2Ffi2rFZVpg4x76Z4f2li5K%2Fs6EGgmwhpeblA%3D&h=48769b06\" target=\"_blank\">https://www.youtube.com/watch?v=r3HsLTai5dQ</a>"},{"pid":"f29dc02defbb747c9802ea870089320aa73813f7","tid":881883,"uid":136662,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-30T05:56:14.000Z","msg":"邊境改名做左膠區<br />\n再利用媒體專sell左膠區<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"69975e2c44a2d202dc271cb4fce3df94448b2e75","tid":881883,"uid":202862,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-30T05:56:42.000Z","msg":"偶像！<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"073b58099e2c9bc766ae09153fa8e3a4b99e4f10","tid":881883,"uid":78873,"like":0,"dislike":0,"score":0,"quote":{"pid":"a103bf6badf92e8a6b2cb57958b02e8601edb848","tid":881883,"uid":79563,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-10-30T05:54:32.000Z","msg":"<strong><span style=\"color: red;\">皇家香港軍團（義勇軍）解散前最後一次反偷渡行動 - (鄧梓峰中尉)(1995年)</span></strong><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=r3HsLTai5dQ\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3Dr3HsLTai5dQ&d=gNd%2FZe%2F%2Ffi2rFZVpg4x76Z4f2li5K%2Fs6