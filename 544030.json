rmal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"973d38baec6720f4b1f3f4b5f11655a0900d3017","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-29T17:01:57.000Z","msg":"<img src=\"https://holland.pk/uptow/i4/ca6d37a6f02a82a02b97a01078ce492e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fuptow%2Fi4%2Fca6d37a6f02a82a02b97a01078ce492e.jpg&h=06a141ea&s={SIZE}\" /><br />\n<img src=\"https://holland.pk/uptow/i4/9ac4f0791fdaf7c3a42ad863274a7e0b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fuptow%2Fi4%2F9ac4f0791fdaf7c3a42ad863274a7e0b.jpg&h=0ad4c30a&s={SIZE}\" />"},{"pid":"514b0715577fb406bbe466aa2003447dcc056ab6","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-29T17:06:56.000Z","msg":"<span style=\"font-size: large;\">班迪球世界錦標賽有乙組  <br />\n<br />\nA組： 愛沙尼亞、烏克蘭、日本、蒙古<br />\nB組： 荷蘭、斯洛伐克、索馬利亞、中國</span>"},{"pid":"be64c10931926f195f040f555771591b198918d3","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-29T17:33:35.000Z","msg":"愛沙尼亞 5-1 日本<br />\n烏克蘭 3-1 蒙古<br />\n<br />\n荷蘭 7-1 中國"},{"pid":"dc8224091b39ad84f081320573e0475d294cf13c","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-29T18:12:30.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"832f4a50089935a2455f00be50698d2a33b6da5f","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-29T18:49:26.000Z","msg":"話時話索馬利亞係熱帶<br />\n組隊參加冰雪運動 <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"211a40e500916e182b830c65757f1d4ee229de26","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-30T05:05:00.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"29572deeee688b98380611f44b496c22a108dd69","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-30T05:10:33.000Z","msg":"<strong>普京歡迎2018年班迪球世界錦標賽參賽者</strong><br />\n<img src=\"https://holland.pk/uptow/i4/74938c0dde78e2de3dda282c741a905b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fuptow%2Fi4%2F74938c0dde78e2de3dda282c741a905b.jpg&h=6c52e8aa&s={SIZE}\" /><br />\n<br />\n俄羅斯總統普京歡迎2018年伯力班迪球世界錦標賽的參賽者，組織者和客人。<br />\n<br />\n普京說，世界錦標賽的舉辦是重要事件。全世界的頂尖球隊再次匯聚一堂，展現它們的球藝，性格，對成果的追求，為最強稱號而戰，奉獻給這一冬季體育項目愛好者一個節日。<br />\n<br />\n普京祝願參賽者取得好成績，球迷留下深刻，難忘的印象。<br />\n<br />\nA組將從1月29日至2月4日第三次在伯力舉辦。B組將從1月28日至2月3日在中國的哈爾濱舉辦。"},{"pid":"688dfc8974770d793dcdb10308e06087cec1c2b8","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-30T06:00:43.000Z","msg":"愛沙尼亞 5-1 日本<br />\n荷蘭 9-0 索馬利亞<br />\n斯洛伐克 2-3 中國"},{"pid":"3d0a7486b5a1dca6c503bfa164e535b05e2a4e84","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-30T06:22:25.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"21b4d0ae50c2592fe0ac1b3e4f024fc63bbf7676","tid":544030,"uid":78774,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-30T06:54:49.000Z","msg":"Off Topic一問<br />\n係香港想打冰球有咩門路 睇過總會D course 都係俾小朋友學<br />\n<br />\n利申：廿幾歲 新手 只識向前溜冰<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"67bd068caea6d7f199f70adf65deb90a0b14270c","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-30T07:08:33.000Z","msg":"俄羅斯遠東的伯力是俄羅斯遠東第一大城市，是外東北重要的航空、水路和鐵路重鎮。<br />\n<br />\n清朝前期東北邊疆重鎮之一。1860年，英法聯軍進攻北京，清廷舉朝外逃。沙俄外交代表假作「調停人」，一面挑撥英、法繼續進攻北京，一面捉來充當臨時談判代表的奕昕，奕昕被逼和俄國簽訂了《中俄北京條約》，從此伯力城及其烏蘇里江以東至海，40多萬平方公里的廣大地區被沙俄割佔。<br />\n<br />\n後來俄羅斯把伯力改名為哈巴羅夫斯克。伯力以大工業中心地著稱，並設有一批高等院校。伯力常住人口60萬左右，當地人口的文化素質被認為普遍較高，政治和社會環境比較穩定。<br />\n<br />\n伯力是中國商品進入俄羅斯的重要集散地。中國和俄羅斯兩國商人通過這裏，將貨物向俄內地運輸、批發。很多業戶同時也顧及到俄羅斯內地市場。"},{"pid":"c3f812fd6ac945168f5989aa92cb3b051156e758","tid":544030,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"r