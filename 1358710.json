v%3De%26sfns%3Dmo&d=gHNHb7VIn83nczLIzOZu1ZgFNMRZLCTiZeA0y1vO9n4%3D&h=80dedf25\" data-auto-link target=\"_blank\">https://www.facebook.com/178965725523592/posts/2344305415656268?s=1419369080&amp;v=e&amp;sfns=mo</a>"},{"pid":"9df0cde0fe82d3a0b6236e710418f0f659e339be","tid":1358710,"uid":48379,"like":1,"dislike":2,"score":-1,"citedBy":2,"replyTime":"2019-07-26T01:14:32.000Z","msg":"如果係咁既話  我del左條片佢?"}]}