ssets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6c802b59af1547451f168c0dfd05d71aceb17039","tid":1382864,"uid":68080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T14:56:35.000Z","msg":"唔好only讚<br />\n推下得唔得<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f100caa2d4bec780a9ea4f97dd6768bd8ae18d78","tid":1382864,"uid":68080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T15:06:55.000Z","msg":"有無人可以推下<br />\n打左好耐<br />\n我真係覺得今次係和理非回合<br />\n去機場真係有得搞<br />\n俾大家透下氣都好啊"},{"pid":"21b9bb5005b3117ca52113ba12eeebc8d1e47534","tid":1382864,"uid":42431,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-07-29T15:11:46.000Z","msg":"有D長, 放工都見到agile 有D驚<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 正評anyway"},{"pid":"eaeb858161e74befb2984e400a45fed3a5c526a4","tid":1382864,"uid":63045,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T15:11:57.000Z","msg":"[置頂]設立三毛台：聽聽三毛講咩，連尼住幫幫手<br />\n<a href=\"https://lih.kg/1382623\" data-auto-link target=\"_blank\">https://lih.kg/1382623</a><br />\n- 分享自 LIHKG 討論區<br />\n幫置頂"},{"pid":"d4af050c3e682b5ab87e4bde4a596e1f439b9b1b","tid":1382864,"uid":202889,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-29T15:13:58.000Z","msg":"支持 和你飛多次<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1188d3fc27290fbde2ca370b5917a1d75f4942a4","tid":1382864,"uid":68080,"like":0,"dislike":0,"score":0,"quote":{"pid":"21b9bb5005b3117ca52113ba12eeebc8d1e47534","tid":1382864,"uid":42431,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-07-29T15:11:46.000Z","msg":"有D長, 放工都見到agile 有D驚<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 正評anyway"},"citedBy":0,"replyTime":"2019-07-29T15:18:12.000Z","msg":"所以先開上班台<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><br />\n覺得大家會明我意思D"},{"pid":"3a3b7a0fdac287134646e3706d6b07fa13ce5430","tid":1382864,"uid":68080,"like":0,"dislike":0,"sco