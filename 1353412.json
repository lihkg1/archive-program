color: red;\"><span style=\"font-size: x-large;\">黨媒上先講大型民眾衝突 再報示威期間破壞/放火/襲擊普通市民 <span style=\"font-size: x-large;\">[red</span></span>]打造真正暴動畫</span>[/red]<br />\n<br />\n<br />\n<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-23T03:31:02.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-23T03:47:29.000Z","msg":"唔建議去元朗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-23T04:04:11.000Z","msg":"我都覺得好伏<br />\n問題係依家勢在必行咁 好難禁得住大家既怒火<img src=\"/assets/faces/lm2/frown.gif\" class=\"hkgmoji\" /><br />\n所以先打咁大段野俾大家睇睇自己面對緊乜野"},{"pid":"5a9e9d46b95d8c24d3ec4239c4542391dea139fa","tid":1353412,"uid":43322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T04:06:49.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"3c2c24a99fb514b5ee1de2cb56d5bd6c08fbd347","tid":1353412,"uid":43322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T04:14:37.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"af48f1a348948a016795cc6cfedd2da64bf5c02b","tid":1353412,"uid":43322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T04:23:58.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"bc542610c14ebdc3dcc51d2da90dacd7d569053e","tid":1353412,"uid":43322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T04:46:02.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}