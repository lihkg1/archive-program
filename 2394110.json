sets/faces/cat/rain.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" />"},{"pid":"3e4a86d891b2079c20855bfbc5b72345e5d89410","tid":2394110,"uid":288675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-04T03:43:56.000Z","msg":"唔入冊已經要還神<br />\n有支雷射筆都10個月"},{"pid":"ffd2e2a858dab2b75fce8f1f87774e51d33844f2","tid":2394110,"uid":240362,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2021-02-04T03:48:02.000Z","msg":"兩名年輕男女被控於前年12月在旺角堵路，男被告受審後證據不足脫罪，女被告則罪成。裁判官認為警員沒有捉錯人，並指女被告造成的阻礙「超過微不足道的程度」，觸犯罪行。女被告今日在西九龍裁判法院接受判刑，裁判官考慮到她有悔意，犯錯時只得17歲，判處200小時社會服務令。<br />\n<br />\n裁判官鍾明新指，被告堵路行為對交通及公眾安全造成風險，僥倖的是警方迅速清理路障。雖然被告審訊後才被定罪，但考慮到被告用作堵路的物件沒攻擊性亦不易燃，且接納被告有悔意，加上她案發時年僅17歲，因此判她接受200小時社會服務令。鍾官提醒，以社會服務令代替監禁，並非軟性懲罰，被告須完成所有時數。<br />\n<br />\n鍾官早前裁決時，接納警員證人誠實可靠，警員一直緊盯女被告，片段顯示警員下車後追截三秒便拘捕女被告，加上她當日所背著的背囊款式獨特，顏色搶眼和鮮艷，因此認為警員不會拉錯人。<br />\n<br />\n鍾官亦指，涉案馬路屬公眾地方，是繁忙的行車道。從片段可見，有木卡板被放在行車綫，另一條行車綫則擺有雪糕筒，有一輛車需要「急剎轉右」，被告造成的阻礙「超過微不足道的程度」，故裁定罪名成立。<br />\n<br />\n<a href=\"https://hk.appledaily.com/local/20210204/TXFT7MFGT5E75OP2V5OYXH3MHQ/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210204%2FTXFT7MFGT5E75OP2V5OYXH3MHQ%2F&d=LTOHNK%2B9fuVs8qin7tjZRPUbXA8pdDK36CymbYVYMuw%3D&h=df422bc7\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210204%2FTXFT7MFGT5E75OP2V5OYXH3MHQ%2F&h=999aeac2\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20210204/TXFT7MFGT5E75OP2V5OYXH3MHQ/</a>"},{"pid":"efa829579b0fe556cf0ad9c0859c5799853fa37e","tid":2394110,"uid":52779,"like":0,"dislike":0,"score":0,"quote":{"pid":"ffd2e2a858dab2b75fce8f1f87774e51d33844f2","tid":2394110,"uid":240362,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2021-02-04T03:48:02.000Z","msg":"兩名年輕男女被控於前年12月在旺角堵路，男被告受審後證據不足脫罪，女被告則罪成。裁判官認為警員沒有捉錯人，並指女被告造成的阻礙「超過微不足道的程度」，觸犯罪行。女被告今日在西九龍裁判法院接受判刑，裁判官考慮到她有悔意，犯錯時只得17歲，判處200小時社會服務令。<br />\n<br />\n裁判官鍾明新指，被告堵路行為對交通及公眾安全造成風險，僥倖的是警方迅速清理路障。雖然被告審訊後才被定罪，但考慮到被告用作堵路的物件沒攻擊性亦不易燃，且接納被告有悔意，加上她案發時年僅17歲，因此判她接受200小時社會服務令。鍾官提醒，以社會服務令代替監禁，並非軟性懲罰，被告須完成所有時數。<br />\n<br />\n鍾官早前裁決時，接納警員證人誠實可靠，警員一直緊盯女被告，片段顯示警員下車後追截三秒便拘捕女被告，加上她當日所背著的背囊款式獨特，顏色搶眼和鮮艷，因此認為警員不會拉錯人。<br />\n<br />\n鍾官亦指，涉案馬路屬公眾地方，是繁忙的行車道。從片段可見，有木卡板被放在行車綫，另一條行車綫則擺有雪糕筒，有一輛車需要「急剎轉右」，被告造成的阻礙「超過微不足道的程度」，故裁定罪名成立。<br />\n<br />\n<a href=\"https://hk.appledaily.com/local/20210204/TXFT7MFGT5E75OP2V5OYXH3MHQ/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210204%2FTXFT7MFGT5E75OP2V5OYXH3MHQ%2F&d=LTOHNK%2B9fuVs8qin7tjZRPUbXA8pdDK36CymbYVYMuw%3D&h=df422bc7\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210204%2FTXFT7MFGT5E75OP2V5OYXH3MHQ%2F&h=999aeac2\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20210204/TXFT7MFGT5E75OP2V5OYXH3MHQ/</a>"},"citedBy":0,"replyTime":"2021-02-04T03:49:14.000Z","msg":"<img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" />"},{"pid":"7af55e617e741aee996d94b9c402f76956b134b0","tid":2394110,"uid":51752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-04T04:57:44.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a115a4ec458c38d51d4b7877190ccbc8c2da9307","tid":2394110,"uid":49329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-04T05:04:07.000Z","msg":"唉<br />\n<br />\n<img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" />"},{"pid":"74bf21acd1df05995343e0f5dfdd8c724e608309","tid":2394110,"uid":232157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-04T05:38:54.000Z"