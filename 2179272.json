8我以為自己超人和主角，比警察捉入青山，1 24出院，1 27潘教唆我衝入警局救潘好多次，教唆我報假案話潘失蹤兩次，1 29用鐵凳打我五十次，又用狗屎粘落我額頭上，用戒刀兇我，又拿戒刀裝我，又找來黑社會兇我，1 30揾嫲嫲男友捉我入青山，重特登色誘我希望我非禮潘，6 13出院，潘在6 28主動約我M記等，潘叫我比我部手機潘，我以為約會，就無戒心比咗手機潘，潘改我手機密碼，刪除來電記錄和錄音，最係還鎖了我部手機，我10 30出院，11 7打比潘，潘仲叫我仆街盧彥遜，又威脅我要再送我入院"},{"pid":"ffe25231efd486dcda5b554faca10a33c7499e97","tid":2179272,"uid":150720,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-19T05:33:28.000Z","msg":"手腳<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"41e39eb94e1a2a2cc6a19281069fbf164985213b","tid":2179272,"uid":37719,"like":0,"dislike":0,"score":0,"quote":{"pid":"ffe25231efd486dcda5b554faca10a33c7499e97","tid":2179272,"uid":150720,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-19T05:33:28.000Z","msg":"手腳<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-19T05:41:44.000Z","msg":"考古c<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"509d82613850fab6384182290aec131e1d0a5104","tid":2179272,"uid":150720,"like":0,"dislike":0,"score":0,"quote":{"pid":"41e39eb94e1a2a2cc6a19281069fbf164985213b","tid":2179272,"uid":37719,"like":0,"dislike":0,"score":0,"quote":{"pid":"ffe25231efd486dcda5b554faca10a33c7499e97","tid":2179272,"uid":150720,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-19T05:33:28.000Z","msg":"手腳<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-19T05:41:44.000Z","msg":"考古c<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-19T05:59:04.000Z","msg":"你系藍c<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"1efc124e9215a9b1beec4da32fd4294e695e5b5d","tid":2179272,"uid":11506,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-19T07:17:38.000Z","msg":"我想租 有冇汽水任飲"},{"pid":"b973ab3e5e0358502d52f7a79b95f514915