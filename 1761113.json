kgmoji\" />"},{"pid":"e9149abed1ee601d072b02046b139e1fe66be460","tid":1761113,"uid":94968,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-11-28T17:11:17.000Z","msg":"到時支那打數字要用加減乘除次方表達<br />\n64=4^3<br />\n5=3+2"},{"pid":"530a818e2035f959f76f2dae5e3a7866889a72f8","tid":1761113,"uid":133341,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-28T17:12:23.000Z","msg":"推"},{"pid":"f72bf152bdcd08178ad3dce88eccd19c82e075dc","tid":1761113,"uid":141151,"like":4,"dislike":0,"score":4,"quote":{"pid":"3fc605cadcb8acd807f2101c06e2e6ed365884ac","tid":1761113,"uid":85097,"like":27,"dislike":0,"score":27,"citedBy":3,"replyTime":"2019-11-28T16:37:58.000Z","msg":"<span style=\"font-size: xx-large;\">5</span>大訴求 缺<span style=\"font-size: xx-large;\">1</span>不可<br />\n<br />\n之後「51」呢個組合做埋禁用字眼<br />\n<br />\n勞動節都可以收埋皮<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><br />\n<br />\n唔使再見到所謂51黃金周<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><br />\n<br />\n51黃金周個名我地攞嚟自己用，振興黃色經濟圈<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-28T17:24:49.000Z","msg":"51黃金周，消費撐黃店<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},{"pid":"79616438c7562897d154a20b88a3742fc17a6d3a","tid":1761113,"uid":16567,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-28T17:29:48.000Z","msg":"返祖<br />\n<br />\n用返甲乙丙丁"},{"pid":"a8c6cafe9bad48c5c12e43e44ed056ffc0e48b88","tid":1761113,"uid":172465,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-28T17:34:03.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"766432a0293679873915d3a5748bed644b9e9e2e","tid":1761113,"uid":258696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-28T17:34:53.000Z","msg":"5"},{"pid":"5fe5890e706df52b7728cc4ef7bf0576973d718d","tid":1761113,"uid":213772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-28T17:54:11.000Z","msg":"黑色衫<br />\n校服<br />\n頭盔<br />\n黃色<br />\n眼罩<br />\n面罩/豬嘴<br />\n雨傘<br />\n鐳射筆<br />\n磚頭<br />\n火魔<br />\n煙霧<br />\n旗<br />\n連儂牆<br />\n拖手<br />\n攝衫<br />\n<br />\n相信宜家只要以上任何兩樣野或以上同時出現喺某樣野，就會達到投射效應令支共提防<br />\n<br />\n要令5同1成為禁用字就必需將佢形象化 更清晰容易咁同抗爭運動掛勾。<br />\n<br />\n舉例嚟講，最有效直接就係喺有影響力嘅媒體(times封面) 帶住口罩舉起五隻手指，或者舉起一隻手指做安靜嘅動作。然後乜野都唔洗多講，只需要簡單講一個「5」/「1」字。 <br />\n咁樣做我都幾肯定第二日成個支共都會輕機<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"0d38315e96864b125d0f50762d7a42bbd59f6c46","tid":1761113,"uid":307203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-28T17:55:03.000Z","msg":"Push"},{"pid":"7069f56718c6c97c15d47d7cfc7108a464bc4f22","tid":1761113,"uid":168509,"like":0,"dislike":0,"score":0,"quote":{"pid":"3fc605cadcb8acd807f2101c06e2e6ed365884ac","tid":1761113,"uid":85097,"like":27,"dislike":0,"score":27,"citedBy":3,"replyTime":"2019-11-28T16:37:58.000Z","msg":"<span style=\"font-size: xx-large;\">5</span>大訴求 缺<span style=\"font-size: xx-large;\">1</span>不可<br />\n<br />\n之後「51」呢個組合做埋禁用字眼<br />\n<br />\n勞動節都可以收埋皮<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><br />\n<br />\n唔使再見到所謂51黃金周<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><br />\n<br />\n51黃金周個名我地攞嚟自己用，振興黃色經濟圈<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-28T18:00:49.000Z","msg":"呢個名好大陸 起個果新嫁啦 做咩要汁人舊鞋"},{"pid":"0fda025e1812c29ee6f904ee14ec35abeeedd303","tid":1761113,"uid":60941,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-28T18:11:38.000Z","msg":"<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />有冇人整做「五大訴求 缺一不可」隻手勢<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5394c75ab5d9987fdd174778d5f50004103298f2","tid":17