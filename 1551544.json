3fe355d833772217ab92d63dc09d48","tid":1551544,"uid":171718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-08T05:42:40.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"af2aaad4e08bbdbf9a196000f96e604cd862f285","tid":1551544,"uid":201266,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-08T05:44:39.000Z","msg":"老雞<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ec3b9e4f842cb00b4d4aabb9a056d4fc56959381","tid":1551544,"uid":110331,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-08T05:47:22.000Z","msg":"<a href=\"https://lih.kg/1549899\" data-auto-link target=\"_blank\">https://lih.kg/1549899</a><br />\n<a href=\"https://lih.kg/1549899\" data-auto-link target=\"_blank\">https://lih.kg/1549899</a><br />\n<a href=\"https://lih.kg/1549899\" data-auto-link target=\"_blank\">https://lih.kg/1549899</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<span style=\"color: red;\">美領大遊行要齊人！</span>[/size=6]<br />\n<br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: x-large;\">只要過左五大訴求就會成真！<br />\n政府要係2020實行真。普選立法會<br />\n侵犯人權的官員人和家庭成員簽證可被撤銷，外資可被凍結！</span></span><br />\n<br />\n<img src=\"https://na.cx/i/QmfHUdC.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQmfHUdC.png&h=89bc45e5&s={SIZE}\" /><img src=\"https://na.cx/i/ksEYsyD.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FksEYsyD.png&h=ab62bc0b&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: orange;\">呢個先喺真真正正嘅END GAME<br />\n未清楚咩事可以睇下面</span></span><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">1。</span></span><span style=\"font-size: large;\"><span style=\"color: pink;\">草案要求中國政府履行承諾，容許港人治港、高度自治，並且確保香港人可以通過普選，選出行政長官及立法會所有議席，當中特別設下「時限」，要求在2020年普選立法會。</span></span><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><span style=\"color: orange;\">2。</span></span></span><span style=\"color: pink;\"><span style=\"font-size: large;\">特別警告香港若就23條立法，除非可證明不影響港人及外籍居民的人權，否則美國政府可中止《香港政策法》等。</span></span><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: orange;\">3。</span></span><span style=\"font-size: xx-large;\"><span style=\"font-size: large;\"><span style=\"color: pink;\">侵犯人權的及損害香港自治的官員及人士的清單。名單裡的人在美國的資產可被凍結、個人和家庭成員的簽證可被撤銷，要求美國總統調查及制裁打壓香港自由的官員。會交代香港是否有官員因協助侵犯人權而需要受制裁。</span></span></span><br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: orange;\">這有助國際社會持續監察香港的狀況，如能每年通過查證，實際上等同美國年年為一國兩制投下信任一票，這一方面有助有助保障香港高度自治，同時亦會加強國際社會對香港的信心。</span></span><br />\n<br />\n<img src=\"https://na.cx/i/3DYm9M6.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3DYm9M6.png&h=40ab8a6e&s={SIZE}\" /><img src=\"https://na.cx/i/LehviFs.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLehviFs.png&h=cadff255&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: teal;\">未簽聯署即做！<br />\n<a href=\"https://petitions.whitehouse.gov/petition/hong-kong-say-no-carrie-lams-so-called-concessions-continue-call-us-pass-hk-human-rights-and-democracy-act\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fhong-kong-say-no-carrie-lams-so-called-concessions-continue-call-us-pass-hk-human-rights-and-democracy-act&d=N8yyMuQB0XA0Wgs8sIkproE4T4y%2BYV5jPOnVoTo%2FPYs%3D&h=bb6aa5b9\" data-auto-link target=\"_blank\">https://petitions.whitehouse.gov/petition/hong-kong-say-no-carrie-lams-so-called-concessions-continue-call-us-pass-hk-human-rights-and-democracy-act</a></span></span><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">聽日12點遮打花園見！</span></span><br />\n<br />\n<br />\n<img src=\"https://na.cx/i/7A6LR0y.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7A6LR0y.png&h=81aa1e4c&s={SIZE}\" />"},{"pid":"6ffde16f8370e71b2cdf8052803450f0a62af301","tid":1551544,"uid":34777,"like":0,"dislike":0,"score":0,"quote":{"pid":"8675fa92c6aca3b815d89d5ada3dfb7c69e617a7","tid":1551544,"uid":70745,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-08T05:42:02.000Z","msg":"我屌<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-08T05:48:13.000Z","msg":"唔好同我爭<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e05af3a9e58e75d04f3b1935112b0867bb13a14a","tid":1551544,"uid":269173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-08T05:48:16.000Z","msg":"<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},{"pid":"10c616f0e9adc05504cac933fdf6a2cda9e2faa0","tid":1551544,"uid":70745,"like":0,"dislike":0,"score":0,"quote":{"pid":"6ffde16f8370e71b2cdf8052803450f0a62af301","tid":1551544,"uid":34777,"like":0,"dislike":0,"score":0,"quote":{"pid":"8675fa92c6aca3b815d89d5ada3dfb7c69e617a7","tid":1551544,"uid":70745,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-08T05:42:02.000Z","msg":"我屌<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-08T05:48:13.000Z","msg":"唔好同我爭<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-08T05:48:39.000Z","msg":"你要晒？"}]}