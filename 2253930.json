{"tid":2253930,"cid":37,"subCid":0,"title":"★深圳「孔雀計劃」招攬人才：可連續10年免費租住2153平方呎房屋 並獲600萬元置業補助","createTime":"2020-10-22T13:11:35.000Z","updateTime":"2020-10-23T07:25:53.000Z","uid":19454,"like":2,"dislike":2,"uniUserReply":6,"replies":[{"pid":"d3f2db524332d5c55f6fcdf6a634d0182ebe6960","tid":2253930,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-22T13:11:35.000Z","msg":"<span class=\"xx-large\">挽留人才：住得大，過得好</span><br />\n<br />\n不「安居」難以「樂業」，內地多會提供不同程度的住屋優惠，藉此留住人才，持續發展。深圳針對人才的房屋政策可謂「點面結合」&mdash;&mdash;「點」指高端人才享有房屋津貼，例如「孔雀計劃」招攬的海外高級人才，可連續10年免費租住200平方米（約2153平方呎）的房屋，並獲當局提供多達600萬元人民幣的置業補助；「面」指深圳當局大舉興建公共房屋和「人才住房」，例如於2018年注資1000億元成立「人才安居集團」，計劃提供30萬個單位。<br />\n<br />\n<a href=\"https://www.hk01.com/%E5%91%A8%E5%A0%B1/539339/%E6%B8%AF%E6%B7%B1%E8%9E%8D%E5%90%88-%E9%A6%99%E6%B8%AF%E6%86%91%E4%BB%80%E9%BA%BC%E8%88%87-%E4%BA%BA%E6%89%8D%E5%A4%A9%E5%A0%82-%E8%81%AF%E6%89%8B\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E5%2591%25A8%25E5%25A0%25B1%2F539339%2F%25E6%25B8%25AF%25E6%25B7%25B1%25E8%259E%258D%25E5%2590%2588-%25E9%25A6%2599%25E6%25B8%25AF%25E6%2586%2591%25E4%25BB%2580%25E9%25BA%25BC%25E8%2588%2587-%25E4%25BA%25BA%25E6%2589%258D%25E5%25A4%25A9%25E5%25A0%2582-%25E8%2581%25AF%25E6%2589%258B&d=mhl3ai6H9Odyk596tiaOPY26uSpwD1fkwqqc2qDkc5E%3D&h=71474faa\" data-auto-link target=\"_blank\">https://www.hk01.com/%E5%91%A8%E5%A0%B1/539339/%E6%B8%AF%E6%B7%B1%E8%9E%8D%E5%90%88-%E9%A6%99%E6%B8%AF%E6%86%91%E4%BB%80%E9%BA%BC%E8%88%87-%E4%BA%BA%E6%89%8D%E5%A4%A9%E5%A0%82-%E8%81%AF%E6%89%8B</a>"},{"pid":"94471d3e887cd9178781ee54a608b8eae3804f48","tid":2253930,"uid":19454,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-10-22T13:11:42.000Z","msg":"<img src=\"/assets/faces/lm2/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/oh.gif\" class=\"hkgm