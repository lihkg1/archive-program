/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-02-20T05:23:50.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"b6a1e3f447f2dff2dacd4fcfdc59250a35e5a0ae","tid":1028870,"uid":50457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-20T05:46:59.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"}]}