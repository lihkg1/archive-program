hk.net/upload/2018/10/08/142346_eff5cdab49c6f627e2bc8f9dea410dfe.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F08%2F142346_eff5cdab49c6f627e2bc8f9dea410dfe.png&h=f7a9993b&s={SIZE}\" />"},{"pid":"e2976876e422abd67b835642ea7fb5516f1c722e","tid":852760,"uid":38523,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-08T06:26:56.000Z","msg":"佢答上面埋廢話既時候<br />\n已經係我第7、8次問佢之前答我既都係一堆廢話<br />\n而唔敢正面答<br />\n大家可以深思<br />\n點解一條大家都知答案既問題<br />\n佢會唔答？<br />\n因為答左佢<br />\n泛民同保皇就不再一樣<br />\n保皇就成為唯一大仆街<br />\n冇得用泛民轉移視線<br />\n至於點解要咁做？<br />\n大家心照"},{"pid":"7bb852fc63391e0b0b589f8dbc258f03cc91ab81","tid":852760,"uid":206831,"like":5,"dislike":0,"score":5,"quote":{"pid":"bc7ec2617f4c9f2dd41b2627b3333f714cc9f226","tid":852760,"uid":38523,"like":1,"dislike":1,"score":0,"quote":{"pid":"3794d758e069ee6f5d8847adea791974d8fcb19c","tid":852760,"uid":206831,"like":7,"dislike":1,"score":6,"citedBy":1,"replyTime":"2018-10-08T06:15:31.000Z","msg":"咪住<br />\n「特權調查沙中線係咪關鍵」<br />\n呢個問題本身就有bugs，個關鍵係乜呢？<br />\n<br />\n1.係解決沙中線現有問題？屌你啦擺明就禮崩樂壞，合理預期毫無成效<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n2.係要揭露真相比公眾？<br />\n我話OK就OK.jpg<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /> <br />\n<br />\n再講，你憑咩assume一個有政治立場嘅人要全方位無死角地關心所有香港時事<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n要狙擊其他user OK啊，質疑埋政治立場都冇問題，但可唔可以理智啲，唔答一條問題完全代表唔到任何野<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n甚至再退一步，曾經炒中資同埋喺某啲地方工作就代表今日唔能夠衷誠推動港獨咩？呢種概念擺明係支共嘅終生剝奪政治權利<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n係呢個邏輯之下，任何宣傳建國嘅想法都應該消失啦下話？<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n一日港豬 你成世都港豬 <br />\n你飲過閪茶 建國之後要清算<br />\n<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-08T06:19:29.000Z","msg":"因為關愛座hunter話<br />\n泛民關鍵時候賣港<br />\n我問佢<br />\n特權調查條例沙中線算唔算關鍵時候<br />\n佢就避足幾頁都唔答<br />\n你上面堆野<br />\n你可以對住佢講番架<br />\n不過我估到佢話泛民關鍵時候賣港<br />\n你又唔會跳出來幫叫佢解釋咩叫關鍵<br />\nanyway<br />\n你呢堆話應該同佢講<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-08T06:28:02.000Z","msg":"唔好搞笑啦<br />\n有人柒咗就變咗你無柒到？<br />\n<br />\n不如你老實講句<br />\n關鍵唔關鍵呢個細眉細眼位根本唔撚關事<br />\n你私怨就私怨啦<br />\n夾硬搵位入<br />\n<br />\n況且泛民有無賣港都要拗<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n你覺得咁都有爭議咁就當我輸啦屌<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 2018年啦屌你老母<br />\n仲泛民<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n話說我係咪變咗你心入面嘅關愛座打手？<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 係嘅話話聲我知，咁撚戇鳩嘅人我唔會再同佢討論落去"},{"pid":"89982d4bf733ae0ddbc955e693fdc8bf66d8b134","tid":852760,"uid":38523,"like":0,"dislike":0,"score":0,"quote":{"pid":"7bb852fc63391e0b0b589f8dbc258f03cc91ab81","tid":852760,"uid":206831,"like":5,"dislike":0,"score":5,"quote":{"pid":"bc7ec2617f4c9f2dd41b2627b3333f714cc9f226","tid":852760,"uid":38523,"like":1,"dislike":1,"score":0,"quote":{"pid":"3794d758e069ee6f5d8847adea791974d8fcb19c","tid":852760,"uid":206831,"like":7,"dislike":1,"score":6,"citedBy":1,"replyTime":"2018-10-08T06:15:31.000Z","msg":"咪住<br />\n「特權調查沙中線係咪關鍵」<br />\n呢個問題本身就有bugs，個關鍵係乜呢？<br />\n<br />\n1.係解決沙中線現有問題？屌你啦擺明就禮崩樂壞，合理預期毫無成效<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n2.係要揭露真相比公眾？<br />\n我話OK就OK.jpg<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /> <br />\n<br />\n再講，你憑咩assume一個有政治立場嘅人要全方位無死角地關心所有香港時事<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n要狙擊其他user OK啊，質疑埋政治立場都冇問題，但可唔可以理智啲，唔答一條問題完全代表唔到任何野<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n甚至再退一步，曾經炒中資同埋喺某啲地方工作就代表今日唔能夠衷誠推動港獨咩？呢種概念擺明係支共嘅終生剝奪政治權利<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n係呢個邏輯之下，任何宣傳建國嘅想法都應該消失啦下話？<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n一日港豬 你成世都港豬 <br />\n你飲過閪茶 建國之後要清算<br />\n<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-08T06:19:29.000Z","msg":"因為關愛座hunter話<br />\n泛民關鍵時候賣港<br />\n我問佢<br />\n特權調查條例沙中線算唔算關鍵時候<br />\n佢就避足幾頁都唔答<br />\n你上面堆野<br />\n你可以對住佢講番架<br />\n不過我估到佢話泛民關鍵時候賣港<br />\n你又唔會跳出來幫叫佢解釋咩叫關鍵<br />\nanyway<br />\n你呢堆話應該同佢講<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-08T06:28:02.000Z","msg":"唔好搞笑啦<br />\n有人柒咗就變咗你無柒到？<br />\n<br />\n不如你老實講句<br />\n關鍵唔關鍵呢個細眉細眼位根本唔撚關事<br />\n你私怨就私怨啦<br />\n夾硬搵位入<br />\n<br />\n況且泛民有無賣港都要拗<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n你覺得咁都有爭議咁就當我輸啦屌<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 2018年啦屌你老母<br />\n仲泛民<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n話說我係咪變咗你心入面嘅關愛座打手？<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 係嘅話話聲我知，咁撚戇鳩嘅人我唔會再同佢討論落去"},"citedBy":0,"replyTime":"2018-10-08T06:33:02.000Z","msg":"你唔好搞笑啦<br />\n所謂關鍵時候係佢提出<br />\n我就番佢所講同詞既問佢<br />\n佢答唔到<br />\n而且<br />\n你又同關愛座用埋一樣轉移視線<br />\n依加佢話泛民關鍵時候賣港<br />\n我咪問佢沙中線算唔算關鍵時候囉<br />\n好不過係佢答唔到<br />\n不過唔知點解你入來幫佢答姐<br />\n可能用第二位身份答<br />\n可以解決佢答個時自相矛盾個問題啦<br />\n仲有<br />\n下面個段可以收番埋啦<br />\n唔通五毛自己打句&ldquo;我唔知係咪變成五毛啦&rdquo;<br />\n就可以証明自己唔係五毛狗<br />\n你係咪關狗打手係由你自己講既野展示出來架<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7efb294a959ff9536afb80e9e389f26f7f449e7b","tid":852760,"uid":38523,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-08T06:34:00.000Z","msg":"關狗可以入來答未啊？<br />\n所謂關鍵時候係你提出<br />\n依加開你又答唔到<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a673095e612ec47db1253178a961a184a321c4fe","tid":852760,"uid":38523,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-08T06:37:11.000Z","msg":"關服愛座hunter最新回應<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/10/08/143610_bcae8530380d3b951f30a82db767a7ea.png\" data-thumbnail-src=\"h