s/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"f019a155e7d4c4e4f0212ad3641a189c2c47f525","tid":774682,"uid":51041,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-11T06:26:19.000Z","msg":"s9+都好似唔錯<br />\n夠平均<br />\n起碼平d先"},{"pid":"8bbb4b734d5d94197dfefcbb77c769b2c0c28600","tid":774682,"uid":164092,"like":0,"dislike":0,"score":0,"quote":{"pid":"f019a155e7d4c4e4f0212ad3641a189c2c47f525","tid":774682,"uid":51041,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-11T06:26:19.000Z","msg":"s9+都好似唔錯<br />\n夠平均<br />\n起碼平d先"},"citedBy":0,"replyTime":"2018-08-11T06:28:50.000Z","msg":"其實如果你唔要支筆，S9+已經夠"},{"pid":"cd68d78132c187be42d47815dfdbf23e6c82f499","tid":774682,"uid":163783,"like":0,"dislike":1,"score":-1,"quote":{"pid":"f46ed8b4c5d31fa33d447ec62eb035c452f3fb14","tid":774682,"uid":85180,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-10T13:37:05.000Z","msg":"Note 9 並非目前效能最強手機，排名在他前面至少還有這兩款手機<br />\n<br />\nNote 9 並非目前效能最強手機，排名在他前面至少還有這兩款手機<br />\njanus janus 發表於 2018年8月10日 14:00 收藏此文<br />\n<br />\nNote 9 並非目前效能最強手機，排名在他前面至少還有這兩款手機三星的Note 9已經發表了，一般來說，在旗艦手機的領域中，由於旗艦手機往往在各方面都希望做到最好，往往也就是一場效能大戰。而最新發的旗艦機種由於有後發優勢，通常都會在效能上尬過先前發的其他家廠商的旗艦手機。而外媒也做出了Note 9的效能測試，並且拿它來與先前的其他自家以及其他廠商的旗艦機進行比較。<br />\n<br />\nNote 9 的螢幕從 Note 8 的 6.3 吋小升級到 Note 9 的 6.4 吋，電池容量也提升到 4,000mAh，和 S9+ 或 Note 8 相比可以有更長的續航表現，處理器一樣為高通 Snapdragon 845 或 Exynos 9810 處理器，不過記憶體升級到最高 8GB RAM，多工處理會更有效率（共有 6GB RAM / 128GB ROM、8GB RAM / 256GB ROM 兩版本），並支援最高 512GB 的 micro SD 卡擴充，到時台灣會推出哪個版本，台灣三星表示之後會另行公佈。<br />\n<br />\n我們在昨天也發表過一篇Note 9 與前代旗艦機種的規格比較，若從 Note 8 的角度來看，Note 9 則是在各方面都有小幅升級，處理器更強、相機多了雙光圈功能、電池更大，加上 S Pen 多了遠端遙控功能，對於猶豫是否要從 Note 8 升級到 Note 9 的人可以想想這些功能對自己來說是否實用。<br />\n<img src=\"https://cdn1-techbang.pixfs.net/system/images/453884/original/21bb0a75063f585ddaf866024023bb90.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn1-techbang.pixfs.net%2Fsystem%2Fimages%2F453884%2Foriginal%2F21bb0a75063f585ddaf866024023bb90.jpg&h=f0bea5cb&s={SIZE}\" /><br />\n<br />\n而現在，外媒Tom&rsquo;s Guide則從效能的角度來比較，看看Note 9與其他效能旗艦機種比較，表現又是如何？他們測試的是6GB記憶體/128GB儲存空間版本的 Galaxy Note 9 ，拿來與其他旗艦機進行跑分測試。<br />\n<img src=\"https://cdn0-techbang.pixfs.net/system/images/454000/original/0a3f9f1093f990fe05c0bd6950cdd8fd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn0-techbang.pixfs.net%2Fsystem%2Fimages%2F454000%2Foriginal%2F0a3f9f1093f990fe05c0bd6950cdd8fd.jpg&h=451ab974&s={SIZE}\" /><br />\n<img src=\"https://cdn0-techbang.pixfs.net/system/images/454004/original/b865a4cc9269ba818f22db9d5d57fcb0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn0-techbang.pixfs.net%2Fsystem%2Fimages%2F454004%2Foriginal%2Fb865a4cc9269ba818f22db9d5d57fcb0.jpg&h=5a20ea3a&s={SIZE}\" /><br />\n在這裡要說，說 OnePlus 6 的 9,088 跑贏 Galaxy Note 9 可能不大公平，因為這裡用的 OnePlus 6是8GB的版本，而 Galaxy Note 9 用的是6GB的版本。如果未來他們借到Galaxy Note 9 8GB的版本，可能分數的評比結果很難講。<br />\n<br />\n而與自家相比，S9+的分數為8295，Note 8的分數為6564。<br />\n<img src=\"https://cdn1-techbang.pixfs.net/system/images/454001/original/ae0e81d9a49c893284f46a0c33753d2c.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn1-techbang.pixfs.net%2Fsystem%2Fimages%2F454001%2Foriginal%2Fae0e81d9a49c893284f46a0c33753d2c.jpg&h=85cad7dc&s={SIZE}\" /><br />\n而用3D Mark Slingshot Extreme 來檢驗手機的顯示效能上， Galaxy Note 9 依然不是最高的。跑在他前面的依然是iPhone X以及 OnePlus 6 ，但是這次大勝的是 OnePlus 6 ，分數為5124，第二名是iPhone X的4994，第三名為Note9的4639。<br />\n<img src=\"https://cdn1-techbang.pixfs.net/system/images/454005/original/0e57b6f618f8e274b9c3c4f0a1951d9e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn1-techbang.pixfs.net%2Fsystem%2Fimages%2F454005%2Foriginal%2F0e57b6f618f8e274b9c3c4f0a1951d9e.jpg&h=0056f3be&s={SIZE}\" /><br />\n而與自家相比，S9+的分數為4634，Note 8的分數為3710。<br />\n<br />\n不過，Note 9在顯示測試上則表現得相當好，這款裝置採用的AMOLED面板在廣色域測試的表現中，獲得第二名的成績，僅次於自家的S9+。<br />\n<img src=\"https://cdn2-techbang.pixfs.net/system/images/454003/original/960b114ac730871c0bdd0321f2fd263a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn2-techbang.pixfs.net%2Fsystem%2Fimages%2F454003%2Foriginal%2F960b114ac730871c0bdd0321f2fd263a.jpg&h=7f180ecf&s={SIZE}\" /><br />\n當然，每次講到測試都還是要強調一次，跑分僅供參考而非絕對。不過，Tom&rsquo;s Guide也表示，至少以目前為止，iPhone X依然是目前所有手機中效能最好的一款手機。看來短期之內要打敗它的，只有下一代即將要發佈的iPhone了。"},"citedBy":0,"replyTime":"2018-08-11T15:45:14.000Z","msg":"855 都就出仲用舊科技講效能<br />\n<br />\n好心一樣u既產品就一齊出啦"},{"pid":"1dc997578c0b62c89242787cb62fbbebddac9b3a","tid":774682,"uid":64060,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2018-08-11T15:49:14.000Z","msg":"3 星狗不願面對"},{"pid":"ea30afa382885f9063029e1a14532cf10d6c07c3","tid":774682,"uid":89514,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-08-11T16:15:52.000Z","msg":"此回覆已被刪除"},{"pid":"f3ce0ed7fb76192588022b25f1da86d585a59b00","tid":774682,"uid":158977,"like":0,"dislike":0,"score":0,"quote":{"pid":"c2509608b1f166fdb40a05bec6c851343971d724","tid":774682,"uid":164092,"like":8,"dislike":2,"score":6,"quote":{"pid":"52db9a1826226a8356759466fa54b8117714ea7a","tid":774682,"uid":109383,"like":19,"dislike":8,"score":11,"quote":{"pid":"2945de8b2d546892a077b786a300432921e2d530","tid":774682,"uid":164092,"like":8,"dislike":17,"score":-9,"citedBy":2,"replyTime":"2018-08-10T14:00:19.000Z","msg":"其實A11跑分係快過845，但係開app慢過845嘅機<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-08-10T14:38:02.000Z","msg":"都係得某d app快 某d app慢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 差個0.1 0.2秒就高潮？<br />\n<br />\n一講到重度使用 壓片 打機 845就收皮了<br />\n<br />\n明顯a11既極限高好多 開下app都未出全力就高潮 拎某幾個app開得快d就打J"},"citedBy":2,"replyTime":"2018-08-10T14:41:05.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/10/224050_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F10%2F224050_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=450912cf&s={SIZE}\" /><br />\n搬龍門<img src=\"/assets/faces/normal/clown.gif