s/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"524d3f09a5bcde912dae5b46fa67c00c29c7ee07","tid":2362783,"uid":73381,"like":0,"dislike":0,"score":0,"quote":{"pid":"b3d0a02b94f0c649405840808ccafd233d4aafb4","tid":2362783,"uid":38189,"like":1,"dislike":0,"score":1,"quote":{"pid":"feef31a254bae57f07853482c240891664bb33d9","tid":2362783,"uid":73381,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-11T16:44:02.000Z","msg":"即使不滿意對方的行為，亦不可影響他人的宗教。<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-01-11T16:46:58.000Z","msg":"陳志輝都戇能鳩 深哥都有唔尊重印度教嘅自由"},"citedBy":0,"replyTime":"2021-01-11T16:48:28.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"a2318415e486b9bc240f62e024936527c3290746","tid":2362783,"uid":7439,"like":0,"dislike":0,"score":0,"quote":{"pid":"79ff5c135686ca0c32ac67a712ba9d5751c6704f","tid":2362783,"uid":17606,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2021-01-11T16:43:43.000Z","msg":"15介月感化 懷疑判官收黑錢"},"citedBy":0,"replyTime":"2021-01-11T16:53:24.000Z","msg":"暫委裁判官陳志輝<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" /><br />\n<blockquote>69歲老翁疑不滿鄰居狗隻過於嘈吵，「由朝吠到晚」，聲稱協商多次無果下，涉嫌於去年11月20日，在長洲高山村一單位外，將6粒止痛藥物「克痛」藏於芝士腸中，用以投餵鄰居所養的狗隻，今日在東區法院被裁定一項企圖殘酷對待動物罪成立，陳志輝暫委裁判官指，被告指不清楚狗隻食用該藥物後果只是托詞，狗主能及時發現為不幸中的大幸，<span class=\"red\">判被告囚4周，緩刑18個月。</span></blockquote><br />\n<br />\n<blockquote>兩男一女隸屬東九龍總區衝鋒隊的警員，在2016年一宗毒品案作虛假陳述，其中男警聲稱從男子身上搜出懷疑毒品和吸食工具，但與閉路電視片段不符。3人早前被裁定一項作出傾向並意圖妨礙司法公正的行為罪成，今在觀塘裁判法院判刑。裁判官表示，警務人員作虛假陳述，整個制度將會崩潰，令警隊聲譽受損，公眾亦會失去信心，故須判處阻嚇刑罰，終判各人監禁10星期，各被告獲准保釋等候上訴。</blockquote><br />\n<br />\n<blockquote>42歲藥店東主於今年1月底，遭海關放蛇發現他售賣聲稱「廣州生產」的CSI政府口罩，今（23日）在東區裁判法院承認一項供應已應用虛假商品說明的貨品罪，判罰款2000元。</blockquote><br />\n<br />\n<blockquote>一名物業管理公司前物業經理，在未有適當取得報價單的情況下，欺騙發展商將總值逾五十四萬元的改裝工程判予一間裝修承辦商，早前被廉政公署起訴。被告今日(十二月二十日)在東區裁判法院被判刑。<br />\n侯致遠，四十三歲，仲量聯行物業管理有限公司(仲量聯行)前物業經理，被暫委裁判官陳志輝判處須履行二百小時社會服務。<br />\n被告早前被裁定一項串謀詐騙罪名成立，違反普通法。</blockquote>"},{"pid":"6db0f62d6f2405d5a3d059dc201f646eaadbdbd8","tid":2362783,"uid":60658,"like":0,"dislike":0,"score":0,"quote":{"pid":"3e0d5cff1bc08207f55aa1c0c59e808906e190c9","tid":2362783,"uid":5549,"like":0,"dislike":0,"score":0,"quote":{"pid":"dccf0ef6fbbb7a7ccebe4d1daba79e1d1d9e81d2","tid":2362783,"uid":7439,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2021-01-11T16:42:54.000Z","msg":"嗰隻鬼黎 由佢死啦"},"citedBy":1,"replyTime":"2021-01-11T16:47:45.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-11T17:02:21.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"5807ca4c2a65d35bc31443e3fd6199fd3041404e","tid":2362783,"uid":99700,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-11T23:47:28.000Z","msg":"感化賓"},{"pid":"8299fadae50c18c510b53f62f832a981d22c7d82","tid":2362783,"uid":180462,"like":0,"dislike":0,"score":0,"quote":{"pid":"b3d0a02b94f0c649405840808ccafd233d4aafb4","tid":2362783,"uid":38189,"like":1,"dislike":0,"score":1,"quote":{"pid":"feef31a254bae57f07853482c240891664bb33d9","tid":2362783,"uid":73381,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-11T16:44:02.000Z","msg":"即使不滿意對方的行為，亦不可影響他人的宗教。<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-01-11T16:46:58.000Z","msg":"陳志輝都戇能鳩 深哥都有唔尊重印度教嘅自由"},"citedBy":0,"replyTime":"2021-01-12T03:19:40.000Z","msg":"藐視法庭<img 