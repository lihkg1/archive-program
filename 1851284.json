ref=\"https://t.me/TwitterHelpBot\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FTwitterHelpBot&d=Ey%2FAc8I3uyYuTLy5d8l3rFNDr8uFEZb%2F0ofPPvrEBCw%3D&h=eacce590\" data-auto-link target=\"_blank\">https://t.me/TwitterHelpBot</a><br />\n然後打<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\"> /task</span></strong></span> 攞任務"},{"pid":"2ec52063b9b09144bd6671b2063b8d703fe0026f","tid":1851284,"uid":3149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T04:15:22.000Z","msg":"Push <img src=\"/assets/faces/lny/agree2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/agree2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/agree2.gif\" class=\"hkgmoji\" />"},{"pid":"42b684657960aef0b1d3cdcf03d77957f1e3ef6d","tid":1851284,"uid":249924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T04:16:36.000Z","msg":"推"},{"pid":"88f79a09acf4f498ab07e693167eecb0febd198b","tid":1851284,"uid":288707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T04:19:23.000Z","msg":"作出要求但無行動升級<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<br />\n好撚多黃.jpg"},{"pid":"cd880d496f555483a63123ff2ead464970603045","tid":1851284,"uid":24296,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T04:29:27.000Z","msg":"又係底褲好黃個班？<img src=\"/assets/faces/lny/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"6ad65592f1f8470e41125b3c11dad7e2fd1476bb","tid":1851284,"uid":345502,"like":0,"dislike":0,"score":0,"quote":{"pid":"f365a44aba05d71c049d17ab2c0be7ec0240a35f","tid":1851284,"uid":132587,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2020-01-30T03:32:05.000Z","msg":"次次寫信有撚用<br />\n做到筋疲力盡都唔sl罷工<br />\n無人幫到你"},"citedBy":0,"replyTime":"2020-01-30T04:30:11.000Z","msg":"佢地一罷就真係封關"},{"pid":"a984200ab16d2a00496124b44d59c172f663c0ca","tid":1851284,"uid":292024,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T04:37:05.000Z","msg":"入境班人最垃圾全線罷工仲點開到關？寫信有撚用咩廢物"},{"pid":"37260094c95aff21674d5f64cedcc27196f636a8","tid":1851284,"uid":38775,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T13:05:59.000Z","msg":"海關：搜到丫叉報比黑警知<br />\n入境：多次令無控罪示威者於出境時被捕<br />\n<br />\n慘？佢哋同黑警同罪"}]}