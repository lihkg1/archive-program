assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\nTake care 絲打 有咩想講可以陪你傾下計<br />\n明白你一定好難受<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"a5ea07df01d77d1c26a9b356339474d7d54448da","tid":1821641,"uid":185066,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T15:50:44.000Z","msg":"因為唔夠愛"},{"pid":"1c5e2fc6142969a74eca90aabf51ff9cc87e2f22","tid":1821641,"uid":185066,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T15:52:17.000Z","msg":"希望你遇到果個適合既人 當你遇到佢 以前都可能變得唔係咁重要"},{"pid":"2190aafaacacebed7cdf3f1e47c777106e591200","tid":1821641,"uid":47040,"like":0,"dislike":0,"score":0,"quote":{"pid":"d3dd200404a581105fd3d3919861c173a3888210","tid":1821641,"uid":43890,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-12T12:31:00.000Z","msg":"點解自己唔係咁....<br />\n<br />\n好羨慕有d人岩岩分手又可以即刻溝第二個<br />\n究竟係咩心態？<br />\n係覺得寂寞還是真係咁容易投入一段新感情<br />\n咁快又適應到身邊換左第二個人<br />\n所有生活習慣都唔同哂<br />\n<br />\n如果當初自己唔係咁專一<br />\n依家就唔會咁傷<br />\n每晚發惡夢<br />\n失戀真係好痛苦<br />\n究竟自己幾時先可以放手<br />\n<br />\n有冇專業人士幫下我<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我係絲打"},"citedBy":0,"replyTime":"2020-01-12T16:08:53.000Z","msg":"巴打，雖然咁講好廢<br />\n但係時間係最好既解藥<br />\n專一係好事<br />\n你一定會遇到同你一樣專一既另一半"},{"pid":"a5d38017954736d6bff58a6d4b9cdef56938903b","tid":1821641,"uid":235637,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-13T00:04:30.000Z","msg":"呢啲人有咩好羨慕<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"491893c70693d8eb1914bc968e3ebd963590c3ce","tid":1821641,"uid":190738,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-13T00:57:15.000Z","msg":"我衣加直頭係傷到怕左拍拖<br />\n中意左個男仔好想同佢發展<br />\n但一諗到最後可能會分手<br />\n又唔想傷害自己多次<br />\n係呢個位停左好耐<br />\n好怕再失去<br />\n同時又好有擁有<br />\n好痛架真係<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"ab