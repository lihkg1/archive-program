cJo&d=HziU8jWK8j2Oa3ZLfTDirC1yjuEIKew%2F2lwpseS6mRM%3D&h=938a12d2\" data-auto-link target=\"_blank\">https://youtu.be/o-3F-YD1cJo</a><br />\n《有毒不回》：<br />\n<a href=\"https://youtu.be/KymNPCq0_Io\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FKymNPCq0_Io&d=HziU8jWK8j2Oa3ZLfTDirC1yjuEIKew%2F2lwpseS6mRM%3D&h=ad5ba146\" data-auto-link target=\"_blank\">https://youtu.be/KymNPCq0_Io</a><br />\n<br />\n雖然冇喺節目到以冠軍團嘅方式出道，但後來有公司簽咗風暴黑桃裡面其中六個，分別係：利善榛<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmabGZpzYAfDKH3aKhdPZPXaW4aF3vB1cEn8Xt7FUMfahq?filename=Jg1HnRu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJg1HnRu.jpg&h=218d05b2&s={SIZE}\" /><br />\nig: cindyli0318<br />\n<br />\n裴頡<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmTtHWBwcE6xf6HUhMoQzYrVmUmFb1PZaQMDLoCtcHHLx3?filename=D1CCWbz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FD1CCWbz.jpg&h=cbde5b3d&s={SIZE}\" /><br />\nig: jasminejadeperry<br />\n<br />\nC.Holly<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmVRXaCmrcwDRwLJYSSMRdakoTBMgi2S6rMaf7oQ4uhjKA?filename=npHO2RE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnpHO2RE.jpg&h=8a0cc9ae&s={SIZE}\" /><br />\nig: <a href=\"http://c.holly.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fc.holly.com&d=HziU8jWK8j2Oa3ZLfTDirC1yjuEIKew%2F2lwpseS6mRM%3D&h=98460462\" data-auto-link target=\"_blank\">c.holly.com</a>_<br />\n<br />\n連穎<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmPg16GP5B2dDWxCQF9fq357RMVZZmEgBAQ15ihVJFMaZ6?filename=yp4JRK3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fyp4JRK3.jpg&h=62df5778&s={SIZE}\" /><br />\nig: realerin6<br />\n<br />\n巴倫月<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmcspJwc1pL5nD4rvCUxu2gL8Q6je5cBkbYCMfFbdNTphY?filename=cmrPNit.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcmrPNit.jpg&h=04bbf9c3&s={SIZE}\" /><br />\nig: sizi_lunyue<br />\n<br />\n席子淇<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmNbMU8qapKFMegzCGu2Fvvmw8GjQ7BhKW2EEnoQ6n6HWx?filename=XLJCbLp.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXLJCbLp.jpg&h=b2c1dc92&s={SIZE}\" /><br />\nig: jjjjner<br />\n<br />\n風暴黑桃嘅決賽歌係《Pain Killer》，據說係C.Holly想寫俾佢阿媽嘅<br />\n決賽《Pain Killer》<br />\n<a href=\"https://youtu.be/iVuF4HbWV8o\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FiVuF4HbWV8o&d=HziU8jWK8j2Oa3ZLfTDirC1yjuEIKew%2F2lwpseS6mRM%3D&h=13c0ed1e\" data-auto-link target=\"_blank\">https://youtu.be/iVuF4HbWV8o</a><br />\n<br />\n後來，HUR推出MV版嘅《Pain Killer》：<br />\n<a href=\"https://youtu.be/mY2baL7nm9U\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FmY2baL7nm9U&d=HziU8jWK8j2Oa3ZLfTDirC1yjuEIKew%2F2lwpseS6mRM%3D&h=438a9088\" data-auto-link target=\"_blank\">https://youtu.be/mY2baL7nm9U</a><br />\n超級高質<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n佢哋公司算係最俾心機經營女團嘅人，可以睇番佢哋嘅YouTube Channel同Instagram <br />\nYouTube Channel:<br />\n<a href=\"https://youtube.com/c/HUROFFICIAL-AOA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutube.com%2Fc%2FHUROFFICIAL-AOA&d=HziU8jWK8j2Oa3ZLfTDirC1yjuEIKew%2F2lwpseS6mRM%3D&h=43079a2d\" target=\"_blank\">https://youtube.com/c/HUROFFICIAL-AOA</a><br />\n<br />\nInstagram：<br />\n@hur_official_<br />\n<a href=\"https://instagram.com/hur_official_?igshid=lz6vm95ewc4a\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Finstagram.com%2Fhur_official_%3Figshid%3Dlz6vm95ewc4a&d=HziU8jWK8j2Oa3ZLfTDirC1yjuEIKew%2F2lwpseS6mRM%3D&h=cfd14d93\" target=\"_blank\">https://instagram.com/hur_official_?igshid=lz6vm95ewc4a</a>"},{"pid":"35dec6e078fe2b01044be623eea0eb52df3a966d","tid":2448243,"uid":319823,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-04-01T21:59:04.000Z","msg":"宜家先見到有人討論！三團都好高質！<img src=\"/assets/faces/mouse/love.g