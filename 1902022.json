s/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"20973939faf941b6228b1728c046793724218843","tid":1902022,"uid":234225,"like":0,"dislike":0,"score":0,"quote":{"pid":"7fe81de1cd70ee4ef6671f86490be4fa2a33059c","tid":1902022,"uid":282808,"like":0,"dislike":0,"score":0,"quote":{"pid":"214c6bcc88acada57a6e673a460efb2ed427c217","tid":1902022,"uid":234225,"like":0,"dislike":0,"score":0,"quote":{"pid":"d573732a43ca9b6f5f034268b8ba537a0dcc2a78","tid":1902022,"uid":282808,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-28T06:55:54.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-28T06:57:07.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-28T06:57:55.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-28T06:59:08.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"bf385484f837e2a5e2d62621fc33723f17530794","tid":1902022,"uid":282808,"like":0,"dislike":0,"score":0,"quote":{"pid":"20973939faf941b6228b1728c046793724218843","tid":1902022,"uid":234225,"like":0,"dislike":0,"score":0,"quote":{"pid":"7fe81de1cd70ee4ef6671f86490be4fa2a33059c","tid":1902022,"uid":282808,"like":0,"dislike":0,"score":0,"quote":{"pid":"214c6bcc88acada57a6e673a460efb2ed427c217","tid":1902022,"uid":234225,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-28T06:57:07.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-28T06:57:55.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-28T06:59:08.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-28T06:59:53.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"477ff5f54be76485bb35fef6aa94e62de52e0b75","tid":1902022,"uid":182010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T07:00:43.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"7ec1ecbd1039358d8e9842dfbffe4e32160bbf7e","tid":1902022,"uid":247139,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-28T07:01:27.000Z","msg":"女主 不了<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"a594000ea92767ae325692033c100c7413beadfc","tid":1902022,"uid":234225,"like":0,"dislike":0,"score":0,"quote":{"pid":"bf385484f837e2a5e2d62621fc33723f17530794","tid":1902022,"uid":282808,"like":0,"dislike":0,"score":0,"quote":{"pid":"20973939faf941b6228b1728c046793724218843","tid":1902022,"uid":234225,"like":0,"dislike":0,"score":0,"quote":{"pid":"7fe81de1cd70ee4ef6671f86490be4fa2a33059c","tid":1902022,"uid":282808,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-28T06:57:55.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-28T06:59:08.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-28T06:59:53.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-28T07:02:03.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"0aaba1f0cae953bc3cd567121f8d2c7a6b79cc4b","tid":1902022,"uid":282808,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2020-02-28T07:03:08.000Z","msg":"<strong><ins><span style=\"color: red;\">Chapter 3 私補夜</span></ins></strong><br />\n<br />\n劉sir好盡責，每一次私補佢都有教我好多要點，我地晚晚都會講電話練speaking，佢甚至要我每日寫500字日記，當練文筆。係好大workload，但係我每次都趕得切交，而每一次劉sir都會摸我個頭，讚我乖。<br />\n<br />\n今晚好大雨，簡直雷雨交加。劉sir叫我唔好太趕，小心淋親。不過我無理，我正係知道我好想快D見到佢，好想快D補習。我衝到佢門口，全身濕漉漉。搭正 9:00pm<br />\n<br />\n「哇，Mary，都叫你唔好咁趕啦，快D入來，小心冷親！」<br />\n<br />\n我入到去劉sir即刻沖左杯熱朱古力俾我，仲幫我放左缸熱水俾我沖涼先。我沖左個好舒服既熱水涼，跟住。屌我都無帶多套衫....<br />\n<br />\n「劉sir我無帶衫呀！！！」<br />\n「um...我都無多衫俾你添...你包塊毛巾出來先丫」<br />\n<br />\n好尷尬，我第一次咁樣俾人見到。劉sir好貼心咁開左暖爐，我地如常咁樣補習。只係劉sir面紅紅咁，下面又好似略為突起。好尷尬(＞人＜;)<br />\n<br />\n「Mary...咁你今日點返去呀...不如訓係度一晚？我今晚幫你曬乾套校服」<br />\n<br />\n「都都...可以既..多謝劉sir...」<br />\n<br />\n其實我真係一個A0毒撚來，男人手仔都無掂過，無啦啦要同個男人同床訓真係少少怕醜，雖然我好鍾意佢...<br />\n<br />\n劉sir間屋係開放式，得一張床一張書檯同埋一個開放式廚房，啊仲有洗手間。所以其實所有野一眼睇曬。佢間屋好乾淨，想做女主人了🤣<br />\n<br />\n劉sir去雪櫃開左支啤酒飲，雖然我17歲，但係得我地兩個，應該無人知道既，所以佢都倒左細細杯俾我。<br />\n<br />\n「我習慣每晚臨訓前都飲一支，舒緩壓力。咁樣聽日先有動力對住你班化骨龍XD，你唔飲話我知呀，我飲埋佢。」<br />\n<br />\n「唔怕，只要屋企人唔知，我可以飲既」<br />\n<br />\n「大個女曳曳啦，飲醉酒會好大獲架wo，唔驚斷片咩」<br />\n<br />\n塊面微紅既劉sir突然講嘢唔同左，視線一路望住我心口對隱隱若現既34C<br />\n<br />\n「不過1718歲你哩D女仔學下飲酒差唔多架啦，如果唔係大個出去俾陌生人搞都唔知咩事」<br />\n<br />\n「啊係咩哈哈劉sir，我有少少眼訓啦...你飲埋佢丫」<br />\n<br />\n我開始驚驚地，劉sir從來無試過講嘢咁無分寸。我係鍾意佢，但係我都未ready佢咁快講哩D，我驚佢飲醉對我大膽...<br />\n<br />\n「Mary，其實老師都係一個人，都係有七情六慾，所以你唔好覺得老師係聖人呀，眼訓就上床訓啦～」<br />\n<br />\n我即刻沖去床既一個角落鋪好被。<br />\n正當我以為準備墮入夢鄉時候<br />\n一個重大既身體壓o係我身上。"},{"pid":"26a088cf0b9932cc23bc58dc985ba83adfe6c173","tid":1902022,"uid":282808,"like":3,"dislike":2,"score":1,"citedBy":3,"replyTime":"2020-02-28T07:04:17.000Z","msg":"今日post咁多先<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n以後維持一日1-2篇<br />\n除非多人追故<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fc0af7bd430dd716926cd38f8269eed31c9689cb","tid":1902022,"uid":234225,"like":0,"dislike":1,"score":-1,"quote":{"pid":"26a088cf0b9932cc23bc58dc985ba83adfe6c173","tid":1902022,"uid":282808,"like":3,"dislike":2,"score":1,"citedBy":3,"replyTime":"2020-02-28T07:04:17.000Z","msg":"今日post咁多先<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n以後維持一日1-2篇<br />\n除非多人追故<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-28T07:05:12.000Z","msg":"支持"},{"pid":"96f6b02858dd9fc8405b907c4661f2e0edee75a4","tid":1902022,"uid":170630,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-02-28T07:09:39.000Z","msg":"要中大好啲"},{"pid":"2cdd8cc69f03320c0c7d4352af8b2d25fd553330","tid":1902022,"uid":347734,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T07:16:18.000Z","msg":"lm<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"9c0be3843f9b4a5ad5fb42f798d4db63dd3287fc","tid":1902022,"uid":72046,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T07:37:13.000Z","msg":"推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c8e12333771afb90726c52703ddbab4bc972c165","tid":1902022,"uid":272958,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T07:44:59.000Z","msg":"Lm"},{"pid":"7a224f46c7022ddceb1317b54c7995c34ecf7550","tid":1902022,"uid":57237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T08:08:01.000Z","msg":"正啊搞老師"},{"pid":"62643c042e57d8fa51ae19e1f636e105b2bd44c9","tid":1902022,"uid":81812,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T09:18:23.000Z","msg":"Push"},{"pid":"60365102d3d831051469ce6107c8b59feab913e5","tid":1902022,"uid":282808,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T10:45:55.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"f2150d77b51d3dd763b71656cf54358cfa2a3035","tid":1902022,"uid":137332,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T14:51:24.000Z","msg":"pish<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"ae6f635b7ffbca74eb91a579983d610e062f4686","tid":1902022,"uid":302633,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T17:53:30.000Z","msg":"Subscribed!!<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"df637a5313319540ce8ba3a61cf977d4173637b0","tid":1902022,"uid":136747,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T18:56:59.000Z","msg":"屌你咩戲肉先嚟停<img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/dislike.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/dislike.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n支持樓主 已經星星了<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"debefe5d94b1a8191b63846798a600a11b4763e2","tid":1902022,"uid":347734,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-29T06:52:49.000Z","msg":"更新未呀戲肉啦<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"f51a0092ed7ec57c5284387c5be52f037fe49f77","tid":1902022,"uid":282808,"like":6,"dislike":2,"score":4,"citedBy":0,"replyTime":"2020-02-29T08:49:04.000Z","msg":"<strong><ins><span style=\"color: red;\">Chapter 4 私補通常補上...（重甜）</span></ins></strong><br />\n<br />\n「劉老師！唔好呀」<br />\n「Mary...叫我dickson啦...我依家唔係劉老師，我只係一個普通男仔...」<br />\n<br />\n我好驚...好驚第一次會咁樣不明不白俾一個唔係男朋友既人拎左...突然想退縮，唔想再補習...我會唔會今晚就失身...<br />\n<br />\n「唔好呀，我正係想俾未來男朋友...求下你，放過我得唔得...」<br />\n<br />\n佢突然間坐起身，面對住我，我件毛巾都滑埋落地。但係dickson抓住我隻手...<br />\n<br />\n「Mary Choi蔡佳心小姐，你願唔願意做我女朋友？我其實一路都好鍾意你，頭先忍唔住先用錯方法...好對唔住...但係我真係好愛你...你願唔願意？」<br />\n<br />\nomfg幸福來得太容易，劉老師居然同我表白，從此我就係劉夫人喇XD<br />\n<br />\n「我願意...」<br />\n<br />\n「咁以後要叫我dickson架啦啵！」<br />\n<br />\n<span style=\"font-size: small;\"><span style=\"color: red;\">以下情節重甜</span></span><br />\n<br />\nDickson好溫柔咁樣拖住我隻手<br />\n佢視線慢慢從我對眼，望落去我個胸，再望落我下半身，此刻赤裸既我自然咁夾緊左雙腿。點知原來男人覺得咁樣係引誘...<br />\n<br />\n「你個衰妹咁快想俾我搞啦」<br />\n<br />\nDickson用力咁樣張大左我雙腿，跟住開始色瞇瞇咁笑<br />\n<br />\n「傻妹今晚你係我架啦」<br />\n<br />\n佢㩒住我落床，跟住伸左條脷入我個嘴，佢個嘴唇好暖好軟，好舒服，佢帶住我一路打茄輪，我身體開始有D神奇既感覺。佢個嘴慢慢移左去我耳仔度，慢慢咁吹氣，又奶下我對耳仔。<br />\n<br />\n「嗯...」<br />\n<br />\n我竟然發出左人生第一次既呻吟聲。<br />\nDickson聽到之後好興奮，下面突到隔住條褲都feel到。佢除左自己條褲，開始慢慢磨我對腳。佢對手都偷偷地摸住我個胸，一時捏一時轉圈。突然有個好舒服既感覺湧左上我腦度<br />\n<br />\n「啊...嗯...唔好...用力...」<br />\n<br />\n佢原來奶緊我個胸...佢條脷搞到我好痕，但係個痕既感覺又好舒服...我好鍾意哩個感覺...突然 一切都停左...<br />\n<br />\n「無左啦..？」<br />\n<br />\n只見dickson笑淫淫咁望住我<br />\n<br />\n「估唔到你個小淫妹人仔細細就濕到咁」<br />\n<br />\n我望一望自己下半身，見到全條毛巾都濕漉漉...即刻面紅到唔敢望住佢...<br />\n<br />\n點知佢趴底身，個頭開始靠近我下面<br />\n<br />\n「唔好呀，Dickson，果度污糟...」<br />\n<br />\n「我個傻妹下面最乾淨❤️」<br />\n<br />\n佢開始奶我下面，個感覺根本無法用文字形容，我不停呻吟，不停叫，真係好爽，我亦都feel到開始越來越繃緊...<br />\n<br />\n佢突然停左<br />\n<br />\n此刻我根本無辦法控制自己<br />\n<br />\n「Dickson哥哥，我要呀，求下你快D繼續」<br />\n<br />\nDickson壞笑一聲<br />\n拎左個condom出來<br />\n慢條斯理咁問我<br />\n<br />\n「咁要唔要戴套呀」<br />\n「唔要啦，求下你即刻強姦我」<br />\n「好啦，咁我來架啦」"},{"pid":"62674a04f6f9846e3e739982610f867b32f32718","tid":1902022,"uid":225998,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-29T14:39:24.000Z","msg":"有冇好結局"},{"pid":"0f03ba3652daa06159cf4fdab3cff113dea9ba54","tid":1902022,"uid":263344,"like":0,"dislike":0,"score":0,"quote":{"pid":"26a088cf0b9932cc23bc58dc985ba83adfe6c173","tid":1902022,"uid":282808,"like":3,"dislike":2,"score":1,"citedBy":3,"replyTime":"2020-02-28T07:04:17.000Z","msg":"今日post咁多先<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n以後維持一日1-2篇<br />\n除非多人追故<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-29T15:10:59.000Z","msg":"支持"},{"pid":"957d8e07e7e9fa8de705826fbb6ee7f68f72b467","tid":1902022,"uid":182010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-29T16:17:55.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"3f59758c1eb0f65f3a189d12c8dc43b157bf14a8","tid":1902022,"uid":179674,"like":0,"dislike":0,"score":0,"quote":{"pid":"26a088cf0b9932cc23bc58dc985ba83adfe6c173","tid":1902022,"uid":282808,"like":3,"dislike":2,"score":1,"citedBy":3,"replyTime":"2020-02-28T07:04:17.000Z","msg":"今日post咁多先<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n以後維持一日1-2篇<br />\n除非多人追故<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-29T18:24:48.000Z","msg":"真係1日一兩篇 好過好多人嫁喇<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"9a61717f2395928ee709da400ff6c79ed0046c8c","tid":1902022,"uid":237227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-01T03:14:29.000Z","msg":"甜中間停<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />有無搞錯<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />"},{"pid":"ef9166acae286f4692bfecf7245d6c1d75e46a19","tid":1902022,"uid":282808,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-01T03:57:22.000Z","msg":"<strong><ins><span style=\"color: red;\">Chapter 5 中出之後係咩<br />\n</span></ins></strong><br />\n佢長驅直入，一嘢隊左入來...<br />\n<br />\n「痛...」<br />\n「無事架...好快無事...」<br />\n<br />\n一下..兩下..三下..每一下都好似俾人打到爆缸...好痛好痛...但係我依家係Dickson既女人，所以我一定要忍...<br />\n<br />\n慢慢地，個節奏開始緩和番，我亦由痛感變成舒服爽快...<br />\n<br />\n「嗯...嗯...嗯...」<br />\n<br />\n床上染左一大片血花，血花上面有一對男女不知廉恥咁抽插緊...<br />\n<br />\n「我要射啦」<br />\n「唔好射裡面...」<br />\n「sorry&gt;&lt;趕唔切」<br />\n<br />\n翻雲覆雨後，我地好似咩都無發生咁，就咁攬住訓著左。<br />\n<br />\n我發左個惡夢..夢裡面所有人都話我好污糟，話我係雞係公廁...我俾人打俾人鬧...我都覺得自己好cheap...<br />\n<br />\n夢醒，Dickson已經梳洗完畢準備返學。佢臨走前仲囑咐我<br />\n<br />\n「Mary，由於我係老師，你係學生，我我地只可以地下情咋...sorry呀...你可能會話我自私...但係我真係未ready去公開所有野，我唔知D家長，老師，朋友會點睇我地...你諗吓...如果俾人見到一個38歲既男人攬住個17歲學生妹，佢哋會點諗...佢哋會覺得我係色魔，會覺得我呃你...我真係會好大壓力架...」<br />\n<br />\n「Dickson，唔緊要，我尊重你意願...我一定會等你架...我會愛你一生一世！」<br />\n<br />\n講完Dickson就返左學<br />\n我都準備就緒，可以返學<br />\n<br />\n過左半個月，Dickson都無咩點搵我...我話補習佢又話忙，我話掛住佢，佢最多send個錄音俾我...我好掛住佢呀...<br />\n<br />\n不過我都明白，o係一個呀叔眼中，根本無咩可能會當學生妹係情侶，係可以一生人一齊既情侶...尤其是係老師...佢玩厭我，自然可以玩第二個學生妹...<br />\n<br />\n可能我只係咁多條拖羅裡面佢咁橋揀中果條掛...<br />\n<br />\n一個月無見啦...我終於忍唔住偷偷地去佢屋企樓下，我親手煮左咖喱飯，準備俾個驚喜佢...<br />\n<br />\n上到去，我見到佢o係𨋢門口同個身高體重同我差唔多既女仔講byebye。<br />\n<br />\n我震驚<br />\n<br />\n「Dickson！」<br />\n<br />\n佢即刻行埋來按住我把口<br />\n跟住拉左我入屋...<br />\n<br />\n「你同我講呀，果個女仔係邊個，你做咩同佢講byebye！」<br />\n<br />\n「傻妹你諗多左啦，果個我鄰居個女來，佢住對面果座，知道我做老師咪叫我幫佢個女補習」<br />\n<br />\n好似好合理既解釋...<br />\n<br />\n「你係咪正係愛我一個咋？」<br />\n「愛啦愛啦，一場來到不如訓陣？」<br />\n<br />\n於是我地全晚正係上床，我盒咖喱，佢望都無望。<br />\n<br />\n「Mary呀，其實我真係老師來架，多人地方唔好亂叫我知唔知道呀，俾人發現好危險架..」<br />\n「sorry...」<br />\n「夜啦，你返去啦，考試加油」<br />\n我一落樓，就見到另一個同學開心咁跑去佢果棟樓...係咪我諗太多...<br />\n<br />\n可能佢已經搵左第二條拖羅喇..."},{"pid":"32f0ed47e1f9ca2bd2f902e1ccb56503bda84145","tid":1902022,"uid":182010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-01T04:06:47.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"ff09468dae5a933d933be50e2970865fd58aa5c7","tid":1902022,"uid":162892,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-01T05:39:36.000Z","msg":"有啲似鮮浪潮2019 &lt;林同學退學了&gt;"},{"pid":"3df9a2a1b6a2b36601349957a5bd8c08d36124f6","tid":1902022,"uid":282808,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff09468dae5a933d933be50e2970865fd58aa5c7","tid":1902022,"uid":162892,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-01T05:39:36.000Z","msg":"有啲似鮮浪潮2019 &lt;林同學退學了&gt;"},"citedBy":1,"replyTime":"2020-03-01T08:47:45.000Z","msg":"即刻去睇下先<br />\n咩黎<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"bc2bca0975ac11c836e28e496bca73c0b4697470","tid":1902022,"uid":162892,"like":0,"dislike":0,"score":0,"quote":{"pid":"3df9a2a1b6a2b36601349957a5bd8c08d36124f6","tid":1902022,"uid":282808,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff09468dae5a933d933be50e2970865fd58aa5c7","tid":1902022,"uid":162892,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-01T05:39:36.000Z","msg":"有啲似鮮浪潮2019 &lt;林同學退學了&gt;"},"citedBy":1,"replyTime":"2020-03-01T08:47:45.000Z","msg":"即刻去睇下先<br />\n咩黎<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-02T04:54:26.000Z","msg":"師生戀 兩(or more)女爭一男"},{"pid":"b30a9e6925e7afa2fb11c3819e9c8904eab144ef","tid":1902022,"uid":53973,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-02T05:38:00.000Z","msg":"Mary好慘<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n但睇嚟係復仇故嚟"},{"pid":"94a60b3c75e470c7d85a9feb30d9815a3b3c3c44","tid":1902022,"uid":282808,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-03-02T07:02:46.000Z","msg":"<strong><ins><span style=\"color: red;\">Chapter 6 著涼亦錯在我幼稚</span></ins></strong><br />\n<br />\nDickson無再搵過我，我亦都無曬心機讀書...人地溫書，我就去唱K。人地同朋友行山去遊樂場，我就去shisha去飲酒...慢慢我無曬朋友，我變左邊緣人，從科科最少4分變成全炒...我知道咁樣我根本無U讀...但係我完全無精神去讀...人前要帶住開心既面具，要笑住講自己好開心...其實內心好痛苦...考完試，到放榜果日，我都無任何對於成績既不安，因為我知道自己一定炒撚左。<br />\n<br />\n放榜日。Best 5 19分<br />\n中文5**，英文2，數學3分，中國文學5分，通識都係2。其他全U。<br />\n我無驚訝，我知道中文唔會差，畢竟Dickson確實有栽培過我，反而身邊既belle，成績不嬲差開，今次居然28分，中文全部5**，仲大聲話要去讀HKU中文系...<br />\n<br />\n我唯有去HKU SPACE讀中文...<br />\n過左半年既沈澱...我都慢慢從Dickson既傷爬出來...可能當初既我，只不過係一個小妹妹發花癡，先會咁死心塌地...我開始讀書，我依然想入HKU Chinese，我想做個作家，將自己經歷寫成故事...我每次中文都拎到A...我距離目標越來越近...我個3.8gpa令一切都變得有可能...<br />\n<br />\n我仲識左好多朋友，有串串地既Janice，成熟穩重既Ben，有抱負既Robert，等等... 我地o係asso讀得好開心，大家都覺得可以上番U，包括我在內。<br />\n<br />\n我完全無諗過英文會炒<br />\n而炒既原因係因為我唔肯交一篇final essay<br />\n無果篇essay老師唔會俾final分我<br />\n<br />\nessay題目係，誰人青春沒有受過傷，我寫左好耐，寫左好多字，寫到喊，但係最後一步，我就係唔肯交出去，我覺得自己太噁心...咁污糟既人，唔配有人生。<br />\n<br />\n最後我英文拎45分<br />\ngpa得番3.1"},{"pid":"0e53a089cd62fc46e5d17d4dac6c01f6ef02a1a8","tid":1902022,"uid":182010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-02T07:09:52.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"86e150b1ac5fd9dc342c93bbbf865fe1dfb3b2aa","tid":1902022,"uid":170630,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-02T08:58:51.000Z","msg":"Hku中文系都唔勁"},{"pid":"d72e46908c9290b7524144a3ca92344344c1db27","tid":1902022,"uid":300456,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-03-02T10:43:42.000Z","msg":"甜係甜⋯ 但sorry有d假<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />加油"},{"pid":"0f4671b694277d766bfdfcb086a82dd4fa498db0","tid":1902022,"uid":282808,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-03-03T12:14:56.000Z","msg":"<strong><ins><span style=\"color: red;\">Chapter 7 污染一張染黑左既紙</span></ins></strong><br />\n<br />\n3.1...我望住個cgpa，情不自禁就喊左出來...3.1我點報kongu，3.1我可以讀咩... 我唯有報lingu中文，博下有無機會...但係其實好唔甘心...如果唔係篇文，我根本唔會搞成咁...我估...我可以求下sir俾我交多次既...<br />\n<br />\n「Mr Chung, I&rsquo;m very sorry... I didn&rsquo;t mean to miss the final essay... I had some personal reasons and I am willing to make up for my missing work... can you please let me redo my work so that I can pass? I&rsquo;m very sorryy... I&rsquo;m willing to do anything to cover it...」<br />\n<br />\n「Mary... You know it&rsquo;s way past the deadline... I&rsquo;m very sorry but you would have to work harder next semester...」<br />\n<br />\n屌<br />\n我頹左兩日先肯應約，去同Janice Ben食飯。<br />\n<br />\n「激死我啦，個死人英文鍾唔肯俾我改文交，我求曬佢都唔肯...我想入kongu呀😭」<br />\n<br />\n我伏係飯檯度喊，Ben一路摸我個頭一路講笑，句笑話就改變左我一生<br />\n<br />\n「再唔掂你咪上左個老師lor，用你既姿色溝佢姣佢，等佢改分，反正男人全部都係鹹濕，有食唔食罪大惡極呀～係我都上XD」<br />\n<br />\n「Ben仔你唔好冼人啦，mary乖女黎，佢講笑咋，廢話😂」<br />\n<br />\nJanice笑住打左Ben一下，跟住佢哋兩個就當無事發生咁繼續嬉鬧，反而我好認真咁諗緊Ben講既一切...<br />\n<br />\n一張已染黑既白紙，再加多D染料都唔會有人理<br />\n...<br />\n<br />\n沖個靚涼，噴左兩三下費洛蒙香水，著條黑絲，再加條學生妹短裙仔，露膊短衫仔，化個姣妝，我覺得自己根本就成個黃心穎咁。我拎埋部laptop，準備好行入去Mr Chung辦公室...<br />\n<br />\n屌點知一入去見到Alice，我個英文同學。佢地練緊英文speaking...<br />\n<br />\n「Mr Chung... am I interrupting you? I&rsquo;m sorry I just wanted to ask you a few questions on my work」<br />\n<br />\n「ohh sure, Alice, it&rsquo;s the end of our practice session anyways, see you next week!」<br />\n<br />\nAlice望左我一眼，就施施然咁行出去。我亦都開始我既計畫<br />\n<br />\n「okay, I am planning to write a story for my semester 2 essay, and I would like to write about relationships between teacher and students... I just wanted directions for the essay haha」<br />\n<br />\n「ohh.. I guess you can do....」<br />\n<br />\n過程中我時而微笑，偶然撥下帶有香水味既秀髮...我估好快鍾sir就會忍唔住..<br />\n<br />\n「oops I&rsquo;m sorry..」<br />\n跌筆<br />\n一切按照計畫<br />\n趴落地，㩒住佢大比借力<br />\n「found it！」<br />\n抓住佢大比內側上返來<br />\n「sorry sir🤣」<br />\n<br />\n他已赤紅"},{"pid":"85fb5731be5105ed7af3638cd65ac710a43cd2fa","tid":1902022,"uid":282808,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-03-04T04:59:36.000Z","msg":"<ins><strong><span style=\"color: red;\">Chapter 8 我做咩都得<br />\n</span></strong></ins><br />\n「Mr Chung... it&rsquo;s quite hot here, I&rsquo;m going to take off my jacket haha」<br />\n<br />\n「okk...」<br />\n<br />\n我除左件外套，露出左件戰衣。露膊衫將我引以為傲既身材展露無遺，加上一件迷你裙，我夠膽講係男人都會硬，更何況o係費洛蒙香水幫助下，我肯定一分鐘佢就忍唔到！<br />\n<br />\n「Mr Chung... I&rsquo;m getting dizzy..」<br />\n<br />\n我一嘢攤左落鍾sir大比，個頭有意無意咁磨擦佢早已甦醒既巨龍...鍾sir開始面紅，隻手情不自禁咁撫摸我背脊...<br />\n<br />\n「Mary... Mary... Oh you&rsquo;re so hot...」<br />\n<br />\n我知道佢已經忍唔住，就想試探下<br />\n<br />\n「Can you give me an A for English?」<br />\n<br />\n「no... you can&rsquo;t bribe me...」<br />\n<br />\n「But I can give you what you want <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />」<br />\n<br />\n我大膽將隻手放落佢褲檔...慢慢捏...<br />\n<br />\n「I can give you excitement...」<br />\n<br />\n「stop...」<br />\n<br />\n「you will love it...」<br />\n<br />\n我一路勾引鍾sir，佢都開始失去意志...開始慢慢將隻手放上我個胸...捏下捏下..<br />\n<br />\n「lets do it somewhere else」<br />\n<br />\n佢帶左我上佢屋企，上到去之後，頭先所有既忍耐通通無曬，取而代之既係猴擒，暴力...<br />\n<br />\n「唔好以為好好玩，做雞就做雞啦，你都係想合格姐，好簡單，俾我玩夠，自然俾番個分你，不過你咩都要聽我話。」<br />\n<br />\n鍾sir突然用廣東話好兇狠咁警告我<br />\n<br />\n「無問題...你比我合格，我做咩都得..」<br />\n<br />\n「除曬衫，跪底，張大口」<br />\n<br />\n屌原來鍾sir好哩味，有一刻懷疑緊係咪上錯賊船-.-<br />\n<br />\n「要一滴不漏咁吞曬佢，如果唔係你幫我奶番乾淨個地板」<br />\n<br />\n與此同時，Ben笑意淫淫凝視Mary ig<br />\n...<br />\n紙巾散滿一地"}]}