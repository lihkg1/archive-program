1dad4224b5fdb67a5d288a53f76.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F01%2F161532_3ca6e1dad4224b5fdb67a5d288a53f76.png&h=b46cbfa4&s={SIZE}\" /><br />\n<br />\n4. 500系 (1997-2010) <img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/10/01/161613_95bb92453a58e71410ca69eadb84c109.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F01%2F161613_95bb92453a58e71410ca69eadb84c109.png&h=88556c00&s={SIZE}\" /><br />\n<br />\n5. 700系 (1999-今)<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/10/01/161653_e28b6bdca7986a442e11e606635c5423.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F01%2F161653_e28b6bdca7986a442e11e606635c5423.png&h=b8c20f86&s={SIZE}\" /><br />\n<br />\n6. N700系 (2007-今)<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/10/01/161812_35e931da36b96be9f76d94501ce9bce5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F01%2F161812_35e931da36b96be9f76d94501ce9bce5.png&h=99424cb3&s={SIZE}\" /><br />\n<br />\n7. N700A系 (2013-今)<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/10/01/162033_5aa4759367a5359cf39619755de5b422.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F01%2F162033_5aa4759367a5359cf39619755de5b422.png&h=14121b16&s={SIZE}\" /><br />\n<br />\n未來車種：N700S (目標2020年度開始營運)<br />\n <img src=\"https://img.eservice-hk.net/upload/2018/10/01/162252_e84b386c883d4b3a9f229a6cd4a67e01.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F01%2F162252_e84b386c883d4b3a9f229a6cd4a67e01.png&h=521467cb&s={SIZE}\" /><br />\n<br />\nN700A vs N700S<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/10/