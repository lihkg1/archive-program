/haha.gif\" class=\"hkgmoji\" />"},{"pid":"1141f9bc038abccb259964c19e7ab5fe9b4215f2","tid":1149394,"uid":2772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-13T04:05:51.000Z","msg":"咩事咁撚靜焗 推推先"},{"pid":"b065d8812a3cd8295e8c5193c1eb52561f97897b","tid":1149394,"uid":33668,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-05-13T06:48:55.000Z","msg":"屌又柒咗 推推先"},{"pid":"9b657ad7cd50d0032c8f5862612cddcdc04c3084","tid":1149394,"uid":165336,"like":0,"dislike":0,"score":0,"quote":{"pid":"7649d12c0cb8730fbe77e3c74582c13e1a0882c7","tid":1149394,"uid":156144,"like":2,"dislike":8,"score":-6,"citedBy":1,"replyTime":"2019-05-11T06:31:10.000Z","msg":"好過用大陸啲咩輸出啦"},"citedBy":1,"replyTime":"2019-05-13T10:07:05.000Z","msg":"輸出唔係支那野黎<br />\n以前d olg多數台灣公司代理開埋港澳服<br />\n好多遊戲術語係台灣出現之前香港根本冇呢d野<br />\n所以好多都娑左台灣,亦都會出現比較香港feel既字<br />\n例如輸出=放血,以前d人玩mh就係會話幫條龍放血<br />\n放血呢個字其實台灣都有用,不過比起輸出更加似廣東話<br />\n但其實輸出係好用d,例如輸出高既職業就係攻擊力最高<br />\n唔通叫佢做放血職業咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />放自己血呀?"},{"pid":"9a271729f00fd08ef1497a3fbc3a7991a37a2d33","tid":1149394,"uid":156144,"like":0,"dislike":0,"score":0,"quote":{"pid":"9b657ad7cd50d0032c8f5862612cddcdc04c3084","tid":1149394,"uid":165336,"like":0,"dislike":0,"score":0,"quote":{"pid":"7649d12c0cb8730fbe77e3c74582c13e1a0882c7","tid":1149394,"uid":156144,"like":2,"dislike":8,"score":-6,"citedBy":1,"replyTime":"2019-05-11T06:31:10.000Z","msg":"好過用大陸啲咩輸出啦"},"citedBy":1,"replyTime":"2019-05-13T10:07:05.000Z","msg":"輸出唔係支那野黎<br />\n以前d olg多數台灣公司代理開埋港澳服<br />\n好多遊戲術語係台灣出現之前香港根本冇呢d野<br />\n所以好多都娑左台灣,亦都會出現比較香港feel既字<br />\n例如輸出=放血,以前d人玩mh就係會話幫條龍放血<br />\n放血呢個字其實台灣都有用,不過比起輸出更加似廣東話<br />\n但其實輸出係好用d,例如輸出高既職業就係攻擊力最高<br />\n唔通叫佢做放血職業咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />放自己血呀?"},"citedBy":1,"replyTime":"2019-05-13T10:53:53.000Z","msg":"我用開打手 mh直接稱呼職業 etc太刀 槌"},{"pid":"6839c845c9d40f9352ec38358b4b15be0c90ae66","tid":1149394,"uid":165336,"like":0,"dislike":0,"score":0,"quote":{"pid":"9a27172