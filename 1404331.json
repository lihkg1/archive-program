og/itdog2.gif\" class=\"hkgmoji\" />"},{"pid":"4073f9f418165c68911946ee92e69c68d159cc97","tid":1404331,"uid":5995,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-04T04:30:55.000Z","msg":"大家記住要去附近大商場行街<br />\n例如沙田就去新城市<br />\n搞到人地鋪頭落閘 被逼罷工<br />\n多d人出黎集會<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"e30e8d7fd6de8c1f8ad5d7d59ae254a59668178a","tid":1404331,"uid":265935,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T04:57:19.000Z","msg":"推"},{"pid":"e19b45f5e9b06c5dd886380d17cb7a02eed2f6b8","tid":1404331,"uid":71447,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T05:02:58.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1956385fb8e5c620070bc2dc48a63f4786dbb311","tid":1404331,"uid":52621,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T05:05:05.000Z","msg":"推<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"0c1c0b41460544c73b8aa90e4dcda8dce8a0fd38","tid":1404331,"uid":12558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T22:13:53.000Z","msg":"<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" />"},{"pid":"1847052e959a8c600173b248057fd9c11150b59f","tid":1404331,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T22:52:03.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"71de9a001e402d2f6f7ac9b9e73075830cec5618","tid":1404331,"uid":191656,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T23:08:07.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}