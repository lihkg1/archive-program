{"tid":1560452,"cid":12,"subCid":0,"title":"超級突發！啱啱孫中山報夢比我","createTime":"2019-09-11T07:55:27.000Z","updateTime":"2019-09-11T16:20:19.000Z","uid":248789,"like":6,"dislike":1,"uniUserReply":6,"replies":[{"pid":"f46534c94fcb8c545104033e7989dfc0069388dd","tid":1560452,"uid":248789,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T07:55:27.000Z","msg":"<img src=\"https://na.cx/i/PYex2bc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPYex2bc.jpg&h=484db60d&s={SIZE}\" /><br />\n<br />\n<br />\n<span style=\"font-size: large;\">平時冇咩事過比人報夢</span><br />\n<br />\n佢啱啱同我講 <br />\n革命尚未成功，同志們仍須努力<br />\n<br />\n<span style=\"font-size: x-large;\">五大訴求，缺一不可</span><br />\n<br />\n佢不斷同我解釋，佢當年點樣輸比共產黨<br />\n<br />\n佢想提醒我地，五大訴求一日未落實，<br />\n革命都尚未成功&hellip;&hellip;&hellip;&hellip;&hellip;&hellip;<br />\n<br />\n唔好畀黨嘅花言巧語呃到<br />\n<br />\n最後<br />\n<br />\n光復香港，時代革命"},{"pid":"efe7391ac111ef488727a76dfe08237073254489","tid":1560452,"uid":248789,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-11T07:56:19.000Z","msg":"大家點睇"},{"pid":"9becc609b1c3973fe7b80c941069cf9e51f48dae","tid":1560452,"uid":177089,"like":0,"dislike":0,"score":0,"quote":{"pid":"efe7391ac111ef488727a76dfe08237073254489","tid":1560452,"uid":248789,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-11T07:56:19.000Z","msg":"大家點睇"},"citedBy":1,"replyTime":"2019-09-11T07:56:48.000Z","msg":"用狗眼睇"},{"pid":"4dda1ffb0e5eb34d3bd7ff0b6fc04973a20de269","tid":1560452,"uid":248789,"like":0,"dislike":0,"score":0,"quote":{"pid":"9becc609b1c3973fe7b80c941069cf9e51f48dae","tid":1560452,"uid":177089,"like":0,"dislike":0,"score":0,"quote":{"pid":"efe7391ac111ef488727a76dfe08237073254489","tid":1560452,"uid":248789,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-11T07:56:19.000Z","msg":"大家點睇"},"citedBy":1,"replyTime":"2019-09-11T07:56:48.000Z","msg":"用狗眼睇"},"citedBy":0,"replyTime":"2019-09-11T07:57:15.000Z","msg":"Ching&hellip;&hellip;&hellip;&hel