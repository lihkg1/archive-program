>"},{"pid":"db8418947e699fef06ea31cc4f52f00cdd761d61","tid":2180661,"uid":147721,"like":15,"dislike":2,"score":13,"quote":{"pid":"7ae62f9e66fc468640b322659578ea93eb091242","tid":2180661,"uid":113183,"like":91,"dislike":1,"score":90,"citedBy":3,"replyTime":"2020-08-30T04:40:32.000Z","msg":"成班人頭腦仲未清醒<br />\n仲以為係地方政府嘅問題<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n係黨啊 黨啊 黨啊懵撚<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-30T04:47:16.000Z","msg":"唔係頭腦唔清醒 係表現出黎唔可以清醒<br />\n你以為人地真係矇撚咩 個女癱左 仲點會對政府有幻想呀"},{"pid":"8254cce5ebaca443159253e2624cb942668f5f29","tid":2180661,"uid":71335,"like":6,"dislike":1,"score":5,"quote":{"pid":"9a7e8472226cda52c7eb7e492ea57ff69a0c498e","tid":2180661,"uid":118082,"like":41,"dislike":1,"score":40,"quote":{"pid":"face5e0e5176f92ff84dc540aa995b2ea7ecbc33","tid":2180661,"uid":246375,"like":239,"dislike":8,"score":231,"citedBy":5,"replyTime":"2020-08-30T04:30:19.000Z","msg":"抵啦<br />\n不過預感遲d好多支國人黎香港打<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-08-30T04:39:01.000Z","msg":"黎香港都係打中國疫苗。。<img src=\"/assets/faces/lm2/eating.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-30T04:48:25.000Z","msg":"岩呀 而家檢驗用華大 倒數第4準確度"},{"pid":"b8970c1381a50dd5a24fb64e673b11ec4f38ba5b","tid":2180661,"uid":71000,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2020-08-30T04:49:27.000Z","msg":"條撚樣犯咗國安法 拉得"},{"pid":"d633daa2851252c1bdd32734ef3d7cdac9ebe939","tid":2180661,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-30T04:50:49.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"235da8d45e4b57179dc0b738bcaf2e56b825acc9","tid":2180661,"uid":173326,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-08-30T04:52:05.000Z","msg":"奶粉公司心諗：替死鬼<img src=\"/assets/faces/lm2/369.gif\" class=\"hkgmoji\" />"},{"pid":"