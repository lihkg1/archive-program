A%2F%2Fna.cx%2Fi%2FmA48cut.jpg&h=23fa0225&s={SIZE}\" /><img src=\"https://na.cx/i/PuXd72O.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPuXd72O.jpg&h=7541d8ce&s={SIZE}\" /><img src=\"https://na.cx/i/EecNs2P.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEecNs2P.jpg&h=1015ed11&s={SIZE}\" /><img src=\"https://na.cx/i/Kn6Kvga.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKn6Kvga.jpg&h=7e431af2&s={SIZE}\" /><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\">2.尖沙嘴大遊行</span><br />\n平安夜天氣寒冷，為咗要取暖，大家可以出去尖沙咀圍爐，大家儘量出<img src=\"https://na.cx/i/TAjss4f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTAjss4f.jpg&h=d6800e92&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: xx-large;\">副本</span><br />\n當日黨鐵有延長到凌晨嘅服務，大家記得要跳閘，捐閘，踢閘，跳欄，用老人卡，組隊跳閘。<br />\n1個人跳閘自己好危險，100萬人跳閘黨鐵就好危險<br />\n<br />\n<br />\n無論你平安夜果日有咩事，夜晚都要出嚟，一係和你shop，一係尖沙咀，點都要出一個。咩嘢和理非怕危險，要點樣點樣，唔想中計等等，全部都唔係籍口。出嚟啊香港人，出去啊屌你老母，<br />\n出嚟呀出嚟呀出嚟呀"},"citedBy":0,"replyTime":"2019-12-18T07:38:18.000Z","msg":"推啊！<br />\n想訓定stand with HK"},{"pid":"698e4e8f0268246ba351ff36a02b3a7cfe415846","tid":1786740,"uid":67118,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-18T07:39:34.000Z","msg":"推推推"},{"pid":"b930237ee9206d2d313738328f2b6a8a202d19d3","tid":1786740,"uid":298386,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-18T07:40:25.000Z","msg":"[求置頂][推行動] 19/12 社福界搞人權法請願遊行(下午) + 集會(晚上)<br />\n<a href=\"https://lih.kg/1787706\" data-auto-link target=\"_blank\">https://lih.kg/1787706</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n借位宣傳 聽日有行動<br />\n要推到熱門<img src=\"/assets/faces/pigxm/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/knife.gif\" class=\"hkgmoji\" /><br />\n要人啊<img src=\"/assets/faces/pigxm/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/argue.gif\" class=\"h