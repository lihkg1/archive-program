%2F&d=CSzjam5d59%2B0TSQi2Kgm6q3e3GGuF%2FCnRpDBLK0zENU%3D&h=d6b191ab\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20191218%2F60390712%2F&h=1d469c0d\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/realtime/article/20191218/60390712/</a><br />\n<img src=\"/assets/faces/pigxm/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-02T01:21:01.000Z","msg":"總work ?"},{"pid":"8176ba8ad56af785d17bf937228025482e7379b9","tid":1788001,"uid":54959,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T01:26:11.000Z","msg":"<img src=\"/assets/faces/pigxm/cook.gif\" class=\"hkgmoji\" />"},{"pid":"ccb9086f018a853f00398fbc0cbcd4f792cb83f0","tid":1788001,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T01:48:25.000Z","msg":"<img src=\"/assets/faces/xm/angel.gif\" class=\"hkgmoji\" />"},{"pid":"f1a99dfdb43eedb614aac6ba9c9045603f763a69","tid":1788001,"uid":111720,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T01:52:28.000Z","msg":"<img src=\"/assets/faces/xm/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/smile.gif\" class=\"hkgmoji\" />"},{"pid":"57eec8b26eff92d2bd297f8635ed3e5c24ab1679","tid":1788001,"uid":44358,"like":3,"dislike":0,"score":3,"quote":{"pid":"df6296f1d2fb375802fc7c343517234a8e9af14f","tid":1788001,"uid":392,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-02T00:54:27.000Z","msg":"學資處班畜牲已經改左每日最多交3次<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-02T02:03:47.000Z","msg":"改用 E-Banking, 信用卡交費。<br />\n<br />\n重點要一蚊一ＴＲＡＮＳＡＣＴＩＯＮ。"},{"pid":"16636be730ed686785de1dd42576c1607f222f87","tid":1788001,"uid":225192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T02:43:12.000Z","msg":"<img src=\"/assets/faces/lm2xm/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/