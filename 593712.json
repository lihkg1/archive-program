e":0,"score":0,"quote":{"pid":"8c30d42d4a6cdcdbfcd1c5393f8740d2a5c8fe33","tid":593712,"uid":29606,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-03-15T10:34:29.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-03-15T14:11:11.000Z","msg":"<a href=\"https://medium.com/@bluepnume/learn-about-promises-before-you-start-using-async-await-eb148164a9c8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmedium.com%2F%40bluepnume%2Flearn-about-promises-before-you-start-using-async-await-eb148164a9c8&d=TJ3MZuC4%2BvlQOXGaWtZ5AfiMucz1dB5Ms3PJ3VCnrF8%3D&h=82d8993e\" data-auto-link target=\"_blank\">https://medium.com/@bluepnume/learn-about-promises-before-you-start-using-async-await-eb148164a9c8</a>"},{"pid":"ef9ccac391fd1da8804407cfb759e48e53d22120","tid":593712,"uid":23094,"like":0,"dislike":0,"score":0,"quote":{"pid":"39b1609d31f4bac6d42d3e6984cc80753e54f246","tid":593712,"uid":70417,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c30d42d4a6cdcdbfcd1c5393f8740d2a5c8fe33","tid":593712,"uid":29606,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-03-15T10:34:29.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-03-15T10:35:24.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-03-15T14:28:09.000Z","msg":"function func() {<br />\n  doSomethingSync();<br />\n}<br />\n<br />\nasync function asyncFunc() {<br />\n  doSomethingSync();<br />\n}<br />\n<br />\n我諗佢嘅意思係asyncFunc都做到func嘅嘢<br />\n但係有冇嘢係func做到而asyncFunc唔得？"},{"pid":"dd6b2f94b3fa39a6c36dab38f89269bffbddce61","tid":593712,"uid":125976,"like":0,"dislike":1,"score":-1,"quote":{"pid":"ef9ccac391fd1da8804407cfb759e48e53d22120","tid":593712,"uid":23094,"like":0,"dislike":0,"score":0,"quote":{"pid":"39b1609d31f4bac6d42d3e6984cc80753e54f246","tid":593712,"uid":70417,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c30d42d4a6cdcdbfcd1c5393f8740d2a5c8fe33","tid":593712,"uid":29606,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-03-15T10:34:29.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-03-15T10:35:24.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-03-15T14:28:09.000Z","msg":"function func() {<br />\n  doSomethingSync();<br />\n}<br />\n<br />\nasync function asyncFunc() {<br />\n  doSomethingSync();<br />\n}<br />\n<br />\n我諗佢嘅意思係asyncFunc都做到func嘅嘢<br />\n但係有冇嘢係func做到而asyncFunc唔得？"},"citedBy":0,"replyTime":"2018-03-15T15:16:22.000Z","msg":"JS 最原始係 callback function：<br />\n<br />\n如果係 sync task，我估你唔會咁寫：<br />\nfunction concat(a, b, callback) {<br />\n　callback(String(a) + String(b));<br />\n}<br />\n<br />\nconcat(&quot;中出&quot;, &quot;肥絲大隻&quot;, function (result){<br />\n　alert(result);<br />\n})<br />\n<br />\n因為咁太麻煩。<br />\n<br />\n去到 ES5 又唔知點解多咗嚿 Promise 嘅東東，話可說防止 callback hell 喎：<br />\n<br />\nvar concat = function (a, b){<br />\n　return new Promise(function (resolve, reject) {<br />\n　　if(typeof a !== &quot;string&quot; || typeof a !== &quot;string&quot;){<br />\n　　　reject(&quot;fuck&quot;);<br />\n　　}<br />\n　　resolve(a+b);<br />\n　});<br />\n};<br />\n<br />\nconcat(&quot;中出&quot;, &quot;肥絲大隻&quot;)<br />\n　　.then(alert)<br />\n　　.catch(console.log);<br />\n<br />\n<br />\n之後又多咗個 generator function，直到最後又加咗個 aysnc await，其實全部都係 Promise 嘅進化<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"2f49b332d3fe88496291f984fa99005918aebaac","tid":593712,"uid":35211,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-15T16:29:25.000Z","msg":"我個人理解係 async func always return a  new Promise<br />\n係async func 裡面個 return就係resolve, throw就係reject.<br />\n<br />\ntry below in your browser console:<br />\n(async () =&gt; 'resolved')().then(console.log).catch(console.error);<br />\n(async () =&gt; {throw 'rejected'})().then(console.log).catch(console.error);"},{"pid":"a6643190d57ea6369b65b0bf68f133fdbab85915","tid":593712,"uid":11598,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-03-15T16:59:55.000Z","msg":"我屌你 做咩變咗討論 async await 點用<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /> <br />\n我想知點讀 <img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},{"pid":"fda1f7c55b1a39ced9232f68803eaba26de9d82c","tid":593712,"uid":108937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-15T17:03:09.000Z","msg":"a 星<br />\n呀wait"},{"pid":"fd755095c331853af12bd92e9da1b44dfa9a5546","tid":593712,"uid":108937,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c30d42d4a6cdcdbfcd1c5393f8740d2a5c8fe33","tid":593712,"uid":29606,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-03-15T10:34:29.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-03-15T17:03:37.000Z","msg":"async function 一定會 return Promise"},{"pid":"55afe9e066e209ecc47245b511269ac12b4bb0e1","tid":593712,"uid":29606,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-15T17:40:07.000Z","msg":"此回覆已被刪除"},{"pid":"bbb492dfb169cf2a2805b3e092f8aa4445d36190","tid":593712,"uid":23094,"like":0,"dislike":0,"score":0,"quote":{"pid":"55afe9e066e209ecc47245b511269ac12b4bb0e1","tid":593712,"uid":29606,"like":0,"dislike":0,"score":0,"quote":{"pid":"ef9ccac391fd1da8804407cfb759e48e53d22120","tid":593712,"uid":23094,"like":0,"dislike":0,"score":0,"quote":{"pid":"39b1609d31f4bac6d42d3e6984cc80753e54f246","tid":593712,"uid":70417,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-15T10:35:24.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-03-15T14:28:09.000Z","msg":"function func() {<br />\n  doSomethingSync();<br />\n}<br />\n<br />\nasync function asyncFunc() {<br />\n  doSomethingSync();<br />\n}<br />\n<br />\n我諗佢嘅意思係asyncFunc都做到func嘅嘢<br />\n但係有冇嘢係func做到而asyncFunc唔得？"},"citedBy":1,"replyTime":"2018-03-15T17:40:07.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-03-15T17:44:52.000Z","msg":"樓上答咗你<br />\n除非你啲Functions唔需要Return嘢<br />\n如果唔係，加async落去就變咗會Resolve你Return嘅嘢"},{"pid":"775ffa97d2944f46e0daf340832df950e0613dbc","tid":593712,"uid":33883,"like":0,"dislike":0,"score":0,"quote":{"pid":"a6643190d57ea6369b65b0bf68f133fdbab85915","tid":593712,"uid":11598,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-03-15T16:59:55.000Z","msg":"我屌你 做咩變咗討論 async await 點用<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /> <br />\n我想知點讀 <img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-15T17:49:06.000Z","msg":"你讀開嗰個讀法冇錯喎, 有乜問題?!"},{"pid":"dc909d8878d1fe4ee9cbf7d745cd39908adbe3d7","tid":593712,"uid":22535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-30T07:41:35.000Z","msg":"A星 呀wait"}]}