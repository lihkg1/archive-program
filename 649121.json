ke":0,"score":0,"quote":{"pid":"1bb5ff6ffd6bd1d80762de6f37351cd59eb8e14d","tid":649121,"uid":101945,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-01T09:34:19.000Z","msg":"<a href=\"https://www.facebook.com/cablechinadesk/videos/1704274473050365/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fcablechinadesk%2Fvideos%2F1704274473050365%2F&d=Avdvho1xGhCTu8wbE2PnocPrXSGIZiPsBFv3mRhlVuk%3D&h=b118bf1a\" target=\"_blank\">https://www.facebook.com/cablechinadesk/videos/1704274473050365/</a><br />\n<br />\n<a href=\"http://news.tvb.com/greaterchina/5ae6fb23e60383753405eec1/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.tvb.com%2Fgreaterchina%2F5ae6fb23e60383753405eec1%2F&d=Avdvho1xGhCTu8wbE2PnocPrXSGIZiPsBFv3mRhlVuk%3D&h=3cdd8da0\" target=\"_blank\">http://news.tvb.com/greaterchina/5ae6fb23e60383753405eec1/</a><br />\n<br />\n高下立見<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-01T18:23:56.000Z","msg":"TVB嗰個好似小學生作文咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<strong>內地五一黃金周 全國多地景點迎旅客高峰</strong>　2018-04-30 19:16<br />\n<br />\n內地五一黃金周，多個地方景點都迎來旅客高峰。<br />\n<br />\n輕風吹過，橙黃色的金雞菊及紫色的馬鞭草隨風搖曳。不少旅客專程來到浙江麗水市縉雲鎮，觀賞這片超過300平方公里的花海。遊客可以在花叢中穿梭，亦可乘搭小火車，陶醉於美景。<br />\n<br />\n位於貴州的黃果樹瀑布，亦是這個假期旅遊熱點。這裡有全國最大的瀑布，景色壯麗，不少內地人都認為，這裡是人生必到的景點。<br />\n<br />\n有旅客稱：「貴州的話，山好水好，真的挺好的。我來這邊也是五一剛好有假期，來玩一下。」<br />\n<br />\n至於在安徽黃山，數不盡的奇岩怪石被雲霧繚繞。旅客如置身於仙境中，更加流連忘返。"}]}