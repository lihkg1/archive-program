m/view/photo/l/public/p2198329022.webp\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg9.doubanio.com%2Fview%2Fphoto%2Fl%2Fpublic%2Fp2198329022.webp&h=f446d516&s={SIZE}\" /><br />\n<img src=\"https://img9.doubanio.com/view/photo/l/public/p2198329192.webp\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg9.doubanio.com%2Fview%2Fphoto%2Fl%2Fpublic%2Fp2198329192.webp&h=cd28f121&s={SIZE}\" /><br />\n<img src=\"https://i1.kknews.cc/SIG=hk0175/ctp-vzntr/207813q749384nr18q0n68r46s702404.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi1.kknews.cc%2FSIG%3Dhk0175%2Fctp-vzntr%2F207813q749384nr18q0n68r46s702404.jpg&h=113737b0&s={SIZE}\" /><br />\n<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"958e7f5bdf57360d4f813bda23fad0a38122142c","tid":1995264,"uid":7439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-30T10:48:04.000Z","msg":"<blockquote><br />\n2020年4月28日 招標 九龍內地段第11240號 九龍旺角豉油街與上海街交界 住宅 625.5(平方米) 467.18(百萬元)</blockquote><br />\n<img src=\"https://fs.mingpao.com/pns/20200429/s00072/954d411704f9b850625a9351d84405c5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffs.mingpao.com%2Fpns%2F20200429%2Fs00072%2F954d411704f9b850625a9351d84405c5.jpg&h=72df4f0c&s={SIZE}\" />"},{"pid":"54d4a8ee8ad404c06d24dddd1a0e14a699d8cddf","tid":1995264,"uid":7439,"like":0,"dislike":0,"score":0,"quote":{"pid":"fb5eb2f809c819beaf160cc2e4d9883ec027d263","tid":1995264,"uid":7439,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-04-30T06:15:24.000Z","msg":"旺角「蚊型地」下周五招標 估值2.5億起<br />\n2020/02/21<br />\n賣地圖則中，註明為地盤A及地盤B作私人住宅用途的最高樓面總面積，分別可達8921平方呎和11453平方呎。作非工業（不包括私人住宅、倉庫、酒店及加油站）用途的最高樓面面積則按照賣地條件中的相關特別條件計算。<br />\n<br />\n據之前市場估計，項目最多可建樓面料約2.44萬平方呎，估值介乎2.5億至3.2億元<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />，每平方呎樓面估值約1.04萬至1.3萬元不等。"},"citedBy":0,"replyTime":"2020-04-30T10:48:43.000Z","msg":"惟亦有2財團以「執雞」心態低價入標，次低出價約1300萬，呎價約531元，最低入標價1180萬，與中標價相差約7410萬，<span style=\"color: red;\">呎價僅482元，較中標價低約86%。</span><img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"815c229c7f58eb6caf7e745b07ea8a95fdb1805b","tid":1995264,"uid":235152,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-30T11:00:16.000Z","msg":"好心收埋其他兩旁D樓先賣地,到時又起奇異樓<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"29560ef140cd8dd0a11aa0d8697d6356bee89a51","tid":1995264,"uid":7439,"like":0,"dislike":0,"score":0,"quote":{"pid":"815c229c7f58eb6caf7e745b07ea8a95fdb1805b","tid":1995264,"uid":235152,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-30T11:00:16.000Z","msg":"好心收埋其他兩旁D樓先賣地,到時又起奇異樓<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-30T11:42:33.000Z","msg":"中間隔住條後巷<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7968ef6e03143ec7ffefc185d043bbf783c01abe","tid":1995264,"uid":7439,"like":0,"dislike":0,"score":0,"quote":{"pid":"3b50a7b23d1f45b1a5909bcb5c3a964b9ad639ce","tid":1995264,"uid":164435,"like":3,"dislike":0,"score":3,"quote":{"pid":"162199329be7b1e949ebcd29a53dcd61e5b0b048","tid":1995264,"uid":169079,"like":0,"dislike":0,"score":0,"quote":{"pid":"fcabb4595d23b9350114e47c6491963bab2d4190","tid":1995264,"uid":164435,"like":1,"dislike":7,"score":-6,"citedBy":1,"replyTime":"2020-04-30T06:20:57.000Z","msg":"你開間公司都可以投<br />\n咪on9啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-30T06:22:20.000Z","msg":"如果得一間投咪流標囉<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />做樣都要拉幾間陪跑"},"citedBy":2,"replyTime":"2020-04-30T06:23:23.000Z","msg":"流標咪流標囉<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n間中都出現啦<br />\n<br />\n就算幾間公司入唔啱價都可以流標<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-30T15:21:06.000Z","msg":"資料顯示，對上一幅呎價更低的市區住宅用地，要追溯至二○○四年六月，當年售出的九龍城沙浦道地皮，即御‧豪門現址，每方呎樓面呎價僅約2,961元。若計及新界區，是次呎價則為一六年八月後新低，當時元朗凹頭住宅地，每方呎批出價約2,690元。<br />\n<br />\n市場對地皮以低價批出均感到意外，事實上，政府去年上調投地初始按金，以防發展商撻訂。<span style=\"color: red;\">據旺角地的出售章程，投標按金為3,000萬元，推算政府對地價的粗略估價最少2億元，惟最終地價遠低於該水平。</span>"},{"pid":"d4794aea6b667a93ae78347805dfa3aaebc1eb62","tid":1995264,"uid":7439,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-30T15:21:45.000Z","msg":"華坊諮詢評估資深董事梁沛泓稱，地盤由一條後巷分隔成A及B兩個地盤，其中一邊面積不足1,200方呎，<span style=\"color: red;\">電梯也沒有位置興建，若以唐樓形式發展，層數亦受到限制，加上兩個地塊的地積比率不能互相轉移，將來很可能「起唔盡」，故用呎價衡量地皮價值未必太合適。</span><br />\n<br />\n業界：撤辣有助東主周轉<br />\n對於現時經濟下滑，市場氣氛欠佳，政府是否應檢視現行的樓市辣招。他認為，辣招稅限制了市場買賣，雖然最受疫情影響不是住宅物業，但或會有老闆遇上周轉問題，要出糧給員工卻未能賣樓，政府現時逐步撤減辣招，也是個不錯的下台階。<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"dcae14e1869126bc381d473b0ab59cfbcf94ce6a","tid":1995264,"uid":7439,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-04-30T08:41:01.000Z","msg":"鵬程亞洲出價精準，僅高次標3%。<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"}}