b9fab938ec3733d2291c6085a947","tid":1811184,"uid":6845,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-04T12:53:16.000Z","msg":"香港獨立，"},"citedBy":0,"replyTime":"2020-01-04T12:54:27.000Z","msg":"唯一出路"},{"pid":"8a8b3fbc04f1300d862e2d8e0e9b8862b9aa1e15","tid":1811184,"uid":119864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-04T12:56:53.000Z","msg":"依加香港冇美國支持，同監察加上前線和里非既行動先走到依加。<br />\n<br />\n五大訴求變成香港獨立，根本未必會得到美國支持，至少所羅門唔係唔鼓吹香港獨立，而香港獨立比五大訴求更冇基礎性"},{"pid":"ecbf32c4897d492ac55847d19d8ba7a2196774ed","tid":1811184,"uid":128569,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-04T12:57:56.000Z","msg":"如果我地唔講香港獨立咁中共係咪唔會話我地港獨？<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"13380b56ab0b6ab5271610c198d5a99b58c8c545","tid":1811184,"uid":253978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-04T12:59:07.000Z","msg":"唔好俾藉口中共<img src=\"/assets/faces/pigxm/heard.gif\" class=\"hkgmoji\" />"},{"pid":"54eb21b29bb2891218e36e1b2cae049d6ffeb779","tid":1811184,"uid":235665,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c84e0f93487ac0045168557b7441e1373c74179","tid":1811184,"uid":119864,"like":0,"dislike":1,"score":-1,"quote":{"pid":"7880983a0605e4b94d305b7466749c827832f693","tid":1811184,"uid":223216,"like":3,"dislike":0,"score":3,"quote":{"pid":"d78d0ffefe079f32bc4aed78bd0185558c9b3a5d","tid":1811184,"uid":119864,"like":0,"dislike":4,"score":-4,"citedBy":2,"replyTime":"2020-01-04T12:42:16.000Z","msg":"請問你地香港點獨立？"},"citedBy":3,"replyTime":"2020-01-04T12:44:00.000Z","msg":"唔獨立點達到五大訴求加雙普選<img src=\"/assets/faces/pigxm/snowhat.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2020-01-04T12:46:41.000Z","msg":"你未回應香港點獨立？"},"citedBy":1,"replyTime":"2020-01-04T13:00:05.000Z","msg":"脱共"},{"pid":"3aa32e694b7ef7c1d9998b623b6ad64d2c43c68a","tid":1811184,"uid":119864,"like":0,"dislike":0,"score":0,"quote":{"pid":"54eb21b29bb2891218e36e1b2cae049d6ffeb779","tid":1811184,"uid":235665,"like":0,"dislike":0,"sc