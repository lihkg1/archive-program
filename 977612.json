e3f","tid":977612,"uid":2020,"like":5,"dislike":1,"score":4,"quote":{"pid":"0d011b39cd7c0e1c52b9d9f65dfdf469849c226a","tid":977612,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-01-11T10:04:36.000Z","msg":"<a href=\"https://hk.finance.yahoo.com/news/最低工資第-滴血-清潔阿姐四月炒-023332191.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.finance.yahoo.com%2Fnews%2F%E6%9C%80%E4%BD%8E%E5%B7%A5%E8%B3%87%E7%AC%AC-%E6%BB%B4%E8%A1%80-%E6%B8%85%E6%BD%94%E9%98%BF%E5%A7%90%E5%9B%9B%E6%9C%88%E7%82%92-023332191.html&d=M%2FGs6wTTKW0q7aBMIZmwL%2FiMucz1dB5Ms3PJ3VCnrF8%3D&h=1d19e9f4\" target=\"_blank\">https://hk.finance.yahoo.com/news/最低工資第-滴血-清潔阿姐四月炒-023332191.html</a><br />\n<br />\n<img src=\"https://s.yimg.com/ny/api/res/1.2/D6rcvi7RWcXbL7z_A8vCpw--~A/YXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9ODAw/https://media.zenfs.com/en/heawork.tumblr.com/e934666b15ef38ab3e516b3908f54bf9\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs.yimg.com%2Fny%2Fapi%2Fres%2F1.2%2FD6rcvi7RWcXbL7z_A8vCpw--~A%2FYXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9ODAw%2Fhttps%3A%2F%2Fmedia.zenfs.com%2Fen%2Fheawork.tumblr.com%2Fe934666b15ef38ab3e516b3908f54bf9&h=6276f6c1&s={SIZE}\" /><br />\n<br />\n行會通會加最低工資，今年5月1日加到$37.5，呢個消息傳出幾個鐘之後，啲細公司老闆反應最靈活快捷，小編的HR朋友做船務公司，漏夜已經接到老闆指令，話四月底前要炒咗公司幾個清潔工，認真無良。 <br />\n<br />\n一來因爲市道唔好，公司已經賺少咗，二來有加最低工資呢個理由出來，更加俾公司cut budget嘅理據。  但打工仔唔好以為唔關自己事，因為老闆仲落咗「柯打」，公司各位同事之後要幫手分擔清潔阿姐嘅工作，包括： <br />\n<br />\n1）每個部門嘅同事要輪流返早，幫其他同事清潔枱面及其他公用地方。 <br />\n<br />\n2）同事要編更表，兩個人一組每人放工OT洗廁所同pantry。 <br />\n<br />\n3）公司講明繼續供應清潔用品，叫同事唔使擔心。 <br />\n<br />\n4）老闆秘書會頂清潔阿姐嘅茶水位置，負責埋公司茶水。 <br />\n<br />\n5）最後就係廁所唔再有廁紙供應，請同事自備。 <br />\n<br />\n唔好問點解連冇廁所紙都可以關最低工資事，因為老闆立場係覺得所有成本開支都有關連，正所謂「牽一髮」咪乘機「動全身」囉，仲使擇日咩？"},"citedBy":1,"replyTime":"2019-01-11T12:00:29.000Z","msg":"搵d蚊型公司拎黎講<br />\n<br />\n收左商家錢要唱衰最低工資呀？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n個老闆又係智障黎 正宗腦細<br />\n<br />\n做得文職會肯幫你搞清潔？ 執柒左佢啦 你係鬼做生意 你係請人返黎壓榨其他人黎賺錢咋<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"3b2b377020a4aaa33a2e706027fc0fd045625fa2","tid":977612,"uid":4811,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-11T12:00:30.000Z","msg":"拉隊走等佢一次過減省人工成本"},{"pid":"4845eb821a9f8a2d52d4bfbd528f272f392265b9","tid":977612,"uid":117200,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-11T12:01:36.000Z","msg":"加五毫子就話要大炒人,分明係想請4000蚊大陸奴工啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0152b5d6405a30e8fb22ae3aa91e37d03eabea95","tid":977612,"uid":2615,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-11T12:02:11.000Z","msg":"屌你老母叫人洗廁所<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"22b4c7c40b39a863d5e98ac73dcb60fca88fcac6","tid":977612,"uid":19454,"like":0,"dislike":0,"score":0,"quote":{"pid":"4845eb821a9f8a2d52d4bfbd528f272f392265b9","tid":977612,"uid":117200,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-11T12:01:36.000Z","msg":"加五毫子就話要大炒人,分明係想請4000蚊大陸奴工啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-11T12:02:29.000Z","msg":"即批"},{"pid":"9064077b4d8c3ef3d53c05b5b00b5f700510def5","tid":977612,"uid":19454,"like":0,"dislike":0,"score":0,"quote":{"pid":"ab84fc0181d1d8c2b1b43f0d13640419d1607e3f","tid":977612,"uid":2020,"like":5,"dislike":1,"score":4,"quote":{"pid":"0d011b39cd7c0e1c52b9d9f65dfdf469849c226a","tid":977612,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-01-11T10:04:36.000Z","msg":"<a href=\"https://hk.finance.yahoo.com/news/最低工資第-滴血-清潔阿姐四月炒-023332191.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.finance.yahoo.com%2Fnews%2F%E6%9C%80%E4%BD%8E%E5%B7%A5%E8%B3%87%E7%AC%AC-%E6%BB%B4%E8%A1%80-%E6%B8%85%E6%BD%94%E9%98%BF%E5%A7%90%E5%9B%9B%E6%9C%88%E7%82%92-023332191.html&d=M%2FGs6wTTKW0q7aBMIZmwL%2FiMucz1dB5Ms3PJ3VCnrF8%3D&h=1d19e9f4\" target=\"_blank\">https://hk.finance.yahoo.com/news/最低工資第-滴血-清潔阿姐四月炒-023332191.html</a><br />\