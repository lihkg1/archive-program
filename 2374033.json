437c0fc84ec67a066f76f537f00a21","tid":2374033,"uid":191815,"like":0,"dislike":0,"score":0,"quote":{"pid":"365cf7a7cdbc1a83a189b1bb7d444ee66bbd0db7","tid":2374033,"uid":95499,"like":0,"dislike":0,"score":0,"quote":{"pid":"4e7564afc36dc713d21e147df168e5c372f179c1","tid":2374033,"uid":25345,"like":0,"dislike":4,"score":-4,"quote":{"pid":"784a38cca7a326066cb4134bb61f8532b8a4e0d0","tid":2374033,"uid":171800,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-21T02:54:04.000Z","msg":"Lm返屋企再睇真定假<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-21T03:06:48.000Z","msg":"<img src=\"https://i.ytimg.com/vi/__P1paEaDxc/maxresdefault.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.ytimg.com%2Fvi%2F__P1paEaDxc%2Fmaxresdefault.jpg&h=c1c04f12&s={SIZE}\" />"},"citedBy":1,"replyTime":"2021-01-21T03:11:04.000Z","msg":"唔怪得要下海先搵到食<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-21T03:23:28.000Z","msg":"down都廢事 對黑lin<img src=\"/assets/faces/dog/stop.gif\" class=\"hkgmoji\" /><br />\nMIGD MIFD 大把都高汁過佢"}]}