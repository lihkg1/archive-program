27T08:09:32.000Z","msg":"推"},{"pid":"b2fb37c7ca9468708b4f0e5d4b5ecd1f43bf38d0","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:09:37.000Z","msg":"推"},{"pid":"0c1f5bc696d23fa663660c6743074817188a3343","tid":1371183,"uid":70524,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:09:45.000Z","msg":"<img src=\"https://na.cx/i/Qc1NDL6.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQc1NDL6.png&h=c6f9650c&s={SIZE}\" /><br />\n<br />\n南邊圍一堆防暴standby"},{"pid":"4b053eacd12b0f5e95dbefe2a8f213dee45250dd","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:09:48.000Z","msg":"推"},{"pid":"ea4d0c768f64fd599ef2b36f406036829fa3431b","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:10:16.000Z","msg":"推"},{"pid":"1f0ec6106f9dafed733b876296e8b852154bcbe2","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:10:29.000Z","msg":"推"},{"pid":"6edb4b60b9acc474533d64c2194a6c6b6f414e68","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:10:53.000Z","msg":"#交通資訊 <br />\n【特別交通消息】27/7/2019 (15:00)<br />\n<br />\n因應元朗區的交通情況，九巴以下路線會因應實際情況作出改道安排，部份班次或會於中途站停止服務，乘客請依照在場外勤人員指示。<br />\n<br />\n54 / 68 <br />\n路線暫停服務<br />\n<br />\n53<br />\n改道行走<br />\n往荃灣方向：不停元朗站至元朗公園，加停山水樓<br />\n往元朗方向：不停水邊圍邨至元朗站，加停山水樓<br />\n<br />\n64K<br />\n改道行走<br />\n往大埔方向：不停元朗（西）至形點I各站<br />\n往元朗方向：不停形點I至元朗（西）各站<br />\n<br />\n68A<br />\n改道行走<br />\n往青衣方向：不停香港家庭計劃指導會至元朗公園各站<br />\n往元朗方向：不停朗庭園至朗屏邨珠屏樓各站<br />\n<br />\n68E / 68F<br />\n改道行走<br />\n往元朗/元朗公園方向：不停形點I至譽88各站<br />\n往青衣/峻巒方向：不停譽88至形點I各站<br />\n<br />\n68M<br />\n改道行走<br />\n往荃灣方向：不停元朗（西）至形點I各站，加停朗屏邨總站/山水樓<br />\n往元朗方向：不停形點I至元朗（西）各站，加停朗屏邨總站<br />\n<br />\n68X / 268X<br />\n改道行走<br />\n往旺角/西九方向：不停朗庭園至形點I各站，加停山水樓<br />\n往洪水橋方向：不停形點I至元朗公園各站<br />\n<br />\n76K<br />\n改道行走<br />\n往朗屏方向：不停形點I至朗屏邨總站各站<br />\n往上水方向：不停朗屏邨總站至形點I各站<br />\n<br />\n77K<br />\n改道行走<br />\n往上水方向：不停鳳翔路總站至形點I各站<br />\n往朗屏方向：不停形點I至鳳翔路總站各站<br />\n<br />\n261X<br />\n改道行走<br />\n來回方向：不停形點I / 形點II / 形點I<br />\n<br />\n264R<br />\n改道行走<br />\n往大埔方向：不停元朗廣場至形點I各站<br />\n往天水圍方向：不停形點I至元朗公園各站，加停山水樓<br />\n<br />\n268B / 268C<br />\n改道行走<br />\n往九龍方向：不停朗庭園至形點I各站<br />\n往元朗方向：不停形點I至元朗公園各站<br />\n<br />\n269D /  276P<br />\n改道行走<br />\n往瀝源/上水方向：不停水邊圍邨至形點I各站<br />\n往天水圍方向：不停形點I至元朗公園各站，加停山水樓<br />\n<br />\n276<br />\n改道行走<br />\n往上水方向：不停水邊圍邨至形點I各站，加停山水樓<br />\n往天水圍方向：不停形點I至元朗公園各站<br />\n<br />\nB1<br />\n改道行走<br />\n往落馬洲方向：不停朗庭園至形點I各站<br />\n往天水圍方向：不停形點I至元朗公園各站，加停山水樓<br />\n<br />\n968<br />\n改道行走<br />\n往港島方向：不停元朗（西）至形點I各站，加停朗屏邨總站/山水樓<br />\n往元朗方向：不停形點I至元朗（西）各站，加停朗屏邨總站<br />\n<br />\n龍運 E34B / A36<br />\n改道行走<br />\n往機場方向：不停水邊圍邨至形點I各站<br />\n往元朗方向：不停形點I至康水樓/元朗公園各站"},{"pid":"dadfd774aa22f2f65b94cd6c52bc36a9d606424b","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:11:35.000Z","msg":"推"},{"pid":"09140a8240301fbc23c72d6d7c61478a98cf9091","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:11:46.000Z","msg":"推"},{"pid":"562b2acec2f0f74a13ad6d3f7e2cfe91b2a166b0","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:12:20.000Z","msg":"推"},{"pid":"ce85a7f5d86b753f25e9fb658af2933e3fad1dcc","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:14:25.000Z","msg":"推"},{"pid":"2905a8000f6e4914c5f83ba57de9953bfd84652d","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:16:30.000Z","msg":"推"},{"pid":"b88778593eaab32e414d8e424ee0b6d5a71b6a36","tid":1371183,"uid":238499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:16:58.000Z","msg":"1610。<br />\n<br />\n起點1 元西站（B出口出發中，往南邊圍）<br />\n- Control room白藍衫連袋standby。<br />\n- Exit J有綠衫，Exit H K有白、藍衫。<br />\n- 出雞地天橋有綠衫防暴block。<br />\n- 站底有便衣、綠衫standby。<br />\n- 南邊圍停車場有長車、便衣、綠衫。<br />\n- 西邊圍有綠衫、白人。<br />\n<br />\n- 隔離魚場1x架警車，綠衫standby。<br />\n- 隔離雞地體育館停車場full長車。<br />\n- 鳳琴街小巴站有少量長車。<br />\n- 東堤街成街車。<br />\n- 舊墟長車，綠衫巡邏。<br />\n<br />\n起點2 水邊村遊樂場（佔大馬路中）<br />\n- 附近有綠衫巡邏中。<br />\n- 對面係狗局，有防暴standby。<br />\n- 後面係元朗公園，停車場full長車。<br />\n- 斜對面係圖書館，疑似狗竇。<br />\n<br />\n起點3 朗屏西（B出口出發中）<br />\n- Control room 白綠藍衫連袋。<br />\n- Exit B有綠衫。A有藍衫。<br />\nF下面有綠衫防暴、旗手。<br />\nE果頭有綠衫防暴、旗手。<br />\n- 朗屏巴士站有長車standby。<br />\n- 東頭工業區遊樂場附近有警車及綠衫巡邏。<br />\n<br />\n疑似狗竇：<br />\n- 東頭工業區<br />\n- 南邊圍<br />\n- 雞地體育館<br />\n- 消防局<br />\n- 圖書館<br />\n- 元朗公園<br />\n- 朗屏、元朗control room<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n物資站：<br />\n- 元西連儂牆<br />\n- 大會堂門口<br />\n- 康樂路HSBC門口<br />\n水站：<br />\n- Yoho foodeli<br />\n- 雞地Leisure<br />\n- 大陂頭徑嘩鬼<br />\n<br />\n如有資訊（麻煩連相），請告知<br />\n物資站 - @brandt612<br />\n急救站 - @Reus612<br />\n<br />\n急救站地點：<br />\n<a href=\"https://t.me/reminder612/7900\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Freminder612%2F7900&d=YoMLTdJ4KFDt7wuWjEYT18%2BxtiM4uRDursPVmWLIdz4%3D&h=2a29dfc9\" data-auto-link target=\"_blank\">https://t.me/reminder612/7900</a><br />\n休息站地點：<br />\n<a href=\"https://t.me/reminder612/7792\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Freminder612%2F7792&d=YoMLTdJ4KFDt7wuWjEYT18%2BxtiM4uRDursPVmWLIdz4%3D&h=a720e425\" data-auto-link target=\"_blank\">https://t.me/reminder612/7792</a><br />\n#現場情況"},{"pid":"af4012403d231156be0c9b522f98ff40263012a3","tid":1371183,"uid":52566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:22:41.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"76eb45d7a1df4d720f55e5a7f684b78396c71a46","tid":1371183,"uid":21552,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-27T08:23:42.000Z","msg":"Now live 一杯杯白色係水來的？ 一路影住<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji