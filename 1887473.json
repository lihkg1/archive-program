Lf.png&h=fc9e11e8&s={SIZE}\" />"},{"pid":"ada5044f9a3c87573d7a4e9341bfa0a86fe3ab5a","tid":1887473,"uid":317037,"like":4,"dislike":6,"score":-2,"citedBy":0,"replyTime":"2020-03-31T09:39:36.000Z","msg":"佢之前係大窩口我都飲開，每次都會平2蚊比我<img src=\"/assets/faces/big/sosad.gif\" class=\"hkgmoji\" />，但自從親耳聽到佢同嗰阿伯係度屌手足，心都寒埋，係度偽黃r生意<img src=\"/assets/faces/big/kill.gif\" class=\"hkgmoji\" />"},{"pid":"5f7395e1e24295a187547f74a9d12ec7e7f31cb0","tid":1887473,"uid":317037,"like":4,"dislike":3,"score":1,"quote":{"pid":"30979234278754d431dae555d00904fb3694c972","tid":1887473,"uid":257468,"like":6,"dislike":3,"score":3,"citedBy":3,"replyTime":"2020-03-30T15:27:09.000Z","msg":"有手足甘講:<br />\n<br />\n葵涌廣場人流減少了很多很多。老伯伯的深黃小店就快捱不住，他有一個相識幾十年的<strong>藥房老闆朋友，幫他租用半個店面賣一些口罩</strong>，勉強補貼少少租金，口罩都是一些日本大牌子如白元，￼雖然中國代工但我檢查過相信是真品，價錢不算貴，買了一盒給家人，另外再買了一些飲品。到了這樣的環境，他依然放很多支裝水免費給別人，日子不好過，大家好好互相支持。<br />\nPs, 最好瘋狂買嘢飲，只買口罩伯伯係冇錢賺嘅，貨品不是他的。雖然啲口罩都好好又不是炒價🙂<br />\n￼<br />\n請自行查證，這個不懂做生意的伯伯，一見人的外表稍為年輕就突然強行減價，又用新鮮水果做果茶，tg 時又開門支援！賣飲品又免費送水是什麼玩法。<br />\n<br />\n<img src=\"https://na.cx/i/CX47hbU.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCX47hbU.png&h=fd6fc910&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/HVNMxLf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHVNMxLf.png&h=fc9e11e8&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-03-31T09:43:29.000Z","msg":"偽黃學人告咩急，先唔講佢發國難財，淨係講佢屌手足話手足抵死，點都唔抵幫襯啦"},{"pid":"412dc356a3d46719ac9860494d7766ee3f59b665","tid":1887473,"uid":289349,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-31T12:07:06.000Z","msg":"勁多人排隊咩事呀"},{"pid":"9fa5737b2e1c49c7bc064093d84d84d4f8c58108","tid":1887473,"uid":222499,"like":0,"dislike":0,"score":0,"quote":{"pid":"3b8720883383e217dd834aa533cc0463d840c704","tid":1887473,"uid":210254,"like":4,"dislike":9,"score":-5,"citedBy":2,"replyTime":"2020-02-19T22:27:43.000Z","msg":"留意咗呢間店好耐<br />\n好多人表示聽過佢屌手足<br />\n同時好多人話聽過佢屌黑警<br />\n我懷疑伯伯有雙重人格"},"citedBy":0,"replyTime":"2020-04-01T05:12