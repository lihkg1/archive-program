aedf150654a9e24a44565","tid":1697144,"uid":45613,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-06T18:54:13.000Z","msg":"Fuck dogs"},{"pid":"2f879d93eb66c1854e28383fff9202a5a134edb4","tid":1697144,"uid":45613,"like":0,"dislike":0,"score":0,"quote":{"pid":"8b982dfdc60fc3d4400aedf150654a9e24a44565","tid":1697144,"uid":45613,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-06T18:54:13.000Z","msg":"Fuck dogs"},"citedBy":0,"replyTime":"2019-11-06T18:55:35.000Z","msg":"&ldquo;Police dog poop&rdquo;"},{"pid":"8b82d49cec44167e750471287f99da7f266ecfdc","tid":1697144,"uid":120070,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T18:57:29.000Z","msg":"即係confirm左係真？"},{"pid":"83b6e0722b48e3147b849608afad571fde83209a","tid":1697144,"uid":288670,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T18:59:05.000Z","msg":"垃圾香港人 有強姦/輪姦消息流出個陣就話要等fc 要有人證 話真係證實會去打狗<br />\n<br />\n到依家有埋人證出黎啦 就個個扮盲<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n班義士真係慘 為左咁既一班垃圾去犧牲"},{"pid":"c6a722cc4bd887006894e549f5c3e2dfe8ff142a","tid":1697144,"uid":26770,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T19:24:05.000Z","msg":"同埋就算係真係輪姦左, 根本我係政府交班仆街出去咪ok,先前姦報案人都係道歉,咪搵班就退休的高層引咎下台,攬係完全無好處<br />\n<br />\n<br />\n兩大可能<br />\n1 政府查到再前日子邊防區已經有警頭允許部下強姦人再幫手封口<br />\n<br />\n2 當日有人開始姦人時,新屋嶺某囚室的其他黑警就姦埋在場女疑犯,覺得唔姦就蝕<br />\n因為參與輪姦的黑警太多,而服害人超過十人<br />\n所以連行政會議都要做埋五毛野抹黑受害人"},{"pid":"a54d3b91e99103c5ff2937b7194051259a28ecf7","tid":1697144,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T19:56:52.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"45fc7b50897ae1d48f1616aa6f4d9c44bf59e384","tid":1697144,"uid":5205,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T20:04:54.000Z","msg":"自己留意下 屌香港人多數p牌"},{"pid":"