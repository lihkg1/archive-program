href=\"http://www.storm.mg/article/232048\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.storm.mg%2Farticle%2F232048&d=JuMPYOSyz7EowLnPmpXzyUbWhtBCnEJYRTWbVbFBOac%3D&h=d1178b17\" target=\"_blank\">http://www.storm.mg/article/232048</a>"},{"pid":"6f771b3e31f12229d1a2d1c1cfe5d8308a1a9c71","tid":425602,"uid":36857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-06T08:01:17.000Z","msg":"對住中華民國、日本、美國就也文也武<img src=\"/assets/faces/lomoji/38.png\" class=\"hkgmoji\" /> <br />\n<br />\n對住緬甸、印度即刻龜縮<img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" />"},{"pid":"00249455903c29b1d1a7b3cb143eed79c5c6f709","tid":425602,"uid":64073,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-06T08:03:18.000Z","msg":"炸花園口都死咗十幾萬<br />\n炸三峽真係<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"6cd18e145b3b2e97582a955c53c9ee07541d5869","tid":425602,"uid":10637,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-06T08:06:21.000Z","msg":"要射都射去中南海啦"},{"pid":"be6e20f997fd6bd0084a9f82e0432d0c886f6439","tid":425602,"uid":92603,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-10-06T09:49:39.000Z","msg":"<blockquote>對住中華民國、日本、美國就也文也武<img src=\"/assets/faces/lomoji/38.png\" class=\"hkgmoji\" /> <br />\n<br />\n對住緬甸、印度即刻龜縮<img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /></blockquote><br />\n真心講句<br />\n<br />\n中共係理都唔撚想理印度<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"38b6b5527603b76a30cf371e986b5a1e2eed48d8","tid":425602,"uid":1067,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-10-06T09:58:24.000Z","msg":"萬年<br />\n千年<br />\n百年<br />\n不能"},{"pid":"b48703e9c2e60f04df07c148943d226dc5afe2a9","tid":425602,"uid":15815,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-06T10:14:42.000Z","msg":"唔試下點知<img src=\"/assets/faces/