ces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"7510db1f801e62a27308a4446bc694b1150ea9a3","tid":1454911,"uid":97330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T10:58:51.000Z","msg":"重推"},{"pid":"3137d75bb80095d92dfc98df15f1d08510868de9","tid":1454911,"uid":97330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T10:59:36.000Z","msg":"重推 依家前線話留"},{"pid":"f0ca40d09905c68ffc9f2569de1f818d8db170db","tid":1454911,"uid":301839,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T10:59:43.000Z","msg":"成班撚屌be water"},{"pid":"5b0ec4f18df8a2713839ee30462f9a7d1710e5ee","tid":1454911,"uid":97330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T11:02:35.000Z","msg":"重推"},{"pid":"e4a36cbb72b6070aac99a45a7c77cf1d3871c770","tid":1454911,"uid":97330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T11:03:55.000Z","msg":"點都支持前線決定"},{"pid":"fffa853c791a3c8c2ae646928f19a2ac761f9714","tid":1454911,"uid":97330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T11:09:56.000Z","msg":"如果大家既目標係令航班取消 咁依家就可以走<br />\n但如果依家既目標係五大訴求或者威脅性 令外地發出旅遊警示 我認為唔應該咁早走住<br />\n連p圖都出埋<br />\n我都好驚係風向撚，甚至驚自己幫左風向撚<br />\n<br />\n<br />\n我只重申一次：兄弟爬山，請支持前線爬山兄弟既決定<br />\n冷氣軍師應該係要幫佢地文宣同諗後路拆局<br />\n而唔係左右大局"}]}