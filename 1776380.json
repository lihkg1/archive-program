:"e9580152d26df67408acf3a2e63d9a88843e22bc","tid":1776380,"uid":47149,"like":0,"dislike":0,"score":0,"quote":{"pid":"65cd25c063e2fa4cb500c76bd2ca9d308598156b","tid":1776380,"uid":259329,"like":0,"dislike":0,"score":0,"quote":{"pid":"e121c380f2b095982de7fca3663c7897e7826f26","tid":1776380,"uid":47149,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-09T13:24:12.000Z","msg":"<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-12-09T13:30:07.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-12-09T13:31:43.000Z","msg":"<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"b4d5c681994593e771f94c55e4b5a22fdedca180","tid":1776380,"uid":127553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-09T13:33:01.000Z","msg":"<img src=\"https://na.cx/i/UmKV2z6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUmKV2z6.jpg&h=241aee25&s={SIZE}\" /><br />\n<br />\n昨日遊行最深刻的一句「初夏&mdash;&mdash;寒冬」<br />\n我們不經不覺由初夏走到冬天<br />\n由撐黃色食店走到黃色經濟圈<br />\n香港人就是有心有力也有財力<br />\n<br />\n講返正題，以往每年聖誕聯歡/Re-U都總係會叫啲最方便快捷嘅KFC、PizzaHut聖誕套餐，今年相信大家都不了不了，所以我地整合左所有會做到會服務嘅黃店，大家識Do啦！<br />\n*（亦建議學生會將圖印出派比同學宣傳📃）<br />\n<br />\n最後，教育同行全體祝大家有個Yellow Christmas 🎄💛<br />\n<br />\n*我地已盡量向店方直接確認到會服務，但始終人手有限，資料未必齊全，歡迎各位Comment報料。<br />\n<br />\n<br />\nTg: <a href=\"https://t.me/hkteacher\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fhkteacher&d=qnVsOlgekcepRBzFpIlw%2F4TtxWFByFwd8BqLGIwhgUE%3D&h=aadb918e\" data-auto-link target=\"_blank\">https://t.me/hkteacher</a><br />\nFb: shorturl.at/kqtJM<br />\nIg: <a href=\"https://instagram.com/standbyeducatorshk?igshid=juzv8s7rtxb5\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Finstagram.com%2Fstandbyeducatorshk%3Figshid%3Djuzv8s7rtxb5&d=qnVsOlgekcepRBzFpIlw%2F4TtxWFByFwd8BqLGIwhgUE%3D&h=51204c56\" data-auto-link target=\"_blank\">https://instagram.com/standbyeducatorshk?igshid=juzv8s7rtxb5</a>"},{"pid":"f2a75189b8c87720f88a263a52