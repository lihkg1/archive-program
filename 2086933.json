ss=\"hkgmoji\" />"},{"pid":"34934df563243fa1874f0082a58ed98bbcbfb795","tid":2086933,"uid":240372,"like":0,"dislike":0,"score":0,"quote":{"pid":"f6dba0e4f56acd3dacfa7e3b73c411470e8e7e81","tid":2086933,"uid":64337,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-30T13:51:38.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-30T14:16:19.000Z","msg":"推阿，聽日不出來，後日出不來！"},{"pid":"e1a9df201c9efc94126d4b2efa4d800becb9f552","tid":2086933,"uid":64337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T14:24:10.000Z","msg":"<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" />"},{"pid":"9d8a600a1ffcf9be96bc6a31502e8c84047f4930","tid":2086933,"uid":62512,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-30T14:27:09.000Z","msg":"點會， 美帝同英國都仲未制裁<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"96bd1a8b5ab2b09379ad53944870f96894b9b0f3","tid":2086933,"uid":240372,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d8a600a1ffcf9be96bc6a31502e8c84047f4930","tid":2086933,"uid":62512,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-30T14:27:09.000Z","msg":"點會， 美帝同英國都仲未制裁<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-30T14:31:58.000Z","msg":"咁聽日就係show香港人意志既時候，美國都出到聲睇緊香港人既反應<br />\n聽日冇人出，咁點俾人理由做野"},{"pid":"02f0b7b23905b010a8cc471d229c722249f9e9c9","tid":2086933,"uid":105340,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-30T14:32:29.000Z","msg":"真係量力而為<br />\n不要死守 要流動"},{"pid":"d4fc39f4b6c4609d1e88c68ca4cef6fdfab1ca21","tid":2086933,"uid":304769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T14:34:03.000Z","msg":"<strong><span style=\"font-size: xx-large;\"><span style=\"color: green;\">今日大量退出、放負po明顯有係有五毛帶頭，玩類似之前小組解散果攏野，大家唔好on99中計</span></span></strong><br />\n<br />\n今年七一要加主題：<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\"><br />\n寧願最後不得善終<br />\n也不考慮含淚折衷<br />\n<br />\n我要美國制裁，無懼與支共同歸於盡，寧死捍衛自由民主</span></span></strong><br />\n<br />\n認同就拎張紙舉比美國睇，咪比條廢老Martin Lee騎劫我地，搞到美國以為我地驚攬炒而唔做野<br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">黃世澤出左香港自治法篤灰指南，好有用，大家入去睇</span></span></strong><br />\n<br />\n\t<br />\n\t<a href=\"https://youtu.be/s6o2r5DkT-w\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fs6o2r5DkT-w&d=r9GgQvVcrWtMp%2Fshn5VX%2F6b0OKgTvMyjK8k7SjVk7cc%3D&h=5e2511f1\" target=\"_blank\">https://youtu.be/s6o2r5DkT-w</a><br />\n<br />\n<br />\n借個位<br />\n正視聽：若抗爭方向不隨局勢改變，只會無謂地損兵折將<br />\n香港街頭抗爭目標，亦都係街頭抗爭最大效果；&ldquo;攬炒&rdquo;已經達到，今次搞蟈安法其實仲攬炒過上年出老解。<br />\n宜家<strong><span style=\"color: red;\">跟著落黎就係引導全球政府同議會（尤其美國）對付支那以及滅共</span></strong>，所以大家重點應該著眼帶出清晰民意授權比各國政府做野，畫面靚+全球廣泛報導（類似反蟈安法銅鑼灣自由行）係最理想，用選票帶出民意亦十分重要。<br />\n<br />\n<strong><span style=\"color: red;\">大家要小心五毛、熱普城共諜放負風向：美國唔會幫我地（舊年年尾）-》英國係廢國無用架（今年年頭）-》歐盟奶共唔會幫我地、美國制裁無用（宜家）</span></strong><br />\n<br />\n大家要記住，香港生路只有一條：救香港人+攬炒促進支爆+重建香港。<strong><span style=\"color: red;\">沒有支爆，香港獨立或者歸英等重建方案全部都係痴人說夢。</span></strong><br />\n<br />\n未來幾個月至支共瓦解期間大家要做嘅事：1.<strong><span style=\"color: red;\">走資</span></strong>2.全球救生艇<strong><span style=\"color: red;\">救手足加有細路既黃絲家庭</span></strong>（細路是重點，香港未來棟樑，正如今時今日d前線義士，咪比佢地洗腦變小糞紅，否則香港係真正玩完）3.比足夠<strong><span style=\"color: red;\">民意授權，敦促美國以至各國凌遲式消除香港作為支那獲得外資渠道</span></strong>，包括但不限於：禁止美國個人或公司投資港股，暫停接受香港用美元結算等等4.最後就真係等<span style=\"color: red;\"><strong>支那自己爆</strong></span>"},{"pid":"8b7111371445692fa1dc7fc88f7bc1e9f64e5ac8","tid":2086933,"uid":240372,"like":0,"dislike":0,"score":0,"quote":{"pid":"02f0b7b23905b010a8cc471d229c722249f9e9c9","tid":2086933,"uid":105340,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-30T14:32:29.000Z","msg":"真係量力而為<br />\n不要死守 要流動"},"citedBy":0,"replyTime":"2020-06-30T15:09:28.000Z","msg":"出左黎先，對家既代價將會大好多"}]}