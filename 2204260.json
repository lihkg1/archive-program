sosad.gif\" class=\"hkgmoji\" />"},{"pid":"33f47b90fd3d07af6d58938268579316bb408196","tid":2204260,"uid":203346,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d609ddb77e07524ded0b8bccdb5f435358f1aed","tid":2204260,"uid":132486,"like":1,"dislike":1,"score":0,"quote":{"pid":"b1f00ceef0923cfe1a8447bb77059d41febbb3d6","tid":2204260,"uid":294518,"like":2,"dislike":0,"score":2,"quote":{"pid":"d6e8e67474adec6d5861e5e63d2d25f15a2faa97","tid":2204260,"uid":132486,"like":1,"dislike":7,"score":-6,"citedBy":1,"replyTime":"2020-09-16T02:55:08.000Z","msg":"呢個呀姐的口音好難聽得清佢講咩"},"citedBy":2,"replyTime":"2020-09-16T02:58:24.000Z","msg":"你英文聽力幾分？"},"citedBy":2,"replyTime":"2020-09-16T03:00:25.000Z","msg":"好撚低分呀，咁同佢d 口音有咩關係？<br />\n唔撚比評論？"},"citedBy":0,"replyTime":"2020-09-16T03:03:40.000Z","msg":"咁你可以去睇下佢篇essay"},{"pid":"ce6619a1f37d45e80b6edbc5c686149a7f741c21","tid":2204260,"uid":185631,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-16T03:15:33.000Z","msg":"<img src=\"https://s3.amazonaws.com/gnews-media-offload/wp-content/uploads/2020/09/11052255/DD8E8A66-7096-41B4-BAB7-48F33BB7C0BF-1152x1536.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs3.amazonaws.com%2Fgnews-media-offload%2Fwp-content%2Fuploads%2F2020%2F09%2F11052255%2FDD8E8A66-7096-41B4-BAB7-48F33BB7C0BF-1152x1536.png&h=2d1b04c9&s={SIZE}\" /><br />\n<strong><br />\n英雄科學家閆麗夢博士就是滅共第三道大門嗎？ &mdash;&mdash;觀路德直播後的感想<br />\n</strong><br />\n美東時間9月10號，新中國聯邦的路德先生和英雄科學家閆麗夢博士參加了一個來自紐約的秘密會議。據路德透露會議在紐約麥哈頓私人宅院召開，會議結果決定中共滅亡正式進入倒計時，參加本次會議的有朱利安尼、班農先生等美國重量級人物。<br />\n<br />\n<br />\n朱利安尼先生是川普總統的私人律師兼顧問。 911恐怖襲擊時期，時任紐約市長的朱利安尼以他卓越的領導能力而聞名全球，被尊稱為紐約之王，他同時也是名天主教徒，有虔誠的信仰。<br />\n<br />\n<br />\n此前路德社曾透露中共製造的CCP病毒將面臨三大階段的定性。第一階段由閆麗夢博士從專業上證實了CCP病毒（新冠病毒）來自中共病毒實驗室，是中共軍方專屬產物；第二階段將由美國最權威頂級的生化武器專家定性，CCP病毒是否為生化武器；第三階段將由美國情報部門確認，CCP病毒是實驗室洩露還是故意釋放。<br />\n<br />\n<br />\n本次會議結束，路德社明確中共即將滅亡，說明美國已完成CCP病毒三大階段的定性。閆麗夢博士是打開滅共三道大門的關鍵，其姓氏中的閆字就是第三道大門，是不是第三道大門要打開了，我們期待路德社的後續解說。"},{"pid":"2ef59c87f0b6d22a9030e65e09e536a9f58b3283","tid":2204260,"uid":127575,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-16T03:15:37.000Z","msg":"<span class=\"xx-large\">藍屍+保皇黨+支共：<br />\n<br />\n好嬲好嬲<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /></span>"},{"pid":"4a94567f886b606070c488dc3d4bc5c4dcd4c584","tid":2204260,"uid":185631,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-16T03:16:14.000Z","msg":"<img src=\"https://na.cx/i/v49fOGG.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fv49fOGG.png&h=3ab56a75&s={SIZE}\" />"},{"pid":"c648dc40436a99546e4b42caa91df23fc8b709f0","tid":2204260,"uid":31215,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-16T03:34:54.000Z","msg":"好似冇乜人講<br />\n大家都唔太信咁"},{"pid":"01ffd345a6bc854da3df2fe4f1c1fad2f5bf4f25","tid":2204260,"uid":20099,"like":0,"dislike":0,"score":0,"quote":{"pid":"c648dc40436a99546e4b42caa91df23fc8b709f0","tid":2204260,"uid":31215,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-16T03:34:54.000Z","msg":"好似冇乜人講<br />\n大家都唔太信咁"},"citedBy":0,"replyTime":"2020-09-16T04:06:00.000Z","msg":"份report唔夠力證<br />\n<br />\n要睇佢第二份<br />\n<br />\n但真係好驚佢比人買起<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"f0c243ad61a3cc1d155e3e73756f7d51b698c68c","tid":2204260,"uid":294518,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-16T05:09:09.000Z","msg":"<a href=\"https://twitter.com/TuckerCarlson/status/1306053036448583680?s=20\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2FTuckerCarlson%2Fstatus%2F1306053036448583680%3Fs%3D20&d=%2F2JumwqaKkMO2nYek6mTvYVlFhl8e2VpHQ9vpRm7Uxg%3D&h=8612c3b9\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftwitter.com%2FTuckerCarlson%2Fstatus%2F1306053036448583680%3Fs%3D20&h=88ca6778\" data-auto-link target=\"_blank\">https://twitter.com/TuckerCarlson/status/1306053036448583680?s=20</a>"},{"pid":"86e528e7ebcdcdb8502c63a