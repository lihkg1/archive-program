404800,"uid":238467,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T11:08:51.000Z","msg":"塞緊嘅打工仔同手足到場個個人都有野做！！！<br />\n<br />\n聽日幫人罷工活動細節！！！！！<br />\n<a href=\"https://lih.kg/1405730\" data-auto-link target=\"_blank\">https://lih.kg/1405730</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"4fd811f9a7f90d126a9a501fe72ddb6e306af9c3","tid":1404800,"uid":180485,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-04T11:16:16.000Z","msg":"[遍地開花］8月5朝早7點15元朗西鐵站要屯元天人！！<br />\n<a href=\"https://lih.kg/1391481\" data-auto-link target=\"_blank\">https://lih.kg/1391481</a><br />\n<br />\n<img src=\"https://na.cx/i/hZ1Sq1G.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhZ1Sq1G.png&h=c93b4c03&s={SIZE}\" /><img src=\"https://na.cx/i/utyA8e1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FutyA8e1.png&h=b6305f72&s={SIZE}\" /><img src=\"https://na.cx/i/q7WyUU2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fq7WyUU2.png&h=48d5c742&s={SIZE}\" /><img src=\"https://na.cx/i/LsETUU3.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLsETUU3.png&h=484cb9bd&s={SIZE}\" /><img src=\"https://na.cx/i/qfcY51J.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqfcY51J.png&h=a2a7f5e7&s={SIZE}\" />"},{"pid":"ceda625bc3f1e2d4e861ccf7ab090a46d32699c1","tid":1404800,"uid":267235,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T11:18:43.000Z","msg":"推"},{"pid":"096432902a90dc0714eea44d2e5f5006dea2bae1","tid":1404800,"uid":267235,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T11:20:00.000Z","msg":"三罷呀"},{"pid":"e36cd1ce9a6cbf7cc2e3b598455b2742c69c9b8e","tid":1404800,"uid":267235,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T11:20:15.000Z","msg":"推推推"},{"pid":"d94b35ff173df919fed3eff03bb30994f33a1b4c","tid":1404800,"uid":267235,"like":0,"dislike":0,"score":0,"citedBy":