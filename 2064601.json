8:47.000Z","msg":"其實LIHKG+除咗冇廣告之外有咩function？<br />\n我都係而家先知有得俾錢"},{"pid":"371ad6d8fd7ae85070a04ad7eacc5e66fae3053c","tid":2064601,"uid":119408,"like":0,"dislike":0,"score":0,"quote":{"pid":"258a1288ddca7f4847e7021f41e70e24e517b547","tid":2064601,"uid":46814,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-16T09:58:47.000Z","msg":"其實LIHKG+除咗冇廣告之外有咩function？<br />\n我都係而家先知有得俾錢"},"citedBy":1,"replyTime":"2020-06-16T11:13:25.000Z","msg":"LIHKG＋ 功能<br />\n移除網站及 App 內廣告 （不限裝置）<br />\n提升每小時的發表主題上限<br />\n提升封鎖會員的數量上限<br />\n提升留名的數量上限<br />\n及更多的 LIHKG＋ 功能將會陸續推出<br />\n<br />\n其實主要得block廣告係有用<br />\n撐連登先係主要目的<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><br />\n<br />\n長遠計我想LIHKG+ 有PM功能<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"9a3609f4c2f5368bffdddee5a1e6721de9f2e780","tid":2064601,"uid":46814,"like":0,"dislike":0,"score":0,"quote":{"pid":"371ad6d8fd7ae85070a04ad7eacc5e66fae3053c","tid":2064601,"uid":119408,"like":0,"dislike":0,"score":0,"quote":{"pid":"258a1288ddca7f4847e7021f41e70e24e517b547","tid":2064601,"uid":46814,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-16T09:58:47.000Z","msg":"其實LIHKG+除咗冇廣告之外有咩function？<br />\n我都係而家先知有得俾錢"},"citedBy":1,"replyTime":"2020-06-16T11:13:25.000Z","msg":"LIHKG＋ 功能<br />\n移除網站及 App 內廣告 （不限裝置）<br />\n提升每小時的發表主題上限<br />\n提升封鎖會員的數量上限<br />\n提升留名的數量上限<br />\n及更多的 LIHKG＋ 功能將會陸續推出<br />\n<br />\n其實主要得block廣告係有用<br />\n撐連登先係主要目的<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><br />\n<br />\n長遠計我想LIHKG+ 有PM功能<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-16T11:15:46.000Z","msg":"好，真心唔鍾意而家個廣告<br />\n好有詐騙網站feel<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"27d7c63b1824679a79c9e0e532f0181883c829c3","tid":2064601,"uid":336565,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-16T11:15:58.000Z","msg":"P牌無得join?"},{"pid":"0cb9b8c4b963404083c618681746a008a4b5f511","tid":206460