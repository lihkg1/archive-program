id":"c8ab259de5d28574fed422483c70864a78494fc6","tid":1075434,"uid":25424,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-03-25T16:13:12.000Z","msg":"你都要溝返凍既，點解要用滾水<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9e20e55813fbfbdcb8a4af60f913caa9e90e31c6","tid":1075434,"uid":189109,"like":0,"dislike":0,"score":0,"quote":{"pid":"c8ab259de5d28574fed422483c70864a78494fc6","tid":1075434,"uid":25424,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-03-25T16:13:12.000Z","msg":"你都要溝返凍既，點解要用滾水<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-25T16:23:20.000Z","msg":"可能佢住個到冇電熱水爐"}]}