ji\" />"},{"pid":"f183c174b70a57156cb32a6be39ad12c2e8d1ba8","tid":884802,"uid":44661,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-01T03:37:48.000Z","msg":"垃圾徵費 但唔分類,有閪用咩"},{"pid":"aeae0ab2cb6b7bd199bd6ef27198bb28c58eca31","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"ab2b1ffe5fdae042d3a7c257a8474037be00c44a","tid":884802,"uid":62506,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-11-01T01:31:42.000Z","msg":"<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-02T04:00:39.000Z","msg":"知彼知己<br />\n睇下香港政府點講垃圾徵費先<br />\n<a href=\"http://www.mswcharging.gov.hk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.mswcharging.gov.hk&d=b7DOn9OyI3Miq2JAdG7N8EbWhtBCnEJYRTWbVbFBOac%3D&h=6766a613\" data-auto-link target=\"_blank\">http://www.mswcharging.gov.hk</a>"},{"pid":"f9741e5638f608936c2c95ccc785b1333c84bec8","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"aeae0ab2cb6b7bd199bd6ef27198bb28c58eca31","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"ab2b1ffe5fdae042d3a7c257a8474037be00c44a","tid":884802,"uid":62506,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-11-01T01:31:42.000Z","msg":"<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-02T04:00:39.000Z","msg":"知彼知己<br />\n睇下香港政府點講垃圾徵費先<br />\n<a href=\"http://www.mswcharging.gov.hk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.mswcharging.gov.hk&d=b7DOn9OyI3Miq2JAdG7N8EbWhtBCnEJYRTWbVbFBOac%3D&h=6766a613\" data-auto-link target=\"_blank\">http://www.mswcharging.gov.hk</a>"},"citedBy":1,"replyTime":"2018-11-02T04:02:11.000Z","msg":"諗下點樣駁政府呢兩大論點<br />\n<br />\n減廢/回收成效:<br />\n<br />\n首爾自1995年推行廢物按量收費及配套措施後，其回收率在15年內由29%上升至66%。<br />\n<br />\n在1994年至2011年間，首爾的人均家戶垃圾棄置量從每日1.3公斤降至0.34公斤，減幅達74%。<br />\n<br />\n台北市於2000年實施廢物收費後，其回收率在10年內由2.4 %(1999年)上升至61%(2011年)。<br />\n<br />\n在2000年至2011年間，台北市的人均家戶垃圾棄置量從每日1.11公斤降至0.39公斤，減幅達65%。"},{"pid":"0e13555b97be051d49e550c2ba7f0fd994988bce","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"f9741e5638f608936c2c95ccc785b1333c84bec8","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"aeae0ab2cb6b7bd199bd6ef27198bb28c58eca31","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"ab2b1ffe5fdae042d3a7c257a8474037be00c44a","tid":884802,"uid":62506,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-11-01T01:31:42.000Z","msg":"<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-02T04:00:39.000Z","msg":"知彼知己<br />\n睇下香港政府點講垃圾徵費先<br />\n<a href=\"http://www.mswcharging.gov.hk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.mswcharging.gov.hk&d=b7DOn9OyI3Miq2JAdG7N8EbWhtBCnEJYRTWbVbFBOac%3D&h=6766a613\" data-auto-link target=\"_blank\">http://www.mswcharging.gov.hk</a>"},"citedBy":1,"replyTime":"2018-11-02T04:02:11.000Z","msg":"諗下點樣駁政府呢兩大論點<br />\n<br />\n減廢/回收成效:<br />\n<br />\n首爾自1995年推行廢物按量收費及配套措施後，其回收率在15年內由29%上升至66%。<br />\n<br />\n在1994年至2011年間，首爾的人均家戶垃圾棄置量從每日1.3公斤降至0.34公斤，減幅達74%。<br />\n<br />\n台北市於2000年實施廢物收費後，其回收率在10年內由2.4 %(1999年)上升至61%(2011年)。<br />\n<br />\n在2000年至2011年間，台北市的人均家戶垃圾棄置量從每日1.11公斤降至0.39公斤，減幅達65%。"},"citedBy":0,"replyTime":"2018-11-02T04:04:25.000Z","msg":"過去30年間， 香港的都市固體廢物總量增加接近76%，遠超同期人口增長的33%。人均棄置量遠高於其他主要城市。<br />\n<br />\n過去，有部分人士可能誤以爲丟棄垃圾沒有成本，未能意識到過度消費、濫丟亂棄的壞習慣會損耗地球資源，為環境帶來沉重負擔。根據其他大城市的經驗，「都市固體廢物收費」是推動減廢的火車頭，有助扭轉「大嘥鬼」的習慣。"},{"pid":"7c223bff6f0823dd03f0570da4d5c4b5976a4e6e","tid":884802,"uid":53026,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-02T04:16:02.000Z","msg":"好似話連匪派都唔預過到"},{"pid":"2e6a88d4cc632f1d1c9b5c2f04e2f54e143eb37e","tid":884802,"uid":810,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-11-02T04:16:47.000Z","msg":"唔洗阻止 反正我理閪得佢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"3469bf412e54f9c985859630c77fd479945cdabe","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"2e6a88d4cc632f1d1c9b5c2f04e2f54e143eb37e","tid":884802,"uid":810,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-11-02T04:16:47.000Z","msg":"唔洗阻止 反正我理閪得佢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-02T04:19:13.000Z","msg":"好似大約平均每人每月駛多20蚊左右"},{"pid":"81bbf70bee8b6fc2e5456110a02349653c576891","tid":884802,"uid":36287,"like":1,"dislike":1,"score":0,"quote":{"pid":"3469bf412e54f9c985859630c77fd479945cdabe","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"2e6a88d4cc632f1d1c9b5c2f04e2f54e143eb37e","tid":884802,"uid":810,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-11-02T04:16:47.000Z","msg":"唔洗阻止 反正我理閪得佢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-02T04:19:13.000Z","msg":"好似大約平均每人每月駛多20蚊左右"},"citedBy":0,"replyTime":"2018-11-02T04:23:30.000Z","msg":"其實落街食個早餐都唔只呢個價<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n無咩動力為錢做多啲野<br />\n利申不嬲屋企有自己分類扔回收"},{"pid":"00c9616050abd6b8a37f0cc5e1d4568cd277ca98","tid":884802,"uid":33868,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-02T04:24:38.000Z","msg":"佢過同唔過都無咩分別，<br />\n反正香港人唔會用"},{"pid":"c60794c90cfeaeba7d7aaf5e17571703794d68ce","tid":884802,"uid":62506,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-02T04:48:38.000Z","msg":"其實任何政策罰款都係最差<br />\n<br />\n因為都做成社會不公，有錢人就有掉垃圾權？窮人就無掉垃圾權？"},{"pid":"31727de5b493592f44ec35ce3921631921d7f644","tid":884802,"uid":20816,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-02T09:46:41.000Z","msg":"無"},{"pid":"1710bd96663e9239db3995ec47f785d5e16c99e6","tid":884802,"uid":62506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-04T06:37:04.000Z","msg":"香港人口密度高，根本唔適合推行垃圾徵費"},{"pid":"e2fee444d445c37480e7a663fe4ade497c849e1d","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-17T12:03:40.000Z","msg":"<strong>強推垃圾徵費 或令衛生問題惡化</strong><br />\n<br />\n政府去年尾向立法會提交都巿固體廢物收費條例草案，筆者十分支持環保，認同減廢減碳的大方向，亦相信社會支持污者自付的原則，惟政府過去推出的廢物收費計劃，都出現非法棄置問題，有關情況多年來都未能解決， 若再強推垃圾徵費，恐怕令環境污染及衛生問題進一步惡化。<br />\n<strong><br />\n非法棄置垃圾愈見嚴重<br />\n</strong><br />\n政府於2005 年推出「建築廢物處置收費計劃」，鼓勵建築廢物產生者減少產生廢物，以及將廢物篩選分類、再用及循環再造，根據環保署的統計數字，2004/2005 年於堆填區棄置的整體建築廢物為每日6500 多噸，到2006 年已大減三成多至每日4000 多噸。從數字上來看，運到堆填區的建築廢物確實顯著減少，但代表建築廢物成功減廢及回收嗎？<br />\n<br />\n<br />\n<br />\n實際上，大量的建築廢物被非法棄置，令各區出現衛生黑點，無論街邊、天台、鄉郊，都有建築廢物。例如恒大往花心坑村的水務署私人車路，約有10 個避車處，經常有不法之徒傾倒建築廢料。該情況在去年政府推出「四電一腦」後更為嚴峻。<br />\n<br />\n<br />\n<br />\n「四電一腦」原意是促進循環再造及妥善處置本港產生的廢電器電子產品，政府雖強調「四電一腦」政策成功，但現實是劣評如潮，不但扼殺「收買佬」的生存空間，持牌經營「四電一腦」的回收商更未能做到即日搬走舊機，有市民因而放棄回收，選擇棄置「四電一腦」。原有的建築廢物棄置黑點加上「四電一腦」的棄置物，令問題雪上加霜，例如坑口村停車埸、沙角尾停車場及大水坑垃圾站，充斥泥頭、木材、雪櫃、電視等，構成環境污染。筆者已經就衛生黑點投訴十年，至今都仍然未見改善。<br />\n<br />\n<br />\n<br />\n<strong>宜先解衛生問題再收費</strong><br />\n<br />\n<br />\n<br />\n現時本港更有鼠患問題，2017 年的鼠患參考指數為百分之3.5，較2010 年的百分之1.5 高1.3 倍，去年上半年荃灣區更高達百分之8.2，接近百分之10 的警界線，反映情況嚴峻。筆者曾收到居民投訴「老鼠大過貓」及老鼠入屋，更出現一塊老鼠板捉到6 隻老鼠的情況，如果強推垃圾徵費，或會出現廚餘非法棄置，令衛生及老鼠問題更趨嚴重。"},{"pid":"9a04a6cdba0dda2df19883232324aa17048b44e4","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-17T12:04:35.000Z","msg":"<a href=\"https://www.speakout.hk/%E6%B8%AF%E4%BA%BA%E5%8D%9A%E8%A9%95/42369/%E5%BC%B7%E6%8E%A8%E5%9E%83%E5%9C%BE%E5%BE%B5%E8%B2%BB-%E6%88%96%E4%BB%A4%E8%A1%9B%E7%94%9F%E5%95%8F%E9%A1%8C%E6%83%A1%E5%8C%96#selected\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.speakout.hk%2F%25E6%25B8%25AF%25E4%25BA%25BA%25E5%258D%259A%25E8%25A9%2595%2F42369%2F%25E5%25BC%25B7%25E6%258E%25A8%25E5%259E%2583%25E5%259C%25BE%25E5%25BE%25B5%25E8%25B2%25BB-%25E6%2588%2596%25E4%25BB%25A4%25E8%25A1%259B%25E7%2594%259F%25E5%2595%258F%25E9%25A1%258C%25E6%2583%25A1%25E5%258C%2596%23selected&d=b7DOn9OyI3Miq2JAdG7N8EbWhtBCnEJYRTWbVbFBOac%3D&h=9c140517\" data-auto-link target=\"_blank\">https://www.speakout.hk/%E6%B8%AF%E4%BA%BA%E5%8D%9A%E8%A9%95/42369/%E5%BC%B7%E6%8E%A8%E5%9E%83%E5%9C%BE%E5%BE%B5%E8%B2%BB-%E6%88%96%E4%BB%A4%E8%A1%9B%E7%94%9F%E5%95%8F%E9%A1%8C%E6%83%A1%E5%8C%96#selected</a>"},{"pid":"651da95001bfa4b9b9e9cb2513b573142a2daa2d","tid":884802,"uid":149978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-17T12:06:10.000Z","msg":"<strong>垃圾徵費官網及宣傳</strong><br />\n<a href=\"https://www.mswcharging.gov.hk/[/quote]\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.mswcharging.gov.hk%2F%5B%2Fquote%5D&d=b7DOn9OyI3Miq2JAdG7N8EbWhtBCnEJYRTWbVbFBOac%3D&h=b5aee8b5\" data-auto-link target=\"_blank\">https://www.mswcharging.gov.hk/[/quote]</a>"}]}