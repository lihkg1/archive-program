uid":277178,"like":0,"dislike":0,"score":0,"quote":{"pid":"46869a7726a1d08e25c26bc836ccbe8918162b1e","tid":1397054,"uid":18648,"like":5,"dislike":0,"score":5,"quote":{"pid":"cb4f705c16b6b330f3bdaec0733ca7c0aa38ac29","tid":1397054,"uid":277178,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-02T11:19:08.000Z","msg":"好番左？"},"citedBy":1,"replyTime":"2019-08-02T11:37:57.000Z","msg":"仲係好辛苦<br />\n好耐無試過訓教好<br />\n但我會堅強生活<br />\n要睇到香港重光<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-02T14:30:54.000Z","msg":"求生意志好緊要<br />\n一日唔放棄<br />\n就可以係個洞爬番出黎<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n支持你呀！！！"},{"pid":"d50de7e373397552e551be342c28be9993eaf0b9","tid":1397054,"uid":277178,"like":0,"dislike":0,"score":0,"quote":{"pid":"27e3aeb42d9324eee74babc11b5f3fb5db379fbf","tid":1397054,"uid":18648,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f6c6445f129287d58fc1cd3e8b4ac8811037eb3","tid":1397054,"uid":277178,"like":0,"dislike":0,"score":0,"quote":{"pid":"acd671ddeef8fa12c707ff5feb17093c8c4de563","tid":1397054,"uid":55227,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-02T11:20:09.000Z","msg":"呢d 病應該無話可以完全好翻"},"citedBy":1,"replyTime":"2019-08-02T11:22:23.000Z","msg":"咁依家算係穩定左？<br />\n靠食藥定點？"},"citedBy":1,"replyTime":"2019-08-02T11:39:39.000Z","msg":"靠食藥穩定<br />\n但一唔記得食藥<br />\n過兩日就仆街了"},"citedBy":1,"replyTime":"2019-08-02T14:32:13.000Z","msg":"有無試過靜觀呼吸？<br />\n可以調節到情緒"},{"pid":"12472c952c6be3b52918461a0c261fb4bdd959d6","tid":1397054,"uid":18648,"like":0,"dislike":0,"score":0,"quote":{"pid":"d50de7e373397552e551be342c28be9993eaf0b9","tid":1397054,"uid":277178,"like":0,"dislike":0,"score":0,"quote":{"pid":"27e3aeb42d9324eee74babc11b5f3fb5db379fbf","tid":1397054,"uid":18648,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f6c6445f129287d58fc1cd3e8b4ac8811037eb3","tid":1397054,"uid":277178,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-02T11:22:23.000Z","msg":"咁