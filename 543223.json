ts/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0f1fe76f1e27f53af2812f065f10a6987f578170","tid":543223,"uid":47674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-29T07:05:41.000Z","msg":"周明權......<br />\n係咪會德豐地產？"},{"pid":"938fd1a337e4ac69ba14b4e297513340cd7d3c0e","tid":543223,"uid":47674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-29T07:12:46.000Z","msg":"講噪音污染、光污染<br />\n偏偏就唔提貨輪嘅廢氣污染<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <br />\n<br />\n遠洋貨輪停泊碼頭排廢氣<br />\n研究：葵青1500人增患癌風險<br />\n<a href=\"https://hk.news.appledaily.com/local/daily/article/20091011/13300602\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20091011%2F13300602&d=LlKYsBJqCa29R27Wx8rYi6WGW%2FHqnCni%2B1xW1zXhD2s%3D&h=c77c1ad4\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20091011%2F13300602&h=e315f0e9\" target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20091011/13300602</a>"},{"pid":"da04e585a0c7c9545891b5ef37b367d060aaa748","tid":543223,"uid":47674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-29T07:15:21.000Z","msg":"貨輪泊岸排廢氣　三屋邨居民受影響<br />\n<a href=\"http://hk.on.cc/hk/bkn/cnt/news/20150301/bkn-20150301184108289-0301_00822_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20150301%2Fbkn-20150301184108289-0301_00822_001.html&d=LlKYsBJqCa29R27Wx8rYi6WGW%2FHqnCni%2B1xW1zXhD2s%3D&h=b71d1b28\" target=\"_blank\">http://hk.on.cc/hk/bkn/cnt/news/20150301/bkn-20150301184108289-0301_00822_001.html</a>"},{"pid":"dc167ece1726fe67b0644e51d15f8ff658c1e886","tid":543223,"uid":38671,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-29T07:18:15.000Z","msg":"叫香港人訓貨櫃，去大灣區<br />\n公屋就留俾新移民"},{"pid":"045247409e7bdd324e394aa6495b49c58e4c1879","tid":543223,"uid":26752,"l