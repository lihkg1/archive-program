c=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"c825929ff9fef2a03cc6688510fbf3149cae3925","tid":616962,"uid":24614,"like":0,"dislike":0,"score":0,"quote":{"pid":"89780fd664ff8330b9989abafa167c60daed5564","tid":616962,"uid":99805,"like":2,"dislike":1,"score":1,"citedBy":2,"replyTime":"2018-04-04T15:29:08.000Z","msg":"其實骨折醫院都幫唔到你乜野<br />\n只係固定，咁你範圍細就得<br />\n<br />\n問題係留意有無內出血，即係慢慢腫起成個波咁<br />\n有就快d cut白車<br />\n無就今晚平訓，搵野zip係小腿升高少少對腳就得"},"citedBy":0,"replyTime":"2018-04-04T16:10:16.000Z","msg":"內出血會點？"},{"pid":"ca69f020c10d548ad05eac42f63828927c557cb3","tid":616962,"uid":140309,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T16:12:58.000Z","msg":"急症室黎講唔係心臟/呼吸問題,都係非/次緊急,要等好耐<br />\n睇咗門診先啦"},{"pid":"e705ec6f9292593c2545d5706f1f70d088e8183a","tid":616962,"uid":103156,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-04T16:18:18.000Z","msg":"夜晚急症室，得好少醫生，你哋非緊急  case , 真係有可能要等天光。"},{"pid":"2bb2fad0a56d416d3f1624bcddcb9b39e55daa10","tid":616962,"uid":78253,"like":0,"dislike":0,"score":0,"quote":{"pid":"1381c9bb1bbd897700f0f203e61640b11e3f3c77","tid":616962,"uid":35324,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T16:08:58.000Z","msg":"決定聽朝去排急症算<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n多謝各位巴打<br />\n聽日再同大家update最新情況<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n排急症期間可喺度以同我傾計<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-04T16:43:52.000Z","msg":"唔是話<br />\n我啱先年初四喺樓梯「凳」低咗幾級<br />\n即時反應都暈同想嘔<br />\n本身都有諗去睇法國急症<br />\n但都係揀去人哋度拜年打機<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n跟住第二日先是鳩但睇吓跌打中醫<br />\n而家咪行得走得<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n渣咖<br />\n<br />\n去私家唔係唔得<br />\n但要有心理準備佢一定要你鳩照X光"},{"pid":"15ddc0ba5ad760ca87c9d3ebb518e25b61c400d9","tid":616962,"uid":78253,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-04T16:45:03.000Z","msg":"拎本書去排啦<br />\n電話應該頂唔到咁耐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ba449a63b393187a8bf74283d591eac880e28be5","tid":616962,"uid":111979,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T16:59:16.000Z","msg":"當年我踢波踢裂腳指尾骨<br />\n去左啲照x光診所到照<br />\n照x光嗰個話無移位去睇跌打都得架啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n跟住拎埋張片去睇跌打<br />\n敷左三四次<br />\n一兩個禮拜後都無痛啦"},{"pid":"49d5b956ab00dddb1f13bac4d52ca224eddfed91","tid":616962,"uid":129506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-04T17:01:24.000Z","msg":"我係你睇跣打<br />\n<br />\n睇急症唔算濫用，你叫救護車先算濫用<br />\n<br />\n只係聽日紅日，分分鐘排6個鐘，比幾百$好過啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d962b93882d5cdbce2aea3de6b7e4e76fbdde82c","tid":616962,"uid":26353,"like":0,"dislike":0,"score":0,"quote":{"pid":"ca69f020c10d548ad05eac42f63828927c557cb3","tid":616962,"uid":140309,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T16:12:58.000Z","msg":"急症室黎講唔係心臟/呼吸問題,都係非/次緊急,要等好耐<br />\n睇咗門診先啦"},"citedBy":1,"replyTime":"2018-04-04T17:07:01.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 無知扮專家"},{"pid":"403bf742bb24d4218dadada188ca4a682800b35f","tid":616962,"uid":61271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-04T17:10:36.000Z","msg":"正常應該係睇骨科照x光<br />\n但聽日係假期，一般專科同x光中心都唔開，你等唔切，去睇急症，無人會怪你"},{"pid":"c3cb2945f4fd453e1119d4a422bc9a9fcd6d6193","tid":616962,"uid":78253,"like":0,"dislike":0,"score":0,"quote":{"pid":"d962b93882d5cdbce2aea3de6b7e4e76fbdde82c","tid":616962,"uid":26353,"like":0,"dislike":0,"score":0,"quote":{"pid":"ca69f020c10d548ad05eac42f63828927c557cb3","tid":616962,"uid":140309,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T16:12:58.000Z","msg":"急症室黎講唔係心臟/呼吸問題,都係非/次緊急,要等好耐<br />\n睇咗門診先啦"},"citedBy":1,"replyTime":"2018-04-04T17:07:01.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 無知扮專家"},"citedBy":1,"replyTime":"2018-04-04T17:10:55.000Z","msg":"而家係咁啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n就算爆哂缸如果仲有知覺<br />\n話好痛呀幾時到我呀，都唔鳩理你啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\nBB發燒會快少少嘅<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1bfec95ebe7d3bb9042cd27dca370eb89233d901","tid":616962,"uid":78253,"like":0,"dislike":0,"score":0,"quote":{"pid":"ba449a63b393187a8bf74283d591eac880e28be5","tid":616962,"uid":111979,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T16:59:16.000Z","msg":"當年我踢波踢裂腳指尾骨<br />\n去左啲照x光診所到照<br />\n照x光嗰個話無移位去睇跌打都得架啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n跟住拎埋張片去睇跌打<br />\n敷左三四次<br />\n一兩個禮拜後都無痛啦"},"citedBy":1,"replyTime":"2018-04-04T17:11:32.000Z","msg":"有斷骨嘅話跌打都會摸到啦"},{"pid":"91d66a0c0b75ee6a0458c704ddc507bc21021d89","tid":616962,"uid":111979,"like":0,"dislike":0,"score":0,"quote":{"pid":"1bfec95ebe7d3bb9042cd27dca370eb89233d901","tid":616962,"uid":78253,"like":0,"dislike":0,"score":0,"quote":{"pid":"ba449a63b393187a8bf74283d591eac880e28be5","tid":616962,"uid":111979,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T16:59:16.000Z","msg":"當年我踢波踢裂腳指尾骨<br />\n去左啲照x光診所到照<br />\n照x光嗰個話無移位去睇跌打都得架啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n跟住拎埋張片去睇跌打<br />\n敷左三四次<br />\n一兩個禮拜後都無痛啦"},"citedBy":1,"replyTime":"2018-04-04T17:11:32.000Z","msg":"有斷骨嘅話跌打都會摸到啦"},"citedBy":0,"replyTime":"2018-04-04T17:17:49.000Z","msg":"我只係腳指尾骨裂左少少<br />\n無移位<br />\n外表睇腳指尾只係有紅腫<br />\n同㩒落有啲痛<br />\n我原先都以為只係啲拉傷左啲筋腱<br />\n你肯定佢會摸到？"},{"pid":"0cd2f919042f00a1e183803d5cce8a493594bd61","tid":616962,"uid":26353,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-04-04T17:50:23.000Z","msg":"急症嘅概念係 accident and emergency <br />\n常見嘅病症大概分<br />\n內科<br />\n外科<br />\n婦科<br />\n兒科<br />\n骨科<br />\n精神科<br />\n<br />\n點先叫急？<br />\n其實有生命危險或會引致任何部分失去功能就係急<br />\n<br />\n已經冇心跳冇呼吸嘅一定最急<br />\n有心跳但跳過200下嘅迷迷糊糊又係最急<br />\n心跳得20下又低血壓嘅又係最急<br />\n行得走得心跳100下鬆啲但係STEMI嘅又係最急<br />\n二氧化碳酸性中毒或呑錯格唔識自己抖氣又係最急<br />\n張力性爆肺但仲識抖氣有心跳嘅都係急<br />\n<br />\n樓上話唔係心臟同呼吸嘅問題就唔分緊急<br />\n咁我再舉下例<br />\n<br />\n血糖過低又係急<br />\n體溫太高太低中暑失溫又係急<br />\n肝腎功能電解質失衡又係急<br />\n中風抽筋（羊癎）腦膜炎又係急<br />\n腸塞盲腸炎腹腔炎膽管塞又係急<br />\n斷骨燒傷創傷內外出血又係急<br />\n早產遲產宮外孕又係急<br />\n發狂傷害人傷害自己又係急<br />\n突然盲咗睇嘢突然矇咗有重影有嘢入眼整唔走又係急<br />\n鼻血流一晚都唔停又可以係急<br />\n（前題你運用正確方法止血）<br />\n<br />\n以上只係各科入面嘅千分之一例子<br />\n點先叫唔濫用急症其實好難界定<br />\n因為病症輕重一般人唔識分係有定冇生命危險（除非好客觀地明顯）<br />\n亦唔知自己嘅不適再發展落去係咪會有咩嚴重後果（一般人醫護知識水平低）<br />\n但有啲情況又好明顯係濫用<br />\n例如喉嚨痛兩聲咳有黃痰又睇急症<br />\n係呀你可以話我點知係咪肺炎呀<br />\n咁你咪睇咗屋邨個醫生先囉<br />\n佢聽完你個肺覺得唔妥就叫你照肺㗎啦<br />\n再者食完藥休息完都唔好或者轉差先再睇急症都得<br />\n有啲人腰骨痛行去睇急症<br />\n一問起原來痛咗10幾年<br />\n大佬呀<br />\n你咁撚急<br />\n真係膠刀肺豉髀"},{"pid":"db6f0f93fd7e52d51ede493d8891929610bc1b13","tid":616962,"uid":26353,"like":0,"dislike":0,"score":0,"quote":{"pid":"c3cb2945f4fd453e1119d4a422bc9a9fcd6d6193","tid":616962,"uid":78253,"like":0,"dislike":0,"score":0,"quote":{"pid":"d962b93882d5cdbce2aea3de6b7e4e76fbdde82c","tid":616962,"uid":26353,"like":0,"dislike":0,"score":0,"quote":{"pid":"ca69f020c10d548ad05eac42f63828927c557cb3","tid":616962,"uid":140309,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T16:12:58.000Z","msg":"急症室黎講唔係心臟/呼吸問題,都係非/次緊急,要等好耐<br />\n睇咗門診先啦"},"citedBy":1,"replyTime":"2018-04-04T17:07:01.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 無知扮專家"},"citedBy":1,"replyTime":"2018-04-04T17:10:55.000Z","msg":"而家係咁啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n就算爆哂缸如果仲有知覺<br />\n話好痛呀幾時到我呀，都唔鳩理你啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\nBB發燒會快少少嘅<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-04T17:54:20.000Z","msg":"你爆哂缸冇反應唔嗌心跳過快血壓低咪理你囉天才<br />\n大把人聯完針就止咗血仲要嘈點解等咁耐就真係想一刀劈到你入手術室做EOT<br />\n睇下你仲嗌唔嗌到好痛呀<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"fb22573881b471b4604956d2c85b48eb4a17f43d","tid":616962,"uid":16676,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-04-04T18:22:52.000Z","msg":"<a href=\"https://img.eservice-hk.net/upload/2018/04/05/021924_3e7ab404f1ce2d7086a14fed3e975d30.png\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F05%2F021924_3e7ab404f1ce2d7086a14fed3e975d30.png&d=CSB0IGd1xZxngogkQDZv4zA5unq%2FSd9ZKvr75NUD1%2F0%3D&h=1a6d4c4c\" target=\"_blank\">https://img.eservice-hk.net/upload/2018/04/05/021924_3e7ab404f1ce2d7086a14fed3e975d30.png</a><span style=\"color: red;\"><strong><span style=\"font-size: x-large;\">慎入</span></strong></span><br />\n<br />\n開頭以為無事, 轉頭就唔痛, 開頭都唔肯去睇<br />\n<br />\n<br />\n<br />\n點知照完xray, 原來好齊咁斷左<br />\n半年假 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}