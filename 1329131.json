{"tid":1329131,"cid":5,"subCid":0,"title":"【真・葛咸城】香港大廈外牆現《蝙蝠俠》標誌","createTime":"2019-07-18T06:18:47.000Z","updateTime":"2019-07-20T01:33:10.000Z","uid":184679,"like":5,"dislike":0,"uniUserReply":2,"replies":[{"pid":"c90db4df918e7fa5689ee06cb1a50100578246e5","tid":1329131,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-18T06:18:47.000Z","msg":"<img src=\"http://static.stheadline.com/stheadline/inewsmedia/20190718/_2019071813181637579.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.stheadline.com%2Fstheadline%2Finewsmedia%2F20190718%2F_2019071813181637579.jpg&h=3ed5c6dd&s={SIZE}\" /><br />\n<br />\n《蝙蝠俠》標誌由葛咸城轉到香港出現！今年適逢《蝙蝠俠》誕生80周年，DC娛樂公司聯同香港半島酒店大搞慶祝活動，9月會有蝙蝠俠日將蝙蝠標誌投射在酒店外牆，同時仲有蝙蝠俠及小丑夜跑。<br />\n<br />\n《蝙蝠俠》80年來跨越不同年代，是超級英雄之一。為慶祝80周年，香港半島酒店將於 9 月21日蝙蝠俠日當晚8時至午夜12 時，將蝙蝠標誌投射到酒店大樓外牆上。<br />\n<br />\n另外，籌辦夜跑的單位Hybrid group指，參加的跑手可以穿上特別設計之蝙蝠俠夜光上衣 (Batman Glow T-shirt)，與穿上小丑，小丑女等經典角色跑衫，一同上陣完成4公里路程，地點在西九文化區苗圃公園，晚上6時至9時。夜跑活動今日開始接受報名啦，預計有6千至8千人參與，票會成人由 420 港元起，小童由 320 港元起。<br />\n<br />\n<img src=\"http://static.stheadline.com/stheadline/inewsmedia/20190718/_2019071813181791657.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.stheadline.com%2Fstheadline%2Finewsmedia%2F20190718%2F_2019071813181791657.jpg&h=318abccd&s={SIZE}\" /><br />\n<br />\n<pre><code data-type=\"\">http://hd.stheadline.com/news/realtime/hk/1547262/%E5%8D%B3%E6%99%82-%E6%B8%AF%E8%81%9E-Kelly-Online-%E8%9D%99%E8%9D%A0%E4%BF%A0-%E6%A8%99%E8%AA%8C%E7%8F%BE%E9%A6%99%E6%B8%AF-Batman%E5%B0%8F%E4%B8%91%E4%B8%8A%E8%BA%AB%E9%AC%A5%E5%A4%9C%E8%B7%91</code></pre>"},{"pid":"88e882a1630cfdaa1e5729f59c2c2e44491d9fec","tid":1329131,"uid":110207,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-20T01:19:31.000Z","msg":"啱晒宜家<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fa30cad0d14dd37fff6ad9c116ddb9b491f80eed","tid":1329131,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T01:33:10.000Z","msg":"<img src=\"https://quotesaga-img.s3.amazonaws.com/quote/QS_41418446496b4fe29c99ddd60b881678.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fquotesaga-img.s3.amazonaws.com%2Fquote%2FQS_41418446496b4fe29c99ddd60b881678.jpg&h=103ceb38&s={SIZE}\" />"}]}