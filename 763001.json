d":168172,"like":3,"dislike":0,"score":3,"quote":{"pid":"dce2e47d32fba8e0fe899cec8ba50b656fa689cd","tid":763001,"uid":6974,"like":15,"dislike":4,"score":11,"citedBy":2,"replyTime":"2018-08-01T10:36:38.000Z","msg":"扮窮呢 <br />\n<br />\n利申：返工個陣唔見左銀包<br />\n<br />\n被同事執到 發現我銀包得返$50 <br />\n<br />\n但係個陣月中 唔應該咁窮 <br />\n<br />\n佢地執返比我 問我係咪好唔掂 <br />\n<br />\n<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><br />\n<br />\n利申：銀行3位數<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-01T14:58:09.000Z","msg":"通常有錢先易比人屈<br />\n推佢又麻煩"},{"pid":"163a250c0635ed2f7719e52a46e2777d22d1e85a","tid":763001,"uid":30478,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-08-01T15:01:49.000Z","msg":"陳奕迅 Class 詞：林寶<br />\n<br />\n&hellip;<br />\n型入格 其實無標準 不過有區分<br />\n誰動作人脈說話修養格調夠品質<br />\n<br />\n而教也學不到<br />\n人氣派跟氣度<br />\n連多少錢都買不到<br />\n文化指數<br />\n只可仰慕 皆因冇就冇"},{"pid":"2b2a2441948484f198b0d181cffc2ef4936099a3","tid":763001,"uid":44243,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-08-01T15:03:03.000Z","msg":"有錢人爭住扮窮<br />\n窮撚就少少野都拎黎威"},{"pid":"04c2a320964008a5fae00c50916b419a4b6c370e","tid":763001,"uid":29702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-01T15:03:53.000Z","msg":"此回覆已被刪除"},{"pid":"e5a1c8233356127885310731a2298bb2d9199a9f","tid":763001,"uid":9430,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-01T15:04:33.000Z","msg":"真係有錢都唔會介意人地點睇 窮撚先會咁玻璃心"},{"pid":"0d11c6fc13f0ec04cb2e70560e980e0714be7450","tid":763001,"uid":20442,"like":0,"dislike":0,"score":0,"quote":{"pid":"a0fad45d676f8b86109de18542e47f8841c01d5b","tid":763001,"uid":41245,"like":183,"dislike":5,"score":178,"citedBy":3,"replyTime":"2018-07-31T19:26:56.000Z","msg":"其實多咗好多窮人出嚟呻窮就真<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /> <br />\n不嬲都有階級觀念依樣嘢<br />\n特別香港係英國建立<br />\n階級觀念更加嚴重<br />\n但英式嗰啲係class，支那嗰啲係rich<br />\n依家係多咗人曬自己rich，少咗人/冇人曬class<br />\n而依家rich嘅人係唔會追求轉型做class，為自己包裝品味同格調，亦可以從派錢畀賤種得到尊重，得到尊重嘅方法變得更廉價<br />\n依種由class轉做rich係一個悲哀嘅現象，亦源自暴發本身改變唔到自身人格嘅本質<br />\n而亦因為class已經冇rich嚟得吸引，而令到「高級」一層嘅人嘅形象已經越嚟越差<br />\n「低級」嘅人變得可以係相反嘅一面&mdash;&mdash;&mdash;窮到拎到尊重，所以呻窮就變到seek到attention，你唔難發現講「哪有錢你老母」嘅人係多咗人<br />\n社會開始變得更加膚淺同廉價"},"citedBy":0,"replyTime":"2018-08-01T15:13:02.000Z","msg":"講得好，好耐冇見的高質留言<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"2e6f467306c611fa682519f71166bd1509128ad9","tid":763001,"uid":127929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-01T15:15:57.000Z","msg":"agger"},{"pid":"5282dcc227d40682047fe0f7d8925a3c1097e97f","tid":763001,"uid":168172,"like":0,"dislike":0,"score":0,"quote":{"pid":"e1265574b96919d24e6eaad9e7e60aebca8f559d","tid":763001,"uid":195479,"like":0,"dislike":0,"score":0,"quote":{"pid":"a008d5faeff8530b70007feeca3c75bebc46c8e9","tid":763001,"uid":168172,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2018-08-01T14:56:39.000Z","msg":"從來都只會話自己窮<br />\n唔用名牌<br />\n唔著貴衫 做gym汁身形<br />\n練唱歌 我覺得咁樣 high class好多"},"citedBy":1,"replyTime":"2018-08-01T14:57:36.000Z","msg":"我都覺"},"citedBy":0,"replyTime":"2018-08-01T15:17:38.000Z","msg":"我覺得炫D用錢都買唔到既野先真正令人崇拜<br />\n<br />\n好似EASON 學友咁,個樣唔得但有唱歌加持,即刻令仔好多"},{"pid":"7359968e497cd566cd6f69e71a7f59b40b7e435d","tid":763001,"uid":67815,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2018-08-01T15:21:52.000Z","msg":"留名<br />\n你有錢到某個位 自不然會發覺呢個世界有錢過你既人大有人在<br />\n一個禮拜零用錢六萬到二十萬我都聽過 講緊係廿十歲仔<br />\n對佢地黎講錢根本係個慨念唔係數字<br />\n<br />\n所以我成日都話 心中富有就得<br />\n就算你係公屋仔 都可以好多人過得更加快樂"}]}