急需既前線同手足"},{"pid":"5d6bf1dfbc08f2d0143a9026cceb9cdb3efe75ad","tid":1873854,"uid":247798,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-11T02:07:47.000Z","msg":"推"},{"pid":"1ad0a7027f9bf2fb994bcfac4e090164f14d24a4","tid":1873854,"uid":36471,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-11T02:08:00.000Z","msg":"Push"},{"pid":"a1e7b50fbad8deae59bae9ef6da8f956b06147b5","tid":1873854,"uid":23639,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-11T02:08:13.000Z","msg":"推"},{"pid":"de91de434dad7e94c9d990a21c78b9cf689f8112","tid":1873854,"uid":23639,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-11T02:08:26.000Z","msg":"推"},{"pid":"ad3f438a7c276741536144b86ec94ed4caff75bd","tid":1873854,"uid":242889,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-11T02:27:33.000Z","msg":"推"},{"pid":"6ce7d902053fcfebb68e7e6987f26b793a039f92","tid":1873854,"uid":3206,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-11T02:40:21.000Z","msg":"咁耐都未見2盒THX<br />\n就知撲口罩嗰堆所謂&quot;手足&quot;有幾撚自私<br />\n一入黎見到講政治就上一頁 <br />\n睇都唔睇人地講乜<br />\n樓主做得好<br />\nsor我係有d偏激"},{"pid":"d8685da5ceb01f253d905a1a996e762684a677d4","tid":1873854,"uid":52839,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-11T02:44:17.000Z","msg":"幫推"},{"pid":"16d5d261c0a1e5d91a25f12b22a80af553b9b9e9","tid":1873854,"uid":329321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-11T02:46:42.000Z","msg":"push"},{"pid":"155c20b6ab4682d4d1eb6061822b4470711be9dd","tid":1873854,"uid":227851,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-11T02:46:45.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"05de22ab8619a9b484794add6cc833a52ff1fc4c","tid":1873854,"uid":299303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-11T02:47:28.000Z","msg":"P牌都推！"},{"pid":"33eeee265af8ce23f9454725c12e8cc77d25ffb6","tid":1873854,"uid":265824,"like":0,"dislike":0,"score":0,"