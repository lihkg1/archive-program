r />\n屌佢老母，香港本身行運絕大多數都係同種類，唔撚知幾時收咁多文化差異咁大嘅人，人地國際城市就吸人材，我地就吸埋一堆人霸住成條北河街。<br />\n仲有你以為剩係得假結婚，大把巴基斯坦佬嘅子女係姪，你吹得佢漲？"},{"pid":"62864dd0240c536f93045730762c46160a3b0335","tid":401870,"uid":29804,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-16T04:13:29.000Z","msg":"龍緯汶 弱智咁款"},{"pid":"be137e3fb05a6695af08eafe5d6f72a128542379","tid":401870,"uid":41205,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-16T04:14:03.000Z","msg":"張超雄<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"08306ae07935a412d9a95ede84c66bfab040f984","tid":401870,"uid":26218,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-16T04:16:04.000Z","msg":"同張超雄爭飯食<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"e23dda5d0ea41781e8668f70e00d8f5f9340a6c9","tid":401870,"uid":38982,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-16T04:17:20.000Z","msg":"香港ISIS<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"150f0798bc5ff9c8358f22e0b0d472c7aad388f4","tid":401870,"uid":94828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-16T04:18:32.000Z","msg":"<span style=\"font-size: xx-large;\">男童黨</span><br />\n<img src=\"/assets/faces/big/@.gif\" class=\"hkgmoji\" />"},{"pid":"de8aebe2e4119a56b2853730a496c83e6d022962","tid":401870,"uid":4550,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-16T04:22:04.000Z","msg":"有牌黑社會"},{"pid":"e65c9838edfc662ccf2cd1c54e8554ebbda76aaf","tid":401870,"uid":39871,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-16T04:24:24.000Z","msg":"伊斯蘭國<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"6c8dd9764888f94874726f44f2c0a02d0576492c","tid":401870,"uid":5419,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-16T04:34:24.000Z","msg":"強姦黨<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/a