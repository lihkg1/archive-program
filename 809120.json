uid":67225,"like":0,"dislike":0,"score":0,"quote":{"pid":"4a11bf7ca94ea41b055a1849f6a0b3dcc8dc33a2","tid":809120,"uid":34468,"like":13,"dislike":0,"score":13,"quote":{"pid":"8c537ca9ccc0d032e7b2d5a200a3cfa03a8faa23","tid":809120,"uid":42246,"like":7,"dislike":0,"score":7,"quote":{"pid":"bfa3caaabdc8da28b51d1b827e352d2dfb523d4d","tid":809120,"uid":3514,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-07T02:21:14.000Z","msg":"泰利個陣係咪有份迫鳩摩佬走<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-07T02:23:40.000Z","msg":"冇啦 早幾個星期 泰利係ig玩你問我答<br />\n有條友問 佢跟個最好既教練係？<br />\n泰利答daddy"},"citedBy":2,"replyTime":"2018-09-07T02:26:06.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/09/07/102551_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F07%2F102551_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=38b7988c&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-09-07T03:08:43.000Z","msg":"D摩性真係<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"d81a58f63c14803a16e585b6f522542ee623d396","tid":809120,"uid":60695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-07T03:14:32.000Z","msg":"曼聯已經準備好件26號波衫"},{"pid":"7a3f87aecca27dfacfb6545a3d15d14f27bbb603","tid":809120,"uid":30478,"like":2,"dislike":0,"score":2,"quote":{"pid":"c98d4fa54646699f9400ea3d7c60bdcc0ee54b3b","tid":809120,"uid":117187,"like":14,"dislike":0,"score":14,"citedBy":3,"replyTime":"2018-09-07T02:27:42.000Z","msg":"今次睇中咗邊個老婆<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-07T03:15:46.000Z","msg":"2018年9月7日 星期五 <br />\n下一篇上一篇<br />\n山神與女友分手 網民：曼聯「起死回生」<br />\n<br />\n【明報專訊】曼聯球星「山神」阿歷斯山齊士自年初由阿仙奴加盟後，屢被批評表現平庸。這名29歲智利前鋒近日於個人社交網站宣布與演員女友洛迪古斯分手，結束1年情。有網民指此舉或有助山神專注於比賽，成為曼聯重返正軌的契機。<br />\n<br />\n留言祝福對方永遠快樂<br />\n<br />\n山神於社交網站上載影片，片段中除有與女友的合照外，還附上以西班牙語撰寫的信息。山神指希望對方永遠快樂：「希望你未來幸福美滿，和你一起我度過了最好的時光，但我們決定了各走各路，尋找自己的夢想。」他又希望外界不要胡亂猜測及造謠，給予兩人空間及尊重。<br />\n<br />\n網民普遍對山神揮慧劍斬情絲予以支持，並表示此舉對曼聯是百利而無一害。更有網民指山神自加盟曼聯後至今只入3球，其分手的決定或有助他提高入球效率，助曼聯重返正軌和「起死回生」。<br />\n<br />\n<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"4acf1f2e95b3c59dd32c3b3eb46cddb9eadc8a67","tid":809120,"uid":53238,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-07T03:22:55.000Z","msg":"摩佬已經無哂契仔"},{"pid":"76b62fe06c89ca65d26e737510cb9be59f139f95","tid":809120,"uid":25754,"like":0,"dislike":0,"score":0,"quote":{"pid":"c98d4fa54646699f9400ea3d7c60bdcc0ee54b3b","tid":809120,"uid":117187,"like":14,"dislike":0,"score":14,"citedBy":3,"replyTime":"2018-09-07T02:27:42.000Z","msg":"今次睇中咗邊個老婆<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-07T03:25:17.000Z","msg":"摩狗老婆"},{"pid":"9a52be993ee8846f2a9908e07afd6938cf9169fa","tid":809120,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-07T03:25:17.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"229feb6a33c85ca8cbbdc3f4e88b3eeb560ddb72","tid":809120,"uid":117187,"like":0,"dislike":0,"score":0,"quote":{"pid":"76b62fe06c89ca65d26e737510cb9be59f139f95","tid":809120,"uid":25754,"like":0,"dislike":0,"score":0,"quote":{"pid":"c98d4fa54646699f9400ea3d7c60bdcc0ee54b3b","tid":809120,"uid":117187,"like":14,"dislike":0,"score":14,"citedBy":3,"replyTime":"2018-09-07T02:27:42.000Z","msg":"今次睇中咗邊個老婆<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-07T03:25:17.000Z","msg":"摩狗老婆"},"citedBy":0,"replyTime":"2018-09-07T03:26:30.000Z","msg":"食過返尋味<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},{"pid":"36e2d95feb2a7f10d3cba867b7df1a62869c9ad0","tid":809120,"uid":2772,"like":0,"dislike":1,"score":-1,"quote":{"pid":"7a3f87aecca27dfacfb6545a3d15d14f27bbb603","tid":809120,"uid":30478,"like":2,"dislike":0,"score":2,"qu