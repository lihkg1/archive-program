eplyTime":"2019-03-27T09:58:53.000Z","msg":"可惜冇錢"},{"pid":"4ca2d0df66d2f7e0b85e72e5a26af7a16a9002f7","tid":1076950,"uid":31098,"like":0,"dislike":0,"score":0,"quote":{"pid":"5cb971aff94d03fc776dfc055810d4a4d580cc86","tid":1076950,"uid":209773,"like":17,"dislike":0,"score":17,"citedBy":2,"replyTime":"2019-03-27T07:10:52.000Z","msg":"連啲非洲黑人都唔相信中國食物安全<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-27T10:01:47.000Z","msg":"連非洲人都醒過推介大灣區鯇魚魚生嗰個 <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"a7f113b9ea70608b4c4b8442e4af99294fd5e139","tid":1076950,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-28T13:27:47.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"52a6754150e60c9112e5b0281df0742ef7b01b39","tid":1076950,"uid":159870,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-28T14:00:38.000Z","msg":"據稱目前中國每年向肯尼亞出口的魚類產品達170萬美元，是三年前的兩倍還要多。<br />\n<br />\n屌你係香港買層樓都冇左<br />\n吹到貿易戰<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3a55b3341d5e341b19004378d18eed94dad2a325","tid":1076950,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-29T01:50:50.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"49ed76cfcab24ba6d9ef509c770a4b2b02ce380f","tid":1076950,"uid":3063,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-29T01:57:39.000Z","msg":"羅非魚唔係食屎嫁咩？"},{"pid":"7937ed0571fc97c8ca76543aa8b83a12d67780c1","tid":1076950,"uid":44199,"like":0,"dislike":0,"score":0,"quote":{"pid":"49ed76cfcab24ba6d9ef509c770a4b2b02ce380f","tid":1076950,"uid":3063,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-29T01:57:39.000Z","msg":"羅非魚唔係食屎嫁咩？"},"citedBy":1,"replyTime":"2019-03-29T04:15:16.000Z","msg":"即係街市當垃圾賣既非洲鯽"},{"pid":"7c8a4860382191d56df8f1b133f8b598d56ea6f7","tid":1076950,"uid":3063,"like":0,"dislike":0,"score":0,"quote":{"pid":"7937ed0571fc97c8ca76543aa8b83a12d67780c1","tid":1076950,"uid":44199,"like":0,"dislike":0,"score":0,"quote":{"pid":"49ed76cfcab24ba6d9ef509c770a4b2b02ce380f","tid":1076950,"uid":3063,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-29T01:57:39.000Z","msg":"羅非魚唔係食屎嫁咩？"},"citedBy":1,"replyTime":"2019-03-29T04:15:16.000Z","msg":"即係街市當垃圾賣既非洲鯽"},"citedBy":0,"replyTime":"2019-03-29T04:38:33.000Z","msg":"黃大仙明渠釣個隻"},{"pid":"69b29c5d3a5a633e009ac5305a4a48980360bfce","tid":1076950,"uid":24730,"like":1,"dislike":0,"score":1,"quote":{"pid":"7cb781bf0b8cf0e83419c00191cd90974a588c0b","tid":1076950,"uid":50526,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-03-27T09:56:45.000Z","msg":"周圍絕子絕孫式捕撈<br />\n人哋梗係冇晒魚啦<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-29T04:49:43.000Z","msg":"捉晒人地啲魚，然後賣自己啲魚畀人<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"f1206cd13925edf998664d56394314d382c5b4ce","tid":1076950,"uid":234658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-29T04:55:22.000Z","msg":"此回覆已被刪除"}]}