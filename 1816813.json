24:45.000Z","msg":"澳洲嘅後果<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"69a5ae44b59866fc54aab3e61b671711ea9b594f","tid":1816813,"uid":261913,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-01-08T14:27:04.000Z","msg":"變一萬香港人<br />\n九十九萬支那人<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"7b16979cfc7036e5329f65c0ca6bff3dbdbed618","tid":1816813,"uid":253016,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-01-08T14:30:28.000Z","msg":"chinada 支那豬的天堂"},{"pid":"ffd9734fd6121b088769c9a88438d1fed319086d","tid":1816813,"uid":186388,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-08T14:43:19.000Z","msg":"收嗮香港人！"},{"pid":"33db66e070ed3f5df2ceb264ef8d8bc6f96de245","tid":1816813,"uid":89514,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-01-08T14:46:23.000Z","msg":"此回覆已被刪除"},{"pid":"0dc6f12b8ebb2f31a38b50e51832068a896329cf","tid":1816813,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-08T23:28:07.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"558bc4705651c02548a1ddc6551a017aac42ec60","tid":1816813,"uid":57462,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-08T23:48:14.000Z","msg":"上年又話收緊唔比中國人移民<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />想變澳洲"},{"pid":"1ebf9d121bd49d190aac82d01f8bf2e76afcc73f","tid":1816813,"uid":20241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-08T23:51:53.000Z","msg":"非專業人士點先可以移民加拿大<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"67cfe55788c4382feb0560714f13270c3c75a358","tid":1816813,"uid":170249,"like":0,"dislike":0,"score":0,"quote":{"pid":"ffd9734fd6121b088769c9a88438d1fed319086d","tid":1816813,"uid":186388,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-08T14:43: