" class=\"hkgmoji\" />"},{"pid":"a0a94c742cdc66709cacd3a39f4fd84ddcdddc4b","tid":688084,"uid":90827,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-27T01:07:38.000Z","msg":"不如講左個結局出來先"},{"pid":"261cf37a543df6dfce7ba0aa0bd7cc8c50e31ca9","tid":688084,"uid":190657,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-26T01:45:56.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />文呢"},{"pid":"494401f57f3e69347a830f7cae059c18fb6243d2","tid":688084,"uid":7049,"like":0,"dislike":0,"score":0,"quote":{"pid":"261cf37a543df6dfce7ba0aa0bd7cc8c50e31ca9","tid":688084,"uid":190657,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-26T01:45:56.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />文呢"},"citedBy":1,"replyTime":"2019-04-26T14:22:55.000Z","msg":"爛尾<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}