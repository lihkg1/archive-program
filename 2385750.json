ad12fc0650f8d4ed22b22c","tid":2385750,"uid":124450,"like":3,"dislike":2,"score":1,"citedBy":0,"replyTime":"2021-01-30T02:26:36.000Z","msg":"老老豆豆<br />\n冇錢就唔好行電影製作條路<br />\n<br />\n荷里活好多導演都係有家底支持先拍到第一二套片<br />\n所以監製話事都冇計 因為錢唔係喺你度"},{"pid":"14bc252ac863e4042b53e38fbd068e79934d9272","tid":2385750,"uid":35712,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-01-30T02:28:43.000Z","msg":"記得有排d港產片真係爛都完全唔想睇"},{"pid":"169f38aa075e5ab663b0fd44852255db6188ccc2","tid":2385750,"uid":236359,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-01-30T02:39:57.000Z","msg":"垃圾投資方 改橋死全家"},{"pid":"3404df6948faf735c154f79a0207c8ce3a7c063d","tid":2385750,"uid":253223,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-30T02:45:36.000Z","msg":"未到位<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />拍開支戲？"},{"pid":"46f7fbae9226df2c41c73afb3cebf103ebbe09a8","tid":2385750,"uid":21141,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-30T03:35:47.000Z","msg":"電影呢行不嬲都係人脈大過天，香港咁細就更加小圈子<br />\n無論幾有才華，唔識人就企晒係到"},{"pid":"3b62e23d457c06ca6e0130aaac6a45cfe46b8860","tid":2385750,"uid":53498,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-30T05:19:27.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"}]}