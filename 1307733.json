.000Z","msg":"push"},{"pid":"0740690ffef8e2cb494fe11c3deee0767e42301e","tid":1307733,"uid":64948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T16:39:54.000Z","msg":"push"},{"pid":"6f1f3c98fb7546e28d685e7641ad4f3846cf0730","tid":1307733,"uid":64948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T23:56:21.000Z","msg":"推"},{"pid":"dc0fd0dfd3b4bd146ea4e049fdc2ea2b490ca43e","tid":1307733,"uid":64948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T23:56:48.000Z","msg":"推"},{"pid":"c95de41401a48253ffef60ed71fd4293498406cb","tid":1307733,"uid":77092,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T23:56:49.000Z","msg":"此回覆已被刪除"},{"pid":"7e357806c1976e4d561a2589875c672412fce513","tid":1307733,"uid":64948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T01:02:17.000Z","msg":"推"},{"pid":"ddb0fd79f08e8bc03083da4c8b9f04ae9b8b36cd","tid":1307733,"uid":39682,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T01:05:20.000Z","msg":"推，唔係好多人好似個哥仔咁頂得 <img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" />"},{"pid":"22ed4aeaf4bf6f8aeae913c64f179bdb10925f32","tid":1307733,"uid":28202,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-12T01:09:36.000Z","msg":"執業大律師陸偉雄接受《晴報》訪問時表示，市民的確可引用該條例行使「公民拘捕權」，但要注意當中存在一定風險，有多項重點要注意，切勿濫用。<br />\n<br />\n    （一）只適用於「可逮捕的罪行」<br />\n<br />\n    根據資料，「可逮捕的罪行」是指可判處超過12個月監禁的罪行，但陸偉雄指在牆上貼便條、撕下他人的便條、互相推撞等均不屬此列，襲擊、傷人、謀殺、縱火等則屬可逮捕的罪行，「但一般市民有機會錯誤判斷」，一旦誤用有機會構成「非法禁錮」等罪行。<br />\n<br />\n    （二）誤傷疑犯可反被指控<br />\n<br />\n    陸偉雄提醒，市民制服疑犯時只可使用合理武力，包括不可故意傷害疑犯，然而疑犯有可能奮力反抗掙扎，即使使用合理武力，過程中仍有機會誤傷疑犯，令其扭傷手、骨折等，仍然有機會構成「襲擊」等罪行。<br />\n<br />\n    （三）拍攝影片須紀錄完整過程<br />\n<br />\n    常言道「有片有真相」，惟陸偉雄提醒用作舉證的影片，愈完全紀錄整個衝突過程，愈是有力證據，相反如只拍頭、拍尾，或曾被剪輯、修改均影響其可信性，同時對方亦會對影片真實性提出質疑。<br />\n<br />\n陸偉雄認為亂用「101拘捕令」可帶來嚴重後果，就如去年大圍車房命案，3人協助捉賊時疑犯在過程中突然離世，令各人捲入誤殺案，雖然最終獲撤銷控罪，惹上官非卻令他們失去數個月的自由。"},{"pid":"b04f439ce9f7437980a2f17dad47d980ef205001","tid":1307733,"uid":26846,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-12T01:10:27.000Z","msg":"吹奏比人打個班 完全反人性"},{"pid":"4096f5488b5a8c3d7cc9ee1247d372d3952b0e82","tid":1307733,"uid":64948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T01:16:22.000Z","msg":"推"},{"pid":"0ad5479e00c24311b717f621353c61865b0f8106","tid":1307733,"uid":64948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T01:34:07.000Z","msg":"推"},{"pid":"040336553a7914654d695742bbf9953d0cbdec4f","tid":1307733,"uid":143499,"like":0,"dislike":0,"score":0,"quote":{"pid":"12606308fb40a6ccb299fc8d16a43c3efb5f3492","tid":1307733,"uid":64948,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-11T16:34:02.000Z","msg":"大埔有同路人比人打到骨裂之後<br />\n唔好再同我講面對班藍絲要打不還手<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n你地成日講以武制暴，又驚打完人比班狗告<br />\n而家就教精你，打完人都唔會有事<br />\n有無聽過<span style=\"font-size: xx-large;\"><span style=\"color: red;\">101拘捕令A條呀</span></span><br />\n<br />\n<span style=\"font-size: xx-large;\">下次比班藍絲打個陣，做足以下步驟:<br />\n1.對方郁手，請即還拖<br />\n2.叫身邊人開始拍片（呢樣唔難呀<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />你地咁撚鐘意見到有人比人打就影人），拍低以下你要講既野<br />\n<span style=\"color: red;\">你剛剛干犯左傷人罪行，我而家(?)點(?)分報警求助，係警察來到前，你唔可以逃跑，反抗，否則我會用「101拘捕令A條」賦予既市民拘捕權，用合理適當既武力將你制服直至到你唔再反抗，逃跑，或警察到達現場</span></span><br />\n<br />\n唔好再同我講比人打要和理非<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">仁者無勇 便成犬儒</span></span>"},"citedBy":0,"replyTime":"2019-07-12T01:43:18.000Z","msg":"香港人會政治潔癖，仲有好多係懦夫<br />\n<br />\n上次三十幾人圍住一個阿叔， 阿叔打完人仲可以拍下蘿柚就走人，完全冇人阻止佢"},{"pid":"bef0c97de5a8d051efc65c1ff8e964b3dc704d93","tid":1307733,"uid":25108,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-12T01:46:27.000Z","msg":"（二）誤傷疑犯可反被指控<br />\n<br />\n陸偉雄提醒，市民制服疑犯時只可使用合理武力，包括不可故意傷害疑犯，然而疑犯有可能奮力反抗掙扎，即使使用合理武力，過程中仍有機會誤傷疑犯，令其扭傷手、骨折等，仍然有機會構成「襲擊」等罪行。<br />\n<br />\n咁佢反抗就肯定會受傷架啦<br />\n點會唔反抗俾你捉<br />\n其實101都幾廢<br />\n樓主講既直接還拖就俾人拉埋返去告打鬥"}]}