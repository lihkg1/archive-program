se/pray.gif\" class=\"hkgmoji\" />"},{"pid":"56ee4e033c737234c45c751748bf3654924edd55","tid":2424623,"uid":280475,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-26T18:42:23.000Z","msg":"好人一生平安"},{"pid":"d2ef4b9c26b9784b3e6d01d4dacd09d49ac1c0f7","tid":2424623,"uid":12572,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-26T18:43:27.000Z","msg":"推 我公公都有呢個病<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" /><br />\n前前後後入左好多次醫院切腸 切得無得到切了"},{"pid":"b8784ffbdddc5405fbccf7afd81d39c4464b4f28","tid":2424623,"uid":99871,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-26T18:47:24.000Z","msg":"輕輕一推 又學到d新野<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><br />\n本身自己都係胃好虧既人 所以好明"},{"pid":"847b4899fc6916a22401be794f77b0695834557c","tid":2424623,"uid":363816,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T18:50:13.000Z","msg":"推"},{"pid":"7a175eae2675b1558dd2952bbc0837c1f2bb8686","tid":2424623,"uid":126382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T19:03:44.000Z","msg":"推俾餅仔睇"},{"pid":"7d2f336f734049727316aff5a169e0ed3c590a23","tid":2424623,"uid":229068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T19:45:25.000Z","msg":"<img src=\"/assets/faces/cow/gold.gif\" class=\"hkgmoji\" />"},{"pid":"8fdba998481de9d0844fbf091f8a4e6d84b6d189","tid":2424623,"uid":135040,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T19:49:50.000Z","msg":"入黎!!"},{"pid":"66986bb4d07ae21981dda544179599f29d1c4997","tid":2424623,"uid":48222,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T20:03:23.000Z","msg":"pish"}]}