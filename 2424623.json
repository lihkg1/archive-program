f\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e21046d1fc775e0d78fe7bbfc2c428171f0ee5ef","tid":2424623,"uid":375563,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2021-02-26T17:50:11.000Z","msg":"P牌推唔到 但幫手！"},{"pid":"4c07050db16dc39c3b634d2aea84f4022a80eaa3","tid":2424623,"uid":26708,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-26T17:50:42.000Z","msg":"<img src=\"/assets/faces/dog/discover.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"f835e719d24fd08cc7d4a118d5128df732b00b2e","tid":2424623,"uid":26708,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-26T17:50:59.000Z","msg":"<img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/sad.gif\" class=\"hkgmoji\" />"},{"pid":"9ac62d2550cfd8e9f79de69b6a45922cede8e8cb","tid":2424623,"uid":26708,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-26T17:51:20.000Z","msg":"<img src=\"/assets/faces/cow/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"e9483bf292e9756118802a4f55941d14dc3c9acd","tid":2424623,"uid":26708,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e21046d1fc775e0d78fe7bbfc2c428171f0ee5ef","tid":2424623,"uid":375563,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2021-02-26T17:50:11.000Z","msg":"P牌推唔到 但幫手！"},"citedBy":0,"replyTime":"2021-02-26T17:51:33.000Z","msg":"<img src=\"/assets/faces/