過身比啲有宗教既親人屈咗做基督教追思會。好撚反感。<br />\n<br />\n最後係叮囑屋企人要好好照顧自己，養多幾隻小動物陪伴自己的，唔好太寂寞，就算我唔係到都一直愛住佢地。"},{"pid":"50646e5363a0e6505d220d9a6fc552107027da52","tid":908853,"uid":96080,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a79b7997281f020ed8f5eebf22208b0a1acfaec","tid":908853,"uid":111842,"like":1,"dislike":0,"score":1,"quote":{"pid":"4eaaef43c61217110c7ec03cb838a914f155654a","tid":908853,"uid":96080,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-20T02:23:59.000Z","msg":"用咩方法離開？"},"citedBy":2,"replyTime":"2018-11-20T03:17:31.000Z","msg":"應該燒炭"},"citedBy":0,"replyTime":"2018-11-20T03:59:24.000Z","msg":"酒店？"},{"pid":"1db0922f2a3ead6417f9984f6bd49cbff1ef6d00","tid":908853,"uid":97451,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-20T04:17:31.000Z","msg":"此回覆已被刪除"}]}