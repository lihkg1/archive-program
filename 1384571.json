hatsapp"},{"pid":"ba11aa9df9a34ae381c15e700b694655451fada0","tid":1384571,"uid":77416,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T02:23:25.000Z","msg":"push"},{"pid":"e1b95dd78c87b8784ac8db4638eecb71be235f1c","tid":1384571,"uid":265048,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-30T02:24:38.000Z","msg":"小建議 個人覺得web base 好過App<br />\n資料容易handle"},{"pid":"fe42daa38576672e2a7ef2740fba034eda1ecc1e","tid":1384571,"uid":62790,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2019-07-30T02:25:29.000Z","msg":"寫 TG bot 仲快仲好。更難俾狗 trace 到..."},{"pid":"0c324eff1e11c68d52757546f21822e40ccabd04","tid":1384571,"uid":229607,"like":0,"dislike":0,"score":0,"quote":{"pid":"2bd2e0efa5b467ae3e333a9e66cee1262cb21389","tid":1384571,"uid":161848,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-07-30T02:22:12.000Z","msg":"等於暴露義士行蹤<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-30T02:26:01.000Z","msg":"係架，每樣pre-plan 既行動都一定會有被暴露行動既風險，所以就要係度問，鬼車同鬼客風險大，定係App被滲透風險大，同埋有無辦法匿名但又可以認到人定鬼既方法"},{"pid":"92c01917de318ff3309b1eb6b8f32e9b5ba5953d","tid":1384571,"uid":62790,"like":0,"dislike":0,"score":0,"quote":{"pid":"e1b95dd78c87b8784ac8db4638eecb71be235f1c","tid":1384571,"uid":265048,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-30T02:24:38.000Z","msg":"小建議 個人覺得web base 好過App<br />\n資料容易handle"},"citedBy":1,"replyTime":"2019-07-30T02:26:03.000Z","msg":"web-based 太 open , 易俾人放蛇落trap"},{"pid":"f15e07a68c6effa55a6fc3b886058cd9107fe9cd","tid":1384571,"uid":259191,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T02:26:14.000Z","msg":"push"},{"pid":"a6adcacfde87cf8027563b57b616bbf86dd8499a","tid":1384571,"uid":122167,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-30T02:28:05.000Z","msg":"一陣差佬扮義載, 車你返差館 <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"77e1900