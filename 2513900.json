4d31e7e12c368b8051b6","tid":2513900,"uid":168138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-03T03:30:43.000Z","msg":"操你媽B<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2b38684a6759194c100e1af68576e78d5030c40e","tid":2513900,"uid":168138,"like":0,"dislike":0,"score":0,"quote":{"pid":"36aa3541d8501e73c43fd9d15bae48dc92edae49","tid":2513900,"uid":366655,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-05-03T03:29:50.000Z","msg":"男人打丁po一入就有片<br />\n依啲po link都無條<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-05-03T03:31:00.000Z","msg":"因為佢真係好柒<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e60c3695d4bcedad7d718faa415fcbedbae36cc9","tid":2513900,"uid":351574,"like":1,"dislike":0,"score":1,"quote":{"pid":"45a834afd8df355cacc8b6983303ea59a6191774","tid":2513900,"uid":16659,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-03T01:58:47.000Z","msg":"<img src=\"https://hk.appledaily.com/resizer/8qTNyXPRO6dyXgbf83iAnzoKn48=/802x451/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/TU6YBOJVTZBRHL27ZHNY5DKP3E.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2F8qTNyXPRO6dyXgbf83iAnzoKn48%3D%2F802x451%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FTU6YBOJVTZBRHL27ZHNY5DKP3E.jpg&h=65c78a60&s={SIZE}\" /><br />\n<br />\n中國籍AV女優陳美惠今年甫入行即是非多多，早前她自爆失業，並在社交網出售着過的胸圍及底褲賺生活費，又傳出已婚扮單身，更懷疑出蠱惑來騙fans金錢。<br />\n<br />\n據陳美惠表示，她由6歲起就隨父母到日本長居，20年來沒有返回中國，不過陳美惠跟父母關係欠佳，她從18歲時便選擇離家出走。近日，陳美惠在Twitter自爆全家已知道她下海拍AV，公開母親傳給她的訊息，其母寫了：「今天小舅都告訴我了，為甚麼不接電話？你真會為我們老刑家丟人，你活着你自己的為甚麼要給你爸丟臉，我真的後悔生了你。」陳美惠之後再發文回應，指與家人10年沒有來往卻來電痛罵，她自言：「就因為這件事情，我已經拍了，沒法再回頭了，要恨就恨你們自己生了我這樣的窩囊廢。」網民就叫她千萬不要回到中國。<br />\n<img src=\"https://hk.appledaily.com/resizer/xVyVg6gPxcg0cGGnwpfO-ntg7Zk=/802x1262/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/QNNSACQTYNFU7OH6KOJ6FLJ34I.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FxVyVg6gPxcg0cGGnwpfO-ntg7Zk%3D%2F802x1262%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FQNNSACQTYNFU7OH6KOJ6FLJ34I.jpg&h=ba7e198c&s={SIZE}\" /><br />\n<img src=\"https://hk.appledaily.com/resizer/VKYPES44V3DVeg_sbRDzA89d2DM=/802x1205/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/7GKTFTS5BFDP5P7IYYQGA7U5FA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FVKYPES44V3DVeg_sbRDzA89d2DM%3D%2F802x1205%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2F7GKTFTS5BFDP5P7IYYQGA7U5FA.jpg&h=9120a727&s={SIZE}\" /><br />\n<img src=\"https://hk.appledaily.com/resizer/DLrNUNcMHqW-sY07hhuLXlCjQyQ=/802x460/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/DMQL7L5GYRFGBAO5GURGIFIG34.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FDLrNUNcMHqW-sY07hhuLXlCjQyQ%3D%2F802x460%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FDMQL7L5GYRFGBAO5GURGIFIG34.jpg&h=8794826f&s={SIZE}\" /><br />\n<br />\n<a href=\"https://hk.appledaily.com/entertainment/20210503/SH2XZSPY65FJLCNU4GQXWR6DC4/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Fentertainment%2F20210503%2FSH2XZSPY65FJLCNU4GQXWR6DC4%2F&d=LCDPOb8M8FyYKm9nuxOGtb32HZRMtn4xjJY4gFhUisg%3D&h=29e9d539\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Fentertainment%2F20210503%2FSH2XZSPY65FJLCNU4GQXWR6DC4%2F&h=6ce893cc\" data-auto-link target=\"_blank\">https://hk.appledaily.com/entertainment/20210503/SH2XZSPY65FJLCNU4GQXWR6DC4/</a>"},"citedBy":0,"replyTime":"2021-05-03T03:33:54.000Z","msg":"<a href=\"https://www.dmm.co.jp/digital/videoa/-/detail/=/ci