ss=\"hkgmoji\" />"},{"pid":"246b6428d7b417b9ff7ff5f0985114231a08da59","tid":2058154,"uid":288675,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-10T04:48:09.000Z","msg":"企最硬係佢 個時"},{"pid":"a2e67fa2b398bf2d43aa73bbd25a8574f6ee2533","tid":2058154,"uid":19437,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-10T04:49:20.000Z","msg":"認你陰鳩妹妹啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f5d26e2717af07c52000a3e3d8cf643d697a8f92","tid":2058154,"uid":52605,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-10T04:52:04.000Z","msg":"葉劉姐姐 再嘈你妹妹踢埋你出局呀嗱"},{"pid":"2509d1722403425e52a2b08970ae889b1a36d389","tid":2058154,"uid":30246,"like":6,"dislike":0,"score":6,"quote":{"pid":"b7039205527b9a779d2de35f5c3d1ebc08b7460b","tid":2058154,"uid":221343,"like":83,"dislike":1,"score":82,"citedBy":2,"replyTime":"2020-06-10T02:58:10.000Z","msg":"你自己都有份支持，扮嘢<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-10T04:54:35.000Z","msg":"《逃犯條例》修訂爭議引發大規模警民衝突，陳智思、湯家驊、林健鋒等行會成員今日口風都似乎軟化，稱目前不可能繼續審議條例，個人不反對擱置，但<span style=\"color: red;\">同屬行政會議成員葉劉淑儀企硬，表示未有得悉政府會撤回條例，堅持修例「有利而無害」</span>，指《逃犯條例》是「送中」，這說法是「不負責任的謊言」，同時指責台灣總統蔡英文以政治立場凌駕公義。<br />\n<br />\n<span style=\"color: red;\">葉劉淑儀表示，至今無聽到政府撤回條例，首要工作是要通過</span>，議員可以安全開會，呼籲市民表達訴求時不要訴諸暴力，她又分別以中英文，多次稱<span style=\"color: red;\">修改的《逃犯條例》並非「惡法」，反而「有利而無害」</span>，市民不需要擔心，更批評有人形容修例等同「送中」是「不負責任的謊言」。<br />\n<br />\n葉劉淑儀提及擱置修例，是等同於撤回，又說「政府面對痛苦嘅選擇」，<span style=\"color: red;\">強調政府若過屈服，會損害香港的未來。</span>葉劉淑儀又指責台灣領導人，表示「政治立場不能凌駕公義」。被問到若支持修例，可能會在明年立法會選舉失去支持，葉劉淑儀指修例通過後，會向市民解釋。她又表示周三政總外的示威，有議員「好驚」，贊同警方的行動是「防禦性」，又指示威者有很多武器，警方只是「逼不得已」才使用布袋彈、催淚彈等。<br />\n<br />\n<a href=\"https://www.thestandnews.com/politics/%E5%8F%8D%E9%80%81%E4%B8%AD-%E8%91%89%E5%8A%89%E6%B7%91%E5%84%80%E4%BC%81%E7%A1%AC-%E6%88%91%E5%86%87%E8%81%BD%E5%88%B0%E8%A9%B1%E8%A6%81%E6%92%A4%E5%9B%9E/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E5%258F%258D%25E9%2580%2581%25E4%25B8%25AD-%25E8%2591%2589%25E5%258A%2589%25E6%25B7%2591%25E5%2584%2580%25E4%25BC%2581%25E7%25A1%25AC-%25E6%2588%2591%25E5%2586%2587%25E8%2581%25BD%25E5%2588%25B0%25E8%25A9%25B1%25E8%25A6%2581%25E6%2592%25A4%25E5%259B%259E%2F&d=TNVh%2FXBsTmD9bRjMILuVa%2FzGhZJjjhZ%2BTSWVZI8Eykc%3D&h=b851c247\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E5%258F%258D%25E9%2580%2581%25E4%25B8%25AD-%25E8%2591%2589%25E5%258A%2589%25E6%25B7%2591%25E5%2584%2580%25E4%25BC%2581%25E7%25A1%25AC-%25E6%2588%2591%25E5%2586%2587%25E8%2581%25BD%25E5%2588%25B0%25E8%25A9%25B1%25E8%25A6%2581%25E6%2592%25A4%25E5%259B%259E%2F&h=a516c9dc\" data-auto-link target=\"_blank\">https://www.thestandnews.com/politics/%E5%8F%8D%E9%80%81%E4%B8%AD-%E8%91%89%E5%8A%89%E6%B7%91%E5%84%80%E4%BC%81%E7%A1%AC-%E6%88%91%E5%86%87%E8%81%BD%E5%88%B0%E8%A9%B1%E8%A6%81%E6%92%A4%E5%9B%9E/</a>"},{"pid":"dc8e8d7f98abef4cbf75e75843939286368782f0","tid":2058154,"uid":74171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-10T04:57:09.000Z","msg":"訓咗幾耐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cc6909f7e8fc7734ed282d154b945c3ef75d628c","tid":2058154,"uid":46933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-10T04:57:37.000Z","msg":"姐姐沒盡到責任指導不濟的妹妹<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"b3ac1c1a14a238a9f8f229d29a673722836b1e6c","tid":2058154,"uid":180293,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-10T04:58:10.000Z","msg":"最主要係 企開D啦 你講野不論黃藍其實都冇人會聽<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b61633eb585738b4ee959bdb1955d22575eb6d32","tid":2058154,"uid":160747,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-10T04:58:51.00