ime":"2020-05-03T15:32:21.000Z","msg":"希望係真"},{"pid":"881bfec9de38afe959d855d1d73f3579a3266d37","tid":1999922,"uid":55810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-03T15:34:43.000Z","msg":"即刻申請個ac入嚟睇<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1e916c2dfb25942d11aac3ccbf2976e761fae4e2","tid":1999922,"uid":302783,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-03T15:39:14.000Z","msg":"多謝樓主 而家溫定先<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />5星星有望"},{"pid":"805e99591f9bb4022df76a8f90f4ed568cde32a3","tid":1999922,"uid":333026,"like":0,"dislike":0,"score":0,"quote":{"pid":"99250487c177e49e945bd1c580c1124c2b13084b","tid":1999922,"uid":200521,"like":2,"dislike":0,"score":2,"quote":{"pid":"974aea8653b2d694ca9d93a35ab11bb2fce20ff9","tid":1999922,"uid":333026,"like":1,"dislike":0,"score":1,"quote":{"pid":"aecdc5994d2e2b89067d7aa512c7ab8bd5f3c968","tid":1999922,"uid":175523,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-05-03T13:34:11.000Z","msg":"成個連登故咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-03T14:58:19.000Z","msg":"蒲松齡走得太前<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-03T15:16:45.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-03T15:43:48.000Z","msg":"<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},{"pid":"d61b49e23df74624e421cf15107446b449376909","tid":1999922,"uid":236193,"like":0,"dislike":0,"score":0,"quote":{"pid":"7c7cab7a5aea1031c80c4db1e3757f9217a3704a","tid":1999922,"uid":200521,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-05-03T13:22:57.000Z","msg":"啱啱收到內幕消息，聽日會出聊齋誌異入面一個小篇章。快啲溫熟個譯文！<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n以下僅限會員，記得唔好亂咁send<img src=\"/assets/faces/lm2/ok.gif\" class=\"hkgmoji\" />：<br />\n<br />\n<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-05-03T15:56:40.000Z","msg":"樓豬，聽日出我切<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"bf0ad21a7cf1c15c585b5079762cf91a99697ee9","tid":1999922,"uid":200521,"like":0,"dislike":0,"score":0,"quote":{"pid":"d61b49e23df74624e421cf15107446b449376909","tid":1999922,"uid":236193,"like":0,"dislike":0,"score":0,"quote":{"pid":"7c7cab7a5aea1031c80c4db1e3757f9217a3704a","tid":1999922,"uid":200521,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-05-03T13:22:57.000Z","msg":"啱啱收到內幕消息，聽日會出聊齋誌異入面一個小篇章。快啲溫熟個譯文！<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n以下僅限會員，記得唔好亂咁send<img src=\"/assets/faces/lm2/ok.gif\" class=\"hkgmoji\" />：<br />\n<br />\n<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-05-03T15:56:40.000Z","msg":"樓豬，聽日出我切<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-03T16:14:34.000Z","msg":"咁你可以切定先了。<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"1d6342195f5cac6e757c5b2b0dc3b70303b63851","tid":1999922,"uid":207799,"like":0,"dislike":0,"score":0,"quote":{"pid":"d61b49e23df74624e421cf15107446b449376909","tid":1999922,"uid":236193,"like":0,"dislike":0,"score":0,"quote":{"pid":"7c7cab7a5aea1031c80c4db1e3757f9217a3704a","tid":1999922,"uid":200521,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-05-03T13:22:57.000Z","msg":"啱啱收到內幕消息，聽日會出聊齋誌異入面一個小篇章。快啲溫熟個譯文！<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n以下僅限會員，記得唔好亂咁send<img src=\"/assets/faces/lm2/ok.gif\" class=\"hkgmoji\" />：<br />\n<br />\n<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-05-03T15:56:40.000Z","msg":"樓豬，聽日出我切<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-03T16:16:56.000Z","msg":"我跟 利申聽日考"},{"pid":"41f0652937f88b602c37cdf52a7aef330f2d885b","tid":1999922,"uid":302752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-03T16:17:31.000Z","msg":"LM <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5976aabf94ba09f8e50565175b67f1950a07306f","tid":1999922,"uid":206115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-03T16:24:32.000Z","msg":"欣屍學生冇福了"},{"pid":"ec65433f6cab4b27b2412b3c0c2cf5a1e45b94ff","tid":1999922,"uid":48362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-03T16:25:34.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"000ead184c82a71d9cb18bf89ab694accf7ef02a","tid":1999922,"uid":129042,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-03T16:28:45.000Z","msg":"多謝樓主"}]}