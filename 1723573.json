le=\"color: green;\"><span style=\"font-size: x-large;\">唔想佢嘅學生, 什至前線勇武精英最後被大圍捕殲滅, 絕對唔係割蔗之意.</span></span><br />\n<br />\n請大家都勤下身邊嘅人冷靜分析下<br />\n<br />\n#核彈都唔割<br />\n#光復香港 時代革命<br />\n#Bewater"},{"pid":"4bba218d75d5be7a09dd57da77c5de0af7b0f7bc","tid":1723573,"uid":150152,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-11-15T08:56:44.000Z","msg":"乜都私了，係咪濫用左呀"},{"pid":"e2e567eb0c6488b15f8c9276fdfbe987d8966578","tid":1723573,"uid":92347,"like":0,"dislike":0,"score":0,"quote":{"pid":"34459c55881ff27ba3213adceb63031b6accddc1","tid":1723573,"uid":1734,"like":0,"dislike":0,"score":0,"citedBy":5,"replyTime":"2019-11-15T08:31:42.000Z","msg":"佢老母成日出賣中大人 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-15T09:05:49.000Z","msg":"吹風之後MON POST狗你地又可以放大件事黎講?"},{"pid":"d63e12b6f0de22a08325d7985670ce8783b692ce","tid":1723573,"uid":179837,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T09:07:36.000Z","msg":"拉"},{"pid":"1234258f8d807aa06472cf1efacb117a5dd03f0f","tid":1723573,"uid":97104,"like":0,"dislike":0,"score":0,"quote":{"pid":"34459c55881ff27ba3213adceb63031b6accddc1","tid":1723573,"uid":1734,"like":0,"dislike":0,"score":0,"citedBy":5,"replyTime":"2019-11-15T08:31:42.000Z","msg":"佢老母成日出賣中大人 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-15T09:07:50.000Z","msg":"佢全家俾中共夾住"}]}