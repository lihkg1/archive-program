ets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"ab9023e5fa2277a1fa49c0f2c56f70846176cfc6","tid":2089283,"uid":154406,"like":0,"dislike":0,"score":0,"quote":{"pid":"bdf6158e05fcbb89af2bcb642670a604f58969e3","tid":2089283,"uid":60658,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-01T14:50:01.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-01T14:52:25.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"8862b9dd13ca02a9a7c62cadba2c2034d401d3e5","tid":2089283,"uid":134997,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b190bbda41227d3e3d4d20c5980052e7f7c1de8","tid":2089283,"uid":19552,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-01T14:52:23.000Z","msg":"頭先時代廣場打到好癲 黑警封晒個場黎打人唔比記者入<br />\n但時事台比bno洗晒板<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-01T14:54:27.000Z","msg":"今日比人拉嗰班慘撚到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 希望佢地出返嚟牙爺無咁惡<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d869627c3f5185c9e463e70dd8391de79ca6af38","tid":2089283,"uid":153,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-01T14:57:44.000Z","msg":"手足齊上齊落<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"201deee402357694e5cef4b724a15e00400abc8a","tid":2089283,"uid":304769,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-01T15:35:35.000Z","msg":"BNO平權正視聽<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">黑色五毛分化警告，大量五毛正在用藍絲有BNO、走人對唔住97後割97後等風向進行分化</span></span></strong>，大家小心。<br />\n<br />\n1.<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">大家比人拉過/有小朋友（細路是重點，香港未來棟樑，正如今時今日d前線義士，咪比佢地洗腦變小糞紅，否則香港係真正玩完）的話就應該即刻走</span></span></strong>，其他人亦應該起碼做好隨時走既準備，<strong><span style=\"font-size: x-large;\"><span style=\"color: green;\">香港抗爭運動已經由本土抗爭升級為準國際戰爭， 我們能做的十分有限。 相反大家離開或準備好隨時可以離開，則美國及其盟友可以隨時採取行動，對香港進行制裁，令香港達至零經濟活動， 甚至日後作出軍事行動亦無需擔心誤傷香港人。</span></span></strong> 而且大家亦可用移民理由提取所有資產及強積金進一步<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">打擊香港的財政儲備</span></span></strong>。<br />\n而且多人走亦可以起到掩護最需要走既手足，救奶左野手足係目前最重要既事。<br />\n<br />\n2.大家<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">無需擔心藍絲以及黑警移民英國</span></span></strong>，藍絲得兩種a.垃圾b.收成期，a.涯唔到六年移民監b.揾錢唔捨得走/走要承受巨大損失<br />\n<br />\n重點：大家<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">不應該反對平權或現階段設立篩選，因為這樣會妨礙奶左野手足逃難</span></span></strong>。反而，大家應該在藍絲移民英國後再篤灰。大家，要記住，<strong><span style=\"font-size: x-large;\"><span style=\"color: green;\">篤灰係一把藍絲頭上既利劍，一日未入籍一日都嚮度，我就係要佢地嚮英國每一日都擔心比人篤灰，呢樣恐懼做為懲罰先係最大懲罰</span></span></strong>。<br />\n<br />\n3.<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">97後手足唔會被割</span></span></strong>，首先，佢地可以跟BNO父母及配偶前往英國。第二，對於<strong><span style=\"font-size: x-large;\"><span style=\"color: green;\">未受BNO平權保障嘅人佢哋仲有美國既救生艇計劃</span></span></strong>，該計劃估計幾日內亦會通過。"},{"pid":"b2eb14297b8ffd9ce2b6a383ecb5b08b0bab9741","tid":2089283,"uid":316927,"like":0,"dislike":0,"score":0,"quote":{"pid":"201deee402357694e5cef4b724a15e00400abc8a","tid":2089283,"uid":304769,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-01T15:35:35.000Z","msg":"BNO平權正視聽<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">黑色五毛分化警告，大量五毛正在用藍絲有BNO、走人對唔住97後割97後等風向進行分化</span></span></strong>，大家小心。<br />\n<br />\n1.<strong><span style=\"font-size: x-large;\"><span style=\"color: red