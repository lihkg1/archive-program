rc=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-14T03:51:31.000Z","msg":"<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"155a34989e36660e47af9baad9701740532c6901","tid":1060392,"uid":220985,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec85bf6752da0b2dec96ec22452f58d666830bd4","tid":1060392,"uid":122570,"like":1,"dislike":0,"score":1,"quote":{"pid":"13431619b6a65571d84dc4b41b2588fc12008e51","tid":1060392,"uid":220985,"like":0,"dislike":0,"score":0,"quote":{"pid":"9149f873d103e86eee3d4059dddf4aaecff06737","tid":1060392,"uid":122570,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-03-14T02:18:12.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-14T03:32:01.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-03-14T03:48:36.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-14T03:54:42.000Z","msg":"<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />"},{"pid":"d798c99a140e231974328627188b7b41e1cfca0f","tid":1060392,"uid":122570,"like":3,"dislike":0,"score":3,"quote":{"pid":"155a34989e36660e47af9baad9701740532c6901","tid":1060392,"uid":220985,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec85bf6752da0b2dec96ec22452f58d666830bd4","tid":1060392,"uid":122570,"like":1,"dislike":0,"score":1,"quote":{"pid":"13431619b6a65571d84dc4b41b2588fc12008e51","tid":1060392,"uid":220985,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-14T03:32:01.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-03-14T03:48:36.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-14T03:54:42.000Z","msg":"<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-14T03:57:07.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"95388565c5c7b1ca7dff8f1e5087766ddad4e43f","tid":1060392,"uid":60731,"like":13,"dislike":0,"score":13,"citedBy":1,"replyTime":"2019-03-14T04:17:45.000Z","msg":"唔啱聽的說話你想唔想聽?<br />\n忘記一段感情的最好方法, 一係搵過個一係等時間過<br />\n若然都係唔work, 就一係新的唔夠好, 一係時間唔夠耐<br />\n我都係過來人, 我都沉左3年時間<br />\n三年黎, 我做左好多以前無時間做, 同由細到大都想做的野<br />\n本來只係識打機上高登, 用呢三年時間學識<br />\n品酒, 沖咖啡, 影相, 交響樂, 書法, 油畫<br />\n行書店畫廊酒窖的時間多過以前行信和一倍<br />\n慢慢發覺, 其實我一直以黎念念不忘的只係一段回憶<br />\n如果呢一刻佢出現喺我面前, 有機會同我喺返埋一齊<br />\n我會點? 我地會點?<br />\n無可能100%似以前一樣, 無論如何有d野發生左就係發生左<br />\n無論佢會點彌補, 我有幾寬容, 我地之間點都無可能再好似以前咁<br />\n佢帽左我, 的確佢係做過<br />\n<br />\n原來, 我三年黎執著緊的只係一堆美好的回憶<br />\n咁樣無必要去刻意忘記佢<br />\n只要諗通左由一個「人」變到一件「事」咁去看待<br />\n我成個人都放鬆曬<br />\n到今時今日我都無忘記我曾經咁開心過<br />\n所以今時今日的我比以前更開心"},{"pid":"03743c187e2700af87cb8e2f7b403015fc118547","tid":1060392,"uid":27907,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-03-14T04:29:22.000Z","msg":"拍左7年 宜家分左手差唔多一年<br />\n都仲係日日諗起 <br />\n頭幾個月晚晚飲酒先訓到覺<br />\n宜家叫好少少 但係都係放唔低<br />\n甚至佢已經同左人一齊 我都仲係想等佢 <br />\n會希望自己改好 有一日佢可能會返嚟<br />\n有試過做gym 做運動 返多份工 溝女 填滿哂啲時間<br />\n但係就算同緊第個女仔出街都係會諗起個佢 <br />\n有啲咩事有咩煩惱都剩係想同佢講<br />\n 剩係最信任係佢 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n朋友傾過勸過屌過 我都move on唔到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"fb8e6f19295ccc82daefe16e13f477f5bddd75f8","tid":1060392,"uid":21187,"like":1,"dislike":0,"score":1,"quote":{"pid":"03743c187e2700af87cb8e2f7b403015fc118547","tid":1060392,"uid":27907,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-03-14T04:29:22.000Z","msg":"拍左7年 宜家分左手差唔多一年<br />\n都仲係日日諗起 <br />\n頭幾個月晚晚飲酒先訓到覺<br />\n宜家叫好少少 但係都係放唔低<br />\n甚至佢已經同左人一齊 我都仲係想等佢 <br />\n會希望自己改好 有一日佢可能會返嚟<br />\n有試過做gym 做運動 返多份工 溝女 填滿哂啲時間<br />\n但係就算同緊第個女仔出街都係會諗起個佢 <br />\n有啲咩事有咩煩惱都剩係想同佢講<br />\n 剩係最