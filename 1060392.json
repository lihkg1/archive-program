es/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"a579f4287d9b57e5b57e430b50502cfd32267f11","tid":1060392,"uid":175056,"like":0,"dislike":0,"score":0,"quote":{"pid":"a3f0dd6450b810c5baa32dc82c0b52f3a146e92c","tid":1060392,"uid":215026,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-03-13T19:04:24.000Z","msg":"巴打有無搵過佢？有無機會翻撻<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-14T05:40:37.000Z","msg":"無<br />\n佢仲同當時第三者一齊"},{"pid":"ec43c2a5dfed2be1c4349aa37727299c5537813d","tid":1060392,"uid":27907,"like":1,"dislike":0,"score":1,"quote":{"pid":"a3545c3f9b4f794d23e66604a2d11a13b5ed7ff9","tid":1060392,"uid":175056,"like":0,"dislike":0,"score":0,"quote":{"pid":"03743c187e2700af87cb8e2f7b403015fc118547","tid":1060392,"uid":27907,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-03-14T04:29:22.000Z","msg":"拍左7年 宜家分左手差唔多一年<br />\n都仲係日日諗起 <br />\n頭幾個月晚晚飲酒先訓到覺<br />\n宜家叫好少少 但係都係放唔低<br />\n甚至佢已經同左人一齊 我都仲係想等佢 <br />\n會希望自己改好 有一日佢可能會返嚟<br />\n有試過做gym 做運動 返多份工 溝女 填滿哂啲時間<br />\n但係就算同緊第個女仔出街都係會諗起個佢 <br />\n有啲咩事有咩煩惱都剩係想同佢講<br />\n 剩係最信任係佢 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n朋友傾過勸過屌過 我都move on唔到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-14T05:27:06.000Z","msg":"巴打 我明"},"citedBy":2,"replyTime":"2019-03-14T05:41:31.000Z","msg":"宜家日日返工等放工 <br />\n有約人有波打都仲好<br />\n無野做自己返到屋企就仆街啦 <br />\n獨處幾個鐘 啲情緒又走哂出黎<br />\n試過心情差到要逼自己落街 <br />\n就算同7仔M記職員講兩句野都好<br />\n總之唔可以自己一個 <br />\n行到攰或者飲啲酒攰攰地先返去訓<br />\n<br />\n其實我都好憎自己變成咁 <br />\n但係好似無野可以幫到自己咁 <img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n求解脫/屌醒<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c8b87cf68a908ecb3a3162328bfaefda37037279","tid":1060392,"uid":175056,"like":0,"dislike":0,"score":0,"quote":{"pid":"23f224d00601c80441fd8898f4c8afe3aba249d0","tid":1060392,"uid":156700,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-03-14T02:55:15.000Z","msg":"如果好似樓主既情況，覺得越逼自己去識新女，學新野，不停轉移視線係無乜大用，倒不如擁抱住呢個諗法，接受自己忘記唔到，每日做好自己算啦～點解唔開心要逼自己開心，越逼個對比越強烈越放唔低<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />接受咁樣既自己，分分鐘過得好d"},"citedBy":1,"replyTime":"2019-03-14T05:42:25.000Z","msg":"嗯 已經接受呢個我 但係味能夠對佢無情緒波動"},{"pid":"3e29866f6269e6767c8d151af7d5cfd43ed93bf1","tid":1060392,"uid":175056,"like":0,"dislike":0,"score":0,"quote":{"pid":"95388565c5c7b1ca7dff8f1e5087766ddad4e43f","tid":1060392,"uid":60731,"like":13,"dislike":0,"score":13,"citedBy":1,"replyTime":"2019-03-14T04:17:45.000Z","msg":"唔啱聽的說話你想唔想聽?<br />\n忘記一段感情的最好方法, 一係搵過個一係等時間過<br />\n若然都係唔work, 就一係新的唔夠好, 一係時間唔夠耐<br />\n我都係過來人, 我都沉左3年時間<br />\n三年黎, 我做左好多以前無時間做, 同由細到大都想做的野<br />\n本來只係識打機上高登, 用呢三年時間學識<br />\n品酒, 沖咖啡, 影相, 交響樂, 書法, 油畫<br />\n行書店畫廊酒窖的時間多過以前行信和一倍<br />\n慢慢發覺, 其實我一直以黎念念不忘的只係一段回憶<br />\n如果呢一刻佢出現喺我面前, 有機會同我喺返埋一齊<br />\n我會點? 我地會點?<br />\n無可能100%似以前一樣, 無論如何有d野發生左就係發生左<br />\n無論佢會點彌補, 我有幾寬容, 我地之間點都無可能再好似以前咁<br />\n佢帽左我, 的確佢係做過<br />\n<br />\n原來, 我三年黎執著緊的只係一堆美好的回憶<br />\n咁樣無必要去刻意忘記佢<br />\n只要諗通左由一個「人」變到一件「事」咁去看待<br />\n我成個人都放鬆曬<br />\n到今時今日我都無忘記我曾經咁開心過<br />\n所以今時今日的我比以前更開心"},"citedBy":0,"replyTime":"2019-03-14T05:44:37.000Z","msg":"嗯 我地既時光係回憶 係開心 但只係一件事情"},{"pid":"6567683af2e846e510684d67cf911077027df736","tid":1060392,"uid":175056,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec43c2a5dfed2be1c4349aa37727299c5537813d","tid":1060392,"uid":27907,"like":1,"dislike":0,"score":1,"quote":{"pid":"a3545c3f9b4f794d23e66604a2d11a13b5ed7ff9","tid":1060392,"uid":175056,"like":0,"dislike":0,"score":0,"quote":{"pid":"03743c187e2700af87cb8e2f7b403015fc118547","tid":1060392,"uid":27907,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-03-14T04:29:22.000Z","msg":"拍左7年 宜家分左手差唔多一年<br />\n都仲係日日諗起 <br />\n頭幾個月晚晚飲酒先訓到覺<br />\n宜家叫好少少 但係都係放唔低<br />\n甚至佢已經同左人一齊 我都仲係想等佢 <br />\n會希望自己改好 有一日佢可能會返嚟<br />\n有試過做gym 做運動 返