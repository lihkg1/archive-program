09-01T06:15:31.000Z","msg":"咩世代"},{"pid":"7591d922ab5d5963b8c247265143a8cf1df83cd2","tid":1526262,"uid":92479,"like":0,"dislike":0,"score":0,"quote":{"pid":"7fde241c05a031789a7f89ca01d8015dd3499d13","tid":1526262,"uid":201732,"like":18,"dislike":3,"score":15,"citedBy":1,"replyTime":"2019-09-01T05:07:48.000Z","msg":"<a href=\"https://www.facebook.com/HKWATCHOFFICIAL/videos/352058912370113/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FHKWATCHOFFICIAL%2Fvideos%2F352058912370113%2F&d=dE5eED8%2BMjLqHtNzOSR2Xw5Iyec62GFiithg4eFnous%3D&h=29b481d9\" target=\"_blank\">https://www.facebook.com/HKWATCHOFFICIAL/videos/352058912370113/</a>"},"citedBy":0,"replyTime":"2019-09-01T06:16:24.000Z","msg":"正仆街"},{"pid":"83b98f131bdd91971979aa25d235033c1b031c54","tid":1526262,"uid":92479,"like":2,"dislike":0,"score":2,"quote":{"pid":"3608d29eca077f294f712c483ac07ac0f7f0b1db","tid":1526262,"uid":201732,"like":32,"dislike":0,"score":32,"citedBy":2,"replyTime":"2019-09-01T05:07:11.000Z","msg":"<a href=\"https://m.facebook.com/story.php?story_fbid=451490695578966&amp;id=333035294091174\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2Fstory.php%3Fstory_fbid%3D451490695578966%26id%3D333035294091174&d=dE5eED8%2BMjLqHtNzOSR2Xw5Iyec62GFiithg4eFnous%3D&h=6539313e\" data-auto-link target=\"_blank\">https://m.facebook.com/story.php?story_fbid=451490695578966&amp;id=333035294091174</a><br />\n<br />\n警 察 撞 爛 貨 Van 側 鏡 司 機 理 論 原 告 變 被 告"},"citedBy":0,"replyTime":"2019-09-01T06:16:44.000Z","msg":"條路咁撚闊都有行埋面痴撚線"},{"pid":"98725afe48d3b71d88312d7c7f776c612097d5f0","tid":1526262,"uid":220864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T06:18:23.000Z","msg":"推"},{"pid":"08862611d7b85156f66e28eae00cb214eab271e9","tid":1526262,"uid":220864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T06:18:38.000Z","msg":"推"},{"pid":"614cfa2945fd88a8190ba1c8b248e5f170381824","tid":1526262,"uid":60398,"like":0,"dislike":0,"score"