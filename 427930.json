<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"55305124f3deedbb358d89888c3ff1b6dad13da0","tid":427930,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-08T17:28:11.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f55953940e614367f611369a2c60a3a6eeb0a7a4","tid":427930,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-08T23:51:29.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b86344fdc91d6f3209b3b653f2f296fb32203965","tid":427930,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-09T05:55:22.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"af9546cfb1e87b83d3cb0647ffe20e6e723a864c","tid":427930,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-09T06:30:24.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2ad7e345cfd9f4d02c2531831701f8bd926c8e2f","tid":427930,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-09T07:31:36.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ea31ab0d2f9ae5242871e5c9546cc918a0f2560f","tid":427930,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-09T08:06:23.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8587ed3ab70770e8562dab45cb6e3b5c3ed8c952","tid":427930,"uid":106408,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-09T08:43:03.000Z","msg":"唔推唔係人<br />\n內容根本應該長期置頂"},{"pid":"24d5d8a43ae4f83733413f37e259fd9e45b56a33","tid":427930,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-09T08:52:34.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"fd0013eb0c4f07f2a3663ebea82278450e59e0a7","tid":427930,"uid":48157,"like":0,"dislike":0,"score":0,"citedBy":0,"repl