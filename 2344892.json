pid":"5dc40fec24fb897a8b00c484ff8f381d792f8f3a","tid":2344892,"uid":253608,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-29T06:34:40.000Z","msg":"支那野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"24f5dbc1ebf917671706878695e20687a816832a","tid":2344892,"uid":143241,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-12-29T06:41:36.000Z","msg":"緊火到咁都要走,咁肯定幾樣衰下"},{"pid":"7867882ef2f5fdc3a9886d058920df8721f5d366","tid":2344892,"uid":91753,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-12-29T06:44:46.000Z","msg":"//此時一場罪惡正悄悄降臨//<br />\n<br />\n<img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/wail_r.gif\" class=\"hkgmoji\" />"},{"pid":"6b695cbdf4b951b84e5fedaea5832b0fecdba40d","tid":2344892,"uid":301406,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-12-29T06:45:56.000Z","msg":"我想睇相呀"},{"pid":"b6856543760db9d518a756d681e9cbdf1cf11ca3","tid":2344892,"uid":195877,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-12-29T06:47:49.000Z","msg":"蒙頭入閘<img src=\"/assets/faces/pigxm/dance3.gif\" class=\"hkgmoji\" />"}]}