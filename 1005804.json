faces/lny/pig2.gif\" class=\"hkgmoji\" />"},{"pid":"7269edea1874bbb206d62ab2fdbcbd4529131c89","tid":1005804,"uid":62950,"like":0,"dislike":0,"score":0,"quote":{"pid":"cb024d199947451bacb18b9e9378c6d65bcdf2f8","tid":1005804,"uid":34223,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-02-03T04:13:30.000Z","msg":"樓豬小心俾含撚狗咬 <img src=\"/assets/faces/lomoji/20.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/pig2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-02-03T04:42:18.000Z","msg":"連圖都貼埋  行都遊過 金又課過(雖然唔過100蚊)<br />\n咁都夠薑咬我 想話鳩我唔環保 丟撚哂D場刊<br />\n定係話我唔幫佢承傳 好似聖經咁轉贈比有需要人士?<img src=\"/assets/faces/lm2lny/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a7421b89bf167edf648c370795b8fbf5e9dd45fc","tid":1005804,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-03T04:51:49.000Z","msg":"<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"}]}