mg src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"08c5d0eb7250e9ba1b79f1064220416779228d4d","tid":1256843,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-26T05:44:11.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"abf0ccdb156d2c74f99bacefb4614ed387b3a0bd","tid":1256843,"uid":53610,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-26T07:04:17.000Z","msg":"應該傳開佢<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"77a86768a16a3ebf464725376db3b8aa807d1f15","tid":1256843,"uid":68463,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-26T07:11:06.000Z","msg":"問D官咪知點解可以非法動工<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"104d06f1039c43d2892b55186ee8230d188eb48d","tid":1256843,"uid":100986,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-29T01:15:19.000Z","msg":"洪森<img src=\"/assets/faces/dog/beg_connect.gif\" class=\"hkgmoji\" />"},{"pid":"bb46b9caaea2232e110d1100fde6360bd962e980","tid":1256843,"uid":167956,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-29T01:20:39.000Z","msg":"香港亦不遠矣<br />\n睇睇沙中線?!<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}