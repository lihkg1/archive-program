F%E5%AD%B8%E7%94%9F%E5%85%84%E5%BC%9F%E7%A2%BA%E8%A8%BA/</a>"},{"pid":"f01ed226bec75cf672bd93427ef715f7806324a4","tid":1892132,"uid":40470,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-22T10:33:43.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n痴線"},{"pid":"02dc5b1932a2cd397fea8aead889adc949f98707","tid":1892132,"uid":25538,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-22T10:33:54.000Z","msg":"玩大左"},{"pid":"160005535aea1b70f5155707cb8930667d2dfaa5","tid":1892132,"uid":3454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-22T10:35:31.000Z","msg":"最緊要奧運<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"9360e85aa2277dae232caa2162d6fa8134b2b3a9","tid":1892132,"uid":138964,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-22T10:36:20.000Z","msg":"boomvoomboom<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"9bd96568cdfbd1ef8d07d4dbc40d226e3948e4a4","tid":1892132,"uid":85604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-22T10:37:30.000Z","msg":"唔想比韓國反cap咁喎<br />\n個個都想做亞洲第二"},{"pid":"8c65f953f2ca6f0f97b483a3ead005065bafae3c","tid":1892132,"uid":12599,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-22T10:39:50.000Z","msg":"同病毒玩政治<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"ef885a3ffcef75c305d69ef1c34d5d3385918b00","tid":1892132,"uid":212878,"like":0,"dislike":0,"score":0,"cit