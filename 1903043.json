A%2F%2Fna.cx%2Fi%2F4jKCeuA.jpg&h=b5fe24c2&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/SVjOk8O.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSVjOk8O.jpg&h=6c3d967e&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/BxWUgHa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBxWUgHa.jpg&h=1ea4f4bb&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/4JgEsOR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4JgEsOR.jpg&h=9095be26&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/5b4292b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F5b4292b.jpg&h=75a2e8d2&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/QZjVLAx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQZjVLAx.jpg&h=bcdb2625&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/5Rq9P2c.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F5Rq9P2c.jpg&h=18626d7d&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/zBaJUtT.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzBaJUtT.jpg&h=1439ba03&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-02-29T12:38:59.000Z","msg":"幾多年？"},"citedBy":0,"replyTime":"2020-02-29T12:42:45.000Z","msg":"2010年自己睇,講真進攻功能組別一直都有,事實係無變過,反而變左理所當然存在,十幾年前連建制都會話最後會係要進行雙普選,你地係度進攻功能組別......<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n取消功能組別都叫左十幾年,點解仲叫人玩?繼續玩呢個制度邊個最開心?<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1810616\" data-auto-link target=\"_blank\">https://lih.kg/1810616</a>"},{"pid":"28e9223d666ff29a44d73aab3a8b6fda80a85a7c","tid":1903043,"uid":290739,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-29T12:43:30.000Z","msg":"推<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"a002085e3515be10fed1db147bbdbbec18b2259d","tid":1903043,"uid":205927,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-29T12:43:59.000Z","msg":"過半！！"},{"pid":"8b05b7cc259414baa8b1a9bb70cb41380f31631f","tid":1903043,"uid":254383,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-02-29T12:45:42.000Z","msg":"好似黎明行動咁，唔主動出擊，亦唔會意外爭取人權法快速立法<br />\n<br />\n一直要主動出擊同任何方法都要用"},{"pid":"0ca74f29a49ef20d6085e07a9de8cde9b8892570","tid":1903043,"uid":9394,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-02-29T12:50:45.000Z","msg":"支持，但各手足要小心唔好亂話人係熱狗<br />\n我地要真討論 唔好亂攻擊啲意見分歧既人"},{"pid":"8803f2b6de7ec09b5b051f3429938d63b2d1e69e","tid":1903043,"uid":224741,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d086ef547318e804e00fb2c0eb33f3e53d19c4e","tid":1903043,"uid":23194,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-28T17:01:16.000Z","msg":"取消功能組別係香港人嘅共識<br />\n但係用乜嘢方法呢？<br />\n有人想佛系等美國用人權民主法案取消2020功能組別<br />\n但現實上，我唔認為美國會喺11月大選前會因為香港同中國攤牌<br />\n唔係話美國唔會幫香港，但係時機的確唔<br />\n加上執行上嗰班人從來冇諗過有乜嘢「實際」行動可以令美國咁做<br />\n<br />\n進攻功能組別的確冇可能因為咁樣而即時取消功能組別<br />\n我哋從來都知道呢條路唔係一步登天<br />\n立法會個半，短時間可以擋到23條立法國歌發信用評級系統<br />\n而我認為其中一樣重要功能就係可以否決財政預算<br />\n堵塞庫房外匯儲備送中<br />\n斷中共回血劍，配合美國<br />\n可以令佢哋係中美貿易戰乖乖挨打<br />\n引發支爆，失去中共唯一（經濟）管治的合法性<br />\n到該時候就是真正解放香港之時<br />\n<br />\n有人會質疑選舉過程政府可能會舞弊，例如掌心雷、換票箱、DQ等等，到時就真是人權民主法案發揮作用的時候。<br />\n<br />\n<br />\n有人會問，當否決兩次財政預算，特首有權解散立法會。我認為這樣會跌入Dr. Strange 的無限循環<br />\n可能有人會認為中產公務員醫護受唔起政府財政停擺，但這樣冇辦法要光復香港就必須要受一些痛苦<br />\n學生可以為香港人擋子彈，成年人也要有經濟動盪的準備<br />\n<br />\n另一個問題係選舉入邊如何分配本土配額<br />\n我認為可以根據天琦一六年新東補選得票比例同泛民主派協調出選配額<br />\n希望係地區直選得到22至23席<br />\n所有代表民主陣營出選的候選人也必須提交投名狀<br />\n已表示他們會堅定反對23條國歌法信用評級系統等奧斯威爾式惡法，以及承諾不會出賣同路人<br />\n天琦講過：條條大佬通羅馬，放棄教條主義，邊個方法得就用邊個<br />\n<br />\n希望大家放下成見，唔好扼殺呢一個可能性，大家可以多加討論<br />\n最後一個問題就係，究竟熱普城屬唔屬於本土派？<br />\n認同就麻煩推一下，謝謝"},"citedBy":1,"replyTime":"2020-02-29T17:13:06.000Z","msg":"醒未啊，唔好自己騙自己啦，3份2票先可以改變普選，你9月最多米一半，何來3份2啊，任命要中共任命簽署，你點樣叫佢簽一個佢控制唔到既人，最後要美國幫到時輸3年，3年貿易戰打完邊度有人幫你<img src=\"https://na.cx/i/RfNHykE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRfNHykE.jpg&h=3d035f8d&s={SIZE}\" />"},{"pid":"b24fd3e6e5a68dd8cc0297aa6385ffe85d3ac782","tid":1903043,"uid":230703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-29T17:17:55.000Z","msg":"慢慢尼，最少要對家做好多資源去變"},{"pid":"0377e258cf9c5a8c0861c61061787dc91d91eadf","tid":1903043,"uid":59818,"like":0,"dislike":0,"score":0,"quote":{"pid":"0ca74f29a49ef20d6085e07a9de8cde9b8892570","tid":1903043,"uid":9394,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-02-29T12:50:45.000Z","msg":"支持，但各手足要小心唔好亂話人係熱狗<br />\n我地要真討論 唔好亂攻擊啲意見分歧既人"},"citedBy":0,"replyTime":"2020-02-29T17:18:24.000Z","msg":"就算唔係熱狗都有部份獨派唔支持玩選舉<br />\n仲要獨派最憎熱狗 所以亂屈人熱狗真係周圍樹敵<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4196c6fccba32f4aa18218bb13d2cd1c557cabc6","tid":1903043,"uid":71253,"like":0,"dislike":0,"score":0,"quote":{"pid":"8803f2b6de7ec09b5b051f3429938d63b2d1e69e","tid":1903043,"uid":224741,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d086ef547318e804e00fb2c0eb33f3e53d19c4e","tid":1903043,"uid":23194,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-28T17:01:16.000Z","msg":"取消功能組別係香港人嘅共識<br />\n但係用乜嘢方法呢？<br />\n有人想佛系等美國用人權民主法案取消2020功能組別<br />\n但現實上，我唔認為美國會喺11月大選前會因為香港同中國攤牌<br />\n唔係話美國唔會幫香港，但係時機的確唔<br />\n加上執行上嗰班人從來冇諗過有乜嘢「實際」行動可以令美國咁做<br />\n<br />\n進攻功能組別的確冇可能因為咁樣而即時取消功能組別<br />\n我哋從來都知道呢條路唔係一步登天<br />\n立法會個半，短時間可以擋到23條立法國歌發信用評級系統<br />\n而我認為其中一樣重要功能就係可以否決財政預算<br />\n堵塞庫房外匯儲備送中<br />\n斷中共回血劍，配合美國<br />\n可以令佢哋係中美貿易戰乖乖挨打<br />\n引發支爆，失去中共唯一（經濟）管治的合法性<br />\n到該時候就是真正解放香港之時<br />\n<br />\n有人會質疑選舉過程政府可能會舞弊，例如掌心雷、換票箱、DQ等等，到時就真是人權民主法案發揮作用的時候。<br />\n<br />\n<br />\n有人會問，當否決兩次財政預算，特首有權解散立法會。我認為這樣會跌入Dr. Strange 的無限循環<br />\n可能有人會認為中產公務員醫護受唔起政府財政停擺，但這樣冇辦法要光復香港就必須要受一些痛苦<br />\n學生可以為香港人擋子彈，成年人也要有經濟動盪的準備<br />\n<br />\n另一個問題係選舉入邊如何分配本土配額<br />\n我認為可以根據天琦一六年新東補選得票比例同泛民主派協調出選配額<br />\n希望係地區直選得到22至23席<br />\n所有代表民主陣營出選的候選人也必須提交投名狀<br />\n已表示他們會堅定反對23條國歌法信用評級系統等奧斯威爾式惡法，以及承諾不會出賣同路人<br />\n天琦講過：條條大佬通羅馬，放棄教條主義，邊個方法得就用邊個<br />\n<br />\n希望大家放下成見，唔好扼殺呢一個可能性，大家可以多加討論<br />\n最後一個問題就係，究竟熱普城屬唔屬於本土派？<br />\n認同就麻煩推一下，謝謝"},"citedBy":1,"replyTime":"2020-02-29T17:13:06.000Z","msg":"醒未啊，唔好自己騙自己啦，3份2票先可以改變普選，你9月最多米一半，何來3份2啊，任命要中共任命簽署，你點樣叫佢簽一個佢控制唔到既人，最後要美國幫到時輸3年，3年貿易戰打完邊度有人幫你<img src=\"https://na.cx/i/RfNHykE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRfNHykE.jpg&h=3d035f8d&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-02-29T17:32:09.000Z","msg":"樓主有講要靠立會普選咩"},{"pid":"8912ca35af68f88244b15207e0cdf6381e1dc79f","tid":1903043,"uid":71253,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-29T17:39:08.000Z","msg":"立會爭議席一黎係光復返本土個生態，二黎係拎資源，三係令本土入屋，而選舉係有極高既曝光度<br />\n其他乜野功能組別普選就太天方夜譚，但有人去試都唔反對<br />\n<br />\nbtw我覺得熱狗唔係本土<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f248f3cb2d15a76364d82d102f660cb7c02ea405","tid":1903043,"uid":224741,"like":0,"dislike":0,"score":0,"quote":{"pid":"4196c6fccba32f4aa18218bb13d2cd1c557cabc6","tid":1903043,"uid":71253,"like":0,"dislike":0,"score":0,"quote":{"pid":"8803f2b6de7ec09b5b051f3429938d63b2d1e69e","tid":1903043,"uid":224741,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d086ef547318e804e00fb2c0eb33f3e53d19c4e","tid":1903043,"uid":23194,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-28T17:01:16.000Z","msg":"取消功能組別係香港人嘅共識<br />\n但係用乜嘢方法呢？<br />\n有人想佛系等美國用人權民主法案取消2020功能組別<br />\n但現實上，我唔認為美國會喺11月大選前會因為香港同中國攤牌<br />\n唔係話美國唔會幫香港，但係時機的確唔<br />\n加上執行上嗰班人從來冇諗過有乜嘢「實際」行動可以令美國咁做<br />\n<br />\n進攻功能組別的確冇可能因為咁樣而即時取消功能組別<br />\n我哋從來都知道呢條路唔係一步登天<br />\n立法會個半，短時間可以擋到23條立法國歌發信用評級系統<br />\n而我認為其中一樣重要功能就係可以否決財政預算<br />\n堵塞庫房外匯儲備送中<br />\n斷中共回血劍，配合美國<br />\n可以令佢哋係中美貿易戰乖乖挨打<br />\n引發支爆，失去中共唯一（經濟）管治的合法性<br />\n到該時候就是真正解放香港之時<br />\n<br />\n有人會質疑選舉過程政府可能會舞弊，例如掌心雷、換票箱、DQ等等，到時就真是人權民主法案發揮