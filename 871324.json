"f3917784db15529c15f493658c499772da97bee7","tid":871324,"uid":106426,"like":0,"dislike":0,"score":0,"quote":{"pid":"86313bd732915adcb0d60539644bf6d03974cffc","tid":871324,"uid":21279,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-10-22T01:56:09.000Z","msg":"至on9a係力架總統<br />\n個時已知俄仔唔跟條約<br />\n講兩聲當冇事<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-22T02:13:47.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-10-22T02:25:22.000Z","msg":"力架可能心底好憎美國白人"},{"pid":"81828653864b6ef72e927c22b4fe1be214b70559","tid":871324,"uid":54337,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-22T02:41:22.000Z","msg":"中国直接受導彈威脅，又成最大贏家"},{"pid":"e57605a2a70c61467085825855c60d24395402b7","tid":871324,"uid":69013,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-10-22T02:45:35.000Z","msg":"WW3<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"742383e27a7ff823c2491ee2e176f2f3304f4e51","tid":871324,"uid":120955,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-22T03:02:18.000Z","msg":"軍備競賽加快科技進步"},{"pid":"b7e6b4f80493e8aaec79356028f09c973c0f3dc6","tid":871324,"uid":15205,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-22T03:12:35.000Z","msg":"乜撚野叫要挾<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n要脅吓嘛<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"9907551bb726f89dedddd0330fe35e8a8de1e3b4","tid":871324,"uid":25601,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-22T03:16:03.000Z","msg":"宇宙對地激光精準攻擊"},{"pid":"573866c78616acca8a6a213d5e912bc73571199c","tid":871324,"uid":79563,"like":0,"dislike":0,"score":0,"quote":{"pid":"742383e27a7ff823c2491ee2e176f2f3304f4e51","tid":871324,"uid":120955,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-22T03:02:18.000Z","msg":"軍備競賽加快科技進步"},"citedBy":0,"replyTime":"2018-10-22T03:29:07.000Z","msg":"引誘支那軍備競賽<br />\n<br />\n瓦解蘇聯既方法, 又再重演一次<br />\n<br />\n<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"f27ba420cc921bc90c7c8864e7ab4a386c812ae3","tid":871324,"uid":26601,"like":0,"dislike":0,"score":0,"quote":{"pid":"6a45baa017c42be45318ebd62765951b88b59b26","tid":871324,"uid":41245,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-22T01:45:27.000Z","msg":"英國又賣歐洲"},"citedBy":1,"replyTime":"2018-10-22T05:54:23.000Z","msg":"英國都係比較岩同美紐澳加埋堆"},{"pid":"1335c0a74e5a38e85846639cb427bfc2ab0cac45","tid":871324,"uid":2404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-22T05:56:01.000Z","msg":"殺到嚟門口，維尼肯含未？<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"16ca66137ecb12cf8f8d1d0073953bbf088d8e85","tid":871324,"uid":42283,"like":0,"dislike":0,"score":0,"quote":{"pid":"f27ba420cc921bc90c7c8864e7ab4a386c812ae3","tid":871324,"uid":26601,"like":0,"dislike":0,"score":0,"quote":{"pid":"6a45baa017c42be45318ebd62765951b88b59b26","tid":871324,"uid":41245,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-22T01:45:27.000Z","msg":"英國又賣歐洲"},"citedBy":1,"replyTime":"2018-10-22T05:54:23.000Z","msg":"英國都係比較岩同美紐澳加埋堆"},"citedBy":0,"replyTime":"2018-10-22T06:00:14.000Z","msg":"英國唔惦到要痴中共 希望佢快手啦"},{"pid":"e32e179bb435498954e4b4dfdf3355a7ca22e40c","tid":871324,"uid":36178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-22T06:16:08.000Z","msg":"迫住美國玩軍備徑賽<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"}]}