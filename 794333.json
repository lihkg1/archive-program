d34f4bfa159ed895f365e137476c03aa5375","tid":794333,"uid":50457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-26T09:11:40.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"64cabe7a83b7f32b41ffa0659cd5b14fd819c970","tid":794333,"uid":165377,"like":2,"dislike":0,"score":2,"quote":{"pid":"ee015c7bfb4b650a0bea3a038eafc4665fd5eac0","tid":794333,"uid":56147,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-26T09:09:01.000Z","msg":"點先做到完全無朋友"},"citedBy":1,"replyTime":"2018-08-26T09:32:29.000Z","msg":"做得太過火<br />\n成個中國已經比人定型做間諜國家<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"da15cbf4af52d35684c10fd1808f2d47c378558d","tid":794333,"uid":24788,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-26T09:34:12.000Z","msg":"今次要幾錢<br />\n講啦"},{"pid":"d66b3574744788e62cc8056202bf6681789421cd","tid":794333,"uid":90601,"like":6,"dislike":0,"score":6,"quote":{"pid":"64cabe7a83b7f32b41ffa0659cd5b14fd819c970","tid":794333,"uid":165377,"like":2,"dislike":0,"score":2,"quote":{"pid":"ee015c7bfb4b650a0bea3a038eafc4665fd5eac0","tid":794333,"uid":56147,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-26T09:09:01.000Z","msg":"點先做到完全無朋友"},"citedBy":1,"replyTime":"2018-08-26T09:32:29.000Z","msg":"做得太過火<br />\n成個中國已經比人定型做間諜國家<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-26T09:37:11.000Z","msg":"又唔見胡溫時代會係咁 講到尾都係錢銀+態度問題<br />\n<br />\n維尼上位之後 恃住自己多錢就成日想搵人笨柒 投資人地國家就偷工減料 食人夾棍 順帶偷鳩埋人地投術 仲要想做一方霸主<br />\n<br />\n雖然無人提過維尼成日出國到底同人傾啲咩 但觀乎中美談判 訪英 外交部 其餘6常委既口刎 條友本身應該真係當自己係皇帝 好自然就黑人憎"}]}