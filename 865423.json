\"hkgmoji\" />"},{"pid":"005dfbcdbe5a255feafce02bfc7413b90a5d1159","tid":865423,"uid":28309,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-17T06:36:23.000Z","msg":"沒事兒<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f32e67767c4e7e8e42fe058250968d42504024c0","tid":865423,"uid":25787,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-17T07:44:19.000Z","msg":"支那肯復興東莞我肯定你成個廣州樓價升到停唔到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"79c2a1416ec2c3c1135d34a288073cc674da51d0","tid":865423,"uid":54373,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-17T09:16:52.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"48599282704d2822a0509d2c9cb569e2104c1489","tid":865423,"uid":113449,"like":0,"dislike":0,"score":0,"quote":{"pid":"dc3afc97ff502fbddfbfb6eefc76ccb6068a95a8","tid":865423,"uid":20414,"like":9,"dislike":0,"score":9,"citedBy":2,"replyTime":"2018-10-17T05:59:05.000Z","msg":"62年管理費<br />\n31年就塌，咁有冇得回水"},"citedBy":0,"replyTime":"2018-10-17T09:28:56.000Z","msg":"送62年管理費搵邊個笨實<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n一係管理費變左由其他戶主俾埋<br />\n一係到時拆多個item,管理費唔包會所管理費或者大廈保養維修，變相都係要交<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"}]}