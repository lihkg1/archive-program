37cfd6280fb","tid":2357522,"uid":295230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T15:24:32.000Z","msg":"<img src=\"/assets/faces/mouse/pray.gif\" class=\"hkgmoji\" />"},{"pid":"42ef4ac35ab1fd611914a22e0c58bb1cd48325e2","tid":2357522,"uid":295230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T15:44:57.000Z","msg":"<img src=\"/assets/faces/mouse/medicine.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"da5b33d4d756925f200d617177d38603076742c8","tid":2357522,"uid":295230,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-01-07T13:26:03.000Z","msg":"無錯<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n農業革命無疑係現代文明既基石，無農業革命我地根本無機會出生，因為係無法支撐咁大量既世界人口，其重要性係不可質疑。但農業革命都係帶來種種既壞處問題，包括地球環境開始被極端改變、分工的勞動形社會造成性別不平等、人口過量增長導致資源緊張、複雜的貿易及city states既出現令到大型戰爭的平常化。<br />\n<br />\n不過即使係咁，我都認為農業革命係overall一件好事，畢竟無農業革命我就無法係到打字比大家睇，當然都唔會無視每個人類革命所帶來的問題，只係唔會好似班後現代主義者咁極端，而是用一個客觀角度黎睇"}}