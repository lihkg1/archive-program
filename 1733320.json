":1733320,"uid":61660,"like":5,"dislike":0,"score":5,"quote":{"pid":"36b1dfef28433e70d0a57fa5cf53777b63bb7d11","tid":1733320,"uid":272186,"like":0,"dislike":17,"score":-17,"quote":{"pid":"e8ae93ccc1c3fbd272b2b72537edd8c00585bb92","tid":1733320,"uid":168169,"like":0,"dislike":5,"score":-5,"citedBy":3,"replyTime":"2019-11-18T05:38:01.000Z","msg":"孤星淚之後發生d 咩？"},"citedBy":3,"replyTime":"2019-11-18T05:44:29.000Z","msg":"孤星淚係講緊法國大革命初期<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n成個故事係sad 革命唔成功 啲手足一個一個被殺"},"citedBy":0,"replyTime":"2019-11-18T05:57:27.000Z","msg":"孤星淚次係鬼大革命"},{"pid":"53c76b95543290718a5466ee5fbb5aa3e53505c9","tid":1733320,"uid":161781,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0fe21b34da0ed3ac195d84b7d37f9477619fcf5f","tid":1733320,"uid":33868,"like":1,"dislike":1,"score":0,"quote":{"pid":"9b2d96b25a8ed4cd5f9e37b02401df8111a24203","tid":1733320,"uid":161781,"like":5,"dislike":1,"score":4,"quote":{"pid":"36b1dfef28433e70d0a57fa5cf53777b63bb7d11","tid":1733320,"uid":272186,"like":0,"dislike":17,"score":-17,"citedBy":3,"replyTime":"2019-11-18T05:44:29.000Z","msg":"孤星淚係講緊法國大革命初期<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n成個故事係sad 革命唔成功 啲手足一個一個被殺"},"citedBy":2,"replyTime":"2019-11-18T05:54:03.000Z","msg":"你真係有睇過les mis..?"},"citedBy":1,"replyTime":"2019-11-18T05:56:12.000Z","msg":"Les Mis的確係悲劇收場"},"citedBy":1,"replyTime":"2019-11-18T05:58:27.000Z","msg":"果場戰鬥係法國大革命？"},{"pid":"9cb40e18df0c1a39835febd9997f44824ff364d3","tid":1733320,"uid":149494,"like":16,"dislike":0,"score":16,"citedBy":4,"replyTime":"2019-11-18T05:59:41.000Z","msg":"權貴用盡一切歪理同不公手段去管治、欺壓百姓<br />\n警察協助權貴維穩<br />\n<img src=\"https://static01.nyt.com/images/2012/12/25/arts/jpmiserables/jpmiserables-jumbo.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic01.nyt.com%2Fimages%2F2012%2F12%2F25%2Farts%2Fjpmiserables%2Fjpmiserables-jumbo.jpg&h=1d0c8d19&s={SIZE}\" /><br />\n<br />\n可以屈人偷面包，再判你坐十九年監<br />\n<img src=\"https://wp-media.patheos.com/blogs/sites/44/2012/12/les-mis-valjean-convict-5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwp-media.patheos.com%2Fblogs%2Fsites%2F44%2F2012%2F12%2Fles-mis-valjean-convict-5.jpg&h=8ed7ea96&s={SIZE}\" /><br />\n<br />\n一班年青人對社會現況看不過眼，站起來反抗<br />\n<img src=\"https://secure.i.telegraph.co.uk/multimedia/archive/02446/LesMis_rables_2446250b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fsecure.i.telegraph.co.uk%2Fmultimedia%2Farchive%2F02446%2FLesMis_rables_2446250b.jpg&h=fa9f3de0&s={SIZE}\" /><br />\n<br />\n警察覺得自己係執行公義，維護法治，誓要剷除一切不法份子<br />\n<img src=\"https://i.ytimg.com/vi/hRzvdQh8D2Q/maxresdefault.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.ytimg.com%2Fvi%2FhRzvdQh8D2Q%2Fmaxresdefault.jpg&h=5c462612&s={SIZE}\" /><br />\n<br />\n另有班人於亂世中借依附權貴同警察搵食<br />\n<img src=\"http://stagedoordish.com/wp-content/uploads/2013/03/Masters-1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstagedoordish.com%2Fwp-content%2Fuploads%2F2013%2F03%2FMasters-1.jpg&h=409d2ef8&s={SIZE}\" /><br />\n<br />\n年青人終於忍唔住，要同班權貴來場終極一戰<br />\n<img src=\"https://66.media.tumblr.com/60f1efbe482f732a6845faca38132e8e/tumblr_pl8hvqKSLX1w0lutwo5_r1_500.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2F66.media.tumblr.com%2F60f1efbe482f732a6845faca38132e8e%2Ftumblr_pl8hvqKSLX1w0lutwo5_r1_500.gif&h=c2694221&s={SIZE}\" /><br />\n<br />\n警察混入人群，找機會瓦解年青人的行動<br />\n<img src=\"https://i.pinimg.com/originals/68/33/08/6833083ae1ca03511b1ff467ff511395.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.pinimg.com%2Foriginals%2F68%2F33%2F08%2F6833083ae1ca03511b1ff467ff511395.jpg&h=00368ce8&s={SIZE}\" /><br />\n<br />\n結局︰<br />\n年青人的力量有限，以卵擊石下慘死<br />\n<img src=\"https://vignette.wikia.nocookie.net/lesmiserables/images/0/07/The_Final_Battle.png/revision/latest?cb=20130715153112\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Flesmiserables%2Fimages%2F0%2F07%2FThe_Final_Battle.png%2Frevision%2Flatest%3Fcb%3D20130715153112&h=ed58d211&s={SIZE}\" /><br />\n<br />\n怕事的一般百姓於年青人抗爭時沒有出來幫忙，在他們死後才走出來表現喪傷<br />\n<img src=\"https://vignette.wikia.nocookie.net/lesmiserables/images/0/0d/Turning.png/revision/latest?cb=20130716133218\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Flesmiserables%2Fimages%2F0%2F0d%2FTurning.png%2Frevision%2Flatest%3Fcb%3D20130716133218&h=a565eab2&s={SIZE}\" />"},{"pid":"928def84f54e459a22dab6dfa7ca80c7935ba461","tid":1733320,"uid":25424,"like":3,"dislike":0,"score":3,"quote":{"pid":"36b1dfef28433e70d0a57fa5cf53777b63bb7d11","tid":1733320,"uid":272186,"like":0,"dislike":17,"score":-17,"quote":{"pid":"e8ae93ccc1c3fbd272b2b72537edd8c00585bb92","tid":1733320,"uid":168169,"like":0,"dislike":5,"score":-5,"citedBy":3,"replyTime":"2019-11-18T05:38:01.000Z","msg":"孤星淚之後發生d 咩？"},"citedBy":3,"replyTime":"2019-11-18T05:44:29.000Z","msg":"孤星淚係講緊法國大革命初期<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n成個故事係sad 革命唔成功 啲手足一個一個被殺"},"citedBy":0,"replyTime":"2019-11-18T06:00:00.000Z","msg":"法乜鳩大革命初期呀<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n拿破崙都收埋皮啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"cd908f430d77e5426f989c674e131f361a3ae359","tid":1733320,"uid":338743,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-18T06:00:14.000Z","msg":"此回覆已被刪除"},{"pid":"b9e18cb8157ad00293963b41677827f8ef6fab2a","tid":1733320,"uid":42730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T06:04:07.000Z","msg":"最高的法律是良心"},{"pid":"3c46172bb545