f23f.png&h=743389f1&s={SIZE}\" /><br />\n<br />\n<a href=\"https://hk.news.appledaily.com/top/realtime/article/20180426/2_583898_0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Ftop%2Frealtime%2Farticle%2F20180426%2F2_583898_0&d=lZTbtb35zidcig6EcEc21wCO%2BKh2Nr2cOOQ8tL9eopA%3D&h=2cd5787a\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Ftop%2Frealtime%2Farticle%2F20180426%2F2_583898_0&h=e63c28f3\" target=\"_blank\">https://hk.news.appledaily.com/top/realtime/article/20180426/2_583898_0</a></blockquote><br />\n<br />\n篇文重點係呢到先啱<br />\n支那豬落黎搶野已經係常態<br />\n你點屌佢地一樣都係唔要面衝落黎<br />\n仲要一路搶一路屌鳩返你地<br />\n但呢間野擺明就係為左賺錢出賣香港嘅賣港賊<br />\n主動落廣告引大陸人落黎搶野<br />\n呢種行為真係好撚嘔心<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"98776518e18f41957ee50d37d97d0a8ee65d679e","tid":642570,"uid":63154,"like":1,"dislike":0,"score":1,"quote":{"pid":"93368a1b61e9692ad939a73fb5e4a8d2341db6de","tid":642570,"uid":38671,"like":7,"dislike":0,"score":7,"quote":{"pid":"2f34630075bdc88ae54c62981ac9cecef0563e49","tid":642570,"uid":47819,"like":5,"dislike":1,"score":4,"citedBy":2,"replyTime":"2018-04-26T01:26:17.000Z","msg":"大陸人咩9 都搶<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-26T01:30:03.000Z","msg":"因為支那乜都假，官方野都信唔過<br />\n支那人自己都知，最就近係去香港搶<br />\n<br />\n但有時支那人又好矛盾<br />\n又想要香港既好野，但又想香港變支那<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-26T03:23:21.000Z","msg":"其實唔矛盾，因為佢冇你諗得咁遠，蝗蟲會唔會覺得食清光塊田冇明天？唔會，到時咪又再逃過難，因為呢種生物就唔會諗明天，蜜蜂就會，所以蜜蜂係高等過蝗蟲"},{"pid":"d924460e0487494f32d1996325d365d486453248","tid":642570,"uid":3649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-26T03:59:02.000Z","msg":"我土生土長香港人都未試過去家計會打疫苗 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n最驚打針"},{"pid":"a85758967b4f6eb50e8ebec0ec45524e7ea3c2fe","tid":642570,"uid":28309,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-26T05:27:59.000Z","msg":"勵害了 我的國"},{"pid":"e0c7570b0fac483ecea76e46b0a6fb97d291053b","tid":642570,"uid":97551,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-26T07:49:16.000Z","msg":"他說家計會資源少，供應國內這麼多人是沒有可能，「他們集中資源服務香港人，我覺得很合情合理。」 <br />\n<br />\n<br />\n<img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" />"},{"pid":"58b0fa281540e6956ea9f8fdc05affceffda7b7d","tid":642570,"uid":53811,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-26T07:50:47.000Z","msg":"呢支野又真係好少聽到港女去打<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"}]}