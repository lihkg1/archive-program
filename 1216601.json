s=\"hkgmoji\" />"},{"pid":"f8bd5a9e67c67639e2deb7a247a571a3dffb7841","tid":1216601,"uid":140354,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-13T11:38:32.000Z","msg":"咁不如拍底美好影像, 再抄底number加以表揚<br />\n你擺到明望, 知你係邊個, 佢咪冇左期待<br />\n如果所有人偷偷影, 放上網表揚佢地既工作, 咁佢又唔知幾時會俾人影, 周圍既人隨時都有可能會影佢<br />\n佢個精神壓大好多, 應該會多D驚喜<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"907d873bb3b79021202c4b14e7c95eee57d44ea8","tid":1216601,"uid":220746,"like":0,"dislike":0,"score":0,"quote":{"pid":"2591973682a24b5764f9588380d837ec6493f17e","tid":1216601,"uid":74954,"like":9,"dislike":2,"score":7,"quote":{"pid":"77e50372d59713e24b9631c7518bdaac84f52e9d","tid":1216601,"uid":108016,"like":35,"dislike":1,"score":34,"citedBy":1,"replyTime":"2019-06-13T10:30:06.000Z","msg":"星期日帶定箱雞蛋去<br />\n請警犬食"},"citedBy":2,"replyTime":"2019-06-13T10:36:19.000Z","msg":"喂喂喂  你講野小心d <br />\n我地市民唔洗食?  我就買定蕃茄 大家可以補充體力<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-13T11:40:09.000Z","msg":"怕存貨不足  要早d買定放係室溫<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"969d2de18f436a44e136ac0d70b6d5f04469d5b1","tid":1216601,"uid":74954,"like":0,"dislike":0,"score":0,"quote":{"pid":"907d873bb3b79021202c4b14e7c95eee57d44ea8","tid":1216601,"uid":220746,"like":0,"dislike":0,"score":0,"quote":{"pid":"2591973682a24b5764f9588380d837ec6493f17e","tid":1216601,"uid":74954,"like":9,"dislike":2,"score":7,"quote":{"pid":"77e50372d59713e24b9631c7518bdaac84f52e9d","tid":1216601,"uid":108016,"like":35,"dislike":1,"score":34,"citedBy":1,"replyTime":"2019-06-13T10:30:06.000Z","msg":"星期日帶定箱雞蛋去<br />\n請警犬食"},"citedBy":2,"replyTime":"2019-06-13T10:36:19.000Z","msg":"喂喂喂  你講野小心d <br />\n我地市民唔洗食?  我就買定蕃茄 大家可以補充體力<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-13T11:40:09.000Z","msg":"怕存貨不足  要早d買定放係室溫<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-13T11:45:36.000Z","msg":"雞蛋要買就過期既<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n聽講會壯陽"},{"pid":"7f92cdf7a14c129dadc45792d5864ea9da06bd9b","tid":1216601,"uid":258696,"like":0,"dislike":0,"score":0,"quote":{"pid":"a13db12cd44b9498aee7b2a64eedade529f338fc","tid":1216601,"uid":3241,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-13T11:21:23.000Z","msg":"對黑警行納粹禮啦， 反正班狗同黨衛軍一d分別都冇"},"citedBy":1,"replyTime":"2019-06-13T11:47:07.000Z","msg":"佢地都唔識架啦 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 自己係猶太人都講得出"},{"pid":"250700e88b6b903087340e61b62dd975d9705ea8","tid":1216601,"uid":165200,"like":0,"dislike":0,"score":0,"quote":{"pid":"f8bd5a9e67c67639e2deb7a247a571a3dffb7841","tid":1216601,"uid":140354,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-13T11:38:32.000Z","msg":"咁不如拍底美好影像, 再抄底number加以表揚<br />\n你擺到明望, 知你係邊個, 佢咪冇左期待<br />\n如果所有人偷偷影, 放上網表揚佢地既工作, 咁佢又唔知幾時會俾人影, 周圍既人隨時都有可能會影佢<br />\n佢個精神壓大好多, 應該會多D驚喜<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-13T12:50:23.000Z","msg":"我目標係令佢哋一路行必一路有心理壓力，時時刻刻成為過街老鼠，要參與人數夠多，時間夠長，先有效果。但好處係極低成本，任何人、隨時隨地，無需裝備都做得。<br />\n<br />\n你呢招都有用，但難度略略高少少，起碼你要隨時預備影相，又或者見到黑警，搵到電話之後，再影。你知啦，香港人生活節奏極快，搞咁多嘢，好多人會「趕返工，不了」<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n但我都欣賞你個方法，仲想加些少建議，一係唔做，一做就要做多步 <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><br />\n<br />\n即係建立個database，大家將每個黑警嘅編號，連同見到嘅時間、地點都記錄低，幫佢哋做log book，要一查就搵到哂，咁市民想當面見偶像，送下花，都知點搵到佢哋嘛 <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"be45d4d98e0a9791dca627067217c38f4a11526d","tid":1216601,"uid":165200,"like":0,"dislike":0,"score":0,"quote":{"pid":"d167e01f05167cdec5b9d5663f9da2e20a9698b8","tid":1216601,"uid":212246,"like":4,"dislike":0,"score":4,"quote":{"pid":"ec094185ada432bc1fd018f9cd1131a62d3b7e35","tid":1216601,"uid":165200,"like":3,"dislike":0,"score":3,"quote":{"pid":"1c0b32abcff9e85b3e53fb9c3893d8db70c69d3d","tid":1216601,"uid":149607,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-06-13T10:30:08.000Z","msg":"全城帶頭盔口罩行動點睇?"},"citedBy":2,"replyTime":"2019-06-13T10:59:46.000Z","msg":"無話唔得嘅，但未必人人做得（例如：你叫中環返工嗰班西裝友、OL點玩？<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />）<br />\n<br />\n我提出嘅係極低成本，無需任何道具，只要有心，人人都可參與嘅方法。<br />\n<br />\n當然，一個山頂，好多條路，除咗可以各有各做，甚至歡迎做到嘅都做齊佢 <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-13T11:18:06.000Z","msg":"全體白色西裝裇衫鄙視黑警呢？可以有草木皆兵嘅效果"},"citedBy":0,"replyTime":"2019-06-13T12:57:13.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /> 咁唔係人人可參與，又唔會日日做得，只做一日半日，無效果，不如唔好做"},{"pid":"497534248984779df26a9161fa60daa30988f2b4","tid":1216601,"uid":165200,"like":1,"dislike":0,"score":1,"quote":{"pid":"7f92cdf7a14c129dadc45792d5864ea9da06bd9b","tid":1216601,"uid":258696,"like":0,"dislike":0,"score":0,"quote":{"pid":"a13db12cd44b9498aee7b2a64eedade529f338fc","tid":1216601,"uid":3241,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-13T11:21:23.000Z","msg":"對黑警行納粹禮啦， 反正班狗同黨衛軍一d分別都冇"},"citedBy":1,"replyTime":"2019-06-13T11:47:07.000Z","msg":"佢地都唔識架啦 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 自己係猶太人都講得出"},"citedBy":0,"replyTime":"2019-06-13T12:58:57.000Z","msg":"班偽進仔以為你係fan屎打氣咋 <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"25711eedcf5b6a41675d3abac1ab5cb7eb11964d","tid":1216601,"uid":69314,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T13:02:33.000Z","msg":"<span style=\"color: red;\">614 油油行動 正式啟動 </span><br />\n<br />\n大家一齊入黎發夢，幫手推同share出去<br />\n<br />\n614 油油行動 正式啟動<br />\n<a href=\"https://lih.kg/1217162\" data-auto-link target=\"_blank\">https://lih.kg/1217162</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"530df28b5116779aae8ab7e70a558aa3f83df3d8","tid":1216601,"uid":191656,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d3bd83f2f2e1f77f6c4f78c6bace57be3fac939","tid":1216601,"uid":165200,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-06-13T10:28:35.000Z","msg":"自69、612兩日後，各式和理非非、激進、以武止暴，以至不合作運動等等招數都有人出過。小弟不才，一直喺連登都只係個有account嘅cdrom，從未出post。但今誠香港危急存亡之秋，都想出一分力，諗吓有乜最低成本嘅抗爭手法。<br />\n<br />\n終於，今朝出門時，喺樓下見到幾個工賊會嘅仆街派傳單，心中忽生一計，非常簡單，人人都可參與，完全合法，成本低無可低：<br />\n<br />\n1. 「攻擊」對象：主要係黑警，其次所有建制賊都係追擊目標<br />\n2. 方法：易到極，每次見到目標人物，只需當佢哋殺父仇人咁，怒睥佢哋！<br />\n<br />\n今早試咗一次，個工賊義工本來四萬咁口遞張傳單畀我，我一睥，即時睇住佢個心離一離 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />，成個人後退幾步，真係幾箋鬼 <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />（記住忍笑 <img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />）<br />\n<br />\n試想像一下，如果參與人數夠多，除有表態作用，呢班賣港賊每日行出街就會覺得被人十面埋伏，好似過街老鼠咁，大大增加佢哋心理壓力。<br />\n<br />\n而我哋成本？幾乎係零！<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n唔好睇小心理戰，只要影響到5%黑警，負面情緒好易骨牌式擴散，隨時有機會令開心浩園餐賣斷市 <img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-13T13:02:47.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"8d6a7e8bf3b95c5f8f7b1e9493fa52730b0d5874","tid":1216601,"uid":226955,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-13T13:03:25.000Z","msg":"2014雨革、612當日已經證明班警犬全部都係冇良心<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />以下為集眾人之力結合成嘅圖集，希望大家可以幫手廣傳：<br />\n<br />\n<br />\n<a href=\"https://www.facebook.com/450867315005279/posts/2299277576830901/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F450867315005279%2Fposts%2F2299277576830901%2F&d=BSpFugi7VYdA%2F48z81zRmUzlOXIvf7DEkQzrkg%2FJo1w%3D&h=c233f0c1\" data-auto-link target=\"_blank\">https://www.facebook.com/450867315005279/posts/2299277576830901/</a><br />\n<br />\n612嗰日一位16歲女學生嘅心聲<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> 建議大家可以聽下<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />聽完之後我好嬲，亦都好想喊，香港今時今日嘅景況，除咗班高官之外，班蓄生警犬亦都有份一手一腳造成<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/LUxq7VC.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLUxq7VC.gif&h=721ac9a4&s={SIZE}\" /><br />\n<br />\n<strong>一名少年於金鐘一帶背向警察站立，遭十多名速龍小隊成員<span style=\"color: red;\">強行拉扯到地上用警棍圍毆</span>。</strong><br />\n<br />\n<img src=\"https://na.cx/i/aQu85Ja.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaQu85Ja.gif&h=0ec58946&s={SIZE}\" /> <br />\n<br />\n<strong>一名少女下午於立法會地下門外落單，遭近十名警員<span style=\"color: red;\">以盾牌及警棍按倒地上瘋狂圍毆</span>。</strong><br />\n<br />\n<img src=\"https://na.cx/i/wk41Gxi.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fwk41Gxi.gif&h=5c8616cb&s={SIZE}\" /><br />\n<br />\n<strong>一名手無寸鐵市民於大會堂對出方向，遭4-5名警員<span style=\"color: red;\">揮棍不停攻擊頭部倒地。</span></strong><br />\n<br />\n<img src=\"https://i.lihkg.com/540/https://na.cx/i/4g17BRj.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%2Fi%2F4g17BRj.gif&h=509faf8a&s={SIZE}\" /><br />\n<br />\n<strong>一名外藉男子於愛丁堡廣場附近，因行動不便獨自坐於花槽旁，<span style=\"color: red;\">遭警員以胡椒噴劑近距離向臉部射擊。</span></strong><br />\n<br />\n<img src=\"https://na.cx/i/eLz5ovx.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeLz5ovx.gif&h=58851dc8&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/i8PQzCe.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fi8PQzCe.gif&h=58a9a71f&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/UvSnqJW.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUvSnqJW.gif&h=c1469b1b&s={SIZE}\" /><br />\n<br />\n<strong>下午時份於金鐘天橋附近一帶，一名中年婦人向警員哭求停止對香港人使用武力，<span style=\"color: red;\">遭警員近距離以不明武器擊中頭部。</span></strong><br />\n<br />\n<img src=\"https://i.lihkg.com/540/https://na.cx/i/d6KQzNf.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%2Fi%2Fd6KQzNf.gif&h=b3ebd9eb&s={SIZE}\" /><br />\n<br />\n<strong>一名市民於金鐘橋底下，遭警員<span style=\"color: red;\">瞄準頭部射擊</span>。</strong><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">同場加映：</span></span><br />\n示威者吐血<br />\n<a href=\"https://youtu.be/hRCPds07zSM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FhRCPds07zSM&d=BSpFugi7VYdA%2F48z81zRmUzlOXIvf7DEkQzrkg%2FJo1w%3D&h=189dfb67\" data-auto-link target=\"_blank\">https://youtu.be/hRCPds07zSM</a> <br />\n<br />\n拖行暈倒示威者<br />\n<a href=\"https://youtu.be/GfhHJqNVPig\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FGfhHJqNVPig&d=BSpFugi7VYdA%2F48z81zRmUzlOXIvf7DEkQzrkg%2FJo1w%3D&h=5a0fc2de\" data-auto-link target=\"_blank\">https://youtu.be/GfhHJqNVPig</a> <br />\n<br />\n唔比救護車入<br />\n<a href=\"https://youtu.be/mT8SH2EJctk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FmT8SH2EJctk&d=BSpFugi7VYdA%2F48z81zRmUzlOXIvf7DEkQzrkg%2FJo1w%3D&h=1cceca20\" data-auto-link target=\"_blank\">https://youtu.be/mT8SH2EJctk</a> <br />\n<br />\n地鐵站噴椒<br />\n<a href=\"https://youtu.be/sQk9mLw07WM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FsQk9mLw07WM&d=BSpFugi7VYdA%2F48z81zRmUzlOXIvf7DEkQzrkg%2FJo1w%3D&h=671190aa\" data-auto-link target=\"_blank\">https://youtu.be/sQk9mLw07WM</a> <br />\n<br />\n開槍<br />\n<a href=\"https://youtu.be/9bbFANmVWZ4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F9bbFANmVWZ4&d=BSpFugi7VYdA%2F48z81zRmUzlOXIvf7DEkQzrkg%2FJo1w%3D&h=71c4224f\" data-auto-link target=\"_blank\">https://youtu.be/9bbFANmVWZ4</a> <br />\n<br />\n向記者放tear gas<br />\n<a href=\"https://youtu.be/cWZ0R67V5Yg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FcWZ0R67V5Yg&d=BSpFugi7VYdA%2F48z81zRmUzlOXIvf7DEkQzrkg%2FJo1w%3D&h=2aad8459\" data-auto-link target=\"_blank\">https://youtu.be/cWZ0R67V5Yg</a> <br />\n<br />\n事後嚟張大合照慶功先<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/3BUJgDg.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3BUJgDg.png&h=d811719e&s={SIZE}\" /><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">強烈建議告上聯合國！向對示威者施過度武力嘅警察懲處！終生不得踏入歐美國家半步！呢班人渣注定世世代代共享中國人嘅榮耀</span></span>"},{"pid":"846ec7a4db966279688c0646743644e4492cf222","tid":1216601,"uid":53922,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T13:03:56.000Z","msg":"<span style=\"font-size: xx-large;\">有狗經過....<br />\n汪汪汪</span>"},{"pid":"cf57274b0a793045860ec407235b1e59db70a87e","tid":1216601,"uid":76681,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-13T13:13:25.000Z","msg":"sorry, 2014年後,   不嬲都出街會啤<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b9fdeaecbea674506d7e743fb8dedd7c87c146e1","tid":1216601,"uid":165200,"like":0,"dislike":0,"score":0,"quote":{"pid":"cf57274b0a793045860ec407235b1e59db70a87e","tid":1216601,"uid":76681,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-13T13:13:25.000Z","msg":"sorry, 2014年後,   不嬲都出街會啤<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-13T13:16:11.000Z","msg":"Well done bro <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n齊齊推廣，要更多人參與 <img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"ac99d6a1f363fcff3148f1fe59ee5c8e7d96e89c","tid":1216601,"uid":6604,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-13T13:18:22.000Z","msg":"星期日見到黑警都講句「放下屠刀，立地成佛」"},{"pid":"01e6993a07f9f6741464dc5bd2e3e7bced3b664d","tid":1216601,"uid":260139,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-13T13:30:39.000Z","msg":"撐<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n遇黑警做野唔洗對佢地態度咁好<br />\n同埋排斥佢地仔女<br />\n等佢地知道自己行為有幾撚可恥<br />\n個個話香港 守護自己家園<br />\n含撚啦<img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /><br />\n你地只係將屋企人同埋香港人送去牆入面生活咋<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f2e999b332fcdc43e7ac81ecb6dda12569e1e35b","tid":1216601,"uid":165200,"like":0,"dislike":0,"score":0,"quote":{"pid":"01e6993a07f9f6741464dc5bd2e3e7bced3b664d","tid":1216601,"uid":260139,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-13T13:30:39.000Z","msg":"撐<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n遇黑警做野唔洗對佢地態度咁好<br />\n同埋排斥佢地仔女<br />\n等佢地知道自己行為有幾撚可恥<br />\n個個話香港 守護自己家園<br />\n含撚啦<img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /><br />\n你地只係將屋企人同埋香港人送去牆入面生活咋<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-13T13:40:02.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n先打沉心靈最脆弱嗰班，然後一步一步打上去，要令佢哋變哂過街老鼠，咪以為做衰嘢唔洗還 <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"f163be5ba64159ce12446b659e808aad1adb4d59","tid":1216601,"uid":165200,"like":2,"dislike":0,"score":2,"quote":{"pid":"ac99d6a1f363fcff3148f1fe59ee5c8e7d96e89c","tid":1216601,"uid":6604,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-13T13:18:22.000Z","msg":"星期日見到黑警都講句「放下屠刀，立地成佛」"},"citedBy":0,"replyTime":"2019-06-13T14:27:34.000Z","msg":"2014年之後已經知道無用 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n不斷被人咁睥法點都有一定心理壓力，只要令佢哋感到變咗過街老鼠，無地自容（借用上面Bradley_Cooper巴打用語），就算佢哋再無恥，都好難完全唔受影響，長期草木皆兵嘅感覺唔係人人捱得住。<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><br />\n<br />\n任何低成本又可傷害敵人嘅方法，多多益善！<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4862ff8ecad578b4a345f01dc5a3ee9fcfc0861c","tid":1216601,"uid":163758,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d3bd83f2f2e1f77f6c4f78c6bace57be3fac939","tid":1216601,"uid":165200,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-06-13T10:28:35.000Z","msg":"自69、612兩日後，各式和理非非、激進、以武止暴，以至不合作運動等等招數都有人出過。小弟不才，一直喺連登都只係個有account嘅cdrom，從未出post。但今誠香港危急存亡之秋，都想出一分力，諗吓有乜最低成本嘅抗爭手法。<br />\n<br />\n終於，今朝出門時，喺樓下見到幾個工賊會嘅仆街派傳單，心中忽生一計，非常簡單，人人都可參與，完全合法，成本低無可低：<br />\n<br />\n1. 「攻擊」對象：主要係黑警，其次所有建制賊都係追擊目標<br />\n2. 方法：易到極，每次見到目標人物，只需當佢哋殺父仇人咁，怒睥佢哋！<br />\n<br />\n今早試咗一次，個工賊義工本來四萬咁口遞張傳單畀我，我一睥，即時睇住佢個心離一離 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />，成個人後退幾步，真係幾箋鬼 <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />（記住忍笑 <img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />）<br />\n<br />\n試想像一下，如果參與人數夠多，除有表態作用，呢班賣港賊每日行出街就會覺得被人十面埋伏，好似過街老鼠咁，大大增加佢哋心理壓力。<br />\n<br />\n而我哋成本？幾乎係零！<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n唔好睇小心理戰，只要影響到5%黑警，負面情緒好易骨牌式擴散，隨時有機會令開心浩園餐賣斷市 <img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-13T14:30:48.000Z","msg":"我試過雨革時行路撞尻d散仔, 屌你d散仔打橫行, 條路你架依家? d同事驚我俾人塔返去<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"03f048613dc6e1af13534c8b42696264b2404c50","tid":1216601,"uid":30991,"like":0,"dislike":0,"score":0,"quote":{"pid":"2591973682a24b5764f9588380d837ec6493f17e","tid":1216601,"uid":74954,"like":9,"dislike":2,"score":7,"quote":{"pid":"77e50372d59713e24b9631c7518bdaac84f52e9d","tid":1216601,"uid":108016,"like":35,"dislike":1,"score":34,"citedBy":1,"replyTime":"2019-06-13T10:30:06.000Z","msg":"星期日帶定箱雞蛋去<br />\n請警犬食"},"citedBy":2,"replyTime":"2019-06-13T10:36:19.000Z","msg":"喂喂喂  你講野小心d <br />\n我地市民唔洗食?  我就買定蕃茄 大家可以補充體力<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-13T14:36:10.000Z","msg":"其實認真我都想食橙同香蕉 