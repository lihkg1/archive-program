67cac83060332c","tid":2361311,"uid":29627,"like":0,"dislike":3,"score":-3,"quote":{"pid":"601a1892bc367762c6383adff902ca620930f2f5","tid":2361311,"uid":50595,"like":5,"dislike":3,"score":2,"citedBy":7,"replyTime":"2021-01-10T14:39:47.000Z","msg":"<img src=\"https://na.cx/i/SVZcPnR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSVZcPnR.jpg&h=8277d8a3&s={SIZE}\" />"},"citedBy":2,"replyTime":"2021-01-10T14:42:34.000Z","msg":"肉地腳正<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},{"pid":"9aeceb2823d9ad2112faa4cc32b121b78ff38f5f","tid":2361311,"uid":50595,"like":1,"dislike":0,"score":1,"quote":{"pid":"a5b9e1e271be9f6edf03946f5467cac83060332c","tid":2361311,"uid":29627,"like":0,"dislike":3,"score":-3,"quote":{"pid":"601a1892bc367762c6383adff902ca620930f2f5","tid":2361311,"uid":50595,"like":5,"dislike":3,"score":2,"citedBy":7,"replyTime":"2021-01-10T14:39:47.000Z","msg":"<img src=\"https://na.cx/i/SVZcPnR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSVZcPnR.jpg&h=8277d8a3&s={SIZE}\" />"},"citedBy":2,"replyTime":"2021-01-10T14:42:34.000Z","msg":"肉地腳正<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-10T14:43:15.000Z","msg":"睇完嗰樣你一定會後悔<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"ddea1f16d5b6042b46aaa4129f2affa2403001c4","tid":2361311,"uid":75050,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2021-01-10T14:44:33.000Z","msg":"大部份肥到成座山咁嘅肥婆，條頸後面都好多老泥，因為佢哋沖涼嘅時候卒唔到。 <br />\n<br />\n老泥俾頸部脂肪一層層夾住，日復日年復年咁累積。 <br />\n所以大部份肥婆條頸都係黑色，越黑老泥越厚。 <br />\n如果你哋有幸溝到肥婆，就人一世物一世點都要試下。<br />\n首先用手指濕少少水起勢咁卒，用匙羹刮出嚟，加兩滴美極慢慢品嚐。 <br />\n初哥可能話核突，但你唔食肥婆老泥等於登上白雲山唔食山水豆腐花一樣咁傻的嗎。 <br />\n<br />\n下身方面又係有學問，肥婆食咁多漢堡包同牛肉，男性荷爾蒙分泌過盛。 <br />\n所以塊西至屎o全部都係毛，無論佢幾乾淨，都有陣咸魚溝變壞乳酪嘅味道。 <br />\n據英國研究，82.5%肥婆都唔會剃腳毛，因為烏低身嗰下等於做sit up，有違肥人忠旨。 <br />\n所以肥婆啲腳毛永遠好似鐵線咁粗。 <br />\n奶西嘅時候叫佢瞓低你忠個頭埋去，兩隻手要掃佢隻腳啲鐵線等佢起雞皮，然後叫佢嗰對火腿夾實自己個頭唔好比空氣流出。 <br />\n陣咸魚味喺真空環境會得到昇華，係有層次而漸進的。<br />\n奶嗰時攝攝聲，有3D立體音響加回音效果。 <br />\n你嗅覺，味覺，觸覺，聽覺得到前所未有嘅享受，呢啲先叫人生啊。 <br />\n<br />\n啪啪啪嗰part唔多講，因為肥婆塊田多肉好撞係常識，你塞咗入去會感受到溫暖同安全感，比一層一層肉緊緊包住。 <br />\n<br />\n<br />\n成日笑肥婆以為自己好識食嗰啲人，根本就係未夠班，自以為是嘅表現。你比食女界嘅高手揀減肥前欣宜定係整容後楊怡，佢完全唔想答你，一嚟佢唔想笑勁你問無聊野，二嚟佢已經諗緊點班支美極返嚟。"},{"pid":"4c1a225e430b1dc68704159384f61c6fd8241f6f","tid":2361311,"uid":108814,"like":0,"dislike":0,"score":0,"quote":{"pid":"9aeceb2823d9ad2112faa4cc32b121b78ff38f5f","tid":2361311,"uid":50595,"like":1,"dislike":0,"score":1,"quote":{"pid":"a5b9e1e271be9f6edf03946f5467cac83060332c","tid":2361311,"uid":29627,"like":0,"dislike":3,"score":-3,"quote":{"pid":"601a1892bc367762c6383adff902ca620930f2f5","tid":2361311,"uid":50595,"like":5,"dislike":3,"score":2,"citedBy":7,"replyTime":"2021-01-10T14:39:47.000Z","msg":"<img src=\"https://na.cx/i/SVZcPnR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSVZcPnR.jpg&h=8277d8a3&s={SIZE}\" />"},"citedBy":2,"replyTime":"2021-01-10T14:42:34.000Z","msg":"肉地腳正<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-10T14:43:15.000Z","msg":"睇完嗰樣你一定會後悔<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-10T14:44:40.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />講到咁你就咪食"},{"pid":"0820e11206e4a8f003b9564e13e10562faad6fca","tid":2361311,"uid":14065,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-10T14:46:14.000Z","msg":"出嚟之前唔知架咩<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f7e5004e5f8f480bebdad94e267275c8936ee3fd","tid":2361311,"uid":189109,"like":5,"dislike":0,"score":5,"quote":{"pid":"94ab462b04feec7c2d10b1e9f921091e06963822","tid":2361311,"uid":161620,"like":1,"dislike":6,"score":-5,"quote":{"pid":"f3290e239b1253169cb015b2036ec6f512