rmal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"530bdefc92cd053b11e2bde421384ba287ac514e","tid":1997643,"uid":219007,"like":3,"dislike":0,"score":3,"quote":{"pid":"9dc60447ec0d773c8bae4ec1861b4e79f7da9587","tid":1997643,"uid":184787,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2020-05-01T20:10:47.000Z","msg":"欣賞佢地採訪夠博<br />\n但依單野的確記者情緒有啲失控<br />\n希望改善下"},"citedBy":0,"replyTime":"2020-05-01T20:17:31.000Z","msg":"如果計情緒失控 林匡正誇張好多<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n但其實林匡正講得啱，係咪呃錢爭人錢嗰啲之後先再算，而家採訪緊無謂坳，所以佢先過去調停。<br />\n<br />\n只不過係調停嗰陣肥仔無啦啦走去挑林匡正機<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n以林匡正嘅性格就屌番佢轉頭<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6039bad1badbd014366ddb28ef01e9d9a129a5ba","tid":1997643,"uid":27530,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2020-05-01T20:18:09.000Z","msg":"佢當日個問題其實係馬後炮<br />\n<br />\n依家睇番緊係各國開始封關好，但各國三月前都無咁做。再講番佢問既野，香港比人轉機去其他國家，其他國家應自己判斷比唔比入境，你比人入境就唔關香港事啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n係連登自high話人問得好"},{"pid":"b449005f125fa226fd22c3752de5ef72d4333351","tid":1997643,"uid":214036,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-05-01T20:18:32.000Z","msg":"此回覆已被刪除"},{"pid":"c80a0ff2e7297ee25834fddd6eea793e7e39980f","tid":1997643,"uid":160964,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-01T20:20:11.000Z","msg":"唔睇"},{"pid":"eb667e077f8bf6b829acf250b369a740864a424f","tid":1997643,"uid":61348,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2020-05-01T20:20:20.000Z","msg":"咁既內部細矮野有咩值得關注.....<br />\n<br />\n屌柒林鄭先係重點<br />\n<br />\n反毓撚 根本搵野屌"},{"pid":"f3596382860d9452033bc5617aab30dda5afb364","tid":1997643,"uid":160964,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-05-01T20:20:50.000Z","msg":"捉鬼日報<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d76fd6e88c20f252bfbaeb299a946f7dafb889a5","tid":1997643,"uid":219007,"like":2,"dislike":0,"score":2,"quote":{"pid":"6039bad1badbd014366ddb28ef01e9d9a129a5ba","tid":1997643,"uid":27530,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2020-05-01T20:18:09.000Z","msg":"佢當日個問題其實係馬後炮<br />\n<br />\n依家睇番緊係各國開始封關好，但各國三月前都無咁做。再講番佢問既野，香港比人轉機去其他國家，其他國家應自己判斷比唔比入境，你比人入境就唔關香港事啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n係連登自high話人問得好"},"citedBy":1,"replyTime":"2020-05-01T20:24:34.000Z","msg":"香港國際大都會<br />\n你嗰幾日遲咗封關，而病毒係可以係冇徵狀嘅情況之下已經有傳染能力，亦都有案例係大陸人經香港去其他地方之後證實確診。 當然佢哋都有責任，但你自己明知已經有危險，仲要遲遲唔封關，咁樣做同隱瞞疫情係冇乜分別。<br />\n所以先會問佢喺世界爆發疫情上香港係咪有責任呢？<br />\n <br />\n而癲狗日報用英文問，加上佢係鬼佬<br />\n咁樣問法林鄭月娥第一下會真係以為國際有聲音要追討賠償包括香港。  所以林鄭月娥先問多佢一次係咩傳媒機構，就係咁解<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"06cd9817029093bfcac0a03438e7c159f2025f82","tid":1997643,"uid":219007,"like":1,"dislike":0,"score":1,"quote":{"pid":"25549a3a2d055fbe6ab264fa4ab39f61e81e8eb2","tid":1997643,"uid":189109,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2020-05-01T20:12:35.000Z","msg":"4隻字嘩眾取寵<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-01T20:26:27.000Z","msg":"可唔可以解釋吓邊度嘩眾取寵？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f009ea59197e85d9aa907bee407480145b30ec93","tid":1997643,"uid":27530,"like":0,"dislike":1,"score":-1,"quote":{"pid":"d76fd6e88c20f252bfbaeb299a946f7dafb889a5","tid":1997643,"uid":219007,"like":2,"dislike":0,"score":2,"quote":{"pid":"6039bad1badbd014366ddb28ef01e9d9a129a5ba","tid":1997643,"uid":27530,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2020-05-01T20:18: