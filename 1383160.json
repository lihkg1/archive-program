,"tid":1383160,"uid":58140,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-29T16:01:20.000Z","msg":"上cool無問題架啵 剝牙先慘"},"citedBy":1,"replyTime":"2019-07-29T16:13:21.000Z","msg":"我要剝牙呀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />會點架&hellip;我擔心去旅行食唔到野&hellip;"},{"pid":"dddfa4edb463bb38f6432657b574ef5bca11f335","tid":1383160,"uid":35504,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2019-07-31T06:40:53.000Z","msg":"要一星期先習慣<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"a7a40321c27f920a6499a1f734fb412bf9d6f49b","tid":1383160,"uid":268546,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T06:43:55.000Z","msg":"印象中頭一星期keep住只係食粥都覺得好難頂<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"3aa172b7e14f7db5c6def38aa203e0788e4aedaf","tid":1383160,"uid":249885,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-31T07:36:36.000Z","msg":"係會痛定點"},{"pid":"c5688f1916583bd9084e1a2482790b9635e98dad","tid":1383160,"uid":268546,"like":0,"dislike":0,"score":0,"quote":{"pid":"3aa172b7e14f7db5c6def38aa203e0788e4aedaf","tid":1383160,"uid":249885,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-31T07:36:36.000Z","msg":"係會痛定點"},"citedBy":0,"replyTime":"2019-07-31T09:00:05.000Z","msg":"酸痛 基本上用唔到力咬野<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"64c6485505e53d04b1a585ebe74f7217183c1704","tid":1383160,"uid":71459,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T09:00:36.000Z","msg":"調整先on9<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"445173cb3f7adb8e9baf018612a941d36d3404f0","tid":1383160,"uid":93633,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-31T09:14:50.000Z","msg":"正常頭個禮拜食唔到硬野,之後開始慢慢好。但如果過咗一排後佢調整得大，你之後一兩日都會keep住痛。"},{"pid":"12797dd8e72de3e3db3b29e9a8ebc6625242d838","tid":1383160,"uid":93633,"like":0,"dislike":0,"score":0,"quote":{"pid":"445173cb3f7adb8e9baf018612a941d36d3404f0","tid":1383160,"uid":93633,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-31T09:14:50.000Z","msg":"正常頭個禮拜食唔到硬野,之後開始慢慢好。但如果過咗一排後佢調整得大，你之後一兩日都會keep住痛。"},"citedBy":0,"replyTime":"2019-07-31T09:15:50.000Z","msg":"我每兩個禮拜番去調整一次"},{"pid":"a633915d761c15d635641fac1385e60ec12ab7f7","tid":1383160,"uid":16123,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-31T09:16:32.000Z","msg":"我覺得最慘係每次覆診要等個幾鐘<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"96d3fdc2b729b8ad8c8c57641a9741b5a5e4a304","tid":1383160,"uid":291745,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T19:04:27.000Z","msg":"剝牙固然痛<br />\n但第一次上箍（我用Damon）真係酸痛到不得了<br />\n我連食白飯都痛到飆眼淚<br />\n所以就食咗一個禮拜粥同蛋榚<img src=\"/assets/faces/lm2/frownsmile.gif\" class=\"hkgmoji\" /><br />\n之後漸漸適應咗<br />\n之後覆診都係三天倒就適應到"},{"pid":"a8888cb73cf0630ff460242419edbc2f02561d23","tid":1383160,"uid":27670,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-02T19:13:46.000Z","msg":"十幾年前箍<br />\n差唔多2個禮拜先可以俾d力食野<br />\n但係大舊同硬野依然係要剪細<br />\n同埋用錯力咬野食會好撚痛<br />\n唔小心刮到牙肉既話直頭係地獄<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n試過打波俾人鋤到一野 爆光爆到好似武俠片咁嘔血<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n之後你預每次覆診之後都要大概1-2禮拜先習慣<br />\n越初期覆診得越密 基本上頭一年甚至年半你都冇乜時間可以正常食野<br />\n同埋唔食得香口膠"},{"pid":"1ce6f116e455f2afee88546a7ee8c47d6ea96b64","tid":1383160,"uid":27670,"like":1,"dislike":0,"score":1,"quote":{"pid":"9862e4faa35eb67bc1eaee421dca0146a475e7bc","tid":1383160,"uid":106481,"like":0,"dislike":0,"score":0,"quote":{"pid":"b0d9069655542da46b1823eccea289e35299cef6","tid":1383160,"uid":58140,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-29T16:01:20.000Z","msg":"上cool無問題架啵 剝牙先慘"},"citedBy":1,"replyTime":"2019-07-29T16:13:21.000Z","msg":"我要剝牙呀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />會點架&hellip;我擔心去旅行食唔到野&hellip;"},"citedBy":0,"replyTime":"2019-08-02T19:21:41.000Z","msg":"信我 唔好因為怕痛或者怕麻煩而選擇唔剝牙<br />\n以前細個老母一聽到剝牙嚇到瀨屎<br />\n最後冇剝到 箍完之後過左年幾左右 下顎走位<br />\n雖然係好撚輕微 但係留心睇既話會睇得出個嘴歪左少少<br />\n好撚sad<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />我仲要箍撚左5年<br />\n不過我果時主要係因為下排既牙成排上左前面所以先箍<br />\n所以都可能同我本身d骨有關係 參考用<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"5f8712ac257e841e6b054e05536e25dba5c6a438","tid":1383160,"uid":306785,"like":1,"dislike":0,"score":1,"quote":{"pid":"b2106d7051c9a86e661bdd1ab3bca3466ef758c1","tid":1383160,"uid":106481,"like":0,"dislike":0,"score":0,"quote":{"pid":"c39c91ab44ef575459246f9987040ec5c889b000","tid":1383160,"uid":199736,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-29T15:49:35.000Z","msg":"邊一隻箍先<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-29T15:53:32.000Z","msg":"傳統鋼cool呢"},"citedBy":0,"replyTime":"2019-08-21T10:55:50.000Z","msg":"我記得我係一日後就冇咩問題"},{"pid":"13fc45de72adc348dd05606a8c24981a283ae91b","tid":1383160,"uid":306785,"like":0,"dislike":0,"score":0,"quote":{"pid":"a633915d761c15d635641fac1385e60ec12ab7f7","tid":1383160,"uid":16123,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-31T09:16:32.000Z","msg":"我覺得最慘係每次覆診要等個幾鐘<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-21T10:56:47.000Z","msg":"同感<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />好想佢直接確實同我講要等幾耐<br />\n甘樣我就可以出去消磨時間"},{"pid":"46f5604524e3c495b301578d89494cae7bbeb961","tid":1383160,"uid":16123,"like":0,"dislike":0,"score":0,"quote":{"pid":"13fc45de72adc348dd05606a8c24981a283ae91b","tid":1383160,"uid":306785,"like":0,"dislike":0,"score":0,"quote":{"pid":"a633915d761c15d635641fac1385e60ec12ab7f7","tid":1383160,"uid":16123,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-31T09:16:32.000Z","msg":"我覺得最慘係每次覆診要等個幾鐘<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-21T10:56:47.000Z","msg":"同感<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />好想佢直接確實同我講要等幾耐<br />\n甘樣我就可以出去消磨時間"},"citedBy":1,"replyTime":"2019-08-21T11:30:19.000Z","msg":"我都係咁話, 等個幾鐘, 睇5-10分鐘出返黎<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n我去個間仲要得幾個位, 成日企係到等個幾鐘<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><br />\n有時覺得有啲陪人去睇就唔好坐, 一個人睇兩三個人陪,霸哂啲位坐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a61668d3acef4376a28a41416b88229343ebac64","tid":1383160,"uid":306785,"like":0,"dislike":0,"score":0,"quote":{"pid":"46f5604524e3c495b301578d89494cae7bbeb961","tid":1383160,"uid":16123,"like":0,"dislike":0,"score":0,"quote":{"pid":"13fc45de72adc348dd05606a8c24981a283ae91b","tid":1383160,"uid":306785,"like":0,"dislike":0,"score":0,"quote":{"pid":"a633915d761c15d635641fac1385e60ec12ab7f7","tid":1383160,"uid":16123,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-31T09:16:32.000Z","msg":"我覺得最慘係每次覆診要等個幾鐘<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-21T10:56:47.000Z","msg":"同感<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />好想佢直接確實同我講要等幾耐<br />\n甘樣我就可以出去消磨時間"},"citedBy":1,"replyTime":"2019-08-21T11:30:19.000Z","msg":"我都係咁話, 等個幾鐘, 睇5-10分鐘出返黎<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n我去個間仲要得幾個位, 成日企係到等個幾鐘<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><br />\n有時覺得有啲陪人去睇就唔好坐, 一個人睇兩三個人陪,霸哂啲位坐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-21T12:17:52.000Z","msg":"有時企係到 有空位但係附近嚟左個啱啱嚟嘅老人家 <br />\n都唔好意思坐<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n搞到我次次去都要早啲 好似爭位<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"afa0b0888844426320d19bfccd5fb50c3b937bc9","tid":1383160,"uid":325346,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-23T13:40:52.000Z","msg":"認同<br />\n整可能整5-15分鐘<br />\n但前面條友整成個鐘<br />\n乜mood都無晒<br />\n好心牙醫唔好預15分鐘睇一個<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}