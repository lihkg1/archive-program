 class=\"hkgmoji\" />"},{"pid":"4c668c15583618a8ea88d661f8d50cb119ceb6d8","tid":1884604,"uid":92448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-17T17:12:17.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4880974103148f75ca0c2aaa25eb8347f7906249","tid":1884604,"uid":213747,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-02-17T17:12:27.000Z","msg":"咁想唱榮光借俾你唱囉 早講嘛<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"ecbcc45e16269490c17558d2c8c295942fc1e29a","tid":1884604,"uid":268410,"like":1,"dislike":0,"score":1,"quote":{"pid":"f235ddc276237ad854c0d1e75a3560bbcc0086c5","tid":1884604,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-02-17T16:52:33.000Z","msg":"大陸新冠肺炎確診病例，突破了7萬大關，死亡人數超過1700人，儘管疫情還沒獲得控制，但大陸外交部似乎已經急著在國際間消毒，外交部長王毅到德國出席國際會議，強調「黎明正在到來」，更說大陸防疫措施完善，其他國家根本做不到。<br />\n<br />\n大陸外交部長 王毅：「黎明正在到來，曙光就在前方。」<br />\n<br />\n高喊即將迎來曙光，這是大陸外交部長王毅，對新冠肺炎疫情下的最新註解。<br />\n<br />\n大陸外交部長 王毅：「疫情確實給中國的經濟，和社會發展帶來了挑戰，中國經濟的大勢，和長期向好的基本面，沒有也不會改變。」<br />\n<br />\n王毅特地飛到德國，參加慕尼黑安全會議，但他出席的目的，更像是要幫這波從大陸爆發的新冠肺炎，來做外交上的大消毒。<br />\n<br />\n大陸外交部長 王毅：「目前在中國境外，確診的病例，僅僅佔到所有病例的1%，我們卓有成效地，阻止了疫情在全球範圍的擴散。」<br />\n<br />\n堅稱全球疫情並不嚴重，王毅此行還特地在德國安排路透社專訪，親上火線，就是要親自消滅對大陸隱匿疫情、防疫破功的國際輿論。<br />\n<br />\n大陸外交部長 王毅：「我們把防控疫情做得如此徹底，我看任何一個其他國家做不到，但是中國做到了。」<br />\n<br />\n宣稱大陸防疫，無人能敵，王毅話鋒一轉，劍指美國。<br />\n<br />\n大陸外交部長 王毅：「確實也有一些國家，他們的反應有些過度，那麼甚至會引發一些，不必要的恐慌，那麼也不符合WHO，提出的政策建議。」<br />\n<br />\n言下之意，罵的就是美國帶頭執行旅遊禁令和撤僑，都是反應過度，而且美國要捐一億美元幫助大陸防疫，這筆錢，王毅也說免了吧。<br />\n<br />\n大陸外交部長王毅：「既然是給中國及其他需要的國家，我們建議美國可以用在，最需要的地方和最需要的國家。」<br />\n<br />\n<a href=\"https://tw.news.yahoo.com/大陸展開國際-消毒-王毅-疫情控制黎明將至-160538856.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.news.yahoo.com%2F%E5%A4%A7%E9%99%B8%E5%B1%95%E9%96%8B%E5%9C%8B%E9%9A%9B-%E6%B6%88%E6%AF%92-%E7%8E%8B%E6%AF%85-%E7%96%AB%E6%83%85%E6%8E%A7%E5%88%B6%E9%BB%8E%E6%98%8E%E5%B0%87%E8%87%B3-160538856.html&d=rocWq0H159RMtn9QCTPVbHhUmc0vP2awQoWdJLgJf%2FY%3D&h=e4051b99\" target=\"_blank\">https://tw.news.yahoo.com/大陸展開國際-消毒-王毅-疫情控制黎明將至-160538856.html</a>"},"citedBy":0,"replyTime":"2020-02-17T17:14:41.000Z","msg":"打少陣飛機啦仆街"},{"pid":"e7939bded6ea9719c8eb0f49b4f9ec9e2c294ddb","tid":1884604,"uid":54927,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-17T17:15:19.000Z","msg":"黎明來到？"},{"pid":"471b5389985d73b786d6da6687c5e47534ceafd1","tid":1884604,"uid":54927,"like":0,"dislike":0,"score":0,"quote":{"pid":"4880974103148f75ca0c2aaa25eb8347f7906249","tid":1884604,"uid":213747,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-02-17T17:12:27.000Z","msg":"咁想唱榮光借俾你唱囉 早講嘛<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-17T17:16:11.000Z","msg":"唔割"},{"pid":"b4cf03cf9699e21bbec5ab181d359407f7a31607","tid":1884604,"uid":141151,"like":8,"dislike":0,"score":8,"quote":{"pid":"68ea02588e593cb3103b4659e03a1983e2d8a26d","tid":1884604,"uid":26876,"like":103,"dislike":1,"score":102,"citedBy":2,"replyTime":"2020-02-17T16:54:04.000Z","msg":"<span style=\"font-size: xx-large;\">黎明來到</span>"},"citedBy":1,"replyTime":"2020-02-17T17:16:14.000Z","msg":"<strong><span style=\"font-size: xx-large;\">要光復</span></strong>"},{"pid":"ead727e3c2bf0bf42a6c0ca92bb8d41b760f12dc","tid":1884604,"uid":160176,"like":5,"dislike":0,"score":5,"quote":{"pid":"b4cf03cf9699e21bbec5ab181d359407f7a31607","tid":1884604,"uid":141151,"like":8,"dislike":0,"score":8,"quote":{"pid":"68ea02588e593cb3103b4659e03a1983e2d8a26d","tid":1884604,"uid":26876,"like":103,"dislike":1,"score":102,"citedBy":2,"replyTime":"2020-02-17T16:54:04.000Z","msg":"<span style=\"font-size: xx-large;\">黎明來到</span>"},"citedBy":1,"replyTime":"2020-02-17T17:16:14.000Z","msg":"<strong><span style=\"font-size: xx-large;\">要光復</span></strong>"},"citedBy":1,"replyTime":"2020-02-17T17:17:05.000Z","msg":"這"},{"pid":"a8283e503e5666e0ccbf27270c6fc60d74f79af6","tid":1884604,"uid":207462,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime"