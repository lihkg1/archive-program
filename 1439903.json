normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"72f08569698a4b0a1bf412b16342f426fa85618f","tid":1439903,"uid":67069,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:14:53.000Z","msg":"推"},{"pid":"de9b8e93fd2e1d99d682140e6295e4b4fd1d94e0","tid":1439903,"uid":202889,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-10T15:17:03.000Z","msg":"兩手空空係咪大機會D"},{"pid":"094157c0392d770c4007dc91a89c0597a1ac8277","tid":1439903,"uid":115977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:19:25.000Z","msg":"Push"},{"pid":"882286d26a68e211ab37f891169e38963189d7ea","tid":1439903,"uid":88177,"like":1,"dislike":0,"score":1,"quote":{"pid":"de9b8e93fd2e1d99d682140e6295e4b4fd1d94e0","tid":1439903,"uid":202889,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-10T15:17:03.000Z","msg":"兩手空空係咪大機會D"},"citedBy":0,"replyTime":"2019-08-10T15:19:34.000Z","msg":"唔係，兩手空空同孭背囊都有見過，最緊要問多兩句，你一chok問source通常都會縮。"},{"pid":"f22b651ecb3cf60a387337c4dad86e41760807ff","tid":1439903,"uid":300697,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:23:53.000Z","msg":"值得大家關注"},{"pid":"c6e614c0608c11fa63b5a65445ba2aed5c30c471","tid":1439903,"uid":300697,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-10T15:24:30.000Z","msg":"自己執生，不要過度信任"},{"pid":"5eaf1095e673051d0417eb0e408a86ca7a9323e5","tid":1439903,"uid":88177,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-10T15:31:18.000Z","msg":"<span style=\"font-size: x-large;\"><span style=\"color: red;\">[整合]</span></span><br />\n<br />\n1. 應對策略<br />\n- 唔好硬撼，保持<span style=\"color: red;\"><strong>50-100米</strong></span>距離後 <br />\n- 望下身處位置，留意逃生路線係咪一致，係咪一條<strong><span style=\"color: red;\">大直路</span></strong>，例如觀塘道，欽洲街。<br />\n- 冷靜睇清楚旗號，狗推進慢，突擊步程短 ，<strong><span style=\"color: red;\">多數跑完100米左右就收皮</span></strong>要重整，如無意外係走得甩<br />\n- 如有懷疑問多兩句，<strong><span style=\"color: red;\">問source</span></strong>，冷靜d<br />\n<br />\n<br />\n2. 提高警覺<br />\n- &ldquo;警察由唔同方向嚟緊，包抄緊！&rdquo;<br />\n- 通常出現喺盾陣前面前線！<br />\n- 警察防線一推進，會喺最前帶路，<span style=\"color: red;\">大約一個鐘左右就會突然消失</span>！<br />\n- 通常係男，可能着黑衫，戴豬<br />\n- 突然間話要快閃某個好遠嘅地方！仲要係走埋嚟逐個同你講，唔係用大聲公。<br />\n咀。<br />\n- 可能會show個live地圖出黎，話你知邊道有狗過緊黎！<br />\n<br />\n<br />\n<span style=\"color: red;\">總言之，小心駛得萬年船，一個都不能少。</span>"},{"pid":"3c9a76a92b8e0686471e73b06a487608cfdae4d0","tid":1439903,"uid":88177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:31:59.000Z","msg":"推"},{"pid":"463009dc481c5d70f7dec52d1d3cf5864826a2ff","tid":1439903,"uid":88177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:33:50.000Z","msg":"農曆七月要防撞鬼"},{"pid":"c05bd49f63cb7bede4df81ce5d0b6abcc0f4024d","tid":1439903,"uid":88177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:34:24.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"ec43c52691264e0d8ba2f09e35f0146292b5e00f","tid":1439903,"uid":88177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:34:35.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3f06800adf183f2ab819b49fb98764821719ad55","tid":1439903,"uid":88177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:47:38.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"7e9a2458cfa26927e6dd05ad5ed8ed0279ba352d","tid":1439903,"uid":88177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:48:13.000Z","msg":"推呀"},{"pid":"328412952fee25eac59cda38207966ed504c5044","tid":1439903,"uid":88177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:48:24.000Z","msg":"推呀"},{"pid":"3c74977fbebb3f1221e9ee76d63f1068fb779d2e","tid":1439903,"uid":88177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T15:48:36.000Z","msg":"唔好沉呀"},{"pid":"933c90b1d84b3044afb90414ba318a2481d8196f","tid":1439903,"uid":1247,"like"