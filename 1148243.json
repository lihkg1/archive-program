og/haha.gif\" class=\"hkgmoji\" />"},{"pid":"8b82a78f9fe7431b11544ff18a7c1bf1d40f4d7d","tid":1148243,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-10T12:45:14.000Z","msg":"貿易戰背景下<br />\n美帝主義荷里活大片復仇者 喺大陸大收<br />\n就知邊個係莊 邊個喺閒"},{"pid":"0ada51f511f96973a0d5f640866184c43f1c0fac","tid":1148243,"uid":133375,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-10T12:46:17.000Z","msg":"g持出兵<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6574eb2b472463aa57464cfbc248b101e6865697","tid":1148243,"uid":90403,"like":2,"dislike":0,"score":2,"quote":{"pid":"fcd0d777c7de1fb6ef33dc10b36240a6fbb3e7b2","tid":1148243,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-10T10:47:36.000Z","msg":"中美第11回合貿易談判於美國時間9日晚間展開，不過由於雙方未達成共識，美國預定對中國價值2000億美元商品開徵的25%關稅，於美國時間10日0時1分（台灣時間10日12時1分）確定生效。<br />\n<br />\n對此，中國商務部深表遺憾，並表示將不得不採取必要的反制措施。<br />\n<br />\n消息一出，中國網友留言支持商務部的強硬態度，責怪美國「耍流氓」、「美帝主義」，批評川普「對待政治如同兒戲」，也有人罵「川普是個神經病，中國已經足夠強大，不會聽任這個金毛撒野」、「美國人太不要臉！」<br />\n<br />\n另有一群網友則相信中國政府能夠反制美國。「美方真的是在作死」、「與美國抗爭到底！」、「支持強烈反擊」、「大國底氣！」、「全中國人民團結起來。反對霸權主義！」、「支持政府採取強有力反制措施。」<br />\n<br />\n還有網友表示，「美帝就像個小孩，說翻臉就翻臉，沒有信用度，亳無大國風範和擔當。對世界及百姓極不負責。最後只能自食其果。」<br />\n<br />\n中國國務院副總理劉鶴對於磋商失敗表示，「我們感到遺憾。所以希望找到最好的方法來解決。」<br />\n<br />\n《環球時報》10日也刊登一篇社評稱，出口對中國經濟成長的比例一直在下降，美國拉高的關稅轉化成GDP以後，「肯定是很小的百分之零點幾」，企圖說明對美國開徵25%高關稅的影響很低。<br />\n<br />\n此外，對於美國政府能否持續對中國課徵高關稅1年以上，社評指稱「非常難」，對此表達質疑。<br />\n<br />\n<a href=\"https://tw.mobi.yahoo.com/news/中美貿易戰-中國網友呼籲打倒-美帝主義-萬餘則留言支持商務部反擊-100100188.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.mobi.yahoo.com%2Fnews%2F%E4%B8%AD%E7%BE%8E%E8%B2%BF%E6%98%93%E6%88%B0-%E4%B8%AD%E5%9C%8B%E7%B6%B2%E5%8F%8B%E5%91%BC%E7%B1%B2%E6%89%93%E5%80%92-%E7%BE%8E%E5%B8%9D%E4%B8%BB%E7%BE%A9-%E8%90%AC%E9%A4%98%E5%89%87%E7%95%99%E8%A8%80%E6%94%AF%E6%8C%81%E5%95%86%E5%8B%99%E9%83%A8%E5%8F%8D%E6%93%8A-100100188.html&d=hvrwae4HshPHSMms9GCCYC1yjuEIKew%2F2lwpseS6mRM%3D&h=86f624bb\" target=\"_blank\">https://tw.mobi.yahoo.com/news/中美貿易戰-中國網友呼籲打倒-美帝主義-萬餘則留言支持商務部反擊-100100188.html</a>"},"citedBy":0,"replyTime":"2019-05-10T13:02:47.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" />"},{"pid":"574ace3eea3feb20be9decc74a0554466928183c","tid":1148243,"uid":14503,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-10T13:06:01.000Z","msg":"玉石俱焚 or 以卵擊石？<br />\n支持反擊<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"30332a80c8c7087d2c68ec1c573bc2f87dd049f9","tid":1148243,"uid":29816,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-10T13:08:49.000Z","msg":"係就快啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"405d2e2a6350676ea5869bd6df102269bae3c4dc","tid":1148243,"uid":20815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-10T13:11:56.000Z","msg":"還有網友表示，「美帝就像個小孩，說翻臉就翻臉，沒有信用度，亳無大國風範和擔當。對世界及百姓極不負責。最後只能自食其果。」<br />\n<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />新聞封鎖真係慘"},{"pid":"22f881444a819e952780ce697da86d45683837ea","tid":1148243,"uid":12265,"like":3,"dislike":0,"score":3,"quote":{"pid":"9859a762f9ab306cf4c96b5f996df21258525242","tid":1148243,"uid":99962,"like":8,"dislike":0,"score":8,"citedBy":2,"replyTime":"2019-05-10T11:25:44.000Z","msg":"如果一人一送張張綠卡唔知佢地會點<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-10T13:15:42.000Z","msg":"打倒共產黨口號隨即四起<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},{"pid":"0061614c8d9514a01ad55043d921bd1e5f3f228c","tid":1148243,"uid":11301,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-10T13:22:18.000Z","msg":"操你媽，咱們中國人不能夠被洋鬼子欺負<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" 