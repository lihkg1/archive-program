:1883932,"uid":132587,"like":25,"dislike":0,"score":25,"citedBy":1,"replyTime":"2020-02-17T12:51:41.000Z","msg":"時間證明左hktvmall會成功<br />\nviutv都唔例外<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-17T12:53:24.000Z","msg":"電視一向都係極長線投資"},{"pid":"66a07fa5d96bbaa3a941cc62a919d7d15163f0cd","tid":1883932,"uid":227275,"like":0,"dislike":0,"score":0,"quote":{"pid":"ab1d3a4410e49020332b0d996035c86c99a12c5b","tid":1883932,"uid":6435,"like":0,"dislike":0,"score":0,"quote":{"pid":"88dd450c184c326e6f5b0f1a48d600d68df4e24e","tid":1883932,"uid":132587,"like":25,"dislike":0,"score":25,"citedBy":1,"replyTime":"2020-02-17T12:51:41.000Z","msg":"時間證明左hktvmall會成功<br />\nviutv都唔例外<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-17T12:53:24.000Z","msg":"電視一向都係極長線投資"},"citedBy":1,"replyTime":"2020-02-17T12:53:52.000Z","msg":"viutv只係誠哥既一件玩具"},{"pid":"6acd5e4b1b22b51625abe1e46396415b0d1f84ad","tid":1883932,"uid":289708,"like":7,"dislike":0,"score":7,"quote":{"pid":"66a07fa5d96bbaa3a941cc62a919d7d15163f0cd","tid":1883932,"uid":227275,"like":0,"dislike":0,"score":0,"quote":{"pid":"ab1d3a4410e49020332b0d996035c86c99a12c5b","tid":1883932,"uid":6435,"like":0,"dislike":0,"score":0,"quote":{"pid":"88dd450c184c326e6f5b0f1a48d600d68df4e24e","tid":1883932,"uid":132587,"like":25,"dislike":0,"score":25,"citedBy":1,"replyTime":"2020-02-17T12:51:41.000Z","msg":"時間證明左hktvmall會成功<br />\nviutv都唔例外<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-17T12:53:24.000Z","msg":"電視一向都係極長線投資"},"citedBy":1,"replyTime":"2020-02-17T12:53:52.000Z","msg":"viutv只係誠哥既一件玩具"},"citedBy":1,"replyTime":"2020-02-17T12:55:05.000Z","msg":"Richard既玩具"},{"pid":"af46339ea8aa0585f0955151d44dc6aaa6b5c827","tid":1883932,"uid":7439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-17T14:56:36.000Z","msg":"<a href=\"https://www.thestandnews.com/culture/%E5%A5%87%E5%A6%99%E9%9B%BB%E8%A6%96%E5%95%9F%E6%92%AD%E5%89%8D-%E7%9C%8Bviutv%E7%9A%84%E6%96%B0%E4%B8%80%E8%BC%AA%E6%94%BB%E5%8B%A2/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fculture%2F%25E5%25A5%2587%25E5%25A6%2599%25E9%259B%25BB%25E8%25A6%2596%25E5%2595%259F%25E6%2592%25AD%25E5%2589%258D-%25E7%259C%258Bviutv%25E7%259A%2584%25E6%2596%25B0%25E4%25B8%2580%25E8%25BC%25AA%25E6%2594%25BB%25E5%258B%25A2%2F&d=Fzfx2iZ%2BI%2BdTugby0OFGQ7Tr7UizNwCuyTydxCoZ6r4%3D&h=43da2ec6\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fculture%2F%25E5%25A5%2587%25E5%25A6%2599%25E9%259B%25BB%25E8%25A6%2596%25E5%2595%259F%25E6%2592%25AD%25E5%2589%258D-%25E7%259C%258Bviutv%25E7%259A%2584%25E6%2596%25B0%25E4%25B8%2580%25E8%25BC%25AA%25E6%2594%25BB%25E5%258B%25A2%2F&h=e24cf3ec\" target=\"_blank\">https://www.thestandnews.com/culture/%E5%A5%87%E5%A6%99%E9%9B%BB%E8%A6%96%E5%95%9F%E6%92%AD%E5%89%8D-%E7%9C%8Bviutv%E7%9A%84%E6%96%B0%E4%B8%80%E8%BC%AA%E6%94%BB%E5%8B%A2/</a><br />\n跟住來到戲肉《午夜伴廊》，<span style=\"color: red;\">我不明白 ViuTV 既然可以下决心取消《帶住矛盾去旅行２》，怎不再忍痛當機立斷處決這個自家製作劇集（可能是外判出去，但怎都屬本地製作）？</span><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />它不是自殺式收視炸彈是甚麼？可以看得出的是，是它有心，很想搞新意，追求風格化......但起碼對我來說確實很難頂，逼到自己看多一集是因為它打住「朱凌凌」的招牌，總帶來一絲希望熱身後會有些少可觀之處，但結果，再次強調只是「對我來說」，仍屬慘不忍睹。<br />\n<br />\n從演員和製作團隊的陣容看，今次是話劇人 revamp，涉足搞電視節目，由較多公眾熟識的白只拉大隊，以廟街歌廳為背景，聽落都算幾特別，而他們亦不甘心沿隨港台式的踏實或無綫的 melodramatic 路線，但可惜拍得如果客氣些講句，真是太&hellip;...性格了，相比先前替 Viu TV 省招牌，經過精心包裝的《瑪嘉烈與大衛》和《三一如三》，《午夜伴廊》似在刻意唱反調，另闢蹊徑拍一部飄忽無重心的「爛衫戲」，頭一二集基本上沒有情節或發展可言，在歌廳搞個天才比賽，盡量玩參賽者各種各樣的「騎呢」。<br />\n<br />\n事實上劇集似乎正想用「騎呢」當成風格，甚至賣點，<span style=\"color: red;\">製作團隊或許認為是他們獨特的美學觀，是一部「藝術性」、「前衛」、「荒誕」、「另類」集一身的電視劇集而引以為傲</span>，但唔想講到咁白都無可逃避要講，劇中幾個女角還可以，其餘所有大小男角的造型和外觀，已大大超出「玩個性」，實在太&hellip;&hellip;醜了，醜到令我作哂悶，甚至無法令自己直視螢幕。<br />\n<br />\n也許有人反駁同一電視台周末出街另一個新節目主持人林雪不是更醜嗎？但不要忘記他勝在有大氣、有聲勢、有他只此一家的 charisma，更是 icon 級人馬，而白只和他的同行者，起碼在電視圈才剛起步，仍未成氣候，根本不夠本錢拿醜出來橫行哂冷，<span style=\"color: red;\">他們似乎忘了 ViuTV 先前的自製戲劇節目，如有為人津津樂道之處，就是包裝得「型」，是品味，以小清新的畫面和音樂去吸引自詡為同類的觀眾</span>，包括這些「有型人」箇中的一些 KOL，大家有著「識英雄重英雄亅的良好感覺，當然醜也可以很有型，不過《午夜伴廊》在這方面顯然力有不逮了。"},{"pid":"df19d05e13d3fb920271289fc9c8da8043b4cdbf","tid":1883932,"uid":2819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-17T14:58:10.000Z","msg":"viu 好波"},{"pid":"66625ccab8bc55e578da1c7084e58181704b93c9","tid":1883932,"uid":85180,"like":0,"dislike":0,"score":0,"quote":{"pid":"6852494a1c1267c83f150e5c7cfca54805672d77","tid":1883932,"uid":14337,"like":17,"dislike":0,"score":17,"quote":{"pid":"7fea50c9fa4b94728a1ed4e2566545c4b695dc0f","tid":1883932,"uid":228995,"like":4,"dislike":0,"score":4,"citedBy":3,"replyTime":"2020-02-17T12:41:37.000Z","msg":"mirror救viutv?"},"citedBy":1,"replyTime":"2020-02-17T12:52:39.000Z","msg":"係error"},"citedBy":0,"replyTime":"2020-02-17T15:06:35.000Z","msg":"係姜濤"},{"pid":"6caa1c9fb01e0aabf9a1524000506e627ce14d11","tid":1883932,"uid":108337,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-17T15:07:40.000Z","msg":"仲係蝕緊<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"ccb7d5e08414853f319f2215beee048526ac2c3e","tid":1883932,"uid":31098,"like":0,"dislike":0,"score":0,"quote":{"pid":"6caa1c9fb01e0aabf9a1524000506e627ce14d11","tid":1883932,"uid":108337,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-17T15:07:40.000Z","msg":"仲係蝕緊<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-17T15:26:01.000Z","msg":"對阿 Richard 嚟講三億散紙嚟啫<br />\n最重要係佢有無興趣繼續玩 <img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"10cb4f5507b324bacdc58a18b62df55c353ee988","tid":1883932,"uid":7439,"like":0,"dislike":0,"score":0,"quote":{"pid":"6acd5e4b1b22b51625abe1e46396415b0d1f84ad","tid":1883932,"uid":289708,"like":7,"dislike":0,"score":7,"quote":{"pid":"66a07fa5d96bbaa3a941cc62a919d7d15163f0cd","tid":1883932,"uid":227275,"like":0,"dislike":0,"score":0,"quote":{"pid":"ab1d3a4410e49020332b0d996035c86c99a12c5b","tid":1883932,"uid":6435,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-17T12:53:24.000Z","msg":"電視一向都係極長線投資"},"citedBy":1,"replyTime":"2020-02-17T12:53:52.000Z","msg":"viutv只係誠哥既一件玩具"},"citedBy":1,"replyTime":"2020-02-17T12:55:05.000Z","msg":"Richard既玩具"},"citedBy":0,"replyTime":"2020-02-17T16:46:25.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2d8327b43c1fa5b033423402b79106cb434ac702","tid":1883932,"uid":7439,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-21T07:09:45.000Z","msg":"<em>立春過後，才正式進入令人聞風喪膽的庚子年。歷史會記載今年的大事件，而電視業也面臨着萬象更新。無綫主席陳國強在立春卸任，黎瑞剛心腹許濤已得到香港永久居民身份，可以合法擔任董事局主席，未知黎氏真正掌權後，會為無綫帶來怎樣天翻地覆的改變。<br />\n<br />\n陳國強二○一一年入股無綫時，無綫股價是四十多元，到他二○一五年成為董事局主席，股價已跌至三十多元，而到他卸任時，股價一直徘徊在十一、 二元。<span style=\"color: red;\">無綫近年股價跌幅驚人，這也是管理層的成績表。無綫去年上市三十年首次蝕錢，罪魁禍首除了星美債券，也是明顯的業績倒退，而下半年網民抵制在無綫落廣告的商戶，對無綫廣告收益有前所未見的影響，黃金時段廣告是肉眼可察的減少。</span><br />\n<br />\n新年假期收視受惠於觀眾抗疫而留在家中，《開心速遞》重現平均二十七點的佳績，<span style=\"color: red;\">但有收視沒廣告，又有何用呢？無綫要開源，就靠中資企業落廣告和合拍劇</span>，但大陸受疫情影響最嚴重，整個社會停頓，正所謂人算不如天算，誰會想到，天下間竟然會需要擔心無綫出不了糧的一天？當天王維基申請電視牌失敗，又有誰想到HKTV mall會有市值超越無綫的一天？<br />\n<br />\n無綫和其他競爭者的競逐，像極了寓言故事龜兔賽跑，因為兔子從不把烏龜當作對手，而無綫這隻兔子，也不重視跟烏龜比賽這個賽場，要從香港區選手成為中國區選手。然而，烏龜默默地向前爬，雖然走得慢，但起碼方向正確。<span style=\"color: red;\">公平地說，ViuTV和HKTV mall去年中期業績仍然虧損超過一億，但企業形象討好，業務正面發展中。</span><br />\n<br />\nViuTV節目質素參差，但《黑市》帶來不少希望。向來對王貽興和劉翁組合諸多批評，但《黑市》發揮了王貽興所長。摒除連續劇結構，具有點子的單元，再加上人文味道，凸顯出短篇小說才是才子的看家本領。《黑市》最大缺點是節奏較慢，<span style=\"color: red;\">主因是短篇故事內容和反轉不足以支撐一小時單元</span>，若然仿效《世界奇妙物語》一小時三個故事，一定會更精采。<br />\n<br />\n不過，單元劇有助於ViuTV發展，因為旗下藝人可以充分得到鍛鍊演技的機會。無綫藝員青黃不接，但看着《理想國》和《黑市》，<span style=\"color: red;\">都驚訝於ViuTV能演戲的人有那麼多。ViuTV用藝人不如無綫複雜，基本不是無綫人都可以用</span>，相反，無綫既要捧親生仔，又害怕會益了外人，反而變得綁手綁腳。新一年，陸續傳來無綫不跟老演員續約的消息，除了開源節流，也期望無綫重新檢視藝人制度。<br />\n<br />\n</em>"},{"pid":"b1260b6f75f1807ba47cbf89e79e21d2a081ad63","tid":1883932,"uid":117729,"like":0,"dislike":0,"score":0,"quote":{"pid":"7fea50c9fa4b94728a1ed4e2566545c4b695dc0f","tid":1883932,"uid":228995,"like":4,"dislike":0,"score":4,"citedBy":3,"replyTime":"2020-02-17T12:41:37.000Z","msg":"mirror救viutv?"},"citedBy":0,"replyTime":"2020-02-21T07:17:14.000Z","msg":"error救viutv"}]}