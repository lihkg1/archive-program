>\n環保署發言人表示，署方自去年11月多次接獲投訴，指觀塘瑞和街一帶，有蔬菜店持續以門前揚聲器，大聲播放叫賣錄音，嚴重影響附近居民。環保署隨後多次巡查，並在今年4月發現，該店經警告後仍持續大聲播放錄音；在評估附近住宅後確認噪音已構成煩擾，遂按《噪音管制條例》提出檢控。"},{"pid":"8ad021426a556c7986c7c6d9f408b097f6f36d85","tid":912860,"uid":2500,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-23T06:18:43.000Z","msg":"老是常出現"},{"pid":"6f03b0e074d66b545735b23339623a547b70bd04","tid":912860,"uid":40804,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-23T06:26:22.000Z","msg":"香港葛咸城<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"ce65821cdf323a523b733f9676e7e3b25cd5f2e1","tid":912860,"uid":71748,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-23T06:49:01.000Z","msg":"9蚊斤菜心平咩？"},{"pid":"4725c8a7364c4826c42522ac2f3adfb8051788cf","tid":912860,"uid":54373,"like":0,"dislike":0,"score":0,"quote":{"pid":"ce65821cdf323a523b733f9676e7e3b25cd5f2e1","tid":912860,"uid":71748,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-23T06:49:01.000Z","msg":"9蚊斤菜心平咩？"},"citedBy":0,"replyTime":"2018-11-23T07:01:21.000Z","msg":"你想世清賣$8？"},{"pid":"b273058619793bfa8b2107bc492904e1b6da1080","tid":912860,"uid":155558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-23T07:31:44.000Z","msg":"我建議你落深水埗行一行"}]}