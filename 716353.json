lass=\"hkgmoji\" />"},{"pid":"0cff12331746e5d6f615dae5488edc12f839ba48","tid":716353,"uid":57376,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-29T00:46:51.000Z","msg":"終於到29號<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" />"},{"pid":"3fb0c388f7d28b346f7b39b5cfc16d9b475f246d","tid":716353,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-03T01:32:52.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"fcf066f400c7f4805a6403a6616f95e0af467bc3","tid":716353,"uid":141151,"like":0,"dislike":0,"score":0,"quote":{"pid":"3fb0c388f7d28b346f7b39b5cfc16d9b475f246d","tid":716353,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-03T01:32:52.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-03T01:34:44.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <br />\n走數﹗<br />\n賣國侵"},{"pid":"9d20b2cd407bbb4deeedf7b46a0194610aeb97ab","tid":716353,"uid":17008,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-03T01:51:00.000Z","msg":"中國唔敢郁手中國投資既美國公司<br />\n中國d咩智庫一日到黑講中國勃起，無諗到人地可以咁玩，依排雞手鴨腳唔識應對<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"97926146e32663beb7f02e4dd49c1e9f9e73112c","tid":716353,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-03T04:42:50.000Z","msg":"<img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" />"},{"pid":"fef5f73d24d79bf418fa3aabd0f74d08f7f617b2","tid":716353,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-04T02:58:25.000Z","msg":"<img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" />"}]}