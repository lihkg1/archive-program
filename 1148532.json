3:26.000Z","msg":"臭嘅人"},{"pid":"e0b44524f632ffd8b70bc00ca314a9a40801ea28","tid":1148532,"uid":72564,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-05-10T14:25:14.000Z","msg":"靚女 搞到我成程車都要扯住旗<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"28facdc1bc4b3bd449ec3d58e214da280cfd5df8","tid":1148532,"uid":68457,"like":1,"dislike":0,"score":1,"quote":{"pid":"715ab3098b8d5fb67d741aba8652435ecb7a6d4f","tid":1148532,"uid":21395,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2019-05-10T14:02:47.000Z","msg":"臭狐<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-10T14:27:23.000Z","msg":"盡量放慢呼吸"},{"pid":"4b177b957161f349a532f373f3f82de7a436a5e2","tid":1148532,"uid":69841,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-10T14:51:28.000Z","msg":"有臭狐 煙味 打完波唔沖身啲汗味etc.<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n遇過最難頂係個鬼婆 有浸咖喱人味濃烈50倍左右咁嘅味 離遠都頂唔順想嘔<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},{"pid":"4760356df6dc3625309c34281ad946a57566772e","tid":1148532,"uid":21395,"like":0,"dislike":0,"score":0,"quote":{"pid":"28facdc1bc4b3bd449ec3d58e214da280cfd5df8","tid":1148532,"uid":68457,"like":1,"dislike":0,"score":1,"quote":{"pid":"715ab3098b8d5fb67d741aba8652435ecb7a6d4f","tid":1148532,"uid":21395,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2019-05-10T14:02:47.000Z","msg":"臭狐<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-10T14:27:23.000Z","msg":"盡量放慢呼吸"},"citedBy":0,"replyTime":"2019-05-10T14:57:54.000Z","msg":"我一係行去第二卡<br />\n一係落車等下架<br />\n真係臭到想嘔<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"fe2be99978cb5ab41abb981b78edc7b4387885b8","tid":1148532,"uid":190368,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2019-05-10T14:59:31.000Z","msg":"咳到肺甩 但唔帶罩<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"cd5d3890e0fc1f4