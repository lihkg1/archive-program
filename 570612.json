7.000Z","msg":"唔明樓主想玩乜"},{"pid":"ff7c9eeaa215e845c5fbff158290af6306cadf2b","tid":570612,"uid":78429,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2018-02-23T21:33:28.000Z","msg":"算罷啦<br />\n<br />\n求其換下色又當係"},{"pid":"6a4445b606deeaa69f3c14ffbfd8513d5ba58ed3","tid":570612,"uid":29021,"like":2,"dislike":12,"score":-10,"quote":{"pid":"12bc9e19b00c6cf46ca5351f8814a309da8dc61a","tid":570612,"uid":48796,"like":15,"dislike":1,"score":14,"citedBy":1,"replyTime":"2018-02-23T21:18:37.000Z","msg":"唔明樓主想玩乜"},"citedBy":1,"replyTime":"2018-02-23T21:42:02.000Z","msg":"將brand A 融合落 brand B 嘅風格，但係又要保留返brand A 嘅名<br />\n通常係A公司買咗B公司，然後又想話俾人知已經一統天下，同時又要保留舊brand name以免啲人唔知以為間嘢執笠留唔住舊客，就會有啲咁嘅情況<br />\n而家就係玩rebranding，一齊ff吓個brand會俾另一個brand蹂躪成點<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f5b702743f39dbd66ceac4509ea80778d7b0fc82","tid":570612,"uid":29021,"like":2,"dislike":5,"score":-3,"quote":{"pid":"ff7c9eeaa215e845c5fbff158290af6306cadf2b","tid":570612,"uid":78429,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2018-02-23T21:33:28.000Z","msg":"算罷啦<br />\n<br />\n求其換下色又當係"},"citedBy":1,"replyTime":"2018-02-23T21:43:39.000Z","msg":"好多時的確啲公司搞rebrand都係換色、簡化線條咁就當係，咁但係其實一啲都唔求其，配色同埋字型配搭已經係一樣好考功夫嘅野嚟"},{"pid":"cf8a0a612118ca2894bd4375211643c5e05dff4a","tid":570612,"uid":72795,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-02-23T21:45:22.000Z","msg":"留名 幾好玩"},{"pid":"015b2baa3ab7cf36b9aec4fe0c52d45b8f4ecd89","tid":570612,"uid":78429,"like":1,"dislike":3,"score":-2,"quote":{"pid":"f5b702743f39dbd66ceac4509ea80778d7b0fc82","tid":570612,"uid":29021,"like":2,"dislike":5,"score":-3,"quote":{"pid":"ff7c9eeaa215e845c5fbff158290af6306cadf2b","tid":570612,"uid":78429,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2018-02-23T21:33:28.000Z","msg":"算罷啦<br />\n<br />\n求其換下色又當係"},"citedBy":1,"replyTime":"2018-02-23T21:43:39.000Z","msg":"好多時的確啲公司搞rebrand都係換色、簡化線條咁就當係，咁但係其實一啲都唔求其，配色同埋字型配搭已經係一樣好考功夫嘅野嚟"},"citedBy":1,"replyTime":"2018-02-23T21: