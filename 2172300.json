/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"33b07fcd47e414e6b2a0cd289162fe160bbeae7c","tid":2172300,"uid":81273,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-24T14:10:35.000Z","msg":"買波衫條友係老闆安排"},{"pid":"c607cd1a2215fd1795d7945d049c1f4c41b4de13","tid":2172300,"uid":196860,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-24T14:38:22.000Z","msg":"以為歌詞"},{"pid":"d96aef4d52d3c9527bec38aeff172eb59c2cefdb","tid":2172300,"uid":199081,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-24T14:43:23.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b0fb0f85fe61e9ff1414555b1b9dc73b3813fc56","tid":2172300,"uid":236878,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-24T14:55:13.000Z","msg":"潮文？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1dac24ce593fee9cfb826845d1ed929a9df9aa05","tid":2172300,"uid":87155,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-24T15:55:22.000Z","msg":"屌你老未邊到搵<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"a1fce5cd95b860c40db5485e0d7f755ce49c3544","tid":2172300,"uid":370738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-24T16:19:30.000Z","msg":"睇曬<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"26cacd13f1fe445a2b388b9b75dadf83e604bb17","tid":2172300,"uid":313974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-24T17:08:21.000Z","msg":"幾好笑<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"176b19946e46e878f4cadcafd71f8284f820926c","tid":2172300,"uid":5549,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-24T17:25:52.000Z","msg":"邊道抄返黎？都幾癲<img s