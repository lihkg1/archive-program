g&d=NEeHCsu%2FqEZuPycg%2B0xSpmg5BW3O7pEdz%2F%2BecHjXtrw%3D&h=f69d3a2d\" data-auto-link target=\"_blank\">https://t.me/joinchat/LC07DRR2_Zhy4SozxReqrg</a>"},{"pid":"814c1e751b5a0629f06bc74e0378b6120264cd76","tid":1702382,"uid":70246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:29:53.000Z","msg":"1111"},{"pid":"3bea0b56b3a59fbda010a2da25c4ca50255dd87d","tid":1702382,"uid":205927,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:32:40.000Z","msg":"推"},{"pid":"4d80e31f0e3c65513de3790931ce01f1bff79f15","tid":1702382,"uid":136591,"like":0,"dislike":0,"score":0,"quote":{"pid":"dde541260119ce073d6427ea6ac1eb6cfcd317a0","tid":1702382,"uid":48987,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-09T17:26:04.000Z","msg":"見到狗 湧上去 踩死"},"citedBy":0,"replyTime":"2019-11-09T17:33:14.000Z","msg":"勇氣！"},{"pid":"0b9f281c9e609a972d0c707a533a1b16282f8fa9","tid":1702382,"uid":48873,"like":0,"dislike":0,"score":0,"quote":{"pid":"5e389414dce6f4c8c11a3443dac0778d409e54f6","tid":1702382,"uid":265917,"like":26,"dislike":0,"score":26,"citedBy":2,"replyTime":"2019-11-09T16:10:16.000Z","msg":"<span style=\"color: violet;\"><span style=\"font-size: xx-large;\"><strong>想多啲人參與擺工？</strong></span></span><br />\n<br />\n<span style=\"color: pink;\"><span style=\"font-size: x-large;\">小妹發現facebook好少行動文宣流通 <br />\n同埋好少係街收到airdrop既文宣</span></span><br />\n<br />\n<strong>要記住嚟場革命唔係淨係屬於連登仔<br />\n四五十歲既人多數淨係上fb 佢地多數只會認同大眾都吹奏緊既野</strong><br />\n<br />\n<span style=\"color: violet;\"><span style=\"font-size: xx-large;\"><strong>我地有咩可以做？</strong></span></span><br />\n<br />\n<span style=\"color: pink;\"><span style=\"font-size: x-large;\"><strong>正所謂「識睇一定睇comment」<br />\n1）我地要多啲係唔同post下面貼行動文宣同出下發夢注意事項post<br />\n2）仲有要係街不斷airdrop啲文宣俾人</strong></span></span><br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>零成本 你唔係唔做呀嘛</strong></span></span>"},"citedBy":0,"replyTime":"2019-11-09T17:36:45.000Z","msg":"贊成 宣傳嚴重不足"},{"pid":"56a377c815e130b7cdcf709c1a43e7c148fb42a0","tid":1702382,"uid":136591,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:40:40.000Z","msg":"推"},{"pid":"eaaee0092ffbd05705027f7d3654ec3d16804d2c","tid":1702382,"uid":64810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:42:13.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"0a2a967e6a9a9ede35a47e7e0d2eae2aa5eaba3b","tid":1702382,"uid":30019,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-09T17:42:14.000Z","msg":"此回覆已被刪除"},{"pid":"edae6593573f1a34da20230f80b0549ce507f4bb","tid":1702382,"uid":325757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:43:56.000Z","msg":"仆街臭狗！<br />\n香港報仇啦！"},{"pid":"9e0b73900dc80f514874f1287c428a2be9bf4f57","tid":1702382,"uid":191366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:44:29.000Z","msg":"光復香港 時代革命"},{"pid":"a4a7506242e536144a3961345f7574d458c3c67a","tid":1702382,"uid":136591,"like":0,"dislike":0,"score":0,"quote":{"pid":"0a2a967e6a9a9ede35a47e7e0d2eae2aa5eaba3b","tid":1702382,"uid":30019,"like":0,"dislike":0,"score":0,"quote":{"pid":"f8e9154916dca679d793b81cb46910a8b4ff4a20","tid":1702382,"uid":136591,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-09T16:08:19.000Z","msg":"五個月既抗爭之路，大家一齊走過。<br />\n當中士氣有高漲，有低落。<strong><span style=\"color: orange;\">大家都好叻</span></strong>，一齊走過當中高高低低。<br />\n大家回想下，自己既付出：<br />\n<strong><span style=\"color: blue;\">老年人</span></strong>：相信各公公婆婆都心痛學生，不少晚上睇住電視而流淚。更身體力行落街抗爭。<br />\n<strong><span style=\"color: blue;\">大人</span></strong>：心痛學生，憤而出錢支援學生，落街屌狗，更甚用自己地位、職業去發聲。<br />\n<strong><span style=\"color: blue;\">年青人</span></strong>：以血肉之軀抵抗政權，被家人踢出家門、放低學業、係前線擋子彈、食煙食椒、係狗屋被毒打、被強姦。<br />\n<br />\n首先，<span style=\"font-size: large;\"><span style=\"color: red;\">好多謝大家一路並肩作戰</span></span>。<br />\n<br />\n數之不盡既<strong><span style=\"color: red;\">手足被捕、被打、被斬、被彈傷、被自殺、被浮屍、被送中、被姦。</span></strong><br />\n更有<strong><span style=\"color: red;\">數位手足放低遺願，先走一步。</span></strong><br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: maroon;\">這時這刻，大家憤怒、震怒。</span></span><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">周同學既遇害，女手足既被強姦。</span></span><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: violet;\">我們永不忘記！</span></span><br />\n<br />\n<span style=\"color: gold;\">曙光來了。</span>因為全民憤怒。<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: violet;\">夫戰，勇氣也。</span></strong></span><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: pink;\">讓憤怒化作勇氣。<br />\n</span></span><br />\n<br />\n<strong><span style=\"color: gold;\">政府害怕了。</span></strong>近日與警察慢慢割席。<br />\n<span style=\"color: gold;\"><strong>警察害怕了。</strong></span>近日與前線慢慢割席。<br />\n他們害怕的，是我們香港人民。<br />\n<br />\n共匪游擊專家，毛澤東所言：<span style=\"font-size: xx-large;\"><span style=\"color: red;\">「敵疲我打，敵退我追」</span></span><br />\n<br />\n機會來了。大家要好好把握。<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">各路同志，珍重。</span></span><br />\n明天，後天。將來。以港人之名，重奪香港。<br />\n同行兒女，一起光復香港。<br />\n<br />\n<img src=\"https://na.cx/i/od4FWXv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fod4FWXv.jpg&h=90120750&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/CoZ3ahw.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCoZ3ahw.png&h=24b72a8c&s={SIZE}\" /><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: gold;\">光復香港，時代革命。</span></strong></span>"},"citedBy":1,"replyTime":"2019-11-09T17:42:14.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-11-09T17:45:25.000Z","msg":"光復香港 時代革命"},{"pid":"2c61098ab1c791f0a375d91969c00c2b6e4512f4","tid":1702382,"uid":164634,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:50:32.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: orange;\"><strong>自由 唔係他人賦予 而係要爭取返黎架</strong></span></span>"},{"pid":"a7f5331436f2c4a15da2bc7fa006c4cdf82fa402","tid":1702382,"uid":322175,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:51:09.000Z","msg":"共產黨  今次真係 末路了<br />\n1)  殺香港 2萬人 ,再鎖國 15年<br />\n2)  美國佬 分一半 香港 管治權<br />\n<br />\n如果係1) 大家可以 安心 閃出香港 ,15年後再見<br />\n如果係2) 香港 要先立23條 ,要嚟克制美帝爪牙<br />\n(其實共產黨 怕死...... 變現實)<br />\n這一波 至係真EndGame反抗<br />\n<br />\n現在一班港豬 還指望  什麼選舉 ..什麼人權法<br />\n30日後 全部落空 ...... 希望幻滅 ....<br />\n在分化的 大家 ...... 才死決心一&ldquo;戰&rdquo;<br />\n<br />\n&ldquo;戰&rdquo;  才有未來 .......<br />\n選舉 =&ldquo;不戰&rdquo;...制度不改 一樣死,但可遲10年死<br />\n人權法 ... (忘了它吧！) .....先說利益 &ldquo;錢&rdquo;<br />\n&ldquo;不戰&rdquo; ... 美國佬見幫共產黨有着數 當然幫共產黨, <br />\n但如果一&ldquo;戰&rdquo;  香港贏了 ,重此立國都得<br />\n如果輸了 美國佬 ,會退市冷戰 =冇錢<br />\n如果 美國佬 真係為錢 ,<br />\n就算開戰 美國佬 反而更有理據幫香港"},{"pid":"e9864cfebb5b21e615dc7652c68fa17861c10df9","tid":1702382,"uid":12583,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:52:31.000Z","msg":"1111 大三罷"},{"pid":"337891cf2b65c6a0a7e2a13b45b97b5455d0c877","tid":1702382,"uid":208099,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:54:51.000Z","msg":"<a href=\"https://youtu.be/0yXTHODE24Q\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F0yXTHODE24Q&d=NEeHCsu%2FqEZuPycg%2B0xSpmg5BW3O7pEdz%2F%2BecHjXtrw%3D&h=cd5a71ed\" target=\"_blank\">https://youtu.be/0yXTHODE24Q</a>"},{"pid":"d9af9f6762199c22c499f23827116a1babbb87ee","tid":1702382,"uid":65354,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T17:55:05.000Z","msg":"光復香港 時代革命"},{"pid":"d53104a5f9c243937c156b561327239f7a8ef882","tid":1702382,"uid":30019,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-09T18:01:20.000Z","msg":"此回覆已被刪除"},{"pid":"284c24a6415bd3871ef357f41bcecacd743649be","tid":1702382,"uid":136591,"like":0,"dislike":0,"score":0,"quote":{"pid":"d53104a5f9c243937c156