m%2Fdb%2Fpeople%2Fview.mhtml%3Fid%3D5785%26display_set%3Dbig5&d=QL8Dn08IhbOMzyUdcig6xU%2FDJpISyAq9ELy6OyFxwDc%3D&h=bae6ad3d\" target=\"_blank\">http://hkmdb.com/db/people/view.mhtml?id=5785&amp;display_set=big5</a><br />\n以前喺電影叫伊凡威喎 <img src=\"https://img.eservice-hk.net/upload/2018/09/24/014534_12dce3cb521d639bb955ddb0f91a02e5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F24%2F014534_12dce3cb521d639bb955ddb0f91a02e5.png&h=feefedce&s={SIZE}\" />"},{"pid":"14a13627ceba7175e7ca71e256b80bf5165b3e98","tid":985972,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-18T06:20:43.000Z","msg":"<blockquote><blockquote><blockquote>方剛、龍方 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n重有鄒兆龍<br />\n<br />\n腳趾姐果然係上一代香港人 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n睇開舊港產既一定會識依班人既薑汁兄 <img src=\"https://img.eservice-hk.net/upload/2018/05/05/130749_f6d79dfbdfb935b547b31d6eec79afed.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F05%2F130749_f6d79dfbdfb935b547b31d6eec79afed.png&h=0657fa5a&s={SIZE}\" /></blockquote>到底趾嬸幾多歲<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /></blockquote><br />\n年齡係女人秘密吖ok <img src=\"https://img.eservice-hk.net/upload/2018/05/05/130749_f6d79dfbdfb935b547b31d6eec79afed.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F05%2F130749_f6d79dfbdfb935b547b31d6eec79afed.png&h=0657fa5a&s={SIZE}\" />"},{"pid":"a0a93c98d45337c9e0b2417c23cd1dd76a67e1fb","tid":985972,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-18T07:15:53.000Z","msg":"<img src=\"https://cdn.discuss.com.hk/t/6a91e4/f/320x0/http://ww2.sinaimg.cn/mw690/006wjEcYjw1f88z0abq0mj30ci09e3z1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.discuss.com.hk%2Ft%2F6a91e4%2Ff%2F320x0%2Fhttp%3A%2F%2Fww2.sinaimg.cn%2Fmw690%2F006wjEcYjw1f88z0abq0mj30ci09e3z1.jpg&h=26ed71c2&s={SIZE}\" /><br />\n<br />\n盧惠光<br />\n<br />\n曾是泰拳冠軍，86年拍攝首部影片《扭計雜牌軍》，之後進入成家班, 代表作:《A計劃》、《警察故事》、《賭神》、《赤子威龍》、《寶貝計畫》、《新宿事件》、《奪帥》、《滅門》、《古惑仔系列》演綽號「太子」和《千王之王2000》王晶的手下等<br />\n《醉拳2》的一字馬腳踢開鐵桶，令人深刻<br />\n《超級學校霸王》仲要同張學友、劉德華、黎明三大天王和任達華等對戰"},{"pid":"1301583f689c30854b992b068751e381bc41e94d","tid":985972,"uid":44730,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-01-18T07:16:11.000Z","msg":"<img src=\"https://cdn.discuss.com.hk/t/b64e9b/f/320x0/http://ww2.sinaimg.cn/mw690/006wjEcYjw1f8837j62mmj30ci09i3zm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.discuss.com.hk%2Ft%2Fb64e9b%2Ff%2F320x0%2Fhttp%3A%2F%2Fww2.sinaimg.cn%2Fmw690%2F006wjEcYjw1f8837j62mmj30ci09i3zm.jpg&h=66b8e90e&s={SIZE}\" /><br />\n<br />\n徐少強<br />\n<br />\n做過股市會計，後來被邵氏睇中改行做演員，至今也有三十年， 《咏春》裡和甄子丹和楊紫琼對打就知道身手不錯<br />\n《龍虎列傳2》飾演天剎邪神<br />\n《武狀元蘇乞兒》飾演反派趙無極"},{"pid":"ab9817d4a637809a8630ca92208af3151032b838","tid":985972,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-18T07:16:57.000Z","msg":"<img src=\"http://ww1.sinaimg.cn/mw690/006wjEcYjw1f88z06jfyjj30ci09374r.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fww1.sinaimg.cn%2Fmw690%2F006wjEcYjw1f88z06jfyjj30ci09374r.jpg&h=d2200b41&s={SIZE}\" /><br />\n<br />\n王霄<br />\n<br />\n已故，是反派中最富有貴族氣質的演員，跟尊龍的氣質相仿，多做高智商的犯罪，代表作:《我在黑社會的日子》、《上海皇帝之歲月風雲》、《警察故事3》等<br />\n演《至尊無上之兄弟情深》的賭徒和《鼠膽龍威》的高智商罪犯，令人深刻，演古裝也好型"},{"pid":"d54a41a0a5ead7ab1bb3d37f7c55bb7cbe8cd7ad","tid":985972,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-18T07:17:29.000Z","msg":"<img src=\"http://ww1.sinaimg.cn/mw690/006wjEcYjw1f88z07128yj30ci08jdge.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fww1.sinaimg.cn%2Fmw690%2F006wjEcYjw1f88z07128yj30ci08jdge.jpg&h=1072a902&s={SIZE}\" /><br />\n<br />\n曹查理<br />\n<br />\n張智霖的舅父，邵氏公司出身的喜劇演員，多演衣冠禽獸和勢利小人，亦接拍多部三級片，代表作品有《最佳損友》、《猛鬼霸王花》、《卿本佳人》、《情不自禁》、《我為卿狂》，《艷降勾魂》等"},{"pid":"0b77586199416315de80ece62606468a56fa12bc","tid":985972,"uid":146435,"like":1,"dislike":0,"score":1,"quote":{"pid":"ab9817d4a637809a8630ca92208af3151032b838","tid":985972,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-18T07:16:57.000Z","msg":"<img src=\"http://ww1.sinaimg.cn/mw690/006wjEcYjw1f88z06jfyjj30ci09374r.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fww1.sinaimg.cn%2Fmw690%2F006wjEcYjw1f88z06jfyjj30ci09374r.jpg&h=d2200b41&s={SIZE}\" /><br />\n<br />\n王霄<br />\n<br />\n已故，是反派中最富有貴族氣質的演員，跟尊龍的氣質相仿，多做高智商的犯罪，代表作:《我在黑社會的日子》、《上海皇帝之歲月風雲》、《警察故事3》等<br />\n演《至尊無上之兄弟情深》的賭徒和《鼠膽龍威》的高智商罪犯，令人深刻，演古裝也好型"},"citedBy":0,"replyTime":"2019-01-18T07:17:51.000Z","msg":"醫生 人總需要靠自己"},{"pid":"7a57c9a04f7d72ae924cf1bc1bac2fffea7389e7","tid":985972,"uid":44730,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-01-18T07:18:02.000Z","msg":"<img src=\"http://ww4.sinaimg.cn/mw690/006wjEcYjw1f89hxjb5inj30ci08zdge.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fww4.sinaimg.cn%2Fmw690%2F006wjEcYjw1f89hxjb5inj30ci08zdge.jpg&h=9abe6e4f&s={SIZE}\" /><br />\n<br />\n翁世傑&nbsp;&nbsp;<br />\n<br />\n97後去了美國，戲裡專演花花公子，次次想用迷藥迷奸女角但都失敗，之後接拍多部三級片，代表作：《滿清禁宮奇案》、《凶貓》、《精裝追女仔》、《最佳損友》、《城市特警》等&nbsp;<br />\n《精裝追女仔》和《最佳損友》為人所熟識"},{"pid":"37f5042700dab00708947c469d952a879c49c9df","tid":985972,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-18T07:18:35.000Z","msg":"<img src=\"http://ww4.sinaimg.cn/mw690/006wjEcYjw1f88z086plnj30ci08v0td.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fww4.sinaimg.cn%2Fmw690%2F006wjEcYjw1f88z086plnj30ci08v0td.jpg&h=267f69e7&s={SIZE}\" /><br />\n<br />\n楊群<br />\n<br />\n他得過第七屆和第十一屆金馬獎的兩次影帝<br />\n早年代表作《千王之王》的北千王和《金瓶雙豔》的西門慶<br />\n《一本漫畫闖天涯》演黑幫老大"},{"pid":"5ce923c55128f89eac26b2ef9a946fd578a98bee","tid":985972,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":