B1%E8%A1%8C%E5%B1%B1%E5%A2%AE%E7%9F%B3%E6%BE%97%E4%B8%80%E5%BA%A6%E5%A4%B1%E8%B9%A4-%E7%9B%B4%E5%8D%87%E6%A9%9F%E6%95%91%E8%B5%B7%E9%80%81%E9%99%A2%E4%B8%8D%E6%B2%BB</a><br />\n<span class=\"x-large\">一名外籍男子下午3時許到馬鞍山郊野公園行山，行至馬大石澗的英雄瀑時，懷疑失足墮落水潭中，被水沖走，失去蹤影，同行女友人報警求助。<br />\n<br />\n警方及救援人員上山搜索，經過1小時後，鎖定男事主的位置，將他獲起，惟男事主當時已陷入昏迷，頭部流血，由飛行服務隊直升機將他吊起，送往東區醫院搶救，惟證實傷重不治。<br />\n<br />\n該名男子的親友事後趕到醫院了解，得知男子不治後在醫院外後傷心痛哭。警方正調查事件原因。</span>"},{"pid":"0e04956dd29d85acf138039f517d8cf53f477647","tid":2164782,"uid":118120,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-08-19T11:38:09.000Z","msg":"明知風勢大仲去....."},{"pid":"3993826c4705731df0f6e63535720da078b5be8b","tid":2164782,"uid":343268,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-08-19T11:41:09.000Z","msg":"此回覆已被刪除"},{"pid":"57a888b74bc41150225223961a51acdb5d6abf55","tid":2164782,"uid":35420,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-08-19T11:43:40.000Z","msg":"死得好<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"492822eaa3ca3a17737e7c5baa3e6a26036ad49b","tid":2164782,"uid":313615,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-19T11:44:18.000Z","msg":"無可疑"},{"pid":"18ab37972898a1a89155305dd29abee488da948c","tid":2164782,"uid":13303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-19T11:45:10.000Z","msg":"做英雄<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"e637072592125086eafdb787d0adb7e930ee9314","tid":2164782,"uid":356218,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2020-08-19T11:46:56.000Z","msg":"此回覆已被刪除"},{"pid":"efe9a5a3c0777e3b787251eaa12ee7391e866afb","tid":2164782,"uid":174317,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-19T11:49:22.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"b7cbe360f858ee1d5295ea763dfdee06c91f827e","tid":2164782,"uid":283700,"like":1,"dislike":2,"score":-1