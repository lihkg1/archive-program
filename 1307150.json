 />\n<br />\n《自殺．自療．互助舍》"},{"pid":"1bca90a9e5fab0f608e1b29b57cdbf137c8fe795","tid":1307150,"uid":250382,"like":0,"dislike":1,"score":-1,"quote":{"pid":"1421ebaa03ce4088c9e8678b78997edd82ceab1c","tid":1307150,"uid":275191,"like":0,"dislike":1,"score":-1,"quote":{"pid":"36c349c84db95fec771d33b9c980028341443235","tid":1307150,"uid":250382,"like":1,"dislike":1,"score":0,"quote":{"pid":"eae5e35393dc92e4e835c7d6ba47b502ce95feb4","tid":1307150,"uid":275191,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-07-12T03:37:02.000Z","msg":"咁已經完全唔sweet<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />拍拖拍到好似單身咁"},"citedBy":1,"replyTime":"2019-07-12T03:49:26.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-12T03:50:12.000Z","msg":"但係我同佢講過分手 佢又唔想"},"citedBy":1,"replyTime":"2019-07-12T05:55:21.000Z","msg":"<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"}]}