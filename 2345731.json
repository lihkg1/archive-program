pid":"0ca18b523e0341a6fc824e1724ea82e5b3713f2f","tid":2345731,"uid":38861,"like":1,"dislike":2,"score":-1,"quote":{"pid":"42410311ff4a42c9e6a3b3648b0a5351ae3e1c05","tid":2345731,"uid":52076,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-29T18:21:34.000Z","msg":"食益生菌會唔會好啲？"},"citedBy":2,"replyTime":"2020-12-29T18:24:09.000Z","msg":"應該要長期持之以恆咁食先有機會改變得到<img src=\"/assets/faces/xm/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n至少益力多嗰隻係咁<img src=\"/assets/faces/xm/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"abc0be9dedcc846640376bae5e79a6b599b65439","tid":2345731,"uid":258345,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-12-29T18:25:08.000Z","msg":"高質<br />\n留名支持"},{"pid":"2fc98afa976ad725d7ed29cc5f6599390826eb7c","tid":2345731,"uid":230316,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-12-29T18:50:10.000Z","msg":"好少住家飯食<br />\n有無supplement推介"},{"pid":"c02d8b339c6ced0d3794f2a8fde6c3629ab4f6cb","tid":2345731,"uid":52076,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0ca18b523e0341a6fc824e1724ea82e5b3713f2f","tid":2345731,"uid":38861,"like":1,"dislike":2,"score":-1,"quote":{"pid":"42410311ff4a42c9e6a3b3648b0a5351ae3e1c05","tid":2345731,"uid":52076,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-29T18:21:34.000Z","msg":"食益生菌會唔會好啲？"},"citedBy":2,"replyTime":"2020-12-29T18:24:09.000Z","msg":"應該要長期持之以恆咁食先有機會改變得到<img src=\"/assets/faces/xm/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n至少益力多嗰隻係咁<img src=\"/assets/faces/xm/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-29T18:55:02.000Z","msg":"而家好似好多人食緊益生菌藥丸supplement咁<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />所以好奇一問"},{"pid":"f8c7633ac5799d5d46c8115594d7afd3fbb280d2","tid":2345731,"uid":353508,"like":0,"dislike":1,"score":-1,"quote":{"pid":"d356e7958566a4ad61487a0a6fa81bf3165207a7","tid":2345731,"uid":38861,"like":9,"dislike":1,"score":8,"quote":{"pid":"a7c4df5862200ae611a850a853c23eca15d8a523","tid":2345731,"uid":34119,"like":0,"dislike":3,"score":-3,"citedBy":2,"replyTime":"2020-12-29T18:08:53.000Z","msg":"盲腸係咪用嚟收集腸道細菌?<img src=\"/assets/faces/lm2xm/think.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-12-29T18:15:15.000Z","msg":"<img src=\"/assets/faces/pigxm/wine.gif\" class=\"hkgmoji\" />應該就唔係，結腸(Colon)就最多腸道細菌寄居。<img src=\"/assets/faces/pigxm/wine.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-29T19:03:34.000Z","msg":"所以點解比較多人有ca colon就係因為個度多細菌寄居<img src=\"/assets/faces/xm/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"27da78e555c91c02e72ece1ca9fd9fdff3be8eb1","tid":2345731,"uid":79851,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-12-29T19:32:15.000Z","msg":"啲科學家點知隻老鼠係易生癌？<img src=\"/assets/faces/lm2xm/think.gif\" class=\"hkgmoji\" />"},{"pid":"28a0570fc1d50222cc1e0bcb95526ce89128a1ef","tid":2345731,"uid":129676,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2020-12-29T19:36:46.000Z","msg":"係咪貼漏左要買咩產品既link<img src=\"/assets/faces/pigxm/heard.gif\" class=\"hkgmoji\" />"},{"pid":"13a41e5cfe90bf8aea24c95a5725e5ba2d42cf29","tid":2345731,"uid":123725,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7c4df5862200ae611a850a853c23eca15d8a523","tid":2345731,"uid":34119,"like":0,"dislike":3,"score":-3,"citedBy":2,"replyTime":"2020-12-29T18:08:53.000Z","msg":"盲腸係咪用嚟收集腸道細菌?<img src=\"/assets/faces/lm2xm/think.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-12-29T19:41:13.000Z","msg":"中學bio啊sir話人類進化到今時今日 盲腸已經冇用處 <br />\n反而兔仔嘅盲腸就用嚟消化乾草<br />\n<br />\n個人推測:<br />\n所以我諗如果人類盲腸同兔仔一樣功能嘅話 因為人類飲食習慣已經冇食草呢個選項好耐 所以就退化到冇用處"}]}