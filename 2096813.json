Fhk.appledaily.com%2Fresizer%2FAua48Z-vDRXUFaZLGh5YdJ9GXsM%3D%2F720x405%2Ffilters%3Aquality%28100%29%2Farc-photo-appledaily.s3.amazonaws.com%2Fap-ne-1-prod%2Fpublic%2F4UG5FMLQJZVNGUDTURBNGHNEWA.png&h=db7ebc41&s={SIZE}\" />"},"citedBy":2,"replyTime":"2020-07-06T12:12:57.000Z","msg":"呢一年<br />\n都未見過呢位法官判過案<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"45b4576347a1d2d18f27b44c4aef71019f6392be","tid":2096813,"uid":216521,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-06T12:13:07.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3a2d53c86ba25404aec01383c417a236a3e49c4b","tid":2096813,"uid":68706,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-07-06T12:13:50.000Z","msg":"一時糊塗又會喺關員表露身份時即刻走佬兼拒捕嘅？<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"74a18a5f64e749bec70a27188315820c263aefd2","tid":2096813,"uid":28432,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-07-06T12:13:57.000Z","msg":"睇咗陣個官講D野 都知會輕判 <img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><br />\n賣假貨賣到被海關斷正又襲擊海關 都可以吹到咁正面 香港法治得淡笑 <img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bf412ca83eff31de7ef86f0591f5275ce2057b0e","tid":2096813,"uid":272569,"like":0,"dislike":0,"score":0,"quote":{"pid":"e17af3355ef4793450978464a2cbdb1bbb7d3204","tid":2096813,"uid":5195,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-06T11:20:45.000Z","msg":"三年前加入警隊的警員，去年9月遭海關放蛇，揭發出售三對冒牌「adidas」波鞋，更在被捕時傷及三名海關人員。涉案警員今日在觀塘裁判法院承認四罪，求情透露去年曾於社會運動期間在最前線執勤並且受傷，對回復社會秩序有貢獻，早前卻因執勤而遭「起底」，導致精神及情緒受壓。裁判官杜浩成先索取社會服務令報告，押後至本月20日判刑，涉案警員獲准繼續保釋。<br />\n<br />\n被告黃港恆（25歲）今承認出售應用偽造商標的貨品、管有應用偽造商標的貨品罪作出售用途，以及兩項抗拒海關人員罪。控罪指他於去年9月26日在港鐵觀塘站大堂近A出口出售一對及管有兩對作出售用途、應用偽造「adidas」商標的波鞋，同日在上述地點故意抗拒兩名海關人員執行職務。<br />\n<br />\n辯方大律師求情指，被告接受高等教育後，於2017年加入警隊。去年社會運動期間，被告遭派遣到機動部隊最前線執勤，並曾受傷，對回復社會秩序作出貢獻，事後卻遭人「起底」，家中收到一些單張，令被告精神及情緒受壓。<br />\n<br />\n辯方大狀又指，被告與妻子育有一名九個月大男嬰，兩人居於三百呎單位。被告為了騰出空間擺放兒子的物品，將原價1,000元的「珍藏」以每對500元變賣，惟因糊塗，未查清楚涉案波鞋是否冒牌。辯方又指，被告父親五年前離世，被告要照顧患有精神病的母親。<br />\n<br />\n官：不希望警隊成為社會害群之馬<br />\n<br />\n至於抗拒關員的行為，大狀指被告是在情急下作出反應，為此感到懊悔，希望親口向關員致歉。被告承認控罪，將要面對警隊紀律聆訊，前途蒙上陰影。辯方呈上被告的上司、同僚及家人共52人的求情信件，內容指被告品格良好，希望首兩項控罪以罰款形式處理；至於抗拒關員罪名，希望法庭從其經濟及家庭背景考慮，判以社會服務令或感化令。<br />\n<br />\n裁判官杜浩成今指，過往處理警員干犯刑事罪行時已曾解釋，社會投放資源訓練警隊，希望他們維護社會安寧，打擊罪惡，認真執法，更希望他們以身作則，不會變成社會的害群之馬，這些都是社會的合理期望。<br />\n<br />\n杜官續指，被告投身警隊工作年資不長，但已贏得不少同事的讚賞，指被告工作認真，盡量爭取機會，在警務層面作出成績，又獲得兩位高級長官的評價，對被告相當有利。被告又因身份問題，涉在維護公眾秩序後引致被起底；案發時又由於被告家庭轉變，為騰出空間變賣物資而犯案，關員其後也搜不到其他偽冒品。<br />\n<br />\n被告作為警員守法意識不足<br />\n<br />\n惟被告在被捕時傷害執法人員，兩項控罪相對嚴重。而被告作為警員，守法意識不足，幸好本案與其執勤無關，否則將更嚴重。杜官先為被告索取社會服務令報告，同時警告被告索閱報告不代表不會判監。<br />\n<br />\n案情指，海關關員於網絡巡邏打擊冒牌，9月26日假扮買家，在觀塘港鐵站與被告進行交易。被告帶同三對球鞋，及後關員表露身份，被告即時逃跑。鄭姓關員捉住被告，惟被告在屢次警告下仍掙扎，其後有四名關員合力制服被告，包括馮姓關員按住被告雙手。惟被告不肯就犯，繼續掙扎，警告下仍強烈抵抗，最後被鎖上手銬制服。三名海關分別手腕、前臂及肩膊受傷。<br />\n【案件編號 ：KTCC335/20】"},"citedBy":0,"replyTime":"2020-07-06T12:14:05.000Z","msg":"智傷？"},{"pid":"31123a405b92b22488eba17e69a49b2faee45872","tid":2096813,"uid":14494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-06T12:14:12.000Z","msg":"犯法就係犯法？"},{"pid":"53254f679320934b503be24d24153b211756ca26","tid":2096813,"uid":346701,"like":1,"dislike":0,"score":1,"quote":{"pid":"f2f5d05df266df8ee043d5efc4ce220553612460","tid":2096813,"uid":103156,"like":8,"dislike":0,"score":8,"citedBy":4,"replyTime":"2020-07-06T11:22:56.000Z","msg":"高等教育即係？"},"citedBy":0,"replyTime":"2020-07-06T12:14:31.000Z","msg":"毅進大學<br />\n簡稱 毅大<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" />"},{"pid":"c46178b420210912bb0473bc41b767f679fbf76e","tid":2096813,"uid":97200,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-06T12:14:55.000Z","msg":"DLLM 學生社運被捕想保釋睇未期屋企人就咎由自取<br />\n做狗犯法情有可原<img src=\"/assets/faces/d