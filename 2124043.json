s/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d7be8db57631bf63a57c7fdd290dabb422ec5d32","tid":2124043,"uid":522,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-07-25T06:17:42.000Z","msg":"重推2025中國製造算啦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},{"pid":"1335279e8b13f0a58585f827f013ec8d013b2f62","tid":2124043,"uid":182475,"like":1,"dislike":0,"score":1,"quote":{"pid":"fa09718d797806981ebd272e9859de5045b5a2a2","tid":2124043,"uid":112232,"like":52,"dislike":3,"score":49,"citedBy":3,"replyTime":"2020-07-25T06:09:57.000Z","msg":"地攤經濟衰左一次<br />\n強仔仲要玩多次？"},"citedBy":1,"replyTime":"2020-07-25T06:20:50.000Z","msg":"佢唔低低地試多次就真係隨時滅黨啦今次"},{"pid":"267c9d85b5c0713c1c2063dc4cba7eb971787ae5","tid":2124043,"uid":54337,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-25T06:22:45.000Z","msg":"內循環呢？"},{"pid":"b1de738f60099e731d0d198131cff0bae74d93d4","tid":2124043,"uid":245441,"like":2,"dislike":0,"score":2,"quote":{"pid":"267c9d85b5c0713c1c2063dc4cba7eb971787ae5","tid":2124043,"uid":54337,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-25T06:22:45.000Z","msg":"內循環呢？"},"citedBy":0,"replyTime":"2020-07-25T06:24:39.000Z","msg":"有 炒散都係內循環 <br />\n以日計算"},{"pid":"b634470db6350f75fb69dfa2f63d873ed93ba69f","tid":2124043,"uid":45708,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-07-25T06:26:08.000Z","msg":"李克強違反香港國安法<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"009e0c8c3ff5c4c87cd4b1c4abe7beffb02a4dc0","tid":2124043,"uid":113929,"like":0,"dislike":0,"score":0,"quote":{"pid":"e9d963b3e488dc13b6384bf244a10549b7c4ac8e","tid":2124043,"uid":28114,"like":54,"dislike":0,"score":54,"citedBy":5,"replyTime":"2020-07-25T06:08:00.000Z","msg":"大陸經濟差到，炒散當正職<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-25T06:46:01.000Z","msg":"炒散=正職=要交稅"},{"pid":"aaf2398749a4199a7ab993d5b016ffccaca93315","tid":2124043,"uid":126133,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-07-25T06:49:15.000Z","msg":"咩吖，GDP升緊喎<br />\n又冇肺炎又冇水災喎<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n仲唔gogogo<br />\n<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"c79be4da4532e369406e49f286fd87b5e0a1e4a9","tid":2124043,"uid":130466,"like":1,"dislike":0,"score":1,"quote":{"pid":"752fe5522df4956d172f3920d80ea327c2a1418a","tid":2124043,"uid":28114,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-25T06:06:46.000Z","msg":"【記者蕭律生、駱亞／報導】中國經濟下滑嚴重，就業問題大。最近，中共總理李克強提到發展零工經濟，支持臨時工就業方式。北京一名擅長經濟研究的律師認為，李克強此舉不觸及中共本質問題，是無奈中的「舉措」。中國一名剛畢業的大學生則認為，這是李克強地攤經濟的2.0版。<br />\n<br />\n中共政府網7月23日消息，7月22日中共國務院常務會議上，李克強指，要支持多管道靈活就業，要鼓勵個體經營。同時要支持非全日制就業，即可能是臨時工，也可能是兼職，以此提升居民收入。李克強還稱要發展零工市場，讓城鎮居民和農民工就近加入零工經濟。<br />\n<br />\n北京一名擅長經濟研究的律師向本報分析說，這是李克強面對當下中國經濟崩盤、社會失序、災禍頻繁情況下的一種政治正確說法，也飽含無奈。「作為一個總理是可悲的，不通過和平民主的方式澈底改變社會，在專制獨裁的條件下，是沒有辦法走出這個死局。」<br />\n<br />\n該律師分析說，這些話沒有觸及大問題，即體制層面的計劃經濟與市場經濟、專制與自由的問題，是一種無關痛癢的講法，李克強可能是希望落得良心上不背負罪責，怕將來被清算罷了。<br />\n<br />\n中國一位剛畢業的大學生告訴本報記者：「李克強說的這個靈活就業其實就是變相承認就業形勢不好，要求各地政府鼓勵民眾打零工避免社會因失業問題不穩，這其實是他『地攤經濟』那個提法的2.0版，都屬於比較務實但是不怎麼顧面子的政策。上次地攤經濟被習派懟回去了，這次靈活就業恐怕不是太好懟，但是習被打了臉肯定不會善罷甘休，後頭有戲看了。」<br />\n<br />\n他還表示，「儘管自己找到工作了，但我的很多同學現在沒找到工作，要他們去打零工，估計心理落差會很大，但是聊勝於無，說不定還是得靠這個暫時維持一下，不至於過多啃老。」<br />\n<br />\n稍早，7月13日，李克強主持「經濟形勢專家和企業家座談會」時，再提地方政府要給企業減稅降費，以解決畢業生和農民工的就業問題。<br />\n<br />\n中國金融師任中道曾對本報表示，中共國庫空虛，各個地方政府都在到處搜刮，中央和地方的矛盾也很嚴重，政令不出中南海。<br />\n<br />\n李克強此前還提出「地攤經濟」，要求各地方給予支持，隨後就傳出北京城管下令嚴查占地擺攤，廣州、深圳等地方政府跟進，中共喉舌媒體亦紛紛轉向。<br />\n<br />\n7月7日，中共領導人習近平在給應屆畢業生回信中，要求各界克服疫情帶來的不利影響，要千方百計幫助大學畢業生就業。外界認為，這透露出大學生就業形勢已相當嚴峻。◇"},"citedBy":1,"replyTime":"2020-07-25T06:57:19.000Z","msg":"但係我又唔明，內地咁興讀碩讀博，明明人工唔高"},