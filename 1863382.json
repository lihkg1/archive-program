2cc21a6bf15ff","tid":1863382,"uid":291785,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-02-05T06:58:13.000Z","msg":"取消喇<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n命仔同錢，樣重要啲呀？"},"citedBy":1,"replyTime":"2020-02-06T06:11:42.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"876bfcdfab9c06c4c5679f3aff257d7ac733e760","tid":1863382,"uid":291785,"like":1,"dislike":0,"score":1,"quote":{"pid":"04c6a63c6008da10f7c1a321054878c3aa61fe5a","tid":1863382,"uid":13804,"like":0,"dislike":0,"score":0,"quote":{"pid":"c4220b4a048be716c4abebd70432cc21a6bf15ff","tid":1863382,"uid":291785,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-02-05T06:58:13.000Z","msg":"取消喇<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n命仔同錢，樣重要啲呀？"},"citedBy":1,"replyTime":"2020-02-06T06:11:42.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-06T06:52:31.000Z","msg":"第一，我唔建議去旅行主要係因為你一出門口要<span style=\"color: red;\"><strong>搭交通工具、會經出入口口岸</strong></span>。港共政府唔封關，之前仲有武漢飛機抵達機場。<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">依家都仲未禁止晒大陸航空，加上支那人衛生意識咁差，有病/潛伏期周街走，好容易中招<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /></span></strong></span><br />\n<br />\n第二，我唔會話香港一定好安全。因為淋病又唔全面封關、又唔派口罩，依家都去到社區爆發嘅階段<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" />我建議留返喺香港只係想大家唔好周街走，減少感染機會。所以我依家都係主要留喺屋企應對疫情。<br />\n<br />\n第三，有啲國家/地區的確安全過香港，因為冇確診個案，例如以色列。<span style=\"color: red;\"><strong>泰國都有確診個案</strong></span>，其實都唔算得上安全，<span style=\"font-size: large;\"><strong><span style=\"color: red;\">點樣可以證明到泰國安全過香港<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />？</span></strong></span>加上有新聞報道指出<span style=\"font-size: large;\"><strong><span style=\"color: red;\">泰國有的士司機中招<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />（詳情見下面條link）</span></strong></span>，<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>俾你去到泰國都要搭交通工具去住宿，而乘搭交通工具有機會會中招。</strong></span></span><br />\n<br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1505911-20200131.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1505911-20200131.htm&d=%2FE8yPsxO6SBEJdrny20pcWg5BW3O7pEdz%2F%2BecHjXtrw%3D&h=35a27aa9\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1505911-20200131.htm&h=9b15c1b4\" target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1505911-20200131.htm</a>"},{"pid":"231dd5a4ce5b052bcf81d52a85cab30b6f9e51a6","tid":1863382,"uid":22913,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T07:17:25.000Z","msg":"我呢幾日睇台灣新聞<br />\n台灣禁咗香港 都未禁泰國"},{"pid":"2ec2be82d54d77dd973f81f69a4d2e85056c9bb6","tid":1863382,"uid":261937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T07:19:39.000Z","msg":"我去布吉，希望平安<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"1d783dd6e44e9a382a3d87f4fa2cbb8c810450c4","tid":1863382,"uid":260223,"like":0,"dislike":0,"score":0,"quote":{"pid":"c53762af85b42dc88759abbd97005ba0533b2835","tid":1863382,"uid":59920,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-02-05T06:28:19.000Z","msg":"<img src=\"/assets/faces/normal/bouncy.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-06T07:26:14.000Z","msg":"早你一日出發 已cancelled <br />\nrefunded"},{"pid":"572bb7aeb0b92449ff48866453036f333abcb21f","tid":1863382,"uid":59920,"like":0,"dislike":0,"score":0,"quote":{"pid":"1d783dd6e44e9a382a3d87f4fa2cbb8c810450c4","tid":1863382,"uid":260223,"like":0,"dislike":0,"score":0,"quote":{"pid":"c53762af85b42dc88759abbd97005ba0533b2835","tid":1863382,"uid":59920,"like":0,"dislike":0,"scor