gmoji\" />"},{"pid":"7bd9f6c83b75e9f6115983604c9e75669a6cba99","tid":1530033,"uid":268131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:29:15.000Z","msg":"唔完美，但可以接受。"},{"pid":"d1b7be872857b2728ae7d5179eb2e9111530e9d6","tid":1530033,"uid":59971,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:30:34.000Z","msg":"推"},{"pid":"ab94daada586861926a13abee7b1c84a07ec9f0c","tid":1530033,"uid":252510,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:31:00.000Z","msg":"認同 然後我罷左工"},{"pid":"532e255ba6a435819f9ed9d6d76635abfac73f26","tid":1530033,"uid":244809,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:31:53.000Z","msg":"罷工有成本<br />\n要減低風險同成本，要做到8月5前個社會氣氛<br />\n起碼公司冇寫明會留record,就係叫你地拎假小心<br />\n但共出聲後，四大同好多銀行都冇再講可以彈性上班或home office<br />\n所以依家要幫學生罷左課先，搞返個氣勢先再諗"},{"pid":"4d5068734fa2da71bb66de789611872e4998eac3","tid":1530033,"uid":218084,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:32:58.000Z","msg":"真係太多資訊 加埋831<br />\n關於罷工方面宣傳的確被轉移左<br />\n唔緊要架 不完美 改善就得<br />\n拎住個831呢個核彈 儲住大家嘅憤怒<br />\n之後再黎多次真正大罷工<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n呢幾日重點係罷課 <br />\n罷課就已經講左好耐 <br />\n呢個就一定要搞得成啦！"},{"pid":"fe1fd4d46b1ef7d9c22e34fa35b4401a045f2551","tid":1530033,"uid":277853,"like":1,"dislike":0,"score":1,"quote":{"pid":"2232ed546a7ee8efc91fc94617ba3807a6f335c0","tid":1530033,"uid":31215,"like":17,"dislike":0,"score":17,"quote":{"pid":"34fbc30355cdebbdd5e26bec2aced5d8a7a26909","tid":1530033,"uid":215487,"like":2,"dislike":1,"score":1,"citedBy":2,"replyTime":"2019-09-02T00:56:11.000Z","msg":"有冇手足 感覺愈來愈失望"},"citedBy":2,"replyTime":"2019-09-02T00:58:46.000Z","msg":"你睇到尋日就知唔使失望啦<br />\n幾多人入機場<br />\n幾多人救仔<br />\n<br />\n如果失望係動員唔到更多市民<br />\n其實feel到大家有心<br />\n之後宣傳做好啲"},"citedBy":0,"replyTime":"2019-09-02T01:33:53.000Z","msg":"推<br />\n<br />\n呢個真<br />\n尋日接放學嘅車龍長到一個點<br />\n<br />\n<br />\n罷工好難，藍老闆會炒你黃老闆又唔想佢無飯開<br />\n某啲深黃行業又被白色恐怖同道德綁架控制<br />\n學子罷到課會有noise<br />\n但都唔夠和理非集吸睛"},{"pid":"c35f0b55319551a69fc956cc4aee87581438700f","tid":1530033,"uid":162327,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:34:00.000Z","msg":"同埋今日多狗都係敗因 一入站幾批防暴"},{"pid":"6e475896b687b47c3f148b130e506782f9b6c115","tid":1530033,"uid":218084,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:34:22.000Z","msg":"同埋都真 <br />\n之前5/8大家會識話留力聽日呀咁<br />\n今次罷工前發生太多野 仲要好沉痛嘅野<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4815b18c4af818799aaaf80c2e3fee5cd48c9a30","tid":1530033,"uid":300937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:34:33.000Z","msg":"岩呀其實好多人都係睇個勢先再決定嘅 所以宣傳真係好重要<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"cf24697d2533caa3c83d2eeb0c30ec1708e18636","tid":1530033,"uid":263618,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:35:16.000Z","msg":"講咗唔好塞鐵,頂"},{"pid":"5c4fb5f5985899b1a64926d7acc6430c1aaa6375","tid":1530033,"uid":182802,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:37:13.000Z","msg":"1430 添馬"},{"pid":"3418727fe3f1739645f2d0cd68d7c27ce55e59f1","tid":1530033,"uid":294068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:38:16.000Z","msg":"<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"dac9e7d1597cf8e55038e1f847f8904800d16043","tid":1530033,"uid":126403,"like":0,"dislike":0,"score":0,"quote":{"pid":"34fbc30355cdebbdd5e26bec2aced5d8a7a26909","tid":1530033,"uid":215487,"like":2,"dislike":1,"score":1,"citedBy":2,"replyTime":"2019-09-02T00:56:11.000Z","msg":"有冇手足 感覺愈來愈失望"},"citedBy":0,"replyTime":"2019-09-02T01:39:32.000Z","msg":"仲有好多同路人嫁，唔好失望呀！<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"e6fc90d75a0c03ed48083c5e3029eab0f678b3cd","tid":1530033,"uid":179414,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:41:23.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"1b91559c98c148d494b882a1831c9db7e003bdd1","tid":1530033,"uid":65457,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-02T01:41:46.000Z","msg":"85大罷工係幾樣野配合而成<br />\n早好多日已經知道罷工係要去邊<br />\n七區集會宣傳得好好<br />\n反觀今次好似為罷課主導咁<br />\n8月2有醫護同公務員集會 仲有旺角再遊行<br />\n黃大仙街坊既勇武<br />\n所以真係可一不可再<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1fa06cc1df68758cbe0818e95cab3c655aff74f9","tid":1530033,"uid":13610,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:44:48.000Z","msg":"不完美 可接受 有改善空間"},{"pid":"56ef54dd55f915b91b49b93fa398b497ce602abd","tid":1530033,"uid":78020,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:45:37.000Z","msg":"1430去集會<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"95433b5c94100b8b40bdbe9500d4b43c1212729d","tid":1530033,"uid":174950,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-02T01:45:59.000Z","msg":"認同樓主。<br />\n之前85三罷自己都有去，全公司都有參與85罷工。<br />\n亦有去到集會，但今日我公司冇參與到。<br />\n<br />\n因為老闆話唔知罷左工之後可以做啲咩，<br />\n全部同事都話如果有集會嘅話，罷工冇問題。<br />\n因為佢地想為香港出一分力。<br />\n<br />\n但係去到今日三罷，<br />\n我啲同事話宣傳不足。<br />\n冇明確目標嘅集合地點，<br />\n完全冇方向。<br />\n<br />\n所以一定要有宣傳，<br />\n仲要係有足夠嘅宣傳。<br />\n要明確話比人聽集合地點，<br />\n塞鐵，回旋處駕駛練習都要做。<br />\n唔好再理民意撚，<br />\n好多人都好希望可以被罷工。<br />\n<br />\n香港人，加油。<br />\n香港人，缺一不可。<br />\n光復香港，時代革命。"},{"pid":"3449bf9d90abc48fec8876f981be4e0c7d38fda2","tid":1530033,"uid":199050,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:46:12.000Z","msg":"冷氣軍師淨係識屌人唔罷工<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n屌你老尾返足5日工，星期六日仲企出嚟，被圍行撚到仆街，你估我今日想返工呀！"},{"pid":"6c803aae687f59cd4c38db04d02a645a1e81d68b","tid":1530033,"uid":69473,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:51:39.000Z","msg":"不完美但可一齊改善！<br />\n兄弟爬山，一齊努力！"},{"pid":"ea9fe1cd109bbcc501a7d4ec00c57f6017e6aefd","tid":1530033,"uid":275109,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:51:53.000Z","msg":"借個位屌醒垃圾 謝謝<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">無罷工嘅人你哋同港豬冇分別</span></span><br />\n<a href=\"https://lih.kg/1530174\" data-auto-link target=\"_blank\">https://lih.kg/1530174</a><br />\n<br />\n<img src=\"https://na.cx/i/JuR3EjL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJuR3EjL.jpg&h=cfcfafd7&s={SIZE}\" />"},{"pid":"ec01872f220e44c9488dc65097c119f79ce9826e","tid":1530033,"uid":137,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:53:10.000Z","msg":"經歷左早兩日，大家都倦啦唔好又屌啦<br />\n大家回下氣先啦"},{"pid":"6acce50678feb4161a1ed8b474d8ce88c0e18354","tid":1530033,"uid":46197,"like":0,"dislike":0,"score":0,"quote":{"pid":"eca9bba3c0b19c6001845da764885a89e5fe8516","tid":1530033,"uid":31215,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2019-09-02T00:37:37.000Z","msg":"85罷工宣傳得好勁<br />\n好似民陣都有出聲<br />\n仲有公務員集會做勢<br />\n文宣百花齊放<br />\n傳單隊派埋傳單，落地鐵站舉牌<br />\n612 同 85有小店帶頭響應出fb<br />\n然後連登貼哂上黎<br />\n做足一至兩個星期<br />\n個氣氛濃烈到大企業都叫人home office<br />\n加埋七區集會<br />\n<br />\n今次淨係得連登仔喺連登講<br />\n星期六日遊行，已經係打仗，冇人講罷工<br />\n冇一個好似工務員嗰個嘅和理非式造勢晚會<br />\n出面提都冇人提<br />\n個個以為今日淨係學生罷課<br />\n<br />\n個宣傳力度真係差幾班<br />\n<br />\n至於超合作運動 <br />\n其實好多巴打仲努力中，亦有效果<br />\n但睇返今次個宣傳力同之前差好多班<br />\n之前又係一至兩星期講定<br />\n今鍋個個都講831，同91機場<br />\n好少聽到有人講92超合作<br />\n<br />\n同埋<br />\n831俾人追甩肺<br />\n91俾人圍幾粒鐘<br />\n92點樣call 7點<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n越難做嘅行動，前一兩日做啲唔好咁heavy 嘅野好冇<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n簡單黎講，今次唔係行動做得唔大規模，係宣傳做得唔大規模<br />\n你遊行仲可以喺連登早一兩日先開post call 幾萬人出黎<br />\n但想幾十萬人參與嘅罷工<br />\n真係要做一兩星期宣傳<br />\n傳單隊要出動<br />\n中間夾雜啲和理非造勢活動先成到火喉<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-02T01:53:21.000Z","msg":"感謝"},{"pid":"d9c8d5e8d8d9687a382085a7c319e154b8754d97","tid":1530033,"uid":260325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T01:54:45.000Z","msg":"push"},{"pid":"b4df7aff5cbc8adb61d55b481a3c53182c9f8478","tid":1530033,"uid":161365,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T02:01:11.000Z","msg":"唔係9293罷工咩？"},{"pid":"b48bf425bec219a444d2d71ec9491022e18b1bb9","tid":1530033,"uid":279650,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T02:05:24.000Z","msg":"罷工的工人群眾可能會聚集在工作場所外面，勸說其他同僚參與罷工，或嘗試阻止僱主與客戶的交易來往。零售或服務行業的罷工稱為「罷市」。另一種罷工方式是工人留守在工作場所內，但拒絕工作或拒絕離開。<br />\n<br />\n也有罷工工人會以只完成工作的最基本要求以示抗議，此方式稱為「怠工」或「按章工作」。例如，工人可能會格外嚴格地執行所有安全守則，從而減低工作效率；又或者拒絕超時工作。<br />\n<br />\nwiki：<br />\n<a href=\"https://zh.m.wikipedia.org/wiki/%E7%BD%B7%E5%B7%A5\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wikipedia.org%2Fwiki%2F%25E7%25BD%25B7%25E5%25B7%25A5&d=nh4ioWg9Uual2b2uu0vi%2FaGvShGfzVnrv2JJWMS0YvQ%3D&h=e5e21ced\" data-auto-link target=\"_blank\">https://zh.m.wikipedia.org/wiki/%E7%BD%B7%E5%B7%A5</a><br />\n<br />\n利申： 波已射, 但番到公司嘅，都唔係做唔到罷工<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"3ecbf01ce9a47f8618356fe47b84a1fd9a91a287","tid":1530033,"uid":34881,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T02:06:56.000Z","msg":"<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"11eec7800a698284f4af24a32cf722aea0f9f1e0","tid":1530033,"uid":69419,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T02:07:10.000Z","msg":"唔好意思, 不如睇埋呢個post<br />\n[突發] 香港人終於有屬於依個時代既進行曲 (原創) !!!!!《願榮光歸香港》 大合唱團mv版<br />\n<a href=\"https://lih.kg/afMuPmU\" target=\"_blank\">https://lih.kg/afMuPmU</a>"},{"pid":"420659668d2e06dbcbae470019d8b85d87ecc9c8","tid":1530033,"uid":188685,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T02:18:51.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">全民跳閘</span></span>"},{"pid":"01bdf47d5d0e0f3e14bf35fc486b1b966e71a6b4","tid":1530033,"uid":2360,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T02:27:03.000Z","msg":"好多人尋晚行咗20公里 7點起唔到身啊<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"436a2465ce3aa5c7659fcbf0bcb69ba6ad12c03e","tid":1530033,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T02:28:20.000Z","msg":"推 agree 加油"},{"pid":"725f32b9554b01f48784d774f7290bb8ebb4ba8f","tid":1530033,"uid":239842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T02:33:08.000Z","msg":"認同<br />\n<br />\n琴日太heavy，唔係唔想罷工，但有時番工都係一種心靈休息。<br />\n<br />\n不完美，可改善！宣傳同造勢可加強。"},{"pid":"8814de573ce5b97ddbcd0ce321848685bc4bcb1f","tid":1530033,"uid":21920,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-02T02:34:14.000Z","msg":"可否唔好咁密<br />\n隔開幾日比各位手足做下自己野<br />\n然後落重注文宣 連儂牆 之後再行動"},{"pid":"2c1826f8ee1c5d643bd4352c1ffa19a7692646fe","tid":1530033,"uid":67553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T02:42:38.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"745f650f656f714f4bdac534ad81bf91bd30f50a","tid":1530033,"uid":31215,"like":0,"dislike":0,"score":0,"quote":{"pid":"8814de573ce5b97ddbcd0ce321848685bc4bcb1f","tid":1530033,"uid":21920,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-02T02:34:14.000Z","msg":"可否唔好咁密<br />\n隔開幾日比各位手足做下自己野<br />\n然後落重注文宣 連儂牆 之後再行動"},"citedBy":0,"replyTime":"2019-09-02T02:52:10.000Z","msg":"排期唔好日日衝<br />\n其中一兩日做宣傳日，為重點日子做勢<br />\n整牆、派傳單、舉派、做行為藝術、擺埋街站唔使多人<br />\n勇武又可以休息<br />\n和理非又可以參與、帶埋細路同老人上場都得<br />\n又有效果"},{"pid":"86cd71a3d6fdb17094fcac7202833316b4cbde32","tid":1530033,"uid":223681,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T02:53:21.000Z","msg":"agger"}]}