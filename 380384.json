2017/08/31/092928_5b4d11f96454d60cad37a1fa0c9e065b.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F31%2F092928_5b4d11f96454d60cad37a1fa0c9e065b.png&h=2df67f38&s={SIZE}\" />"},{"pid":"514a91ee9e40761cbe4da2499af7043541af7253","tid":380384,"uid":34123,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-08-31T02:58:08.000Z","msg":"好緊張，究竟睇完會唔會去到燒書燒figures嘅程度<img src=\"/assets/faces/lomoji/13.png\" class=\"hkgmoji\" />"},{"pid":"5c4905a34a87d87860cad78eaa9ae27c6ff4b2a9","tid":380384,"uid":99971,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-08-31T03:44:48.000Z","msg":"套野好似完全比人無視左<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"98f31cbeffb23ae0817bf6c070c67a4ce9d432ab","tid":380384,"uid":34123,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-08-31T05:00:01.000Z","msg":"麻麻地，有幾幕好怪好詭異<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7854546a1d4705ac0bc698bc96f5ee26783efc55","tid":380384,"uid":42338,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-08-31T05:08:40.000Z","msg":"睇完 電視劇水準 真係同AOS差唔多水準<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1912f67b6d8feab6c4d083f43ad1d8cd2ddd8d18","tid":380384,"uid":34123,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-08-31T05:11:22.000Z","msg":"Lockjaw真係主角級，Title Animation有佢<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"b80537e8d3f7554a41d65b979ef8c4d1ac93945f","tid":380384,"uid":34123,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-08-31T06:26:27.000Z","msg":"基本上就係第一、二集嘅剪輯合集。劇情大約講述生活在月面城市Attilan的Black Bolt派出了Triton到地球調查Inhumans人口爆發一事。然而Triton遭遇伏擊，生死不明。Black Bolt派出Gorgon到地球搜索Triton。而一直不滿Black Bolt一直以來的統治政策的Maximus趁勢發動武力政變，一眾皇室成員輾轉逃到夏威夷，各散東西。各皇室成員一方面要適應地球上嘅生活，另一方面也要集合一起，奪回Attilan的統治權。而Maximus也派出追兵到地球，決意要消滅皇室成員&hellip;以上基本上就係首兩集的內容。內容上中規中矩，基本上講Inhumans唔講呢啲皇室野都仆硬街架喇。(講緊你呀！Marvel Now! Inhumans，仲有你呀！AoS 成段Inhumans劇情呀)驚喜嘅係佢今次講多左以往漫畫經常忽略左Inhumans低下階層。<br />\n<br />\n<br />\nInhumans第一部分(一、二集)使用IMAX拍攝，老實講係有啲浪費，雖然夏威夷風景捕捉得好靚，但真係唔值得特意使用IMAX。另外，特技方面，始終係Agents of Shield嘅水平，都冇咩好講。<br />\n<br />\n演員方面，大家的表現中規中矩。<br />\n<br />\n角色方面，Maximus非常吸引，奪權十分有理據。而Karnak的角色設計十分詭異，大部份有佢鏡頭都十分奇怪。落地球之後Karnak嘅戲份極度搞笑。有趣地今次Maximus和Karnak的設定都和漫畫出入頗大，今次Maximus設定為沒有超能力(只少目前所見)，而Karnak則擁有超能力，可以把他看成一個擁有超級電腦，能計算各種情況並作出應對的人，但劇中能力表達也是十分怪異。<br />\n<br />\nBlack Bolt，係弱化左，不過劇中表現都唔錯。另外發現MCU入面Teaser係最強武器，Thor同Black Bolt都衰喺佢手上。<br />\n<br />\nMedusa&hellip;Well，大家都明衰咩，Marvel都識玩，中段剃左佢啲頭髮。不過落髮一幕又係好好笑。另外發現大部份頭髮特技用左去一開頭佢同Black Bolt喺床上纏綿&hellip;<br />\n<br />\nLockjaw真是主角級待遇，片頭中特意在Inhumans大標題旁配了一隻Q版動畫Lockjaw。劇中表現也十分可愛。<br />\n<br />\n<br />\nInhumans首兩集不算太差，但也說不上好。如果大家想睇，建議等到正式在abc播出才觀看，因為電視版會有更多新片段，總片長比IMAX放映版為長。"},{"pid":"2618f96f2fd74b767f33b3223d1e886df90b0149","tid":380384,"uid":34123,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-08-31T06:27:15.000Z","msg":"<a href=\"http://www.talkcomic.com/uncategorized/marvels-inhumans-imax%e7%89%b9%e5%88%a5%e7%89%88%e7%9f%ad%e8%a9%95.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.talkcomic.com%2Funcategorized%2Fmarvels-inhumans-imax%25e7%2589%25b9%25e5%2588%25a5%25e7%2589%2588%25e7%259f%25ad%25e8%25a9%2595.html&d=wk85qkTUVy%2B7OZ5kMMZABghMEkA7P3Wv%2FuCJwdwWxT4%3D&h=4cb3ac56\" target=\"_blank\">http://www.talkcomic.com/uncategorized/marvels-inhumans-imax%e7%89%b9%e5%88%a5%e7%89%88%e7%9f%ad%e8%a9%95.html</a>"},{"pid":"4c8ca0dde581a9207613ef86d8accd3feb62067d","tid":380384,"uid":60500,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-08-31T09:26:17.000Z","msg":"等陣睇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3dc5db56f88616bf50d273b5eb314f99129eef91","tid":380384,"uid":35504,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-08-31T11:58:32.000Z","msg":"當佢一集四十幾分鐘 咁而家76分鐘 即係短咗5-10分鐘<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"4b19e039f756f1cda4415b8ece7d7b80cd1aa75