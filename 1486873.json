ets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"03e69070073cf15d7eed10e380047594840b4c3f","tid":1486873,"uid":273621,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-19T05:01:04.000Z","msg":"岩，琴日係包括和理非在內民意表達，反映民意無逆轉，對家分化策略無效果。"},{"pid":"244414c04b714c798f749858eb7a534861e599cc","tid":1486873,"uid":286319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:02:57.000Z","msg":"推"},{"pid":"55fc43ecf28920ed25bec97e9e78f81d446a981b","tid":1486873,"uid":44174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:04:02.000Z","msg":"推"},{"pid":"7becd5e15a8a28f3f63a1104da16c816c4512dc3","tid":1486873,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:06:02.000Z","msg":"［永不割蓆，永不分化，保持改進］今日總結，畢竟大家都冇上帝視角，有各自嘅限制，請大家對手足保持體諒嘅態度<br />\n<a href=\"https://lih.kg/1485890\" data-auto-link target=\"_blank\">https://lih.kg/1485890</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<br />\n<br />\n<br />\n818 總結，我認為大家要互相體諒，畢竟大家都冇上帝視角，有各自嘅限制<br />\n<br />\n例如全面散場前三個鐘已經去到金鐘同散咗場嘅巴打，因為擔心前線安危，加上嗰日目標已經達成（搶佔國際輿論），冇必要死守，所以叫走，但始終人已經唔係身處現場，冇上帝視角，望住live 仲見到咁多人，自然開始心急，語氣上亦變得可能唔係太好<br />\n<br />\n同一時間，前線亦想所有人平平安安走曬，自己做最後一批先走，咁當然一定會有鬼從中叫人留低/ 賴死唔走，間接迫你留低「保護」佢哋，同樣前線亦冇上帝視角，難以判斷係手足定係鬼，加上客觀因素（現場人多電話收到嘅信號會少/ 局勢變化可能太快）散嘅速度自然亦會慢<br />\n<br />\n<br />\n都係呢一句：<br />\n永不割蓆，永不分化，保持改進<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n所以，請大家對手足保持體諒嘅態度，兵荒馬亂之際大家嘅心情難免心急，語氣上亦會有所失儀，唯希望大家之後仍然可以再度團結，齊上齊落，打贏呢一場逆權運動<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"2161e7ebcc2cc220f1036c000e8e9f559d7f40d1","tid":1486873,"uid":261811,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:06:44.000Z","msg":"推"},{"pid":"3e3a615aa69333ec273570b359b1bc6f29cabab2","tid":1486873,"uid":37528,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-08-19T05:07:28.000Z","msg":"無錯，尋日真係為勇武正名<br />\n不過今日好多post話和理非無用，得勇武有用係咩居心？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"12f2b4b6a92627fc71485b528fc28cebc5543637","tid":1486873,"uid":117968,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:10:51.000Z","msg":"721 811"},{"pid":"abf63a5023a336d3752b9274f7ed3c480b2949a9","tid":1486873,"uid":103230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:12:08.000Z","msg":"有班友扮唔知有咩用上黎問<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n笑撚死"},{"pid":"1dc2a1ad7183fa6c1543879c9fa22422a6ffb477","tid":1486873,"uid":69276,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:12:13.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1a1033efac79f64166d6ea19be0fd325caffa656","tid":1486873,"uid":155487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:12:29.000Z","msg":"寫得好好<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"1114740467bf6cbefee16d594f2e85102ea9d22f","tid":1486873,"uid":103230,"like":0,"dislike":0,"score":0,"quote":{"pid":"3e3a615aa69333ec273570b359b1bc6f29cabab2","tid":1486873,"uid":37528,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-08-19T05:07:28.000Z","msg":"無錯，尋日真係為勇武正名<br />\n不過今日好多post話和理非無用，得勇武有用係咩居心？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-19T05:12:33.000Z","msg":"風向"},{"pid":"82642eb574ee2d61c458575192980e3b1618a042","tid":1486873,"uid":55955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:14:09.000Z","msg":"推"},{"pid":"3c3793b1e2149c313d22fbdebbbec42c060cf05e","tid":1486873,"uid":277702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:14:39.000Z","msg":"不tui不是yan"},{"pid":"2e830356c5a5e97d2edcb8a5a1821e7a28fd8d99","tid":1486873,"uid":270889,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:14:55.000Z","msg":"淋病黑警記招無限助攻 <br />\n尋晚光復行動召集人又比黑社會/黑警打<br />\n咁搞法今次運動想失民心都難"},{"pid":"01a234af6ffb55e2423eca846d62c938adafec73","tid":1486873,"uid":241904,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:18:33.000Z","msg":"818係一個表態<br />\n話比全世界知香港人既訴求<br />\n比政治本錢我地set deadline"},{"pid":"4ed0ed9498813130588297de4fd403a938882850","tid":1486873,"uid":287929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:20:53.000Z","msg":"agger"},{"pid":"29f6e93e5bc61f2735ce5269576d44fba87fa592","tid":1486873,"uid":60924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:29:45.000Z","msg":"琴日之前我都驚真係冇人出，但果日見到搭地鐵既人潮真係好感動<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"07140ddda5bc655be95a652d9498ede733248683","tid":1486873,"uid":266755,"like":0,"dislike":0,"score":0,"quote":{"pid":"de564c8ff57fd99c83828217f436bae33d8ad661","tid":1486873,"uid":55955,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-08-19T04:27:25.000Z","msg":"尋日170萬人大家都同意民陣個數字應該係低估咗，實際人數應該同616相當。對於尋日個遊行今日見到有幾種講法<br />\n1. 遊行對政府已經冇壓力，點解仲要搞?<br />\n2. 和理非活動有咁多人出席，係唔係代表呢個運動開始走向和理非?<br />\n以上我認為係唔明白818嘅意義，甚至我估計最後留守係金鐘嗰班都唔知個遊行目的係乜，見冇乜成果就想留守係度 (唔同意話個班係鬼)<br />\n&nbsp;<br />\n尋日818遊行個人認為有兩點意義<br />\n1. 比彈藥外國政府做嘢<br />\n先唔好評論外國會唔會真係出手先，但至少有希望。尋日全日遊行和平咁進行，比外國政府出師有名去支持香港。中共一支嘗試抹黑示威者係暴徒，話美國政府支持暴亂分子、恐怖活動。尋日完全證明示威者並非暴徒，示威者能放能收，暴力係手段而唔係目的，所有暴力行為係為咗比壓力政府而不是想破壞社會。<br />\n&nbsp;<br />\n2. 集結民心，為勇武行動正名<br />\n機場行動之後，有部份人擔心呢個運動係咪變得太激進。經過尋日遊行，見到有啲勇武手足擔心係唔係勇武行動嘅終結？我認為剛剛相反，616之後呢兩個月經歷過以前香港從來未經歷過嘢，示威者用嘅武力係前所未見。而所有勇武行動背後最重要一點，就係背後有冇民意支持，如果脫離民意就會變成一小撮人越走越激進，政府自85之後一直都係用呢招想分化和理非，再加經濟牌去孤立激進派<br />\n而尋日就證明<span style=\"color: red;\">經過兩個月既行動仍然有大約二百萬人支持，民心係冇損失到</span>，大家對之後嘅行動更加有信心。所以尋日點解有咁多人咁緊張叫啲手足要儘快離開，叫人散水的原因並唔係反對勇武抗爭。<br />\n&nbsp;<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">最後加多點: 尋日只係成個運動嘅一小步，千祈唔好自滿<br />\n以前做開嘅文宣要繼續努力去做，一放鬆就真係會失敗</span></span>"},"citedBy":0,"replyTime":"2019-08-19T05:30:21.000Z","msg":"push"},{"pid":"878ff715fac87dc7d44cae3aaac170eb31ab78aa","tid":1486873,"uid":13099,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:31:19.000Z","msg":"Up"},{"pid":"769ee12baf91c9b4601526be1c41f5b36ca94ffc","tid":1486873,"uid":267461,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:36:23.000Z","msg":"同意，幫推"},{"pid":"b50a6de89dd6589b37fc822faaadd7e3248d99bd","tid":1486873,"uid":132217,"like":0,"dislike":0,"score":0,"quote":{"pid":"de564c8ff57fd99c83828217f436bae33d8ad661","tid":1486873,"uid":55955,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-08-19T04:27:25.000Z","msg":"尋日170萬人大家都同意民陣個數字應該係低估咗，實際人數應該同616相當。對於尋日個遊行今日見到有幾種講法<br />\n1. 遊行對政府已經冇壓力，點解仲要搞?<br />\n2. 和理非活動有咁多人出席，係唔係代表呢個運動開始走向和理非?<br />\n以上我認為係唔明白818嘅意義，甚至我估計最後留守係金鐘嗰班都唔知個遊行目的係乜，見冇乜成果就想留守係度 (唔同意話個班係鬼)<br />\n&nbsp;<br />\n尋日818遊行個人認為有兩點意義<br />\n1. 比彈藥外國政府做嘢<br />\n先唔好評論外國會唔會真係出手先，但至少有希望。尋日全日遊行和平咁進行，比外國政府出師有名去支持香港。中共一支嘗試抹黑示威者係暴徒，話美國政府支持暴亂分子、恐怖活動。尋日完全證明示威者並非暴徒，示威者能放能收，暴力係手段而唔係目的，所有暴力行為係為咗比壓力政府而不是想破壞社會。<br />\n&nbsp;<br />\n2. 集結民心，為勇武行動正名<br />\n機場行動之後，有部份人擔心呢個運動係咪變得太激進。經過尋日遊行，見到有啲勇武手足擔心係唔係勇武行動嘅終結？我認為剛剛相反，616之後呢兩個月經歷過以前香港從來未經歷過嘢，示威者用嘅武力係前所未見。而所有勇武行動背後最重要一點，就係背後有冇民意支持，如果脫離民意就會變成一小撮人越走越激進，政府自85之後一直都係用呢招想分化和理非，再加經濟牌去孤立激進派<br />\n而尋日就證明<span style=\"color: red;\">經過兩個月既行動仍然有大約二百萬人支持，民心係冇損失到</span>，大家對之後嘅行動更加有信心。所以尋日點解有咁多人咁緊張叫啲手足要儘快離開，叫人散水的原因並唔係反對勇武抗爭。<br />\n&nbsp;<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">最後加多點: 尋日只係成個運動嘅一小步，千祈唔好自滿<br />\n以前做開嘅文宣要繼續努力去做，一放鬆就真係會失敗</span></span>"},"citedBy":0,"replyTime":"2019-08-19T05:54:39.000Z","msg":"推"},{"pid":"47d984f8a5d9da9440fe6575b33ce483c98a3ed4","tid":1486873,"uid":13099,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:55:05.000Z","msg":"Push"},{"pid":"cb6869116a54c0f07102e5d16ac6a75a84167315","tid":1486873,"uid":71997,"like":0,"dislike":0,"score":0,"quote":{"pid":"320e1e