es/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c0329fb49d05a40554785609fb1e8dd6f50e0392","tid":2492364,"uid":66324,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-17T05:24:05.000Z","msg":"YC走左咪到nancy食集中營lor, 你估国家會鍾意呢D根不正苗不紅的人咩 <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"309976a97cf2bdb6873678e640bc844de12ad38b","tid":2492364,"uid":89182,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04-17T05:24:19.000Z","msg":"香港人！移民！<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"234e24be810965328d03af8068472ca8688a9f68","tid":2492364,"uid":304769,"like":0,"dislike":0,"score":0,"quote":{"pid":"67d325e6f5b4a17d5c5ef6f74b7dbd748f7c7a33","tid":2492364,"uid":166080,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-17T05:22:46.000Z","msg":"推"},"citedBy":0,"replyTime":"2021-04-17T05:25:28.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"c51c6cf0eaa4c2da5b5878f98783d3ead42a97b7","tid":2492364,"uid":272569,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-04-17T05:25:41.000Z","msg":"比啲自信自己，你係香港人亦都係人才<br />\n<br />\n走左一個就係少一個就係少一份稅。<br />\n<br />\n去到外國開頭辛苦唔習慣就一定，同轉工一樣一定會唔慣。<br />\n<br />\n去到外國間屋又大又有花園又唔使ot又有得投票車位又多油費又平係唔習慣。<br />\n<br />\n咁當然有負面，但對比返就知點都有so過唔走。"},{"pid":"b5b625737c2c111f2c175f0e57b9e9c3135fa550","tid":2492364,"uid":304769,"like":0,"dislike":0,"score":0,"quote":{"pid":"0503b481ae02e53898c68cab48f51bf724d3fc44","tid":2492364,"uid":268591,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-17T05:23:00.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-17T05:26:26.000Z","msg":"<img src=\"/assets/faces/big/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"9ca327c5b46ef56b2e1d093c7b970ea14da422e7","tid":2492364,"uid":159271,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-04-17T05:26:43.000Z","msg":"支持。移民一向係為下一代。 <br />\n大家預左要捱。 但係外國，你可以安心組織家庭，有下一代。 佢地有好教育環境，讀好書，畢業做專業人士，你生活都會變好！ （見証左好多當年越南難民去美國，老豆老母捱，仔女出黎做律師，醫生，Big 4會計）<br />\n<br />\n係香港，你直係夠膽生兒育女？ 你夠膽生，佢大個都怨你一世！"},{"pid":"e403c57dbd4c1997473fada7a67bf524a2de9744","tid":2492364,"uid":267548,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-17T05:27:44.000Z","msg":"走越多真香港人越有用，要支那國死嘅話香港就要死一次"},{"pid":"628a747849dad9318dba52c080998d620ea0941f","tid":2492364,"uid":304769,"like":0,"dislike":0,"score":0,"quote":{"pid":"e7d67b66a030b37af66062a1aae429cd164c71b7","tid":2492364,"uid":327169,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-17T05:23:34.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-17T05:28:56.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"bb1f49607762667c4afcfd8ac8b7bca39bc99487","tid":2492364,"uid":159271,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-17T05:29:02.000Z","msg":"終極真攬炒！"},{"pid":"c086400f785cae2bbb3b69d07951b25049af2856","tid":2492364,"uid":304769,"like":0,"dislike":0,"score":0,"quote":{"pid":"c0329fb49d05a40554785609fb1e8dd6f50e0392","tid":2492364,"uid":66324,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-17T05:24:05.000Z","msg":"YC走左咪到nancy食集中營lor, 你估国家會鍾意呢D根不正苗不紅的人咩 <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-17T05:29:18.000Z","msg":"無錯，留返比班廢藍去死<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5de2ad4b9a516d2da7ce0dca517d7983625445a5","tid":2492364,"uid":304769,"like":0,"dislike":0,"score":0,"quote":{"pid":"309976a97cf2bdb6873678e640bc844de12ad38b","tid":2492364,"uid":89182,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04-17T05:24:19.000Z","msg":"香港人！移民！<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-17T05:29:56.000Z","msg":"其實唔係移民，係走難"}]}