9:14.000Z","msg":"擺明有仇口啦，坐咗咁耐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e6d9422b2af6e34e754c84497c3c7715246813b6","tid":1902870,"uid":276989,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T15:40:15.000Z","msg":"手足來的"},{"pid":"7c00af73d9ddd02aeb80fd174d61059a45bec43b","tid":1902870,"uid":273218,"like":0,"dislike":0,"score":0,"quote":{"pid":"b2414dbe29b09500b9c3ac851f9706938d4bad64","tid":1902870,"uid":161274,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-02-28T15:15:01.000Z","msg":"13億thx<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-29T05:05:51.000Z","msg":"洗咩封城<br />\n家居隔離咪得<br />\n唔封城香港大把隱形病人經深圳輸入北京<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"}]}