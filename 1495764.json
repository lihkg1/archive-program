o.com/pns/%e6%b8%af%e8%81%9e/article/20190822/s00002/1566413142829/%e3%80%90emily%e3%80%91%e6%86%82%e6%93%be%e4%ba%82%e9%87%91%e8%9e%8d%e4%b8%ad%e5%bf%83-%e5%bc%b5%e8%8f%af%e5%b3%b0%e5%80%a1%e8%a6%8f%e7%ae%a1%e3%80%8c%e4%ba%82%e6%8f%90%e6%ac%be%e3%80%8d\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2F%25e6%25b8%25af%25e8%2581%259e%2Farticle%2F20190822%2Fs00002%2F1566413142829%2F%25e3%2580%2590emily%25e3%2580%2591%25e6%2586%2582%25e6%2593%25be%25e4%25ba%2582%25e9%2587%2591%25e8%259e%258d%25e4%25b8%25ad%25e5%25bf%2583-%25e5%25bc%25b5%25e8%258f%25af%25e5%25b3%25b0%25e5%2580%25a1%25e8%25a6%258f%25e7%25ae%25a1%25e3%2580%258c%25e4%25ba%2582%25e6%258f%2590%25e6%25ac%25be%25e3%2580%258d&d=MOEBQbH5BhSBv0g7AWUGIbXdyKWV89KwSxbYnQ5zRIM%3D&h=056a4baf\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2F%25e6%25b8%25af%25e8%2581%259e%2Farticle%2F20190822%2Fs00002%2F1566413142829%2F%25e3%2580%2590emily%25e3%2580%2591%25e6%2586%2582%25e6%2593%25be%25e4%25ba%2582%25e9%2587%2591%25e8%259e%258d%25e4%25b8%25ad%25e5%25bf%2583-%25e5%25bc%25b5%25e8%258f%25af%25e5%25b3%25b0%25e5%2580%25a1%25e8%25a6%258f%25e7%25ae%25a1%25e3%2580%258c%25e4%25ba%2582%25e6%258f%2590%25e6%25ac%25be%25e3%2580%258d&h=352e05f5\" data-auto-link target=\"_blank\">https://news.mingpao.com/pns/%e6%b8%af%e8%81%9e/article/20190822/s00002/1566413142829/%e3%80%90emily%e3%80%91%e6%86%82%e6%93%be%e4%ba%82%e9%87%91%e8%9e%8d%e4%b8%ad%e5%bf%83-%e5%bc%b5%e8%8f%af%e5%b3%b0%e5%80%a1%e8%a6%8f%e7%ae%a1%e3%80%8c%e4%ba%82%e6%8f%90%e6%ac%be%e3%80%8d</a>"},{"pid":"680e03851e22f755fe1112888521ae972d418d5a","tid":1495764,"uid":202720,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-22T08:04:59.000Z","msg":"敵人反對的我們就要堅決擁護 敵人擁護的我們就要堅決反對!!!<br />\n<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"37f52464e046a84201d2683293ce