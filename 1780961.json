1,"uid":66365,"like":0,"dislike":2,"score":-2,"quote":{"pid":"94b95a081be3bd66f4d203e26e6fbb101b75e4c7","tid":1780961,"uid":29702,"like":15,"dislike":8,"score":7,"citedBy":4,"replyTime":"2019-12-12T20:02:52.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-12-12T21:09:09.000Z","msg":"on9<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"bdd7b8aa5b9b06785acf4cc6f8835f97a23c3984","tid":1780961,"uid":17103,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-12-12T21:13:36.000Z","msg":"九成個老母係蝗，咩中歐混血咁撚好聽。<br />\n傻閪移民外國重唔信科技就去行歪路。"},{"pid":"32c00a94035ad95022476e3a2a9a75987c522b10","tid":1780961,"uid":60591,"like":0,"dislike":0,"score":0,"quote":{"pid":"cce8536be6d9599dd2adc9c1e798f946d28c9b07","tid":1780961,"uid":321837,"like":0,"dislike":0,"score":0,"quote":{"pid":"3ab70492e085fa0f866d825564840f227498c747","tid":1780961,"uid":183035,"like":9,"dislike":0,"score":9,"quote":{"pid":"94b95a081be3bd66f4d203e26e6fbb101b75e4c7","tid":1780961,"uid":29702,"like":15,"dislike":8,"score":7,"citedBy":4,"replyTime":"2019-12-12T20:02:52.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2019-12-12T20:10:23.000Z","msg":"其實都唔算係中醫，根本係呃神騙鬼"},"citedBy":1,"replyTime":"2019-12-12T20:49:26.000Z","msg":"拍打好正常，不過係拍打自己。拍人好易出事。"},"citedBy":0,"replyTime":"2019-12-12T21:29:54.000Z","msg":"有事咪睇醫生呀吓 高手"},{"pid":"052bb5b1ddf04ee852d1b836f7cb5b2d76fdc897","tid":1780961,"uid":249885,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-12T21:57:52.000Z","msg":"死得好"},{"pid":"bc7d1be6851defd774eb12f6ba9f6f19e04d5a8b","tid":1780961,"uid":188,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-12T22:20:01.000Z","msg":"脊「醫」唔係醫<br />\n最多只係按摩技師"},{"pid":"7dd538a752bee670b669129a567c168724548ef1","tid":1780961,"uid":75556,"like":0,"dislike":0,"score":0,"quote":{"pid":"c7aed393c17422337310c0374497be14b9ac414f","tid":1780961,"uid":4596,"like":9,"dislike":1,"score":8,"citedBy":2,"replyTime":"2019-12-12T20:08:28.000Z","msg":"脊醫都係<img src=\"/assets/faces/normal/d