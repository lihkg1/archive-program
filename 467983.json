/photos/cache/FOOTBALL-INDEFLAG_XxRVO20copy_y8mIo_1200x0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2FFOOTBALL-INDEFLAG_XxRVO20copy_y8mIo_1200x0.png&h=76d945f5&s={SIZE}\" /></blockquote><br />\n支持港隊，買條頸巾或毛巾保暖<img src=\"/assets/faces/fs/fozen_smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n上次波台就醒<img src=\"/assets/faces/big/good.gif\" class=\"hkgmoji\" /> <br />\n<br />\n蒙住面噓, 無證據話你唱緊定噓緊<br />\n<br />\n但聲就全部噓"},{"pid":"5a1c1f5f5d69036a1052deb48737237ea4076409","tid":467983,"uid":20933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-14T05:46:36.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"662ddef7e7cf114baeed59e476fb778c770391db","tid":467983,"uid":48157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-14T10:05:17.000Z","msg":"此回覆已被刪除"},{"pid":"5449a6a5156310e00d704717aa325bc5de129d1d","tid":467983,"uid":48157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-14T10:07:17.000Z","msg":"此回覆已被刪除"},{"pid":"e8636812bb2698d273eff169cd5dc0b8dfcc68be","tid":467983,"uid":48157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-14T10:08:26.000Z","msg":"此回覆已被刪除"}]}