=\"hkgmoji\" />"},{"pid":"8ee1c37edc9516548af97446d30e9c8451a27851","tid":1486723,"uid":105526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T03:29:37.000Z","msg":"民意逆轉<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"2d4fe19a6dd5036f9d948a0a95afa8e79494a48c","tid":1486723,"uid":270078,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T03:31:39.000Z","msg":"核彈都唔割, 大家都係香港人"},{"pid":"66e635d1c735cc54977997bb052ac4ce2b843da3","tid":1486723,"uid":173849,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:23:04.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"08fdba81b662302b1e48f0922a4569e9da113091","tid":1486723,"uid":137588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:24:01.000Z","msg":"核彈都唔割<br />\n無分和勇"},{"pid":"804c349e72fd8d8a32fb72dcbd25614c6468bb18","tid":1486723,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:25:01.000Z","msg":"［永不割蓆，永不分化，保持改進］今日總結，畢竟大家都冇上帝視角，有各自嘅限制，請大家對手足保持體諒嘅態度<br />\n<a href=\"https://lih.kg/1485890\" data-auto-link target=\"_blank\">https://lih.kg/1485890</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<br />\n<br />\n818 總結，我認為大家要互相體諒，畢竟大家都冇上帝視角，有各自嘅限制<br />\n<br />\n例如全面散場前三個鐘已經去到金鐘同散咗場嘅巴打，因為擔心前線安危，加上嗰日目標已經達成（搶佔國際輿論），冇必要死守，所以叫走，但始終人已經唔係身處現場，冇上帝視角，望住live 仲見到咁多人，自然開始心急，語氣上亦變得可能唔係太好<br />\n<br />\n同一時間，前線亦想所有人平平安安走曬，自己做最後一批先走，咁當然一定會有鬼從中叫人留低/ 賴死唔走，間接迫你留低「保護」佢哋，同樣前線亦冇上帝視角，難以判斷係手足定係鬼，加上客觀因素（現場人多電話收到嘅信號會少/ 局勢變化可能太快）散嘅速度自然亦會慢<br />\n<br />\n<br />\n都係呢一句：<br />\n永不割蓆，永不分化，保持改進<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n所以，請大家對手足保持體諒嘅態度，兵荒馬亂之際大家嘅心情難免心急，語氣上亦會有所失儀，唯希望大家之後仍然可以再度團結，齊上齊落，打贏呢一場逆權運動<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"72f0d5011cc881b783371447f9ab90f04cc182fc","tid":1486723,"uid":230911,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:28:21.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c10507e830f7a533189fbd817f10f9d71badac8a","tid":1486723,"uid":222907,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:29:45.000Z","msg":"飲喜茶已經有人割<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"4a7013e7c54915e41b645b9886ddec2393fc8760","tid":1486723,"uid":264915,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:30:15.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c15989c2b1d026929c0018a2eca176f227cb371d","tid":1486723,"uid":276175,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T05:44:05.000Z","msg":"尋日落大雨，而且只係集會。如唔係，三百萬絕對有可能！"}]}