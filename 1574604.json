2F%2Fna.cx%2Fi%2Fh9V6bUo.png&h=e0ced6ce&s={SIZE}\" /><br />\n手足做得好，對準政權"},"citedBy":0,"replyTime":"2019-09-16T14:13:11.000Z","msg":"你次次Reply都係會放張死人Joker圖出黎<img src=\"/assets/faces/mf/donno.gif\" class=\"hkgmoji\" />"},{"pid":"3729495bf823a523dfe1a82e09ac671d74046d2c","tid":1574604,"uid":53026,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-16T14:19:07.000Z","msg":"有關張翔的路邊社消息<br />\n2018/10/04 04:12:38 網誌分類: 生活<br />\n04 Oct<br />\n         回到母校香港大學陸佑堂，首次和新任校長張翔見面。張翔是世界及材料科學家，他主持研製的隱身衣，被《時代》雜誌列入○八年十大科學發現。他既具備國際視野，又熟悉內地情況。<br />\n<br />\n          張翔令港大校董會眼前一亮之處，是他提出拉攏中國科學院和港大設立聯合實驗室。前天張翔在陸佑堂會見舊生時，已落實列出將成立：一、粵港幹細胞及再生醫學研究中心，二、化學地球動力學聯合實驗室、三、深港生物材料聯合實驗室、四、滬港化學合成聯合實驗室、五、新材料合成和檢測聯合實驗室。<br />\n<br />\n          另一方面，他亦提出港與英國劍橋、牛津，美國柏克萊和史丹福大學合組跨地域全球校園，東西南北打通經脈，令港大有更多資源發展未來。<br />\n<br />\n          張翔是不可多得的人才。港大得到張翔，是冷手執個熱煎堆。我得到的路邊社消息是，<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">張翔母校南京大學一早已經決定聘請他了。張翔亦已答應，並做好離職前的準備。然而南京大學忽然亮出了一個非常辣的條件，就是要求張翔及他的家人包括妻兒，都同樣放棄美國籍！</span></span></strong><br />\n<br />\n          這可不容易，張翔的兒子自小在美國長大，長得像ABC，很難因為事業而影響家庭。條件談不攏，<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">張翔只好放棄南京大學</span></span></strong>。此時，港大校長馬斐森任期未滿，突然「劈炮」。張翔在年紀、學術及領導才能都符合港大要求，加上一早已作好離職準備，港大真是求之不得。港大校長之職，挑戰重重，祝願張翔能披荊斬棘，帶領港大走向高峰吧。<br />\n<br />\n        潘麗瓊"},{"pid":"12e9d943da713a3ac094081b230b4c390c96ff1d","tid":1574604,"uid":293227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T14:32:15.000Z","msg":"推929 101 全球反共遊行<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">全世界幫老共慶生啦喂</span></span>"},{"pid":"cb98a9b1ccbf18e05f525e4fba72357a768a121c","tid":1574604,"uid":37112,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T15:03:35.000Z","msg":"一大😎"},{"pid":"107a33b5ca6b8ded324423888309f0caafe23a61","tid":1574604,"uid":70524,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T15:04:28.000Z","msg":"<strong><span style=\"color: orange;\">721<br />\n831<br />\n新屋嶺集中營</span></strong>"},{"pid":"0d674cbaa0a48067f3b607008dcc16a2de18f60e","tid":1574604,"uid":39872,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T15:09:59.000Z","msg":"天滅中共<br />\n全黨死清光<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"6d4fad751cd23631870b2d2148b79c03fdf9f294","tid":1574604,"uid":37112,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T15:21:53.000Z","msg":"<img src=\"https://na.cx/i/N8p3nvf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FN8p3nvf.jpg&h=4d37a3a2&s={SIZE}\" />"}]}