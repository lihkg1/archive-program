/normal/clown.gif\" class=\"hkgmoji\" />拉!"},{"pid":"d878d31fe3e85258f8c565bbb81e3e3210e48d94","tid":2192324,"uid":33359,"like":0,"dislike":1,"score":-1,"quote":{"pid":"d80bcc334f23a043c29d0c2237c3b2d55b591f4b","tid":2192324,"uid":11365,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-07T04:57:40.000Z","msg":"Enter個下大叫拉<br />\n型到<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-07T05:12:59.000Z","msg":"好似細個玩勁舞團個陣<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n最尾個下拍space 一定要有咁大力得咁大力<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"2fee5a654b3e24087866ef3c639f1010df1d655b","tid":2192324,"uid":21424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-07T06:11:39.000Z","msg":"拉<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"}]}