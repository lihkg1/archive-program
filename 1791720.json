=\"https://www.facebook.com/107457800635080/posts/159723118741881/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F107457800635080%2Fposts%2F159723118741881%2F%3Fd%3Dn&d=Wr%2FXdV%2FekiVpClOitW4NQY6aL69TDc1SPHZju%2B%2BXLiQ%3D&h=c44b4a64\" data-auto-link target=\"_blank\">https://www.facebook.com/107457800635080/posts/159723118741881/?d=n</a>"},{"pid":"c1c507a2ca851cd373fbfd4c56003b42a2292eda","tid":1791720,"uid":61277,"like":13,"dislike":45,"score":-32,"citedBy":3,"replyTime":"2019-12-21T09:05:43.000Z","msg":"所有法律開支都係612出<br />\n星火根本冇打算過幫義士，由頭到尾都係連登仔一廂情願以為佢地好幫前線，而事實上佢地16年都比人踢爆過將捐款落格拎來搭的士、飲飲食食<br />\n<br />\n鐵一般既事實，留名睇有人唔肯面對現實話我分化"},{"pid":"baf641ad22b304d0c0c2803d99f4b2dc513ebb4d","tid":1791720,"uid":177213,"like":19,"dislike":3,"score":16,"citedBy":2,"replyTime":"2019-12-21T09:14:49.000Z","msg":"嘩呢個Po咁多五毛嘅<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"dad0ff2187743d213e2a3de4e45b39da15abbb79","tid":1791720,"uid":68018,"like":1,"dislike":9,"score":-8,"citedBy":1,"replyTime":"2019-12-21T10:01:51.000Z","msg":"屌你now都分化？<br />\n一定係偽黃！<br />\n個律師一定唔係星火既律師<br />\n唔知邊到請番黎<br />\n<br />\n你班人到今日仲想分化係想點？<br />\n星火靜靜地比左好多錢手足又同你講咩？<br />\n你地批評星火意圖好明顯啦<br />\n講左幾多次星火好多野做<br />\n要投資錢搵錢先養到其他手足<br />\n你班攻擊星火既五毛死全家！"},{"pid":"e11fab7ff4739aae9eecc31c5ab2a28b41016634","tid":1791720,"uid":144084,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2019-12-21T10:02:58.000Z","msg":"一日唔殺狗<br />\n場運動一日唔會完<br />\n講完"},{"pid":"e8d69dc0827f776c2dc9e07ababb07e01c7f8074","tid":1791720,"uid":33028,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-12-21T10:03:53.000Z","msg":"義務提供法律支援"},{"pid":"f9796a94e1b01ed19f7595402ecb2d416b1e2982","tid":1791720,"uid":47222,"like":3,"dislike":1,"score":2,"quote":{"pid":"0a35530fab7672136d60f1b7a256975e8cf4dc4a","tid":1791720,"uid":158613,"like":217,"dislike":1,"sco