ssets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><br />\n兄弟要爬山呀"},{"pid":"9de9edca47e0f1ca53cdb900bc9adba3e3faf057","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:26:46.000Z","msg":"<img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" />"},{"pid":"92a804bd7e0be165dcd091a386d7ea3de7a9c534","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-22T02:35:23.000Z","msg":"噚日大家辛苦嘞<br />\n<img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" />"},{"pid":"d138d6c3450306cab75354875cc6b6a3630207bb","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T12:34:17.000Z","msg":"<img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" />"},{"pid":"dd2433c57afc0ccdd055b0e72045b7ddc176b1d0","tid":1235351,"uid":265467,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T12:34:45.000Z","msg":"Sorry ，借位一用<br />\n<br />\n大家應該由問題根源去思考，與其一樣樣去反對政府D賣港政策，點解唔用真普選趕走曬班賣港賊，必須要令更多人知問題根源核心，個個支持真普選！！！<br />\n<br />\n現有大家要爭取D問題層次如果向上推，就會發現係香港現有制度出現問題，一日冇真普選，相同問題絕對會源源不絕！！！<br />\n<br />\n一日無真普選,建制派，港共政權賣港賊一車車補上，要徹底趕走賣港賊,只有真普選！！！各自跑山，真香港人加油！！<br />\n<br />\n［真普選救祖國行動］200年前香港割讓救國，如今中共有難，香港再割責無旁貸！！！<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1252184\" data-auto-link target=\"_blank\">https://lih.kg/1252184</a><br />\n<br />\n［請廣傳］香港只有真普選先可以趕走港共政府同建制派賣港賊！<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1251736\" data-auto-link target=\"_blank\">https://lih.kg/1251736</a>"},{"pid":"6913c8642944caa766570af43199110b82601b0c","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-24T03:00:09.000Z","msg":"返工<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" />"},{"pid":"25366f49a9925c0b7bac019de82d041f228e15a5","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T01:59:57.000Z","msg":"不忘初心，每日推一推<br />\n<img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" />"},{"pid":"5a3f8835fb912588c08030f9c699ef09eb44191d","tid":1235351,"uid":106336,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T02:03:30.000Z","msg":"呢個真係好有用<img src=\"/assets/faces/lm2/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"e746968b0af5d824322496c546072310a51bb95e","tid":1235351,"uid":221265,"like":0,"dislike":0,"score":0,"quote":{"pid":"b2642711f339e91737477e8a41ef9ebee983d38b","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-17T06:11:49.000Z","msg":"要打持久戰，我哋要有健康嘅精神狀態<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n如果唔係就好易做錯判斷，咁就變豬隊友嘞<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><br />\n<br />\n呢兩個禮拜我哋吸收咗太多真嘅假嘅資訊，參加咗好多人行動，我哋需要休息一陣<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><br />\n<br />\n我好想喺度推動大家一齊，每日做靜觀（Mindfulness）<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n咩係靜觀可以睇以下呢段片<br />\n<a href=\"https://www.youtube.com/watch?v=-LHT_2sgMtg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D-LHT_2sgMtg&d=goC%2B%2BwCxwRgX8SEPTes0u1tn4zyk5OLfN8GNswWzUNI%3D&h=51327b4f\" target=\"_blank\">https://www.youtube.com/watch?v=-LHT_2sgMtg</a><br />\n<br />\n有研究指出，有持續進行靜觀習慣嘅人，大腦嘅灰質會增加，對人嘅同理心，耐性都會改善<br />\n<br />\n另外一個重點，係可以改善睡眠質素，令身體健康啲！<br />\n<br />\n呢度另外有一篇長文講靜觀<br />\n<a href=\"https://treehole.hk/靜觀-一文爲你解通/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftreehole.hk%2F%E9%9D%9C%E8%A7%80-%E4%B8%80%E6%96%87%E7%88%B2%E4%BD%A0%E8%A7%A3%E9%80%9A%2F&d=goC%2B%2BwCxwRgX8SEPTes0u1tn4zyk5OLfN8GNswWzUNI%3D&h=d7b25fc3\" data-auto-link target=\"_blank\">https://treehole.hk/靜觀-一文爲你解通/</a><br />\n<br />\n咁靜觀點做呢？<br />\n其實真係好簡單<br />\n1. Set好Timer做1分鐘 (可以唔止1分鐘，但建議啱啱開始可以由每日1分鐘做起）<br />\n2. 坐好，雙手放喺大腿上<br />\n3. 合埋雙眼<br />\n4. 慢慢深呼吸，將注意力放喺<br />\n-- 鼻哥窿上面，感受下吸氣同呼氣鼻哥窿嘅感覺，或者<br />\n-- 腹部隆起同收縮嘅感覺<br />\n5. 重複4. 直到Timer響<br />\n<br />\n當你深呼吸嘅時候，可能會諗起好多嘢Side track你嘅注意力，但唔需要緊張，只要當你察覺到自己分咗心嘅時候，慢慢返返去鼻哥窿或者腹部嘅感覺就可以嘞<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n大家趁而家放飯，留一分鐘時間畀自己做一做<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/pEcn2yu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpEcn2yu.jpg&h=96ab9e9c&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-06-25T02:04:12.000Z","msg":"係咪即係冥想？"},{"pid":"343510c184b3b311984739054c5393ebef203566","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"quote":{"pid":"e746968b0af5d824322496c546072310a51bb95e","tid":1235351,"uid":221265,"like":0,"dislike":0,"score":0,"quote":{"pid":"b2642711f339e91737477e8a41ef9ebee983d38b","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-17T06:11:49.000Z","msg":"要打持久戰，我哋要有健康嘅精神狀態<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n如果唔係就好易做錯判斷，咁就變豬隊友嘞<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><br />\n<br />\n呢兩個禮拜我哋吸收咗太多真嘅假嘅資訊，參加咗好多人行動，我哋需要休息一陣<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><br />\n<br />\n我好想喺度推動大家一齊，每日做靜觀（Mindfulness）<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n咩係靜觀可以睇以下呢段片<br />\n<a href=\"https://www.youtube.com/watch?v=-LHT_2sgMtg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D-LHT_2sgMtg&d=goC%2B%2BwCxwRgX8SEPTes0u1tn4zyk5OLfN8GNswWzUNI%3D&h=51327b4f\" target=\"_blank\">https://www.youtube.com/watch?v=-LHT_2sgMtg</a><br />\n<br />\n有研究指出，有持續進行靜觀習慣嘅人，大腦嘅灰質會增加，對人嘅同理心，耐性都會改善<br />\n<br />\n另外一個重點，係可以改善睡眠質素，令身體健康啲！<br />\n<br />\n呢度另外有一篇長文講靜觀<br />\n<a href=\"https://treehole.hk/靜觀-一文爲你解通/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftreehole.hk%2F%E9%9D%9C%E8%A7%80-%E4%B8%80%E6%96%87%E7%88%B2%E4%BD%A0%E8%A7%A3%E9%80%9A%2F&d=goC%2B%2BwCxwRgX8SEPTes0u1tn4zyk5OLfN8GNswWzUNI%3D&h=d7b25fc3\" data-auto-link target=\"_blank\">https://treehole.hk/靜觀-一文爲你解通/</a><br />\n<br />\n咁靜觀點做呢？<br />\n其實真係好簡單<br />\n1. Set好Timer做1分鐘 (可以唔止1分鐘，但建議啱啱開始可以由每日1分鐘做起）<br />\n2. 坐好，雙手放喺大腿上<br />\n3. 合埋雙眼<br />\n4. 慢慢深呼吸，將注意力放喺<br />\n-- 鼻哥窿上面，感受下吸氣同呼氣鼻哥窿嘅感覺，或者<br />\n-- 腹部隆起同收縮嘅感覺<br />\n5. 重複4. 直到Timer響<br />\n<br />\n當你深呼吸嘅時候，可能會諗起好多嘢Side track你嘅注意力，但唔需要緊張，只要當你察覺到自己分咗心嘅時候，慢慢返返去鼻哥窿或者腹部嘅感覺就可以嘞<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n大家趁而家放飯，留一分鐘時間畀自己做一做<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/pEcn2yu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpEcn2yu.jpg&h=96ab9e9c&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-06-25T02:04:12.000Z","msg":"係咪即係冥想？"},"citedBy":0,"replyTime":"2019-06-25T03:34:30.000Z","msg":"可以咁講"},{"pid":"0d2c3b8d3730203b15508dc4adeeeb8e292be900","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-26T01:29:44.000Z","msg":"早晨！返工練一練<img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" />"},{"pid":"0ce25353e0eb0f46307502dfecef48de533dcc4e","tid":1235351,"uid":176834,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-06-26T02:07:45.000Z","msg":"唔知點解我一set timer就會精神緊張<br />\n好撚驚個鬧鐘會響<br />\n嗰1分鐘之內不停擘大眼睇下幾時完<br />\n然後喺佢響幾秒前快手㩒熄佢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n完全做唔到靜觀呢樣野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"b61e2ba3832da0bafb8b5661bd4b58f55da9de7a","tid":1235351,"uid":13754,"like":1,"dislike":0,"score":1,"quote":{"pid":"0ce25353e0eb0f46307502dfecef48de533dcc4e","tid":1235351,"uid":176834,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-06-26T02:07:45.000Z","msg":"唔知點解我一set timer就會精神緊張<br />\n好撚驚個鬧鐘會響<br />\n嗰1分鐘之內不停擘大眼睇下幾時完<br />\n然後喺佢響幾秒前快手㩒熄佢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n完全做唔到靜觀呢樣野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-26T02:35:54.000Z","msg":"我有時都會㗎<br />\n<br />\n咁你可試試下掉返轉<br />\n放鬆-&gt;吸一次氣就數數字-&gt;呼氣<br />\n<br />\n例子：<br />\n吸氣(1)-&gt;呼-&gt;吸氣(2)-&gt;呼-&gt;&gt;&gt;吸氣(10)-&gt;呼<br />\n重複幾次<br />\n<br />\n或者可以用Calm, headspace, 心導遊或者newlife330呢啲apps去帶住自己做<br />\n<br />\n咁應該會容易啲手"},{"pid":"f786ec65f17912aac629bcdd260c613c99af1f2a","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-26T05:42:11.000Z","msg":"食飽飯練習咗先做嘢<img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" />"},{"pid":"8401b47d589d1f0a92ada32dd33c61d47a8d28a6","tid":1235351,"uid":13754,"like":0,"dislike":0,"score":0,"cite