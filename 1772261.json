.lih.kg/540/https://na.cx/i/bktn4YN.gif\" />"},{"pid":"bd21c0d67b85977c85d21d292eb6af7181a209ea","tid":1772261,"uid":128603,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-06T20:33:15.000Z","msg":"<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"af30d584926bbe75ce23139184bdeff019136cb3","tid":1772261,"uid":130626,"like":0,"dislike":0,"score":0,"quote":{"pid":"89a69fbacbc417e578505b987bc077e3ed2ec711","tid":1772261,"uid":279356,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-06T20:30:32.000Z","msg":"好嬲 要早日康復<br />\n<img src=\"https://na.cx/i/N1Bg9NU.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FN1Bg9NU.gif&h=5666855a&s={SIZE}\" /><br />\n<img src=\"https://i.lih.kg/540/https://na.cx/i/bktn4YN.gif\" />"},"citedBy":0,"replyTime":"2019-12-06T23:07:05.000Z","msg":"Thx for sharing"},{"pid":"acedcdc224468034d9b854353694ae9c3db58500","tid":1772261,"uid":123696,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-12-06T23:16:37.000Z","msg":"<blockquote>他的思緒飄到香港重光之後，眾人齊集煲底脫下口罩，與愛人牽手走過黑地毯浪漫一吻，有情人終成眷屬，「最想自己都經歷這些時刻。」自言「好恨拍拖」的男生忽然含羞答答。</blockquote><br />\n<br />\n好有少女心<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /><br />\n<br />\n我睇到佢喊嗰條片 自己都差啲喊咗<br />\n<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"df37570632b4a63af06f1f4f06be6053951ac7be","tid":1772261,"uid":45927,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-06T23:26:14.000Z","msg":"辛苦手足"},{"pid":"36b34383050d61fae15b1f12ec9b365b68cae826","tid":1772261,"uid":14350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-06T23:28:57.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"794aaad02c9730004e2005917433e5217b07d238","tid":1772261,"uid":315299,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-06T23:58:43.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/norm