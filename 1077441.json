mg src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"982edcf6f4c2b76cf8b95e8fd981e960a323fe9c","tid":1077441,"uid":36901,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-25T15:56:50.000Z","msg":"呢d風已經完全唔撚信"},{"pid":"9101a3901d7b29d2c62bfd92caae671bbe8dd473","tid":1077441,"uid":155095,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-03-25T16:00:21.000Z","msg":"作為共產黨中央領導核心<span style=\"color: red;\">七位</span>政治局常務委員<span style=\"color: red;\">之一</span>的<strong>韓正</strong>表示，中國希望持續增加進口。「中國不以追求貿易順差為目標，」他說。<br />\n<br />\n韓正講only <img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},{"pid":"752609839022554ec9a14610fb60a91d1a5eefc1","tid":1077441,"uid":30169,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2019-03-25T16:02:11.000Z","msg":"<img src=\"https://na.cx/i/0dAtbBY.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0dAtbBY.gif&h=d3d20c23&s={SIZE}\" />"},{"pid":"663acd044de625ab5b1a93536fd52967cc8c2f16","tid":1077441,"uid":76310,"like":9,"dislike":0,"score":9,"quote":{"pid":"ba4a691375c933fffc20952510608537de119882","tid":1077441,"uid":50386,"like":16,"dislike":0,"score":16,"citedBy":1,"replyTime":"2019-03-25T15:46:43.000Z","msg":"入世貿入咗十鳩幾年<br />\n而家先話準備開放<br />\n好撚嘢<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-25T16:05:21.000Z","msg":"自己應承左18年唔做既野<br />\n<br />\n而家再承諾<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n弱智都唔信佢啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4267a5d12b5c626128c33f0320c0e53b86c23d71","tid":1077441,"uid":114275,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-03-25T16:16:12.000Z","msg":"今次支那過到骨 十年之後老美想再撚佢就更難"},{"pid":"d0f7812daf7448ec57738371e86e95a816516c49","tid":1077441,"uid":70786,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-25T20:22:30.000Z","msg":"改革開放40年<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"916d9815be9aff5d14170d17394b4018bb19675b","tid":1077441,"uid":62650,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-25T20:23:31.000Z","msg":"中國承諾係垃圾黎...美國佬唔好中計"},{"pid":"189b022801ba304c4b47afa9bf9637ab670ba09f","tid":1077441,"uid":20498,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-25T20:33:28.000Z","msg":"中共:假一賠十"},{"pid":"5543b91cbf82d3ad9435687087711cd1a535b8ba","tid":1077441,"uid":64716,"like":5,"dislike":0,"score":5,"quote":{"pid":"c48bb9c458836419d5d78dba51832f14863ceb05","tid":1077441,"uid":76745,"like":14,"dislike":0,"score":14,"citedBy":2,"replyTime":"2019-03-25T15:43:29.000Z","msg":"改革開放左40年 都仲係處於準備開放更多市場既狀態<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-25T21:04:09.000Z","msg":"呢個係共慘黨模型o既死症。<br />\n唔係唔想開放，而係一開放成知管治權就會散哂。 第一係所有國產貨大部份失去競爭力，唯然made in china佔據地球70% 但多是基於外牌品牌oem .<br />\n第二係放棄重重關税同限制，變相實體資金大量流走，第三係班呀爺冇哂飯開。<br />\n<br />\n一個比較簡單o既解釋就係： 以前到現在一直行緊有入盡量冇出，一旦放開國民就會有大量購買外國貨而錢就流哂出去。<br />\n<br />\n正常健康經濟體系當然冇事，但中國呢幾十年從來未正常過，谷得咁快o既後遺症。<br />\n多撚謝江派同成班冇腦太子黨把成個中國通漲推到去爆煲邊緣，成堆國企同民企冇得再慢慢起步，一定要獨市先有得生存。仲未計一大堆騙子企業，即係根本成個bussiness都係笑話，炒空炒價無實業o既空殼，例如樂視。"},{"pid":"71db8431be7f29165e170c9ebfa8401fadd1829e","tid":1077441,"uid":156363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-25T21:07:44.000Z","msg":"大隻講"},{"pid":"a9c7fc5225c5c448d56af0eedf86d9956e4bc25a","tid":1077441,"uid":64716,"like":3,"dislike":0,"score":3,"quote":{"pid":"2130603d618ddbcf6b22d5ce741829f186697d15","tid":1077441,"uid":49197,"like":4,"dislike":0,"score":4,"quote":{"pid":"c48bb9c458836419d5d78dba51832f14863ceb05","tid":1077441,"uid":76745,"like":14,"dislike":0,"score":14,"citedBy":2,"replyTime":"2019-03-25T15:43:29.000Z","msg":"改革開放左40年 都仲係處於準備開放更多市場既狀態<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-25T15:48:05.000Z","msg":"鬼敢全面開放<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />,越開得多,中共D謊言越快比民眾識穿<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-25T21:15:07.000Z","msg":"其實係你地太天真，國內揾緊錢個班，全都比你地清楚，明白發生緊咩事，但又基於利益問題繼續扮傻。<br />\n由上而下都建基在扭曲誠實o既生態模式下，你要活得好就要同化呢種遊戲模式。<br />\n拳頭&gt;財富&gt;權力 ,要站得穩，必需要得到權力，所以必先盡快得到錢，那誰還有心情慢慢實務實幹去發展實業？<br />\n上到位o既企業，滾存咁多權力，你叫佢放低個拳頭努力做好同外國企業公平競爭喎？<br />\n<br />\n你叫老習開放，咁即係推個班人去死，千千層扣，最頂層利益都係權力核心，你話會發生咩事？"},{"pid":"74c02ba9b558f95dea695ec848c0676291aa0b4d","tid":1077441,"uid":224066,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-03-25T21:57:10.000Z","msg":"可以做啲乜話畀全世界知<br />\n<img src=\"https://na.cx/i/E6FkO8r.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FE6FkO8r.png&h=f223bcce&s={SIZE}\" />"},{"pid":"3569c354c748417243b9c86d85469095aa38bcd1","tid":1077441,"uid":18955,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2019-03-25T22:03:09.000Z","msg":"中共一直以黎<br />\n有咩誠諾係實踐到？<br />\n<br />\n國共合作？<br />\n一國兩制？<br />\n高度自治？<br />\n中英聯合聲明？<br />\n世貿協議？<br />\n。。。。。。"}]}