plyTime":"2019-08-18T00:21:47.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"4294c25acb294af3d7a1610070d94fd85ba71128","tid":1481653,"uid":53361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T00:21:59.000Z","msg":"<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"267b52dc454a0b68c4256dfc137d2aa51bb25358","tid":1481653,"uid":171543,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T00:22:36.000Z","msg":"推"},{"pid":"f4b95a12d35fab7ac53d9184b16d42016bc90dec","tid":1481653,"uid":220438,"like":0,"dislike":0,"score":0,"quote":{"pid":"a78754bba95b941b3f49fd3db553fdf47680ecba","tid":1481653,"uid":16792,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a9a37dd35cbd07659db0641f6adf6667ffc6723","tid":1481653,"uid":220438,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-08-17T20:25:38.000Z","msg":"成個法團俾你換埋都冇用 黑警有心硬闖你阻佢就阻差辦公拉你 反抗就係拒捕 講道理同法律有鬼用 佢地濫捕濫告完全冇後果"},"citedBy":1,"replyTime":"2019-08-17T23:59:37.000Z","msg":"有冇辦法可以解散警隊？"},"citedBy":1,"replyTime":"2019-08-18T00:29:02.000Z","msg":"解散狗隊搵擺放軍黎執法<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"2fe72af1bb728b335c16098b737f802422b8bd10","tid":1481653,"uid":16792,"like":0,"dislike":0,"score":0,"quote":{"pid":"f4b95a12d35fab7ac53d9184b16d42016bc90dec","tid":1481653,"uid":220438,"like":0,"dislike":0,"score":0,"quote":{"pid":"a78754bba95b941b3f49fd3db553fdf47680ecba","tid":1481653,"uid":16792,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a9a37dd35cbd07659db0641f6adf6667ffc6723","tid":1481653,"uid":220438,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-08-17T20:25:38.000Z","msg":"成個法團俾你換埋都冇用 黑警有心硬闖你阻佢就阻差辦公拉你 反抗就係拒捕 講道理同法律有鬼用 佢地濫捕濫告完全冇後果"},"citedBy":1,"replyTime":"2019-08-17T23:59:37.000Z","msg":"有冇辦法可以解散警隊？"},"citedBy":1,"replyTime":"2019-08-18T00:29:02.000Z","msg":"解散狗隊搵擺放軍黎執法<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-18T00:35:20.00