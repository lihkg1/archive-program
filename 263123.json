-hk.net%2Fupload%2F2017%2F05%2F30%2F015153_e2db85332ce8ac8f9f62e53c9b815319.jpg&h=670453ad&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/30/015154_e2f96485d86ee8f3f379ee0a3aa0ab2d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F30%2F015154_e2f96485d86ee8f3f379ee0a3aa0ab2d.jpg&h=454d11ac&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/30/015155_f15ac9e045fcf7b6728c7ebee25245b9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F30%2F015155_f15ac9e045fcf7b6728c7ebee25245b9.jpg&h=804a3c90&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/30/015156_f15ac9e045fcf7b6728c7ebee25245b9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F30%2F015156_f15ac9e045fcf7b6728c7ebee25245b9.jpg&h=63038b32&s={SIZE}\" /><br />\n<br />\n佢Facebook <br />\n<a href=\"https://www.facebook.com/ahmed.angel.5?fref=ts\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fahmed.angel.5%3Ffref%3Dts&d=XHnYWkiZIwOO3qOg8qC8saWGW%2FHqnCni%2B1xW1zXhD2s%3D&h=5f64cc0b\" target=\"_blank\">https://www.facebook.com/ahmed.angel.5?fref=ts</a>"},{"pid":"31fa738af73121eaeccfd1ae86071c8ef1a53c6c","tid":263123,"uid":66,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-29T17:56:12.000Z","msg":"回顧<br />\n「天使系美男」如此完美的男子根本不可能存在世界上<br />\n<img src=\"http://www.nedhardy.com/wp-content/uploads/images/2013/may/ahmed/ahmed_22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.nedhardy.com%2Fwp-content%2Fuploads%2Fimages%2F2013%2Fmay%2Fahmed%2Fahmed_22.jpg&h=49fb39f4&s={SIZE}\" /><br />\n<img src=\"http://daizszyxbqbb5.cloudfront.net/wp-content/uploads/2013/05/Ahmed-Angel-550x410.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fdaizszyxbqbb5.cloudfront.net%2Fwp-content%2Fuploads%2F2013%2F05%2FAhmed-Angel-550x410.jpg&h=bd53c333&s={SIZE}\" /><br />\n「他的明亮雙眸具有穿透靈魂的力量，油光秀髮讓女孩忍不住觸摸螢幕。」最近在網路上出現一位「天使系美男」，他的名字叫作艾哈邁德 (Ahmed Angel)。<br />\n<img src=\"http://cs308325.vk.me/v308325378/2a13/Cr6lsH_v8NU.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcs308325.vk.me%2Fv308325378%2F2a13%2FCr6lsH_v8NU.jpg&h=06c26a90&s={SIZE}\" /><br />\n「天使系美男」艾哈邁德的超凡氣質讓人難以直視。<br />\n<img src=\"http://cs308325.vk.me/v308325378/270b/5i942CtQbOU.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcs308325.vk.me%2Fv308325378%2F270b%2F5i942CtQbOU.jpg&h=d60a4e1c&s={SIZE}\" /><br />\n艾哈邁德的姓氏與超凡脫俗的氣質十分相稱，他的一系列照片透過 BuzzFeed 及霍芬頓郵報等知名網站瘋傳，讓每位網友都想要了解他多一點。<br />\n<img src=\"http://25.media.tumblr.com/01e0c0d8ca6b083c3e0873fc2003b50b/tumblr_mikx8u72241qzx30xo2_1280.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2F25.media.tumblr.com%2F01e0c0d8ca6b083c3e0873fc2003b50b%2Ftumblr_mikx8u72241qzx30xo2_1280.jpg&h=f4f919fe&s={SIZE}\" /><br />\n然而除了喜歡化妝、抹髮膠、穿酸蝕牛仔褲之外，「天使系美男」絕大多數資訊仍是個謎。<br />\n<img src=\"http://cdn.ph.upi.com/sv/i/UPI-8661368745721/2013/1/13687461453676/Ahmed-Angel-Iraqi-model-and-photoshop-expert-is-delighting-the-Internet.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcdn.ph.upi.com%2Fsv%2Fi%2FUPI-8661368745721%2F2013%2F1%2F13687461453676%2FAhmed-Angel-Iraqi-model-and-photoshop-expert-is-delighting-the-Internet.jpg&h=d8ec1fad&s={SIZE}\" /><br />\n本來<span style=\"color: red;\"><strong>有網友懷疑，如此完美的男子根本不可能存在世界上</strong></span><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 。<br />\n<img src=\"http://cs303507.vk.me/v303507378/7a5/8ig-bpPoooQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcs303507.vk.me%2Fv303507378%2F7a5%2F8ig-bpPoooQ.jpg&h=d6eabd6a&s={SIZE}\" /><br />\n幸運的是，艾哈邁德從社群網站得知自己走紅的事情，而且很願意向世人展現身分。原來他來自伊拉克，現年 18 歲，目前正在白俄羅斯學醫。[/quote]<br />\n<img src=\"http://i.imgur.com/ybuqRoA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi.imgur.com%2FybuqRoA.jpg&h=e1fbc29e&s={SIZE}\" /><br />\n哈邁德說，「我不是模特兒，我是超級模特兒！」他聲稱自己收到很多電影及藝術工作的合約，但暫時得先把模特兒工作放在一旁，準備專注於研究上。不過像他這樣的美男子也會為了走紅擔憂，「我很榮幸也很困惑，真的不知道該怎麼應付這麼大的名氣。」<br />\n<img src=\"http://image.blingee.com/images19/content/output/000/000/000/7df/820387970_1576446.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimage.blingee.com%2Fimages19%2Fcontent%2Foutput%2F000%2F000%2F000%2F7df%2F820387970_1576446.gif&h=b47b3053&s={SIZE}\" /><br />\n<img src=\"http://metrouk2.files.wordpress.com/2013/05/ay_109844569.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fmetrouk2.files.wordpress.com%2F2013%2F05%2Fay_109844569.jpg&h=f7c8c0dd&s={SIZE}\" /><br />\n<img src=\"http://www.anorak.co.uk/wp-content/uploads/2013/05/ahmed-angel-3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.anorak.co.uk%2Fwp-content%2Fuploads%2F2013%2F05%2Fahmed-angel-3.jpg&h=fe3f6b21&s={SIZE}\" />"},{"pid":"07f13ce00bb70a5f0c106c5e7441de827bd658db","tid":263123,"uid":115655,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-29T17:57:20.000Z","msg":"其實幾靚仔<br />\n係d衫肉酸同個頭柒姐"},{"pid":"d31ab22c65943d21ac08c848d155392ddea6fe96","tid":263123,"uid":36964,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-29T17:58:31.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">GAY</span></span>"},{"pid":"aef3bbcadee6df0e24dbbc10ec081a59fd66de2b","tid":263123,"uid":106544,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-29T18:06:46.000Z","msg":"救命<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bbd04728525da7f91353867be7a40badfacfa342","tid":263123,"uid":47845,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-29T18:09:53.000Z","msg":"屌你老味<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"3d0141bbdbda4fba0fa766940661a6abc851ab78","tid":263123,"uid":51978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-29T18:24:41.000Z","msg":"<blockquote>其實幾靚仔<br />\n係d衫肉