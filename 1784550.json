ike":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T00:27:35.000Z","msg":"推推推"},{"pid":"a3911abbad55384817b63d989bf0279d9a9f3219","tid":1784550,"uid":253688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T01:02:10.000Z","msg":"推推推"},{"pid":"d05f8c15f482f08b9a6e05ef94c7e928ee48a0de","tid":1784550,"uid":253688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T02:00:02.000Z","msg":"推推推"},{"pid":"f74bfb28bb2dde3f58fc951f865c5d2c7cfe8de1","tid":1784550,"uid":253688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T03:49:38.000Z","msg":"推，被捕手足唔係condom"},{"pid":"7e3de0f1a40b59288cfc036842864d1fedf53797","tid":1784550,"uid":253688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T06:57:40.000Z","msg":"推推推"},{"pid":"935f85b7fffb6edf6173a56e1cd3d85b54bfba1b","tid":1784550,"uid":253688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T06:57:40.000Z","msg":"推推推"},{"pid":"457800c523fa83287658b746d40cee0cca2d2991","tid":1784550,"uid":253688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T09:09:52.000Z","msg":"推"},{"pid":"72a34912a3e1a7cf951c59a303082477c65fff7e","tid":1784550,"uid":31200,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T09:31:19.000Z","msg":"其實真係好難，如果告黑警濫捕唔知要搵咩證據，加上打官司贏左都唔代表濫捕唔會發生。<br />\n<br />\n監警會廢既，又冇獨立調查。人權法又未咁快見到效果。<br />\n<br />\n所以前線手足一定要團結，盡量唔好落單，要有哨，練好體能。<br />\n和理非做好掩護，現場太多變數，千祈唔好因爲驚而亂左陣腳<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}