id":"ea128b2f8b5011c5d5cb08cabf5ccfcfd62434d0","tid":1070721,"uid":77642,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-21T03:18:24.000Z","msg":"鑰<br />\n鑰匙〖key〗<br />\n鑰,鎖匙。 &mdash;&mdash;《增補五方元音&middot;駝韻》<br />\n質明啟鑰。 &mdash;&mdash;清&middot;方苞《獄中雜記》<br />\n無鑰,可令銅匠銛開。 &mdash;&mdash;章炳麟《致伯中書》<br />\n又如:鑰牡(開鎖的工具。即鑰匙);鑰鋦(鑰匙)<br />\n<br />\n鑰最舊係指門直閂。上穿橫閂下插地上的直木，後來引申到關、鎖守，<br />\n再後來引申到鎖匙。<br />\n<br />\n到現代，鑰已經被當成key既意思多於鎖、關、鎖守。<br />\n卡巴斯基條key都叫金鑰，所以鑰真係可以解匙。<br />\n<br />\n但鎖鑰呢個詞就真係指闗鍵<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"85157635127d7ac25f65de195ca69403e46fe809","tid":1070721,"uid":41821,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-21T03:19:45.000Z","msg":"鑰匙呢?.?"},{"pid":"5a55a51d86de0dee5e3ad18911b7d0d86644947c","tid":1070721,"uid":136933,"like":0,"dislike":5,"score":-5,"citedBy":0,"replyTime":"2019-03-21T03:40:14.000Z","msg":"我鍾意點打咪點打囉 關你撚事咩<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"a8c6848e470feca3ef0447045171de6e43e440a1","tid":1070721,"uid":195438,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-03-21T03:47:14.000Z","msg":"仲有孌童<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />連啲新聞都成日用錯<br />\n睇到真係火爆，特登打啲錯字"},{"pid":"7e901e5b93557ee62ec6e4fadb1c495dd969a8b5","tid":1070721,"uid":49391,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-03-21T04:06:05.000Z","msg":"<a href=\"https://www.moedict.tw/%E9%8E%96%E9%91%B0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.moedict.tw%2F%25E9%258E%2596%25E9%2591%25B0&d=01EY%2BZdPKRb21p6QCrTOV0YZmLIq74JPLN0FyuDKESI%3D&h=f9be24cb\" data-auto-link target=\"_blank\">https://www.moedict.tw/%E9%8E%96%E9%91%B0</a>"},{"pid":"93ae3674d6b443715fccc66a2478791903fd7781","tid":1070721,"uid":94402,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-2