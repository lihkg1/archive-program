:47:56.000Z","msg":"推"},{"pid":"767d008d57c668e2380a54a77e2592c06191cb91","tid":1548444,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T04:48:46.000Z","msg":"推"},{"pid":"3eefc94ed62f9f5067a09fd06dc6eb77b1992949","tid":1548444,"uid":239492,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T04:58:10.000Z","msg":"只屬於真香港人嘅歌<br />\n<a href=\"https://lih.kg/1547410\" data-auto-link target=\"_blank\">https://lih.kg/1547410</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n麻煩各位如果許可嘅話 背咗首歌佢 然後每日2031停低唱呢首歌 令更多人識同一齊有勇氣唱同發聲。<br />\n<br />\n希望我地可以係煲底相認嘅時候 可以再一齊唱呢首歌<br />\n<br />\n<br />\n<br />\n願榮光歸香港<br />\n<br />\n<br />\n<br />\n<br />\n光復香港 時代革命"}]}