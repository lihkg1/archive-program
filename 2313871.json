盤裡,注入約2cm高度的熱水,放進烤箱以170度c烘烤40分鐘,接著再用160度c繼續烘烤10-15分鐘。搖動模型時,蛋糕表面會像布丁般緩緩搖動的半熟狀態,即代表完成。請依各家烤箱的不同,烘烤時間可做調整。 烤箱先預熱170度c備用。烤模放入大烤盤裡,注入約2cm高度的熱水,放進烤箱以170度c烘烤40分鐘,接著再用160度c繼續烘烤10-15分鐘。搖動模型時,蛋糕表面會像布丁般緩緩搖動的半熟狀態,即代表完成。請依各家烤箱的不同,烘烤時間可做調整。 蛋糕出爐先冷卻後,再放入冰箱冷藏1個小時以上。用刀子沿著模型輕輕劃一圈,取下蛋糕即完成。 蛋糕出爐先冷卻後,再放入冰箱冷藏1個小時以上。用刀子沿著模型輕輕劃一圈,取下蛋糕即完成。"},{"pid":"0b5618e4624a2c0a3c129e47e529cd814985ccef","tid":2313871,"uid":117117,"like":0,"dislike":0,"score":0,"quote":{"pid":"87c3b323713c9b1e5dc0f10227212c2f09e5d793","tid":2313871,"uid":198583,"like":0,"dislike":0,"score":0,"quote":{"pid":"80101bdd9ac97edd106c30b065ec5818253558ee","tid":2313871,"uid":310361,"like":0,"dislike":1,"score":-1,"quote":{"pid":"ecdabfbe6fa43e201473ab509f586bc971c9adf9","tid":2313871,"uid":198583,"like":9,"dislike":4,"score":5,"citedBy":1,"replyTime":"2020-12-06T06:53:52.000Z","msg":"呢個好笑喎 連登咁多垃圾基佬<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-06T06:57:53.000Z","msg":"有D罐頭<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-06T07:06:34.000Z","msg":"可能要出新圖<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-06T07:43:31.000Z","msg":"其實應該要出新圖啦 基佬彩虹旗得六隻色架渣"},{"pid":"c1f8cfb4d243bc4b90fa8f367ca3473f65ae6ff9","tid":2313871,"uid":198583,"like":0,"dislike":0,"score":0,"quote":{"pid":"1f5a9e910840983eaa5dbcf392f57d969f84f9d6","tid":2313871,"uid":44569,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-06T07:35:12.000Z","msg":"乜乜機入面有個人果啲"},"citedBy":0,"replyTime":"2020-12-06T07:45:30.000Z","msg":"但呢個好笑喎"},{"pid":"d854976d509f98621fa07800a801b759938d92c3","tid":2313871,"uid":374602,"like":1,"dislike":1,"score":0,"quote":{"pid":"74e4103b457b4bdbc5f8c65e8503bc801b901ccf","tid":2313871,"uid":366927,"like":16,"dislike":0,"score":16,"citedBy":2,"replyTime":"2020-12-06T07:29:17