 />\n8 00PM左右播了 隨時電腦大爆炸<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"8230cc57b7f0aa7aadac76bcc3a7f14c43b01e9e","tid":103511,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T11:44:09.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"16b3c1651cb2964b18c51ff43da627b635ca872d","tid":103511,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T12:43:37.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"b9ac3ac0a2d5b285b8e72dfef83aa1ee7fe6dbc7","tid":103511,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T13:20:45.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"51f524364e5b4043ce4f97010b7cac275cec7b38","tid":103511,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T13:48:59.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"851b711821fd9a84c65ad8d073d6beb016fecfaa","tid":103511,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T14:16:48.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c73efc73092b55b83a718f6b08da84b52fb6ae1a","tid":103511,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T14:41:24.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}