s=\"hkgmoji\" />"},{"pid":"77c234af7f67f1945cede45db4bf5f9897b00357","tid":603190,"uid":47080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-24T03:33:19.000Z","msg":"台灣新聞？"},{"pid":"41f73643c1be90c38a078919285e4f5eda7f33a4","tid":603190,"uid":36502,"like":6,"dislike":0,"score":6,"quote":{"pid":"92fcf10976b1988a3d8a9d139351f3bf1507e1fa","tid":603190,"uid":167658,"like":4,"dislike":0,"score":4,"quote":{"pid":"2c1b6dd56ebe595861d6cf8c8b226edc1afd516a","tid":603190,"uid":92178,"like":0,"dislike":12,"score":-12,"quote":{"pid":"fe7f8a5d797877f44cab7ad94d3039f2ec2dab34","tid":603190,"uid":132587,"like":22,"dislike":0,"score":22,"citedBy":1,"replyTime":"2018-03-23T14:00:02.000Z","msg":"特朗普好鐘意當中國撚狗咁撚<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-23T14:19:19.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-03-24T03:25:59.000Z","msg":"睇多d新聞啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-24T04:06:18.000Z","msg":"大陸睇唔到外面新聞，唔好怪條支那仔"},{"pid":"b00ecbfb627ec8d53db3c2142aca80ae4185bbdf","tid":603190,"uid":125809,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-24T04:20:01.000Z","msg":"In Trump WE trust"},{"pid":"bc7c713cf7b79430ac4d8d993112129c49bd5ad4","tid":603190,"uid":16055,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-03-24T05:16:49.000Z","msg":"依家覺得侵侵好勁<br />\n對中國了解得好通透<br />\n希望佢可以做落去<br />\n繼續實行對中國方針"},{"pid":"41e535c5eab36ca73b77ed2794649461148ff83b","tid":603190,"uid":81113,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-24T05:18:49.000Z","msg":"Trump最後有冇發賀電？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a973dac07a2247b6339ce8299ac11f5703ba805f","tid":603190,"uid":76488,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-24T05:21:18.000Z","msg":"此回覆已被刪除"},{"pid":"fdcce3f98d32508ead0a67691b8cbe0d79c668dd","tid":603190,"uid":81113,"like":0,"dislike":0,"score":0,"quote":{"pid":"41e535c5eab36ca73b77ed2794649461148ff83b","tid":603190,"uid":81113,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-24T05:18:49.000Z","msg":"Trump最後有冇發賀電？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-24T07:21:23.000Z","msg":"推到有人答<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"18602f261214ef9bf470c7d8d387a8ba47fd7238","tid":603190,"uid":92178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-24T07:26:49.000Z","msg":"此回覆已被刪除"},{"pid":"76c9e8785959bbdae8f355a468613d0fbd8bef0f","tid":603190,"uid":92178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-24T07:28:08.000Z","msg":"此回覆已被刪除"},{"pid":"fcd9e261194d3dfcb49bd833a0125ee47a0f7350","tid":603190,"uid":39855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-24T07:28:40.000Z","msg":"關習習咩事！？根本中共冇誠信。"},{"pid":"15b9ee65e8efdc1004c3a2dba678549857498547","tid":603190,"uid":157362,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-03-24T08:34:56.000Z","msg":"此回覆已被刪除"}]}