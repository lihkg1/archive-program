":"厚到 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-26T05:02:44.000Z","msg":"正想講<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f9d2e0983f7dff09f7ae051e05a20ae827ce695f","tid":996134,"uid":39550,"like":0,"dislike":0,"score":0,"quote":{"pid":"4aa715a75b714959040a46c407a472fc02df1ef4","tid":996134,"uid":22736,"like":0,"dislike":0,"score":0,"quote":{"pid":"de07a939bdb4da82783991ecbea5f0bc81c7cd97","tid":996134,"uid":121146,"like":1,"dislike":0,"score":1,"quote":{"pid":"41b7c3c27de3157124e911025023c2c1225d08e5","tid":996134,"uid":54373,"like":8,"dislike":1,"score":7,"citedBy":1,"replyTime":"2019-01-26T04:52:49.000Z","msg":"<img src=\"https://timgm.eprice.com.hk/hk/mobile/img/2019-01/26/212265/uniqlo_1_58df41df3c2575ac84d6778c38ac7ab8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ftimgm.eprice.com.hk%2Fhk%2Fmobile%2Fimg%2F2019-01%2F26%2F212265%2Funiqlo_1_58df41df3c2575ac84d6778c38ac7ab8.jpg&h=3a16eb10&s={SIZE}\" /><br />\n<br />\n▲ Royole FlexPai <span style=\"color: red;\">去年 10 月發表後</span>，已經在官網發售，難怪柔宇科技可以大口氣。"},"citedBy":1,"replyTime":"2019-01-26T04:54:39.000Z","msg":"厚到 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-26T05:02:44.000Z","msg":"正想講<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-26T05:10:07.000Z","msg":"厚過notebook <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3bcf5e0b566dcee2af3fbfb3c519245ad68382db","tid":996134,"uid":9838,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-26T05:11:47.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"88b4701690f64c26a9231fc21b91b1fb9bd0890f","tid":996134,"uid":187232,"like":2,"dislike":0,"score":2,"quote":{"pid":"049101f0dbbd9206855765b748e83e9ba5cb4ab2","tid":996134,"uid":54373,"like":3,"dislike":29,"score":-26,"quote":{"pid":"0c612ae4be1f3c