0","tid":2144380,"uid":110568,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-07T16:35:45.000Z","msg":"絕不會畀恐怖分子要脅"},{"pid":"fad5ee0f88fb25c15298db2ac5b5ffe7f79da761","tid":2144380,"uid":226466,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-07T16:42:42.000Z","msg":"洋人欺我們太深<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n可摸以拉哂啲加拿大人處決哂佢地<br />\n<br />\n<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n外交人員老弱婦孺都唔好放過"}]}