a8e8506f489423f4be227c1309f5fcb","tid":1846063,"uid":269221,"like":1,"dislike":0,"score":1,"quote":{"pid":"e641796429e88ea67bc9d67a7587147c45611499","tid":1846063,"uid":77416,"like":1,"dislike":0,"score":1,"quote":{"pid":"f991e7f10c3a7d13e07beebd3bc27e3552691b0e","tid":1846063,"uid":269221,"like":0,"dislike":0,"score":0,"quote":{"pid":"39126bba322ad06d945ca8fa8ef4e2de120f47b0","tid":1846063,"uid":194298,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-01-28T16:38:19.000Z","msg":"好似話比人遣返左返菲律賓"},"citedBy":1,"replyTime":"2020-01-28T16:42:28.000Z","msg":"fc?"},"citedBy":1,"replyTime":"2020-01-28T16:44:49.000Z","msg":"Po主有pm人<br />\n但唔肯定係唔係真<br />\n不過希望佢吉人天相<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-28T16:45:24.000Z","msg":"好人一生平安"},{"pid":"85cddba4a152275e49d6cee56521faf02baf0986","tid":1846063,"uid":194325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T16:45:32.000Z","msg":"<img src=\"https://na.cx/i/1DtKWpn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1DtKWpn.jpg&h=a27c226a&s={SIZE}\" /><br />\n<br />\n白色，是醫護常用顏色。不含任何色素，並容易發現污漬，適用於醫院最應保持潔淨的地方。除此之外，白色還代表純粹的善良和堅定的信念。<br />\n<br />\n當日，醫護們憑藉良心忠實履行自己的使命。今日，政權道德綁架他們這一份熱誠和信念。<br />\n<br />\n他們守護了我們生命和健康，但又誰能守護他們？<br />\n<br />\n全城白絲帶，支持醫護罷工。醫護不是condom，我們與醫護同行。<br />\n<br />\n#全城白絲帶 #撐醫護 #撐罷工 #封關口 #醫護非condom #與醫護同行<br />\n#香港金總 #HKFU #standwithmedics<br />\n<br />\n各位金融人都麻煩幫手填問卷，謝謝。<br />\n<br />\n⚠️⚠️緊急⚠️⚠️<br />\n<br />\n香港金融業職工共同抗疫意見調查<br />\n<br />\n香港金融業職工總會欲以問卷方式詢問同業以工業行動共同抗疫的意願和意見，以制定有效方式向僱主及政府表達對僱員對於安全和健康的憂慮，全民共同抗疫。<br />\n<br />\n由於事態緊急，如策劃任何工業行動必需經過既定程序。故此是次問卷將於1月31日23:59截止。希望同業們積極參與此調查，讓金總能全面理解金融界僱主於防疫措施現況，以及會員和同業於共同抗疫的意願，以制定下一步行動。<br />\n<br />\n<a href=\"https://forms.gle/toVdkp2QMVwtZXVr7\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2FtoVdkp2QMVwtZXVr7&d=gjA94EiKSJsk9JMrtOnM5sorGdVmFuHsJRpnpeioS7U%3D&h=0d598a45\" data-auto-link target=\"_blank\">https://forms.gle/toVdkp2QMVwtZXVr7</a><br />\n<br />\n原post傳送門：<br />\n［行動］［請置頂］全民白絲帶 罷工撐醫護<br />\n<a href=\"https://lih.kg/1848612\" data-auto-link target=\"_blank\">https://lih.kg/1848612</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"9b760e157b6f85618cac38e890519bbecb892743","tid":1846063,"uid":198282,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T16:45:47.000Z","msg":"Push"},{"pid":"3d32543ab85d15347029a278d3de2e757067c4cd","tid":1846063,"uid":177338,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T16:47:16.000Z","msg":"push"},{"pid":"0b44cf3c7c6e22363fd78e56e6d3155671e53f48","tid":1846063,"uid":97162,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-01-28T19:22:24.000Z","msg":"<img src=\"https://na.cx/i/Ju7PpJv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJu7PpJv.jpg&h=ae2ec09c&s={SIZE}\" /><br />\nfb見到，未fc，其實都冇得fc...個家人一定唔會出黎講<br />\n狗知佢地邊個"},{"pid":"92e34dfb6d2a6dde691cfb6dff0eef9178e25317","tid":1846063,"uid":8091,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T19:40:38.000Z","msg":"Push"},{"pid":"48aef632c291bbe83bc79b949ff05c036b175aca","tid":1846063,"uid":92353,"like":0,"dislike":0,"score":0,"quote":{"pid":"0b44cf3c7c6e22363fd78e56e6d3155671e53f48","tid":1846063,"uid":97162,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-01-28T19:22:24.000Z","msg":"<img src=\"https://na.cx/i/Ju7PpJv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJu7PpJv.jpg&h=ae2ec09c&s={SIZE}\" /><br />\nfb見到，未fc，其實都冇得fc...個家人一定唔會出黎講<br />\n狗知佢地邊個"},"citedBy":0,"replyTime":"2020-01-28T20:57:17.000Z","msg":"如果假嘅就會出黎澄清 <br />\n咁冇人出黎否認就<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"4eedbc50a634a594e6b429435022f61617600967","tid":1846063,"uid":199957,"like":2,"dislike":0,"score":2,"quote":{"pid":"37bc90c6d30c7ba737c66fee8dd35136b9afa281","tid":1846063,"uid":22796,"like":1,"dislike":0