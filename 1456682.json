.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOrhvw3Y.png&h=942f3e53&s={SIZE}\" /><img src=\"https://na.cx/i/ed4Nzhj.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fed4Nzhj.png&h=3afd5846&s={SIZE}\" /><img src=\"https://na.cx/i/KkNzehk.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKkNzehk.png&h=57b32bdb&s={SIZE}\" />"},{"pid":"1a9bb57837dd9d80d1c50c7e988e6c46a1c7cf27","tid":1456682,"uid":271617,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-12T10:43:42.000Z","msg":"目前我人仍在機埸，明白大家對於近日的抗議有一定憂慮，但實在無需過分恐慌，一些假消息傳出去也是不必要的。<br />\n<br />\n一、<span style=\"font-size: xx-large;\"><span style=\"color: red;\">#香港機場沒有切斷任何網絡</span></span>，順粹是人群聚集後網絡收得很差而已，過去遊行人數多的時候也有同樣狀況。<br />\n<br />\n二、目前機場燈火通明，機場快綫及機場巴士仍正常運作，有推着行李的香港人仍然繼續前往機場，亦有示威者正在陸續離開，包括沿機場路步行至東涌。<br />\n<br />\n三、客運大樓的大部份商店已落閘，現場所見仍有過千名示威者於接機大堂。<br />\n<br />\n四、目前仍有班機等待抵港，包括夜晚8:30的班機，亦有班機等待飛離香港。<br />\n<br />\nBy：黃之峰 facebook 現場 18:17"},{"pid":"d207d01bc3a954d5d84877c325b0a9da9a69c141","tid":1456682,"uid":239143,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-12T10:49:21.000Z","msg":"<img src=\"https://na.cx/i/FpFUejq.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFpFUejq.png&h=63624a73&s={SIZE}\" />"},{"pid":"08b58b7ef5987fb90a2792183e95bf624920b499","tid":1456682,"uid":239143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T10:52:12.000Z","msg":"<span style=\"font-size: xx-large;\">大家幫手，po晒d 鬼/豬隊友出黎！[img]<a href=\"https://na.cx/i/VKinodx.png\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fna.cx%2Fi%2FVKinodx.png&d=nSJvRvahoV7vX7tkwZxFzuSCO5RJLUOM1IbOSdmZk8c%3D&h=cb1bb921\" data-auto-link target=\"_blank\">https://na.cx/i/VKinodx.png</a></span>"},{"pid":"d88dbac87cf8a3f1e69496a66a3832647fbe54ed","tid":1456682,"uid":239143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T10:52:36.000Z","msg":"<img src=\"https://na.cx/i/Mqpqk0v.png\" data-thu