s%3A%2F%2Fna.cx%2Fi%2F70pZwL4.png&h=72ae88bc&s={SIZE}\" /><img src=\"https://na.cx/i/CZd0gcK.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCZd0gcK.png&h=07325f03&s={SIZE}\" /><img src=\"https://na.cx/i/xo5YNjq.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fxo5YNjq.png&h=7e2b114c&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-07-22T01:57:47.000Z","msg":"推"},{"pid":"616417f092165c4963de12525018fabff854c5a5","tid":1344760,"uid":117837,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T01:58:28.000Z","msg":"良田村青山基督教墳場 李趣寬<br />\n<br />\n青山基督教墳場<br />\n新墟<br />\n<a href=\"https://goo.gl/maps/knEJKwS9DgbjWNFz7\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgoo.gl%2Fmaps%2FknEJKwS9DgbjWNFz7&d=D9%2BIkncl4BF5lZ8wPV9kyCaGrLhPWbn%2F%2Bskqqi57m1s%3D&h=da793e57\" data-auto-link target=\"_blank\">https://goo.gl/maps/knEJKwS9DgbjWNFz7</a><br />\n<br />\n何君堯之子<br />\n<br />\nHO JUN WANG (何俊宏）CONRAD<br />\n身份證：P597608(5)<br />\n電話 61277337<br />\n新界元朗牛潭尾道葡萄園洛菲大道3號屋<br />\n<br />\nJ圖就無啦，不過我有兩個號碼，大家可 以好好利用：何俊螢64068666、P5973205<br />\n<br />\n何君堯於2011年獲選成為良田村村代表後，同年四月獲選為屯門鄉事委員會主席，取代出任該位置四十多年的劉皇發。<br />\n<br />\n<br />\n良田村<br />\n始建於大清嘉慶年間的一條客家原居民村，居民以何姓為主，直至1970年代皆世代務農。何氏家族祖籍博羅縣楊村鎮井水龍村，由十八世太公何三梓遷至屯門菠蘿山山腳。由於得到屯門河谷肥沃土壤的地利，因而命名為良田村。<br />\n<br />\n何君堯老母 良田村青山基督教墳場 李趣寬<br />\n囝搵老豆老母<br />\n<br />\n<br />\nSource from 老豆搵仔"},{"pid":"5ee2df4e6afbf578088cdba5b1ede9d16b8af56a","tid":1344760,"uid":158888,"like":0,"dislike":0,"score":0,"quote":{"pid":"d9da29beb48dd9d1300eda44c7796e3ca89c77eb","tid":1344760,"uid":278463,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-22T01:41:37.000Z","msg":"<span style=\"font-size: x-large;\"><strong><span style=\"color: purple;\">何君堯死人頭個網站登入不了，我想去佢議員辦事處投訴呢，請問地址在哪裡？<br />\n<a href=\"http://www.juniusho.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.juniusho.com&d=D9%2BIkncl4BF5lZ8wPV9kyCaGrLhPWbn%2F%2Bskqqi57m1s%3D&h=011ff209\" data-auto-link target=\"_blank\">http://www.juniusho.com</a></span></strong></span>"},"citedBy":0,"replyTime":"2019-07-22T01:58:56.000Z","msg":"<span style=\"color: red;\">去律師公會投訴佢煽動暴動<br />\n香港律師公會<br />\n<a href=\"http://www.hklawsoc.org.hk/pub_c/memberlawlist/member.asp?id=940020\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.hklawsoc.org.hk%2Fpub_c%2Fmemberlawlist%2Fmember.asp%3Fid%3D940020&d=D9%2BIkncl4BF5lZ8wPV9kyCaGrLhPWbn%2F%2Bskqqi57m1s%3D&h=95dab832\" data-auto-link target=\"_blank\">http://www.hklawsoc.org.hk/pub_c/memberlawlist/member.asp?id=940020</a><br />\n英國律師公會<br />\n<a href=\"https://www.lawsociety.org.uk/get-in-touch/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.lawsociety.org.uk%2Fget-in-touch%2F&d=D9%2BIkncl4BF5lZ8wPV9kyCaGrLhPWbn%2F%2Bskqqi57m1s%3D&h=f42f350a\" data-auto-link target=\"_blank\">https://www.lawsociety.org.uk/get-in-touch/</a></span>"}]}