51:57.000Z","msg":"驚自學會學壞發音返唔到轉頭"},{"pid":"d9056af1ed00998e622da394c7b64b5294113e97","tid":1292622,"uid":86756,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-07T17:52:16.000Z","msg":"留名"},{"pid":"f951f4a8f03892b9779caefa5cbb3067d4c4f7ec","tid":1292622,"uid":235080,"like":17,"dislike":1,"score":16,"quote":{"pid":"414cf09aee3369401ac278711f8b0ffdbbeee758","tid":1292622,"uid":6435,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-07-07T17:51:57.000Z","msg":"驚自學會學壞發音返唔到轉頭"},"citedBy":0,"replyTime":"2019-07-07T18:08:24.000Z","msg":"記住幾樣嘢<br />\n<br />\na. 每個音節都要發音<br />\nseparate英文讀做se-pa-rate<br />\n西班牙文讀做se-pa-ra-teh<br />\n(assume有呢隻字 純粹舉例)<br />\n<br />\nb. H 無音<br />\n所以&quot;hola&quot;(你好)讀做oh-la<br />\n好多人會錯讀成hole-la<br />\n<br />\nc. Double L 讀成 Y<br />\n所以&quot;llamar&quot;(to call)讀做ya-mar<br />\n唔係lah-mar或者lah-lah-mar<br />\n<br />\nd. V 讀成 B<br />\n所以&quot;ver&quot;(to see)讀做ber<br />\n&quot;llevar&quot;(to wear)讀做yeh-bar<br />\n<br />\ne. 重音同埋嗰條斜線<br />\n初學你好似英文咁stress<br />\n見到條斜線就stress喺嗰個音節<br />\n基本上8成機會都係啱<br />\n呢個係好深嘅topic 有緣再講"},{"pid":"2114aba2923660b711a5bbc99365048b25bd6b2a","tid":1292622,"uid":275428,"like":0,"dislike":1,"score":-1,"quote":{"pid":"48e8d1d031d7fb0e59ef8feb5774a9c97839e4d8","tid":1292622,"uid":235080,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2019-07-07T17:51:22.000Z","msg":"有咩唔明可以問我 學咗七年 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-07T19:13:59.000Z","msg":"自學定上堂？邊啲入門教材比較啱用？Thanks Ching <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"c4cbf282d82af01ba3201b667b2265d769f252b9","tid":1292622,"uid":198245,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-07T22:05:59.000Z","msg":"Lm"},{"pid":"556c09816ea1ad7b16941ec6327b0341918a61e9","tid":1292622,"uid":235080,"like":0,"dislike":1,"score":-1,"quote":{"pid":"2114aba2923660b711a5bbc99365048b25bd6b2a","tid":1292622,"uid":275428,"like":0,"dislike":1,"s