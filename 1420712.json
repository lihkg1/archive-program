assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n希望可以指證錯處<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-06T06:26:37.000Z","msg":"其實係指完整文字轉述<br />\n而非簡單整合<br />\n因為會有機會字眼會有分別兼帶有個人色彩<br />\nBTW，thanks 巴打"},{"pid":"622828aff55f6f044dcd5f8ee7e07b32c4e56076","tid":1420712,"uid":49028,"like":0,"dislike":0,"score":0,"quote":{"pid":"33e175bc87e98e3f1cb9231a7b214bb016c79cca","tid":1420712,"uid":31773,"like":0,"dislike":0,"score":0,"quote":{"pid":"556c48caf8be2c0cc13f0f3aaf9581357aca2577","tid":1420712,"uid":49028,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a2657d3eb6e9ba20cb2a30877e8297ab763b45c","tid":1420712,"uid":38358,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-06T06:00:40.000Z","msg":"我建議你認真去逐字，文字原版好重要，而且當中有幾段你既轉譯真係令到個意思唔同左"},"citedBy":1,"replyTime":"2019-08-06T06:23:01.000Z","msg":"唔好意思<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n希望可以指證錯處<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-06T06:26:37.000Z","msg":"其實係指完整文字轉述<br />\n而非簡單整合<br />\n因為會有機會字眼會有分別兼帶有個人色彩<br />\nBTW，thanks 巴打"},"citedBy":0,"replyTime":"2019-08-06T07:31:32.000Z","msg":"感謝你<br />\n我應該寫清楚啲<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /><br />\n係文字整合"},{"pid":"cca0b3d98b61e1f4aa979ee339df90a0e552f9f4","tid":1420712,"uid":3149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T07:51:18.000Z","msg":"Push"},{"pid":"6231d19f5dc4a5c18c994886414208676d1d8ff1","tid":1420712,"uid":238301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:02:37.000Z","msg":"幫推"},{"pid":"ae252d50a09e32675a8601d06e1ec877f595be6b","tid":1420712,"uid":118125,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-06T08:06:42.000Z","msg":"辛苦晒記者會既巴打絲打<br />\n注意槍打出頭鳥, 記得你地出黎,就已經被注意監視 , 要繼續行和理非路線<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"23824ece9854f04cf4baefcb12ff4e4b4b6beb9e","tid":1420712,"uid":235535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:07:31.000Z","msg":"推"},{"pid":"52cdda8fa2176755fe8318500cb4885e1c556550","tid":1420712,"uid":235535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:09:45.000Z","msg":"推"},{"pid":"eacd4ece383c410975f43837a131dd9bbab43c7c","tid":1420712,"uid":36592,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:12:48.000Z","msg":"推"},{"pid":"f9dde4089cba79e3c5dfaa62168d11494aef460e","tid":1420712,"uid":260367,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-06T08:22:16.000Z","msg":"好有心機<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 鼓勵<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"e6164fc8b846fd38a7ac32b379a3168e60b77e4c","tid":1420712,"uid":49028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T09:10:16.000Z","msg":"推"},{"pid":"7b366410f9cdbd52609ebb309345db8d1be4cb9b","tid":1420712,"uid":49028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T09:24:54.000Z","msg":"推"}]}