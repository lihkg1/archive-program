ets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b7b6714b2e2b7b2552b2c404d9f5ce92340fc3ed","tid":2146223,"uid":75923,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-08T14:42:24.000Z","msg":"推"},{"pid":"fe89907f551c8d096cc3b2b941008f7424179a88","tid":2146223,"uid":244607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-08T14:46:21.000Z","msg":"法治？"},{"pid":"d213073bd4bcd7ab801a8e2855156d22a7ebf6cf","tid":2146223,"uid":262464,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-08T14:46:55.000Z","msg":"去到醫院可以唔驗血架咩 一驗就知架喎？"},{"pid":"4b14ba6a1512aee57fefe7c260dd240c282c697d","tid":2146223,"uid":126183,"like":2,"dislike":5,"score":-3,"quote":{"pid":"cf3a3fceca224d83e84cea0ff08a7650437c696a","tid":2146223,"uid":60853,"like":102,"dislike":1,"score":101,"citedBy":4,"replyTime":"2020-08-08T12:30:40.000Z","msg":"撞車都無拉不小心駕駛<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-08T14:48:48.000Z","msg":"撞車=犯法？<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><br />\n咁計法屯公 龍翔道每日要拉幾多人？<br />\n兒登<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"fd8debd4a5dfa0c0ff523b4e2dc24942d59f15c9","tid":2146223,"uid":49669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-08T14:50:10.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"56a825511414d30e55b12639b4e1ce85d688fb52","tid":2146223,"uid":15084,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-08T14:51:00.000Z","msg":"去年11月8日凌晨2時許，一輛隸屬東九龍總區交通部警車，沿九龍灣宏照道往啟祥道方向行駛，當左轉入啟祥道時，適時一輛電單車沿啟祥道往觀塘道方向前行，兩車懷疑收掣不及，在啟祥道及宏照道交界的「黃格仔」相撞，姓吳(54歲)鐵騎士飛墮地上。警方經初步調查後，以涉嫌「危險駕駛」及「拒絕提供檢查呼氣測試樣本」，拘捕電單車司機。被捕司機是一名休班警務人員。 <br />\n<br />\n55歲被告吳港衛今(25日)於觀塘裁判法院<span class=\"red\">承認駛不小心駕駛及拒絕提供檢查呼氣測試樣本兩罪，被判罰款6500港元、停牌24個月及需自費完成駕駛改進課程。 </span><br />\n<br />\n被告吳港衛，在控罪書上無報稱職，他現承認於去年11月8日凌晨，駕駛其電單車沿啓祥道東行時，因衝紅燈而與一部警車相撞，導致警車泵把脱落，被告自己亦被拋到地上受傷，他同日拒絕在醫院提供呼氣樣本進行酒精測試，最終被捕。 <br />\n<br />\n25/1/2019<br />\n<br />\n白粉唔貼link<br />\n簡單啲講姐係冇事啦"},{"pid":"096fff695100d9fe972cf46509a08e36ce45758c","tid":2146223,"uid":80455,"like":0,"dislike":0,"score":0,"quote":{"pid":"d213073bd4bcd7ab801a8e2855156d22a7ebf6cf","tid":2146223,"uid":262464,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-08T14:46:55.000Z","msg":"去到醫院可以唔驗血架咩 一驗就知架喎？"},"citedBy":0,"replyTime":"2020-08-08T14:51:33.000Z","msg":"而家話拒絕提供血液樣本<br />\n<br />\n根住過咗咁耐<br />\n證據都無撚咗<br />\n <br />\n擺明放生"},{"pid":"41642069b4c6c89ea29e59eb1db48279a4dfdce8","tid":2146223,"uid":286669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-08T14:52:01.000Z","msg":"曲都可以變返直，好野"},{"pid":"0ccd2cee8957045f235b598b93cf42c4cf8a8aae","tid":2146223,"uid":262464,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-08T14:55:40.000Z","msg":"好野 犯錯唔認的最佳例子"},{"pid":"9c228dce7a81f7cf420f8fbf592968dda7603730","tid":2146223,"uid":267410,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-08T15:03:03.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8177256a7f4b7811252323f2dca58a39a2075754","tid":2146223,"uid":330499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-08T15:07:44.000Z","msg":"首先，佢話自己咩頭暈又話斷片唔記得，又話撞親盤骨受傷。如果佢係咁重傷既話，popo點會唔等救護黎先抬佢出去呀～陣間郁到林楊明先生搞到佢拍唔到popo劇點計先<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n第二，頭暈又會連吹波都吹唔到既，加上呢條友有醉駕前科咁都唔落案危險駕駛既話～我真心祝福我地律政司刑事檢控科同負責調查既Popo唔會受到可惡既美帝制裁呀<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"67bb34a7c742af0206c0fc97dbccfd0f6bb1c368","tid":2146223,"uid":108987,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-08T15:11:22.000Z","msg":"繼續攬 繼續無法無天<img src=\"/assets/faces/lm2/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/photo.gif\" class=\"hkgmoji\" />"},{"pid":"ff1cd04d5479490be966b44a0fa0dc0b87c51e6