s/fifa/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"4eb69a04331d080f7426021cedac5b2dd396a681","tid":724501,"uid":87687,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-07-02T04:22:01.000Z","msg":"旺財 ig <br />\n<br />\ngreyhound_wong_choi<br />\n<br />\n堅持每日有update <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"6567defdd2bec0a4d14a9386101a00cacff32f85","tid":724501,"uid":87687,"like":5,"dislike":0,"score":5,"quote":{"pid":"e1aa7a1571569ed586c84351939fdc85978f5dad","tid":724501,"uid":175896,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-02T03:39:24.000Z","msg":"可唔可以講下點解澳門個間唔俾你地領養?"},"citedBy":0,"replyTime":"2018-07-02T04:32:49.000Z","msg":"佢唔係唔比，而係同我地以為&ldquo;有狗搵人養，有人養就得&rdquo; 既期望落差好大。<br />\n<br />\n佢講左好耐都仲係話未決定，未落實，有消息會通知。都應該係事實，佢既聯絡staff 係helpful既，佢都冇咩好辦法。<br />\n<br />\n後來問下人，原來佢咁多年來只係放左幾隻出來，我地就覺得與其白等不如搵下外國。<br />\n<br />\n我估佢地係上頭有點兒自己都未知自己想點吧。斷估又係&ldquo;冇人理咪側側膊，有理理咪拖上拖&rdquo; 咁既戰術。<br />\n<br />\n佢後來（近排）真係有通知話可以領，不過我地已經領左旺財，再領就超過我地capacity 了。所以咪盡下打力打嘴砲，推動一下咁。"},{"pid":"a4bc3e9b47bc866085ec5a46415b784245f00bea","tid":724501,"uid":87687,"like":3,"dislike":0,"score":3,"quote":{"pid":"bb1a4a461023eace378d48a3902b7487a4347aa1","tid":724501,"uid":174268,"like":2,"dislike":0,"score":2,"quote":{"pid":"ba4c33ccc7b8ce84c7addfa3c85d387db972dfa4","tid":724501,"uid":87687,"like":2,"dislike":0,"score":2,"quote":{"pid":"1d66f5fa63c67ebbe60cba3cb4fecf23e0a7353f","tid":724501,"uid":62755,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-07-02T01:18:52.000Z","msg":"巴打好有心<br />\n呢個時間出呢篇文<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-02T02:22:00.000Z","msg":"呢篇文真係我地嘅心聲，<br />\n同左旺財－齊生活，真係遇到好多我地無諗過嘅困難，<br />\n但係只要見到佢每日食得，玩得，痾得，訓得，就覺得好安慰。<img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-02T04:08:44.000Z","msg":"巴打，想知海外領養手續，同埋外國有無邊間領養機構係可靠巴？謝謝你<img src=\"/assets/faces/fifa/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-02T04:35:42.000Z","msg":"返去搵條link 比你。<br />\n如果唔係有特別喜好，而香港冇，例如grey hound, 其實係香港領唐狗或其他狗係好ok的。最大優勢係可以同佢互動下，睇下佢鐘唔鐘意你先。我覺得呢個緊要"},{"pid":"e78aa59b3a3dbd2ba387000da3286b3e186a5e69","tid":724501,"uid":27088,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-02T04:36:51.000Z","msg":"可唔可以分享用邊間agent ?<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"1771b13c08d9b56be28d18097849a490a415a558","tid":724501,"uid":31386,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-07-02T04:42:43.000Z","msg":"無知一問 點解有人覺得改做旺財係心地唔好？<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"aa16651565f67728db00747eb221baa3a6c27d34","tid":724501,"uid":36432,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-07-02T04:47:48.000Z","msg":"巴打好好人<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"ebae1a6289ba03eaf8457a820941a8b42b3035f4","tid":724501,"uid":191736,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-02T05:09:31.000Z","msg":"幾好睇，支持"},{"pid":"94b1b9ec057f04c7ca13e1c36b25f34a0b83f045","tid":724501,"uid":87687,"like":6,"dislike":0,"score":6,"quote":{"pid":"1771b13c08d9b56be28d18097849a490a415a558","tid":724501,"uid":31386,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-07-02T04:42:43.000Z","msg":"無知一問 點解有人覺得改做旺財係心地唔好？<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-02T05:19:53.000Z","msg":"佢係一位好elgant 講野有少少posh 味的年輕女仕，佢果句說話如果翻譯成正常廣東話的話就會係：<br />\n<br />\n&ldquo;屌你兩條仆街改名改到咁閪都得既？&rdquo;<br />\n<br />\n&ldquo;哎呀你地兩個心地唔好呀，叫佢做旺財。&rdquo;<br />\n<br />\n佢表達㤞異既文句真係典雅。好配服。"},{"pid":"f0c042cc14a14ed4fdb3911d7f87fec6d1bc34dd","tid":724501,"uid":80294,"like":1,"dislike":0,"score":1,"quote":{"pid":"94b1b9ec057f04c7ca13e1c36b25f34a0b83f045","tid":724501,"uid":87687,"like":6,"dislike":0,"score":6,"quote":{"pid":"1771b13c08d9b56be28d18097849a490a415a558","tid":724501,"uid":31386,"like":2,"dislike":0,"score":2,"citedBy