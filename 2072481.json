20T15:42:34.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-20T16:57:52.000Z","msg":"我都會咁<br />\n但多數拖個幾鐘到<img src=\"/assets/faces/cat/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-20T19:12:47.000Z","msg":"經常拖到人哋炸機叫我覆<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3f343abe40339a90b70d67226f74b5d3773c524d","tid":2072481,"uid":137978,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2020-06-20T19:14:34.000Z","msg":"Me<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />覺得自己依家真係好似廢人<br />\n好多人利用之前個段時間增值自己<br />\n而我乜都冇做<br />\n自己都好明白<br />\n就真係差個第一步<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4957386b002eda9a63b0447f0799bf50dc4b239c","tid":2072481,"uid":137978,"like":9,"dislike":0,"score":9,"quote":{"pid":"a6061a6a031bf242b332bd2ba5530e1dbc443f70","tid":2072481,"uid":96032,"like":108,"dislike":0,"score":108,"citedBy":9,"replyTime":"2020-06-20T15:42:34.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-20T19:16:16.000Z","msg":"我都係咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n有時仲覺得人地好撚煩<br />\n明明就好小事<br />\n覺得自己好衰<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2626b15fe192ef1843ac3b2cec763f481f39a399","tid":2072481,"uid":279814,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-20T19:53:25.000Z","msg":"我已經知自己就係咁既人<br />\n本質就係拖<br />\n我唔會再嬲自己拖咁二重傷害自己<br />\n反正都改唔到<br />\n真係好好好想做既<br />\n咁實唔拖<br />\n拖得都係唔係想做既<br />\n個後果完全可承擔"},{"pid":"a02a56fdecc2e350fc8b9ce940256ae79e429a0a","tid":2072481,"uid":243668,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-20T22:47:04.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"2e5f4aa47aa1cc24c027255010ef037c13fcec1d","tid":2072481,"uid":237355,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-06-21T01:12:39.000Z","msg":"你自己唔肯逼自己<br />\n講咩都無用"},{"pid":"855816e5fb7277f6635a2e4e6eb85e5c5efab415","tid":2072481,"uid":107661,"like":0,"dislike":0,"score":0,"quote":{"pid":"12c5f22261436023deeb80a48a69881c658702d5","tid":2072481,"uid":21836,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1b979c4f48c6c9e749cc419d007f4c60b61a0b8","tid":2072481,"uid":107661,"like":0,"dislike":0,"score":0,"quote":{"pid":"0200115cf284743b4b340e49f99a6afba626f83b","tid":2072481,"uid":21836,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-20T15:58:22.000Z","msg":"完全一樣<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-20T15:59:37.000Z","msg":"睇黎好多巴絲都有<br />\n大家一齊改左佢啦 真心拖延症/懶好影響自己<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-20T16:28:51.000Z","msg":"可以全日咩都唔做<img src=\"/assets/faces/big/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-21T02:08:21.000Z","msg":"呢個我都係 可以訓係張床度 但又唔起身<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"89f20e663050bab523fb356e1540b2aa0ef98569","tid":2072481,"uid":207336,"like":0,"dislike":0,"score":0,"quote":{"pid":"c2b150567bf0fb767b18e56b55566ed3c6d87b83","tid":2072481,"uid":107661,"like":1,"dislike":0,"score":1,"quote":{"pid":"b4ac973042ba25c527cefb314161fea703e31af1","tid":2072481,"uid":207336,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2020-06-20T15:44:42.000Z","msg":"我都係，不過通常係好得閒既時侯先會，如果知好多野要交（有deadline）就會有動力去做野<br />\n反而宜家自己想做既野就一直拖 明明有時間就係唔肯行第一步"},"citedBy":1,"replyTime":"2020-06-20T15:51:24.000Z","msg":"有deadline果d 我都會拖 不過的確係好少少 至少最後會做<br />\n就係巴打你講果d自己既野/無deadline 就一直拖 拖到突然比人追要/比人話 先壓力上升咁去做<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-21T02:09:25.000Z","msg":"但當你行出左第一步，接落黎就會好順利<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"32088fd038c040b81e44e1409ca14