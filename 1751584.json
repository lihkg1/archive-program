b3fb728","tid":1751584,"uid":278294,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:18:24.000Z","msg":"推"},{"pid":"3765b6c1d4ea756183e0b23088a47fb3ff740a90","tid":1751584,"uid":290176,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:20:18.000Z","msg":"<strong><span style=\"font-size: xx-large;\">唔好忘記04 年-08年個屆的教訓</span></strong> <img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" />"},{"pid":"213a573cf654d01cff420bb33fe4df7daa33701e","tid":1751584,"uid":291491,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:20:52.000Z","msg":"poly 救人阿<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"32ed4d015cd65919b2926a25af774b4cfcff7e62","tid":1751584,"uid":81236,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:24:37.000Z","msg":"<span style=\"color: red;\">全面打擊種票、蛇齋餅糭/枕等問題<br />\n將所有植根係地區既利益連根拔起，包括但不限於基建、工程、法團、撥款、<span style=\"font-size: xx-large;\">老人院</span>等，唔可以比佢有機會死灰復燃</span>"},{"pid":"6e51f59fc651f916fe2527914914617aaadb52d6","tid":1751584,"uid":81236,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:24:50.000Z","msg":"Push"},{"pid":"1e78c034012b05582c61ce6070767ffa463175b4","tid":1751584,"uid":15010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:25:20.000Z","msg":"推"},{"pid":"e048e761888fa8195820a1806306759aa5066288","tid":1751584,"uid":113163,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:26:05.000Z","msg":"推"},{"pid":"ccd0d072ed515e3c4962e0d40b173b8688ab0a4d","tid":1751584,"uid":81236,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:30:28.000Z","msg":"Push"},{"pid":"173653507c39eb464054e1e688d1f68f5ae84d4f","tid":1751584,"uid":53610,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:37:31.000Z","msg":"生生性性，做多啲地區，派多啲福袋，用啲資金搞好個黃色生態圈<br />\n機會只得一次，下次唔止你哋泛民輸，全香港人都會一齊攬炒<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},{"pid":"8042e15af2ad61404331fd1d07ec825df4df47df","tid":1751584,"uid":16959,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:38:12.000Z","msg":"推"},{"pid":"e999f7f83fca1d1af964cba0d290d3f766eded6b","tid":1751584,"uid":225100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:39:00.000Z","msg":"希望泛民當選人可以考慮下沈教授嘅建議<br />\n唔係嘅話 總有一日會分裂<br />\n//<br />\n全體非建制派參選人，其實應該及早簽署一個簡單約章，一切理念那些虛的東西一概不必，只有一個條款：<span style=\"color: gold;\">當選後，願意每月捐出五千元，共同成立一個基金</span>。基金並非由這些區議員管理，而是委任一些勇武派、本土派相對信任（或起碼接受）的社會賢達，或被剝奪選舉權的代表共同管理，例如本土論述權威孔誥烽教授、練乙崢教授、陳雲博士、被高調DQ的黃之鋒、已經身在獄中的梁天琦等，負責營運這個支援前線的基金，特別註明支援那些因為參加運動而被控告、坐牢、出走的前線朋友。假如非建制派得到200席，這就是每月100萬、一年1200萬、三年3600萬，再找一些同情運動的中產眾籌一個1:1的matching fund，一場選舉，就可以成立多一個7200萬元的基金，也就是另一個「612基金」。這不能解決所有問題，但可以慢慢建構「和勇命運共同體」，這其實是雙方都需要的。<br />\n//<br />\n沈旭暉：大考驗・大戰略：區議會選舉後的分裂與團結<br />\n<a href=\"https://lih.kg/1750945\" data-auto-link target=\"_blank\">https://lih.kg/1750945</a>"},{"pid":"a097b33f7cd98921727d0564bb841fd1081450cb","tid":1751584,"uid":298250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:39:05.000Z","msg":"推"},{"pid":"a592a38055a3ed904767b899df22e8d483fd0eae","tid":1751584,"uid":34343,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:39:16.000Z","msg":"push 721 831 1111"},{"pid":"200bf962c8c9cbcce408530a18be54b2f01c7c3c","tid":1751584,"uid":37722,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:39:26.000Z","msg":"講得好<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"04d69fa1362c6632d17c36c634f18bce74e7ffa7","tid":1751584,"uid":193353,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:41:08.000Z","msg":"咪撚曲解五大訴求，一開始係個五個，到完個日都係個五個。"},{"pid":"35408b78f3496240076716cc56d883a116e882bf","tid":1751584,"uid":7168,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:42:02.000Z","msg":"推"},{"pid":"4e8f147277debd653b93f57868947e20dcb7a9e2","tid":1751584,"uid":4448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:43:33.000Z","msg":"推"},{"pid":"9499b67483709309379f4d4c330220eadd328491","tid":1751584,"uid":40,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:43:34.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"98f5de615a6f8a4d79c358f0e27c3bf33f428cdf","tid":1751584,"uid":70745,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:44:32.000Z","msg":"講得好"},{"pid":"2b1aca998358d0ae21693051fd30a968d371f582","tid":1751584,"uid":61257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:46:41.000Z","msg":"<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},{"pid":"9df671f166859daf968ae6ecaf69d40475933a93","tid":1751584,"uid":199845,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:47:22.000Z","msg":"PUSH"},{"pid":"146d38947656fbe8df077d8c9faa08b4da52c084","tid":1751584,"uid":96556,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:47:37.000Z","msg":"推爆佢"},{"pid":"43a65d599089124798099a1593cffaedfed803e4","tid":1751584,"uid":58345,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:48:44.000Z","msg":"推"},{"pid":"fabfa4df7ed6f845b92ff4a2961bb67f96b32864","tid":1751584,"uid":81236,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-24T18:52:41.000Z","msg":"Push"}]}