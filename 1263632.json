uigocO.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpuigocO.png&h=1c3c27eb&s={SIZE}\" /><br />\n<br />\n此post已完"},{"pid":"749abbea5d26c4cdc8f2298aeba0e819432924e5","tid":1263632,"uid":61348,"like":2,"dislike":7,"score":-5,"quote":{"pid":"ded9554370673117a2b1a68a60b18f1550cfb56a","tid":1263632,"uid":4942,"like":15,"dislike":4,"score":11,"citedBy":2,"replyTime":"2019-06-28T10:49:49.000Z","msg":"<img src=\"https://na.cx/i/puigocO.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpuigocO.png&h=1c3c27eb&s={SIZE}\" /><br />\n<br />\n此post已完"},"citedBy":0,"replyTime":"2019-06-28T10:51:00.000Z","msg":"收皮喇，青政童子軍"},{"pid":"7aeef0a1670f600c30d38c441eeaad6c00996e18","tid":1263632,"uid":389,"like":3,"dislike":0,"score":3,"quote":{"pid":"ded9554370673117a2b1a68a60b18f1550cfb56a","tid":1263632,"uid":4942,"like":15,"dislike":4,"score":11,"citedBy":2,"replyTime":"2019-06-28T10:49:49.000Z","msg":"<img src=\"https://na.cx/i/puigocO.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpuigocO.png&h=1c3c27eb&s={SIZE}\" /><br />\n<br />\n此post已完"},"citedBy":0,"replyTime":"2019-06-28T10:51:29.000Z","msg":"不了要返工<br />\n此post已完"},{"pid":"f8c7ac9c80844458f51f63730cb05c0a1df26dac","tid":1263632,"uid":157994,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-06-28T11:58:39.000Z","msg":"關於「六二六」後續<br />\n<br />\n我們認為抗爭者應遵循不被捕原則行動。不過，昨晚警方態度惡劣，又在無預警情況下使用胡椒噴霧攻擊市民，收到有關消息的楊逸朗（Joe Yeung）心切保護同伴，他本意殿後，並呼籲在場人士率先撤退：「幾多人來就幾多人走！」<br />\n<br />\n可惜並非每位義士都像議員一樣，能夠借法律所賦予的權力以一擋百，何況昨晚連鄺議員也遭警員無視其合法要求、並且遭警員用粗口辱罵；後來在場義士決意留守，蒙受警察抄寫個人資料、甚至秋後算帳的後果。不過無論如何，我們應尊重這些義士的決定，畢竟他們每一位都心繫香港，才會親身出現在現場。<br />\n<br />\n不恥笑，不辱罵，尊重義士決定，採取合理方法保護義士。<br />\n<br />\n我們必須謹記，這場運動我們不僅追求撤回反送中條例，更追求「釋放所有義士及政治犯」、「成立獨立調查委員會、追究警方濫權濫捕」以及修訂「公安條例」。民眾抗爭、集會的權益，我們理應一同爭取，反對政治檢控；且維持聯繫團結一志，力抗內鬨排除抹黑。<br />\n<br />\n本陣線的成立由始至終為的是第一條原則：「我們永遠站在抗爭者的一方。」<br />\n<br />\n_<br />\n<br />\n澄清：本機制並非大台，目標在於引領多方合作，是次活動由群眾自發，政治人物負責協助召集，至現場梁已無用咪對群眾說話。現場沒有大台。<br />\n<br />\n抗爭聯合陣線"},{"pid":"f69fa8967ab487597b2d419f417769e0923b0784","tid":1263632,"uid":48083,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-28T11:59:25.000Z","msg":"今次贊成"},{"pid":"6e6f8da3f90708ba78b020c1672d81926722d9fa","tid":1263632,"uid":174530,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-06-28T12:00:50.000Z","msg":"兄弟爬山，樓主老母！"},{"pid":"04d471114ca14ac4f91e72eaed23c838fecad0a7","tid":1263632,"uid":156254,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-06-28T15:47:11.000Z","msg":"<span style=\"font-size: xx-large;\">比人睇外國勢力入侵就影響在「整場運動既目的」<br />\n<br />\n<span style=\"color: red;\">我地大家資源本身都係自資, 而且唔係外國勢力入侵先發起呢場運動</span><br />\n<br />\n係本身大家都知條「法例有問題」。<br />\n<br />\n宜家咁講, 會令到大家年青人「原來就係受人控制,先做呢件事」...!!!!! <br />\n<br />\n咁揚出去, 「外國會點睇香港人」???</span>"},{"pid":"e45812ee2757bf137c65ae4d8db62214e33b7a7f","tid":1263632,"uid":270158,"like":5,"dislike":4,"score":1,"citedBy":1,"replyTime":"2019-06-28T16:04:47.000Z","msg":"唔好再對宣誓玩嘢而被DQ班人存有任何幻想，佢哋咁做蠢到無朋友，根本唔應該搞政治，係香港人信錯咗佢哋。"},{"pid":"94e6c2c402612e4aa26d747598abcbd028e118df","tid":1263632,"uid":61348,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-28T16:08:08.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1ab34116e538cf68e9b2e76ed325a9101d890b99","tid":1263632,"uid":51546,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-28T16:08:11.000Z","msg":"<blockquote>唔好再對宣誓玩嘢而被DQ班人存有任何幻想，佢哋咁做蠢到無朋友，根本唔應該搞政治，係香港人信錯咗佢哋。</blockquote><br />\n五毛仲用dq玩野就係蠢呢招<br />\n過幾年就話罵中國俾人引渡就係蠢到無朋友，根本唔應該搞政治，係香港人信錯咗佢哋<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5f93b358f7c280ad5b4daf14baf661195a2aca64","tid":1263632,"uid":88663,"like":0,"dislike":0,"score":0,"quote":{"pid":"f8c7ac9c80844458f51f63730cb05c0a1df26dac","tid":1263632,"uid":157994,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-06-28T11:58:39.000Z","msg":"關於「六二六」後續<br />\n<br />\n我們認為抗爭者應遵循不被捕原則行動。不過，昨晚警方態度惡劣，又在無預警情況下使用胡椒噴霧攻擊市民，收到有關消息的楊逸朗（Joe Yeung）心切保護同伴，他本意殿後，並呼籲在場人士率先撤退：「幾多人來就幾多人走！」<br />\n<br />\n可惜並非每位義士都像議員一樣，能夠借法律所賦予的權力以一擋百，何況昨晚連鄺議員也遭警員無視其合法要求、並且遭警員用粗口辱罵；後來在場義士決意留守，蒙受警察抄寫個人資料、甚至秋後算帳的後果。不過無論如何，我們應尊重這些義士的決定，畢竟他們每一位都心繫香港，才會親身出現在現場。<br />\n<br />\n不恥笑，不辱罵，尊重義士決定，採取合理方法保護義士。<br />\n<br />\n我們必須謹記，這場運動我們不僅追求撤回反送中條例，更追求「釋放所有義士及政治犯」、「成立獨立調查委員會、追究警方濫權濫捕」以及修訂「公安條例」。民眾抗爭、集會的權益，我們理應一同爭取，反對政治檢控；且維持聯繫團結一志，力抗內鬨排除抹黑。<br />\n<br />\n本陣線的成立由始至終為的是第一條原則：「我們永遠站在抗爭者的一方。」<br />\n<br />\n_<br />\n<br />\n澄清：本機制並非大台，目標在於引領多方合作，是次活動由群眾自發，政治人物負責協助召集，至現場梁已無用咪對群眾說話。現場沒有大台。<br />\n<br />\n抗爭聯合陣線"},"citedBy":1,"replyTime":"2019-06-28T16:14:27.000Z","msg":"完全唔講有條友揸咪要求其他意思同佢一齊堅守嗰個街口<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"517fccbbd9100d954f3f33d8ca995a6b5d3c4cb3","tid":1263632,"uid":61348,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-29T07:07:23.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"dd6cb8302a209529d0e30489c973dc6b4a07a216","tid":1263632,"uid":157994,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f93b358f7c280ad5b4daf14baf661195a2aca64","tid":1263632,"uid":88663,"like":0,"dislike":0,"score":0,"quote":{"pid":"f8c7ac9c80844458f51f63730cb05c0a1df26dac","tid":1263632,"uid":157994,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-06-28T11:58:39.000Z","msg":"關於「六二六」後續<br />\n<br />\n我們認為抗爭者應遵循不被捕原則行動。不過，昨晚警方態度惡劣，又在無預警情況下使用胡椒噴霧攻擊市民，收到有關消息的楊逸朗（Joe Yeung）心切保護同伴，他本意殿後，並呼籲在場人士率先撤退：「幾多人來就幾多人走！」<br />\n<br />\n可惜並非每位義士都像議員一樣，能夠借法律所賦予的權力以一擋百，何況昨晚連鄺議員也遭警員無視其合法要求、並且遭警員用粗口辱罵；後來在場義士決意留守，蒙受警察抄寫個人資料、甚至秋後算帳的後果。不過無論如何，我們應尊重這些義士的決定，畢竟他們每一位都心繫香港，才會親身出現在現場。<br />\n<br />\n不恥笑，不辱罵，尊重義士決定，採取合理方法保護義士。<br />\n<br />\n我們必須謹記，這場運動我們不僅追求撤回反送中條例，更追求「釋放所有義士及政治犯」、「成立獨立調查委員會、追究警方濫權濫捕」以及修訂「公安條例」。民眾抗爭、集會的權益，我們理應一同爭取，反對政治檢控；且維持聯繫團結一志，力抗內鬨排除抹黑。<br />\n<br />\n本陣線的成立由始至終為的是第一條原則：「我們永遠站在抗爭者的一方。」<br />\n<br />\n_<br />\n<br />\n澄清：本機制並非大台，目標在於引領多方合作，是次活動由群眾自發，政治人物負責協助召集，至現場梁已無用咪對群眾說話。現場沒有大台。<b