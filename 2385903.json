sets/faces/lm2/diu.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"5ee754f58ed5eee9e29ae6e6da3447b5851192e2","tid":2385903,"uid":88134,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2021-01-29T09:17:40.000Z","msg":"其實已經違返咗好多次"},{"pid":"766c45c440bb75253bd989facbf7824b3505b2e0","tid":2385903,"uid":34119,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-29T09:17:46.000Z","msg":"全民BC<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"bea60f74dec10c4ad62214ea9dd91ccc1fc5a818","tid":2385903,"uid":389613,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-29T09:18:54.000Z","msg":"<span class=\"red\"><span class=\"xx-large\">香港人用 BNO 係搬石頭砸中共春袋</span></span><br />\n<br />\n原來用 BNO 離開係 Trump 一早 set 左比中共既計時炸彈！我地更應該繼承 Trump 既精神，用 BNO 逼 Biden 同中共開戰 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /> <span class=\"red\">只要有大批香港人離開，會造成現時已經虛弱既經濟徹底崩潰，而中共強行鎖國則引來百國聯軍。</span><br />\n<br />\n--------<br />\n<br />\n<span class=\"red\">劇本１：支共反制 BNO 會引致戰爭 <img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /></span><br />\n<br />\n[武俠小說] 因為 BNO 香港變成外交博奕戰場！Trump 偷偷地幫香港插左支定海神針迫 Biden 打柒中共！<br />\n<a href=\"https://lih.kg/2377934\" data-auto-link target=\"_blank\">https://lih.kg/2377934</a><br />\n<br />\n<span class=\"red\">劇本２：支共比 BNO 走引致經濟崩潰 <img src=\"/assets/faces/mouse/yea.gif\" class=\"hkgmoji\" /></span><br />\n<br />\n[神話故事] 中共經濟末日狂奔，BNO 就係大衛與歌利亞決戰粒石頭。港人出走成就 Trump 滅共偉業。<br />\n<a href=\"https://lih.kg/2380593\" data-auto-link target=\"_blank\">https://lih.kg/2380593</a><br />\n<br />\n--------<br />\n<br />\n不論你係撐 Trump 既手足、定係支持滅共既手足，今次 BNO Visa 係時候身體力行，用你對腳投票去支持 Trump 呢條滅共戰線 <img src=\"/assets/faces/pig/champagne.gif\" class=\"hkgmoji\" /> <span class=\"red\">多你一個好多，少你一個唔掂！你既決定將會成為世界走向正義定係腐敗既關鍵因素！</span>"},{"pid":"acf5fc2211b3c19ac3a3d18b45f0ecfe