%2Fna.cx%2Fi%2Fij5x8vz.png&h=336277be&s={SIZE}\" />"},{"pid":"15d209ee1ccb4fb9e9664449b1cf8b3518ac47c6","tid":1358392,"uid":122676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T02:49:52.000Z","msg":"此回覆已被刪除"},{"pid":"acc9af8dedb1d5e22c306b083ac9bdfc40b6e63d","tid":1358392,"uid":44181,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-24T02:51:38.000Z","msg":"前線永遠都係我地既英雄！"},{"pid":"8ce160b56210835d038447b3da39023145fb770d","tid":1358392,"uid":276379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T02:52:53.000Z","msg":"推"},{"pid":"3fa4a7f6b9b9d3c12e2ee6e719b81911476cd831","tid":1358392,"uid":229425,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T02:55:48.000Z","msg":"真係好撚型，<br />\n食完煙，開揸番起個盾。<br />\n再列隊上前<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />"},{"pid":"cdb3100722010af711b3735794b578d7faac471a","tid":1358392,"uid":198175,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T03:02:05.000Z","msg":"不動如山, 香港勁揪!<br />\n<br />\n出煙都出到麻目晒冇反應, 唯有狂開槍打人, 都無法驅散人群, 仲要作勢反攻, 我諗D防暴係前線見到一眾義士不動如山, 心底驚到瀨屎, 再有下次D義士加裝加甲, 連槍都冇作用時, 仲點對付? 就靠無敵水炮車?<br />\n&nbsp;<br />\n最勁係散場後仲有義士組隊入咗元朗支援, 無俱黑惡勢力, 真係勁揪!"},{"pid":"35ffd522e9903fa72d742dcf1166da120858b652","tid":1358392,"uid":246803,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T03:04:12.000Z","msg":"屌 好撚感動"},{"pid":"55b4a38147874e7cdfe78d70a5b199d55bb70da0","tid":1358392,"uid":1935,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T03:04:53.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"c7d496be60a5d47bd9e80e1cb5de566994ae6843","tid":1358392,"uid":267307,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T03:07:58.000Z","msg":"英雄 <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"04d143b790a64475b27bed82ade8b4b3b5107097","tid":1358392,"uid":272545,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-07-24T03:12:13.000Z","msg":"有前線及勇武派係我地既幸福"},{"pid":"27964010ef0710a3bcc8ddc5feed3fe18fb9c6f5","tid":1358392,"uid":47509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T03:13:52.000Z","msg":"好勇敢<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"a597a2d0fe0f7f65a97aa82eed93e509ae16d3ea","tid":1358392,"uid":36592,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:24:52.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b66f1b05326c1cdd9a2c182dea4b53d73ef8c4bf","tid":1358392,"uid":18245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:31:21.000Z","msg":"<div style=\"text-align: center;\"><code>（瞄準政權）上環黑警36槍企圖殺害抗爭者 中共策劃元朗恐襲</code></div><br />\n<br />\n<br />\n<div style=\"text-align: center;\">所有嘢都係中共係背後策劃<br />\n如果呢個政權係仆街係十惡不赦<br />\n咁擁護佢嘅黑警 黑社會都一樣咁仆街<br />\n咁十惡不赦 但唔好浪費咁多時間係呢<br />\n班卒仔到 <br />\n主力打大佬 瞄準返中共 唔好out focus唔係就真係對唔住咁多位被呢個政權殺害嘅戰友</div><br />\n<br />\n<span style=\"font-size: xx-large;\"><div style=\"text-align: center;\">義士宣言：不排除成立臨時立法會</div></span><br />\n<span style=\"font-size: small;\"><a href=\"https://lih.kg/1350879\" data-auto-link target=\"_blank\">https://lih.kg/1350879</a><br />\n- 分享自 LIHKG 討論區</span><br />\n<br />\n<span style=\"font-size: xx-large;\"><div style=\"text-align: center;\">[長文] 時代周刊直指港府失去管治香港能力嘅分析</div></span><br />\n<span style=\"font-size: small;\"><a href=\"https://lih.kg/1356861\" data-auto-link target=\"_blank\">https://lih.kg/1356861</a><br />\n- 分享自 LIHKG 討論區</span><br />\n<br />\n<br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\"><strong>支持前線所有決定</strong></span></div><br />\n<br />\n民情，輿論，選票，呢啲唔洗我哋去諗，點去收拾所謂嘅殘局，就交比啲政治人物去煩啦<br />\n<br />\n<br />\n<div style=\"text-align: center;\"><strong><span style=\"font-size: xx-large;\">我哋要做嘅係我哋認為啱嘅事</span></strong></div><br />\n<br />\n<img src=\"https://na.cx/i/4LYjFvR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4LYjFvR.jpg&h=d444c005&s={SIZE}\" /><br />\n<br />\n<code>「人民不應該害怕他們的政府，政府應該害怕它的人民。」（People should not be afraid of their governments. Governments should be afraid of their people.）</code><br />\n<div style=\"text-align: center;\"><br />\n<pre><code data-type=\"\">五大訴求，勿忘初衷\n遍地開花，不撤不散\n打倒軍權，反對國家恐怖主義\n光復香港，時代革命</code></pre><br />\n<pre><code data-type=\"\">&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash; 八大訴求 &mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;\n一、徹底撤回修例\n二、收回暴動定義\n三、撤銷對今為所有反送中抗爭者控罪\n四、徹底追究警隊濫權情況\n五、以行政命令解散立法會，立即實行雙真普選\n六、要求永不落實「社會信用評分系統」\n七、要求移除全港「多功能智慧燈柱」\n八、追究元朗鄉黑暴徒及警察失蹤</code></pre></div><br />\n<br />\n定性721黑警上環血腥鎮壓，元朗黑社會恐怖襲擊，警黑合作散播中國國家恐怖主義:<br />\n<div style=\"text-align: center;\"><br />\n<strong><span style=\"font-size: xx-large;\">警察戰線:</span></strong></div><br />\n<img src=\"https://na.cx/i/7gq6kYx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7gq6kYx.jpg&h=1f5648e1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/hY7P3bT.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhY7P3bT.jpg&h=5c1777d4&s={SIZE}\" /><br />\n警察冇預警下開槍射36發橡膠彈，有人爆頭，警察已無視通例，已失去合法性<br />\n警察放任黑社會打市民，完全冇制止，並假指無發現武器收隊，傳媒發現雙方實有公開溝通<br />\n警察公然無視電話求助，元朗警署落閘，違反警隊職責<br />\n<div style=\"text-align: center;\"><br />\n<span style=\"font-size: xx-large;\">黑社會戰線:</span></div><br />\n<img src=\"https://na.cx/i/d7DWJcw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fd7DWJcw.jpg&h=92c6a934&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/idEKR5S.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FidEKR5S.jpg&h=e6380dff&s={SIZE}\" /><br />\n拉攏任何政治冷感市民，有錢人，元朗問題非個別事件，收錢恐襲任何區都會發生，任何人都有機會中招<br />\n俾藍絲睇到佢地支持何君堯即係支持黑社會打人斬人，令藍絲同何君堯反面<br />\n<br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\">國際戰線:</span></div><br />\n<br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\">攬炒巴團隊</span></div><br />\n<img src=\"https://media.giphy.com/media/RhkvtuUcntXSuoVzay/giphy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2FRhkvtuUcntXSuoVzay%2Fgiphy.gif&h=254e8117&s={SIZE}\" /><br />\nLink:<br />\nFacebook:<br />\n<a href=\"https://www.facebook.com/standwithhk/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fstandwithhk%2F&d=gHNHb7VIn83nczLIzOZu1fRe10cHvJvhFGsNMWslaGA%3D&h=d52b7c1f\" target=\"_blank\">https://www.facebook.com/standwithhk/</a><br />\n<br />\nTwitter:<br />\n<a href=\"https://twitter.com/Stand_with_HK\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2FStand_with_HK&d=gHNHb7VIn83nczLIzOZu1fRe10cHvJvhFGsNMWslaGA%3D&h=4562f8a0\" target=\"_blank\">https://twitter.com/Stand_with_HK</a><br />\n<br />\nInstagram:<br />\n<a href=\"https://www.instagram.com/standwithhk_/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fstandwithhk_%2F&d=gHNHb7VIn83nczLIzOZu1fRe10cHvJvhFGsNMWslaGA%3D&h=6657ce89\" target=\"_blank\">https://www.instagram.com/standwithhk_/</a><br />\n<br />\nYouTube:<br />\n<a href=\"https://www.youtube.com/channel/UCyi42Y5o1ksO_yFItyHW7Jw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fchannel%2FUCyi42Y5o1ksO_yFItyHW7Jw&d=gHNHb7VIn83nczLIzOZu1fRe10cHvJvhFGsNMWslaGA%3D&h=b3e1f226\" target=\"_blank\">https://www.youtube.com/channel/UCyi42Y5o1ksO_yFItyHW7Jw</a>[/quote]<br />\n<br />\n<blockquote><br />\n[我都要攬炒][時事台]一齊上twitter將黑警濫權揚威國際，警告遊客不要來港旅遊！！！<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1325723\" data-auto-link target=\"_blank\">https://lih.kg/1325723</a><br />\n</blockquote><br />\n<br />\n向外國抗議中國政府散播國家恐怖主義<br />\n向外媒及各國投訴香港警察包庇黑社會合作各自無差別打人，違反通例無預警開槍，已失去合法性<br />\n港鐵作為國際地鐵聯盟之一公然妄顧市民安危強逼市民離開車廂被打<br />\n黑社會涉嫌在元朗發動恐襲襲擊，主腦直指中共政府<br />\n<br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\">自發治安戰線:</span></div><br />\n<img src=\"https://na.cx/i/sf52DMn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fsf52DMn.jpg&h=ecc7650f&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/OejSgx3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOejSgx3.jpg&h=01748b84&s={SIZE}\" /><br />\n<br />\n<blockquote><img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<blockquote><strong><span style=\"font-size: large;\">香港防衛隊  正式成立<br />\n<a href=\"https://lih.kg/1342844\" data-auto-link target=\"_blank\">https://lih.kg/1342844</a><br />\n<br />\n【HKSDF】香港自衛隊<br />\n<a href=\"https://lih.kg/1352390\" data-auto-link target=\"_blank\">https://lih.kg/1352390</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n[請長期置頂] 民間保衛隊初形 公民團結行公義 任何抗命運動適用<br />\n<a href=\"https://lih.kg/1351343\" data-auto-link target=\"_blank\">https://lih.kg/1351343</a><br />\n<br />\n<br />\n【元朗恐襲】真心，如果眾籌，成立「香港自衛隊保安公司」優先過登報<br />\n<a href=\"https://lih.kg/1346745\" data-auto-link target=\"_blank\">https://lih.kg/1346745</a><br />\n</span></strong></blockquote><br />\n<br />\n<div style=\"text-align: center;\"><br />\n<span style=\"font-size: xx-large;\">思想革命戰線:</span></div><br />\n<br />\n平民遊戲工作室出條政治片十分值得思考<br />\n<a href=\"https://lih.kg/1357566\" data-auto-link target=\"_blank\">https://lih.kg/1357566</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n劉細良 香港內戰<br />\n<a href=\"https://youtu.be/QbJTdHbdGIU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FQbJTdHbdGIU&d=gHNHb7VIn83nczLIzOZu1fRe10cHvJvhFGsNMWslaGA%3D&h=17f6d5a7\" data-auto-link target=\"_blank\">https://youtu.be/QbJTdHbdGIU</a><br />\n<br />\n梁天琦 本土自治勇武抗爭嘅理由<br />\n<a href=\"https://youtu.be/36olyar0wHE\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F36olyar0wHE&d=gHNHb7VIn83nczLIzOZu1fRe10cHvJvhFGsNMWslaGA%3D&h=f3cbb231\" data-auto-link target=\"_blank\">https://youtu.be/36olyar0wHE</a><br />\n<br />\n梁天琦 革命<br />\n<a href=\"https://youtu.be/VEUhAVki0DA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FVEUhAVki0DA&d=gHNHb7VIn83nczLIzOZu1fRe10cHvJvhFGsNMWslaGA%3D&h=19c8c975\" data-auto-link target=\"_blank\">https://youtu.be/VEUhAVki0DA</a><br />\n<br />\n<br />\n<div style=\"text-align: center;\"><br />\n<span style=\"font-size: xx-large;\">港鐵戰線:</span></div><br />\n<img src=\"https://na.cx/i/F4hpgc9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FF4hpgc9.jpg&h=372e2d1d&s={SIZE}\" /><br />\n<br />\n全面係所有車站招貼: 元朗站逼市民落車被打，妄顧安危<br />\n一定要令每個站每個角落都見到<br />\n全面不合作運動，再加宣傳市民全面罷坐港鐵<br />\n<blockquote><br />\n<blockquote><br />\n<strong>[置頂] 724 725 三罷交癱</strong><br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1353127\" data-auto-link target=\"_blank\">https://lih.kg/1353127</a><br />\n</blockquote><br />\n<br />\n<br />\n大group:<br />\n<a href=\"http://t.me/mtr723\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ft.me%2Fmtr723&d=gHNHb7VIn83nczLIzOZu1fRe10cHvJvhFGsNMWslaGA%3D&h=fa5b8864\" target=\"_blank\">http://t.me/mtr723</a><br />\n<br />\n荃灣綫<br />\n<a href=\"https://t.me/joinchat/H9HhP1HDsPqChixQv4i2Yw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fjoinchat%2FH9HhP1HDsPqChixQv4i2Yw&d=gHNHb7VIn83nczLIzOZu1fRe10cHvJvhFGsNMWslaGA%3D&h=f2b815a8\" target=\"_blank\">https://t.me/joinchat/H9HhP1HDsPqChixQv4i2Yw</a><br />\n<br />\n觀塘綫<br />\n<a href=\"https://t.me/joinchat/H9HhP1AfZbR7xvsS0C6h4A\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fjoinchat%2FH9HhP1AfZbR7xvsS0C6h4A&d=gHNHb7VIn83nczLIzOZu1fRe10cHvJvhFGsNMWslaGA%3D&h=98875d0c\" target=\"_blank\">https://t.me/joinchat/H9HhP1AfZbR7xvsS0C6h4A</a><