assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"5ac38c3a81a7ecc369df4b1ad24480821e51f102","tid":2180521,"uid":343643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-30T03:16:06.000Z","msg":"導彈內循環<img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6ca005a14707335adf6d81232181f117854534a7","tid":2180521,"uid":123848,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-30T03:17:14.000Z","msg":"敵傷0 自傷50 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6c9be49a2f214a58e8815cfccc8020a20d955ba6","tid":2180521,"uid":52855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-30T03:20:13.000Z","msg":"唔好話美國，日本都ko佢"},{"pid":"f8c348ca83b27373a9146475dfc0069142bf6a3e","tid":2180521,"uid":360688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-30T03:23:15.000Z","msg":"懷疑如果真係爆第三次世界大戰，蛆蟈係自己打死自己<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"f83afdfda8887ea36b24d4caa314deb10930f19d","tid":2180521,"uid":120955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-30T03:25:33.000Z","msg":"下落不明果支一定係鑽緊地心直通美國"},{"pid":"a5161d9e00a1fc6431a5702825602083fa60adb6","tid":2180521,"uid":61766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-30T03:29:05.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"a61741119044872108ee1cfa3983eb5cbbe01c40","tid":2180521,"uid":61766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-30T03:29:33.000Z","msg":"支那又贏，不停內射真係中國獨有"}]}