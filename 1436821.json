ts/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"52508b2b47084d756b27aefaaa41dafc7031e44c","tid":1436821,"uid":101606,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:43:21.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e22098ed11adda591187f6cca708c8e5a004e7f5","tid":1436821,"uid":203535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T15:49:00.000Z","msg":"真雙普選，還政於民<br />\n獨立調查，反黑反暴<br />\n釋放義士，還我公義<br />\n沒有暴動，只有暴政<br />\n送中惡法，不撤不散<br />\n<br />\n有冇得諗？<br />\n<br />\n【拋磚】一齊嗌五大訴求口號？<br />\n<a href=\"https://lih.kg/1433908\" data-auto-link target=\"_blank\">https://lih.kg/1433908</a><br />\n- 分享自 LIHKG 討論區"}]}