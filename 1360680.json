/wet.gif\" class=\"hkgmoji\" />"},{"pid":"8521d71f560408e40b5dc1460bcddfed1d59a9f4","tid":1360680,"uid":51618,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T14:15:58.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"b429543ae5cc060e5af93e88fb3726d66a87b208","tid":1360680,"uid":54678,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T14:16:00.000Z","msg":"香港人根本唔燒到自己度唔知痛<br />\n唔係721無差別攻擊 啲人都唔覺黑警有問題<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"61b7eea9a9a65332cb8a949587b0ddf714ca89a5","tid":1360680,"uid":236183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T14:16:03.000Z","msg":"中啊"},{"pid":"a137bca360df447acd7c8a2445fd872403be6de2","tid":1360680,"uid":51618,"like":0,"dislike":0,"score":0,"quote":{"pid":"dbc73078b1c51c4d520d7dd7aed915f1bacf14f4","tid":1360680,"uid":109892,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-24T11:51:21.000Z","msg":"啱啱睇到有個熱門post講點解香港人唔響應罷工<br />\n無錯我哋可以繼續屌佢哋係港豬<br />\n但對成件事無幫忙<br />\n佢哋唔罷工 係因為今次社運仲未燒到佢哋<br />\n<span style=\"color: red;\">元朗無差別恐襲？我住九龍<br />\n警察無出旗射36槍？ 我都唔係示威者</span><br />\n<br />\n呢場革命要成功 就一定要<span style=\"font-size: large;\"><span style=\"color: gold;\"><strong>逆向思考</strong></span></span><br />\n對於港豬 咩先係最為緊要？<br />\n<br />\n<ins><strong>1. 樓</strong></ins><br />\n元朗恐襲之後已經有新聞話準買家轉軚 賣家減價<br />\n只要呢場運動令到更多地區樓價下瀉<br />\n你估隻豬會緊張嗰層仲有20要供既樓<br />\n定驚罷工無咗份工？<br />\n罷一日工 未必會比人炒<br />\n但元朗搞一晚 層樓已經可以跌20萬<br />\n當愈嚟愈多人層樓揸唔實/眨值<br />\n自然想件事愈快解決<br />\n自然叫得醒扮訓既人<br />\n<br />\n<strong><ins>2. 返工</ins></strong><br />\n香港人有幾熱愛返工大家都知<br />\n雖然今朝既不合作活動會有人支持諒解<br />\n但肯定有部分怪我哋阻住佢返工<br />\n如果香港動盪既程度去到失控程度<br />\n外資中資開有念頭撤資/真係結業<br />\n咁會點？<br />\n哇 即刻驚無收入養家供樓去旅行啦<br />\n仲唔係失業之前上街表示不滿？<br />\n你會揀罷工定工都無埋？<br />\n<br />\n<br />\n有時候 人係要迫先會做嘢<br />\n每次行動 我哋都損軍折將<br />\n參加者唔可以只減不加<br />\n我哋要<span style=\"font-size: large;\"><strong><span style=\"color: red;\">吸納更多人加入</span></strong></span><br />\n所以勇武係必須<br />\n唔好再諗住和理非非<br />\n香港人依家非生即死<br />\n只要將社運變成真革命 做到全民勇武<br />\n我哋成功既機率就更高<br />\n<br />\n<br />\n如果我哋唔可以令政府回應五大訴求<br />\n我哋就應該將茅頭指向林鄭團隊<br />\n只要推翻到整個團隊<br />\n我哋先令中共知道 香港係由香港人話事<br />\n你推多件垃圾出嚟<br />\n香港人就掉佢老母落堆填區<br />\n你會話要推翻既 係中共？<br />\n都係嗰句 我哋要<span style=\"font-size: large;\"><strong><span style=\"color: red;\">面對現實</span></strong></span><br />\n美國英國歐盟都未可以推翻中共<br />\n難道我哋做得到？<br />\n咩解放軍 咩美軍來了我帶路 咩各國制裁<br />\n太虛無飄渺 太遙遠<br />\n香港人搞返好香港先係首要任務<br />\n所以我哋有個明確目標 - <span style=\"font-size: large;\"><strong><span style=\"color: gold;\">普選</span></strong></span><br />\n唔單止要推翻林鄭團隊 仲要一人一票<br />\n有咗普選 你覺得仲有人摟住啲犬？<br />\n到時想點查就回查 要拉既就拉 要放既就放<br />\n只要有普選 無論係五大定七大訴求都有計傾<br />\n<br />\n最後重點<br />\n<strong><span style=\"font-size: large;\"><span style=\"color: red;\">拖更多人落水 浸濕佢地個頭 睇下仲點做港豬</span></span></strong><br />\n<span style=\"font-size: large;\"><strong><span style=\"color: gold;\">勇武係唯一出路 將今次社運真正變成革命</span></strong></span><br />\n談判條件就係真普選<br />\n如果連林鄭團隊都推唔到落台<br />\n講咩光復香港？"},"citedBy":0,"replyTime":"2019-07-24T14:16:15.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"05b3806c635f88ec6ef37b15acf715294e64b532","tid":1360680,"uid":109892,"like":0,"dislike":0,"score":0,"quote":{"pid":"3f15ac086911a4be6c3663fa58a26df6e5b51914","tid":1360680,"uid":77484,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T13:53:28.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-07-24T14:16:18.000Z","msg":"地產零售旅遊齊齊炒<br />\n睇下扮訓既人仲可以扮到幾時<br />\n放長雙眼<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"45a318e6f2faa58f85a218c60d32ce56ab827278","tid":1360680,"uid":197538,"like":0,"dislike":0,"score":0,"quote":{"pid":"3701e8b2ba1ff5d2c4fda1f6857d95938b0f0ddb","tid":1360680,"uid":109892,"like":0,"dislike":0,"score":0,"quote":{"pid":"fbbe48479c86236b7524fdf2e7414e88dacd2463","tid":1360680,"uid":109892,"like":0,"dislike":0,"score":0,"quote":{"pid":"8684c05eb38200f0a4321c935bc698c5f89b0fbd","tid":1360680,"uid":197538,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-24T13:58:47.000Z","msg":"每個人都會有自己諗法，你第一句已經話唔支持你嘅人係港豬！你覺得人地仲會聽入耳？只會覺得你說話好難聽好討厭！<br />\n<br />\n年輕人，唔好咁主觀！試下係其他人角度出發，（正如藍絲第一句叫你暴徒，你已經唔撚想理佢第2句）幻想下你係中立人士/藍絲，人地點勸你先會聽？"},"citedBy":1,"replyTime":"2019-07-24T14:06:31.000Z","msg":"我好似係話出面有人屌唔罷工既人係港豬<br />\n你係咪get錯咗呀Uncle/Auntie?<br />\n<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-24T14:08:54.000Z","msg":"點都好啦<br />\n你嗰句「年輕人」都好搞笑下<br />\n理性討論又要講到年齡？<br />\n又係食鹽多過我食米嗰啲長輩論？<br />\n不如「長輩」你又諗下點樣同年輕人溝通啦"},"citedBy":1,"replyTime":"2019-07-24T14:18:05.000Z","msg":"不是的！我是好欣賞你地！只不過作為做左10多年律師，俾少少意見而已！<br />\n<br />\n當然你可以當我廢老九up!"},{"pid":"d50150fa1565429e3bbe5e6ac8c55b6faf746db3","tid":1360680,"uid":109892,"like":1,"dislike":0,"score":1,"quote":{"pid":"b429543ae5cc060e5af93e88fb3726d66a87b208","tid":1360680,"uid":54678,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T14:16:00.000Z","msg":"香港人根本唔燒到自己度唔知痛<br />\n唔係721無差別攻擊 啲人都唔覺黑警有問題<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-24T14:20:43.000Z","msg":"問心啦<br />\n香港人有時係好自私<br />\n睇過個post話元朗嗰晚班白衫軍未衝上月台<br />\n有人同車廂入面既人講出面打人<br />\n竟然有人會話：打咪打，唔好搞到我就得！<br />\n點知......<br />\n<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><br />\n人人捱打 永不落空"},{"pid":"b6df1e2145f9035c8509b3c96ecb69744b9d4cf2","tid":1360680,"uid":278786,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T14:25:38.000Z","msg":"還未講到核心原因。香港人好醒，就算真是全港大罷工一日又掂？林鄭都是當無到。罷工同絕食類似，皆自殘自傷的招式，對文明政府會有D用，對林鄭唔會。<br />\n<br />\n一日罷工變成長期大罷工就有用，但機會更渺茫。"},{"pid":"d8fdcf5b3a0a4aa41161297b8bbfb1e6217c697a","tid":1360680,"uid":7570,"like":0,"dislike":0,"score":0,"quote":{"pid":"a9a8742fa0a328ca4385d66b35df8e225b3c10b6","tid":1360680,"uid":57835,"like":0,"dislike":0,"score":0,"quote":{"pid":"6fe7b7336a32b2e6f15ff49675cb5eb38863ffa4","tid":1360680,"uid":7570,"like":7,"dislike":0,"score":7,"citedBy":2,"replyTime":"2019-07-24T12:07:33.000Z","msg":"好悲觀咁講<br />\n等到開始燒到有焦味啦<br />\n果班奴工先會醒架<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-24T13:26:36.000Z","msg":"佢地醒咪就係終於有人阻佢返工囉<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n我覺得呢一步真係未必行得岩"},"citedBy":1,"replyTime":"2019-07-24T14:26:59.000Z","msg":"佢地醒果日 係佢係條街比黑社會打 報警 冇人理<br />\n咁佢就知驚啦<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><br />\n<br />\n我認為<br />\n我地唔需要好執著得到全部人既認同/諒解<br />\n但係一路keep住遊說未明白到成件事既市民<br />\n潛移默化咁令到佢地會體諒我地做既野<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"63b6ef21700ca998941928fa11985abcbe94bd35","tid":1360680,"uid":109892,"like":2,"dislike":0,"score":2,"quote":{"pid":"45a318e6f2faa58f85a218c60d32ce56ab827278","tid":1360680,"uid":197538,"like":0,"dislike":0,"score":0,"quote":{"pid":"3701e8b2ba1ff5d2c4fda1f6857d95938b0f0ddb","tid":1360680,"uid":109892,"like":0,"dislike":0,"score":0,"quote":{"pid":"fbbe48479c86236b7524fdf2e7414e88dacd2463","tid":1360680,"uid":109892,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T14:06:31.000Z","msg":"我好似係話出面有人屌唔罷工既人係港豬<br />\n你係咪get錯咗呀Uncle/Auntie?<br />\n<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-24T14:08:54.000Z","msg":"點都好啦<br />\n你嗰句「年輕人」都好搞笑下<br />\n理性討論又要講到年齡？<br />\n又係食鹽多過我食米嗰啲長輩論？<br />\n不如「長輩」你又諗下點樣同年輕人溝通啦"},"citedBy":1,"replyTime":"2019-07-24T14:18:05.000Z","msg":"不是的！我是好欣賞你地！只不過作為做左10多年律師，俾少少意見而已！<br />\n<br />\n當然你可以當我廢老九up!"},"citedBy":1,"replyTime":"2019-07-24T14:27:47.000Z","msg":"又或者咁講啦<br />\n我哋後生一輩 唔係想偏激鬧人<br />\n而係眼見身邊有太多叫唔醒 係到扮訓既人<br />\n當有人上街抗爭中槍捱催淚彈既時候<br />\n有人可以去深圳飲喜茶唱k<br />\n唔係話佢哋無自由選擇享受生活<br />\n只係我哋好傷心憤怒<br />\n點解有人對香港既慘況視若無睹<br />\n有如一隻豬<br />\n只著眼糧食溫飽<br />\n只著眼嗰間細到可憐既屋<br />\n而係豬欄以外既事情一概不理<br />\n叫佢哋一聲「港豬」係不齒佢哋既行為<br />\n叫佢哋一聲「港豬」係想宣洩憤怒既情緒<br />\n互相交流先有進步<br />\n無關年齡<br />\n無關背景"}]}