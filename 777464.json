 class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"78c4ad1c2a48f1444c9d0f634e40b66f2997644a","tid":777464,"uid":184233,"like":3,"dislike":0,"score":3,"quote":{"pid":"11a7fa6926973dde29b1cf33a87bcea6e0b96ca5","tid":777464,"uid":116364,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa7b813a7d2e6fbacffdf750db4f5c0222398529","tid":777464,"uid":184233,"like":1,"dislike":2,"score":-1,"quote":{"pid":"f3ee3315aea8e72376972e5a56794e49d4112822","tid":777464,"uid":116364,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-13T03:51:02.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-08-13T04:02:46.000Z","msg":"你驚人地笑你乜先？ <br />\n真係無乜野好驚"},"citedBy":1,"replyTime":"2018-08-13T04:16:49.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2018-08-13T04:49:20.000Z","msg":"得罪講句<br />\n做得叻都淆個班人就真係死得<br />\n<br />\n唔叻都唔緊要咖<br />\n大把人差過你<br />\n就算真係比人笑又有乜所謂<br />\n笑下又唔洗死<br />\n試下做咗先<br />\n&quot;因為害怕失敗，而連嘗試也沒有經歷過的人，是最可悲。&quot;<br />\n唔好收收埋埋<br />\n其實柒咗都唔會有好多人知 <br />\n當你成日意為好多人會望住你個陣，其實只係你諗多咗，現實中其實無咁多人關心你係點，柒咗定點，都無乜人有興趣。<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 所以最緊要係你自己想做就做，淆底而唔做嘅話，蝕底個個倒頭來都係你自己。"},{"pid":"0744e9f81c6503e32d6b6d28670213f8b51ab441","tid":777464,"uid":184233,"like":1,"dislike":0,"score":1,"quote":{"pid":"687cc85bde69a99e0de8b4e8242e033c952a6608","tid":777464,"uid":23229,"like":0,"dislike":0,"score":0,"quote":{"pid":"f16d0e45dfebd6823c1aa4bbd50cab65c3b1df65","tid":777464,"uid":116364,"like":3,"dislike":0,"score":3,"quote":{"pid":"356bde5b9c9f71b0bf67778fd93825d773805720","tid":777464,"uid":184233,"like":1,"dislike":4,"score":-3,"citedBy":1,"replyTime":"2018-08-13T03:43:53.000Z","msg":"學語言，又唔敢出聲 ... 心諗你學語言唔出聲學乜鳩<br />\n唔肯定都讀咗出嚟先啦老友，你唔讀出嚟點知啱定錯<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> 你讀出嚟，就算錯啊，咁身邊嘅人都可以指正返。<br />\n<br />\n<br />\n又比如<br />\n出街買野見到無痴價錢牌 問都唔夠膽問 係咁同隔離個個講 &quot;你幫我問啦～你去問啦～&quot; <br />\n買衫有無碼個d 又係咁 <br />\n心諗你問個價，問個碼都淆 <img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> <br />\n<br />\n返學返工叫組員/同事 做野 都唔敢，最後自己硬食晒 ... 呢D最睇唔過眼，次次聽到有D朋友係咁，我就會大大力屌，拎出你嘅勇氣出嚟，堂堂大男人，叫人幫手做D野都淆。有時真係抵你成份報告自己做晒人地就走去玩。<br />\n<br />\n仲有好多呢D 正常社交野都淆 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-08-13T03:48:09.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-08-13T04:30:42.000Z","msg":"問野我都還好 唔會驚問價問碼個啲生活野<br />\n但講到職場或者做正經野就好驚人<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-13T04:51:32.000Z","msg":"人地又唔會食咗你嘅<br />\n正正常常你有禮貌嘅，職場/正經野，問人又好，拜託人地做野又好，指揮下屬做野又好，都無需要驚。"},{"pid":"3880bd7a8ec3c38574c10c25251a9f61e7d89a56","tid":777464,"uid":23229,"like":0,"dislike":0,"score":0,"quote":{"pid":"78c4ad1c2a48f1444c9d0f634e40b66f2997644a","tid":777464,"uid":184233,"like":3,"dislike":0,"score":3,"quote":{"pid":"11a7fa6926973dde29b1cf33a87bcea6e0b96ca5","tid":777464,"uid":116364,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa7b813a7d2e6fbacffdf750db4f5c0222398529","tid":777464,"uid":184233,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2018-08-13T04:02:46.000Z","msg":"你驚人地笑你乜先？ <br />\n真係無乜野好驚"},"citedBy":1,"replyTime":"2018-08-13T04:16:49.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2018-08-13T04:49:20.000Z","msg":"得罪講句<br />\n做得叻都淆個班人就真係死得<br />\n<br />\n唔叻都唔緊要咖<br />\n大把人差過你<br />\n就算真係比人笑又有乜所謂<br />\n笑下又唔洗死<br />\n試下做咗先<br />\n&quot;因為害怕失敗，而連嘗試也沒有經歷過的人，是最可悲。&quot;<br />\n唔好收收埋埋<br />\n其實柒咗都唔會有好多人知 <br />\n當你成日意為好多人會望住你個陣，其實只係你諗多咗，現實中其實無咁多人關心你係點，柒咗定點，都無乜人有興趣。<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 所以最緊要係你自己想做就做，淆底而唔做嘅話，蝕底個個倒頭來都係你自己。"},"citedBy":0,"replyTime":"2018-08-13T06:15:44.000Z","msg":"但到頭來真係唔係個個都有勇氣去跨越自己個份心理障礙<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"d27ca5b8c9fc081e715cf228dc8947019783b4