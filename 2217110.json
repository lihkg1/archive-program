a1a40aa7e1d5c8f9a74adbfba10318bb","tid":2217110,"uid":28654,"like":1,"dislike":0,"score":1,"quote":{"pid":"fc022f0bf24408666d594e51350c0a687864e430","tid":2217110,"uid":39464,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-25T07:59:37.000Z","msg":"<img src=\"https://www.hkcnews.com/news_%E6%96%B0%E8%81%9E/hk-discuss/2020/09/%E4%B8%AD%E7%BE%8E%E8%A1%9D%E7%AA%81-%E8%93%AC%E4%BD%A9%E5%A5%A7-%E6%A2%B5%E8%92%82%E5%B2%A1-20200925120006_217f_large.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.hkcnews.com%2Fnews_%25E6%2596%25B0%25E8%2581%259E%2Fhk-discuss%2F2020%2F09%2F%25E4%25B8%25AD%25E7%25BE%258E%25E8%25A1%259D%25E7%25AA%2581-%25E8%2593%25AC%25E4%25BD%25A9%25E5%25A5%25A7-%25E6%25A2%25B5%25E8%2592%2582%25E5%25B2%25A1-20200925120006_217f_large.png&h=7de83254&s={SIZE}\" /><br />\n<br />\n美國國務院的聲明指，蓬佩奧將於9月27日到10月2日訪問希臘、意大利、梵蒂岡及克羅地亞。訪問梵蒂岡時，蓬佩奧將在「外交推動及捍衛宗教自由教廷論壇」（Holy See Symposium on Advancing and Defending Religious Freedom through Diplomacy）發言。聲明又稱，蓬佩奧將會晤教廷國務卿帕羅林（Secretary of State Cardinal Parolin）以及教廷外長加拉查（Secretary for Relations with States Archbishop Gallagher）。<br />\n<br />\n蓬佩奧出訪梵蒂岡之前，本月20日在Twitter轉發他在宗教刊物《第一要務》（First Things）的文章 〈中國天主教徒與教會的道德見證〉 ( China&rsquo;s Catholics and The Church&rsquo;s Moral Witness) ，指中國人權狀況嚴重惡化，宗教信徒受害，中梵簽署主教任命臨時協議兩年後，顯然協議並未能令天主教徒免受蹂躪。<br />\n<br />\n<a href=\"https://www.hkcnews.com/article/34217/%E8%93%AC%E4%BD%A9%E5%A5%A7-%E6%A2%B5%E8%92%82%E5%B2%A1-34217/%E8%93%AC%E4%BD%A9%E5%A5%A7%E4%B8%8B%E5%91%A8%E8%A8%AA%E6%A2%B5%E8%92%82%E5%B2%A1%E6%99%A4%E6%95%99%E5%BB%B7%E5%9C%8B%E5%8B%99%E5%8D%BF\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hkcnews.com%2Farticle%2F34217%2F%25E8%2593%25AC%25E4%25BD%25A9%25E5%25A5%25A7-%25E6%25A2%25B5%25E8%2592%2582%25E5%25B2%25A1-34217%2F%25E8%2593%25AC%25E4%25BD%25A9%25E5%25A5%25A7%25E4%25B8%258B%25E5%2591%25A8%25E8%25A8%25AA%25E6%25A2%25B5%25E8%2592%2582%25E5%25B2%25A1%25E6%2599%25A4%25E6%2595%2599%25E5%25BB%25B7%25E5%259C%258B%25E5%258B%2599%25E5%258D%