{"tid":966632,"cid":5,"subCid":0,"title":"【插畫】不要再說“Chinese” New Year了，過農曆新年可不是「中國人」的專利喔","createTime":"2019-01-03T02:51:42.000Z","updateTime":"2019-02-05T12:24:41.000Z","uid":8543,"like":181,"dislike":5,"uniUserReply":41,"replies":[{"pid":"0d1a5fec35dd699b190e2535b6af507155ef6a80","tid":966632,"uid":8543,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-03T02:51:42.000Z","msg":"<strong>我們想讓你知道的是</strong><br />\n過農曆年可不是「中國人」的專利喔。<br />\n<br />\n<img src=\"https://image2.thenewslens.com/2016/02/2016.02.15-%E4%BD%A0%E9%81%8E%E8%BE%B2%E6%AD%B7%E5%B9%B4%EF%BC%81%E4%BD%A0%E6%98%AF%E4%B8%AD%E5%9C%8B%E4%BA%BA%EF%BC%81-724x1024.jpg?auto=compress&amp;q=80&amp;w=1080\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimage2.thenewslens.com%2F2016%2F02%2F2016.02.15-%25E4%25BD%25A0%25E9%2581%258E%25E8%25BE%25B2%25E6%25AD%25B7%25E5%25B9%25B4%25EF%25BC%2581%25E4%25BD%25A0%25E6%2598%25AF%25E4%25B8%25AD%25E5%259C%258B%25E4%25BA%25BA%25EF%25BC%2581-724x1024.jpg%3Fauto%3Dcompress%26q%3D80%26w%3D1080&h=47a31f29&s={SIZE}\" /><br />\n<br />\n確實，有很多國家的人們都慶祝農曆新年，亞洲國家包括中國、台灣、韓國、越南、新加坡、馬來西亞等都將農曆新年列為國定節日慶祝。<br />\n<br />\n<a href=\"https://www.thenewslens.com/article/36258\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thenewslens.com%2Farticle%2F36258&d=s782VIATokQK7aLWwCtuWzOU%2Fspzl0GStOx2So8CiJ8%3D&h=ba4cd08f\" target=\"_blank\">https://www.thenewslens.com/article/36258</a>"},{"pid":"df1c22911e9ceb78f16980e51e600e79629db297","tid":966632,"uid":193364,"like":370,"dislike":1,"score":369,"citedBy":1,"replyTime":"2019-01-03T02:52:33.000Z","msg":"lunar new year <img src=\"/assets/faces/xm/clown2.gif\" class=\"hkgmoji\" />"},{"pid":"2dddea02d1297d67fae53b57a8a508421245e5a3","tid":966632,"uid":107364,"like":20,"dislike":205,"score":-185,"citedBy":3,"replyTime":"2019-01-03T02:54:41.000Z","msg":"此回覆已被刪除"},{"pid":"c837fcb0fe7a011d788b16e202002a6899896d7f","tid":966632,"uid":26385,"like":230,"dislike":1,"score":229,"citedBy":2,"replyTime":"2019-01-03T03:03:46.000Z","msg":"以前明明係叫lunar new year<br />\n呢十幾年再無人咁叫<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"eb33882c478d0bb0080def5bf4ebdaa498cc61da","tid":966632,"uid":88008,"like":17,"dislike":1,"score":16,"citedBy":0,"replyTime":"2019-01-03T03:06:17.000Z","msg":"Happy new year"},{"pid":"3b51b8fa7f407539fc8fea1f6a4458851ec63a5a","tid":966632,"uid":74908,"like":49,"dislike":2,"score":47,"quote":{"pid":"c837fcb0fe7a011d788b16e202002a6899896d7f","tid":966632,"uid":26385,"like":230,"dislike":1,"score":229,"citedBy":2,"replyTime":"2019-01-03T03:03:46.000Z","msg":"以前明明係叫lunar new year<br />\n呢十幾年再無人咁叫<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-03T03:08:34.000Z","msg":"被人洗腦改變咗口徑"},{"pid":"56b7afa611f7b3ef99db28cb7b79b5e079220a40","tid":966632,"uid":40335,"like":126,"dislike":1,"score":125,"citedBy":3,"replyTime":"2019-01-03T03:08:51.000Z","msg":"唔知點解會變左Chinese New Year。中文不嬲叫農曆新年，所以英文一定係Lunar New Year。"},{"pid":"4d5efeda6026be0a5dd5ffca0e6d27f65926cf75","tid":966632,"uid":98551,"like":8,"dislike":0,"score":8,"citedBy":2,"replyTime":"2019-01-03T03:11:09.000Z","msg":"咁其實農歷係咩人發明？"},{"pid":"d1b29dc5bdf1bf30e89123ea9b9a3c10a1193c4b","tid":966632,"uid":35070,"like":55,"dislike":4,"score":51,"citedBy":0,"replyTime":"2019-01-03T03:15:20.000Z","msg":"羅馬：拜个早年<img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20150213/large/1423815702_7ed3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20150213%2Flarge%2F1423815702_7ed3.jpg&h=6fdfa1c3&s={SIZE}\" />"},{"pid":"faa49d94d23cdbbfb8f258a9d773b87e892f2629","tid":966632,"uid":18167,"like":16,"dislike":0,"score":16,"quote":{"pid":"3b51b8fa7f407539fc8fea1f6a4458851ec63a5a","tid":966632,"uid":74908,"like":49,"dislike":2,"score":47,"quote":{"pid":"c837fcb0fe7a011d788b16e202002a6899896d7f","tid":966632,"uid":26385,"like":230,"