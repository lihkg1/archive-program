{"tid":1066050,"cid":1,"subCid":0,"title":"咪再笑連c雅係公廁","createTime":"2019-03-17T16:22:40.000Z","updateTime":"2019-03-19T13:46:11.000Z","uid":227275,"like":7,"dislike":22,"uniUserReply":6,"replies":[{"pid":"b219af2138240ea4bfe4c75c2db2d9b55a328b0e","tid":1066050,"uid":227275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-17T16:22:40.000Z","msg":"連尊重下人都唔識 <br />\n詩詞歌賦呢啲野你地都搵得開玩笑 <br />\n雅觀得體邊隻雞會有? <br />\n真係既一定有雞個種風塵味 <br />\n係又雞唔係又雞有咩咁好講 <br />\n公平啲啦好心你班人 <br />\n廁所咁多屎你地唔去食 <br />\n黎黎去去都係呢啲唔悶架? <br />\n仲貼埋人地啲圖出黎亂講 <br />\n有冇廉恥架你班人 <br />\n邊有人盲反到咁 <br />\n個個女星性感少少就係雞 <br />\n係又點丫,你班高登仔有得睇無得屌架啦都"},{"pid":"046d47631f67dbe9dda1341358a841a4d90c0eca","tid":1066050,"uid":107201,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-03-17T19:37:13.000Z","msg":"好<br />\n<br />\n<br />\n尷尬"},{"pid":"663190725b76e897cc69656f7b454f51f6909385","tid":1066050,"uid":227275,"like":0,"dislike":2,"score":-2,"quote":{"pid":"046d47631f67dbe9dda1341358a841a4d90c0eca","tid":1066050,"uid":107201,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-03-17T19:37:13.000Z","msg":"好<br />\n<br />\n<br />\n尷尬"},"citedBy":0,"replyTime":"2019-03-18T00:12:35.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"0e42d18e02523ceec4817e2f9a1decc708928561","tid":1066050,"uid":227275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-18T15:31:19.000Z","msg":"31"},{"pid":"b11fbe7a0ed337820a0450d673063a8b4c59f4b6","tid":1066050,"uid":227275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-18T16:29:37.000Z","msg":"2"},{"pid":"55b9b6085c44f5e347f759f1cc1b7a8533aba98c","tid":1066050,"uid":227275,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-19T13:13:54.000Z","msg":"7"},{"pid":"06d47c20872a329785a9e084fa70bdd9e025afc4","tid":1066050,"uid":16613,"like":0,"dislike":0,"score":0,"quote":{"pid":"55b9b6085c44f5e347f759f1cc1b7a8533aba98c","tid":1066050,"uid":227275,"like":0,"dislike":0,"score":0,"citedBy":1,"