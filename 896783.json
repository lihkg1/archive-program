ji\" />"},{"pid":"e549c2de37f9a995076fb16189ba7bad71134715","tid":896783,"uid":26506,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c84bb150f00b12c119ea8a0bde65ce88924ffb2","tid":896783,"uid":79563,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-11-10T10:45:38.000Z","msg":"<img src=\"https://i.postimg.cc/Hkz83N67/002.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.postimg.cc%2FHkz83N67%2F002.jpg&h=d466fa2c&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-11-10T15:09:13.000Z","msg":"Link? <br />\n<a href=\"https://hk.news.appledaily.com/local/daily/article/20121113/18065685\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20121113%2F18065685&d=MT3PDYCEpOChyhPV5aSm9J4f2li5K%2Fs6EGgmwhpeblA%3D&h=4e82846c\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20121113%2F18065685&h=98f7aedb\" target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20121113/18065685</a>"},{"pid":"0ccc351b905646d00c6d5258de484c693878519b","tid":896783,"uid":118709,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-10T15:13:49.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"8af7a93180a7ec136b4cd31e0b994aa6f8b3975b","tid":896783,"uid":118709,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-10T15:22:16.000Z","msg":"有錢人鍾意點玩都得屌你老母"},{"pid":"ae5e9c325fa5a3d4dda8b0035dcc8f8cdf6773dd","tid":896783,"uid":97036,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-10T15:25:15.000Z","msg":"19歲大學畢業<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5419091c88b0b545afc0cf778a6c3531d174b6fa","tid":896783,"uid":41818,"like":0,"dislike":0,"score":0,"quote":{"pid":"310da897520a27b58de86dd7eb1ac9dcb1e2856d","tid":896783,"