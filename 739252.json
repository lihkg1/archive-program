播晒出街，「斷人衣食猶如殺人父母」喎，難怪寫真出版商考慮循法律途徑控告侵權。"},{"pid":"07348a67535d8f439e79e046918301077b53b1cc","tid":739252,"uid":174418,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-21T15:45:35.000Z","msg":"毛記已玩完 請將焦點轉移"},{"pid":"77683be4a377b5bd7cc8abd370792a144453f476","tid":739252,"uid":38173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-21T15:54:16.000Z","msg":"on9當有趣，抵你比人告"},{"pid":"c9ba4dbeed7ccc10b74369f568c41e281ff17b76","tid":739252,"uid":162567,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-22T11:36:18.000Z","msg":"毛記抽中賺好閪多<br />\n利申: 抽唔到"},{"pid":"c4180acb0228cf1e3ba0ad247e7ce662ed7448f8","tid":739252,"uid":166462,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9ba4dbeed7ccc10b74369f568c41e281ff17b76","tid":739252,"uid":162567,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-22T11:36:18.000Z","msg":"毛記抽中賺好閪多<br />\n利申: 抽唔到"},"citedBy":1,"replyTime":"2018-07-22T13:11:24.000Z","msg":"好記得一開就8蚊<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"8689e310db16f7dc89839e7301d5d8a96a0cffe0","tid":739252,"uid":93649,"like":0,"dislike":0,"score":0,"quote":{"pid":"c4180acb0228cf1e3ba0ad247e7ce662ed7448f8","tid":739252,"uid":166462,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9ba4dbeed7ccc10b74369f568c41e281ff17b76","tid":739252,"uid":162567,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-22T11:36:18.000Z","msg":"毛記抽中賺好閪多<br />\n利申: 抽唔到"},"citedBy":1,"replyTime":"2018-07-22T13:11:24.000Z","msg":"好記得一開就8蚊<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-22T14:25:43.000Z","msg":"好似9個幾十蚊"},{"pid":"2035c226e368c34bfdf36ef84f32c3c6aaa0c8a1","tid":739252,"uid":162567,"like":0,"dislike":0,"score":0,"quote":{"pid":"8689e310db16f7dc89839e7301d5d8a96a0cffe0","tid":739252,"uid":93649,"like":0,"dislike":0,"score":