:-3,"quote":{"pid":"b3043112a757a6c1b5a8a1cf7509d968e82dce92","tid":1848830,"uid":69416,"like":28,"dislike":2,"score":26,"citedBy":1,"replyTime":"2020-01-28T16:33:44.000Z","msg":"新年流流搏開年<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\nbtw下次睇清楚D先<br />\n幫你推一推"},"citedBy":1,"replyTime":"2020-01-28T16:34:33.000Z","msg":"想大家知姐<img src=\"/assets/faces/lny/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-28T16:35:33.000Z","msg":"好彩誠哥醒目識搞排隊系統<br />\n如果唔係Server就爆<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n唔緊要啦"},"citedBy":0,"replyTime":"2020-01-28T16:36:28.000Z","msg":"多謝你<img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" />"},{"pid":"08b9e034e819f381caaced08150c5bc1bb689b32","tid":1848830,"uid":194325,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-01-28T16:37:06.000Z","msg":"<img src=\"https://na.cx/i/1DtKWpn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1DtKWpn.jpg&h=a27c226a&s={SIZE}\" /><br />\n<br />\n白色，是醫護常用顏色。不含任何色素，並容易發現污漬，適用於醫院最應保持潔淨的地方。除此之外，白色還代表純粹的善良和堅定的信念。<br />\n<br />\n當日，醫護們憑藉良心忠實履行自己的使命。今日，政權道德綁架他們這一份熱誠和信念。<br />\n<br />\n他們守護了我們生命和健康，但又誰能守護他們？<br />\n<br />\n全城白絲帶，支持醫護罷工。醫護不是condom，我們與醫護同行。<br />\n<br />\n#全城白絲帶 #撐醫護 #撐罷工 #封關口 #醫護非condom #與醫護同行<br />\n#香港金總 #HKFU #standwithmedics<br />\n<br />\n各位金融人都麻煩幫手填問卷，謝謝。<br />\n<br />\n⚠️⚠️緊急⚠️⚠️<br />\n<br />\n香港金融業職工共同抗疫意見調查<br />\n<br />\n香港金融業職工總會欲以問卷方式詢問同業以工業行動共同抗疫的意願和意見，以制定有效方式向僱主及政府表達對僱員對於安全和健康的憂慮，全民共同抗疫。<br />\n<br />\n由於事態緊急，如策劃任何工業行動必需經過既定程序。故此是次問卷將於1月31日23:59截止。希望同業們積極參與此調查，讓金總能全面理解金融界僱主於防疫措施現況，以及會員和同業於共同抗疫的意願，以制定下一步行動。<br />\n<br />\n<a href=\"https://forms.gle/toVdkp2QMVwtZXVr7\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2FtoVdkp2QMVwtZXVr7&d=rcEdfnhTqGmqsB%2B6X%2FYCGeBrFmK%2FfjgW9YhWFGnkYF4%3D&h=0a075c27\" data-auto-link target=\"_blank\">https://forms.gle/toVdkp2QMVwtZXVr7</a><br />\n<br />\n原post傳送門：<br />\n［行動］［請置頂］全民白絲帶 罷工撐醫護<br />\n<a href=\"https://lih.kg/1848612\" data-auto-link target=\"_blank\">https://lih.kg/1848612</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"66c61186ad1f86c4dc01740ba854bbe3e9dec93b","tid":1848830,"uid":294953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T16:37:20.000Z","msg":"願口罩歸誠哥"},{"pid":"f61be4590a75c385ce18da72b04b9efca441551b","tid":1848830,"uid":81236,"like":1,"dislike":0,"score":1,"quote":{"pid":"d3b074a04a8388a8176c863ce48f43a6573f28a5","tid":1848830,"uid":33452,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-01-28T16:36:07.000Z","msg":"有心就好有心就好<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-28T16:37:44.000Z","msg":"多謝<img src=\"/assets/faces/lny/cry.gif\" class=\"hkgmoji\" />"},{"pid":"46813edf8adabb8443e0a31c1dd9ec25b9e892c3","tid":1848830,"uid":54228,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2020-01-28T16:38:19.000Z","msg":"下次記得加密"},{"pid":"8a3111d6b17cabff02bc6f2dff98d96d9d84fb8e","tid":1848830,"uid":81236,"like":0,"dislike":0,"score":0,"quote":{"pid":"46813edf8adabb8443e0a31c1dd9ec25b9e892c3","tid":1848830,"uid":54228,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2020-01-28T16:38:19.000Z","msg":"下次記得加密"},"citedBy":0,"replyTime":"2020-01-28T16:39:00.000Z","msg":"一定會<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"0f38dd4359aa690f12189c69d9bba23b05addf73","tid":1848830,"uid":21141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T16:39:26.000Z","msg":"唔緊要<br />\n有消息下次再講<img src=\"/assets/faces/lny/biggrin