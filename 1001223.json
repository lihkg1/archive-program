kgmoji\" />"},{"pid":"5c6d474c19f56775d332effbff79be2649d97915","tid":1001223,"uid":145656,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-01-30T05:29:49.000Z","msg":"屌你老母，如果真係照比長奉，真係隻手遮天惡撚到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5531e0d0d5698deecb0cc8640b6c43910954426b","tid":1001223,"uid":55296,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-30T05:30:48.000Z","msg":"可以話派就派？"},{"pid":"f342ea56474673c0d4621f09cf2727dc5f4c35f2","tid":1001223,"uid":71133,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-30T05:31:08.000Z","msg":"為左個面是非黑白不分，港英整治警隊咁多年就俾呢班仆街敗晒"},{"pid":"1d36dabc9aae55979205f6c7d060e1b4845d416f","tid":1001223,"uid":5020,"like":1,"dislike":0,"score":1,"quote":{"pid":"11220c85437f632f94f4c0fd6c1c99765dc1833e","tid":1001223,"uid":5020,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc841e986b3abb7ec2d2dbfcb2cfd1eb2f0710c3","tid":1001223,"uid":11973,"like":2,"dislike":6,"score":-4,"citedBy":3,"replyTime":"2019-01-30T05:14:36.000Z","msg":"人哋署長都話係跟足程序俾退休金㗎喎<br />\n如果法例寫明個機制係咁<br />\n本身佢又係entitle嘅話有乜問題<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n連登仔唔係成日口口聲聲講咩法治精神嘅咩?<br />\n而家又唔駛講嗱<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /> <br />\n又用返人治呀<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /> <br />\n個籠門唔係咁搬法㗎嘛<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-30T05:27:39.000Z","msg":"警隊未能作出處分<br />\n<br />\n根據《退休金條例》，若公務員違法，其退休金可能會被取消。朱經緯於2015年7月退休，卻在2014年11月底處理雨傘運動相關的行動中揮動警棍，襲擊途人鄭仲恒，投訴課至2015年12月裁定投訴成立，當時朱已退休5個月，故警隊未能對他作出處分，朱亦應能穩袋其退休金。<br />\n<br />\n舊制公務員享長俸福利<br />\n<br />\n朱經緯於1979年加入警隊，屬舊制公務員，按他退休前月薪約11.3萬元計算，他退休後可選擇領取每月長俸約7.5萬元，或可折算其退休金最多25%，即一筆過先取退休酬金約318萬元，再每月領取長俸近5.7萬元。朱在去年12月被定罪，之後保釋等候上訴，期間若他一直有取得長俸，而又選擇前者的計劃的話，應已領得277.5萬，而若他選擇後者，即先支取部份酬金，則應已收若528.9萬。<br />\n<br />\n<br />\n紅01之前報過<br />\n<br />\n<a href=\"https://www.hk01.com/%E7%A4%BE%E6%9C%83%E6%96%B0%E8%81%9E/235093/%E6%9C%B1%E7%B6%93%E7%B7%AF%E4%B8%8A%E8%A8%B4-%E9%80%80%E4%BC%91%E5%BE%8C%E8%A2%AB%E8%B5%B7%E8%A8%B4-%E6%96%99%E6%9C%80%E9%AB%98%E5%B7%B2%E8%A2%8B%E9%80%BE5%E7%99%BE%E8%90%AC%E9%80%80%E4%BC%91%E9%87%91%E5%8F%8A%E9%95%B7%E4%BF%B8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E7%25A4%25BE%25E6%259C%2583%25E6%2596%25B0%25E8%2581%259E%2F235093%2F%25E6%259C%25B1%25E7%25B6%2593%25E7%25B7%25AF%25E4%25B8%258A%25E8%25A8%25B4-%25E9%2580%2580%25E4%25BC%2591%25E5%25BE%258C%25E8%25A2%25AB%25E8%25B5%25B7%25E8%25A8%25B4-%25E6%2596%2599%25E6%259C%2580%25E9%25AB%2598%25E5%25B7%25B2%25E8%25A2%258B%25E9%2580%25BE5%25E7%2599%25BE%25E8%2590%25AC%25E9%2580%2580%25E4%25BC%2591%25E9%2587%2591%25E5%258F%258A%25E9%2595%25B7%25E4%25BF%25B8&d=CddLi1wVc%2F0RDzQLDYdfB%2FcTfOzAwtSP2zPdisjLlXU%3D&h=9a4444a4\" target=\"_blank\">https://www.hk01.com/%E7%A4%BE%E6%9C%83%E6%96%B0%E8%81%9E/235093/%E6%9C%B1%E7%B6%93%E7%B7%AF%E4%B8%8A%E8%A8%B4-%E9%80%80%E4%BC%91%E5%BE%8C%E8%A2%AB%E8%B5%B7%E8%A8%B4-%E6%96%99%E6%9C%80%E9%AB%98%E5%B7%B2%E8%A2%8B%E9%80%BE5%E7%99%BE%E8%90%AC%E9%80%80%E4%BC%91%E9%87%91%E5%8F%8A%E9%95%B7%E4%BF%B8</a>"},"citedBy":1,"replyTime":"2019-01-30T05:31:14.000Z","msg":"手快快submit 咗<br />\n按佢犯法時間計佢係無得拎<br />\n但黑警一拖拖足成年，拖到佢退休先正式起訴，確保佢退休有糧出<br />\n到底係邊個唔依法呢？"},{"pid":"0338cd11bcb3c2e41cf117abf8217027930e3ba4","tid":1001223,"uid":15739,"like":0,"dislike":0,"score":0,"quote":{"pid":"b3a520f9f0938f9a4d8a176292a2924d9a3fb347","tid":1001223,"uid":140769,"like":0,"dislike":3,"score":-3,"quote":{"pid":"d591e25e33ad172194c53410465024051b4e3f43","tid":1001223,"uid":15739,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2019-01-30T05:09:14.000Z","msg":"成日話要維護警隊形象，一哥都咁出面保個犯，根本就本未倒置，仲話跟足程序做，即係認同程序&gt;法律，咁抵毀法律以後邊個跟？真係無腦到"},"citedBy":1,"replyTime":"2019-01-30T05:10:27.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-01-30T05:34:08.000Z","msg":"做