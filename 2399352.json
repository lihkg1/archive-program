/faces/big/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0e004e5f68a9e0798bf91e139a2fca6a731dcb44","tid":2399352,"uid":99962,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-08T06:20:57.000Z","msg":"獅身人面像出現果陣地球都未有文明"},{"pid":"b7333555bee8413bae05eceb81183bacdc84f23e","tid":2399352,"uid":97181,"like":3,"dislike":0,"score":3,"quote":{"pid":"227a4d5715761d92635702b56307887966dd7344","tid":2399352,"uid":220942,"like":57,"dislike":0,"score":57,"citedBy":5,"replyTime":"2021-02-08T05:18:47.000Z","msg":"如果講景點造假<br />\n某國大部份&ldquo;古舊&rdquo;景點都係近十年廿年內起好<br />\n全部都係20世紀人工化<br />\n啤膠，灌紅毛泥咁起<br />\n地點方便旅遊車，一車車咁車啲水魚入去<br />\n<br />\n而相反日本既寺廟，鳥居，就算係翻新，都用番天然木材去翻新"},"citedBy":0,"replyTime":"2021-02-08T06:22:07.000Z","msg":"講開日本就一定要講伊勢神宮式年遷宮<br />\n不但維持到神宮的狀態<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><br />\n仲可以保存到工匠的技術<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},{"pid":"7eb0466323e84b34dd471f8172995fad2be2e17a","tid":2399352,"uid":13421,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-08T06:24:16.000Z","msg":"呢啲人都做到教授<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />這就是中國"},{"pid":"fa76b987c304f90f01eb9aa86660b8a409e7c1c2","tid":2399352,"uid":256059,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-08T06:25:36.000Z","msg":"問下楊潤雄歷史教科書有無誤導,&nbsp;有無違反國安法, 促請盡快跟據呢位教授糾正...."},{"pid":"eb00bd5f375a2d4c31e74317563aeaf5b14c9a49","tid":2399352,"uid":345502,"like":0,"dislike":0,"score":0,"quote":{"pid":"9b17e317a6c2588e5941dcf88a9d9b5827d458f9","tid":2399352,"uid":28114,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-08T05:06:31.000Z","msg":"浙江大學的教授黃河清近日在其講座直播時宣稱，諸如雅典的巴特農神廟、埃及的金字塔等古代遺跡都是西方在現代偽造。<br />\n<br />\n以埃及胡夫金字塔、獅身人面像為例，黃河清表明有確鑿的西方書籍插圖及歷史照片，證明其在當時並不存在，是在19世紀用混泥凝土建造，「由於西方一直在打壓中華文明，這種否定中華文明，所以我在某種程度上也為中華文明去正名。」<br />\n<br />\n<img src=\"https://cdn.hk01.com/di/media/images/dw/20210204/434041492974080000190386.jpeg/4fHPYRV6XB338tW7GUugw7r1S-aWk0SmCivNSgorzUo?v=w1760\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fdw%2F20210204%2F434041492974080000190386.jpeg%2F4fHPYRV6XB338tW7GUugw7r1S-aWk0SmCivNSgorzUo%3Fv%3Dw1760&h=9087bbf5&s={SIZE}\" /><br />\n黃河清認為，西方虛構歷史、偽造古代遺跡的唯一目的，就是貶低中華文明。（影片截圖）<br />\n<br />\n黃河清表示，在19世紀至20世紀，西方大肆偽造歷史文物，不惜耗費巨資到處偽造古代遺跡，將古埃及、古兩河流域及古印度文明的地位提升，「將這三個文明虛構到比中華文明更古老，其意圖是用大量虛高假像，攪亂世界歷史真相，來弱化中華文明的光輝。」黃河清認為，西方虛構歷史、偽造古代遺跡的唯一目的，就是貶低中華文明。<br />\n<br />\n黃河清的理論是「以圖證史」，指通過網絡資源，獲得大量罕見、幾乎未公開西方古籍插圖和歷史照片，「無可置疑地證明」許多西方古代遺跡都是現代偽造。以埃及胡夫金字塔為例，黃河清表示他有找到巴黎羅浮宮第一任館長德農的畫作，還有跟隨拿破倫遠征埃及的科學家代表團，他們回國後出版的《埃及描述》裡的圖片，均顯示金字塔是建在一片像陝北黃土高原、有溝壑的丘陵之上，不但與今時今日的環境完全不符，而且當時亦不見有胡夫金字塔及獅身人面像。"},"citedBy":0,"replyTime":"2021-02-08T06:28:08.000Z","msg":"呢D一定要煲大佢"},{"pid":"da6b5c08c1859e774cb498b4b03c20fbb66fd1db","tid":2399352,"uid":25073,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-08T06:29:59.000Z","msg":"支那一直有班人覺得古希臘古羅馬係虛構出嚟嘅嘢<br />\n估唔到依家玩到去古埃及<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"cc920a5cf7fe1b21c9ef5761f78654b55acd3d60","tid":2399352,"uid":19067,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-08T06:31:09.000Z","msg":"挪亞方舟都係習大大起架!"},{"pid":"34d284ef87257ab5760bffdb933e88f7e1d4f0b8","tid":2399352,"uid":38910,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-08T06:33:02.000Z","msg":"你係唔係去錯深圳世界之窗呀"},{"pid":"71f7a4db40638b65f1d2d39f52b428dab4f8caf7","tid":2399352,"uid":301820,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-08T06:33:26.000Z","msg":"中共邪教<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"799a96a9b44078e920fa3cf1b0368fed0b19919a","tid":2399352,"uid":298077,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-08T06:35:03.000Z","msg":"中國跌塔&gt;巴黎鐵塔<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"3196a8938d276c374b7ab30a27862b0671