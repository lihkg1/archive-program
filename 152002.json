assets/faces/lomoji/02.png\" class=\"hkgmoji\" />"},{"pid":"81652e227a35136f20b98ba5ca26a6a19eb3eb30","tid":152002,"uid":53278,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-11T15:16:20.000Z","msg":"佢就係信唔過香港人先唔洗你參軍<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5fc023aca60a64e6ef3317b048f502081d9d0fe9","tid":152002,"uid":23221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-11T16:46:35.000Z","msg":"<span style=\"font-size: x-large;\">正呀，為香港建國訓練軍人。</span>"},{"pid":"eb482eb31159239ac1450e29350330e77ceed34c","tid":152002,"uid":63669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-11T16:53:23.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"41f14d96a9c485f9cc4e0bbaa569357851676b01","tid":152002,"uid":54927,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-11T17:01:22.000Z","msg":"<blockquote>俾香港入老解=為香港人提供軍事訓練,為港獨準備人才<br />\n<br />\n我係習近平第一個就拉你落馬 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n傻撚左<br />\n你估個個支持港獨咩"},{"pid":"e1c27659b96d59a3066ab52b7f324d12969f2032","tid":152002,"uid":32676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-11T17:03:05.000Z","msg":"<blockquote><blockquote>俾香港入老解=為香港人提供軍事訓練,為港獨準備人才<br />\n<br />\n我係習近平第一個就拉你落馬 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n傻撚左<br />\n你估個個支持港獨咩</blockquote><br />\n老解係油水位嚟，你話入就入到咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2bd1db47b527d977a3ea9b4fa80da2ec7272512e","tid":152002,"uid":8511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-11T17:14:01.000Z","msg":"好撚多刷鞋狗, 人地話愛國就真係諗計整到「一國一制」<br />\n用下個腦啦, 真係等上海深圳同外國接軌咩?<br />\n你攪窩香港, 你大佬咪又係無運行<br />\n<br />\n所以咁耐都係小動作干涉香港<br />\n真係中國立法去整治香港, 佢地既資本都要承受後果"},{"pid":"de54c16942465ac49f894f87dc0069de81156ca1","tid":152002,"uid":53705,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-12T11:13:07.000Z","msg":"<blockquote><blockquote><blockquote>俾香港入老解=為香港人提供軍事訓練,為港獨準備人才<br />\n<br />\n我係習近平第一個就拉你落馬 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n傻撚左<br />\n你估個個支持港獨咩</blockquote><br />\n老解係油水位嚟，你話入就入到咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n其實加入解放軍, 根本就無乜軍事訓練<br />\n<br />\n因為解放軍 大部份時間都係訓練紀律.....<br />\n即係步操, 叫口號......同埋最出名既 摺被<br />\n<br />\n其餘時間就係洗腦.........即係學習毛澤東思想, 共產黨理念, 愛國愛黨 之類<br />\n<br />\n只有小部份時間真係比你開幾槍, 做下體能訓練, 格鬥訓練咁<br />\n呢D野其實 加入香港警察一樣可以做到"}]}