12<br />\n<br />\n<a href=\"https://www.facebook.com/save12hkyouths/photos/a.112567073917057/178076927366071/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fsave12hkyouths%2Fphotos%2Fa.112567073917057%2F178076927366071%2F&d=K%2BViKRLCts5CIle5BUc%2Byi%2B6%2F41ZtH0%2FHUJlQhqDsdc%3D&h=e48b2673\" data-auto-link target=\"_blank\">https://www.facebook.com/save12hkyouths/photos/a.112567073917057/178076927366071/</a>"},"citedBy":0,"replyTime":"2020-11-12T13:49:36.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"d35099f46699ef5e81b8233d2b2b09ff44f29130","tid":2283263,"uid":232157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-12T13:56:37.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"309216ebe0ac21c4f8593b7b71d8544953d06aff","tid":2283263,"uid":2117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-12T13:58:38.000Z","msg":"<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"b889f0c74aa7ba83f0e0b072cd27e745bb5aef4a","tid":2283263,"uid":34213,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-12T14:06:21.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"168f32733f11f0ebdfbfa7333191a1f456b5c1dc","tid":2283263,"uid":105138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-12T14:07:37.000Z","msg":"<img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" />"},{"pid":"aa0450ec88ac0a770b56e1eb84164495435bc2aa","tid":2283263,"uid":312429,"like":0,"dislike":0,"score":0,"quote":{"pid":"a8c4429b893f4ce20f6ab7644521e1318