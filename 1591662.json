\" />"},{"pid":"0d0a549f24c2ac944b4b2da05da167712dd4ca41","tid":1591662,"uid":134728,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-24T09:12:18.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"32b1646cd03dd6c3eac35d62a510d2d3a5a3b470","tid":1591662,"uid":113187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-24T09:12:33.000Z","msg":"10/10<br />\n<br />\n行動喇"},{"pid":"f98baaa7b064b0bcda3e709b901bb7a5e1769eba","tid":1591662,"uid":1747,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-24T09:12:44.000Z","msg":"走時換其他色衫好d 唔係又好多上次小巴篤灰"},{"pid":"9503a69fe42fd0c7a0b8ec002f8cd122168acb45","tid":1591662,"uid":113187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-24T09:15:04.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">928 唔一定要集會<br />\n<br />\n全日黑衣<br />\n<br />\n全日自由活動</span></strong></span>"},{"pid":"7a2a67ef74cd635b1a7b1598435b445b4fcf3c5b","tid":1591662,"uid":113187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-24T09:18:27.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />唔好掛住查案呀"},{"pid":"ab3f2976aadc73c2f0b5a3a4c4dcfeb025172bce","tid":1591662,"uid":113187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-24T09:19:16.000Z","msg":"一路查案 一路行動<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"}]}