9:45.000Z","msg":"convoy 唔係傳銷咩?"},{"pid":"a027fae0e41e72c0143f1b6cff87fadb3016c915","tid":2450664,"uid":87172,"like":0,"dislike":0,"score":0,"quote":{"pid":"567b7f0a8c14c8699439d34f7bb05e453c86655c","tid":2450664,"uid":353256,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-03-17T15:43:09.000Z","msg":"有無人解釋下點解要打交<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-17T15:59:48.000Z","msg":"因為停牌變廢紙，發窮惡囉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2040d2cb1c28df4d73d3d7242b86fc211571aa84","tid":2450664,"uid":47492,"like":10,"dislike":0,"score":10,"quote":{"pid":"a22de1f7d69dbafdf502219cb256bdd268436178","tid":2450664,"uid":79563,"like":0,"dislike":0,"score":0,"quote":{"pid":"49ce593b8758aafd57ab7d44418a1d50005e931e","tid":2450664,"uid":44358,"like":53,"dislike":1,"score":52,"citedBy":2,"replyTime":"2021-03-17T14:48:11.000Z","msg":"今日深圳仔食台資，他日福建仔食美資。"},"citedBy":2,"replyTime":"2021-03-17T15:40:56.000Z","msg":"內文講係深圳仔被台仔食咗喎<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-17T16:00:17.000Z","msg":"不嬲台灣幫揸緊莊  支那幫想搶"},{"pid":"a8c9beefcbaecef7cf3dc3d76e5786405b740d15","tid":2450664,"uid":51753,"like":0,"dislike":0,"score":0,"quote":{"pid":"54b32c1d5a6a6c2ac8997de05408d10f238af1b1","tid":2450664,"uid":228143,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-03-17T15:53:20.000Z","msg":"佳兆業唔係好有錢嫁咩"},"citedBy":0,"replyTime":"2021-03-17T16:04:50.000Z","msg":"江河日下"},{"pid":"7f6c19b3d6cf734218f1592c94ee40bc985592a8","tid":2450664,"uid":184249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-17T16:05:24.000Z","msg":"雞乸化香港"},{"pid":"26ff388b69e1ca05d9feac3a95257975ef31dc5d","tid":2450664,"uid":2054,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-17T16:06:20.000Z","msg":"瘋了 全都瘋了"},{"pid":"6ea61a1689088efce4fc09176d0f93a2efc89654","tid":2450664,"uid"