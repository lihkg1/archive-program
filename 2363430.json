6559c623773302561a39d046f95cd165dc","tid":2363430,"uid":83102,"like":3,"dislike":0,"score":3,"quote":{"pid":"0c7667ee2e379a0d774b5f60e4e8a14b90229375","tid":2363430,"uid":45830,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd2e5b951f10f893bfd4107d65b355b341b3fd68","tid":2363430,"uid":83102,"like":0,"dislike":3,"score":-3,"quote":{"pid":"e90018451d7efcee546ca168b2dbe4b16b21fb6d","tid":2363430,"uid":45830,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2021-01-13T08:43:31.000Z","msg":"其實有冇需要放4K呢？<br />\n內容好精緻？？"},"citedBy":1,"replyTime":"2021-01-13T08:52:47.000Z","msg":"有需要<br />\n內容好垃圾<br />\n有得拍4k 咪試下出4k睇下<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-13T16:03:58.000Z","msg":"都係問吓八卦吓，無悪意的。<br />\n宜家進度如何？"},"citedBy":1,"replyTime":"2021-01-14T01:41:18.000Z","msg":"試左好耐 應該算係成功左<br />\n事後開mediainfo睇應該估到咩原因<br />\n<br />\n電腦睇得1080p 起曬格<br />\n應該係我一開頭export個 揀mov/mp4 H264 <br />\n原來得8bit<br />\nyoutube應該點都要食要10bit否則有Bugs<br />\n我再睇 因為free版DR17 冇H264 10bit<br />\n跟住我轉用 Mov DNxHR HQX 10bit<br />\n然後成功左 電腦睇正常顯示SDR 1080p /4k 唔起格<br />\niphone睇出出1080p HDR (個mon睇到4k應該出4k)<br />\n<br />\n跟手發現第二個問題 出DNxHR HQX 10bit file size極大<br />\n我條長片高過youtube128GB限制<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n於是我用軟件轉檔轉做mp4 H264 10bit<br />\nupload左上去 睇到1080p 唔起格 等youtube process 埋4k就掂<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n所以係可以8bit扮10bit youtube都食<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n跟住個軟件最好可以出mp4/mov H264 10bit<br />\n<br />\n<br />\n<br />\n然後係color spacing問題<br />\n基本上揀有 Rec 2100/2020 字眼嘅都得<br />\n我見有人用st2084/hlg 乜都有<br />\n<br />\n最大問題係youtube壓HDR to SDR<br />\n2個做法<br />\n1) export完條片再放落DR17 rec2020轉去709 再整個LUT出黎 (youtube講寫 我唔識）<br />\n2) 我發覺Rec.2100 ST2084 好似最掂<br />\n其他用sdr mon睇會死灰/過曝<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n總結<br />\na7c拍8bit出10bit 都得<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />多左hdr睇 我覺得都有靚左（iphone睇落光暗位靚左好多 有層次感)<br />\n<br />\n要成功正常睇<br />\ncolor spacjng 用Rec.2100 St2084<br />\nexport mp4/mov H264 10bit<br />\n一定要10bit以上"},{"pid":"93042cf828f5f51dc1f25fe0099207a58c1ed167","tid":2363430,"uid":195471,"like":0,"dislike":0,"score":0,"quote":{"pid":"1d3c226559c623773302561a39d046f95cd165dc","tid":2363430,"uid":83102,"like":3,"dislike":0,"score":3,"quote":{"pid":"0c7667ee2e379a0d774b5f60e4e8a14b90229375","tid":2363430,"uid":45830,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd2e5b951f10f893bfd4107d65b355b341b3fd68","tid":2363430,"uid":83102,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2021-01-13T08:52:47.000Z","msg":"有需要<br />\n內容好垃圾<br />\n有得拍4k 咪試下出4k睇下<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-13T16:03:58.000Z","msg":"都係問吓八卦吓，無悪意的。<br />\n宜家進度如何？"},"citedBy":1,"replyTime":"2021-01-14T01:41:18.000Z","msg":"試左好耐 應該算係成功左<br />\n事後開mediainfo睇應該估到咩原因<br />\n<br />\n電腦睇得1080p 起曬格<br />\n應該係我一開頭export個 揀mov/mp4 H264 <br />\n原來得8bit<br />\nyoutube應該點都要食要10bit否則有Bugs<br />\n我再睇 因為free版DR17 冇H264 10bit<br />\n跟住我轉用 Mov DNxHR HQX 10bit<br />\n然後成功左 電腦睇正常顯示SDR 1080p /4k 唔起格<br />\niphone睇出出1080p HDR (個mon睇到4k應該出4k)<br />\n<br />\n跟手發現第二個問題 出DNxHR HQX 10bit file size極大<br />\n我條長片高過youtube128GB限制<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n於是我用軟件轉檔轉做mp4 H264 10bit<br />\nupload左上去 睇到1080p 唔起格 等youtube process 埋4k就掂<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n所以係可以8bit扮10bit youtube都食<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n跟住個軟件最好可以出mp4/mov H264 10bit<br />\n<br />\n<br />\n<br />\n然後係color spacing問題<br />\n基本上揀有 Rec 2100/2020 字眼嘅都得<br />\n我見有人用st2084/hlg 乜都有<br />\n<br />\n最大問題係youtube壓HDR to SDR<br />\n2個做法<br />\n1) export完條片再放落DR17 rec2020轉去709 再整個LUT出黎 (youtube講寫 我唔識）<br />\n2) 我發覺Rec.2100 ST2084 好