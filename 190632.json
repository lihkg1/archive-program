2F7g1H6Kh.jpg&h=3106d0c0&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/04/07/181745_3869fa9ab94c64feb5a7280c2eb35f23.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F04%2F07%2F181745_3869fa9ab94c64feb5a7280c2eb35f23.jpg&h=0b0d7564&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/04/07/181747_81586ca237c0230650b2eb61949cf208.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F04%2F07%2F181747_81586ca237c0230650b2eb61949cf208.jpg&h=87292d64&s={SIZE}\" />"},{"pid":"51d3486d2c29855895df25c79a0b8f24e0f027e8","tid":190632,"uid":101863,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-07T11:12:02.000Z","msg":"<blockquote>之前睇過個大陸channel 李老鼠<br />\n佢講過一句 揸唔壞ge豐田 整唔好ge路虎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n雖然我買唔起 但係鍾意就去馬啦<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n有無巴打知有咩整唔好？<br />\n<br />\n我外父係大陸人又係咁講，但係又講唔出有咩整<br />\n<br />\n我有時覺得，一個牌子係一個地方既image定左形，就個個都咁講<br />\n<br />\n就好似係香港，主流意見係雙田吊打mazda，但係係澳洲，mazda受歡迎好多<br />\n<br />\n等land rover車主巴打解讀下"},{"pid":"2809ded56c4920627625590fdf123f189f018ee9","tid":190632,"uid":28153,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-07T11:29:27.000Z","msg":"Landrover賣嘅係實用 可靠去邊都得 discovery spot揸落有少少浮 如果有magnatic ride會好好多 力水ok 波箱順滑 油耗就唔好要求咁多了<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n身邊有朋友都因為屋企而換走部單門轉discovery sport, 我會形容佢係一個有尊嚴嘅爸爸"},{"pid":"6b3066bbfe59ce9c3a941c38ce76ec06e8932dbf","tid":190632,"uid":93432,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-07T11:32:44.000Z","msg":"新車冇得頂<br />\n壞車冇得整<br />\n<br />\n<br />\nDefender <img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" />"},{"pid":"e5fb75e8b9bd1860fb93e79a07bc9d0082db9eb6","tid":190632,"uid":21222,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-07T11: