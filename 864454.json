ji\" />"},{"pid":"fb6e3957b08b95d04b36f692854c8543e0a255cd","tid":864454,"uid":216961,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-16T10:38:58.000Z","msg":"繼續找數<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"fc95e5c071221538c96d1ef11419169205ba6408","tid":864454,"uid":118202,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-16T10:40:05.000Z","msg":"磨牙<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"e80205c9a58df8fdc07f6ad952877b8ce6281f88","tid":864454,"uid":151656,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-16T10:44:42.000Z","msg":"done"},{"pid":"21ddd05a74eeff8a1acb980bd1ca3db34785d5c5","tid":864454,"uid":216961,"like":0,"dislike":0,"score":0,"quote":{"pid":"e80205c9a58df8fdc07f6ad952877b8ce6281f88","tid":864454,"uid":151656,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-16T10:44:42.000Z","msg":"done"},"citedBy":0,"replyTime":"2018-10-16T11:28:57.000Z","msg":"唔該晒呀<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"5b32dbd433404ea9c71d5c2f11f1786857430d08","tid":864454,"uid":216961,"like":0,"dislike":0,"score":0,"quote":{"pid":"fc95e5c071221538c96d1ef11419169205ba6408","tid":864454,"uid":118202,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-16T10:40:05.000Z","msg":"磨牙<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-16T11:31:36.000Z","msg":"我晏啲繼續找數，不過露點唔敢貼，怕俾人bam"},{"pid":"9ab99bcd6a8b79d5958852aa34e18e007bf47320","tid":864454,"uid":216961,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-16T20:07:35.000Z","msg":"經過一日嘅時間，暫時收到67份回應，首先我衷心感激呢67位巴絲嘅協助。<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n如果仲有人呢刻先睇到呢個post未填但願意嘅話都可以填㗎，份問卷仲繼續開放緊。<br />\n<a href=\"https://goo.gl/forms/dZU4wzXs908ZKm5p1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgoo.gl%2Fforms%2FdZU4wzXs908ZKm5p1&d=4ca4e27lY2GGV30PmgtKiP%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=f176d16b\" target=\"_blank\">https://goo.gl/forms/dZU4wzXs908ZKm5p1</a><br />\n有啲巴絲之前會質疑點解要幫我？畢竟我又唔係做學術研究，而係為咗之後嘅商業行為。<br />\n誠言之後個計劃會點行我依家未必能夠確實到，因為正正就係全靠調查所得嘅結果，先會對我原有嘅方向同想法有所影響。<br />\n無論如何，我覺得既然呢個係一個公眾嘅問卷，而且又有咁多位網友慷慨咁願意花時間去填寫。雖然個調查結果同用途會有商業性質，但我認為都好應該花啲時間去做返啲嘢回饋大家，就係公佈初步嘅數據。首先希望等對於個調查有質疑嘅巴絲可以屌得細力少少<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> ，更重要係希望比大家了解一吓自己响戒口同生活習慣上同普遍香港人有無分別，唔洗話做完問卷無得著啦。<br />\n<br />\n首先<br />\n男女比例其實好接近，不過絲打多少少，可能係女性對戒口方面比較著緊，亦可能係絲打比較願意分享啦。<br />\n而有務需要戒口嘅比例亦好接近，但係都有過半數53.7%(36人)係要戒口嘅。<br />\n至於戒口原因，大比數係健康有66.7%(24人), 個人習慣就有8.3%(3), 比較意外嘅係宗教原因居然係有19.4%(7人), 其他就不贅述。<br />\n<br />\n然後先睇健康原因<br />\n好正路體重管理佔45.8%，尤其絲打會比較著緊呢方面嘅戒口<br />\n健身都有20.8%，相信係大隻JJ<br />\n美容就有25%，其實食啲乜用啲乜確實對皮膚都幾大關係㗎<br />\n養生都有20.8%<br />\n之後就係身體有毛病嘅原因<br />\n濕疹有25%<br />\n食物過敏有25%<br />\n異位性皮膚炎估唔到都有成16.7%<br />\n暗瘡亦有12.5%<br />\n糖尿病有8.3%<br />\n高血壓，胃病都係4.2%<br />\n最後講講consultation，有大半人冇搵過專業人仕，只有20.8%係靠專科醫生，另外12.5%靠家庭醫生，可憐地營養師只有1人見過<br />\n<br />\n睇埋個人習慣原因<br />\n比例上同健康原因好接近，不過養生相對比較多有45%<br />\n體重管理有60%, 健身有35%, 美容有20%<br />\n素食有15%, 口味喜好就30%<br />\n<br />\n點樣執行戒口嘞<br />\n有幾discipline去執行戒口，估唔到有成22.6%係永遠執行<br />\n對落都分別有30.2%同32.1%，即係睇嚟會戒口嘅人都有超過八成係有努力執行喎<br />\n至於出外用膳同購物時，大家似乎都會關心執行戒口，可能避免浪費啦，所以都分別有92.5%同86.8%會係事前執行<br />\n如何確保戒口方面，最多就係憑記憶67.9%, 唔理會嘅都有18.9%，其他都係介乎5.7%同7.5%<br />\n<br />\n睇睇話無戒口嘅人<br />\n&ldquo;其實有作食物選擇，只是並非硬性的戒口&rdquo;原來都有成54.8%，口裡說不？<br />\n其餘都係話完全無需要<br />\n<br />\n用膳習慣呢...<br />\n都唔少人會細心睇餐牌，有成52.2%<br />\n不過居然亦有40.3%係會去到邊都只會揀點開嘅餸<br />\n點完先算嘅都估唔到有20.9%<br />\n問店員或者人地介紹就分別11.9%同6%<br />\n會去專門嘅餐廳嘅都唔少，有7.5%<br />\n唔會點揀就有20.9%<br />\n<br />\n雖然話就話有一半人會細心睇餐牌，但係有幾留心成份同營養就似乎幾diverse<br />\n真係好留心嘅得19.4%, 跟住落去就係26.9%, 19.4%, 23.9%, 10.4%<br />\n<br />\n是否容易搵到適合餐飲亦都係diverse嘅<br />\n由非常容易嘅20.9%, 之後係20.9%, 26.9%, 22.4%, 9%<br />\n<br />\n購物習慣方面...<br />\n比例同用膳習慣似乎好接近<br />\n會睇成份標籤嘅都係過半有53.7%<br />\n只買同一樣產品嘅有38.8%<br />\n問店員同人哋介紹都係11.9%<br />\n會去專門店嘅有11.9%<br />\n唔會理嘅就有26.9%<br />\n<br />\n買嘢時會留心成份嘅似乎都唔少人<br />\n由一定會睇嘅開始都有成19.4%, 之後就係34.3%, 22.4%, 9%, 14.9%<br />\n<br />\n容唔容易買到呢，似乎香港真係幾方便<br />\n23.9%覺得非常容易，之後就係35.8%, 25.4%, 7.5%, 7.5%<br />\n<br />\n<br />\n唔知做過問題嘅巴絲，你自己係屬於多數定少數呢？<br />\n再一次感謝大家<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n未做嘅，麻煩幫幫忙吖<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"https://goo.gl/forms/dZU4wzXs908ZKm5p1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgoo.gl%2Fforms%2FdZU4wzXs908ZKm5p1&d=4ca4e27lY2GGV30PmgtKiP%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=f176d16b\" target=\"_blank\">https://goo.gl/forms/dZU4wzXs908ZKm5p1</a>"},{"pid":"7bd3e4aada5f9d7f233257cc7bedf7d4b7454b12","tid":864454,"uid":216961,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-18T10:32:25.000Z","msg":"應承咗會繼續找數<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"}]}