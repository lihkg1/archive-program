\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n陳奕迅 <br />\n<br />\n愛情，幼稚<br />\n<br />\n<span style=\"color: red;\">刻骨銘心的 原來留在身邊不會愉快<br />\n使我愉快的 原來是我過去敷衍過的</span><br />\n一天一天躊躇 一點一點部署<br />\n<span style=\"color: red;\">最愛最終留不住 即使多麼在乎<br />\n不等於可相處 花光心血仍難被記住</span><br />\n<br />\n其實愛情幼稚 難道再沒更重要的事<br />\n難道眼淚會比苦笑容易<br />\n誰造愛情故事 誰又領會背後那真義<br />\n難道創造我的比我無知<br />\n<br />\n彷彿冥冥中 全情投入一般不會共對<br />\n一世共對的 常常是那身邊的小角色<br />\n必須瀟灑自如 必須懂得共處 愛意也許留得住<br />\n<br />\n不緊張不在乎 方可一生相處<br />\n心驚膽顫常常是偶遇<br />\n<br />\n其實愛情幼稚 難道再沒更重要的事<br />\n難道眼淚會比苦笑容易<br />\n誰造愛情故事 誰又領會背後那真義<br />\n難道創造我的比我無知<br />\n<br />\n其實愛情幼稚 難道再沒更重要的事<br />\n難道眼淚會比苦笑容易<br />\n誰造愛情故事 誰又證實世上有這種事<br />\n難道創造我的比我無知<br />\n<br />\n就係呢句令我覺得有身邊人未必係最愛嘅人嘅意思<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"}]}