gmoji\" />"},{"pid":"b534da28d3f5014a294de1e6329cea6a25028661","tid":1321773,"uid":33209,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T18:45:14.000Z","msg":"發夢係沙田見到條人鏈係斜路碌D水落去 咪撚玩啦五寶 下面D人點接呀"},{"pid":"26d6bd77260c48db7b5df5b4eaaea8ad94579dac","tid":1321773,"uid":98520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T18:46:57.000Z","msg":"琴晚發左個刻骨銘心既夢，想同大家分享一下<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1321643\" data-auto-link target=\"_blank\">https://lih.kg/1321643</a>"},{"pid":"4203dc00b9f384ff4e873307b8260966090eb4e4","tid":1321773,"uid":63017,"like":1,"dislike":0,"score":1,"quote":{"pid":"48a5b1547f3697141aadde37bff20560b777ea31","tid":1321773,"uid":44090,"like":2,"dislike":0,"score":2,"quote":{"pid":"c860ee177d5a94be5cf44224d4466337400520f0","tid":1321773,"uid":68483,"like":10,"dislike":0,"score":10,"citedBy":2,"replyTime":"2019-07-15T18:32:44.000Z","msg":"咁同兩條人鏈有咩分別？點解唔直接開兩條人鏈？<br />\n<br />\n<br />\n非駁嘴，智慧低求解釋"},"citedBy":1,"replyTime":"2019-07-15T18:38:42.000Z","msg":"有, 慳位<br />\n而家係兩條望住咁<br />\n中間留位<br />\n右圖方法一條龍可以做到而家做到既野"},"citedBy":0,"replyTime":"2019-07-15T18:48:34.000Z","msg":"你當用左TDMA既傅輸技術,令到同一條CHANNEL既傳輸量上升<br />\n但人既手長度有上限所以唔可以不停加傳輸量"},{"pid":"214c64234fdaeb5fdec630ba20e9c3edfb69f97c","tid":1321773,"uid":24332,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-07-15T18:49:16.000Z","msg":"每次見到人鏈都想講而家物資傳遞好無效率<br />\n第一個問題<br />\n人鏈逐個傳慢過直接拎住行上去好多<br />\n其實只要讓條夠闊嘅路就可以拎上去前線<br />\n直至行唔到先傳 <br />\n第二個問題<br />\n好多時物資重複傳上戰線A 令到戰線B唔夠<br />\n結果同樣嗰幾個頭盔其實一直來回AB咁傳<br />\n所以每次要物資講明數量好重要<br />\n尤其金鐘呢啲面積大 不同戰線距離遠嘅地方"},{"pid":"222220d64a39188c8ff34507a1c8082eb922fa01","tid":1321773,"uid":272971,"like":0,"dislike":0,"score":0,"quote":{"pid":"50053e85ad5a010d0529c6e0b3a6004533429d6f","tid":1321773,"uid":44090,"like":0,"dislike":0,"score":0,"quote":{"pid":"05f868d1fb5702f75df6e70ae983d937b1996136","tid":1321773,"uid":63017,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-15T18:19:57.000Z","msg":"我發夢夢到有物流業工人會用人鏈搬貨<br />\n但可能係初哥條人鏈排到好密搞到個效率低速度慢<br />\n因為由起點到終點要經過太多人既手所以慢<br />\n<br />\n今日就同大家討論人鏈搬貨效率<br />\n<img src=\"https://na.cx/i/tDphXdM.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FtDphXdM.png&h=715d4c04&s={SIZE}\" /><br />\n<br />\n大家會見到圖中間如果大家隔開D黎企人鏈所需人數下降而速度亦會加快,因為傳既次數少左<br />\n<br />\n而人鏈人數真係好足既話,可以跟圖右做<br />\n一半人望左一半人望右隔住企,咁條人鏈就可以左右同時搬貨速度加倍,例如可以左邊搬頭盔右邊搬口罩連分類工作都省返從而再提升效率"},"citedBy":1,"replyTime":"2019-07-15T18:39:18.000Z","msg":"認真呢個po要推<br />\n而家大家既人鏈好似係為左搵d野做而做咁sosad"},"citedBy":0,"replyTime":"2019-07-15T18:49:19.000Z","msg":"認同，發夢見到條鏈都接近人貼人<br />\n但依然有人想攝入嚟<br />\n雖則都明白每個人都想幫手<br />\n其實隔開一個手位企個效果已經差好遠<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"6882f782a9b427b1fa43e82b30dfc60d8621a94c","tid":1321773,"uid":213048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T18:51:00.000Z","msg":"推 第三張圖係幾好<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n唔好意思阻阻你<br />\n<a href=\"https://lih.kg/1321679\" data-auto-link target=\"_blank\">https://lih.kg/1321679</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"80c8f19f1b43f9a2adcedbe598f76400cef55ed6","tid":1321773,"uid":262342,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T18:51:07.000Z","msg":"同意！見到 714 人鏈太密反而手忙腳亂左"},{"pid":"2370f89f20a50bb3f51788785a65fce65021fc7a","tid":1321773,"uid":63017,"like":0,"dislike":0,"score":0,"quote":{"pid":"214c64234fdaeb5fdec630ba20e9c3edfb69f97c","tid":1321773,"uid":24332,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-07-15T18:49:16.000Z","msg":"每次見到人鏈都想講而家物資傳遞好無效率<br />\n第一個問題<br />\n人鏈逐個傳慢過直接拎住行上去好多<br />\n其實只要讓條夠闊嘅路就可以拎上去前線<br />\n直至行唔到先傳 <br />\n第二個問題<br />\n好多時物資重複傳上戰線A 令到戰線B唔夠<br />\n結果同樣嗰幾個頭盔其實一直來回AB咁傳<br />\n所以每次要物資講明數量好重要<br />\n尤其金鐘呢啲面積大 不同戰線距離遠嘅地方"},"citedBy":1,"replyTime":"2019-07-15T18:51:40.000Z","msg":"你無計到有重量,人搬唔行得快"},{"pid":"a04793c0b15cbb51bae6dd6a4fccb60f27d3f618