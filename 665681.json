環保慳紙，但申請就要交實體申請表<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4dfa630814461c5f8f61ad6305faaa8f5124f97c","tid":665681,"uid":117048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-15T13:13:47.000Z","msg":"此回覆已被刪除"},{"pid":"12e113974069a7451b74dceb4f71f0d18f87c784","tid":665681,"uid":117048,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-05-15T13:14:01.000Z","msg":"此回覆已被刪除"},{"pid":"7042dfb877c36778d8a080a350159a1f49e07acb","tid":665681,"uid":123308,"like":0,"dislike":0,"score":0,"quote":{"pid":"12e113974069a7451b74dceb4f71f0d18f87c784","tid":665681,"uid":117048,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-05-15T13:14:01.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2018-05-15T13:19:38.000Z","msg":"因為要公平，等唔識用電腦嘅人，例如老弱婦孺都可以申請"},{"pid":"1fb3d817a5ca8f529e3780d00ca0132f38914cf5","tid":665681,"uid":117048,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-05-15T13:23:13.000Z","msg":"此回覆已被刪除"},{"pid":"818f10d0be42abec19af50a3b9ff2844bddc321c","tid":665681,"uid":37856,"like":1,"dislike":0,"score":1,"quote":{"pid":"7042dfb877c36778d8a080a350159a1f49e07acb","tid":665681,"uid":123308,"like":0,"dislike":0,"score":0,"quote":{"pid":"12e113974069a7451b74dceb4f71f0d18f87c784","tid":665681,"uid":117048,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-05-15T13:14:01.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2018-05-15T13:19:38.000Z","msg":"因為要公平，等唔識用電腦嘅人，例如老弱婦孺都可以申請"},"citedBy":1,"replyTime":"2018-05-15T13:49:27.000Z","msg":"On9 又可以上網報又可以交form咪得"},{"pid":"0322e97d92ed5b0ebafc15ac8dd2a4c4fcda94e3","tid":665681,"uid":194143,"like":0,"dislike":0,"score":0,"quote":{"pid":"818f10d0be42abec19af50a3b9ff2844bddc321c","tid":665681,"uid":37856,"like":1,"dislike":0,"score":1,"quote":{"pid":"7042dfb877c36778d8a080a350159a1f49e07acb","tid":665681,"uid":123308,"like":0,"dislike":0,"score":0,"quote":{"pid":"12e113974069a7451b74dceb4f71f0d18f87c784","tid":665681,"uid":117048,"like":1,"dislike":0,"s