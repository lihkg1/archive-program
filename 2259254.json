/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"96291d8342a0266e084c97aad509ba5665124831","tid":2259254,"uid":119075,"like":0,"dislike":0,"score":0,"quote":{"pid":"66d932f4e5c4cdd76f10a4cd632969655d516c78","tid":2259254,"uid":234839,"like":0,"dislike":0,"score":0,"quote":{"pid":"27c6de09abbd984400cfa59d82313e614574e8b1","tid":2259254,"uid":119075,"like":0,"dislike":0,"score":0,"quote":{"pid":"53e169c6fbb9225488fb9019ad405d9d498e56c4","tid":2259254,"uid":234839,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-26T16:54:17.000Z","msg":"請問暫時有冇併發症？<br />\n因為佢糖尿都未控制到<br />\n所以好擔心就算同佢做完手術佢睇得返嘢<br />\n但又因為糖尿搞到其他地方發炎<br />\n又或者傷口埋唔到口咁"},"citedBy":1,"replyTime":"2020-10-26T17:05:22.000Z","msg":"岩岩做完手術果陣病情未穩定，出現過一次併發症，都係隻眼入面，要做多次手術。之後小心照顧佢，定時打針定時食野，一直到而家都冇出現過併發症，同正常狗狗一樣。<br />\n<br />\n我記得當時專科醫生同我地講，對眼做手術要快，否則對眼Ｄ神經壞哂就做唔到。不過唔肯定係咪隻隻狗同每個Case都一樣，所以都係問清楚醫生好Ｄ。"},"citedBy":1,"replyTime":"2020-10-26T17:07:43.000Z","msg":"做多次手術又六萬<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />？<br />\n如果要再俾多個六萬我真係冇<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-10-26T17:08:47.000Z","msg":"做多一次果次係１萬幾"},{"pid":"92807d9d367419e1be59a171ed722e9e7b845e47","tid":2259254,"uid":46309,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-26T17:09:24.000Z","msg":"人類都係咁，未聽過糖尿上眼？<br />\n糖尿病影響血管，進而影響眼、腎，心腦、手腳<br />\n命水黎"},{"pid":"ab6f8bea1b9bbe6665a5cf9281b38bef4ebefe34","tid":2259254,"uid":234839,"like":0,"dislike":0,"score":0,"quote":{"pid":"96291d8342a0266e084c97aad509ba5665124831","tid":2259254,"uid":119075,"like":0,"dislike":0,"score":0,"quote":{"pid":"66d932f4e5c4cdd76f10a4cd632969655d516c78","tid":2259254,"uid":234839,"like":0,"dislike":0,"score":0,"quote":{"pid":"27c6de09abbd984400cfa59d82313e614574e8b1","tid":2259254,"uid":119075,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-26T17:05:22.000Z","msg":"岩岩做完手術果陣病情未穩定，出現過一次併發症，都係隻眼入