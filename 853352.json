":0,"quote":{"pid":"9ade23b4e71837d2ec2c90bfc5adf2c7adfc45bf","tid":853352,"uid":55533,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-10-08T14:01:26.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://i.imgur.com/VPzWfjR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fi.imgur.com%2FVPzWfjR.jpg&h=4d36305b&s={SIZE}\" /><br />\n<img src=\"https://i.lihkg.com/540/https://i.imgur.com/DdJzqJQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fi.imgur.com%2FDdJzqJQ.jpg&h=9d07a426&s={SIZE}\" /><br />\n<img src=\"https://i.lihkg.com/540/https://i.imgur.com/JLHoKtu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fi.imgur.com%2FJLHoKtu.jpg&h=6865fa35&s={SIZE}\" />"},"citedBy":2,"replyTime":"2018-10-08T14:13:44.000Z","msg":"邊個"},"citedBy":0,"replyTime":"2018-10-08T14:16:09.000Z","msg":"回錯post<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7293406ef03ebe14f5d93ede45e8137a5a8c5cf7","tid":853352,"uid":103759,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-08T14:18:31.000Z","msg":"【廿度回購救不了】騰訊歐洲市低見294元！沈大師：最壞仲未出嚟<br />\n【更新歐美預託證券股價】<br />\n市況疲弱，人行放水、連續20日回購救不到股價，股王騰訊（700）今早跌穿300元大關，為2017年7月後首次，午後再失守300元。騰訊以全日最低位收市，報299元，跌2%，成交金額約67億元。<br />\n騰訊收市後再公布斥資3860萬港元回購12.8萬股公司股份，為連續第20日回購。<br />\n惟多次回購明顯未有作用，歐洲預託證券曾低見294.4元，美國預託證券開市同樣低見296.3元，較今日港股收市價再挫1.5%。<br />\n早已看淡騰訊的訊匯證券行政總裁沈振盈坦言，700「穿300」毫無懸念，他提醒投資者千萬不要撈貨，市場明顯反彈力量不夠，而且下月公布業績，市場普遍預期都不樂觀，「暫時唔掂得住！佢最壞嘅嘢都未出哂嚟！」<br />\n今早騰訊逼近300關口時，300元價位現700餘買盤掛單買入共約70萬股，涉資約2億元，惟「血肉長城」瞬間被消化。<br />\n午後隨即累積近千個買盤，約50萬股買盤待接貨，相當於1.5億元，亦快速沽盤質爆。<br />\n今早共有16隻牛證被打靶收回，其中有3隻牛證的回收價為300元，再對落的兩隻收回價299元的牛證力保不失，仍然死守。<br />\n<a href=\"https://hk.finance.appledaily.com/finance/realtime/article/20181008/58769297\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.finance.appledaily.com%2Ffinance%2Frealtime%2Farticle%2F20181008%2F58769297&d=4M1Ay0u2QmYh%2BS6rfY5nGjQ9OVC7k%2FvddpU5ARN7O10%3D&h=3d7e79f0\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.finance.appledaily.com%2Ffinance%2Frealtime%2Farticle%2F20181008%2F58769297&h=064a282a\" data-auto-link target=\"_blank\">https://hk.finance.appledaily.com/finance/realtime/article/20181008/58769297</a>"},{"pid":"d14b7347228056a62d4e623db38afb09c4b3f753","tid":853352,"uid":103799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-08T14:19:28.000Z","msg":"17歲那日不要臉，痾左兩督屎"},{"pid":"28bf416ec92b239956f45eb494b84c9bc2848773","tid":853352,"uid":103759,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-08T14:40:16.000Z","msg":"推"},{"pid":"de7d96767b4e2b8ee46aa07acad900beaf161f47","tid":853352,"uid":146621,"like":0,"dislike":0,"score":0,"quote":{"pid":"ea7d6c661aaff3547f45098646396f0fd07f3aac","tid":853352,"uid":48334,"like":0,"dislike":0,"score":0,"quote":{"pid":"9ade23b4e71837d2ec2c90bfc5adf2c7adfc45bf","tid":853352,"uid":55533,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-10-08T14:01:26.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://i.imgur.com/VPzWfjR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fi.imgur.com%2FVPzWfjR.jpg&h=4d36305b&s={SIZE}\" /><br />\n<img src=\"https://i.lihkg.com/540/https://i.imgur.com/DdJzqJQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fi.imgur.com%2FDdJzqJQ.jpg&h=9d07a426&s={SIZE}\" /><br />\n<img src=\"https://i.lihkg.com/540/https://i.imgur.com/JLHoKtu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fi.imgur.com%2FJLHoKtu.jpg&h=6865fa35&s={SIZE}\" />"},"citedBy":2,"replyTime":"2018-10-08T14:13:44.000Z","msg":"邊個"},"citedBy":0,"replyTime":"2018-10-08T16:46:16.000Z","msg":"我條女熊熊<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"}]}