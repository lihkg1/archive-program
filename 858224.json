" />"},{"pid":"083db018ad00967070307a43042f0bcf4adfdf72","tid":858224,"uid":208722,"like":4,"dislike":2,"score":2,"quote":{"pid":"352dc9101893deb39fac95be368c2ff9ae5c310b","tid":858224,"uid":32765,"like":3,"dislike":25,"score":-22,"citedBy":4,"replyTime":"2018-10-11T15:48:31.000Z","msg":"共產黨少數德政<br />\n根絕穆斯林狗<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-11T19:21:08.000Z","msg":"如果支那人嚟你屋企趕你屋企人走，你係咪都會話「德政，根絕港豬」？"},{"pid":"e164b9c2dc6fc1a620b3a7a3e47f810e9c3a9f70","tid":858224,"uid":60545,"like":5,"dislike":2,"score":3,"quote":{"pid":"352dc9101893deb39fac95be368c2ff9ae5c310b","tid":858224,"uid":32765,"like":3,"dislike":25,"score":-22,"citedBy":4,"replyTime":"2018-10-11T15:48:31.000Z","msg":"共產黨少數德政<br />\n根絕穆斯林狗<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-11T19:26:16.000Z","msg":"屌你老母<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"},{"pid":"e42ec0a9593b9f77381096033b95ddf2a9717f6b","tid":858224,"uid":97537,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-10-11T19:26:43.000Z","msg":"咁搞法會唔會引到isis塔利班果啲搞下中國<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0a2d9623b45127cb6395ebd806b2f0e5f81df384","tid":858224,"uid":57677,"like":0,"dislike":0,"score":0,"quote":{"pid":"352dc9101893deb39fac95be368c2ff9ae5c310b","tid":858224,"uid":32765,"like":3,"dislike":25,"score":-22,"citedBy":4,"replyTime":"2018-10-11T15:48:31.000Z","msg":"共產黨少數德政<br />\n根絕穆斯林狗<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-11T20:19:31.000Z","msg":"近排 child登小左反回"},{"pid":"b60d2116889afbdb907aa8c3eabc749af956f416","tid":858224,"uid":205530,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-11T20:33:53.000Z","msg":"此回覆已被刪除"},{"pid":"e26af7bb1beaf9012bd17e44429f55011868a9cc","tid":858224,"uid":97240,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-11T22:03:07.000Z","msg":"返勞改營都唔俾<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f0d6e7a1920ea42ef50a86208c64f4f412027c32","tid":858224,"uid":2757,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-11T22:22:36.000Z","msg":"今日新疆， 明日大..."},{"pid":"37851b63583f187643c2c65a436e03e22d075309","tid":858224,"uid":69924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-11T23:44:49.000Z","msg":"唔怕南亞人"},{"pid":"032c4bc403e1a4a8842ae9fa5943152def7c9a53","tid":858224,"uid":32765,"like":0,"dislike":0,"score":0,"quote":{"pid":"083db018ad00967070307a43042f0bcf4adfdf72","tid":858224,"uid":208722,"like":4,"dislike":2,"score":2,"quote":{"pid":"352dc9101893deb39fac95be368c2ff9ae5c310b","tid":858224,"uid":32765,"like":3,"dislike":25,"score":-22,"citedBy":4,"replyTime":"2018-10-11T15:48:31.000Z","msg":"共產黨少數德政<br />\n根絕穆斯林狗<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-11T19:21:08.000Z","msg":"如果支那人嚟你屋企趕你屋企人走，你係咪都會話「德政，根絕港豬」？"},"citedBy":0,"replyTime":"2018-10-12T00:06:35.000Z","msg":"回狗理應同支那人一樣係地球消失"},{"pid":"c513c2f743a3c933efebbed3881ba28b067a9ec2","tid":858224,"uid":52595,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-10-12T00:10:32.000Z","msg":"此回覆已被刪除"},{"pid":"3f52da7a1935885e7407f64718290e3b586d218c","tid":858224,"uid":39710,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-10-12T00:15:37.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />係強国講宗教自由"},{"pid":"01fd7bc0df0ec371baf5abbeda81a86a3e5172ef","tid":858224,"uid":53705,"like":3,"dislike":0,"score":3,"quote":{"pid":"e42ec0a9593b9f77381096033b95ddf2a9717f6b","tid":858224,"uid":97537,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-10-11T19:26:43.000Z","msg":"咁搞法會唔會引到isis塔利班果啲搞下中國<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-12T10:47:59.000Z","msg":"英報告：ISIS的武器近半數來自中國 ..<br />\n<a href=\"http://news.dwnews.com/global/big5/news/2018-01-03/60033306.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.dwnews.com%2Fglobal%2Fbig5%2Fnews%2F2018-01-03%2F60033306.html&d=S3g4AnO7PRlVnxLeX1kOmJZgE6vMW1KEzMhkvokIvkY%3D&h=13d3f7ed\" target=\"_blank\">http://news.dwnews.com/global/big5/news/2018-01-03/60033306.html</a><br />\n<br />\n英國Conflict Armament Research 針對恐怖組織&ldquo;伊斯蘭國&rdquo;（ISIS）的武器來源進行了3年研究，發現其中90%的武器及軍事裝備來自中國和其它前共產黨國家，而高達43.5%是中國制造。 ..<br />\n<br />\n<br />\n沒事兒, 沒事兒, 自己人<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"2c618a898ee57c2088b9d52ad67e2746ff95c74d","tid":858224,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-13T01:46:39.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}