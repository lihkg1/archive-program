:22.000Z","msg":"最緊要睇下實力夠唔夠姐，兩個都夠緊係無問題，但依家個問題就係。。。。。"},"citedBy":1,"replyTime":"2019-03-18T13:40:24.000Z","msg":"有個淨係屈一隊波<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cbc51d8ecef52d750ee854ee6b7fd6389cd535ff","tid":1065973,"uid":25831,"like":0,"dislike":7,"score":-7,"citedBy":0,"replyTime":"2019-03-18T13:42:42.000Z","msg":"此回覆已被刪除"},{"pid":"a5452466927daa5062951850de01219e2e050b70","tid":1065973,"uid":25831,"like":4,"dislike":6,"score":-2,"citedBy":1,"replyTime":"2019-03-18T13:44:24.000Z","msg":"此回覆已被刪除"},{"pid":"117c9bd3f9eef13c5ac9c940e46a28714fd295f7","tid":1065973,"uid":134997,"like":3,"dislike":22,"score":-19,"citedBy":0,"replyTime":"2019-03-18T13:45:06.000Z","msg":"梗唔唔得啦<br />\n<br />\n我地朗迷最有記性<br />\n一句tap in唔計記足一世（一年前）<br />\n而我地牙朗又識摸JJ玩報復<br />\n既然係咁 我地高質朗迷都要做怨婦<br />\n唔計美斯！！！<br />\n<br />\nquote返我朗球迷高質留言<br />\n尾欺狗無碇企<br />\n<img src=\"https://na.cx/i/JZrnMrj.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJZrnMrj.png&h=b691b99e&s={SIZE}\" /><img src=\"https://na.cx/i/6DK1hx0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6DK1hx0.png&h=a290b9ef&s={SIZE}\" /><img src=\"https://na.cx/i/BKTQVjG.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBKTQVjG.png&h=0ae2f4c4&s={SIZE}\" /><img src=\"https://na.cx/i/yEYaaS1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyEYaaS1.png&h=c0adba00&s={SIZE}\" /><br />\n<br />\n（18/3 西甲 第28輪 皇家貝迪斯(1) vs 巴塞隆拿(4) 美斯hat trick）<br />\nfreekick屌入死角唔計<br />\n靠隊友tap in唔計<br />\n臨完場無力chip射-6西入咗唔計<br />\n貝迪斯（西甲第八）下三流球隊唔計<br />\nhat trick 唔計<br />\n西甲唔計<br />\n勁到對面拍手唔計<br />\n<br />\n（14/3 歐冠 16強淘汰賽 次回合 巴塞隆拿(5) vs 里昂(1) 美斯2g2a）<br />\n12碼唔計<br />\n里昂（贏一和一宇宙鏝）唔計<br />\n助攻唔計<br />\n上帝視角助攻-6唔計<br />\n射12碼腳仔軟無力先chip射唔計<br />\n扭到兩個後衛仆街weak foot射入-6唔計<br />\n唔係反超唔計<br />\n順風波我地呀朗totally no mood to 射<br />\n<img src=\"https://na.cx/i/cjd11Su.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fcjd11Su.gif&h=1292ebf0&s={SIZE}\" /><br />\n無不雅動作摸JJ報復唔計<br />\n老婆無喊唔計！！！<br />\n<br />\n總結：<br />\n唔係淘汱賽唔計（三年前）<br />\n巴塞有小白沙維唔計（十年前）<br />\n國家隊無冠唔計（六年前）<br />\n世杯亞軍世杯金球唔計（五年前）<br />\n眼神唔夠堅決唔計（兩年前）<br />\n忠誠唔計 係唔敢接挑戰嘅懦夫！<br />\n總之唔撚俾計<br />\n我地成熟朗迷眼神堅定 不平則鳴<br />\n幾時都話我地唔係針對美斯 只係針對球迷<br />\n所以世杯16強對冠軍基機 半單刀射失 <br />\n退出國家隊 省球迷飲可樂 屋企食lays <br />\n亞軍x3 老婆俾綠帽先計<br />\n我朗先係世一兼歷屎最佳<br />\n就算佢啦啦隊奪冠 屌屁眼 強姦 搶隊友入波 黑隊友面都計！<br />\n頂多係讓半個位俾你一齊做逃稅雙嬌<br />\n我朗好波 我朗舒服 我朗威武！"},{"pid":"b0c3538d098a94f2c15bcfe9091ec1db5721ae35","tid":1065973,"uid":10392,"like":11,"dislike":5,"score":6,"quote":{"pid":"a5452466927daa5062951850de01219e2e050b70","tid":1065973,"uid":25831,"like":4,"dislike":6,"score":-2,"quote":{"pid":"e51ba1aec8da7cc5dd95f921e75db17f5ee3ef95","tid":1065973,"uid":10392,"like":5,"dislike":5,"score":0,"quote":{"pid":"f1c8d4d24a79434e97cfb107a0cb932ce52528b3","tid":1065973,"uid":90515,"like":4,"dislike":3,"score":1,"citedBy":1,"replyTime":"2019-03-17T16:02:22.000Z","msg":"最緊要睇下實力夠唔夠姐，兩個都夠緊係無問題，但依家個問題就係。。。。。"},"citedBy":1,"replyTime":"2019-03-18T13:40:24.000Z","msg":"有個淨係屈一隊波<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-18T13:44:24.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2019-03-18T13:50:47.000Z","msg":"<img src=\"https://na.cx/i/jVnRGx9.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjVnRGx9.png&h=9388ef69&s={SIZE}\" /><br />\n係<br />\n另一個影都見唔到<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"846c02169fc9964fa59a75372747790569bbd02d","tid":1065973,"uid":25831,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-03-18T13:51:11.000Z","msg":"此回覆已被刪除"},{"pid":"2f3aa9abe3d40b81f954b39fc681ade671982af0","tid":1065973,"uid":10392,"like":0,"dislike":0,"score":0,"quote":{"pid":"846c02169fc9964fa59a75372747790569bbd02d","tid":1065973,"uid":25831,"like":0,"dislike":0,"score":0,"quote":{"pid":"b0c3538d098a94f2c15bcfe