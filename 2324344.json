ited said."},{"pid":"f93aa9eb4a005d575c210fa47d3b06376a03e8fd","tid":2324344,"uid":161374,"like":0,"dislike":1,"score":-1,"quote":{"pid":"2e45faa04cded7f93fd8be4a6a6c95188fd1b1a6","tid":2324344,"uid":180156,"like":3,"dislike":1,"score":2,"citedBy":3,"replyTime":"2020-12-14T01:29:01.000Z","msg":"強貼 留名<br />\n已all in航空<br />\n上星期五唔知仲乜跌<br />\n今個星期無理由仲唔升<br />\n好似話第2隻疫苗都準備要批<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-14T02:32:26.000Z","msg":"美國人最憎打疫苗，有冇諗過肺炎最後都係唔會完？"},{"pid":"8af925197cc508f5308c548b7703dbcd5f93e6e4","tid":2324344,"uid":310914,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2020-12-14T02:33:53.000Z","msg":"1/3倉 C, +3X%<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a17aa2d9b51633305d777f4fbca219b36a9a58bf","tid":2324344,"uid":310914,"like":0,"dislike":1,"score":-1,"quote":{"pid":"8af925197cc508f5308c548b7703dbcd5f93e6e4","tid":2324344,"uid":310914,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2020-12-14T02:33:53.000Z","msg":"1/3倉 C, +3X%<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-14T02:36:47.000Z","msg":"等上返70<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"496539f4111f2172308000f6f69fbb83cfedfdda","tid":2324344,"uid":139450,"like":0,"dislike":1,"score":-1,"quote":{"pid":"8af925197cc508f5308c548b7703dbcd5f93e6e4","tid":2324344,"uid":310914,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2020-12-14T02:33:53.000Z","msg":"1/3倉 C, +3X%<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-14T02:38:43.000Z","msg":"唔係2800<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"cacfa116ab746c401411203525e82cb4acf4722b","tid":2324344,"uid":310914,"like":0,"dislike":1,"score":-1,"quote":{"pid":"496539f4111f2172308000f6f69fbb83cfedfdda","tid":2324344,"uid":139450,"like