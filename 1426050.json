tid":1426050,"uid":60686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T01:22:29.000Z","msg":"宜家就係警察=法律。"},{"pid":"4094724223ad29b1f12978ad7d10015e4fb6a9ca","tid":1426050,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T01:58:47.000Z","msg":"push"},{"pid":"c247efb7f0457ef4d0a054eef1db2c58f3f03814","tid":1426050,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T02:05:26.000Z","msg":"push"},{"pid":"27e19c74994329f890e5aa2528c0115b23a277da","tid":1426050,"uid":59037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T02:09:54.000Z","msg":"好文，真心幫到手"},{"pid":"aaa74d1fe7f4acd4652ae29db723c07fcfc10a9a","tid":1426050,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T03:33:20.000Z","msg":"push"},{"pid":"353f87c85f51cf000e8476ac73380706e80bac8c","tid":1426050,"uid":28397,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T03:46:17.000Z","msg":"告唔入 但係可以搞鳩你 司法騷擾"},{"pid":"0bebf0c37debcbdbc4af797f848d51c22d76274b","tid":1426050,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T06:09:23.000Z","msg":"push"},{"pid":"fe976cb856cd538b0f37db7fe944d9265846f171","tid":1426050,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T09:04:52.000Z","msg":"push"}]}