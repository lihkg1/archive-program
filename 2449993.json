al/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b73aefeb2a2a7d6fb059b4503ff73a9295e4a549","tid":2449993,"uid":232157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-17T05:45:45.000Z","msg":"推<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"f19eccb95f51a523a11ae21602a65380b7a073a0","tid":2449993,"uid":167163,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-17T05:54:05.000Z","msg":"Push"},{"pid":"c6e906fbc9a1fe630b4c566f81122470ff353bf9","tid":2449993,"uid":98431,"like":0,"dislike":1,"score":-1,"quote":{"pid":"d50b08d5a76832440143e15cae7cba740cb1c1c6","tid":2449993,"uid":8014,"like":3,"dislike":4,"score":-1,"citedBy":3,"replyTime":"2021-03-17T05:40:29.000Z","msg":"最後要賠番十萬比黨鐵<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n咁當初做咩要咁衝動<img src=\"/assets/faces/cow/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-17T05:57:40.000Z","msg":"支那玩爛左香港 無得做白手套 點解咁衝動<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"9f2d93e3e987ee73e22fef72eb366aa141dee5eb","tid":2449993,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-17T06:03:41.000Z","msg":"網民前年 11 月 2 日在尖沙咀發起集會，警民衝突深夜蔓延至旺角。20 歲調酒師被指在街頭焚燒雜物，今（17 日）在區域法院承認暴動罪，餘下縱火及違反《蒙面法》兩罪，獲控方同意不予起訴存檔法庭。法官祁士偉聽畢辯方求情，押後案件至 3 月 31 日判刑，索取背景及教導所報告。被告須還押，步入囚室前向親友揮手及做心心手勢，旁聽人士亦揮手回應。<br />\n<br />\n辯方續指被告初犯、年輕及善良，案發時只有 19 歲。被告父母從小不在身邊，在破碎家庭長大，一直與祖父母同住，今次因一時衝動犯案，希望之後仍能照顧他們及重拾學業。法官祁士偉聽畢求情，將案件押至 3 月 31 日判刑，索取背景及教導所報告，期間被告要還押。<br />\n<br />\n<a href=\"https://www.thestandnews.com/court/11-3-%E6%97%BA%E8%A7%92-20-%E6%AD%B2%E8%AA%BF%E9%85%92%E5%B8%AB%E8%AA%8D%E6%9A%B4%E5%8B%95%E7%BD%AA%E9%82%84%E6%8A%BC%E5%80%99%E5%88%A4-%E6%AD%A5%E5%85%A5%E5%9B%9A%E5%AE%A4%E5%89%8D%E5%90%91%E8%A6%AA%E5%8F%8B%E5%81%9A%E5%BF%83%E5%BF%83%E6%89%8B%E5%8B%A2/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F11-3-%25E6%2597%25BA%25E8%25A7%2592-20-%25E6%25AD%25B2%25E8%25AA%25BF%25E9%2585%2592%25E5%25B8%25AB%25E8%25AA%258D%25E6%259A%25B4%25E5%258B%2595%25E7%25BD%25AA%25E9%2582%2584%25E6%258A%25BC%25E5%2580%2599%25E5%2588%25A4-%25E6%25AD%25A5%25E5%2585%25A5%25E5%259B%259A%25E5%25AE%25A4%25E5%2589%258D%25E5%2590%2591%25E8%25A6%25AA%25E5%258F%258B%25E5%2581%259A%25E5%25BF%2583%25E5%25BF%2583%25E6%2589%258B%25E5%258B%25A2%2F&d=JW7tglSI9GVP0ZLjrScixTcZFjLth35g1vO%2BxS%2F2N%2Fg%3D&h=61e17afd\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F11-3-%25E6%2597%25BA%25E8%25A7%2592-20-%25E6%25AD%25B2%25E8%25AA%25BF%25E9%2585%2592%25E5%25B8%25AB%25E8%25AA%258D%25E6%259A%25B4%25E5%258B%2595%25E7%25BD%25AA%25E9%2582%2584%25E6%258A%25BC%25E5%2580%2599%25E5%2588%25A4-%25E6%25AD%25A5%25E5%2585%25A5%25E5%259B%259A%25E5%25AE%25A4%25E5%2589%258D%25E5%2590%2591%25E8%25A6%25AA%25E5%258F%258B%25E5%2581%259A%25E5%25BF%2583%25E5%25BF%2583%25E6%2589%258B%25E5%258B%25A2%2F&h=aaa1b872\" data-auto-link target=\"_blank\">https://www.thestandnews.com/court/11-3-%E6%97%BA%E8%A7%92-20-%E6%AD%B2%E8%AA%BF%E9%85%92%E5%B8%AB%E8%AA%8D%E6%9A%B4%E5%8B%95%E7%BD%AA%E9%82%84%E6%8A%BC%E5%80%99%E5%88%A4-%E6%AD%A5%E5%85%A5%E5%9B%9A%E5%AE%A4%E5%89%8D%E5%90%91%E8%A6%AA%E5%8F%8B%E5%81%9A%E5%BF%83%E5%BF%83%E6%89%8B%E5%8B%A2/</a>"},{"pid":"2eb44446d7fedcd15f682c04f12dac289c9de34a","tid":2449993,"uid":260121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-17T06:16:11.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"8513110a9e59c9bbebc803fd70d9b975e15f093c","tid":2449993,"uid":133033,"like":0,"dislike