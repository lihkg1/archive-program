u5ewj.cloudfront.net%2Fmedia%2Fimage%2F2016%2F04%2Fb2dc1ef84e714f6ca195bd7a5e5f745f.jpg%3FimageView2%2F1%2Fw%2F1080%2Fh%2F721%2Fformat%2Fjpg&h=7fe77e83&s={SIZE}\" /><br />\n<a href=\"https://theinitium.com/article/20160419-hongkong-language/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftheinitium.com%2Farticle%2F20160419-hongkong-language%2F&d=vZD5F7UP5hTchfQ0RLCDF5ZgE6vMW1KEzMhkvokIvkY%3D&h=12fa0107\" data-auto-link target=\"_blank\">https://theinitium.com/article/20160419-hongkong-language/</a>"},{"pid":"1ef7266d7aee0517c2779156e2b9cb569a20c735","tid":889524,"uid":128761,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-11-04T16:08:03.000Z","msg":"計中國/台灣/澳門出生人口/人口百分比<br />\n*因為澳門/台灣出世人口應該只佔好少，所以可忽略<br />\n<img src=\"http://i.imgur.com/LQ4GkWH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi.imgur.com%2FLQ4GkWH.jpg&h=0164c375&s={SIZE}\" /><br />\n最多香港人百分比排名<br />\n1. 南區<br />\n2. 灣仔<br />\n3. 大埔<br />\n4. 中西區<br />\n5. 離島<br />\n<br />\n最少中國/台灣/澳門出世人口<br />\n1. 灣仔<br />\n2. 離島<br />\n3. 南區<br />\n4. 中國<br />\n5. 大埔<br />\n<br />\n<br />\n如果計多中國遊客旺點<br />\n灣仔/中國/離島都失守埋<br />\n所以全香港最少中國人既地區應該得返大埔同南區<br />\n<br />\n大埔本身上有北區下有沙田，再加上市中心離火車站遠，地理優越<br />\n不過開始多蝗仔返學，失守指日可待<br />\n南區本身都係上有灣仔中西區，而且都唔係傳統旅遊地區，地理優越<br />\n不過海洋公園長期多中國遊客，失守指日可待"},{"pid":"2b6630089a34747f34ef55ea76354d6b4965e2cb","tid":889524,"uid":128761,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-11-04T16:09:13.000Z","msg":"SORRY，連續兩次將中西區打做中國<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"2c44009416ad096fc7d37f6b3e629b718c778151","tid":889524,"uid":139228,"like":1,"dislike":0,"score":1,"quote":{"pid":"89c7f93cc16e370f5b636ccda83fb07c30c501a4","tid":889524,"uid":158613,"like":0,"dislike":0,"score":0,"quote":{"pid":"26712a93ece913da38fff5f576d061fa0a62b7ec","tid":889524,"uid":139228,"like":0,"dislike":0,"score":0,"quote":{"pid":"7d9e4ec8f0b18983887095d7e5f637d638e2e07c","tid":889524,"uid":158613,"like":1,"dislike":0,"score":1,