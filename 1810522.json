853e5daa22a0af4275c6b200293fdcc807c06","tid":1810522,"uid":55257,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2020-01-04T04:45:46.000Z","msg":"可以減少廢老數量<img src=\"/assets/faces/pigxm/cook.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-04T06:13:57.000Z","msg":"Based on data received by WHO to date, the case fatality ratio is estimated to be less than 1% in persons aged 24 years or younger, 6% in persons aged 25 to 44 years, 15% in persons aged 45 to 64 years, and greater than 50% in persons aged 65 years and older.<br />\n<br />\n根據世衛統計 SARS 24歲或以下先得1% 65歲或以上死亡率去到50%<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"71066b892523d66980cd500e60ce95ed5745cab6","tid":1810522,"uid":30791,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-04T08:53:59.000Z","msg":"<img src=\"/assets/faces/pigxm/sick.gif\" class=\"hkgmoji\" />"},{"pid":"02f620f33d44e7f5998b89632433b8b8287f311c","tid":1810522,"uid":30791,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-04T14:37:47.000Z","msg":"<img src=\"/assets/faces/pigxm/sick.gif\" class=\"hkgmoji\" />"},{"pid":"92efc0679b18fa0798dfaf5b8924b6996c92cc1d","tid":1810522,"uid":30791,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-05T14:18:18.000Z","msg":"<img src=\"/assets/faces/pigxm/sick.gif\" class=\"hkgmoji\" />"},{"pid":"c968e8ab76da6464cc1a0eed77388be3dff17c45","tid":1810522,"uid":194532,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-05T14:24:08.000Z","msg":"<img src=\"/assets/faces/pigxm/wail.gif\" class=\"hkgmoji\" />"},{"pid":"3e1cfeb76eeabdc94cae4c8fa7a280f90382532c","tid":1810522,"uid":30791,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-06T01:23:47.000Z","msg":"<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" />"},{"pid":"070878089f106b0e7549aa64366758216a6cfe27","tid":1810522,"uid":30791,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-06T13:01:48.000Z","msg":"<img src=\"/assets/fa