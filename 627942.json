=https%3A%2F%2Fholland.pk%2Fglz4wv1u&h=16ccb09e&s={SIZE}\" /><br />\n<img src=\"https://holland.pk/9hr7o1e8\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2F9hr7o1e8&h=e23942ab&s={SIZE}\" />"},{"pid":"276a191af0c9e0a71873f2a324a4f5953469fec8","tid":627942,"uid":30067,"like":1,"dislike":6,"score":-5,"quote":{"pid":"495ffb7392f9a44d6e5022523b41562f955a5e3a","tid":627942,"uid":57308,"like":18,"dislike":4,"score":14,"citedBy":2,"replyTime":"2018-04-13T12:34:31.000Z","msg":"大陸機過2千已經戇鳩<br />\n唔係平買你做乜撚"},"citedBy":0,"replyTime":"2018-04-14T03:58:03.000Z","msg":"其實買大陸機已經戇鳩"},{"pid":"1186bcd6695b585d3585421992b24ca68353ff4a","tid":627942,"uid":52215,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-14T04:15:35.000Z","msg":"有冇NFC?"},{"pid":"637f39fd5cca73a702c937c2f092ddb8880ca65c","tid":627942,"uid":5399,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-04-14T05:35:43.000Z","msg":"<a href=\"https://chinese.engadget.com/2018/04/13/xiaomi-blackshark-gaming-phone/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fchinese.engadget.com%2F2018%2F04%2F13%2Fxiaomi-blackshark-gaming-phone%2F&d=Voc7XZDaq3ERB9ldoR2bIY9%2BoveFa0K0Z8Wn6wXPu4k%3D&h=2a39c97e\" target=\"_blank\">https://chinese.engadget.com/2018/04/13/xiaomi-blackshark-gaming-phone/</a><br />\n<br />\n<br />\n<br />\n雖然遊戲筆電小米是選擇了自己來做，但對於遊戲手機這個更小眾一點的品類，他們最終選擇的策略是相對穩妥些的投資。而在今天，跟他們合作的黑鯊終於拿出了自己的第一款產品：黑鯊遊戲手機。從外觀來看它的正面跟普通手機的分別並不大，差異主要在專門針對遊戲時握持手感優化的背蓋。其隆起的部分來得更高，表面也增加了防滑用的紋路。而且在天線的設計上，廠方也特意做成了 X 的形狀，聲稱這種方案能最大可能地避免手持時對訊號的干擾。<br />\n<br />\n除此之外，在後蓋中心的位置也有黑鯊 Logo 造型的呼吸燈。它除了能顯示通知以外，還有根據遊戲內容閃爍的裝飾功能。機身整體的底色為黑色，輔以玩家熟悉的綠色做點綴（咦？），不過根據廠方的說法，後續還會有灰色的版本推出。值得一提的是，在螢幕上方的聽筒位置黑鯊也放進了一顆麥克風（別的地方還有兩顆），以確保用戶在遊戲時能夠清晰通話。另外在螢幕的下方也出現了實體按鍵，指紋模組並沒因為顯示面板拉長到 18:9 而做後置的處理。<br />\n<br />\n<br />\n規格的部分，黑鯊遊戲手機毫無意外搭載了高通最新的 Snapdragon 845 晶片。為了確保能在遊戲時保持效能輸出，廠方也在裝置內放入了導管採用液冷方案來加強散熱。與此同時，5.99 吋的 2,160 x 1,080 螢幕在獨立圖像處理晶片的加持下，能憑藉 MEMC 運動補償技術清除動態畫面中的殘影。面板本身的對比度是 1,500:1，最大亮度為 550 尼特，而且還支援 DCI-P3 色域。另外這款手機也配備了雙喇叭和適用於 QC 3.0 快速充電的 4,000mAh 電池。相機的部分前面是 20MP 的感光器，後面則是 12MP + 20MP 的 CMOS 組合。<br />\n<br />\n而在系統方面，手機預載的 Joy UI 是黑鯊和 MIUI 的團隊共同打造。除了防打擾、遊戲內快速設定等常規特性外，在系統內你也可以直接用到多項小米的服務。至於一定要有的控制器配件，黑鯊拿出來的是一個單邊式的手把（同類型的設計市場中其實也有）。它可以「一秒拆裝」，上面有搖桿和兩顆自訂按鍵。之所以只做一邊，是為了「打破手把和觸控螢幕的邊界」，讓玩家在遊戲時可以按需進行不同的操作。<br />\n<br />\n<br />\n黑鯊遊戲手機會分為 6GB RAM + 64GB 儲存和 8 + 128 兩個版本，售價分別是人民幣 2,999（約 HK$3,750 / NT$14,000）和 3,499 元（約 HK$4,370 / NT$16,330）。手把單賣是 179 人民幣（約 HK$220 / NT$840），前五萬名購買手機的用戶將免費贈送。產品今晚六點起在米家和京東的平台上接受預訂，4 月 20 日正式開賣。"},{"pid":"ee10c6c0ef661f4833eb16b98060309f5fdca638","tid":627942,"uid":141060,"like":5,"dislike":4,"score":1,"citedBy":0,"replyTime":"2018-04-14T05:55:43.000Z","msg":"哩部其實幾正，最平845機 硬件頂級加大電  送埋手制，淨用黎打機其實幾抵玩"},{"pid":"b2b152f188314f02e16a44fb42fadb0f1e3de016","tid":627942,"uid":20658,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2018-04-14T08:09:34.000Z","msg":"小米mix2s定呢部快啲？"},{"pid":"fb9547dc9d3e5c559392763f4e62db9e3fd5ada3","tid":627942,"uid":165404,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2018-04-14T09:29:37.000Z","msg":"睇配置有d心動，但唔知個電夠玩幾耐<br />\n同埋大陸機最驚d後台唔知會撈走咩資料出去"}]}