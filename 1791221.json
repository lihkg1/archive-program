nt%3Dall%26itm_medium%3Dweb&d=Wr%2FXdV%2FekiVpClOitW4NQQoLTLCpuPbPc66RZsxrzrI%3D&h=6510ea97\" data-auto-link target=\"_blank\">https://www.hk01.com/%E5%8D%B3%E6%99%82%E5%9C%8B%E9%9A%9B/412650/%E5%8D%B0%E5%BA%A6%E5%8F%8D-%E5%85%AC%E6%B0%91%E8%BA%AB%E4%BB%BD%E6%B3%95-%E4%BF%AE%E6%AD%A3%E6%A1%88%E7%A4%BA%E5%A8%81%E5%85%A8%E5%9C%8B%E5%A2%9E%E8%87%B314%E6%AD%BB-%E8%8E%AB%E8%BF%AA%E5%8F%AC%E9%83%A8%E9%95%B7%E9%96%8B%E6%9C%83?itm_source=universal_search&amp;itm_campaign=universal_search&amp;itm_content=all&amp;itm_medium=web</a><br />\n<br />\n印度都吹奏 咁不如支持埋香港警察<img src=\"/assets/faces/dogxm/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"dcadd55d38118ba7a284978381605caf359498a5","tid":1791221,"uid":75193,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-22T11:51:30.000Z","msg":"但都係繼續鴻海"},{"pid":"be9a1cab7734676bb2d5f032415d2447f06818ba","tid":1791221,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-22T12:34:51.000Z","msg":"<img src=\"/assets/faces/pigxm/wine.gif\" class=\"hkgmoji\" />"},{"pid":"d510231acd4c2b565084c0eb8c898ca4d54ddffd","tid":1791221,"uid":200495,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-22T12:42:30.000Z","msg":"咖哩味iPhone <img src=\"/assets/faces/lm2xm/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2xm/jable.gif\" class=\"hkgmoji\" />"}]}