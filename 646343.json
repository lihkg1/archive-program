b716de47df495942f3e792cd6cde9f851df4","tid":646343,"uid":8876,"like":0,"dislike":0,"score":0,"quote":{"pid":"b45ded4510b68faab6b8a95f23c7772b4bcdd94b","tid":646343,"uid":175112,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T05:36:47.000Z","msg":"1個月減左十幾磅"},"citedBy":1,"replyTime":"2018-04-29T12:54:47.000Z","msg":"每星期做幾多次 每次幾耐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-29T13:16:40.000Z","msg":"<a href=\"https://youtu.be/cZnsLVArIt8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FcZnsLVArIt8&d=%2B9OPQEDzr2OMqe7q0QsGlJWUQYxlHU4vp7GM3pu%2FB4U%3D&h=54fd4a61\" data-auto-link target=\"_blank\">https://youtu.be/cZnsLVArIt8</a><br />\n<br />\n平均一星期做4次 <br />\n但點都好 搞好左飲食先 <br />\n戒糖 戒高脂食物 減澱粉<br />\n<br />\n簡單例子 <br />\n早餐 蕉/蘋果 加 麥皮<br />\n午餐 譚仔雞肉/豬肉清湯 檸茶走甜<br />\n晚餐 吉野家煎雞飯唔食皮走汁 <br />\n<br />\n你食到咁清淡 基本上唔做運動都瘦到 但做埋可以增肌/減脂 <br />\n<br />\n利伸 以自己做例子鳩up"},{"pid":"84e45b90941bcc90a4cdd41041cdcb0d93467794","tid":646343,"uid":8876,"like":0,"dislike":0,"score":0,"quote":{"pid":"d8a03a4d98bf49f9e4c8d98cff7bf72f600cb332","tid":646343,"uid":175112,"like":0,"dislike":0,"score":0,"quote":{"pid":"e054b716de47df495942f3e792cd6cde9f851df4","tid":646343,"uid":8876,"like":0,"dislike":0,"score":0,"quote":{"pid":"b45ded4510b68faab6b8a95f23c7772b4bcdd94b","tid":646343,"uid":175112,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T05:36:47.000Z","msg":"1個月減左十幾磅"},"citedBy":1,"replyTime":"2018-04-29T12:54:47.000Z","msg":"每星期做幾多次 每次幾耐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-29T13:16:40.000Z","msg":"<a href=\"https://youtu.be/cZnsLVArIt8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FcZnsLVArIt8&d=%2B9OPQEDzr2OMqe7q0QsGlJWUQYxlHU4vp7GM3pu%2FB4U%3D&h=54fd4a61\" data-auto-link target=\"_blank\">https://youtu.be/cZnsLVArIt8</a><br />\n<br />\n平均一星期做4次 <br />\n但點都好 搞好左飲食先 <br />\n戒糖 戒高脂食物 減澱粉<br />\n<br />\n簡單例子 <br />\n早餐 蕉/蘋果 加 麥皮<br />\n午餐 譚仔雞肉/豬肉清湯 檸茶走甜<br />\n晚餐 吉野家煎雞飯唔食皮走汁 <br />\n<br />\n你食到咁清淡 基本上唔做運動都瘦到 但做埋可以增肌/減脂 <br />\n<br />\n利伸 以自己做例子鳩up"},"citedBy":0,"replyTime":"2018-04-29T14:50:05.000Z","msg":"食得仲清淡過你<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n早餐有時食隻蛋 或者唔食<br />\n晏就夜晚都食屋企飯 多菜少飯少肉都係咁減過<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"https://youtu.be/WS5tG55Vdz8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FWS5tG55Vdz8&d=%2B9OPQEDzr2OMqe7q0QsGlJWUQYxlHU4vp7GM3pu%2FB4U%3D&h=4d45d27d\" target=\"_blank\">https://youtu.be/WS5tG55Vdz8</a><br />\n<a href=\"https://youtu.be/lQkD1b5HOPY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FlQkD1b5HOPY&d=%2B9OPQEDzr2OMqe7q0QsGlJWUQYxlHU4vp7GM3pu%2FB4U%3D&h=0f1dde1f\" target=\"_blank\">https://youtu.be/lQkD1b5HOPY</a><br />\n呢排夜晚做呢2 sets <br />\n做一個月再睇下有咩進展<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"21858226d135c11f0b7edc310fa0c0c9d6a28243","tid":646343,"uid":8876,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-29T14:50:54.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>1個月減左十幾磅</blockquote>每星期做幾多次 每次幾耐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><a href=\"https://youtu.be/cZnsLVArIt8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FcZnsLVArIt8&d=%2B9OPQEDzr2OMqe7q0QsGlJWUQYxlHU4vp7GM3pu%2FB4U%3D&h=54fd4a61\" target=\"_blank\">https://youtu.be/cZnsLVArIt8</a><br />\n<br />\n平均一星期做4次 <br />\n但點都好 搞好左飲食先 <br />\n戒糖 戒高脂食物 減澱粉<br />\n<br />\n簡單例子 <br />\n早餐 蕉/蘋果 加 麥皮<br />\n午餐 譚仔雞肉/豬肉清湯 檸茶走甜<br />\n晚餐 吉野家煎雞飯唔食皮走汁 <br />\n<br />\n你食到咁清淡 基本上唔做運動都瘦到 但做埋可以增肌/減脂 <br />\n<br />\n利伸 以自己做例子鳩up</blockquote>食得仲清淡過你<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n早餐有時食隻蛋 或者唔食<br />\n晏就夜晚都食屋企飯 多菜少飯少肉都係<span style=\"color: red;\">冇</span>減過<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"https://youtu.be/WS5tG55Vdz8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FWS5tG55Vdz8&d=%2B9OPQEDzr2OMqe7q0QsGlJWUQYxlHU4vp7GM3pu%2FB4U%3D&h=4d45d27d\" target=\"_blank\">https://youtu.be/WS5tG55Vdz8</a><br />\n<a href=\"https://youtu.be/lQkD1b5HOPY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FlQkD1b5HOPY&d=%2B9OPQEDzr2OMqe7q0QsGlJWUQYxlHU4vp7GM3pu%2FB4U%3D&h=0f1dde1f\" target=\"_blank\">https://youtu.be/lQkD1b5HOPY</a><br />\n呢排夜晚做呢2 sets <br />\n做一個月再睇下有咩進展<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"ed2c9d30fb0c02e5978bb4f05eabd2dd536afcbd","tid":646343,"uid":8174,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6c9ce754f9278be88f2090f945d17cd94a300547","tid":646343,"uid":129573,"like":0,"dislike":0,"score":0,"quote":{"pid":"ba3048e1ab57dd38478a3bde3382342a109d128a","tid":646343,"uid":131686,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T05:33:29.000Z","msg":"我都想知有無人靠hiit減肥<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2018-04-29T05:36:39.000Z","msg":"哂氣<br />\n肥人根本做唔到 HIIT 個強度"},"citedBy":1,"replyTime":"2018-04-29T15:44:18.000Z","msg":"啲人認為 跟片做三分鐘就有用<br />\n<br />\n根本好多人唔知 係個20秒入面係要爆盡全部力 <br />\n<br />\n做到一下得一一卜月<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />   啲垃圾雜誌就係咁<br />\n<br />\n吹噓短時間輕鬆減月日山<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"2bf5077625916b8b11ab5adac1eaab4231f32ecd","tid":646343,"uid":8876,"like":1,"dislike":0,"score":1,"quote":{"pid":"ed2c9d30fb0c02e5978b