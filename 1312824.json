50:56.000Z","msg":"推"},{"pid":"698642fadfc50e9936d0c030770e9ce055d4da7b","tid":1312824,"uid":259675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T16:51:44.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a6bc848c3afd69b5aac547ac0fdc3bbb20bba950","tid":1312824,"uid":135542,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd56baf0499614e9f25d0108e2c5118e51f22146","tid":1312824,"uid":68598,"like":0,"dislike":0,"score":0,"quote":{"pid":"68658bc31b60d777ca590717558667878c47c68a","tid":1312824,"uid":35231,"like":3,"dislike":3,"score":0,"citedBy":1,"replyTime":"2019-07-13T15:36:51.000Z","msg":"thanks<br />\n<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-13T15:39:10.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-13T16:51:44.000Z","msg":"實封橋 近遊行路線得四條橋 公園外拱橋二十隻狗 文化博物館行人橋唔駛十隻狗都封到 係得兩條行車橋易走d"},{"pid":"4590bc3cd4e95bbeddd28b7927f757a34d0e6e9e","tid":1312824,"uid":39710,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-07-13T16:52:13.000Z","msg":"要視乎警察點包圍法<br />\n<br />\n沙田火車站附近商場 (新城市(含連城), 偉華, 沙田廣場, 沙田中心, 好運中心) 基本上用橋連住晒, 點行都得<br />\n如果要去禾輋邨, 建議唔好行好運中心果條橋, 行地面好似好啲<br />\n<br />\n除非城門河兩岸都唔通, 如果唔係由沙田火車站經新城市附近道路向城門河兩岸行 (城門河有最少有5~6個位可以過到對面岸)<br />\n近嘅可到大圍火車站 / 車公廟馬鐵站<br />\n遠少少可以去到沙田圍馬鐵站 / 火炭火車站, 再遠少少去到第一城馬鐵站<br />\n終極真心遠就大學站<br />\n<br />\n假若你行到大圍, 由於大圍無大型商場, 只有小商場仲要得一個主要出入口, 千萬唔好入去<br />\n你只能夠四散是但搵架巴士/ 小巴走人<br />\n<br />\n過到對面岸(河畔花園 / 第一城 / 沙角邨等) 情況同大圍相約"},{"pid":"4bfa7cd43d57108ce5dcafc5e66f726d6a34aa0c","tid":1312824,"uid":276807,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-07-13T16:52:13.000Z","msg":"最新版 推<br />\n<img src=\"https://na.cx/i/ckEagkh.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FckEagkh.png&h=e63c41af&s={SIZE}\" />"},{"pid":"f4a9ea87f858bd3178446fe5400bf0bc7e31e3c3","tid":1312824,"uid":21678,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T16:55:53.000Z","msg":"千祈唔好響open field 開片<br />\n佢哋裝備level 高咁多<br />\n冇著數<br />\n<br />\n但係如果係窄路/ 路口<br />\n可以制造多方夾擊嘅情況<br />\n咁勝算就大好多"},{"pid":"7a1aca532a59cf38e557c06d2e319fd102d5d356","tid":1312824,"uid":135542,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T16:56:45.000Z","msg":"市中心去大圍既路得四條呢 而且除希爾頓條馬路外 其他三條長且窄 風險極高"},{"pid":"2b4243e9d49d72129d394d6cac452d9cf2087bfe","tid":1312824,"uid":201159,"like":1,"dislike":0,"score":1,"quote":{"pid":"40004dc0a8eaee3fd3c9740766ad1dd541627ce7","tid":1312824,"uid":19609,"like":12,"dislike":0,"score":12,"citedBy":4,"replyTime":"2019-07-13T15:42:50.000Z","msg":"<img src=\"https://na.cx/i/31tydJu.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F31tydJu.png&h=f0588d99&s={SIZE}\" /><br />\n<br />\n呢度係沙田連城同新城市既接口<br />\n<br />\n有必要（如遇火警）時新城市會落閘<br />\n<br />\n一封呢度基本上你唔可以經天橋去各大商場"},"citedBy":0,"replyTime":"2019-07-13T16:56:57.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"864d6982b452b0501e0a0f7fb224151edc3d529a","tid":1312824,"uid":276807,"like":0,"dislike":0,"score":0,"quote":{"pid":"4590bc3cd4e95bbeddd28b7927f757a34d0e6e9e","tid":1312824,"uid":39710,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-07-13T16:52:13.000Z","msg":"要視乎警察點包圍法<br />\n<br />\n沙田火車站附近商場 (新城市(含連城), 偉華, 沙田廣場, 沙田中心, 好運中心) 基本上用橋連住晒, 點行都得<br />\n如果要去禾輋邨, 建議唔好行好運中心果條橋, 行地面好似好啲<br />\n<br />\n除非城門河兩岸都唔通, 如果唔係由沙田火車站經新城市附近道路向城門河兩岸行 (城門河有最少有5~6個位可以過到對面岸)<br />\n近嘅可到大圍火車站 / 車公廟馬鐵站<br />\n遠少少可以去到沙田圍馬鐵站 / 火炭火車站, 再遠少少去到第一城馬鐵站<br />\n終極真心遠就大學站<br />\n<br />\n假若你行到大圍, 由於大圍無大型商場, 只有小商場仲要得一個主要出入口, 千萬唔好入去<br />\n你只能夠四散是但搵架巴士/ 小巴走人<br />\n<br />\n過到對面岸(河畔花園 / 第一城 / 沙角邨等) 情況同大圍相約"},"citedBy":0,"replyTim