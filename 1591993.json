br />\n沒水準還喜歡擺架子的老師被我教訓過後，都不敢再回學校；<br />\n餐廳的飯菜不值所定的價格，我就敢不付錢，這種事更是常見&hellip;<br />\n但是！即便是這樣的我，也能分辨出那些令人作嘔的邪惡！<br />\n所謂邪惡，就是你這樣為了自己而利用弱者並踐踏他們的傢伙！<br />\n你這樣的傢伙&hellip;就由我來制裁！"},{"pid":"7286d126b39d1f54f5b0c954cc0f1499f48fc9f3","tid":1591993,"uid":166085,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-27T04:10:55.000Z","msg":"天元 施蒙(大個前)<br />\n垃圾，冇主見"},{"pid":"75b745e296fb1ce24a8d263bfb6d970e5f85c02b","tid":1591993,"uid":64009,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-09-27T04:14:12.000Z","msg":"相良宗介"},{"pid":"2c90fa5de70024d93199d767fa0e4e35e90ddcbf","tid":1591993,"uid":249611,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-27T08:00:28.000Z","msg":"坂本銀時"},{"pid":"29b44f585f7bf75ec7457f474e13043bc0e15eef","tid":1591993,"uid":76753,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T16:32:05.000Z","msg":"越前龍馬"},{"pid":"4a2f847b55be7845800dfb7d2ba71ef382e4fcde","tid":1591993,"uid":13149,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-09-27T17:02:20.000Z","msg":"火影"},{"pid":"cf066665f57fc0bd427f9c5a7eff0e1714e62df0","tid":1591993,"uid":50809,"like":0,"dislike":0,"score":0,"quote":{"pid":"4a2f847b55be7845800dfb7d2ba71ef382e4fcde","tid":1591993,"uid":13149,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-09-27T17:02:20.000Z","msg":"火影"},"citedBy":0,"replyTime":"2019-09-27T17:02:44.000Z","msg":"<img src=\"/assets/faces/dog/zzz.gif\" class=\"hkgmoji\" />"},{"pid":"9e7f192d841e8eba5c96d50ac716493f2acc45fd","tid":1591993,"uid":235264,"like":0,"dislike":0,"score":0,"quote":{"pid":"2c90fa5de70024d93199d767fa0e4e35e90ddcbf","tid":1591993,"uid":249611,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-27T08:00:28.000Z","msg":"坂本銀時"},"citedBy":1,"replyTime":"2019-09-28T02:10:47.000Z","msg":"坂田<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"}]}