\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-17T03:21:09.000Z","msg":"味"},{"pid":"910db6592f755315eb39b17743a7d4907f3cafd6","tid":782693,"uid":22832,"like":0,"dislike":2,"score":-2,"quote":{"pid":"b2a9ad015c1288b2bbe608dce7546507ef0ad8c3","tid":782693,"uid":51701,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-08-17T03:08:05.000Z","msg":"中國豬瘟<br />\n<br />\n幫手食多啲啦"},"citedBy":0,"replyTime":"2018-08-17T03:21:45.000Z","msg":"平又唔食貴又唔食咁幾時先食"},{"pid":"a4f3185d881b26d2cec47d015484018b8bb88deb","tid":782693,"uid":159054,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2018-08-17T03:27:45.000Z","msg":"買樓豬買幾多貨？"},{"pid":"ad054f57e9863b96b66a05115edb3bed41b5bf10","tid":782693,"uid":195887,"like":0,"dislike":0,"score":0,"quote":{"pid":"ee0c1de8d6fc8ed16f87e25152a3f8f21dfb032d","tid":782693,"uid":133033,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2018-08-17T03:07:14.000Z","msg":"大家樂價又無跌<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-17T03:30:12.000Z","msg":"係，<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 從來只有加無減。"},{"pid":"cc6e67cc0223813bd687fdddc395f003c7f3bc7d","tid":782693,"uid":102198,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-17T03:38:53.000Z","msg":"好似爭篇文"},{"pid":"eebd8207d5277d7291224a522c471c310553490a","tid":782693,"uid":54337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T03:38:57.000Z","msg":"唯我焗豬<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"d686ad8f5af35b2ea6a94c8b23b756d391d6478f","tid":782693,"uid":32549,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T03:42:57.000Z","msg":"又唔係巴西<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4287bd8f7c6be54a98b9831d0c0affcade9ace86","tid":782693,"uid":22832,"like":4,"dislike":0,"score":4,"quote":{"pid":"cc6e67cc0223813bd687fdddc395f003c7f3bc7d","tid":782693,"uid":102198,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-17T03:38:53.000Z","msg":"好似爭篇文"},"citedBy":0,"replyTime":"2018-08-17T06:16:51.000Z","msg":"咪話呀叔唔教精你，我身經百戰，而家一腸個餐牌就知咩料。<br />\n拿，大家樂而家最抵食既得一隻，叫上海骨菜飯，有豬扒幾舊，炸到酥，跟涼菜、半隻鹵強同菜飯，先29蚊。<br />\n而焗豬呢都要叫得有技巧，唔係乜lan野時候都叫得，你一定要見佢個牌寫成呎長焗豬先叫得，唔係中伏！<br />\n<br />\n拿，大家樂唔可以成日加價，所以佢d野食質素同果期既食材來價有關！<br />\n如果果期d冰凍豬扒平，佢就會入d大大件成個飯盒咁長，而且有1.748cm厚既豬扒。入左筍野佢地當然唔會放過晒命機會，所以個牌就會寫「成呎長一哥焗豬扒飯」！<br />\n<br />\n如果果期d豬扒來價略貴，佢就會縮lan左成呎長幾隻字，淨係寫「一哥焗豬」！咁你叫時就要心中有數了！<br />\n <br />\n如果果期連一哥兩隻字都冇埋，變成乜lan野鴛鴦焗飯，雞球併豬扒之類咁，就係果期豬扒來貨好貴，佢就整d垃圾出黎頂檔，07年～08年就發生過，一唔小心就中伏！！<br />\n<br />\n<img src=\"https://vignette.wikia.nocookie.net/evchk/images/0/00/2010426123845477750334.jpeg/revision/latest?cb=20101011120834\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fevchk%2Fimages%2F0%2F00%2F2010426123845477750334.jpeg%2Frevision%2Flatest%3Fcb%3D20101011120834&h=a6edcc68&s={SIZE}\" /><br />\n<br />\n不過大家唔駛驚會中伏，其實呢d係有路捉既，果期你上美國芝加哥期貨交易所個網睇豬肉期貨既價，如果巴西豬肉期貨價大跌就係準備有成呎長豬扒既時候了！ <br />\n<br />\n<img src=\"https://vignette.wikia.nocookie.net/evchk/images/e/e8/C562502d.gif/revision/latest?cb=20101011120904\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fevchk%2Fimages%2Fe%2Fe8%2FC562502d.gif%2Frevision%2Flatest%3Fcb%3D20101011120904&h=27745e08&s={SIZE}\" /><br />\n<br />\n下次叫上海骨飯啦，唔跟野飲29蚊，睇師傅手神，有時會整5～6舊細扒入去，仲有一盒仔涼菜，係炸菜青瓜果d，仲有半隻鹵強，而跟飯有盒仔調味醬油，本來係撈涼菜既，但涼菜既夠味，就咁倒落菜飯到撈更香口。鍾意既加多杯佢地既即磨咖啡，以平價啡黎講算十分香口澴滑，+4蚊抵飲！"},{"pid":"891d4c81f7665e42365a06e0e987cbac7759ff73","tid":782693,"uid":93649,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-17T07:06:55.000Z","msg":"1975年既豬肉"},{"pid":"900942ff12c9405371a7b8e304b21c1880f65afc","tid":782693,"uid":22832,"like":2,"dislike":0,"score":2,"quote":{"pid":"891d4c81f7665e42365a06e0e987cbac7759ff73","tid":782693,"uid":93649,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-17T07:06:55.000Z","msg":"1975年既豬肉"},"citedBy":0,"replyTime":"2018-08-17T08:07:31.000Z","msg":"<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"9f96966f5f1a81016b4985d79905a758d4527a2c","tid":782693,"uid":57308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T08:14:54.000Z","msg":"雲ching<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d47896e52f0c7f6a67237a1b44579b937545ffb8","tid":782693,"uid":30169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T08:26:02.000Z","msg":"大陸有大量病豬⋯"},{"pid":"b81868438bd4d5a534d45b8017d2e1aab4d950ab","tid":782693,"uid":29008,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T14:44:47.000Z","msg":"仲$29蚊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}