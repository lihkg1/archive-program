ike":0,"score":0,"quote":{"pid":"52da71d9806c56419f5ac4272199ae52814fe5d6","tid":716483,"uid":2411,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2018-06-25T11:50:07.000Z","msg":"呢啲野真係要細個就學，大個先學就好笨柒<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-25T11:51:41.000Z","msg":"你個名<img src=\"/assets/faces/lomoji/41.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-25T11:53:19.000Z","msg":"我屌你個名<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"3565e330f2b21e6273069e0b7cd83e7d1d5eb067","tid":716483,"uid":71391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T11:54:06.000Z","msg":"有咩唔自學得？？？<br />\n第一個發明嘅人唔通係或地教咩"},{"pid":"fb8d2244e8a14d8d95820ff14e86c284579190e0","tid":716483,"uid":2411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T11:54:08.000Z","msg":"其實揾個識游水嘅朋友帶你去泳池學就好快搞點<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"48f5746232f0108ee7e754413791deebae94c351","tid":716483,"uid":121095,"like":1,"dislike":0,"score":1,"quote":{"pid":"52da71d9806c56419f5ac4272199ae52814fe5d6","tid":716483,"uid":2411,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2018-06-25T11:50:07.000Z","msg":"呢啲野真係要細個就學，大個先學就好笨柒<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-25T11:58:05.000Z","msg":"我都係入到u先開始學游水<br />\n反而覺得大個知咩位做得唔好 好容易改善到"},{"pid":"423e7969d6c6a56ee09ba2d1dd36642aac9530f9","tid":716483,"uid":39012,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T12:17:39.000Z","msg":"低B學游水"},{"pid":"a20156ae41d6340a519f859b6b702d76fbb81e33","tid":716483,"uid":10105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T12:21:26.000Z","msg":"姿勢會錯晒，搞到曬力但只游前到少少"},{"pid":"eb8083502061e9ebbf27d54734faaf3d89b901d6","tid":716483,"uid":17623,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-06-25T12:30:19.000Z","msg":"正常識游水係可以游到好似緩步跑 好放鬆都游到<br />\n自學基本無咩可能<br />\n用錯力 又游唔到<br />\n掌握到水感就好易識游<br />\n要識放鬆識浮識用力<br />\n自學係極難<br />\n自學可以學浮先<br />\n一識浮動作都易做d<br />\n次序<br />\n浮 換氣 腳 手"},{"pid":"65fef408a3a30b97ae1f72fcb3fd13025700c495","tid":716483,"uid":76159,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-06-25T15:33:52.000Z","msg":"上緊堂表示都好難學成<br />\n本身份人好繃緊唔識放鬆<br />\n靠死力游，都游到廿幾米<br />\n但人地輕鬆游我係完全做唔到<br />\n水感勁差<br />\n蛙式點都要兩腳一手，唔係上唔到水換氣<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"04f699dfdca12f143517813af72fcf2e2abeff5c","tid":716483,"uid":183368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T23:14:25.000Z","msg":"我完全自學游水<br />\n呢家剩係識蛙式，應該姿勢有問題，游得比較慢，但連續游倒一round<br />\n仲睇梗自由式點搞，因為游得半個池就冇氣<br />\n<br />\n自己夠膽游過海灘去浮台<br />\n但未自學好就咪亂嚟<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"811e3f96e1e37617abc7e5ca2561932caef9553f","tid":716483,"uid":17506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T23:25:33.000Z","msg":"有無人同我一樣游一陣就會暈暈地<img src=\"/assets/faces/lomoji/16.png\" class=\"hkgmoji\" /> <br />\n好想自學但游極都係咁<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f91c7c214531eef128e7e39ad607a9ffe16bf9ed","tid":716483,"uid":181651,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T23:47:35.000Z","msg":"08年 奧運<br />\n當時仲係學生<br />\n香港游泳池免費 <br />\n暑期又冇乜野做 屋企冇乜錢<br />\n日日落去游水 游左一個暑假 就識游水<br />\n全自學 得閒偷聽隔離泳會教水<br />\n會考後就考左救生員牌 大學幾年都係返pt"},{"pid":"dca8538d9958a87d9047453581b9022b7a32a50e","tid":716483,"uid":15501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T23:51:53.000Z","msg":"一開始剩係吸一口氣，跟住閉住氣游一段距離<br />\n跟住再開點換氣，最後再學踩水<br />\n<br />\n你一開始閉住氣黎游，好少會嗆到"}]}