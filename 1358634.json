d":"f653b60f323326ed741e3639bac07e159f4abcc2","tid":1358634,"uid":46275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T03:46:12.000Z","msg":"好打得會掙扎到最後一刻"},{"pid":"3e3228273c66fb655a174cbd57849bb314f47765","tid":1358634,"uid":17503,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-24T03:46:29.000Z","msg":"推"},{"pid":"82757ddb12b7e52164d85f8471065bd50cb1fbaf","tid":1358634,"uid":74572,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T03:46:45.000Z","msg":"借位 麻煩幫幫手<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n【越洋幫拖】喺美國嘅香港人想收集警暴證據交畀美國警察同議員<br />\n<a href=\"https://lih.kg/1358473\" data-auto-link target=\"_blank\">https://lih.kg/1358473</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"790906c7f285a99745ae366c9da0b3f4596b0e65","tid":1358634,"uid":266924,"like":0,"dislike":0,"score":0,"quote":{"pid":"62b0ab07532d972122646ed6b5f3687a0de27579","tid":1358634,"uid":438,"like":0,"dislike":0,"score":0,"quote":{"pid":"55090772dd49ca28f791774ff48690f67b7dcf89","tid":1358634,"uid":14494,"like":8,"dislike":1,"score":7,"citedBy":1,"replyTime":"2019-07-24T03:28:46.000Z","msg":"地產佬同中華廠商會都出黎，我有冇睇錯<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-24T03:44:22.000Z","msg":"樓價跌咪出黎<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-24T03:46:58.000Z","msg":"唔係樓價跌，佢地唔想普選發生"},{"pid":"4d85d4f1621bc09a579f11a36e7ed7d10eb716cb","tid":1358634,"uid":24133,"like":0,"dislike":0,"score":0,"quote":{"pid":"4a31264683b1c6f68d40db32bb0e1dfffc68d7cf","tid":1358634,"uid":12558,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-07-24T03:34:15.000Z","msg":"認真野冇人推<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-24T03:48:18.000Z","msg":"<span style=\"color: red;\"