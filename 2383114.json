ps://i.lih.kg/thumbnail?u=https%3A%2F%2Fpic.pimg.tw%2Fphotowars%2F1387786809-1027422299.jpg&h=8ecafc2f&s={SIZE}\" />"},{"pid":"4bee45f391e20d068fafe4c345832af92f04091b","tid":2383114,"uid":316927,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2021-01-27T17:59:25.000Z","msg":"賤種英資怡和<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"5e3ffedf70e8bec6111ff11a329396bdad493df7","tid":2383114,"uid":156652,"like":33,"dislike":0,"score":33,"citedBy":2,"replyTime":"2021-01-27T18:02:01.000Z","msg":"黑客要yuu積分嗎<img src=\"/assets/faces/lomoji/04.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/04.png\" class=\"hkgmoji\" />"},{"pid":"310badc9664258ee615b511c8171fdd9b2ab491f","tid":2383114,"uid":153239,"like":2,"dislike":0,"score":2,"quote":{"pid":"36d95b9535962e09427503fbfd229c4a9417ea00","tid":2383114,"uid":176447,"like":18,"dislike":1,"score":17,"citedBy":2,"replyTime":"2021-01-27T17:03:41.000Z","msg":"牛奶乜撚關閉~"},"citedBy":2,"replyTime":"2021-01-27T18:05:32.000Z","msg":"<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />去批一批佢個波"},{"pid":"9a4b17648c7623708c67f417b7ceb35583d53046","tid":2383114,"uid":85284,"like":11,"dislike":20,"score":-9,"quote":{"pid":"371fd5d25d782e975d47cdeb71a5e4fc0871cf18","tid":2383114,"uid":11148,"like":125,"dislike":4,"score":121,"citedBy":1,"replyTime":"2021-01-27T16:57:45.000Z","msg":"明顯係支那蟈家級侵略，布局咁撚深就你想食哂所有香港公資，外資<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2021-01-27T19:10:05.000Z","msg":"點會只係咁簡單吖<br />\n最近無論係美國，以至全球，又或係香港所發生嘅事<br />\n都係極度唔尋常<br />\n作為局外人，可能永遠都唔會知道真相<br />\n但我認為似係涉及世界秩序話事權嘅變化<br />\n一間潛伏香港多年，背景好特別嘅英資大企<br />\n其伺服器攞嚟做緊乜嘢，已經係一件令人好奇嘅事<br />\n當傳聞一衆德國 cia 關於大選伺服器被武力奪走後<br />\n經解密後被人提出有外國勢力涉及事件（包括香港）<br />\n如果美國 deep state 真係已經喺美國大選勝出<br />\n啲各式各樣極唔尋常嘅事<br />\n又點會仲係一浪接一浪出現吖"},{"pid":"7027b2ff6d1071d0b2d030f72a52597a4050a