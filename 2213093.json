pid":"7d007f5a8add06a4c05caa0b66e9243ed196b050","tid":2213093,"uid":75823,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-22T11:12:31.000Z","msg":"買名牌先好d"},{"pid":"4f74e261465ff1e9c1e210183acc699caa465dae","tid":2213093,"uid":115712,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-22T11:21:48.000Z","msg":"<img src=\"https://na.cx/i/m2AfUWH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fm2AfUWH.jpg&h=a96d0cc1&s={SIZE}\" /><br />\n前幾日先見到好熱鬧<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"d03f6b161f9afbb5eb4e3836427e40975f1b093c","tid":2213093,"uid":236140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-22T11:22:33.000Z","msg":"『唔乾淨』當時要私有化會德豐，派番海港城股份俾股東，梗係要整旺個場啦 <br />\n<br />\n<br />\n<span class=\"large\"><span class=\"x-large\">寧派優惠券也不減租</span></span><br />\n<br />\n時代廣場和海港城作為九倉的「金蛋」，在社會運動和疫情影響下，收入明顯下降。今年上半年，海港城及時代廣場整體收入分別跌28%及19%。九倉今年二月至四月將海港城租金減半後，向租戶提供五月份租金四折優惠，但前提要延長租約期最少18個月，和在限期前付清六月底前所有未償還租金。在「加辣」減租條款後，九倉於五月派發第一輪總值1.12億元的消費券。"},{"pid":"b4979a1d64c2d5dccdf96175f43eccad072463f5","tid":2213093,"uid":19217,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-22T11:57:56.000Z","msg":"大把有錢人消費<br />\n同買樓一樣"}]}