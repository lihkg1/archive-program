normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"bae0837d6a962486dcd684ddeec6a55852297d83","tid":203554,"uid":92859,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:29:06.000Z","msg":"以前係外國cafe做過，最正一定係加cream<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n如果屋企冇cread都可以加少少奶（但炒完要盡快食，如果唔係會出水）"},{"pid":"5927024e2a64809198176ec5f6592ccd1cd5fa1f","tid":203554,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:29:18.000Z","msg":"落雨炒蛋"},{"pid":"12f9d835e11107a43fca1d0edeebe830f3894295","tid":203554,"uid":74981,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:30:03.000Z","msg":"<blockquote><blockquote>分享下我既做法:<br />\n<a href=\"https://youtu.be/qopsMuwFlCc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FqopsMuwFlCc&d=tjA1itiRAyOaH4WNB6QjY%2F%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=a46172cc\" target=\"_blank\">https://youtu.be/qopsMuwFlCc</a></blockquote><br />\n好掂 我次次都出水 點搞<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n多謝<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n試下熄火推到佢熟多少少先剷起 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5ca966ccd614f78858dd3ba4f9c78fb6d6213483","tid":203554,"uid":99378,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:30:12.000Z","msg":"<blockquote>加奶落蛋液<br />\n油落鍋<br />\n大火熱左個底<br />\n蛋落鍋<br />\n轉細火<br />\n翻兩翻<br />\n完成</blockquote><br />\n加奶正<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"5a9c427ced81411a097fc9d5e91eccd9c0c0f490","tid":203554,"uid":12970,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-04-16T12:33:57.000Z","msg":"Hot pan<br />\nOliver oil<br />\nLet the pan do the work<br />\n<br />\nScramble egg<br />\nDone"},{"pid":"2cca17ad5618227a02e56d0a3930946a92498b9d","tid":203554,"uid":3713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:34:52.000Z","msg":"<blockquote><blockquote><blockquote>分享下我既做法:<br />\n<a href=\"https://youtu.be/qopsMuwFlCc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FqopsMuwFlCc&d=tjA1itiRAyOaH4WNB6QjY%2F%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=a46172cc\" target=\"_blank\">https://youtu.be/qopsMuwFlCc</a></blockquote><br />\n好掂 我次次都出水 點搞<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n多謝<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n試下熄火推到佢熟多少少先剷起 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n好靚，不過唔慣落咁多油煮嘢！"},{"pid":"916b7371edfe6b6713845b121eb1529b32124b2e","tid":203554,"uid":19381,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:36:00.000Z","msg":"加油加奶，細火炒"},{"pid":"b4fd9a561d174f96cc1afc9e4844a938e0b84f84","tid":203554,"uid":19381,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:36:14.000Z","msg":"<blockquote>加牛油加奶，細火炒</blockquote>"},{"pid":"488278394d6735e28dc30660f83aed5767351b36","tid":203554,"uid":26038,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:36:52.000Z","msg":"<blockquote><blockquote>雞粉lor</blockquote><br />\n巴打平時食開屎？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n咁講即係你唔食大快活炒蛋<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"2202761878076a27330364ccb5bd9484b0001670","tid":203554,"uid":74981,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:37:07.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>分享下我既做法:<br />\n<a href=\"https://youtu.be/qopsMuwFlCc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FqopsMuwFlCc&d=tjA1itiRAyOaH4WNB6QjY%2F%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=a46172cc\" target=\"_blank\">https://youtu.be/qopsMuwFlCc</a></blockquote><br />\n好掂 我次次都出水 點搞<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n多謝<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n試下熄火推到佢熟多少少先剷起 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n好靚，不過唔慣落咁多油煮嘢！</blockquote><br />\n多謝支持<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n2隻蛋其實落2茶匙油已經ok，食落唔會覺得有油<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"810b75a4dbfd49123b9d90f39451920ff882365f","tid":203554,"uid":148,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:37:31.000Z","msg":"<img src=\"https://na.cx/i/pONQ494.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpONQ494.jpg&h=a7432c45&s={SIZE}\" />"},{"pid":"bbbb7d13d432c5b69ad059699c30f6e5fce86ac4","tid":203554,"uid":71895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:37:54.000Z","msg":"中火燒熱pan<br />\n轉小火 落小塊牛油 搽<br />\n再落蛋 (蛋可加少少White pepper/salt)<br />\nKeep住炒<br />\nDone<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n<br />\n記住小火 因為個pan太熱牛油就燶<br />\n<br />\n以前炒蛋都係用普通油 加奶又試過<br />\n但都係用牛油炒蛋最好食！<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"0d4f62d750987c0cb385742b554687d081b43849","tid":203554,"uid":3602,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:39:00.000Z","msg":"<blockquote>Hot pan<br />\nOliver oil<br />\nLet the pan do the work<br />\n<br />\nScramble egg<br />\nDone</blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c9408bd6885dde3c622f314620bf6d0bd79b6d67","tid":203554,"uid":43964,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:39:20.000Z","msg":"大火heat個pan,要香滑就落牛油，落牛油的話放蛋前先好落牛油，唔係牛油好快變黑！ 倒蛋熄火，用餘熱煮，拎對快子打圈，打至喜歡既口感即可！"},{"pid":"c081a64f70964e7defb788cbb88870885954324b","tid":203554,"uid":98041,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:39:44.000Z","msg":"整滑蛋就加少少牛油同奶 熱左個pan先 之後落牛油轉細火落蛋<br />\n推外邊變固體既蛋入內圍 如此類推 到全部蛋都推曬入內圍<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"c0e27873240db47ce81f844e40fbc539e80f6bf1","tid":203554,"uid":24491,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:39:48.000Z","msg":"一定係加奶<br />\n之後整熱個鑊<br />\n熄火 用餘溫炒"},{"pid":"a6ca73c9d49c3eaa32531f377bc5bc306b44c62c","tid":203554,"uid":71768,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:43:15.000Z","msg":"買支雞醬<br />\n<br />\n打蛋 打勻晒 落雞醬 再搞勻佢<br />\n<br />\n落油 熱熱地啲油就落牛油 多小小都唔怕<br />\n<br />\n跟手牛油溶晒就落蛋 慢火係咁搞佢 熄火<br />\n<br />\n<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b458d6e9a18157e419b40bf34d0fb1fe219749fe","tid":203554,"uid":13556,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:47:03.000Z","msg":"我都超鐘意大快活炒蛋<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ec2512de06db1f05d5c571a85803c61398cc27f6","tid":203554,"uid":34241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:51:30.000Z","msg":"懶人炒蛋<br />\n大火熱鑊 落油<br />\n&quot;廊&quot;鑊<br />\n等5-10秒<br />\n落蛋<br />\n<br />\n1。一見變白就瘋狂係外圍剷向中間 (唔過10秒)<br />\n表面包得哂 剷住成包反幾反，熄火，2秒離鑊<br />\n<br />\nor<br />\n<br />\n2。無定向兜<br />\n中間打圈搞 鬆開d蛋液 兜兩下外圍<br />\n熄火 再兜幾下<br />\n離鑊"},{"pid":"c354db23275968f368664b2834499e745b66a037","tid":203554,"uid":65386,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T12:58:49.000Z","msg":"奶是不可或缺的一部分<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"76d90f3aaa2034aa8f414135d7417aab6868ebc6","tid":203554,"uid":25676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T13:04:45.000Z","msg":"<blockquote><blockquote>I加牛奶</blockquote><br />\n聽日先買 屋企既蛋比我用哂<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n你炒咗幾多隻蛋<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e93dafb3efebf9a29ca0b88f82c012c85b9ff4c7","tid":203554,"uid":17920,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T13:04:54.000Z","msg":"<blockquote><a href=\"https://youtu.be/KZvBa4hU3fU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FKZvBa4hU3fU&d=tjA1itiRAyOaH4WNB6QjY%2F%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=388f5c7a\" target=\"_blank\">https://youtu.be/KZvBa4hU3fU</a></blockquote><br />\n<br />\n又向爛口廚神學到野<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"d29c5bde45476acb831891c5e247493e52553a5b","tid":203554,"uid":49176,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T13:06:57.000Z","msg":"<a href=\"https://youtu.be/s9r-CxnCXkg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fs9r-CxnCXkg&d=tjA1itiRAyOaH4WNB6QjY%2F%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=0801147d\" target=\"_blank\">https://youtu.be/s9r-CxnCXkg</a>"},{"pid":"3013aada79f5ff36e0ae25e9a45eb8addea47e3a","tid":203554,"uid":14446,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T13:07:12.000Z","msg":"樓主講大快活果隻應該係美式炒蛋<br />\n發蛋果時加牛奶<br />\n火喉最重要 用中細火 最緊要係比d蛋慢慢咁熟<br />\n用普通油/牛油都得 我覺得分別唔大<br />\n之後就落鑊炒 唔好係咁兜佢 慢慢用個鑊剷向鑊嘅中心畫 畫到見d蛋開始&quot;鯨&quot;就熄火 因為d蛋已經熱左 你放上碟就會啱啱好<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"8ce0b2afa73870485072cd35ff437958de2f706b","tid":203554,"uid":73281,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T13:07:50.000Z","msg":"駛咩加奶<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />極細火+牛油慢慢搞拌已經好香好滑"},{"pid":"696ca01d9e80c9d6a81a1d28572db512dadc5c88","tid":203554,"uid":59114,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-16T13:13:01.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c38f9f