>"},{"pid":"7ae353e3e1cd6e5b25c5cbba1b8f3773cc0b2fdf","tid":1365673,"uid":43556,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-25T17:44:01.000Z","msg":"掃黑除惡"},{"pid":"d3a39d4204e730bd6cd9a7cecd3c275b505bdf42","tid":1365673,"uid":290176,"like":0,"dislike":0,"score":0,"quote":{"pid":"7ae353e3e1cd6e5b25c5cbba1b8f3773cc0b2fdf","tid":1365673,"uid":43556,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-25T17:44:01.000Z","msg":"掃黑除惡"},"citedBy":0,"replyTime":"2019-07-25T18:02:46.000Z","msg":"贊成咁玩。官商鄉黑個個著草都唔掂! <img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" />"},{"pid":"c26f15fa05e9eabab7379b11fc1109cf8331f790","tid":1365673,"uid":70888,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T18:05:06.000Z","msg":"1"},{"pid":"357c036c93e5cf0e9c24a577637abd33614dceea","tid":1365673,"uid":125453,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T18:05:49.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c5c6b1d2fe4727cd7e4e0589e000feb5af4d24ff","tid":1365673,"uid":216789,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T18:25:28.000Z","msg":"<strong>慎防黑惡勢力蔓延禍港，提防本地非法操縱妓女賣淫集團</strong><br />\n<br />\n鑒於近日有無辜香港市民慘遭黑勢力人仕襲擊，現懇切呼籲各香港市民不論男女，請慎防本地非法操縱妓女賣淫集團，保障自身安全，萬事小心，<strong><span style=\"color: red;\">切忌助長黑惡勢力氣焰</span></strong>"},{"pid":"9c8f7d670df1bfb67c4117d041e7b7d34521e5c4","tid":1365673,"uid":15276,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-25T18:46:09.000Z","msg":"五大訴求雖然口號化左好難再不斷改<br />\n不過我覺得可以將次序同詮釋變成下面咁：<br />\n<br />\n一、成立獨立調查委員會，<span style=\"color: gold;\">反對官警黑勾結，追究黑警濫權</span><br />\n二、實行雙普選，<span style=\"color: orange;\">從根本解決問題</span><br />\n三、徹底撤回惡法，<span style=\"color: gold;\">不能重啟送中條例</span><br />\n四、收回暴動定性，<span style=\"color: orange;\">改革公安條例</span><br />\n五、釋放被捕人士，<span style=\"color: gold;\">撤銷抗爭者控罪，濫捕可恥</span>"},{"pid":"658c04b0cbc3bd465ae2f15409d14cc762ec0b36","tid":1365673,"uid":43556,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T04:50:24.000Z","msg":"推"},{"pid":"fa8385f593dfc87c9d716265838c36facbf88848","tid":1365673,"uid":43556,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T05:15:57.000Z","msg":"掃黑除惡"},{"pid":"a9a1548c7d513ee3a4b861c388b9be4fe5be6784","tid":1365673,"uid":107686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T05:16:41.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}