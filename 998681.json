e99e19080a8aa578e50f36a435c5a67d6ff956f","tid":998681,"uid":38383,"like":0,"dislike":4,"score":-4,"quote":{"pid":"5e7cae691147eec9565b5b20b8131ced1898aaad","tid":998681,"uid":59586,"like":27,"dislike":0,"score":27,"quote":{"pid":"655d06574719fe61b82f004683e3969cfdc70fd9","tid":998681,"uid":38383,"like":1,"dislike":48,"score":-47,"citedBy":4,"replyTime":"2019-01-28T06:51:17.000Z","msg":"熱能&gt;變凍&gt;冇熱能&gt;製唔到冷<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-28T06:54:31.000Z","msg":"工業廢熱<br />\n太陽熱能<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-01-28T06:57:45.000Z","msg":"製左冷周圍變凍咪吸唔到熱 要停一陣等佢熱返再製冷再停<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />  利申:9up"},"citedBy":0,"replyTime":"2019-01-28T09:13:10.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /> 係用廢熱同電能，同時<br />\n多廢熱果陣，電能會用小d, 小廢熱果陣電會用多d,.另外佢得50% 轉換率，姐係仲有50%廢熱會出左去。<br />\n<br />\n原理同電，油混合車一樣"},{"pid":"c9a0914d20722d5deaf4d04a7b76735fcee57c45","tid":998681,"uid":38550,"like":3,"dislike":3,"score":0,"citedBy":0,"replyTime":"2019-01-28T09:14:37.000Z","msg":"呢隻嘢工業用係唔錯<br />\n<br />\n不過heat engine本身需要大溫差作為原動力<br />\n一般至少百幾度至幾百度<br />\n如果係本身會製造廢熱嘅場地非常適合<br />\n但若然只係室溫環境就用唔著<br />\n(除非你好傻咁用電去製熱)<br />\n<br />\n另外就係佢效能只有50%左右<br />\n所以用喺廢熱就無問題<br />\n但如果熱力本身有用而想用呢套系統去傳送收集熱力就唔多適合<br />\n<br />\n所以暫時都見唔到可以家用"},{"pid":"3be6fb0eab43ac4da56d0edd8c5d30e5132c0e8d","tid":998681,"uid":55913,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-01-28T09:20:08.000Z","msg":"成個香港裝一部大冷氣啦<br />\n想喺大帽山滑雪<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" />"},{"pid":"f836d59c37306edd4a6e68c589cf98d1220782a7","tid":998681,"uid":111729,"like":0,"dislike":7,"score":-7,"citedBy":0,"replyTime":"2019-01-28T09:23:49.000Z","msg":"用太陽能即係要本身一啲Low grade heat source (i.e. Electric heater)去backup個energy source<br />\nIn that case當冇太陽嘅時候有機會同普通冷氣一樣曬電<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> (同Absorption chiller同一個道理<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> )<br />\n再加上25kW其實都算小 (家用大約2kW, 但商場隨時過千kW)<br />\n唯一我覺得吸引係maintenance free同舊野本身唔用電<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n如果個system本身有個high COP chiller做主力其實真心諗得過用少少嚟試下<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"f6870b6cf2261196bd6122c2c65e5ed1ddb61e12","tid":998681,"uid":196924,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-01-28T09:38:29.000Z","msg":"氬氣為空氣中含量最多的氣體<br />\n<br />\n乜鳩<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />  Argon只係最多嘅inert gas，但係仍然係唔夠1%<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"efa1c8c18eb83186f9a9fce8b4dfd6938129f843","tid":998681,"uid":32586,"like":2,"dislike":0,"score":2,"quote":{"pid":"655d06574719fe61b82f004683e3969cfdc70fd9","tid":998681,"uid":38383,"like":1,"dislike":48,"score":-47,"citedBy":4,"replyTime":"2019-01-28T06:51:17.000Z","msg":"熱能&gt;變凍&gt;冇熱能&gt;製唔到冷<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-28T10:40:55.000Z","msg":"-273度攝氏先可以叫冇熱能"},{"pid":"d3747bd03f41e60e86955507b1a9396f644f610d","tid":998681,"uid":29702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-28T10:45:21.000Z","msg":"此回覆已被刪除"},{"pid":"43f5c46a3846e357b6917db28bcc0a70f0929567","tid":998681,"uid":29880,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-01-28T10:46:32.000Z","msg":"真唔真?<br />\n係真諾貝爾獎都有得攞"},{"pid":"546981f7dc4e60575c7e516f99b41a018699bc8b","tid":998681,"uid":6752,"like":2,"dislike":0,"score":2,"quote":{"pid":"526d3643329691eb709b75ec591b14f430abf45d","tid":998681,"uid":18241,"like":38,"dislike":0,"score":38,"quote":{"pid":"461a20e6961112fccc36698e85f5149eacc11006","tid":998681,"uid":169537,"like":0,"dislike":8,