.000Z","msg":"篇野咁撚悶點做潮文"},{"pid":"e6573ece5ec1b399e672b670146c88574bb412f8","tid":1005630,"uid":53278,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-03T02:17:41.000Z","msg":"巴士公司已經發現左呢個方法<br />\n好似話請左個國內高手做針灸工程師"},{"pid":"cbc1df9f8fa6c6c40d588fd16e4a340d5d5f27d9","tid":1005630,"uid":16783,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-03T02:39:12.000Z","msg":"<img src=\"/assets/faces/lny/slick.gif\" class=\"hkgmoji\" />"},{"pid":"ff2170822237d3a47276ec2fadbd73c5c61d5368","tid":1005630,"uid":143167,"like":0,"dislike":0,"score":0,"quote":{"pid":"22459f776077787a70d1d64290078a86515a54b7","tid":1005630,"uid":134997,"like":4,"dislike":7,"score":-3,"quote":{"pid":"e748abc102e8bb33df714d4e2b4f9f0979092b93","tid":1005630,"uid":82851,"like":43,"dislike":1,"score":42,"citedBy":1,"replyTime":"2019-02-02T11:12:01.000Z","msg":"Topic 有9分，頗具吸引力<br />\n內容3分，過於冗長遲遲未能表達重點"},"citedBy":1,"replyTime":"2019-02-02T11:13:06.000Z","msg":"我兩分鐘睇完都叫長💩💩<br />\nching平時睇開公仔書<img src=\"/assets/faces/lny/pig2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/pig1.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-02-03T02:46:49.000Z","msg":"300字講完嘅野要用600字唔係冗長咁叫乜野。。。"},{"pid":"5ccdc1cb8b3300dbc2a4a1ffaffea77512c55aa4","tid":1005630,"uid":138,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-03T04:09:15.000Z","msg":"@n賓 你一撚定係個徒弟黎"},{"pid":"fab648ee9bc7746988f101d4c16efce2e1ff2657","tid":1005630,"uid":38189,"like":0,"dislike":0,"score":0,"quote":{"pid":"5ccdc1cb8b3300dbc2a4a1ffaffea77512c55aa4","tid":1005630,"uid":138,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-03T04:09:15.000Z","msg":"@n賓 你一撚定係個徒弟黎"},"citedBy":1,"replyTime":"2019-02-03T04:21:33.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"8ec440ed97e8bc51fbc963a243cb3d5dd08a2029","tid":1005630,"uid":138,"like":0,"dislike":0,"score":0,"quote":{"pid":"fab648ee9bc7746988f101d4c16efce2e1ff2657","tid":1005630,"uid":38189,"like":0,"d