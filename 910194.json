/sosad.gif\" class=\"hkgmoji\" /> <br />\n不過宜家都學緊主動多少少 唔好爭扎咁耐<img src=\"/assets/faces/fs/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5a531324e536707c41490ba8096a58cdff0c40b6","tid":910194,"uid":61843,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-22T08:53:56.000Z","msg":"好多 感情事<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"fd9a96ce9030a3f924fccceb85331b4d4e1c1598","tid":910194,"uid":82542,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa2a297005b8eeb8523953ccf1b4deb804c9c9bd","tid":910194,"uid":65220,"like":2,"dislike":0,"score":2,"quote":{"pid":"298e2b336d7abad76777ee098e53d69ec2b85c5b","tid":910194,"uid":82542,"like":0,"dislike":0,"score":0,"quote":{"pid":"1ff03e14ab480ac53eed2cc7fc2c4da37b5afd7c","tid":910194,"uid":65220,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-22T08:17:37.000Z","msg":"<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" /> <br />\n咁有無提自己多啲"},"citedBy":1,"replyTime":"2018-11-22T08:48:30.000Z","msg":"成日都同自己講下次先<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-22T08:52:33.000Z","msg":"內心爭扎完 人地都搞掂左 <img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /> <br />\n不過宜家都學緊主動多少少 唔好爭扎咁耐<img src=\"/assets/faces/fs/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-22T08:54:40.000Z","msg":"我發現我同你一樣搵工搵到懷疑人生<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"848f831704cbbe2874bcc28908ae55f53ae74c52","tid":910194,"uid":38744,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-22T08:57:55.000Z","msg":"會唔會只係你以為你有機會咋"}]}