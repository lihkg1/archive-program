595000052166/%e6%96%b0%e5%86%a0%e8%82%ba%e7%82%8e-%e5%b1%85%e5%bd%a9%e8%99%b9%e7%a2%ba%e8%a8%ba%e8%80%85%e5%af%b5%e7%89%a9%e8%b2%93-%e7%b3%9e%e4%be%bf%e4%b8%80%e5%ba%a6%e5%b0%8d%e6%96%b0%e5%86%a0%e7%97%85%e6%af%92%e5%91%88%e9%99%bd%e6%80%a7?web_push=1</a><br />\n<br />\n漁農自然護理署今晚（17日）表示，一名新型冠狀病毒確診者飼養的貓，其糞便樣本一度對新型冠狀病毒呈陽性，該混種短毛貓居於彩虹，現時沒有與新冠病毒相關的病徵。<br />\n<br />\n漁護署表示，涉事混種短毛貓因畜養人確診，於7月10日被送到港珠澳大橋口岸動物居留所接受檢疫，署方連日為牠抽取口腔、鼻腔、直腸及糞便樣本檢測，其中7月13日的糞便樣本對新冠病毒呈陽性，但其後收集的樣本均呈陰性。漁護署會繼續密切監察該貓，並為其反覆測試。"},{"pid":"4cd3ba82327d24fa27ceff32591fc129d5c180dd","tid":2112850,"uid":128179,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-17T15:42:43.000Z","msg":"<img src=\"/assets/faces/cat/sneeze.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/treat.gif\" class=\"hkgmoji\" />"},{"pid":"9007e9baab14daed144b34a95dbb0bdb4fa19e06","tid":2112850,"uid":70487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-17T15:43:37.000Z","msg":"<img src=\"/assets/faces/cat/sneeze.gif\" class=\"hkgmoji\" />"},{"pid":"ee8bbd556787ae5b8ba6219be6a3cb4dc042d25e","tid":2112850,"uid":72173,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-07-17T15:44:59.000Z","msg":"篤屎中姐 隻貓放左佢啦<img src=\"/assets/faces/dog/on_hold.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/on_hold.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"19f3d253c801ba27a3f8951aadf5c93b43f172c3","tid":2112850,"uid":12267,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-07-17T15:45:24.000Z","msg":"測試都幾次連隻貓都整死埋<img src=\"/assets/faces/lm2/noodles.gif\" class=\"hkgmoji\" />"},{"pid":"63e7ae4fc16f25c2546e19840735f9dff1157e2b","tid":2112850,"uid":29093,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2020-07-17T15:45:33.000Z","msg":"<img src=\"https://na.cx/i/kpQU9h7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FkpQU9h7.jpg&h=7ecdcbb7&s={SIZE}\" />"},{"pid":"0893449b9ceec945675ee48fec73f6f77b0