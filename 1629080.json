31\" data-auto-link target=\"_blank\">https://lih.kg/1666931</a>"},{"pid":"83861f5aecd0581b4f73116026b117bf74c83a6b","tid":1629080,"uid":19434,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-01T13:58:13.000Z","msg":"同問"},{"pid":"b2392f441dd0ee8a420b2287bd3bb1f69241a683","tid":1629080,"uid":128489,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-01T14:37:27.000Z","msg":"此回覆已被刪除"}]}