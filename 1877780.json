al/adore.gif\" class=\"hkgmoji\" />借位</div>"},{"pid":"6c62ee896bf0a08f3eb00538da15f98b9e400166","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-13T18:56:44.000Z","msg":"文呢<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"053dd49843249df3cebdf89e42c88c4e981949c5","tid":1877780,"uid":49931,"like":0,"dislike":0,"score":0,"quote":{"pid":"6c62ee896bf0a08f3eb00538da15f98b9e400166","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-13T18:56:44.000Z","msg":"文呢<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-13T20:36:53.000Z","msg":"今個星期五出！<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"5f611c9b918aafaf6f8d69331d9b2e832bd2d0ee","tid":1877780,"uid":234495,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-14T16:54:05.000Z","msg":"如果唔係白巴推文我差d唔記個咗有遍文<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n樓主要加油"},{"pid":"07dc68fde35fa1d1a97b250b3e7a452f24a68fd8","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"quote":{"pid":"053dd49843249df3cebdf89e42c88c4e981949c5","tid":1877780,"uid":49931,"like":0,"dislike":0,"score":0,"quote":{"pid":"6c62ee896bf0a08f3eb00538da15f98b9e400166","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-13T18:56:44.000Z","msg":"文呢<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-13T20:36:53.000Z","msg":"今個星期五出！<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-18T20:49:11.000Z","msg":"文呢<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"a8c351660091f6eb7cb02d658185ededd0ca7aac","tid":1877780,"uid":49931,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T09:37:42.000Z","msg":"她的右手懸在半空，但我卻猶豫應否接過她的問好。那是她第二次向我伸出右手，那是人類第無數次向我伸出右手。我再次下意識地以手掌將身體移開，我懷疑這個反射動作已經成為我無法改變的習慣，即使我並不抗拒她掌心的溫暖。我不敢正視她的臉，全因我難以直視她那雙帶有鄙視戓是竊笑的目光，那是能把靈魂勒死的目光。<br />\n<br />\n「Shika。」我斜視着她的右手，以逃避她的視線，我感受到我的臉頰因羞恥而發熱。她把右手抬起，抓了抓頭皮。我的視線不經意與她的視線對上，那是尷尬的眼神。人是奇怪的生物。言語的互通明明令人類的相處得以深入，但偏偏言語的互通有時卻令人更無言以對，我有點想變回一隻鹿。<br />\n<br />\n「你都係一個人黎旅行？」她保持着那禮貌而帶有距離的微笑。我有點討厭現在的她，我討厭這個陌生的她。我有點懷念那衷心的笑容，我難以清晰地回想那個笑容，彷彿那個笑容是一個古老的傳說。<br />\n<br />\n「你想唔想睇魚？」我不想繼續跟她談門面說話。<br />\n<br />\n「好呀。」她爽快地答應了。"},{"pid":"7e3319e6e43cbdb2b2bd78e938e6cf7ef4015851","tid":1877780,"uid":49931,"like":0,"dislike":0,"score":0,"quote":{"pid":"07dc68fde35fa1d1a97b250b3e7a452f24a68fd8","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"quote":{"pid":"053dd49843249df3cebdf89e42c88c4e981949c5","tid":1877780,"uid":49931,"like":0,"dislike":0,"score":0,"quote":{"pid":"6c62ee896bf0a08f3eb00538da15f98b9e400166","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-13T18:56:44.000Z","msg":"文呢<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-13T20:36:53.000Z","msg":"今個星期五出！<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-18T20:49:11.000Z","msg":"文呢<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-19T09:42:42.000Z","msg":"出咗<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />多謝巴打鞭策<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5859b7325bce9afa554bd8ddd05e9b778dbeac5b","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-22T20:16:59.000Z","msg":"文呢<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" />"},{"pid":"48afeb153021795e9c6efd634fb0c1c725a01715","tid":1877780,"uid":49931,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-23T16:11:49.000Z","msg":"我領着她走過一大片青葱的草原，那是鹿的天堂，也是鹿的地獄。我喜歡那片香甜的草原，但我卻討厭無故蜂擁而至的人群。有時候，我會在人群中感到窒息，就像我早已不屬於這片草原，縱然這是我唯一的住處。<br />\n<br />\n然後有一天，我無意間發現了那片小天地。沒有人，沒有鹿，只有我自己。在密匝匝的人群間，這個地方有如世外桃園。林中平靜的湖面上時而泛起十數片銀鱗，細看便是悠遊的米鱂。湖邊那群瓣藍蕊紫的雛菊總愛與微風共舞，在無邊的舞台表演一齣清新的默劇，為那僅餘而唯一的觀眾獻技。<br />\n<br />\n我一如以往走到樹林的入口，她卻突然把我叫住：「Shika。」我回頭一看，始發現她止住了腳步，「就咁入去會唔會唔係咁好？」"},{"pid":"c32800c1c6b882cf98721c91f159c5cf32a548b0","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-25T19:22:39.000Z","msg":"<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"f4f8ae503acda3c5c59320a3f34940c282e378ab","tid":1877780,"uid":49931,"like":0,"dislike":0,"score":0,"quote":{"pid":"c32800c1c6b882cf98721c91f159c5cf32a548b0","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-25T19:22:39.000Z","msg":"<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-26T13:31:42.000Z","msg":"逢星期五會出文<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"614fdf8632bc01d610fc275626a87cf3df8b1206","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-01T18:39:01.000Z","msg":"文呢<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" />"},{"pid":"69dcf8b56b743b767763d6075fffa4aa54171793","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-03T19:00:41.000Z","msg":"文呢<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" />"},{"pid":"b18b8f6c137ba6a9edadc2ed0e49f324d1bb6a7b","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-04T19:22:37.000Z","msg":"文<img src=\"/assets/faces/lm2/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"01f5c9b100d5daf14a32fce8122aa9e67178ed9a","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-11T19:00:39.000Z","msg":"文呢<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" />"},{"pid":"9c7574e589a2012b17b3f336cbb81525f67f91ce","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T20:41:29.000Z","msg":"文呢<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" />"},{"pid":"0d986bc5d0c7e4cfaafa7d1fa8dd5ae4bb58eca1","tid":1877780,"uid":246289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-15T21:13:34.000Z","msg":"又話星期五出文<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"}]}