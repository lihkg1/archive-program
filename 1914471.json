/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"d2a620f0b7a67bf30252d7a1179d278e9871f61a","tid":1914471,"uid":58900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-07T18:06:15.000Z","msg":"女仔肯主動 通常都會汁到好嘢"},{"pid":"2f23e4189e08b2ccadbb495b3a09b4f16f0d7fbc","tid":1914471,"uid":350584,"like":0,"dislike":0,"score":0,"quote":{"pid":"128e8ba80c2d7427a0ba7cbc9154514300374405","tid":1914471,"uid":74100,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-07T17:54:29.000Z","msg":"女仔一般唔敢主動 想吸引對方&gt;主動<br />\n但係如果有競爭對手可以試下主動既 得就得唔得咪算<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-07T18:06:55.000Z","msg":"就係唔主動最後咪成日悲劇收場，再上黎連登叫春...<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<br />\n主動d啦，明示d啦，冇人叫你倒貼但點都要主動下啦"},{"pid":"ba76a740f8d3a180addf51fdd40997c6404f6b7d","tid":1914471,"uid":145230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-07T18:15:52.000Z","msg":"此回覆已被刪除"},{"pid":"50c9c8980e9a893c2ab3b37e1cb92a1c46a1eee4","tid":1914471,"uid":74239,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-07T18:44:21.000Z","msg":"主動啲爭取啦！主動啲咋嘛又唔係叫你即刻表白！<br />\n退一萬步講，就算失敗，之後你諗返都會覺得冇乜嘢<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"e762c4ccd551d9f1117ef4b2cf9f9d62fe4e25cd","tid":1914471,"uid":335202,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-07T18:47:16.000Z","msg":"鍾意就去馬啦<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<br />\n既然知道自己鍾意既對象對自己有好感 應該比啲信心自己 主動啲搵對方 <br />\n<br />\n如果一直都係個男仔主動搵你 而你好被動既話 對方就會覺得你其實對佢冇意思 慢慢佢就會放棄唔搵你<br />\n<br />\n唔洗因為你係女仔就一定要男仔主動 好難得自己鍾意既人對自己都有好感<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><br />\n<br />\n到時見到佢同第二個女仔一齊咪仲難受 唔好比自己後悔啊樓主<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"dd47c3721de1c8c5328b7303010b34e48591760d","tid":1914471,"uid":308421,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-08T03:52:12.000Z","msg":"絲打去馬啦  唔去馬遲下佢俾第個女仔溝走咗你喊都喊唔翻<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><br />\n唔敢主動嘅話試下俾啲signal佢溝你<br />\n如果佢都對你有好感嘅話就會就會明你啲signal㗎啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\nEg同佢講邊度開咗間新餐廳 咩咩好好食咁 借啲意約下佢出街 如果有好感嘅十成九都會應約<br />\nBtw我覺得鍾意一個人嘅話唔應該追佢  <br />\n應該做啲嘢令到佢覺得你吸引 例如性格 又或者外表 <br />\n真係鍾意嘅話追都唔使追 好自然就會一齊 <br />\n我同我男朋友無追過大家 未一齊前出街都只係好似普通朋友咁 但出咗幾次街佢拖落嚟就一齊咗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e2175da39f6b7dbe3998b83d65ac6f42f6cd29c9","tid":1914471,"uid":176567,"like":0,"dislike":0,"score":0,"quote":{"pid":"6f68bdd4991879902748d53cb5aae4945281ab48","tid":1914471,"uid":345160,"like":0,"dislike":0,"score":0,"quote":{"pid":"8d16336f48d4a9240530facb363ae28227326770","tid":1914471,"uid":176567,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-07T16:52:44.000Z","msg":"衰D講句 家下肺炎 <br />\n你有鍾意既人好快上"},"citedBy":1,"replyTime":"2020-03-07T17:12:50.000Z","msg":"兩樣嘢有咩關係<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-08T05:50:41.000Z","msg":"叫你珍惜眼前人"}]}