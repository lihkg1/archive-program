i/yt2HG33.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fyt2HG33.jpg&h=9fcb0aae&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/TrPZKfU.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTrPZKfU.jpg&h=433e1fe6&s={SIZE}\" />"},{"pid":"0425dcc65b8ceb0eaaf680013a4369e713609b7d","tid":1576001,"uid":18271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T05:03:55.000Z","msg":"<img src=\"https://na.cx/i/vHTzyJS.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FvHTzyJS.jpg&h=1924b607&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/pE6A2Cc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpE6A2Cc.jpg&h=26dcba71&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/dDb5FoS.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FdDb5FoS.jpg&h=eb7897a9&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/xejGdJS.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxejGdJS.jpg&h=ea5b2155&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/g7q6pQy.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fg7q6pQy.jpg&h=99eb6c94&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/jiBtDay.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjiBtDay.jpg&h=7fc78144&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/3yPKVXd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3yPKVXd.jpg&h=5f5bdc5c&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/mXWEKQy.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmXWEKQy.jpg&h=62808a41&s={SIZE}\" /><br />\n<br />\n9月18日（星期三）晚上<br />\n7:30維多利亞公園球場集合<br />\n8:00組成人鏈<br />\n8:15無間斷大合唱<br />\n9:00自由活動<br />\n我地要令各地球迷知道不分你我目標一致<br />\n<br />\n*請穿着各自愛隊波衫<br />\n<br />\n傳達訊息:<br />\n我地來自唔同球會嘅支持者<br />\n可能係宿敵或者係競爭對手<br />\n但係面對住社會種種嘅不公議<br />\n所有球迷放下成見，恩怨<br />\n為我地嘅地方香港發聲<br />\n球場以外無分你我，共同進退！<br />\n<br />\nEnglish:<br />\nWe are supporters of different soccer clubs. But as we confront the regime, and the injustice we face in society, together we set aside our prejudice. Join the action with us and let Hong Kong hear our voices. There is no opponent on the field , it's just you and us as a team. We advance , we retreat, together as team Hong Kong. Add oil Hong Kong<br />\n<br />\n<br />\n最終目標:<br />\n推到上世界各地體育版頭版！！<br />\n<br />\n<br />\n就著近日伊朗球迷睇波被判監，我地都會有口號去支持<br />\nFight for freedom<br />\nStand with Iran<br />\nFight for freedom<br />\nStand with Hong Kong<br />\n<br />\n歌曲<br />\n《願榮光歸香港》《黃金入球》<br />\n8:15  8:30  8:45  9:00<br />\n<br />\n行動TG group: <a href=\"https://t.me/joinchat/LSlOKkiPRAnfTT-s4Mu8RA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fjoinchat%2FLSlOKkiPRAnfTT-s4Mu8RA&d=ZtzEMfLxU%2BwdrFVc2rz1%2F63e3GGuF%2FCnRpDBLK0zENU%3D&h=c69a55dd\" data-auto-link target=\"_blank\">https://t.me/joinchat/LSlOKkiPRAnfTT-s4Mu8RA</a>"},{"pid":"3a1cd02852d2aa12c5a8a5b420c8e067d16fd2e6","tid":1576001,"uid":52779,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T05:04:13.000Z","msg":"我地都可以為新屋嶺班手足做啲野<br />\n<a href=\"https://lih.kg/1575396\" data-auto-link target=\"_blank\">https://lih.kg/1575396</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"f166776eca83a5f155944549648cba391f195dab","tid":1576001,"uid":12773,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T05:04:31.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"93230f62c50f27e85c3120e