65eb1358852c494f37bb4adc987de93db49","tid":1701331,"uid":86433,"like":0,"dislike":0,"score":0,"quote":{"pid":"619b7bc21af9e0fda25d7dd13cbd4da68cd5f7ad","tid":1701331,"uid":97389,"like":19,"dislike":0,"score":19,"quote":{"pid":"7deaab7441a4e6958b1d65f6854f5d48cbc87c03","tid":1701331,"uid":287387,"like":23,"dislike":0,"score":23,"citedBy":3,"replyTime":"2019-11-09T04:43:40.000Z","msg":"睇黎cancel指紋用返密碼安全d"},"citedBy":1,"replyTime":"2019-11-09T05:17:20.000Z","msg":"一早講佐，keyfile, device, password永遠比生物認證安全。"},"citedBy":1,"replyTime":"2019-11-09T11:04:03.000Z","msg":"周圍都CCTV 除非你部電話唔用<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />如果唔係都幾難次次都係無CCTV既情況係解鎖"},{"pid":"00ab7bf664b5e2b69fe5d98ce46cb3c523bdf0ab","tid":1701331,"uid":77180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T11:05:46.000Z","msg":"中國好先進<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"3d2017c36e9d9885a4bc038e5161bac3abacfc61","tid":1701331,"uid":36013,"like":0,"dislike":0,"score":0,"quote":{"pid":"efcd125c31c578a5bffe3619491b2ffcc8e1da70","tid":1701331,"uid":34708,"like":3,"dislike":0,"score":3,"quote":{"pid":"79ccb5d56f22a9afe01436add92ac167a74213d1","tid":1701331,"uid":66271,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-09T04:01:12.000Z","msg":"<img src=\"https://cdn.i-scmp.com/sites/default/files/styles/1320w/public/d8/images/2019/10/25/tencent_geekpwn.jpg?itok=-WoCvLTg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.i-scmp.com%2Fsites%2Fdefault%2Ffiles%2Fstyles%2F1320w%2Fpublic%2Fd8%2Fimages%2F2019%2F10%2F25%2Ftencent_geekpwn.jpg%3Fitok%3D-WoCvLTg&h=7604d4fa&s={SIZE}\" /><br />\n<br />\n不少智能電話都採用指紋辨識技術，核實用戶身份去解鎖手機或確認交易，現時主要的指紋辨識技術分為：超聲波、電容和光學 3 種。在早前於上海舉行的 GeekPwn 2019 國際安全極客大賽，騰訊安全的玄武實驗室展示破解上述 3 種指紋辨識技術的方法<br />\n<br />\n玄武實驗室邀請現場觀眾在玻璃杯留下指紋，然後利用他們開發的程式採集指紋信息，再以雕刻機將指紋複製。大約 20 分鐘就能夠完成複製程序，實驗室工作人員示範利用指紋模型成功解鎖 3 部智能電話，並在 2 部打卡機核實身份。騰訊安全玄武實驗室表示採集和破解指紋的技術，都是由他們自家研發，只需小面積殘影就足以將指紋複製，而硬件成本只需約 1,000 人民幣（約 1,120 港元）。<br />\n<br />\n騰訊安全玄武實驗室指，他們已經向多家指紋辨識裝置供應商提供資料，希望能夠填塞漏洞，提升指紋辨識技術的安全程度。"},"citedBy":1,"replyTime":"2019-11-09T04:54:08.000Z","msg":"只需小面積殘影就足以將指紋複製<br />\n會唔會係wechat平時收集晒指紋 <br />\n用果小小殘影係database搵返出黎"},"citedBy":0,"replyTime":"2019-11-09T11:06:06.000Z","msg":"拎左14億人做training set, 殘影 project返全隻出嚟"},{"pid":"3222cc3a02edecaa708acdcb95ea4da1e9a4a328","tid":1701331,"uid":97389,"like":0,"dislike":0,"score":0,"quote":{"pid":"7fdbe65eb1358852c494f37bb4adc987de93db49","tid":1701331,"uid":86433,"like":0,"dislike":0,"score":0,"quote":{"pid":"619b7bc21af9e0fda25d7dd13cbd4da68cd5f7ad","tid":1701331,"uid":97389,"like":19,"dislike":0,"score":19,"quote":{"pid":"7deaab7441a4e6958b1d65f6854f5d48cbc87c03","tid":1701331,"uid":287387,"like":23,"dislike":0,"score":23,"citedBy":3,"replyTime":"2019-11-09T04:43:40.000Z","msg":"睇黎cancel指紋用返密碼安全d"},"citedBy":1,"replyTime":"2019-11-09T05:17:20.000Z","msg":"一早講佐，keyfile, device, password永遠比生物認證安全。"},"citedBy":1,"replyTime":"2019-11-09T11:04:03.000Z","msg":"周圍都CCTV 除非你部電話唔用<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />如果唔係都幾難次次都係無CCTV既情況係解鎖"},"citedBy":1,"replyTime":"2019-11-09T11:08:14.000Z","msg":"要練下插褲袋按手機密碼解鎖神功<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"d6b4a40b4924aa067e25de70e41c6005d122b933","tid":1701331,"uid":97389,"like":0,"dislike":0,"score":0,"quote":{"pid":"3222cc3a02edecaa708acdcb95ea4da1e9a4a328","tid":1701331,"uid":97389,"like":0,"dislike":0,"score":0,"quote":{"pid":"7fdbe65eb1358852c494f37bb4adc987de93db49","tid":1701331,"uid":86433,"like":0,"dislike":0,"score":0,"quote":{"pid":"619b7bc21af9e0fda25d7dd13cbd4da68cd5f7ad","tid":1701331,"uid":97389,"like":19,"dislike":0,"score":19,"citedBy":1,"replyTime":"2019-11-09T05:17:20.000Z","msg":"一早講佐，keyfile, device, password永遠比生物認證安全。"},"citedBy":1,"replyTime":"2019-11-09T11:04:03.000Z","msg":"周圍都CCTV 除非你部電話唔用<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />如果唔係都幾難次次都係無CCTV既情況係解鎖"},"citedBy":1,"replyTime":"2019-11-09T11:08:14.