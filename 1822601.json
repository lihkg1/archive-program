/>"},{"pid":"a631977055ecb5523e31c60c88bbd8c4e84bd9b9","tid":1822601,"uid":1072,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-13T07:27:08.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b424c39f49257f817fb0606f0270386a940d6add","tid":1822601,"uid":266289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-13T07:29:24.000Z","msg":"半間屋200萬太少"}]}