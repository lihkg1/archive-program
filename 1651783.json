i/6Egk13F.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6Egk13F.jpg&h=f648d3e2&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-10-13T13:22:38.000Z","msg":"26個係加埋上水嗰啲<br />\n12個先啱"},{"pid":"004f8ead688b16f79da2bc6f861d85aaa4d876dd","tid":1651783,"uid":44423,"like":0,"dislike":0,"score":0,"quote":{"pid":"e3b28491e0a766058d4eec6ccb87ba801424fc1c","tid":1651783,"uid":78377,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-13T13:14:40.000Z","msg":"點解會走去P都唔走去碧湖方向<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n上唔到橋都可以去跳番入粉中個鐵欄揾地方避"},"citedBy":0,"replyTime":"2019-10-13T13:27:17.000Z","msg":"有啲人跟住前面跑去馬路"},{"pid":"03242dd2a21b99a6be6ad1de055bf5679a6b3611","tid":1651783,"uid":189996,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-13T13:28:10.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"c7e19bd3837528f7c328202b1e3e3cf0a62cf6b3","tid":1651783,"uid":44423,"like":0,"dislike":0,"score":0,"quote":{"pid":"03242dd2a21b99a6be6ad1de055bf5679a6b3611","tid":1651783,"uid":189996,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-13T13:28:10.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-13T13:34:53.000Z","msg":"發夢見到有個睇落好細個細細粒&hellip;似中學低form&hellip;"},{"pid":"353d22eaa212061171dea5f8ff04a4e6cb28e347","tid":1651783,"uid":64810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-13T13:34:58.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"5e74bd33f18d7179be787216a0a4906fc5d2aac2","tid":1651783,"uid":325181,"like":0,"dislike":0,"score":0,"quote":{"pid":"9f5ae7a68f0d718164880866033679da1bf9050c","tid":1651783,"uid":44423,"like":0,"dislike":0,"score":0,"quote":{"pid":"938c065940241354835d6095a9f14eafbc9e35e8","tid":1651783,"uid":258566,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-13T12:49:22.000Z","msg":"此回覆已被刪除"},"citedB