3:14.000Z","msg":"好様衰，加埋陣蝗味"},{"pid":"22d7aa8792fd38d646c6eb4a90a8461b978a280f","tid":500543,"uid":45189,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-12-16T02:04:30.000Z","msg":"Yes <br />\n勁樣衰<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d04b77bd10548c13b8a1b51b878263252503955f","tid":500543,"uid":52972,"like":7,"dislike":250,"score":-243,"citedBy":0,"replyTime":"2017-12-16T02:05:00.000Z","msg":"我覺得呢幾張好靚<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/12/16/100432_fdb518c99db577d8cf73e1d298e469a4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F16%2F100432_fdb518c99db577d8cf73e1d298e469a4.jpg&h=f83f4759&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2017/12/16/100435_e9d2f530155264fc1eb60be2b7b9438e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F16%2F100435_e9d2f530155264fc1eb60be2b7b9438e.jpg&h=e5c716c1&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2017/12/16/100437_fdf3b1368fbbda598b1d26e5c7f63e98.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F16%2F100437_fdf3b1368fbbda598b1d26e5c7f63e98.jpg&h=15f33ab5&s={SIZE}\" />"},{"pid":"2cee1d3f0a04ce77897786a5ef35c5372972f001","tid":500543,"uid":53666,"like":6,"dislike":5,"score":1,"citedBy":0,"replyTime":"2017-12-16T02:06:03.000Z","msg":"<blockquote>好様衰，加埋陣蝗味</blockquote><br />\n<br />\n台灣又蝗？ <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"13f7004839c15b584ec94bf7c0be6cbfd3d739bb","tid":500543,"uid":100052,"like":17,"dislike":1,"score":16,"citedBy":0,"replyTime":"2017-12-16T02:07:04.000Z","msg":"對眼好開，好怪<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3a46a5515372f09e63dd1eedf0a1379d4ac28f22","tid":500543,"uid":112528,"l