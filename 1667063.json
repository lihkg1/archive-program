=\"https://lih.kg/1666931\" data-auto-link target=\"_blank\">https://lih.kg/1666931</a>"},{"pid":"ea52d2a496757f49e4beea82f3890ce9c4422c66","tid":1667063,"uid":319596,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-21T10:51:50.000Z","msg":"tg:LalallaNt"},{"pid":"49d1a643d707edd657d808fb99fa84566d2b95a0","tid":1667063,"uid":319596,"like":0,"dislike":0,"score":0,"quote":{"pid":"ea52d2a496757f49e4beea82f3890ce9c4422c66","tid":1667063,"uid":319596,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-21T10:51:50.000Z","msg":"tg:LalallaNt"},"citedBy":0,"replyTime":"2019-10-21T10:52:26.000Z","msg":"hhb as well"},{"pid":"41a703425aa2e80736bdf1b7be49804f0f2e4fc4","tid":1667063,"uid":310041,"like":0,"dislike":1,"score":-1,"quote":{"pid":"27cbbdc3b07d1fe6126658a6c4030f39f9517d02","tid":1667063,"uid":318497,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-21T09:08:18.000Z","msg":"可能因為自己太投入發夢<br />\n冇咩興趣識身邊啲港豬<br />\n有冇fm同我一樣可以做個朋友?<br />\n留個tg我搵你<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><br />\n利申: 返hhb 唔係完全冇朋友但大部分時間自己一個"},"citedBy":0,"replyTime":"2019-11-05T17:48:47.000Z","msg":"可以識個朋友啊(⁎⁍̴̛ᴗ⁍̴̛⁎)<br />\nHhb campus~<br />\nTG:xxEllyxx"}]}