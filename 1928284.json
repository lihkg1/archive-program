moji\" />"},{"pid":"95d21374b297a9199ce71c3dca42e2949bed5eff","tid":1928284,"uid":43133,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T11:38:06.000Z","msg":"告佢老味臭閪<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"352232581ddca636cab459334e305bbac0fb307a","tid":1928284,"uid":122275,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-16T12:09:36.000Z","msg":"告贏左有咩著數"},{"pid":"31808d1152a33200252216e2972a2c2b846e9579","tid":1928284,"uid":3776,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T12:16:49.000Z","msg":"贏左...支那會賠錢嗎？"},{"pid":"0017813b74189135d51f714d6f0b720ab7c36e78","tid":1928284,"uid":40267,"like":0,"dislike":0,"score":0,"quote":{"pid":"352232581ddca636cab459334e305bbac0fb307a","tid":1928284,"uid":122275,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-16T12:09:36.000Z","msg":"告贏左有咩著數"},"citedBy":0,"replyTime":"2020-03-16T12:19:22.000Z","msg":"放風比支那<br />\n你再玩fake news唔好迫我全民反支"}]}