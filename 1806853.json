 src=\"/assets/faces/pigxm/upset_r.gif\" class=\"hkgmoji\" />"},{"pid":"d30eb4565513f48e9dfad11f585df645e8862551","tid":1806853,"uid":27561,"like":1,"dislike":0,"score":1,"quote":{"pid":"a6c920564dbbdd7025582baf0f16e84cdc4f9978","tid":1806853,"uid":100337,"like":0,"dislike":0,"score":0,"quote":{"pid":"3a85493a5b222084623624460c4754f2653a1f41","tid":1806853,"uid":27561,"like":0,"dislike":0,"score":0,"quote":{"pid":"e8fad24d3dbc81dcd151df112c50113f2f1d54e4","tid":1806853,"uid":100337,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-01T14:10:44.000Z","msg":"若果我地滲透返落工聯會到再推返佢得唔得？"},"citedBy":1,"replyTime":"2020-01-01T14:21:32.000Z","msg":"不是不得。效果遠不及成立一個新的。<br />\n<br />\n加入左工會未？"},"citedBy":1,"replyTime":"2020-01-01T14:35:29.000Z","msg":"<img src=\"/assets/faces/normal/bouncy.gif\" class=\"hkgmoji\" /><br />\n但怕開個新嘅未上軌道就被禁"},"citedBy":1,"replyTime":"2020-01-01T14:51:27.000Z","msg":"不是怕就不做。<br />\n不是因為成效少而不為；<br />\n是要一步一步一點一點去做：你可能覺得我是理想主義者：<br />\n但我跟你說：千里之行始於足下。<br />\n<br />\n共勉之。"},{"pid":"65fe0241d0245f1f9f0781ff19056ba1b9ec77df","tid":1806853,"uid":35456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-01T14:53:23.000Z","msg":"此回覆已被刪除"},{"pid":"06abb43d5910d8e85776a166b9154972c02fd406","tid":1806853,"uid":66719,"like":0,"dislike":0,"score":0,"quote":{"pid":"84d1b52761afc89eea5d9aa813ac46150f7bf998","tid":1806853,"uid":12241,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-01-01T14:04:41.000Z","msg":"勇武抗爭都係犯法<br />\n驚乜鳩"},"citedBy":0,"replyTime":"2020-01-01T14:55:37.000Z","msg":"和理非唔方便做犯法野？<img src=\"/assets/faces/xm/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"d44e7e63d38a84135c9f511aab5ae3bb3c5ca7e6","tid":1806853,"uid":253983,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-01-01T14:57:40.000Z","msg":"基本法第二十七條 <br />\n香港居民享有言論、新聞、出版的自由，結社、集會、遊行、示威的自由，組織和參加工會、罷工的權利和自由。 <br />\n<br />\n你禁工會，我仲唔幾條戰線炸鳩你，話你違反中英聯合聲明？"},{"pid":"db875d7f2f6d411ddd0c0fe691b5f353bdb01fa5","tid":1806853,"uid":66324,"like":0,"dislike":0,"