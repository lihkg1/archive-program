assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"73ee46c8aaa1aa9f8762a88d2e4ce41816e58b6d","tid":2439913,"uid":10901,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-10T01:35:05.000Z","msg":"復星醫藥與BioNTech合作研發<br />\n復星醫藥與BioNTech合作研發<br />\n復星醫藥與BioNTech合作研發<br />\n復星醫藥與BioNTech合作研發<br />\n復星醫藥與BioNTech合作研發<br />\n<br />\n咁厚顏<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"cacb93579cc78f810e30245c53afef6ebcba5b73","tid":2439913,"uid":276989,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-03-10T01:52:16.000Z","msg":"只係簽左做亞太區分銷商，就係咁簡單"},{"pid":"1d83e7c30a32737ff91e1d1f065c57664e390b61","tid":2439913,"uid":173002,"like":0,"dislike":0,"score":0,"quote":{"pid":"cacb93579cc78f810e30245c53afef6ebcba5b73","tid":2439913,"uid":276989,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-03-10T01:52:16.000Z","msg":"只係簽左做亞太區分銷商，就係咁簡單"},"citedBy":0,"replyTime":"2021-03-11T16:12:25.000Z","msg":"唔係成個亞太，係淨係得強國同狆共佔領區，<br />\n原因只因強國唔俾美國輝瑞同德國BioNTech係強國分發疫苗，一定要搵強國公司，不過輝瑞疫苗係強國一直挪唔到批文，所以復星仍然無得係強國生產所謂復必泰嘅輝瑞疫苗。"}]}