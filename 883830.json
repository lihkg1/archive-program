{"tid":883830,"cid":5,"subCid":0,"title":"【金庸逝世】王志民讚愛國愛港促進一國兩制　作品蘊民族大義","createTime":"2018-10-31T06:26:27.000Z","updateTime":"2018-10-31T06:51:17.000Z","uid":75969,"like":0,"dislike":5,"uniUserReply":3,"replies":[{"pid":"92e63ea0afb94385589b68928266b3034d9c36b9","tid":883830,"uid":75969,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-31T06:26:27.000Z","msg":"<img src=\"https://fs.mingpao.com/ins/20181031/s00001/cac3b97bc32b556aecd3d86f7a3eb54e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffs.mingpao.com%2Fins%2F20181031%2Fs00001%2Fcac3b97bc32b556aecd3d86f7a3eb54e.jpg&h=45f93474&s={SIZE}\" /><br />\n<br />\n《明報》創辦人、筆名金庸的武俠小說泰斗查良鏞昨日離世，享年94歲。中聯辦主任王志民致唁電悼念表示沉痛悼念。<br />\n<br />\n王志民指，查良鏞作品深蘊「民族大義」和「家國情懷」，對海內外華人產生了深遠影響，讚揚「畢生心繫國家、愛國愛港，為促進『一國兩制』事業發展做了大量卓有成效的工作，為弘揚中華文化作出了重大貢獻」。<br />\n<br />\n特首林鄭月娥昨日亦表示深切哀悼，讚揚查良鏞作品對傳承中華文化有莫大貢獻。<br />\n<br />\n<a href=\"https://news.mingpao.com/ins/instantnews/web_tc/article/20181031/s00001/1540944448562\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.mingpao.com%2Fins%2Finstantnews%2Fweb_tc%2Farticle%2F20181031%2Fs00001%2F1540944448562&d=THuf5Gc%2FlHAsI2zGJgWxltU7RO4jIL0fLOArxO5LqtQ%3D&h=73256fa3\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.mingpao.com%2Fins%2Finstantnews%2Fweb_tc%2Farticle%2F20181031%2Fs00001%2F1540944448562&h=19488a49\" target=\"_blank\">https://news.mingpao.com/ins/instantnews/web_tc/article/20181031/s00001/1540944448562</a>"},{"pid":"8f512f1f522e8ced4a57ee512eed7668f42f612c","tid":883830,"uid":49391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-31T06:50:30.000Z","msg":"<a href=\"https://youtu.be/aA2PnpJ-t2s\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FaA2PnpJ-t2s&d=THuf5Gc%2FlHAsI2zGJgWxltU7RO4jIL0fLOArxO5LqtQ%3D&h=bc0a2396\" target=\"_blank\">https://youtu.be/aA2PnpJ-t2s</a>"},{"pid":"d9262fad9755f1eb7e10f4f70df6b624a338f53b","tid":883830,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-31T06:51:17.000Z","msg":"無屈佢<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"}]}