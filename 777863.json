ssets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"d7b21b60dc2bcfeeffe4e450b538b671d2f3873c","tid":777863,"uid":62830,"like":0,"dislike":0,"score":0,"quote":{"pid":"0e003c44ae63424b694609406335ea9334b822f8","tid":777863,"uid":165495,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-13T14:19:18.000Z","msg":"咁我都係飲食著手, 做返D簡單sit up 掌上壓先"},"citedBy":0,"replyTime":"2018-08-13T15:01:19.000Z","msg":"如果你比較肥，掌上壓會比較易受傷"},{"pid":"704d359dbd1876f0101c05319b553e27112eaa8a","tid":777863,"uid":129169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-13T15:03:16.000Z","msg":"其實揾黎做咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n做gym有恆心，上youtube睇幾條片唔好用錯力就得"},{"pid":"23fc018eca00188365f8f981f705dda9d9c8567b","tid":777863,"uid":165495,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-13T15:13:41.000Z","msg":"我岩岩見AASFP 讀個高級私人體適能教練證書課程 都係萬一蚊 <br />\n係唔係讀完應該識得點做?  咁讀完自己做好似仲實際"},{"pid":"9f317f236045ad262e46bed84b0369df0ce086a1","tid":777863,"uid":59863,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-13T15:30:00.000Z","msg":"上網大把教材啦<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />  一是 上康文署個器械健身班 好似幾十蚊有10堂 你主動小小問個教練 佢都教你啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />  上完又可以之後自由去康文署健身室<br />\n認真 你隔日跑5K 每日朝早30下正確嫁掌上壓 夜晚30下  做到悶咪練下深噂  <br />\n三樣簡單訓練幫到你心肺 減脂  二三頭肌 胸肌 同大腿肌  再升級就做引體上升 訓練埋背肌 <br />\n配合飲食 keep 3個月 包證有明顯嫁進步<br />\n健身慢慢搵一個自己節奏來做就Ok"},{"pid":"865924bd2d26a837355f2e0cdad44301380c7cd7","tid":777863,"uid":61120,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-13T15:32:51.000Z","msg":"留名學野"},{"pid":"8af9fc8393504bd9de12f14b680a5fe10bd15afd","tid":777863,"uid":1482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-13T15:34:30.000Z","msg":"搵胡cfu"},{"pid":"717c208dd31ac08051e5fa0a3fdb4f92c839c869","tid":777863,"uid":185126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-14T03:31:11.000Z","msg":"搵PT無問題<br />\n如果你嫌錢多"}]}