ps%3A%2F%2Fna.cx%2Fi%2FzfcLXJT.jpg&h=707d5f4c&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-09-15T17:41:16.000Z","msg":"<strong>訂檯先𨳒！</strong>"},{"pid":"9b38c03c834c8210ddf50a636bb0b28e3805f0eb","tid":1566880,"uid":59985,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T06:48:37.000Z","msg":"<img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" />"},{"pid":"1517e466d6a1090c61ccc439aba821ecdfaf6000","tid":1566880,"uid":186072,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T07:06:46.000Z","msg":"組隊入去撚下佢地<br />\n但記住叫完啲野千奇唔好食<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"e0a1e58393c1e7b90f3549a0f34a167171fd0dfe","tid":1566880,"uid":151163,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T07:26:20.000Z","msg":"Ok <img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" />"},{"pid":"56a12b83c7d13e96e8b5981ddb3f79e7c2b5d6b7","tid":1566880,"uid":14103,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-16T07:30:46.000Z","msg":"加入夾公仔apps未"},{"pid":"6ad838368b5a10c6b15ba47d8f2a5fef2633f61b","tid":1566880,"uid":59985,"like":0,"dislike":0,"score":0,"quote":{"pid":"56a12b83c7d13e96e8b5981ddb3f79e7c2b5d6b7","tid":1566880,"uid":14103,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-16T07:30:46.000Z","msg":"加入夾公仔apps未"},"citedBy":0,"replyTime":"2019-09-16T11:25:10.000Z","msg":"幫手向admin舉報"},{"pid":"c2379f17b07b03ccaf226a28d96da1ad047fe77e","tid":1566880,"uid":59985,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T14:53:48.000Z","msg":"<img src=\"/assets/faces/mf/smile.png\" class=\"hkgmoji\" />"},{"pid":"cb99ebbc37d5b50d9c63a84274e597389ffd2b9c","tid":1566880,"uid":59985,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T17:19:33.000Z","msg":"<img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" />"},{"pid":"1d81b4414aa2