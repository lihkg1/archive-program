cb1-657-1-c.pdf&d=%2BEgMKdsH73Wj%2FuX4aBpXdiq0XD4M5CHb8byFtBYuAsM%3D&h=e3934fb8\" data-auto-link target=\"_blank\">https://www.legco.gov.hk/yr06-07/chinese/panels/fa/papers/facb1-657-1-c.pdf</a><br />\n<br />\n圖片來源：GOOGLE IMAGE"},"citedBy":0,"replyTime":"2019-08-15T07:59:44.000Z","msg":"補充<br />\n圖片來源：<br />\n香港資金流指標：<a href=\"https://www.macromicro.me/collections/31/cn-finance-relative/3766/hk-cash-flow\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.macromicro.me%2Fcollections%2F31%2Fcn-finance-relative%2F3766%2Fhk-cash-flow&d=%2BEgMKdsH73Wj%2FuX4aBpXdiq0XD4M5CHb8byFtBYuAsM%3D&h=5cffb10b\" data-auto-link target=\"_blank\">https://www.macromicro.me/collections/31/cn-finance-relative/3766/hk-cash-flow</a>"},{"pid":"0469c1b8ba53730fee28dbc06396afe566f893ca","tid":1474500,"uid":87541,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:00:02.000Z","msg":"推"},{"pid":"459db6fcfbe01e0badff1e070e356a49d2016759","tid":1474500,"uid":92074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:03:15.000Z","msg":"前幾日係中銀拎咗成副身家，諗住買條金條加5000美金<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3ca40eb8343cac1eae381b79c27d2cbbb9fcb521","tid":1474500,"uid":45830,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:04:00.000Z","msg":"推"},{"pid":"13f1b832dc630f302b8ea225e60a44845c28fc3c","tid":1474500,"uid":307668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:25:04.000Z","msg":"推"},{"pid":"5bc8438fa03813db344105bd628c3859b14b8fa1","tid":1474500,"uid":307668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:28:08.000Z","msg":"推"},{"pid":"cb08b379f37809e57b5136beacfec3c76c29d4d5","tid":1474500,"uid":307668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:28:23.000Z","msg":"推"},{"pid":"476ad13efd45eafd03c9eb2b4c66fbd2610f44df","tid":1474500,"uid":307668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T08:28:38.000Z","msg"