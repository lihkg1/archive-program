0e8c861a72d82d2c4e0","tid":1301904,"uid":187796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T02:59:27.000Z","msg":"冇人推？"},{"pid":"b08dd43f6c839c1312175dc9f6e5b983694677fb","tid":1301904,"uid":276020,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T03:07:59.000Z","msg":"推"},{"pid":"00f96e6f7716fc6cafbf6a816dc8b97cc3da8e5e","tid":1301904,"uid":203929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T03:55:22.000Z","msg":"Push"},{"pid":"97fcbc142e11128883654581e4937325ab8f7091","tid":1301904,"uid":255992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T06:29:07.000Z","msg":"<span style=\"color: red;\"><strong><span style=\"font-size: x-large;\">各位有心參加呢次有人既人睇睇</span></strong></span><br />\n<br />\n身為上水人,要等各區既人了解下...<br />\n首先先唔理佢遊行路線,我諗金金大致都係圍住d水貨點慢行,但行完希望大家唔好咁快散,要留守一段時間,去邊留守我地要睇情況!!!<br />\n<br />\n<img src=\"https://na.cx/i/ZbdqnbV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZbdqnbV.jpg&h=f427772f&s={SIZE}\" /><br />\n圖入面Building有顏色既就係水貨鋪而有顏色既直線就係經常有水貨活動既地方..<br />\n<br />\n黃色線 - 水客偏高<br />\n馬會附近一帶,馬會及上水廣場對面就係水貨活動重災區,包括上水藥房龍頭 - 龍豐藥房 <br />\n<br />\n<span style=\"color: red;\">優點:相對近火車站,A3出口直行5分鐘<br />\n<br />\n缺點:多廢佬聚腳係馬會同老麥,轉角位正正係馬路,黃色橫線窄,如要留守一定要企出埋馬路,一但企出,上水就係全面塞車..</span><br />\n<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /><br />\n<br />\n橙色線 - 水客聚集龍豐藥房!<br />\n橙色線為最初第一條最多行李地點,雖然水貨鋪唔集中,一個龍豐藥房已經令到水貨客多到仆街,橙色線對面亦都係路窄水貨點,對面龍頭鋪 - 雅施化妝鋪<br />\n<br />\n<span style=\"color: red;\">優點:四條顏色線當中橙色線已經係最闊(計埋用埋條濕鳩單車徑),可以伸延到黃色線對面新都廣場(sasa係地鋪)<br />\n<br />\n缺點:水貨鋪唔集中,水貨客可以大不了去返綠/紅線 </span> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><br />\n<br />\n綠+紅色線- 黑底水貨店<br />\n紅色線唔可以單獨佔領,紅線路窄, 麵家山下係紅線當中 ,全部係小店賣大陸貨比大陸人,紅線只可以作綠線走佬線路<br />\n<span style=\"color: red;\">優點: 水貨店集中,就算收到風,總會有大陸人係到當街入貨,綠+紅色線多小巷,但要小心小巷有警狗<br />\n缺點:狗收網前易佈局,入夜成條街無人</span><br />\n<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /><br />\n<span style=\"color: red;\"><strong><em><span style=\"font-size: x-large;\">緊記!!!!我地到時要睇情況,果4條線無水貨客,無人既,我地就要去返火車站出口C對抗!!!</span></em></strong></span>"},{"pid":"f25fb029879b0ace372060b0b227bf7869057b32","tid":1301904,"uid":80668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T06:32:54.000Z","msg":"<img src=\"https://na.cx/i/Rhb3TkB.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRhb3TkB.png&h=ca269994&s={SIZE}\" />"},{"pid":"f65da14e10bb0f8bf0636d32eec3ab936f85068c","tid":1301904,"uid":169261,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T06:33:40.000Z","msg":"推"},{"pid":"c9a9a8f1b19a9bc5bb491c0c0bcb272d1f4da172","tid":1301904,"uid":3696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T07:16:16.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6830adc8f96f3503ce69944ba7fc93627a0fcf14","tid":1301904,"uid":3696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T07:16:43.000Z","msg":"上水人全部岀哂黎<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"9a9906ea05ebe94c14401ca2e91a73621f6169e3","tid":1301904,"uid":76038,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T07:17:30.000Z","msg":"推呀"},{"pid":"5c398d33bfebb3ab702596b7c9ae4c9a7bdf0c7e","tid":1301904,"uid":6142,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T07:21:52.000Z","msg":"推"},{"pid":"a24736b624c8109297188062533a443e5fb310f4","tid":1301904,"uid":276020,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T07:37:59.000Z","msg":"推"},{"pid":"9b0ce44367c377f217043bd055c8b9ce5fe0deab","tid":1301904,"uid":69472,"like":0,"dislike":0,"score":0,"quote":{"pid":"e2a826d195baa2d1666a9c5ea78f5f3f9890068e","tid":1301904,"uid":10189,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-09T19:07:52.000Z","msg":"屯門上次夠快狠準因為都有update返公園情況<br />\n大家未去之前已經有個印象然後去到知點配合<br />\n我地上水撚洗唔洗都再Update下比其他區既人知<br />\n聽日可以幫手影下邊D位係重災區"},"citedBy":0,"replyTime":"2019-07-10T07:38:58.000Z","msg":"上水哨兵<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"09cadf9d38d82117f6d0357a7320a15d0b04c0a5","tid":1301904,"uid":154627,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T09:11:14.000Z","msg":"前往上水方法<br />\n<br />\n［新界東］<br />\n大埔：W3／73到華明轉273a<br />\n沙田 ：W3<br />\n西貢：1a（綠van） 到彩虹轉277e／地鐵<br />\n將軍澳：去藍田轉277e／798 到沙田轉東鐵<br />\n<br />\n<br />\n［新界西］<br />\n元朗：276, 276p／水車館街紅van<br />\n天水圍：276, 276p, 276a, 276b<br />\n屯門：44, 44a （綠van）；261<br />\n荃灣：278x 或<br />\n481, 481a, 481b （綠van）前往火炭沙田大圍轉東鐵 或<br />\n48x 到沙田轉東鐵 或<br />\n69m, 265m, 269m 去大欖轉 279x/ 978<br />\n葵涌 ：<br />\n69m, 265m, 269m 去大欖轉 279x/ 978 或<br />\n46x, 47x去大圍沙田轉東鐵<br />\n青衣：279x<br />\n<br />\n［九龍西］<br />\n荔枝角、長沙灣、深水埗：270b<br />\n油尖旺：270a<br />\n九龍城：25m（綠van）到九龍塘轉東鐵<br />\n<br />\n［九龍東］<br />\n藍田觀塘九龍灣彩虹：277e／277x到華明轉273a<br />\n<br />\n<br />\n［港島］<br />\n中西區：978或<br />\n104, 101, 113到紅磡轉東鐵<br />\n南區：970, 970X, 971, 973 到大欖轉 978 或<br />\n170, 171到紅磡轉東鐵<br />\n東區：606, 613 到東隧轉 673 或<br />\n118, 116, 102, 106 到紅磡轉東鐵"}]}