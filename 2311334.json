8ba33949","tid":2311334,"uid":101328,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-04T07:45:32.000Z","msg":"你係假野，我推比老師知，你冒充佢<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-04T07:47:18.000Z","msg":"手足<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"2221bbf7fc2ffa35ac23feb7c2b16f6ed22004de","tid":2311334,"uid":105166,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-12-04T08:49:10.000Z","msg":"樓主係Xinn做？<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span class=\"red\">睇翻佢的財務數據，增長快速，但業務變數大，行業有不確定性，估值上比較難，這一定會令股價上落大，這刻仍唔平，投資值博率只是一般。</span><br />\n<br />\n同埋佢不嬲講長線投資，你兩三個月就攞黎講？你短炒咪唔好睇佢囉，唔明你做乜鳩<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5c8c34e5e0c92cfc4c59904131b6bf67b0d859a6","tid":2311334,"uid":374688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-05T12:57:23.000Z","msg":"呢條仆街呃埋唔少錢 <br />\n當一個月開一班 有80人上 每人9000蚊學費<br />\n咁佢一個月就呃左 72萬 扣埋啲租房，印筆記成本<br />\n都賺到笑<br />\n<br />\nbtw 而家疫情咁 唔知佢仲開唔開隨班<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"743f4b0773377bc0627eb0b386893c142aae23b3","tid":2311334,"uid":36298,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-18T03:43:34.000Z","msg":"<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />老師早晨，移卡今日升左11%"},{"pid":"5cf334d2739546b06aebfbf5c2a5084150645bae","tid":2311334,"uid":310914,"like":0,"dislike":0,"score":0,"quote":{"pid":"743f4b0773377bc0627eb0b386893c142aae23b3","tid":2311334,"uid":36298,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-18T03:43:34.000Z","msg":"<img src=\"/a