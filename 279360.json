kgmoji\" />"},{"pid":"05987b9cb64d4719aa6345bf1e0de03eb38d8d98","tid":279360,"uid":104782,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-13T13:58:07.000Z","msg":"羅拔迪尼路"},{"pid":"032cc30c4c2abbe24b261b4ec5b705af3947d010","tid":279360,"uid":108029,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-06-13T14:11:43.000Z","msg":"張國榮係東邪西毒入面既獨白<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"98b360afc850286643ea9f8b6332c306aa4edd86","tid":279360,"uid":39812,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-13T16:39:58.000Z","msg":"<blockquote>張國榮係東邪西毒入面既獨白<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n好多年之後，我有個綽號叫做西毒<br />\n其實任何人都可以好毒<br />\n只要你試過乜嘢叫妒忌<br />\n<br />\n當你唔能夠再擁有嘅時候，唯一可以做嘅，就係令自己唔好忘記"},{"pid":"2368407c1f78f3f2be069611968c303fc971a4a8","tid":279360,"uid":60584,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-15T10:21:01.000Z","msg":"吳孟達 都巿情緣好撚正<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <a href=\"https://youtu.be/LrElJmNixqE\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FLrElJmNixqE&d=n56Gtz%2FeaVfJwK%2Fd5Uq8XL%2BnoHux5cIPnxEj5ZZbdh4%3D&h=e3670c45\" target=\"_blank\">https://youtu.be/LrElJmNixqE</a>"},{"pid":"3409eb32c1412fde5ad4e74b47623e785fd803b1","tid":279360,"uid":3577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-15T10:32:32.000Z","msg":"朝偉亞洲第一"},{"pid":"f16dc701a3ea37b30af306224c67e99ebaf9c5c1","tid":279360,"uid":27608,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-15T14:03:45.000Z","msg":"2046<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"}]}