=\"https://na.cx/i/NjyfeuF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNjyfeuF.jpg&h=88bacf0b&s={SIZE}\" />"},{"pid":"fa259335d2e3a3e3b7b35724466d3cc5cefa5c7f","tid":1847071,"uid":12599,"like":0,"dislike":0,"score":0,"quote":{"pid":"13526c8e66d6c205204ecc6f968a2c0476fe6516","tid":1847071,"uid":265935,"like":0,"dislike":0,"score":0,"quote":{"pid":"2bb24f930a4c4bdd56e7813403a78a85c00e5aec","tid":1847071,"uid":12599,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-28T01:22:05.000Z","msg":"HA高層講緊指引做事, 我就同你地玩指引<br />\n<br />\n跟返HA既指引:<br />\n<a href=\"https://www.ha.org.hk/haho/ho/cs/WHO_IHR_B5.pdf?fbclid=IwAR3sKXd16y9M7mfuSTMKTEghwTt1TDdODlF3AQDJatZ1jjMTVEQYhTDkiGw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ha.org.hk%2Fhaho%2Fho%2Fcs%2FWHO_IHR_B5.pdf%3Ffbclid%3DIwAR3sKXd16y9M7mfuSTMKTEghwTt1TDdODlF3AQDJatZ1jjMTVEQYhTDkiGw&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=1795f5f4\" target=\"_blank\">https://www.ha.org.hk/haho/ho/cs/WHO_IHR_B5.pdf?fbclid=IwAR3sKXd16y9M7mfuSTMKTEghwTt1TDdODlF3AQDJatZ1jjMTVEQYhTDkiGw</a><br />\n中文版<br />\n<br />\n<a href=\"https://www.ha.org.hk/haho/ho/cs/WHO_IHR_EN.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ha.org.hk%2Fhaho%2Fho%2Fcs%2FWHO_IHR_EN.pdf&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=835ea74f\" target=\"_blank\">https://www.ha.org.hk/haho/ho/cs/WHO_IHR_EN.pdf</a><br />\n英文版<br />\n<br />\n如有出入均以英文為準<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">現行世界衞生組織的《國際衞生條例》所列疾病</span></span></strong><br />\n(a) 可能構成國際關注的突發公共衛生事件的疾病，在世界衞生組織的機制下，任何單一病<br />\n例都需即時向世界衞生組織通報<br />\n- 新亞型病毒引起的人流感 (Human influenza caused by a new subtype)<br />\n- 由野毒株引起的脊髓灰質炎 (Poliomyelitis due to wild-type poliovirus)<br />\n- 嚴重急性呼吸道綜合症（SARS）<br />\n- 天花 (Smallpox)<br />\n(b) 可能造成嚴重衛生影響並能在國際上迅速傳播的疾病<br />\n- 霍亂（及其他腸道傳染的流行病）(Cholera (and other epidemic diarrhoeal disease))<br />\n- 肺鼠疫 (Pneumonic plague)<br />\n- 病毒性出血熱（埃博拉熱、拉薩熱、馬爾堡熱、西尼羅熱）(Viral haemorrhagic fevers (Ebola, Lassa, Marburg, West Nile fever))<br />\n- 黃熱病 (Yellow fever)<br />\n<br />\n<span style=\"color: gold;\">WHO自2005年後就無update過呢個表</span>, 即係全世界收MERS同WARS都唔使跟垃圾WHO指引做事, 因為呢兩隻病唔係指引入面<br />\n<br />\n如果HA夠膽唔收WARS病人錢, 我告撚到你班官Hihi呀"},"citedBy":1,"replyTime":"2020-01-28T02:00:10.000Z","msg":"<a href=\"https://www.elegislation.gov.hk/hk/cap599A!zh-Hant-HK\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.elegislation.gov.hk%2Fhk%2Fcap599A%21zh-Hant-HK&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=5c740664\" data-auto-link target=\"_blank\">https://www.elegislation.gov.hk/hk/cap599A!zh-Hant-HK</a><br />\n<br />\n但呢條法例更新咗<img src=\"https://na.cx/i/NjyfeuF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNjyfeuF.jpg&h=88bacf0b&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-01-28T02:09:59.000Z","msg":"呢個係隔離令？"},{"pid":"d77ccee7c1a1878fc943d8618e524eb1c6512124","tid":1847071,"uid":344033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T02:12:02.000Z","msg":"手足裝備抗沙士：護目鏡 非常重要！分析文！大力推！<br />\n<a href=\"https://lih.kg/1845419\" data-auto-link target=\"_blank\">https://lih.kg/1845419</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<a href=\"https://www.facebook.com/112357283631796/posts/117867026414155/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F117867026414155%2F%3Fd%3Dn&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=7fe09377\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/117867026414155/?d=n</a><br />\n<br />\n手足裝備抗沙士：護目鏡<br />\n整體分析：<a href=\"https://www.facebook.com/112357283631796/posts/116690396531818/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F116690396531818%2F%3Fd%3Dn&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=a501ef22\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/116690396531818/?d=n</a><br />\n<br />\n首選：Sellstrom S80225/S80226 Wildland Fire Goggles （戴眼鏡都用得）<br />\n<a href=\"https://www.amazon.com/Sellstrom-Wildland-Goggles-Non-Vented-Anti-Fog/dp/B07DJVPL9Q\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.amazon.com%2FSellstrom-Wildland-Goggles-Non-Vented-Anti-Fog%2Fdp%2FB07DJVPL9Q&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=574a8056\" data-auto-link target=\"_blank\">https://www.amazon.com/Sellstrom-Wildland-Goggles-Non-Vented-Anti-Fog/dp/B07DJVPL9Q</a><br />\n<br />\nSellstrom 依款眼罩，上年九月果陣，已經係前線手足標準裝備，有手足認證，包保放心！其中，依款眼罩有兩大特點。<br />\n<br />\n第一，依款眼罩寫明係 non-vented，即係氣密。戴左之後，基本上就阻隔左外面嘅空氣進入眼罩，所以擋到TG，亦都擋到帶病毒嘅飛沫同空氣，乜春都入唔到眼。依個亦都係佢可以俾美國消防員救山火果陣用嘅原因。氣密係眼罩第一重要條件，如果唔係氣密，病毒同TG都可以經眼罩邊位入眼，大陸衛健委都講明病毒傳染性不斷上升，美國有教授都講左武漢沙士嘅reproductive rate 高過曬佢見過佢嘅病毒，證明今次係非常嚴重，必須要用高規格嘅產品保護自己！<br />\n<br />\n第二，依款眼罩經過 ANSI Z87+ 嘅驗證，保護性極高！<br />\nANSI Z87+嘅定義如下：<br />\n&lsquo;Each product must go through rigorous third-party testing which simulates hazards such as impact by flying objects and debris, high mass impact, and sharp object penetration. In each testing scenario, the lenses and frame must stay intact to pass&rsquo;<br />\n根據網上一個對ANSI Z87+ 眼罩嘅測試，散彈槍都射佢唔穿，所以ANSI Z87+ 嘅standard 係非常高，亦都只有依種眼罩嘅保護性先可以保護前線免受橡膠子彈同布袋彈威脅。<br />\n<br />\n次選：Pyramex CAPSTONE (G504DT或其他型號）<br />\n<a href=\"https://www.amazon.com/Pyramex-Capstone-Direct-Indirect-Anti-Fog/dp/B003UUEW88\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.amazon.com%2FPyramex-Capstone-Direct-Indirect-Anti-Fog%2Fdp%2FB003UUEW88&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=4cb1dfe8\" data-auto-link target=\"_blank\">https://www.amazon.com/Pyramex-Capstone-Direct-Indirect-Anti-Fog/dp/B003UUEW88</a><br />\n<br />\n第一，依款眼罩有氣密帽，應該同樣做到氣密效果，但係因為佢嘅氣密帽可以拆卸，多左個連接位，所以氣密保護性會低小小（始終多個連接位就多個出錯機會）。<br />\n第二，依款眼罩經過D3 測試，證實可以防水滴同化學劑嘅飛淺，理論上有足夠防水性能。<br />\n第三，依款眼罩經過MIL-PRF 32432 美軍標準測試，對子彈衝擊力有一定防禦。<br />\n<br />\n其他選擇：3M 護目鏡<br />\n<br />\n最後選擇：泳鏡（仲易買過平光鏡）<br />\n<br />\n泳鏡顧名思義，就係for 遊水，氣密效果有一定嘅保證，同埋求其一間運動鋪都可以買到，買近視鏡嘅話眼睛都唔洗戴，幾十蚊就有，保護性一定好過平光鏡，不過如果係講嘢都要除口罩，放屁要除褲，戴左帽可能腦都用唔到嘅人，可能佢戴左就會睇唔野。<br />\n<br />\n8.5 最新護目鏡實測 條帶戴高D 鼻位GAP就會消失!!! &amp; 前線超過400位豬嘴實測<br />\n<a href=\"https://lih.kg/1411916\" data-auto-link target=\"_blank\">https://lih.kg/1411916</a><br />\n<br />\n大家幫幫手，like &amp; share 等多啲人睇到！<br />\n<br />\n香港眼罩網店列表：（請各位幫手加落去）<br />\n<br />\n<a href=\"https://www.3armystore.com/products/pyramex-capstone-dual-lens\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.3armystore.com%2Fproducts%2Fpyramex-capstone-dual-lens&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=18415e61\" data-auto-link target=\"_blank\">https://www.3armystore.com/products/pyramex-capstone-dual-lens</a><br />\n<br />\n<br />\n<a href=\"https://www.accstoreonline.com/products/sellstrom-wildland-fire-safety-goggles\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.accstoreonline.com%2Fproducts%2Fsellstrom-wildland-fire-safety-goggles&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=9f3db064\" data-auto-link target=\"_blank\">https://www.accstoreonline.com/products/sellstrom-wildland-fire-safety-goggles</a><br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<a href=\"https://www.autoworld.hk/chinese/pygg504t.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.autoworld.hk%2Fchinese%2Fpygg504t.html&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=a77b78c0\" data-auto-link target=\"_blank\">https://www.autoworld.hk/chinese/pygg504t.html</a><br />\n<br />\n<a href=\"https://youtu.be/dE5IweYn3T4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FdE5IweYn3T4&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=a70f0c8a\" data-auto-link target=\"_blank\">https://youtu.be/dE5IweYn3T4</a><br />\n清洗參考<br />\n<br />\n<a href=\"https://youtu.be/mBGDrY0PyQ4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FmBGDrY0PyQ4&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=ec735447\" data-auto-link target=\"_blank\">https://youtu.be/mBGDrY0PyQ4</a><br />\nSafety test <br />\n<br />\n#屠龍 #藍絲 #藍屍 #黃色經濟圈 #黃店 #裝備 #口罩 #武漢肺炎 #武漢 #P95 #文宣 #N95 #肺炎 #沙士 #香港 #支那人 #高鐵 #眼罩 #tg #lihkg #連登 #高登 #d100 #黑警"},{"pid":"c0ed626da9e1250bd1f470085f682bd4279ce96f","tid":1847071,"uid":161185,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T02:12:09.000Z","msg":"推"},{"pid":"949d16103b5d4b71328962025e05033b9e061ad2","tid":1847071,"uid":265935,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa259335d2e3a3e3b7b35724466d3cc5cefa5c7f","tid":1847071,"uid":12599,"like":0,"dislike":0,"score":0,"quote":{"pid":"13526c8e66d6c205204ecc6f968a2c0476fe6516","tid":1847071,"uid":265935,"like":0,"dislike":0,"score":0,"quote":{"pid":"2bb24f930a4c4bdd56e7813403a78a85c00e5aec","tid":1847071,"uid":12599,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-28T01:22:05.000Z","msg":"HA高層講緊指引做事, 我就同你地玩指引<br />\n<br />\n跟返HA既指引:<br />\n<a href=\"https://www.ha.org.hk/haho/ho/cs/WHO_IHR_B5.pdf?fbclid=IwAR3sKXd16y9M7mfuSTMKTEghwTt1TDdODlF3AQDJatZ1jjMTVEQYhTDkiGw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ha.org.hk%2Fhaho%2Fho%2Fcs%2FWHO_IHR_B5.pdf%3Ffbclid%3DIwAR3sKXd16y9M7mfuSTMKTEghwTt1TDdODlF3AQDJatZ1jjMTVEQYhTDkiGw&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=1795f5f4\" target=\"_blank\">https://www.ha.org.hk/haho/ho/cs/WHO_IHR_B5.pdf?fbclid=IwAR3sKXd16y9M7mfuSTMKTEghwTt1TDdODlF3AQDJatZ1jjMTVEQYhTDkiGw</a><br />\n中文版<br />\n<br />\n<a href=\"https://www.ha.org.hk/haho/ho/cs/WHO_IHR_EN.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ha.org.hk%2Fhaho%2Fho%2Fcs%2FWHO_IHR_EN.pdf&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=835ea74f\" target=\"_blank\">https://www.ha.org.hk/haho/ho/cs/WHO_IHR_EN.pdf</a><br />\n英文版<br />\n<br />\n如有出入均以英文為準<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">現行世界衞生組織的《國際衞生條例》所列疾病</span></span></strong><br />\n(a) 可能構成國際關注的突發公共衛生事件的疾病，在世界衞生組織的機制下，任何單一病<br />\n例都需即時向世界衞生組織通報<br />\n- 新亞型病毒引起的人流感 (Human influenza caused by a new subtype)<br />\n- 由野毒株引起的脊髓灰質炎 (Poliomyelitis due to wild-type poliovirus)<br />\n- 嚴重急性呼吸道綜合症（SARS）<br />\n- 天花 (Smallpox)<br />\n(b) 可能造成嚴重衛生影響並能在國際上迅速傳播的疾病<br />\n- 霍亂（及其他腸道傳染的流行病）(Cholera (and other epidemic diarrhoeal disease))<br />\n- 肺鼠疫 (Pneumonic plague)<br />\n- 病毒性出血熱（埃博拉熱、拉薩熱、馬爾堡熱、西尼羅熱）(Viral haemorrhagic fevers (Ebola, Lassa, Marburg, West Nile fever))<br />\n- 黃熱病 (Yellow fever)<br />\n<br />\n<span style=\"color: gold;\">WHO自2005年後就無update過呢個表</span>, 即係全世界收MERS同WARS都唔使跟垃圾WHO指引做事, 因為呢兩隻病唔係指引入面<br />\n<br />\n如果HA夠膽唔收WARS病人錢, 我告撚到你班官Hihi呀"},"citedBy":1,"replyTime":"2020-01-28T02:00:10.000Z","msg":"<a href=\"https://www.elegislation.gov.hk/hk/cap599A!zh-Hant-HK\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.elegislation.gov.hk%2Fhk%2Fcap599A%21zh-Hant-HK&d=ib6ZiIlk8HgX3sh0XBbtb%2BoeOpwBOZOods3%2BbOb6780%3D&h=5c740664\" data-auto-link target=\"_blank\">https://www.elegislation.gov.hk/hk/cap599A!zh-Hant-HK</a><br />\n<br />\n但呢條法例更新咗<img src=\"https://na.cx/i/NjyfeuF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNjyfeuF.jpg&h=88bacf0b&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-01-28T02:09:59.000Z","msg":"呢個係隔離令？"},"citedBy":0,"replyTime":"2020-01-28T02:12:28.000Z","msg":"係呀<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><br />\n不過內文無講政府會俾錢<br />\n只係講隔離令同唔服從嘅penalty"},{"pid":"dd7a58d699eb54988fc6a65f96793c704316c65e","tid":1847071,"uid":27530,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T02:14:47.000Z","msg":"醫院收費應該係有附屬法例規管，通常係比醫管局自己決定，所以佢唔收都應該冇犯法，可以有熟嘅人再補充"},{"pid":"ce7f2c3e6c85860b87865dc814e752b40a527499","tid":1847071,"uid":22590,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T02:24:59.000Z","msg":"樓主無錯 推"},{"pid":"63a72da816ee9de48808c8150275e25765ee3bca","tid":1847071,"uid":87723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T02:25:54.000Z","msg":"推"},{"pid":"fa0949a7e487acabc7178d9f31a96fefc270ee31","tid":1847071,"uid":259493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T02:28:14.000Z","msg":"[合法罷工 ， 助己助人]<br />\n本身你在醫院/海關/巴士司機/ 金融/任何政府崗位工作<br />\n又有傷風感冒症狀 （很容易自製冷親)<br />\n請上齊裝備即刻去急症室睇醫生 醫生一定畀你嚇親畀假紙你 甚至將你隔離 變相罷工， 即時救港行動<br />\n只要你有輕微發燒症狀， 拍片做證 ，你老細就吹你唔脹， 你問:係唔係要返工傳染畀同事先至安樂？<br />\n病假救港、助己助人、刻不容緩"},{"pid":"98c08995f537894ce43316c1db1ec21c56bc0657","tid":1847071,"uid":22590,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-28T02:46:49.000Z","msg":"記者朋友叫醫管局質素及安全總監鍾健禮呢個撚樣出黎交代"}]}