ets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"117b2515648aee2c500a5684526521f20a40cfc5","tid":1764714,"uid":28181,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-12-01T17:24:14.000Z","msg":"工聯展會"},{"pid":"57c3622ceb13c44b99974fbdcb284b67d6ed0dae","tid":1764714,"uid":95716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-01T17:31:45.000Z","msg":"又有得行街<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"25131930deefa51e96698e615c8cb741ed4d129f","tid":1764714,"uid":216405,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-01T17:34:25.000Z","msg":"此回覆已被刪除"},{"pid":"01748ac91dbca7fa9065b4b33f281da1904da826","tid":1764714,"uid":258731,"like":0,"dislike":0,"score":0,"quote":{"pid":"ef09d31a1c9fe32caa6db58231f3dd54e16f713c","tid":1764714,"uid":78947,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-12-01T10:11:39.000Z","msg":"一年一度工展會由12月10號至12月31號喺維園舉行，22日嘅展期精采活動多多，入場人士定可玩得開心、盡興！當中包括六個主題日，包括「親子天倫日」、「耆樂悠遊日」、「耆妙同樂日」、「芳華綻放耀工展」、「樂頌平安夜」以及「廠商會璀璨輝煌85載」。<br />\n<br />\n  玩之餘更加要買得盡情！全場超過700個攤位，分布10個主題區，包括「香港名牌廣場」、「食品飲料區」、「糧油麵食區」、「蔘茸海味湯料區」、「美容保健區」、「服飾精品區」、「生活家居區」、「美食廣場」、「社企區」及「推廣區」。大會仲由10號至15號，率先推出「工展開鑼大優惠」，大量精選產品低至3折以下，甚至更有低至$1及1折貨品。部分參展商會全個展期推出6折以下優惠產品，工展會仲係愈夜愈著數，事關每日下午5點後，指定產品會「一買一送」，醒目嘅你趁機喇！另外，今年仲有慈善拍賣活動，近百件拍賣品全部以一折起拍賣，做善事之餘又可以拍得平靚正產品，實在一舉兩得，千祈咪錯過！<br />\n<br />\n  工展會門券價格港幣$8，身高1米或以下小童、65歲或以上長者及殘疾人士免費進場。<br />\n<br />\n<a href=\"http://hd.stheadline.com/news/columns/983/20191126/814884/%e5%b0%88%e6%ac%84-%e7%a4%be%e8%ab%96-%e5%9c%b0%e6%b0%88%e5%bc%8f%e6%90%9c%e5%b0%8b-%e7%b5%90%e6%9d%9f%e6%8d%89%e8%bf%b7%e8%97%8f\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhd.stheadline.com%2Fnews%2Fcolumns%2F983%2F20191126%2F814884%2F%25e5%25b0%2588%25e6%25ac%2584-%25e7%25a4%25be%25e8%25ab%2596-%25e5%259c%25b0%25e6%25b0%2588%25e5%25bc%258f%25e6%2590%259c%25e5%25b0%258b-%25e7%25b5%2590%25e6%259d%259f%25e6%258d%2589%25e8%25bf%25b7%25e8%2597%258f&d=HsMqQMGMM0KOGi%2FJd%2BN0Bze9V6YwtzhhzuTx9UUfAJc%3D&h=68f1a198\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fhd.stheadline.com%2Fnews%2Fcolumns%2F983%2F20191126%2F814884%2F%25e5%25b0%2588%25e6%25ac%2584-%25e7%25a4%25be%25e8%25ab%2596-%25e5%259c%25b0%25e6%25b0%2588%25e5%25bc%258f%25e6%2590%259c%25e5%25b0%258b-%25e7%25b5%2590%25e6%259d%259f%25e6%258d%2589%25e8%25bf%25b7%25e8%2597%258f&h=bd0a1381\" data-auto-link target=\"_blank\">http://hd.stheadline.com/news/columns/983/20191126/814884/%e5%b0%88%e6%ac%84-%e7%a4%be%e8%ab%96-%e5%9c%b0%e6%b0%88%e5%bc%8f%e6%90%9c%e5%b0%8b-%e7%b5%90%e6%9d%9f%e6%8d%89%e8%bf%b7%e8%97%8f</a>"},"citedBy":1,"replyTime":"2019-12-01T17:35:42.000Z","msg":"工展會主辦單位見到你呢個post應該會嚇到賴尿咁取消"},{"pid":"f632703574f58437af34f4a6d98392cb45187915","tid":1764714,"uid":68620,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-01T17:40:13.000Z","msg":"有催淚煙要手足幫忙傳過去<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a622caa3fe39ea889002ceb2dfffe4f449e0fa6f","tid":1764714,"uid":235277,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-01T17:47:20.000Z","msg":"持埋架車仔去購物<img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"},{"pid":"ff6d1127fbd908d8f3c2005bdc47386252d32e88","tid":1764714,"uid":235277,"like":0,"dislike":0,"score":0,"quote":{"pid":"a622caa3fe39ea889002ceb2dfffe4f449e0fa6f","tid":1764714,"uid":235277,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-01T17:47:20.000Z","msg":"持埋架車仔去購物<img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-01T17:47:34.000Z","msg":"拎"}]}