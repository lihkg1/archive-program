core":0,"citedBy":1,"replyTime":"2020-05-19T17:40:55.000Z","msg":"我報左霍格space 有無人讀過"},{"pid":"14aa7913b6ac26655673aa4c25a6501c9d8e1160","tid":2024482,"uid":271250,"like":0,"dislike":0,"score":0,"quote":{"pid":"f213d267100a7a9715931e4f99fd190b50571ce1","tid":2024482,"uid":335063,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-19T17:40:55.000Z","msg":"我報左霍格space 有無人讀過"},"citedBy":0,"replyTime":"2020-05-19T17:47:17.000Z","msg":"報咗咩科"},{"pid":"36ab03fc6978a171a61ab3db606265f403a02196","tid":2024482,"uid":335063,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-19T17:49:29.000Z","msg":"我報左黑魔法 出左conditional offer"},{"pid":"e75dcf35d23376fe68001aafe49510bb0f1c582d","tid":2024482,"uid":271250,"like":0,"dislike":0,"score":0,"quote":{"pid":"36ab03fc6978a171a61ab3db606265f403a02196","tid":2024482,"uid":335063,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-19T17:49:29.000Z","msg":"我報左黑魔法 出左conditional offer"},"citedBy":0,"replyTime":"2020-05-19T17:55:04.000Z","msg":"呢科好蝦人讀，我就建議你自己打定底先"},{"pid":"97d0953061f8190e9bc379a2fa476ab52ede8c90","tid":2024482,"uid":335063,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T17:56:15.000Z","msg":"我上個星期 同金妮去禁忌森林溫書 殺左十幾隻食死人"},{"pid":"9327cf70587bd0ca246124b7303ad1216a6f873b","tid":2024482,"uid":271250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T17:57:45.000Z","msg":"巴打你咁屈機點解仲要讀Space"},{"pid":"d4025b1eacc4b800a6205a0cc20208dcea858819","tid":2024482,"uid":97909,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-20T02:07:47.000Z","msg":"岩岩俾professor 石in<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"32e977c20767118e11ede1cf57a14749e7907249","tid":2024482,"uid":113922,"like":2,"dislike":2,"score":0,"citedBy":1,"replyTime":"2020-05-20T02:13:20.000Z","msg":"仲諗住係行動po，點知係垃圾po<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"6f4826fed3e0baa3cfc0cd5fa3baa2837f8356f9","tid":2024482,"uid":58852,"like":2,"dislike":1,"score":1,"quote":{"pid":"32e977c20767118e11ede1cf57a14749e7907249","tid":2024482,"uid":113922,"like":2,"dislike":2,"score":0,"citedBy":1,"replyTime":"2020-05-20T02:13:20.000Z","msg":"仲諗住係行動po，點知係垃圾po<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-20T02:15:53.000Z","msg":"Yes <br />\n碌極都搵唔到火魔資訊"},{"pid":"68fc8f4a76b0a28e6d48870876ca9adb0ff23640","tid":2024482,"uid":103521,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-05-20T02:17:24.000Z","msg":"on9得黎幾好笑<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n希望練好d魔法去到exchange<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />讀postgrad研究新魔藥解決黑魔法既後遺症<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"636e6692bcfb093b0d4863fa6977053a9f9b05d2","tid":2024482,"uid":57647,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-20T02:48:32.000Z","msg":"又幾撚有心機<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"782dca2796f1113d0175b1909f1474a290cd1e5e","tid":2024482,"uid":36995,"like":0,"dislike":0,"score":0,"quote":{"pid":"6f4826fed3e0baa3cfc0cd5fa3baa2837f8356f9","tid":2024482,"uid":58852,"like":2,"dislike":1,"score":1,"quote":{"pid":"32e977c20767118e11ede1cf57a14749e7907249","tid":2024482,"uid":113922,"like":2,"dislike":2,"score":0,"citedBy":1,"replyTime":"2020-05-20T02:13:20.000Z","msg":"仲諗住係行動po，點知係垃圾po<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-20T02:15:53.000Z","msg":"Yes <br />\n碌極都搵唔到火魔資訊"},"citedBy":0,"replyTime":"2020-05-20T03:03:07.000Z","msg":"垃圾學店<br />\n殺狗火魔/弓箭都無教"},{"pid":"1aa8a7fd7341afd7830d0f899f9f52dbbfa03d04","tid":2024482,"uid":122601,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-20T09:32:15.000Z","msg":"Too long did not laugh"}]}