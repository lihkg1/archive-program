dBy":0,"replyTime":"2019-08-04T09:34:32.000Z","msg":"2"},{"pid":"dd7a15da3a3de2e623a99acdd4179f389d0d9878","tid":1405370,"uid":226562,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c7a6237e12bbfee0411e50f9c7fdb471f6c92e0","tid":1405370,"uid":292814,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-04T09:34:21.000Z","msg":"太長"},"citedBy":0,"replyTime":"2019-08-04T09:35:36.000Z","msg":"轉載之後嗰啲係op嘅 design 嚟<br />\n成個概念就係一個協定去利用股市價格釐定游擊目標"},{"pid":"7880722345385ac867a45d689511833926ce2b17","tid":1405370,"uid":226562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T09:35:47.000Z","msg":"1"},{"pid":"c48c284075ce4b4930cb7e29c9177210a239624d","tid":1405370,"uid":226562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T09:36:09.000Z","msg":"0"}]}