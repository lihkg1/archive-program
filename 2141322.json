\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />"},{"pid":"633c28ad22cd9d85fa427d1f3089fbcff4ce3135","tid":2141322,"uid":296700,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-05T18:25:12.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"81acaf7aca126174f2d70c237a11cba65707541a","tid":2141322,"uid":26976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-05T18:29:16.000Z","msg":"香港果啲係垃圾莊圍威喂<br />\n或者敗走美國/唔敢去美國嘅垃圾問題支資公司<br />\n<br />\n收咗香港皮都去唔到美國架喎<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"101eb5ed9025fa393fbe953c4578cbcda1d1d77e","tid":2141322,"uid":299991,"like":0,"dislike":0,"score":0,"quote":{"pid":"d92925ef1383ebd3f0b89249199ee59430378a1f","tid":2141322,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-05T14:40:37.000Z","msg":"【Now新聞台】美國總統特朗普表示，終止香港特殊待遇後，香港的股票市場將不再成功。<br />\n<br />\n特朗普接受霍士新聞訪問指，美國為維持香港的自由給予特殊待遇，不少企業受這個條件吸引，轉到香港的股票市場，令紐約證券交易所、納斯達克等喪失大量生意。美國終止香港特殊待遇後，相信會吸引企業回流，美國會全力以赴爭取這些生意，並會從中大量得益，香港股票市場將不再成功。<br />\n<br />\n特朗普因應港區國安法實施，上個月簽署《香港自治法案》和行政命令，終止香港的特殊待遇。<br />\n<br />\n<a href=\"https://news.now.com/home/local/player?newsId=400639\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D400639&d=0%2B8fQjowpNY%2FdBz24eqX%2F6EbpHCTTcQcXY6VsQHNTK4%3D&h=c4d92fbd\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D400639&h=7311edc5\" data-auto-link target=\"_blank\">https://news.now.com/home/local/player?newsId=400639</a>"},"citedBy":0,"replyTime":"2020-08-05T18:36:46.000Z","msg":"大豆侵<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"20392b134064506191b7a219bc939e7bc4