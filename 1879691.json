s/faces/normal/slick.gif\" class=\"hkgmoji\" />"},{"pid":"a171f2393f983f8664e432815e086cd2848bb516","tid":1879691,"uid":183117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-16T12:50:40.000Z","msg":"好唔好食"},{"pid":"7888160b20ed92a3262c89fe85b0a0426c879c85","tid":1879691,"uid":116705,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-16T12:52:17.000Z","msg":"所有情侶放閃都要受到單身狗詛咒"},{"pid":"73b6f292bde8faa20f8ff1989d4fcd6ceb91cd5f","tid":1879691,"uid":315985,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-16T14:08:29.000Z","msg":"屌你送你男朋友入醫院啦， 仲得閒開po"}]}