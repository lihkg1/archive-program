s%26id%3D8221665B-221F-4845-AFE1-34B94F75BE66&d=DUh6sihs39eOmPFGCy%2Fo554%2BuNhYgvPKbWZYs3KJomg%3D&h=5f3ffcff\" data-auto-link target=\"_blank\">https://www.rubio.senate.gov/public/index.cfm?p=Press-Releases&amp;id=8221665B-221F-4845-AFE1-34B94F75BE66</a>"},{"pid":"7dffd634cc3bc92156e1a60152882d8b6d1d0781","tid":664113,"uid":138713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-19T04:21:18.000Z","msg":"撚狗咁撚<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"945eef3a8073e4926b38d4fd09fc4936159b7dc6","tid":664113,"uid":76310,"like":1,"dislike":0,"score":1,"quote":{"pid":"b7fd258c918f85bea8710d884ff7e8cb63058780","tid":664113,"uid":182475,"like":3,"dislike":0,"score":3,"quote":{"pid":"05c1da36150ccd3f2aeba64354ce234ccb99b321","tid":664113,"uid":24140,"like":1,"dislike":0,"score":1,"quote":{"pid":"3f9e379ebf34d2fdec0163ac1d9a9b0ad6cf90f6","tid":664113,"uid":14103,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-05-14T02:58:05.000Z","msg":"支那開放金融市場會有咩影響？ 有機會大量資金外流<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-22T09:18:57.000Z","msg":"想像下RMB 自由兌換會點 <img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-22T10:47:42.000Z","msg":"正常情況下，外資會湧入，對中國資產及貨幣的需求會上升，買到啲國內嘢同人仔愈來愈貴。之後中國出口(因為匯價問題) 唔再平，然後慢慢減返到一定水平。呢個係「正常」的情況。<br />\n<br />\n但現實嘛... 中國人身體咁誠實，你懂的 <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-19T04:30:52.000Z","msg":"一開放，全強國既人，走得就走晒啦"},{"pid":"5431e7ec834c20da5255d11c9a09e08033396c2b","tid":664113,"uid":28765,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-19T04:35:40.000Z","msg":"又扭軑<img src=\"/assets/faces/fifa/goal.gif\" class=\"hkgmoji\" />"},{"pid":"497f8f1e2e98a7dfa0a4788074ca687c2280bfe9","tid":664113,"uid":20414,"like":0,"di