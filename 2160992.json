3f5a590","tid":2160992,"uid":348984,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7944c63117b66cc921c1263bac5b523d62a575f","tid":2160992,"uid":271176,"like":0,"dislike":0,"score":0,"quote":{"pid":"9894237cde9209156d76e1cf98afea06b695c951","tid":2160992,"uid":331421,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-08-17T10:23:47.000Z","msg":"唔多啲惡法點加速<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-17T10:45:41.000Z","msg":"有總加速師，使自己加？咁快加到新疆咁有咩意思"},"citedBy":0,"replyTime":"2020-08-17T10:56:46.000Z","msg":"agger"},{"pid":"f825160433d937edae587bc271be5ca3ca74aaf4","tid":2160992,"uid":271996,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-17T10:56:59.000Z","msg":"睇到想嘔 班販民點對得住手足"},{"pid":"8f03b420c71eaf66f927ccc7034df598c8328f92","tid":2160992,"uid":103521,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-17T10:58:06.000Z","msg":"<a href=\"https://lihkg.com/thread/2161003/page\" target=\"_blank\">https://lihkg.com/thread/2161003/page</a><br />\n應下我<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"455f21fcfb20f157618df7d26b01df1c09bea8e2","tid":2160992,"uid":245849,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-17T11:04:09.000Z","msg":"<span class=\"x-large\">邊條食屎狗要非法廷任，<br />\n直接支持人大獨裁決定，<br />\n忽視香港人民選舉公義！</span><br />\n<br />\n<span class=\"xx-large\">唔好再自稱民主派！</span><br />\n<br />\n唔好同我講最錯係港共<br />\n港共係人所皆知嘅狗屎垃圾殺人犯<br />\n但唔代表佢迫你就要做！<br />\n<br />\n有個強姦犯姦泛民老母<br />\n之後佢叫泛民姦埋一份<br />\n唔係就要切咗泛民碌嘢<br />\n後泛民主流決定姦老母<br />\n<br />\n泛民算咩嘢受害者？"},{"pid":"f916c263cc7148a54df8966fd05581612eed885f","tid":2160992,"uid":41116,"like":0,"dislike":0,"score":0,"quote":{"pid":"e34057c74e58f0ebda09046c4e6cfa56eeaa12d1","tid":2160992,"uid":271176,"like":0,"dislike":0,"score":0,"quote":{"pid":"ac1a01919050898c96295f953a229211a76bdc0e","tid":2160992,"uid":108016,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-17T10:30:11.000Z","msg":"佢而家立惡法要經立法會？"},"citedBy":2,"replyTime":"2020-08-17T10:47:45.000Z","msg":"經立法會佢地比較好睇，而且好多細項要經"},"citedBy":0,"replyTime":"2020-08-17T11:04:36.000Z","msg":"所以有埋最忠誠反對派一齊唱台戲就更完美"},{"pid":"376ca818f279c11945ce4cda8114c169fa09ad08","tid":2160992,"uid":14103,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-17T11:05:35.000Z","msg":"點解建制果邊永遠可以留<img src=\"/assets/faces/lm2/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4be80cda8c1e03c36685e08c2221f6893390e593","tid":2160992,"uid":290514,"like":0,"dislike":0,"score":0,"quote":{"pid":"d376c082b66fbfb6e55c43f003fcdf9e1032f6d5","tid":2160992,"uid":109570,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2020-08-17T10:21:15.000Z","msg":"本身都覺得要總辭,原因都係個D: <br />\n<br />\n佢要過都係會過<br />\n臨立會冇認受性,入去姐係比認受性佢<br />\nETC 不盡例<br />\n<br />\n但係諗落都係覺得要守. <br />\n<br />\n一黎你講左因為唔守的話，政府可以極速以少代價立惡法 <br />\n<br />\n二黎我地KEEP住做都唔一定比到個認受性政府(臨立會), 依加全世界都知香港咩事, 個橙爛到冇得再爛, 入去只係想確保政府唔可以極速以少代價立惡法<br />\n<br />\n三黎 我覺得無論點都好, 中共都會分化你. 我覺得最好係做個有公信力既民調 再決定點行<br />\n<br />\nsorry 少少1999 一陣返到屋企再同你地討論下<br />\n<br />\n<strong><span class=\"red\">乜都好, 一定要齊心 咪比中共分化</span></strong>"},"citedBy":0,"replyTime":"2020-08-17T11:07:39.000Z","msg":"Point 1：你上面都講左，要過一定要過，速度唔係問題，人大已經講明延任<span class=\"large\"><span class=\"red\">至少</span></span>一年。所以做唔切咪再延囉，一唔係剪布+保安趕走。新界東北撥款、內會選舉、一地兩檢等等大量例子。佢講好要過，就一定可以過到。<br />\n<br />\nPoint 2：冇錯，我同意呢個係point。但係留任只會比對家繼續侮辱、繼續「最黑暗一天」。<br />\n<br />\nPoint 3：唔係支持留守原因，因此唔講。"},{"pid":"2ea18efa63697e7fae4090647231ba42cfff633d","tid":2160992,"uid":59818,"like":0,"dislike":0,"score":0,"quote":{"pid":"e34057c74e58f0ebda09046c4e6cfa56eeaa12d1","tid":2160992,"uid":271176,"like":0,"dislike":0,"score":0,"quote":{"pid":"ac1a01919050898c96295f953a229211a76bdc0e","tid":2160992,"uid":108016,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-17T10:30:11.000Z","msg":"佢而家立惡法要經立法會？"},"citedBy":2,"replyTime":"2020-08-17T10:47:45.000Z","msg":"經立法會佢地比較好睇，而且好多細項要經"},"citedBy":0,"replyTime":"2020-08-17T11:08:35.000Z","msg":"比較好睇<img src=\"/assets/f