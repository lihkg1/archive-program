 咁唯有約d賣家出黎交收下啦<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"e5ee5cdee72ee6822a378d7375209f5bb8797bde","tid":607112,"uid":6964,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b32244d7457208f163c7069d19acb024e07dae9","tid":607112,"uid":83217,"like":3,"dislike":0,"score":3,"quote":{"pid":"a79b833852bf28fcfe6d767478c47c12a881f33b","tid":607112,"uid":6964,"like":5,"dislike":5,"score":0,"citedBy":3,"replyTime":"2018-03-27T04:37:10.000Z","msg":"個班係新香港人"},"citedBy":1,"replyTime":"2018-03-27T06:13:56.000Z","msg":"大撚把香港出世既炒黃牛啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-27T06:49:21.000Z","msg":"拉到人未？"},{"pid":"561c69faa0193ff7de86ac21114acf43d0e78388","tid":607112,"uid":6964,"like":0,"dislike":0,"score":0,"quote":{"pid":"0b9afc379964d8dd74bc199439f8ae9d7efd60e3","tid":607112,"uid":40103,"like":3,"dislike":0,"score":3,"quote":{"pid":"a79b833852bf28fcfe6d767478c47c12a881f33b","tid":607112,"uid":6964,"like":5,"dislike":5,"score":0,"citedBy":3,"replyTime":"2018-03-27T04:37:10.000Z","msg":"個班係新香港人"},"citedBy":1,"replyTime":"2018-03-27T06:12:51.000Z","msg":"閪到震<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n口度屌大陸人搶你資源<br />\n但自己又恰返自己人"},"citedBy":0,"replyTime":"2018-03-27T06:50:07.000Z","msg":"拉到人未？"},{"pid":"76d31ed2d87a9ad5c994d1ea70c7954e9babb4fe","tid":607112,"uid":54344,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-27T06:52:57.000Z","msg":"嗰班咪又係狗。。。"},{"pid":"8be5c692f04fecab22123db54de299c7e7b24d8d","tid":607112,"uid":55924,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-03-27T06:53:01.000Z","msg":"蝻蝗一大堆"},{"pid":"c49a0fc38ab0ad7d761dc7c8116289feafee7919","tid":607112,"uid":78222,"like":2,"dislike":0,"score":2,"quote":{"pid":"a79b833852bf28fcfe6d767478c47c12a881f33b","tid":607112,"uid":6964,"like":5,"dislike":5,"score":0,"citedBy":3,"replyTime":"2018-03-27T04:37:10.000Z","msg":"個班係新香港人"},"citedBy":2,"replyTime":"2018-03-27T06:57:47.000Z","