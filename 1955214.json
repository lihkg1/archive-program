"},{"pid":"72a385693c0c20d713bc41c0f998e9dbf51250f6","tid":1955214,"uid":314244,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-02T11:50:14.000Z","msg":"推"},{"pid":"49fbc5c41bc184bd8c2f547196a3abeab3f6a5cf","tid":1955214,"uid":70745,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-02T11:51:54.000Z","msg":"Push"},{"pid":"b81f3b7cd1c0c0dd721f1d47316ce34d99ea6671","tid":1955214,"uid":211906,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-02T12:43:39.000Z","msg":"推唔郁<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"fe758668d4f7c884d55e487b8f97e5107e2119a2","tid":1955214,"uid":61653,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-02T12:45:35.000Z","msg":"天水<span style=\"color: red;\">圍</span>人"}],"pinned":{"pid":"7c08001c4dcbef7eac3fa91ae19044f507beabbc","tid":1955214,"uid":211906,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-04-02T13:39:15.000Z","msg":"補充番少少資料<br />\n<a href=\"https://www.thestandnews.com/society/%E7%84%A1%E4%BA%BA%E8%AA%8D%E9%A0%98%E9%81%BA%E9%AB%94%E8%88%87%E6%B2%99%E5%B6%BA%E5%85%AC%E5%A2%93/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fsociety%2F%25E7%2584%25A1%25E4%25BA%25BA%25E8%25AA%258D%25E9%25A0%2598%25E9%2581%25BA%25E9%25AB%2594%25E8%2588%2587%25E6%25B2%2599%25E5%25B6%25BA%25E5%2585%25AC%25E5%25A2%2593%2F&d=M80n4YL9TfmCcvG0giRsMnGrSSjb4k8A9Srgfm1924U%3D&h=ed35a73f\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fsociety%2F%25E7%2584%25A1%25E4%25BA%25BA%25E8%25AA%258D%25E9%25A0%2598%25E9%2581%25BA%25E9%25AB%2594%25E8%2588%2587%25E6%25B2%2599%25E5%25B6%25BA%25E5%2585%25AC%25E5%25A2%2593%2F&h=fd8d0ff9\" target=\"_blank\">https://www.thestandnews.com/society/%E7%84%A1%E4%BA%BA%E8%AA%8D%E9%A0%98%E9%81%BA%E9%AB%94%E8%88%87%E6%B2%99%E5%B6%BA%E5%85%AC%E5%A2%93/</a><br />\n沙嶺公墓是一個怎樣的墳場，簡單而言，這是給香港一眾<strong>「無人認領遺體」</strong>最後的葬身之地。<br />\n在沙嶺公墓的無人認領遺體，大多數死者的調查過程是沒有機會進行至「死因研訊」，主要是大部份個案的確是經死因裁判官判斷為<strong>「冇可疑」</strong><br />\n<a href=\"https://www.hkcnews.com/article/28500/%E6%B2%99%E5%B6%BA%E5%85%AC%E5%A2%93-%E6%B8%85%E6%98%8E%E7%AF%80-28501/%E7%84%A1%E6%B3%95%E5%BF%98%E8%A8%98%E5%A2%93%E7%A2%91%E4%B8%8A%E7%9A%84%E7%B7%A8%E8%99%9F\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hkcnews.com%2Farticle%2F28500%2F%25E6%25B2%2599%25E5%25B6%25BA%25E5%2585%25AC%25E5%25A2%2593-%25E6%25B8%2585%25E6%2598%258E%25E7%25AF%2580-28501%2F%25E7%2584%25A1%25E6%25B3%2595%25E5%25BF%2598%25E8%25A8%2598%25E5%25A2%2593%25E7%25A2%2591%25E4%25B8%258A%25E7%259A%2584%25E7%25B7%25A8%25E8%2599%259F&d=M80n4YL9TfmCcvG0giRsMnGrSSjb4k8A9Srgfm1924U%3D&h=0c95d5ab\" target=\"_blank\">https://www.hkcnews.com/article/28500/%E6%B2%99%E5%B6%BA%E5%85%AC%E5%A2%93-%E6%B8%85%E6%98%8E%E7%AF%80-28501/%E7%84%A1%E6%B3%95%E5%BF%98%E8%A8%98%E5%A2%93%E7%A2%91%E4%B8%8A%E7%9A%84%E7%B7%A8%E8%99%9F</a><br />\n2019年的墓碑數量有165個，而2020年只過了三個月，就已經有113個墓碑，沒有人會相信這是一件正常的事情吧？"}}