ts/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"8a7abcff299e1bf0fecaa78dbaccd53361d6c114","tid":1265250,"uid":11097,"like":0,"dislike":0,"score":0,"quote":{"pid":"9839df53cabca067d3566442f2eb31ee9d3b97eb","tid":1265250,"uid":87985,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-29T13:01:17.000Z","msg":"屯門人加油"},"citedBy":0,"replyTime":"2019-07-08T04:11:45.000Z","msg":"嚴格上<br />\n三聖打後既算青山灣<br />\n根本冇人會理果區<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"c614ffb7be96fcb1c15c6d23d161c60e954e8731","tid":1265250,"uid":142332,"like":0,"dislike":0,"score":0,"quote":{"pid":"dadfb210ea7cd41f673a69ec55826bebcd98cd5d","tid":1265250,"uid":92198,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-06-29T05:52:55.000Z","msg":"小弟住咗三聖二十幾年，都係蘇炤成條仆街霸住個位，點知屌你老味，今年葉劉竟然空降參選，仲要租咗黃金海岸單位住。葉劉從來離地到仆街，參選當然唔係為服務居民，而係劍指超區啦，而如果佢當選超區，就自然可以同中央講自己有民意基礎，可以選特首。條友係咩料大家03年都見過，隨時係689加777，23條重臨應該毫無懸念。<br />\n<br />\n蘇炤成條友自區議會選舉成立以來一直連任至今，都幾撚癡線，而葉劉同蘇炤成都係新民黨，更恐怖嘅係，葉劉應該仲可以吸多啲中產票，都咪話唔驚。大家不如集思廣益，睇下點可以令葉劉落選啦。<br />\n<br />\n相關資料：<br />\n三聖選區：<br />\n<img src=\"https://na.cx/i/bnMU0Dp.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbnMU0Dp.png&h=517da777&s={SIZE}\" /><br />\n【政壇諸事町】傳擬租住黃金海岸備戰區選  葉劉：私隱不便透露<br />\n<a href=\"https://www.hk01.com/sns/article/308874\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2Fsns%2Farticle%2F308874&d=FYZ0PdCaIZeH%2BWUkJYSmq4HZfmY0V3SDPlGVafywHRI%3D&h=10db5a0b\" data-auto-link target=\"_blank\">https://www.hk01.com/sns/article/308874</a>"},"citedBy":0,"replyTime":"2019-07-08T04:13:29.000Z","msg":"呢個係一個英雄四起,百花齊放既時代<br />\n<a href=\"https://lih.kg/129220