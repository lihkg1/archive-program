img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"cb5f75f7e6d005df0515f7f3fec89d903d9db7be","tid":1754584,"uid":186640,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-25T09:20:05.000Z","msg":"push"},{"pid":"0aa0c320a0acc6f78de97c27ee39163c0609d6f2","tid":1754584,"uid":84668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-25T09:20:44.000Z","msg":"Push"},{"pid":"e0fd158a5fa30d7625e91220e256a7f813b0ec3d","tid":1754584,"uid":84668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-25T09:21:11.000Z","msg":"你標題直接話搞鳩劉國勳好似會好啲"},{"pid":"d20a9584573d53cb91255553da6e9407092982a8","tid":1754584,"uid":173207,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-25T09:23:27.000Z","msg":"冇力啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"6f8dcd8a0981c621ef3a9745fbf0d2ae53429df9","tid":1754584,"uid":33028,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-25T09:27:11.000Z","msg":"39（4）條係講當選資格，係選舉期間先有用<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"74824a94febf285e946acf410730e4b908441dfc","tid":1754584,"uid":173207,"like":0,"dislike":0,"score":0,"quote":{"pid":"6f8dcd8a0981c621ef3a9745fbf0d2ae53429df9","tid":1754584,"uid":33028,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-25T09:27:11.000Z","msg":"39（4）條係講當選資格，係選舉期間先有用<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-25T09:31:35.000Z","msg":"指出問題 然後發大佢"}]}