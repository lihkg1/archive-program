lass=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /><br />\n香港人犬儒，得把口話好嬲好嬲，<br />\n核彈就黎多過美國俄羅斯加埋，<br />\n但乜都唔撚做。<br />\n又話出實彈就真暴動、又話出緊急法就真暴動，<br />\n周同學而家同死左冇分別，除左好嬲好嬲就仲係屋企打飛機，真係有死亡筆記都冇撚用"},{"pid":"1d5d502df6bc6fbf7ac079e4aaf35f2d1b6ea83f","tid":1698562,"uid":222269,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-07T17:05:36.000Z","msg":"此回覆已被刪除"},{"pid":"5ba944cc8f9a65341a9bad7abc697745cea7c36b","tid":1698562,"uid":222269,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-07T17:06:14.000Z","msg":"此回覆已被刪除"},{"pid":"5a810c71c67d951bab56888b4b031f876f016dd3","tid":1698562,"uid":59450,"like":0,"dislike":0,"score":0,"quote":{"pid":"5ba944cc8f9a65341a9bad7abc697745cea7c36b","tid":1698562,"uid":222269,"like":0,"dislike":0,"score":0,"quote":{"pid":"0001273be8351103ca11e273efff1dcc8b28bf5e","tid":1698562,"uid":59450,"like":0,"dislike":0,"score":0,"quote":{"pid":"6866584a3f6146faf36b653ea99b490a3cac82c6","tid":1698562,"uid":222269,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-07T15:54:42.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-11-07T16:23:09.000Z","msg":"係咪好圓滿"},"citedBy":1,"replyTime":"2019-11-07T17:06:14.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-11-07T17:09:04.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n冇喇喎，摺紙鶴唔好咩～<br />\n<br />\n唔可以話和理非活動冇用架，我摺紙鶴可以祝福每位香港人安全平安度過今次難關<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"a66a9e9dacd3d38b75e8b8fb1b67b80499d876a7","tid":1698562,"uid":222269,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-07T17:30:39.000Z","msg":"此回覆已被刪除"},{"pid":"623653c5c6d96aac0d7d71cfc7b44e4a7123f392","tid":1698562,"uid":138934,"like":0,"dislike":0,"score":0,"quote":{"pid":"a15754d9bb76eac6f62b93408a404250c2597536","tid":1698562,"uid":59450,"like":9,"dislike":0,"score":9,"citedBy":3,"replyTime":"2019-11-07T14:49:06.000Z","msg":"