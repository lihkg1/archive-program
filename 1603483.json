"pid":"c5358e733d94f415f19f25e92a1a397815089462","tid":1603483,"uid":164517,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T17:07:59.000Z","msg":"我哋仲要當佢係香港人？"},{"pid":"6072f25ca48036471265bca18a4946fa0534ad7a","tid":1603483,"uid":2764,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T17:09:17.000Z","msg":"推"},{"pid":"246348cc7e10417323ec08461377a4916930a135","tid":1603483,"uid":271894,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-29T17:11:18.000Z","msg":"其實香港人同黑警一樣<br />\n輸左都係咩都無"},{"pid":"061c7da8694ef4039af915a2602734fa416ee46c","tid":1603483,"uid":195995,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T17:18:45.000Z","msg":"要好好珍惜剩低能夠發夢既自由，因為黎緊每一次都好可能係各自既最後一次<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />."}]}