0158242814e4b8b07bdf0b5f70e16da9","tid":1601164,"uid":20867,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T03:06:05.000Z","msg":"又幫 韓國瑜/國民黨 反助選<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"9e9788e215f7d22a5ae0b5b858b01e5f66146f79","tid":1601164,"uid":74361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T03:06:54.000Z","msg":"蔡英文:好彩馬英九幫手carry, thanks<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"1c5353955d0c271a9a8ce471bb8edbd1dfec5ae9","tid":1601164,"uid":28114,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T04:25:42.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e0a75086195b52599eb09a2995cb45945c6da81c","tid":1601164,"uid":402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T04:33:44.000Z","msg":"佢算唔算叛國"}]}