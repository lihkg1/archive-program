第二日就跌 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"79b36d726d13217486956411a928895491e4d4ce","tid":2458210,"uid":192189,"like":1,"dislike":0,"score":1,"quote":{"pid":"33be1427763d0105fd6f4d3f71bc8e40f47e77b9","tid":2458210,"uid":77143,"like":1,"dislike":0,"score":1,"quote":{"pid":"7f9c4f29f3785d338e52d9953c9df9f9ab0d0cf0","tid":2458210,"uid":55991,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2021-03-26T02:00:48.000Z","msg":"燈唔中個d唔撚講<br />\n間唔時講就好笑姐<br />\n講得多就on9啦<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-26T02:15:41.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />佢係癲咖，全部都燈中"},"citedBy":1,"replyTime":"2021-03-26T03:33:33.000Z","msg":"問題係成日燈中果D都係無人會估到既事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"836fe90f07a89ec1b53cb759ce428d80547c0f1e","tid":2458210,"uid":156375,"like":0,"dislike":0,"score":0,"quote":{"pid":"79b36d726d13217486956411a928895491e4d4ce","tid":2458210,"uid":192189,"like":1,"dislike":0,"score":1,"quote":{"pid":"33be1427763d0105fd6f4d3f71bc8e40f47e77b9","tid":2458210,"uid":77143,"like":1,"dislike":0,"score":1,"quote":{"pid":"7f9c4f29f3785d338e52d9953c9df9f9ab0d0cf0","tid":2458210,"uid":55991,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2021-03-26T02:00:48.000Z","msg":"燈唔中個d唔撚講<br />\n間唔時講就好笑姐<br />\n講得多就on9啦<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-26T02:15:41.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />佢係癲咖，全部都燈中"},"citedBy":1,"replyTime":"2021-03-26T03:33:33.000Z","msg":"問題係成日燈中果D都係無人會估到既事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-26T04:15:48.000Z","msg":"我記得佢燈過周庭<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"87d9c6c17587584523f76b0a104b356cab2c593c","tid":2458210,"uid":2424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-