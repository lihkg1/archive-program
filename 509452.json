ref=\"https://hk.news.appledaily.com/china/realtime/article/20171225/57624012\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Fchina%2Frealtime%2Farticle%2F20171225%2F57624012&d=ZOOWPitwjGLyUMxvqtd0szQ9OVC7k%2FvddpU5ARN7O10%3D&h=5f481cd9\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Fchina%2Frealtime%2Farticle%2F20171225%2F57624012&h=d63eda91\" target=\"_blank\">https://hk.news.appledaily.com/china/realtime/article/20171225/57624012</a></blockquote><br />\n<br />\n好好笑<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"788abc83d130f433136cb49b74fe611be0fb95c6","tid":509452,"uid":82532,"like":1,"dislike":0,"score":1,"quote":{"pid":"80ee19d9079ac59a079f560dc5a56a35969ce8e9","tid":509452,"uid":25858,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2017-12-25T10:45:42.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2017/12/25/184435_64d048f6a41b6d6b7112974c8faf772c.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F25%2F184435_64d048f6a41b6d6b7112974c8faf772c.jpeg&h=8db9aa08&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/12/25/184437_75d29982a467acd5fc8cca78d17a7d78.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F25%2F184437_75d29982a467acd5fc8cca78d17a7d78.jpeg&h=32d0779e&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/12/25/184440_cbaa681288a0395fcec89389afe15473.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F25%2F184440_cbaa681288a0395fcec89389afe15473.jpeg&h=5eab054f&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/12/25/184442_e90c7c9bdfcac7ba03fc0829d3f5c14a.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F25%2F184442_e90c7c9bdfcac7ba03fc0829d3f