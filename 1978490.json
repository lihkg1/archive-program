ike":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T00:52:46.000Z","msg":"唔洗煲太久的<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> 太耐會爛"},{"pid":"80a422606a6475ef3a06791d417dfc5669f919f6","tid":1978490,"uid":117344,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-19T07:47:56.000Z","msg":"蕃薯切開之後要浸水去澱粉"},{"pid":"40f85f4a2fb3e84942bdc7e409db8f1a259d0742","tid":1978490,"uid":71166,"like":0,"dislike":0,"score":0,"quote":{"pid":"80a422606a6475ef3a06791d417dfc5669f919f6","tid":1978490,"uid":117344,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-19T07:47:56.000Z","msg":"蕃薯切開之後要浸水去澱粉"},"citedBy":0,"replyTime":"2020-04-19T07:48:35.000Z","msg":"要浸幾耐<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"}]}