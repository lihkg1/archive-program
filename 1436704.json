33e0887eaa2b3c9ae233601314a4a","tid":1436704,"uid":293677,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-09T11:55:31.000Z","msg":"嘥鳩氣啦<br />\n無指揮 又無組織過<br />\n咩戰陣都無用<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"821804083588804e7975bd25fe625f31179f6728","tid":1436704,"uid":284805,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:56:29.000Z","msg":"有用post 推！<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"a3406714b047c603dea5b54f2c13280daa12a93c","tid":1436704,"uid":61282,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:58:43.000Z","msg":"其實一路都有巴打出戰術post，不過好似無次執行到"},{"pid":"6eba792cd62866c72b4b23bc45df24794a87f6aa","tid":1436704,"uid":261346,"like":0,"dislike":0,"score":0,"quote":{"pid":"6ced8ca107ea8b4b02feb9dd9e4428c4295cbdd1","tid":1436704,"uid":225609,"like":18,"dislike":1,"score":17,"citedBy":1,"replyTime":"2019-08-09T10:39:49.000Z","msg":"第三部分：S1戰陣的其他戰術變化<br />\r\n<br />\r\n變化1 ： <br />\r\n義士A返回第二戰線的時候，義士B可主動出擊，用滅火筒和打狗棒攻擊追近的狗，協助義士A返回第二戰線。<br />\r\n<br />\r\n變化2 ： <br />\r\n義士A返回第二前線既時候，引誘少量狗隻進入第二前線，義士B再關上障礙物，關門打狗。<br />\r\n<br />\r\n變化3 ：<br />\r\n在戰術緩衝區設置陷阱和障礙物，阻礙D狗推進，不過義士A要小心，唔好俾自己D障礙物整親。<br />\r\n<br />\r\n<br />\r\n變化4 ：<br />\r\n例如面對黃大仙等等複雜地形，如果對面只有幾十隻狗集結，建立好第二前線之後，不仿分出另一批手足兜路從另一個路口包抄對面班狗，不過請注意，唔好封死哂對面班狗D路，點都要留番條路俾班狗走，防止班狗以死相搏。<br />\r\n<br />\r\n<br />\r\n<br />\r\n提外話：<br />\r\n我覺得中文字真係博大精深，當「人」遇上「狗」會係點？？ ？？？？？？？？ <br />\r\n原來係伏！！！<br />\r\n<br />\r\n<br />\r\n希望各位手足小心，不留血不被捕！！！"},"citedBy":0,"replyTime":"2019-08-09T12:17:27.000Z","msg":"推"},{"pid":"7cc9e7ea8966afdc1fb8c94496ca25b602635069","tid":1436704,"uid":41460,"like":2,"dislike":0,"score":2,"quote":{"pid":"7329edebaac1c24106ff3294c860ec80f9af40df","tid":1436704,"uid":282587,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-09T11:05:48.000Z","msg":"即係又叫人守路？"},"citedBy":0,"replyTime":"2019-08-09T12:19:02.000Z","msg":"我覺得未必防守 撒退都要有陣形<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><br />\n好似上環旺角咁 中後排塞住前線 狗一衝就亂 結果人堆人人踩人 最後犧牲既係前線<img src=\"/assets/faces/dog/itdog3.gif\" class=\"hkgmoji\" /><br />\n當然有得遊擊當然遊擊 但無可能次次都避到狗<br />\n暫時85黎睇 三大重災區 黃大仙 深水埗 天水圍 都係屬於正面交峰既戰鬥<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"101fd47f015c2d83bd5a4b2d179faccf1fce0eac","tid":1436704,"uid":265455,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T12:20:57.000Z","msg":"推"},{"pid":"35eb906eb2024a2453654d20e41b250166078b58","tid":1436704,"uid":41460,"like":1,"dislike":0,"score":1,"quote":{"pid":"11cd0af250f33e0887eaa2b3c9ae233601314a4a","tid":1436704,"uid":293677,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-09T11:55:31.000Z","msg":"嘥鳩氣啦<br />\n無指揮 又無組織過<br />\n咩戰陣都無用<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-09T12:21:59.000Z","msg":"發夢次次上前線 有啲前線真係唔聽人講野<br />\n但同時有啲前線係聽人講但無人組織<br />\n所以我地做既係嘗試組織前線行動<br />\n咁嗰啲唔聽人講嘅前線見無人聽佢支笛 自然就會加入"},{"pid":"d7320cd349c9d115a86c65d7304d1ecd38f87609","tid":1436704,"uid":225609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T13:41:16.000Z","msg":"推！"},{"pid":"e8f085f2b4703b1f3cb367d80d5838caf54abc36","tid":1436704,"uid":279513,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T14:43:16.000Z","msg":"推"},{"pid":"51d4dd7460752953ad11556697cdcaa524f7f9fe","tid":1436704,"uid":41460,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T15:52:08.000Z","msg":"推"},{"pid":"e20aa2e09e2f38acbd6a0dc47d66e16a18240046","tid":1436704,"uid":225609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T16:55:54.000Z","msg":"推！推！"},{"pid":"5a8fa81f66f04302ace45fe64ffd1c0e9bde7603","tid":1436704,"uid":270489,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-09T17:25:03.000Z","msg":"推戰術討論<br />\n大家睇多啲出到去先會多啲意識"},{"pid":"abe53c803379885f48d1d8bea411f628b4a0e5f1","tid":1436704,"uid":266125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T18:41:08.000Z"