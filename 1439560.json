後佢地根本唔知有家去邊度燒佢後欄，一來保護義士，二來更可以增加佢管治成本<br />\n<br />\n其實上次大埔同沙田之間已經出現呢種效果"},{"pid":"397c745b4f545c5c6cd2be69f68030be54ea6632","tid":1439560,"uid":57076,"like":0,"dislike":0,"score":0,"quote":{"pid":"0da54c40b6362cee63028519e2aa32e3307f8972","tid":1439560,"uid":181257,"like":0,"dislike":0,"score":0,"quote":{"pid":"eddabbbf9a0687ce7ec8c8e0d3499fdac4abd898","tid":1439560,"uid":57076,"like":0,"dislike":0,"score":0,"quote":{"pid":"f722ae427b4b2e9e3bc67dc9c34ba6ee8242c2ce","tid":1439560,"uid":181257,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-08-10T07:02:22.000Z","msg":"轉你老母 敵進啦咩？<br />\n出咗去先再決定啦"},"citedBy":1,"replyTime":"2019-08-10T07:02:59.000Z","msg":"準備姐，預見到啦<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-10T07:05:45.000Z","msg":"姐係未轉啦 講閪咩<br />\n轉你先再開post啦<br />\n講清楚呀 屌你"},"citedBy":2,"replyTime":"2019-08-10T09:36:30.000Z","msg":"轉得未?<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"a930002a44b4aab56240840fce419bd9e2bd6442","tid":1439560,"uid":181257,"like":0,"dislike":0,"score":0,"quote":{"pid":"397c745b4f545c5c6cd2be69f68030be54ea6632","tid":1439560,"uid":57076,"like":0,"dislike":0,"score":0,"quote":{"pid":"0da54c40b6362cee63028519e2aa32e3307f8972","tid":1439560,"uid":181257,"like":0,"dislike":0,"score":0,"quote":{"pid":"eddabbbf9a0687ce7ec8c8e0d3499fdac4abd898","tid":1439560,"uid":57076,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-10T07:02:59.000Z","msg":"準備姐，預見到啦<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-10T07:05:45.000Z","msg":"姐係未轉啦 講閪咩<br />\n轉你先再開post啦<br />\n講清楚呀 屌你"},"citedBy":2,"replyTime":"2019-08-10T09:36:30.000Z","msg":"轉得未?<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-10T10:02:12.000Z","msg":"得"},{"pid":"9d898b95eded1fe232c2d8b3450fbb821124820f","tid":1439560,"uid":181257,"like":0,"dislike":0,"score":0,"quote":{"pid":"397c745b4f545c5