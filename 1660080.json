67424724be088a3b6d9011fcc44809","tid":1660080,"uid":57577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:23:03.000Z","msg":"推"},{"pid":"40bb86d0a9feeb746a7e97f5244ae23f12dc1b52","tid":1660080,"uid":761,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:25:07.000Z","msg":"推"},{"pid":"1018ee9b795ece41045673e84e77d9da9fd1ebe0","tid":1660080,"uid":2867,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:31:28.000Z","msg":"10.20"},{"pid":"92661b43a2d61c52e2f6d26d157f610df47cb74b","tid":1660080,"uid":223034,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:32:27.000Z","msg":"推"},{"pid":"7e3f1d6000f4fa08c377e0f0387c8d7aa09d2bd6","tid":1660080,"uid":145695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:32:55.000Z","msg":"推爆佢<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c582b8a1c04fa7cd1341f3d4d30d3fd6038b67e3","tid":1660080,"uid":29643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:34:03.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"77d59d179e9c5f5ffcbc183a0f88d3dcca454104","tid":1660080,"uid":259493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:34:46.000Z","msg":"攬炒、炒到盡3<img src=\"/assets/faces/lm2/love.gif\" class=\"hkgmoji\" /><br />\n<br />\n所有在美加的手足，香港人真的需要你<br />\n所有nba賽事中場休息都有表演 <br />\n所有美國學校都有表演機會<br />\n<br />\n先播出香港人為何要爭取民主 或 真人演講，香港人為何要抗爭 （學生或女性演講為佳）<br />\n 後播出 反修例運動的血腥片段<br />\n 先播出現榮光原曲MV<br />\n之後，真人唱英文版 glory to Hong Kong<br />\n只需要有當地的管弦樂團 自願幫助, 戴上頭盔眼罩和豬咀， 最重要是；搵足夠的香港留學生 現場領唱<br />\n<br />\n   +++++++++++++++++++++++++<br />\n<br />\n向全場觀眾敬禮 或  鞠躬<br />\n向全世界願意幫助香港的人 致敬！<br />\n用英文大叫：&ldquo; 必需成立獨立調查委員會  和  香港真普選&quot;<br />\n<br />\n+++++++++++++++++++++<br />\n<br />\n 建議先搵校園多做練習或公開場合表演給美國人看，目標是當地的人！不是香港人；我只是出意見，一切以當地的反應為依歸，隨機應變； 現場反應熱烈後，再邁向電視直播中表現， 電視直播絕不可以出錯  <br />\n<br />\n#所有中場休息的表演 應該都有合約/商業贊助， 如果不行，可以嘗試賽前表演 或 其他時間 。 最重要是表演得掌聲，催人熱淚 得到現場觀眾認同，身同感受。 演出就是演出， 觀眾的反應就是一切.<br />\n<br />\n#不要過份控訴警察，西方國家政府/議員/總統十分依賴警察執法&hellip;&hellip;重點是中共的暴和學生的惨，要求即時行動：保護香港人， 我們每一個學生都在死亡邊緣。<br />\n<br />\n# 謹記&ldquo;不要問：他們可以無動於衷 ，不幫助我們！請先問：為何他們一定要幫助我們？&rdquo; 我們既要謙虛也要感恩。<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n# 逢係宣傳都要合乎當地民情 ，同一個廣告在香港大賣未必適合美國， 要&ldquo;配合&rdquo;白人的感受 /黑人的接受 /西班牙牙族裔的喜歡 /女性的認同 ，更加要有普世價值 和美國精神，有很多禁忌是外人難以明白。<br />\n<br />\n#就算中美貿易達成一萬個協議，美國人民都會站在香港人這一邊，因為中共就是邪惡的象徵， 問題只是香港人識唔識做！"},{"pid":"ac33a7e638e4a858fd72d7b32db1a6809c3b39c9","tid":1660080,"uid":77461,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-10-17T10:36:43.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">成個熱門一個行動post都無</span></span><br />\n聽撚到煩<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n每人開個行動post 然後個個都話自己個post要上熱門 <br />\n好似自己個post特別重要咁 根本就自己拆散哂d人"},{"pid":"28ff97ad0da9bdb672bb2df58cd484d12c3a0936","tid":1660080,"uid":144553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:36:58.000Z","msg":"推"},{"pid":"666b6031839367d38814a70fc1a426626f0ffd3a","tid":1660080,"uid":81084,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:36:59.000Z","msg":"Push"},{"pid":"e8f9bf58230b97d54401bcd9462e48a9bac5440e","tid":1660080,"uid":36209,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:37:03.000Z","msg":"推"},{"pid":"0d4a490f4419b0d345146684e835c94dd8c03e63","tid":1660080,"uid":264246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:37:28.000Z","msg":"被滲透左好耐"},{"pid":"5977a3117fee8a0fbc9109fdeaf7d4d7e43885dc","tid":1660080,"uid":190369,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-17T10:38:00.000Z","msg":"推