.net%2Fupload%2F2017%2F11%2F02%2F015225_4d6bb11c6b43132e592235f8ce34bfcb.jpg&h=affae715&s={SIZE}\" /><br />\n<br />\n<br />\n前田敦子<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/11/02/015258_e60888126586f29006bdbaf1b117d630.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F02%2F015258_e60888126586f29006bdbaf1b117d630.jpg&h=d415fb2e&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/11/02/015300_5aacdd35430bcdefaf8127ccdbc64b8f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F02%2F015300_5aacdd35430bcdefaf8127ccdbc64b8f.jpg&h=1eb040bb&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/11/02/015301_a1431f9293fc562ab003c62484325847.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F02%2F015301_a1431f9293fc562ab003c62484325847.jpg&h=e8bd03e8&s={SIZE}\" />"},{"pid":"27616d862553e33f68203ded6e9cb7ef349578f0","tid":455031,"uid":49197,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-01T18:01:31.000Z","msg":"女人真係好撚仆街<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d045d393f35e4ec420e2c21d2d486298c1193c52","tid":455031,"uid":27416,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2017-11-01T18:03:17.000Z","msg":"純電影角度為twist 而twist<br />\n鍾意呢類電影好多套可以更滿足你"},{"pid":"814af6fd140406c39187dc1da6aa17945d4e55ea","tid":455031,"uid":25688,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-01T18:03:33.000Z","msg":"<blockquote>女人真係好撚仆街<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n有時候男人係後天搞到佢變仆街，而女人係天生骨子裡已經係仆街"},{"pid":"805a779b753740d7403e3035078c7ab81054889c","tid":455031,"uid":25688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-01T18:04:59.000Z","msg":"<blockquote>純電影角度為twist 而twist<br />\n鍾意呢類電影好多套可以更滿足你</blockquote><br />\n<br />\n睇影評電影係比小說更畫公仔畫出腸<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /> <br />\n<br />\n咁巴打有咩推薦？"},{"pid":"bed1344d262ebf4c7e2d107dc0bb31c97868038f","tid":455031,"uid":56432,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-01T18:05:47.000Z","msg":"啲歌幾好聽，肥仔典型接盤<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"3d8ab08c412705fe45c13080ce6948e56d675ae9","tid":455031,"uid":20867,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2017-11-01T18:07:57.000Z","msg":"<blockquote><blockquote>女人真係好撚仆街<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n有時候男人係後天搞到佢變仆街，而女人係天生骨子裏已經係仆街</blockquote><br />\n「其實每個男孩，本來都是渴望愛一個人直到永遠的。<br />\n　　　<br />\n只是，沒有任何女孩愛這樣的男孩，她們覺得這樣的男孩太幼稚，太古板，沒有情趣。<br />\n　　　　<br />\n於是男孩開始改變，變成女孩喜歡的那種嘴角掛著壞壞。<br />\n開始學會說甜言蜜語而不是心裏想說的話。<br />\n開始學會假裝關心，學會給女孩送小飾物討好她，學會如何追求，如何把握愛情。<br />\n或者看破紅塵，遊戲情場，成為女人恨恨的那種男人。<br />\n他們可以很容易俘獲女孩子的心，但是他們也會在黑的夜裏叼著煙流淚。<br />\n心裏有愛的時候，沒有女孩；有了女孩，卻永遠沒有了愛的感覺！」"},{"pid":"b8aa867210dd7a0f145ee799a5e61db3050b6057","tid":455031,"uid":1926,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-11-01T18:13:10.000Z","msg":"<blockquote>啲歌幾好聽，肥仔典型接盤<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\nMk仔玩厭左就由毒撚埋單"},{"pid":"79cd3cc6e4274ad790636688c3854791df188ad5","tid":455031,"uid":70013,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-01T19:08:59.000Z","msg":"睇睇下覺得有啲唔對路 因為佢成日標榜有扭橋 我就不斷諗有咩位可以扭 到松田翔太講自己讀嗰科同肥仔唔同時已經覺得有可能會咁扭"},{"pid":"dbb2b7615b124d3514eaf2c5e707adcddc38242f","tid":455031,"uid":18465,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-01T19:19:33.000Z","msg":"<blockquote>呢套嘢拍到前田好靚<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n唔知係咪因為睇之前d宣傳一直sell臨尾個5分鐘有幾咁震撼 又覺得冇咩大不了<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /></blockquote><br />\n咁sell先搞到冇癮"},{"pid":"a929cd603433322dca1d