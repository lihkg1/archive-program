=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"d66ddeb672958b929bf6350600b54691ab673c1e","tid":2163973,"uid":304431,"like":0,"dislike":0,"score":0,"quote":{"pid":"a2cd046e2d4f78df9e4b0545a1b2fe54c2959286","tid":2163973,"uid":242537,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-19T03:20:17.000Z","msg":"<a href=\"https://www.youtube.com/watch?v=8PlagYGIso4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D8PlagYGIso4&d=%2BN%2BzEUDrQz9IsHzLxo0c5mLZ6li1RkmcNQmTobTGNbY%3D&h=959e6dfb\" target=\"_blank\">https://www.youtube.com/watch?v=8PlagYGIso4</a>"},"citedBy":0,"replyTime":"2020-08-19T03:25:37.000Z","msg":"頭盔<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"10e99f58b9fdc3b8b022c902b59d01e0c6ab5fb0","tid":2163973,"uid":31215,"like":0,"dislike":0,"score":0,"quote":{"pid":"953b1fc3dd3744bc58fd2f05b3204068de06f161","tid":2163973,"uid":242537,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2020-08-19T03:21:17.000Z","msg":"<img src=\"https://resource01-proxy.ulifestyle.com.hk/res/v3/image/content/2415000/2415257/20190731_work_01_600.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fresource01-proxy.ulifestyle.com.hk%2Fres%2Fv3%2Fimage%2Fcontent%2F2415000%2F2415257%2F20190731_work_01_600.jpg&h=e919391b&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/Lt4ZU1A.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLt4ZU1A.jpg&h=4ac11723&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/0JGjcKz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0JGjcKz.jpg&h=d4bd38d3&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-08-19T03:28:58.000Z","msg":"<im