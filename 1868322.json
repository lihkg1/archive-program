ormal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-08T02:01:05.000Z","msg":"我都用字試左成晚,原來唔係... 巴打圖係咪公司標志<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ea4f4ea272cda586b561f90766f04ecf7144fcbe","tid":1868322,"uid":285463,"like":0,"dislike":0,"score":0,"quote":{"pid":"e5a03a70531573cec236656fd1f22b40513e9130","tid":1868322,"uid":316255,"like":0,"dislike":0,"score":0,"quote":{"pid":"82623d115b330d3b07e7e8485b396107141081da","tid":1868322,"uid":285463,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-02-07T14:31:27.000Z","msg":"集運有講，入左倉都會叫你聯絡賣家退貨，因為俾你放係倉都出唔到境"},"citedBy":1,"replyTime":"2020-02-07T16:37:13.000Z","msg":"bns 咁多件<br />\n有咁多人手退件咩<br />\nps 假設不幸海運都車唔曬嘅罩"},"citedBy":0,"replyTime":"2020-02-08T14:50:00.000Z","msg":"到左倉可能唔同集運做法有少少唔同，但至少有集運公司會叫你退貨，以台灣為例<br />\n<blockquote><br />\n台灣禁止出口口罩<br />\n緊急通知<br />\n台灣推出「限罩令」，從1月24日至2月23日，管制兩類型口罩出口1個月，因此，即時開始口罩暫時無法出口，若有口罩配送到倉，倉庫人員會盡量在第一時間做拒收處理，如若不小心已簽收的，請客人安排退貨，不便之處請見諒。<br />\n</blockquote>"},{"pid":"c68f4343f5116200147fd0836164429e5e0ad9f9","tid":1868322,"uid":21378,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-08T16:25:08.000Z","msg":"<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"}]}