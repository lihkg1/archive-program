06.000Z","msg":"留島唔留島人"},{"pid":"54fced61e299bd0da3e6227042cffba59372c59d","tid":1825413,"uid":127791,"like":4,"dislike":1,"score":3,"quote":{"pid":"1b39aee75fee267ea41926fd42d62f93d8153504","tid":1825413,"uid":66569,"like":4,"dislike":1,"score":3,"quote":{"pid":"1cba44740f7478a208fce22fd5945af5b2487d25","tid":1825413,"uid":5943,"like":2,"dislike":1,"score":1,"quote":{"pid":"69e9a4046ccdabf16f60ed738e743b9ca635952c","tid":1825413,"uid":14494,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-01-15T09:08:01.000Z","msg":"呢d專才要做幾耐有身分證？"},"citedBy":1,"replyTime":"2020-01-15T09:08:28.000Z","msg":"7年"},"citedBy":1,"replyTime":"2020-01-15T09:10:02.000Z","msg":"計埋係香港讀書果幾年，即係做 3 4 年野就係新香港人，再結埋婚申請埋家人黎"},"citedBy":0,"replyTime":"2020-01-15T09:59:31.000Z","msg":"兩公婆後生做新香港都算 屌 申請埋d 5-60歲老野落黎"},{"pid":"c6754a9ecb983bc0a1bfedc3f49f75677fb78d4b","tid":1825413,"uid":122275,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-01-15T10:49:51.000Z","msg":"講到咁垃圾咪又係仆住落黎<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ca1ab437781218c06deccd649d96e363a6d4dafb","tid":1825413,"uid":162008,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-01-15T11:06:39.000Z","msg":"內地咁好，佢地又咁專才咁叻，照道理唔應該落黎香港，返大陸啦<br />\n<br />\n<br />\n<br />\n台灣就公投完啦 咁香港人呢？<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">香港人唔可以再慣性沉默</span></span>，<br />\n一起發聲，習慣投票表達意見吧<br />\n<br />\n香港地投票 ~ 一個香港人的投票應用程式<br />\n下載連結：iOS / Android<br />\n<a href=\"https://hkvote.org\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhkvote.org&d=8FzWv2H1QRiLw4sTAqHlBiC3g8rst4cc2NZsp7q1N1o%3D&h=9215b7af\" data-auto-link target=\"_blank\">https://hkvote.org</a><br />\n<br />\n原post<br />\n<a href=\"https://lihkg.com/thread/1821362/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1821362/page/1</a>"},{"pid":"fabf3f7239ea3724928f8ec276c95f9821c06144","tid":1825413,"uid":5943,"like":0,"dislike":1,"score":-1,"quote":{"pid":"a617d685ae5215f