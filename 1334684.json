ike":0,"dislike":0,"score":0,"quote":{"pid":"72b45bc95491968c27e79be3c7334bb89ab8d864","tid":1334684,"uid":169665,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-20T10:55:13.000Z","msg":"順便叫人轉場參加法輪功遊行，可以行到西環 <img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-20T11:05:01.000Z","msg":"依個正喎喂"},{"pid":"dc12c4771c5cd8e25a52c6f8a5d075da4cdc94b6","tid":1334684,"uid":18001,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T11:07:52.000Z","msg":"記得AIRDROP <br />\n廢事有人屌叫人散"},{"pid":"f656f6d1877dafaab4962dbe4c231a40dde550a1","tid":1334684,"uid":52023,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T11:08:55.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3cf17884182d5a93ace29a9448d38641cee04662","tid":1334684,"uid":268516,"like":0,"dislike":0,"score":0,"quote":{"pid":"a9cd094008e2fb3fbf00c6727f19a28028b58b66","tid":1334684,"uid":101392,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-20T09:50:34.000Z","msg":"民陣灣仔叫解散之後<br />\n直接join法輪功行埋去西環<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n【突發】有冇人唔知其實聽日中環同西環都有不反對通知書？<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1334761\" data-auto-link target=\"_blank\">https://lih.kg/1334761</a>"},"citedBy":0,"replyTime":"2019-07-20T11:19:10.000Z","msg":"順手connect埋法輪功<br />\n林奠呢舖點同北京解釋"},{"pid":"24d2d86039b78f87a00daf4ea967b715061db95f","tid":1334684,"uid":50055,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-07-20T11:20:36.000Z","msg":"&lt;721遊行Q&amp;A&gt;<br />\n<br />\n明天遊行終點在哪裡？<br />\n－上訴委員會已裁決維持灣仔盧押道作為遊行終點的決定，因此民陣只能按不反對通知書，到盧押道結束遊行。<br />\n<br />\n民陣到達終點後會有什麼安排？<br />\n－我們會嚴格按照不反對通知書要求，在終點只會盡力宣佈「立即解散」。<br />\n<br />\n如果人流太多，加入遊行的人流倒灌到灣仔，終點安排會否有困難？<br />\n<strong>－請向警察查詢。</strong><br />\n<br />\n到盧押道後，如何離開灣仔？<br />\n<strong>－請向警察查詢。</strong><br />\n<br />\n如果灣仔地鐵站不能疏散，所有巴士又停開，怎麼辦？<br />\n<strong>－請向警察查詢。</strong><br />\n<br />\n如果書展人流、中途參與遊行人流、離開遊行的人流相沖，怎麼辦？<br />\n<strong>－請向警察查詢。</strong><br />\n<br />\n如果我需要向金鐘離開，又是否可行？<br />\n<strong>－請向警察查詢。</strong><br />\n<br />\n如果灣仔港鐵站因為人流太多而「飛站」，又可以如何離開？<br />\n<strong>－請向警察查詢。</strong><br />\n<br />\n如果明天遊行路線以外，有％＆＄％＃<br />\n<strong>－總之，請向警察查詢。</strong>警方可以施加上述安排，我們必須相信警方有能力可以處理。<br />\n<br />\n<br />\n<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"0fad54caf5de6da649d2dcf0ef99208fead98a8d","tid":1334684,"uid":34996,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T11:27:55.000Z","msg":"行完可以去金鐘走？"},{"pid":"3d67bfc47a966d5c77d95f4f944102be8d75d959","tid":1334684,"uid":73689,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T11:33:34.000Z","msg":"Push"},{"pid":"22b2502409c2983be94b1b08be5dbfb34aff7978","tid":1334684,"uid":197939,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T11:46:09.000Z","msg":"幾點到幾點"},{"pid":"ce7d509119b9ecdc9a758bc966a45306016a6d45","tid":1334684,"uid":264872,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T11:47:09.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"cc873d78d822a09f7fd51b97876ff2887b7f3df5","tid":1334684,"uid":110509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T13:39:34.000Z","msg":"推"},{"pid":"a725b267b51ddb1d3051898e5fab59ba1ecbce55","tid":1334684,"uid":74888,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T19:14:32.000Z","msg":"Push"},{"pid":"370fd58e64de8d2b9ed2fd8db14c7ffb83590144","tid":1334684,"uid":123456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T19:15:37.000Z","msg":"pish"},{"pid":"18d9dc032c6bdc60361e8d92b0c4925e2877c644","tid":1334684,"uid":261914,"like":0,"dislike":0,"score":0,"quote":{"pid":"2212dc1f4108938757e4ef33f0faabf42b812589","tid":1334684,"uid":269511,"like":123,"dislike":0,"score":123,"citedBy":4,"replyTime":"2019-07-20T08:25:32.000Z","msg":"推<br />