.lih.kg/thumbnail?u=https%3A%2F%2Fwww.cup.com.hk%2Fwp-content%2Fuploads%2F2019%2F06%2F3Vh-1.jpg&h=73162fd9&s={SIZE}\" />"},{"pid":"b236177c7bf426f883e46dc234d976423e4eb52f","tid":2275552,"uid":52594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-07T15:12:30.000Z","msg":"左眼係主力眼"},{"pid":"ef72bd7016091879b05bdfe6c4cd29e0dd0f8f38","tid":2275552,"uid":255269,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1c9146068bf352de4b2c9776f7168cf16c45b0a","tid":2275552,"uid":207254,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-11-07T14:15:14.000Z","msg":"我左右眼差幾百度<br />\n嚴重嗰隻近視 另一隻散光<br />\n初初帶眼鏡半個鐘就頂唔順<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-07T15:14:30.000Z","msg":"我都係一隻眼勁近視<br />\n另一隻眼勁散光<br />\n無咗眼鏡點單眼都睇唔到嘢<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"7bda34b3baf16787c526a618fb160b0748db8058","tid":2275552,"uid":207254,"like":0,"dislike":0,"score":0,"quote":{"pid":"ef72bd7016091879b05bdfe6c4cd29e0dd0f8f38","tid":2275552,"uid":255269,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1c9146068bf352de4b2c9776f7168cf16c45b0a","tid":2275552,"uid":207254,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-11-07T14:15:14.000Z","msg":"我左右眼差幾百度<br />\n嚴重嗰隻近視 另一隻散光<br />\n初初帶眼鏡半個鐘就頂唔順<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-07T15:14:30.000Z","msg":"我都係一隻眼勁近視<br />\n另一隻眼勁散光<br />\n無咗眼鏡點單眼都睇唔到嘢<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-07T15:15:40.000Z","msg":"雖然係差好多<br />\n但係平時雙眼睇野係清楚<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},{"pid":"263b429466565a8488c2ddb2a77ab1324f43f8bb","tid":2275552,"uid":139187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-07T15:16:16.000Z","msg":"唔放心就去驗眼<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2d19467dac72698ba86965a1a531143fbff0fc1d","tid":2275552,"uid":244231,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-07T15:21:47.000Z","msg":"我以前近視遠視弱視散光都有"},{"pid":"db80850fba7906177efa29c0475173ca76582079","tid":2275552,"uid":77905,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-07T15:24:33.000Z","msg":"左右眼唔同顏色 唔同白平衡咁<br />\n<br />\n但仔細睇先覺"},{"pid":"06f8cf016938addc622c954687c96cdb32c0c32a","tid":2275552,"uid":289900,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-07T15:31:42.000Z","msg":"睇咩原因同年齡<br />\n如果係因為眼球調節光線嘅部位有事所以唔準(即係近視/遠視)<br />\n可以透過眼鏡處理<br />\n<br />\n但如果係單眼弱視 即係隻左眼正常 但個腦忽略左眼嘅訊息而主要接收右眼嘅訊息<br />\n咁就冇乜方法救<br />\n而且因為個腦長期忽略左眼輸入嘅訊息 會令左眼連接大腦嘅神經都會退化 左眼弱視會越嚟越嚴重<br />\n處理方法要睇年紀<br />\n如果係細個可以train返左眼 例如夾硬遮住右眼迫身體要習慣返接收左眼嘅資訊 可以改善<br />\n但十幾廿歲之後就算用呢個方法改善機會都係接近0<br />\n咁到時唯有好好保護剩返視力正常個隻眼"},{"pid":"73035d713d9b38656877b18b9c69badab60fdd17","tid":2275552,"uid":53769,"like":0,"dislike":0,"score":0,"quote":{"pid":"392032b8c15c86d2641af6536bd332cbc798ae26","tid":2275552,"uid":271334,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-11-07T14:38:03.000Z","msg":"懶惰眼<br />\n<br />\n細個睇視科 有叫我阻住隻眼一段時間<br />\n但幼稚園貪靚 無跟住咁做<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n依加習慣睇野用開其中一隻眼<br />\n另一隻眼視力差好多<br />\n<br />\n利申 做過smile  問過醫生<br />\n懶惰眼要7歲前處理好"},"citedBy":0,"replyTime":"2020-11-07T15:36:47.000Z","msg":"啱啊 斜視7-8歲前唔搞 搵唔到就一世<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"e458ad9ce1b6ccfedb7516cf1f936c4d2ee6967c","tid":2275552,"uid":289900,"like":0,"dislike":0,"score":0,"quote":{"pid":"3d2f28f763691faf0ec83f6e2fbea6d2b228ef0b","tid":2275552,"uid":103237,"like":0,"dislike":0,"score":0,"quote":{"pid":"12b4dfe648aa615137783865deb5b46246d85af7","tid":2275552,"uid":127425,"like":10,"dislike":0,"score":10,"citedBy":2,"replyTime":"2020-11-07T09:24:11.000Z","msg":"咁你今日開始單起右眼睇野燉番暈佢囉"},"citedBy":1,"replyTime":"2020-11-07T10:03:52.000Z","msg":"Work唔work先"},"citedBy":1,"replyTime":"2020-11-07T15:39:20.000Z","msg":"睇年齡<br />\n十幾仲有機會<br />\n廿歲之後幾乎冇成功案例(咁當然可能因為廿歲之