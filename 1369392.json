,{"pid":"7d56dda4bb39ac0804e8b539692fdf7848e63024","tid":1369392,"uid":104917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T17:42:44.000Z","msg":"我知道大家對報細數不意外<br />\n但都要推！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}