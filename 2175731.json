%8D%B5%E9%A6%96%E5%8D%8A%E5%B0%8F%E6%99%82%E6%97%81%E8%BF%B0%E6%96%87%E5%AD%97%E5%85%A8%E8%A8%98%E9%8C%84/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E8%25AD%25A6%25E5%259C%2596%25E6%2594%25B9%25E5%25AF%25AB-7-21-%25E6%25AD%25B7%25E5%258F%25B2-%25E7%25AB%258B%25E5%25A0%25B4%25E6%2596%25B0%25E8%2581%259E-%25E7%2599%25BC%25E4%25BD%2588-7-21-%25E7%259B%25B4%25E6%2592%25AD%25E9%2597%259C%25E9%258D%25B5%25E9%25A6%2596%25E5%258D%258A%25E5%25B0%258F%25E6%2599%2582%25E6%2597%2581%25E8%25BF%25B0%25E6%2596%2587%25E5%25AD%2597%25E5%2585%25A8%25E8%25A8%2598%25E9%258C%2584%2F&d=hjP0Q4X6c9sJGZoCRXhatmvf1q1qK4rBaJpe4ZKN2Es%3D&h=72298394\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E8%25AD%25A6%25E5%259C%2596%25E6%2594%25B9%25E5%25AF%25AB-7-21-%25E6%25AD%25B7%25E5%258F%25B2-%25E7%25AB%258B%25E5%25A0%25B4%25E6%2596%25B0%25E8%2581%259E-%25E7%2599%25BC%25E4%25BD%2588-7-21-%25E7%259B%25B4%25E6%2592%25AD%25E9%2597%259C%25E9%258D%25B5%25E9%25A6%2596%25E5%258D%258A%25E5%25B0%258F%25E6%2599%2582%25E6%2597%2581%25E8%25BF%25B0%25E6%2596%2587%25E5%25AD%2597%25E5%2585%25A8%25E8%25A8%2598%25E9%258C%2584%2F&h=5e2b9fdd\" data-auto-link target=\"_blank\">https://www.thestandnews.com/politics/%E8%AD%A6%E5%9C%96%E6%94%B9%E5%AF%AB-7-21-%E6%AD%B7%E5%8F%B2-%E7%AB%8B%E5%A0%B4%E6%96%B0%E8%81%9E-%E7%99%BC%E4%BD%88-7-21-%E7%9B%B4%E6%92%AD%E9%97%9C%E9%8D%B5%E9%A6%96%E5%8D%8A%E5%B0%8F%E6%99%82%E6%97%81%E8%BF%B0%E6%96%87%E5%AD%97%E5%85%A8%E8%A8%98%E9%8C%84/</a>"},"citedBy":0,"replyTime":"2020-08-26T15:48:56.000Z","msg":"趙若水報道<br />\n2020年08月26日 10:00PM<br />\n今日（8月26日），警方上門拘捕立法會議員林卓廷及許智峯等16人。其中，林卓廷更被指控參與7.21元朗恐襲，涉及暴動罪，令市民震驚。「立場姐姐」何桂藍當日曾到元朗站更遭白衣人襲擊受傷，她今日就事件出席街站並指責警方一直試圖竄改7.21的事實，但市民可重溫當日一秒未剪的直播片段，相信自有公論。她表示，就算警方拘捕所有相關的市民，事實真相都不容被歪曲。<br />\n<br />\n何桂藍於今日晚上7時許到達街站並表示，一年前的7月21日，當時她身為立場新聞的記者，在得悉一個廚師被人打傷後才到元朗站。她在現場見到有名女士被白衣人打傷頭部，收費區的外面有很多白衣人，他們拿著貼有中共國旗的籐條，木棍，向普通市民施襲，現場是一片混亂。<br />\n<br />\n何桂藍指出，當時情況非常危險，她其後與白衣人保持距離嘗試繼續採訪，但白衣人仍向她和其他市民施襲。<br />\n<br />\n何桂藍：警方的發言有多個錯誤<br />\n何桂藍直言，警方的發言有多個錯誤。她表示，警方指有人激化事件，但事實是在當日下午，已有人遇襲，更有人被打到頭破血流，市民想要離開都離開不了，而非任何人去激化。<br />\n<br />\n對於警方指她以偏頗言論令市民以為是無差別襲擊。她指當日直播片段有約一小時，一秒不剪。鏡頭有拍攝到白衣人、受襲市民等，唯一沒拍攝到的是不在場的警方。因為，直到白衣人從西邊出口離開後才有防暴警到場。<br />\n<br />\n市民可重溫當日片段相信自有公論<br />\n何桂藍表示，警方一直試圖竄改7.21的事實，但市民可重溫當日一秒未剪的片段，相信自有公論。她直言，就算拘捕所有相關的市民，事實真相都不會被歪曲。<br />\n<br />\n對於是否擔心被警方拘捕，何桂藍表示，整個特區政府系統，警隊，以至中共的官媒、黨媒一直不斷放大所謂「保家衛國」的版本，更把遇襲的香港人抹黑成暴徒。她直言：「作為一個現場的見證者，我認為我有責任講出真相，如果因為講出真相在這個政權之下是犯罪的話，警方隨時可以拘捕我。」@"},{"pid":"a28ba918c8517776220f1d28e50a39fe189a0bcc","tid":2175731,"uid":144453,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-26T15:54:21.000Z","msg":"其實應該要借今次拉人案申請攞晒721全部cctv再公開，無得假"},{"pid":"1e84d569f52ee72a9a119e1e2fe40f45982b506a","tid":2175731,"uid":29649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-26T15:54:55.000Z","msg":"lm"},{"pid":"38e11a4d3e3062616467572faa777b721dab3ad8","tid":2175731,"uid":11809,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-26T15:57:12.000Z","msg":"好波<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d673db44411ad02c75870926f1b09f520bd39c8a","tid":2175731,"uid":43062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-26T16:20:39.000Z","msg":"歷史不容刪改<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"44bdc22b1eadf0daaa3b92f76863477bdf39673a","tid":2175731,"uid":265486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-26T16:21:34.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"80e4124462e860b39c61c9b97cc684a6f6ee7b72","tid":2175731,"uid":22556,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-26T16:30:01.000Z","msg":"無咩人知 推多次"}]}