d6e2c7a&s={SIZE}\" /><img src=\"https://na.cx/i/ARU9Kxu.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FARU9Kxu.png&h=a32d7290&s={SIZE}\" /><img src=\"https://na.cx/i/ki2Wpxw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fki2Wpxw.jpg&h=ad0dcc4a&s={SIZE}\" /><img src=\"https://na.cx/i/LEuNwcz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLEuNwcz.jpg&h=ea6c9a69&s={SIZE}\" /><img src=\"https://na.cx/i/EHnjnjf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEHnjnjf.png&h=694880f3&s={SIZE}\" />"},{"pid":"6ece70930a113b5345f4e2d5d084450a583ffd8f","tid":1453030,"uid":143472,"like":53,"dislike":1,"score":52,"citedBy":2,"replyTime":"2019-08-12T03:05:19.000Z","msg":"自2013年開始，李嘉誠已開始不斷出售內地的地產項目，單計2014年就在南京、北京、上海相繼出售三個辦公大樓，累計套現97.8億元。對上一次賣內地資產，則是2016年時出售上海世紀匯項目一半股權，套現近200億元。然而，對於出售上海資產報告，長實企業事務總監班唐慧慈回應時表示，公司經常收到不同出價建議，但有建議不代表公司接受及會出售項目。<br />\n除了賣內地資產， 在出售香港資產上亦絕無手軟。集團旗下電能（00006）分拆港燈（02638）套現近300億元、出售25%屈臣氏股權，套現440億元。至於2017年出售地標中環中心就更為轟動，套現逾400億元。<br />\n長實出售資產的原因之一是將資金轉投海外尋找更高的回報，但事實上，李嘉誠就因睇錯市，錯失了更好的回報。 中環中心近期不斷出現多宗拆售個案，呎價高至4萬元以上。<br />\n經過一輪撤資後，長實在內地及香港的土地儲備均大幅下降 。《彭博》統計，長實在內地的土儲於2016年至2018年間下跌近23%，香港則下跌33%，而海外土儲則未有變動。<br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b4058a5a4c4d6b37ceb91bac34cb988f151a4833","tid":1453030,"uid":55533,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2019-08-12T03:24:36.000Z","msg":"我信誠哥<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"b