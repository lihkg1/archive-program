ta-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FYxUaVpQ.jpg&h=d4b38d8a&s={SIZE}\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">支爆應該和誰看</span></span></strong><br />\n<br />\n<a href=\"https://petitions.whitehouse.gov/petition/request-communist-china-government-redeem-imperial-dynasty-s-bond\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Frequest-communist-china-government-redeem-imperial-dynasty-s-bond&d=mymTsZ9rb3gbearwAuc4QckuRvkIHaPazTq7BlmTy1I%3D&h=cbda322a\" target=\"_blank\">https://petitions.whitehouse.gov/petition/request-communist-china-government-redeem-imperial-dynasty-s-bond</a><br />\n<br />\n<span style=\"font-size: x-large;\"><strong>記得Check verify email</strong></span><br />\n<br />\n任何國際之間既債務都有繼承義務<br />\n慈禧簽果條辛丑條約 一戰果時民國繼續還<br />\n仲要還到1938年因爲打二戰窮到pk<br />\n去求條約國唔追辛丑賠款先可以停<br />\n既然中共自稱滿清正統承繼人<br />\n呢張債券自然本利點都要還<br />\n唔還既佢講乜差野要用南京條約去收番香港<br />\n而且美國政府係未同中共追還錢<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/wjpU2AG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwjpU2AG.jpg&h=45a46f02&s={SIZE}\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\">緊係侵侵啦！</span></strong><br />\n<br />\n<img src=\"/assets/faces/mf/special.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/special2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/special3.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"b258d738200ff4412bc8872122b0f013c21b8480","tid":1565330,"uid":60744,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T06:16:40.000Z","msg":"啱呀，推"},{"pid":"518ebe36dad39f1b29ec9cf640c3ddde13ad0bad","tid":1565330,"uid":186072,"like":3,"dislike":1,"score":2,"quote":{"pid":"3674a23f359b9be2aec812af43b3e4c8ccc185e7","tid":1565330,"uid":63863,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-09-13T06:10:49.000Z","msg":"無必要有咩好爭論<img src=\"/assets/faces/mf/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/sosad.gif\" class=\"hkgmoji\" />而家講緊係點樣將不滿轉為行動。有班友係咁屌人唱榮光，但係又講唔到應該點做<img src=\"/assets/faces/mf/chicken.gif\" class=\"hkgmoji\" />。起碼唱歌你call到人出黎action。"},"citedBy":0,"replyTime":"2019-09-13T06:17:53.000Z","msg":"其實長期咁樣唱落去<br />\n會令到好多人覺得咁樣已經出左力去幫手<br />\n變相會搞到啲人星期六日遊行唔想出黎<br />\n寧願晚晚唱歌算數<br />\n你話搞一啲有主題既集會都有啲用<br />\n但唱歌真係純粹成班人不停嗌中英口號然後唱歌<br />\n無限loop<br />\n實質作用真係不大<br />\n集會既話有人演講下<br />\n將近期值得人關注既事情講下可能仲有用"},{"pid":"a099977583d476b2985a719a9b36a496fcf8d550","tid":1565330,"uid":12335,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T06:17:57.000Z","msg":"推"},{"pid":"b6b8ce16932ab153efebb4372dec651261363a64","tid":1565330,"uid":280743,"like":0,"dislike":0,"score":0,"quote":{"pid":"38fb4931a8cd8c65d121d74e026324b6c890f99a","tid":1565330,"uid":1206,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-13T06:03:55.000Z","msg":"自推20次<br />\n915 東角見"},"citedBy":0,"replyTime":"2019-09-13T06:24:02.000Z","msg":"Push"},{"pid":"240c1666617cd31eacd8978b8918e1c6d5ba2ca7","tid":1565330,"uid":1206,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T06:36:14.000Z","msg":"自推20次<br />\n915 東角見"},{"pid":"73e57baa14e771c67733cf8989aedbd2ca60bce4","tid":1565330,"uid":1206,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T06:39:33.000Z","msg":"自推20次<br />\n915 東角見"},{"pid":"4c6fb5532fb4c8e3a33436d7cb02358339999bd9","tid":1565330,"uid":47480,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T06:39:35.000Z","msg":"推<img src=\"/assets/faces/mf/smile.png\" class=\"hkgmoji\" />"},{"pid":"0d0458d0ad0dade25fce61abbb64f362725e4464","tid":1565330,"uid":128213,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-13T06:41:21.000Z","msg":"要唱915一齊唱，super<img src=\"/assets/faces/mf/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"679503ef2ef610246a7ccfb1929270a048324b7