id":"f14c8c9d301179410dabbf6f27c0a0a741d0aeb7","tid":1693724,"uid":76776,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-11-04T19:22:27.000Z","msg":"此回覆已被刪除"},{"pid":"df20446dd63f6d0f890cc137767def692039e0bf","tid":1693724,"uid":141891,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-04T19:27:12.000Z","msg":"好多野佢都禁唔到<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" />物質同物質之間咁多化學反應<br />\n<br />\n細個上chem堂就聽過生石灰加水會好危險唔好亂咁試，千奇唔好咁做，我chem老師講既<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />"},{"pid":"c63853bfcc5cf718492b8ba47ec558f06c1436dd","tid":1693724,"uid":154702,"like":0,"dislike":0,"score":0,"quote":{"pid":"8b4bb1727ee052b6e0b2c4da34bbf91adb43acc5","tid":1693724,"uid":222970,"like":23,"dislike":0,"score":23,"citedBy":2,"replyTime":"2019-11-04T18:35:48.000Z","msg":"大家有冇睇過breaking bad <br />\n<br />\n主角果陣d材料都係係大學lab偷返黎<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-04T19:32:50.000Z","msg":"神劇"},{"pid":"46728240dee6d20e3058da73bb4de8e0587461d1","tid":1693724,"uid":30067,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-04T23:04:03.000Z","msg":"好危險<br />\n大家唔好做！<br />\n推俾更多人注意"},{"pid":"b91ec295e38b7f113f139f799e7182b78b938d9b","tid":1693724,"uid":189638,"like":1,"dislike":0,"score":1,"quote":{"pid":"8b4bb1727ee052b6e0b2c4da34bbf91adb43acc5","tid":1693724,"uid":222970,"like":23,"dislike":0,"score":23,"citedBy":2,"replyTime":"2019-11-04T18:35:48.000Z","msg":"大家有冇睇過breaking bad <br />\n<br />\n主角果陣d材料都係係大學lab偷返黎<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-04T23:47:58.000Z","msg":"係中學都有化學lab"},{"pid":"cf80d6d94257404ba0d47b895f175114bc1ef6d6","tid":1693724,"uid":222970,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T05:06:50.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ff0858e176df099f5a3148de51be9e7567901383","tid":1693724,"uid":173002,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-11-05T05:13:29.000Z","msg":"大家本來都唔知，<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><br />\n文匯詳盡提說明原來咁易整菠蘿，<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n果然係67暴動始祖嘅黨媒，以後有菠蘿爆炸都係文匯報煽動。 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"061b5d67b4f0ceb71eca585d479ba60fe4f27a15","tid":1693724,"uid":58375,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-11-05T05:17:56.000Z","msg":"篇嘢咁pro係咪工聯會寫？<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />"},{"pid":"c79c51367bd3e609cd7c79f500f21ac6796b5e08","tid":1693724,"uid":2924,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-11-05T05:19:54.000Z","msg":"Let&rsquo;s cook <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"355a559f67ee36777f69f94189b983b5af4202e9","tid":1693724,"uid":222492,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T05:22:07.000Z","msg":"謝謝文匯提供資料"},{"pid":"09919d5bba13a7276aa080193c0a7f1a4b1f16cc","tid":1693724,"uid":52946,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff10d26d05460f631416448c9e0e1b89de0b1ba3","tid":1693724,"uid":3522,"like":29,"dislike":2,"score":27,"citedBy":3,"replyTime":"2019-11-04T18:41:21.000Z","msg":"學到嘢<br />\n多謝文匯報"},"citedBy":0,"replyTime":"2019-11-05T05:23:59.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b6a26666adff3a1ddf82a980aafb3eaf0a6545a2","tid":1693724,"uid":130228,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-11-05T05:24:08.000Z","msg":"Yeah science bitch!"},{"pid":"f50445ef8866e4955cdf892ba8b20c6486f2693c","tid":1693724,"uid":138868,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-11-05T05:25:52.000Z","msg":"我要今個冬天冇人可以明火打邊爐<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"}]}