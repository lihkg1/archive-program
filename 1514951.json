ata-auto-link target=\"_blank\">https://www.facebook.com/1170684516349159/posts/2398098013607797?sfns=mo</a><br />\n<a href=\"https://www.facebook.com/102458676557543/posts/1582783125191750?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F102458676557543%2Fposts%2F1582783125191750%3Fsfns%3Dmo&d=BKn7HUA2FwSq4MnMa2nFTMVJ7iodhWXw1gkpPdYK6Sw%3D&h=eecb152f\" data-auto-link target=\"_blank\">https://www.facebook.com/102458676557543/posts/1582783125191750?sfns=mo</a><br />\n將窗嗌口號變成一種普及的生活方式，會好大感染力<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/cyn9vh9.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fcyn9vh9.png&h=f1d434e2&s={SIZE}\" />"},{"pid":"1b582d23b6eb4cd0c3a662dc84d7d889f3bd4384","tid":1514951,"uid":194452,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T03:07:40.000Z","msg":"829 831 901"},{"pid":"3d935874ba670c6a58f0258418f0f0490cf0c75e","tid":1514951,"uid":162441,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T03:08:18.000Z","msg":"推"},{"pid":"a085ef717630a1b999569c7ba4a35778abc03b85","tid":1514951,"uid":194452,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T03:20:59.000Z","msg":"829 831 901"},{"pid":"c4d25d3e0247f3467ed80b0f9fe9b40a21df89b4","tid":1514951,"uid":234944,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T03:31:38.000Z","msg":"做支線任<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},{"pid":"2cf093d0523dfa180c7a1e423a3053e22934ad2f","tid":1514951,"uid":284452,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T03:31:44.000Z","msg":"樓主識玩<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"}]}