d182c6b9f3d89377d8","tid":1532943,"uid":175326,"like":0,"dislike":0,"score":0,"quote":{"pid":"30357e0381b6fa70d8050d8be3d67948e787bcde","tid":1532943,"uid":55378,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-09-02T15:52:42.000Z","msg":"睇下有幾多天真嬌比樓豬黑警臥底帶到風向先<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-02T15:54:54.000Z","msg":"如果係黑警嘅話我切柒<br />\n<br />\n<span style=\"font-size: xx-large;\">光復香港 時代革命</span>"},"citedBy":1,"replyTime":"2019-09-02T16:14:24.000Z","msg":"唔係黑警就咪叫人停啦<br />\n直接比機會黑政府話壓制有成效<br />\n係應該叫人玩得聰明d<br />\n全面小隊形式游擊，各區同時發生<br />\n放低道德底線，要好似黑警咁有殺人既心<br />\n快閃行動，mission complete就撤退/轉場<br />\n設計好逃走路線先行動<br />\n唔係你講既龜縮<br />\n<br />\n不過你其實都唔錯得曬，因為香港人心態未準備好<br />\n要佢地有殺意基本上唔太可能<br />\n要運動失敗，經歷殘酷統治一段長時間<br />\n開始大部分人失業，無飯食<br />\n先會叫醒佢地<br />\n所以與其出來曬時間，留係屋企都係選擇"},{"pid":"525bab58a477f0a68a39d35f9550683c92aac608","tid":1532943,"uid":275524,"like":0,"dislike":0,"score":0,"quote":{"pid":"067874d4ea912f7e5ec92a448a6a7ac9504ede2c","tid":1532943,"uid":258421,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-09-02T15:46:44.000Z","msg":"同埋單拖既就唔好挑狗機 佢地已經癲到講一句就打人拉人 要好好保護自己呀唔該<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-02T16:16:58.000Z","msg":"仲要有心理， 入佐去，會被打"},{"pid":"038da0b2af2ab6a97f73ec71ffd188b22f8858c5","tid":1532943,"uid":175326,"like":0,"dislike":0,"score":0,"quote":{"pid":"68b624ad4153dbe3d57823ac3ba9c3456b7f2062","tid":1532943,"uid":55378,"like":0,"dislike":0,"score":0,"quote":{"pid":"a15cacce53def13585e1d7d182c6b9f3d89377d8","tid":1532943,"uid":175326,"like":0,"dislike":0,"score":0,"quote":{"pid":"30357e0381b6fa70d8050d8be3d67948e787bcde","tid":1532943,"uid":55378,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-09-02T15:52:42.000Z","msg":"睇下有幾多天真嬌比樓豬黑警臥底帶到風向先<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-02T15:54:54.000Z","msg":"如果係黑警嘅話我切柒<br />\n<br />\n<span style=\"font-size: xx-large;\">光復香港 時代革命</span>"},"citedBy":1,"replyTime":"2019-09-02T16:14:24.000Z","msg":"唔係黑警就咪叫人停啦<br />\n直接比機會黑政府話壓制有成效<br />\n係應該叫人玩得聰明d<br />\n全面小隊形式游擊，各區同時發生<br />\n放低道德底線，要好似黑警咁有殺人既心<br />\n快閃行動，mission complete就撤退/轉場<br />\n設計好逃走路線先行動<br />\n唔係你講既龜縮<br />\n<br />\n不過你其實都唔錯得曬，因為香港人心態未準備好<br />\n要佢地有殺意基本上唔太可能<br />\n要運動失敗，經歷殘酷統治一段長時間<br />\n開始大部分人失業，無飯食<br />\n先會叫醒佢地<br />\n所以與其出來曬時間，留係屋企都係選擇"},"citedBy":1,"replyTime":"2019-09-02T16:20:06.000Z","msg":"呢個唔係龜縮，係戰術性撤退！<br />\n<br />\n好似你咁講，Mission complete 就撤退，但重點係每一次文宣叫人出嚟，都冇講過Mission係咩<br />\n前線嘅人就永遠唔會退<img src=\"/assets/faces/lomoji/39.png\" class=\"hkgmoji\" />又係因為後面嘅人未走，結果又係前線俾人拉！<br />\n<br />\n就係因為我唔係黑警，先知道手足有幾緊要，唔係退唔退嘅問題，係得與失嘅問題！<br />\n<br />\n每一次叫完行完，得到啲咩啊？我就係知道冇晒啲手足<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"8bc2d5828fa06751290e52f0ed2008bb0d9ab057","tid":1532943,"uid":55378,"like":0,"dislike":0,"score":0,"quote":{"pid":"038da0b2af2ab6a97f73ec71ffd188b22f8858c5","tid":1532943,"uid":175326,"like":0,"dislike":0,"score":0,"quote":{"pid":"68b624ad4153dbe3d57823ac3ba9c3456b7f2062","tid":1532943,"uid":55378,"like":0,"dislike":0,"score":0,"quote":{"pid":"a15cacce53def13585e1d7d182c6b9f3d89377d8","tid":1532943,"uid":175326,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-02T15:54:54.000Z","msg":"如果係黑警嘅話我切柒<br />\n<br />\n<span style=\"font-size: xx-large;\">光復香港 時代革命</span>"},"citedBy":1,"replyTime":"2019-09-02T16:14:24.000Z","msg":"唔係黑警就咪叫人停啦<br />\n直接比機會黑政府話壓制有成效<br />\n係應該叫人玩得聰明d<br />\n全面小隊形式游擊，各區同時發生<br />\n放低道德底線，要好似黑警咁有殺人既心<br />\n快閃行動，mission complete就撤退/轉場<br />\n設計好逃走路線先行動<br />\n唔係你講既龜縮<br />\n<br />\n不過你其實都唔錯得曬，因為香港人心態未準備好<br />\n要佢地有殺意基本上唔太可能<br />\n要運動失敗，經歷殘酷統治一段長時間<br />\n開始大部分人失業，無飯食<br />\n先會叫醒佢地<br />\n所以與其出來曬時間，留係屋企都係選擇"},"citedBy":1,"replyTime":"2019-09-02T16:20:06.000Z","msg":"呢個唔係龜縮，係戰術性撤退！<br />\n<br />\n好似你咁講，Mission complete 就撤退，但重點係每一次文宣叫人出嚟，都冇講過Mission係咩<br />\n前線嘅人就永遠唔會退<img src=\"/assets/faces/lomoji/39.png\" class=\"hkgmoji\" />又係因為後面嘅人未走，結果又係前線俾人拉！<br />\n<br />\n就係因為我唔係黑警，先知道手足有幾緊要，唔係退唔退嘅問題，係得與失嘅問題！<br />\n<br />\n每一次叫完行完，得到啲咩啊？我就係知道冇晒啲手足<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-02T16:27:29.000Z","msg":"咁呢個係佢地唔跟策略行事<br />\n係人既問題，休息幾耐都唔會變<br />\n講左咁耐be water，之前都有人真係跟下，但突然又變翻以前咁死板，睇唔透"},{"pid":"380b1fe2be2772f483e01b73c9595bfa664f288a","tid":1532943,"uid":175326,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T16:28:14.000Z","msg":"推啊<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />我唔想冇晒啲手足啊"},{"pid":"c05b664da9576a84c17944c76b94189e78abd740","tid":1532943,"uid":287028,"like":0,"dislike":0,"score":0,"quote":{"pid":"9420e4ad57715b35c14eda7a3ed003c75c920b58","tid":1532943,"uid":175326,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-02T15:43:34.000Z","msg":"第一，呢幾日，已經睇到黑警佈晒陣咁，不斷加速佢哋嘅行動，已經有好多個手足畀人拉咗，最終只會趨向黑警同政府想要嘅結局。<br />\n<br />\n第二，所有手足千萬唔好再單走或者唔跟大隊走，咁樣只會一個一個畀人拉，手足不斷咁減少。<br />\n<br />\n第三，我哋呢幾日嘅行動，真係<strong><span style=\"font-size: xx-large;\">好好好失敗</span></strong>，論成效只係變咗一個造勢大會，抑或是喂喂喂集會，對政府一啲影響到冇。<br />\n<br />\n就以上呢三點，我懇請大家諗清楚，我哋點樣做下一步先可以贏，政府想喺10月1號之前解決我哋，咁我哋係咪應該調轉頭諗下，呢幾個星期都養精蓄銳，到10月1號嘅時候搞壇大野出嚟，而唔係一日一日咁俾人搣人數。"},"citedBy":2,"replyTime":"2019-09-02T16:29:16.000Z","msg":"巴打留個tg"},{"pid":"ee34b43812160e61c648fcb6c655894ca3f4e74e","tid":1532943,"uid":99703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T16:29:55.000Z","msg":"推！"},{"pid":"a5ac13dd9df70b7d80ceb00a0e74f67530a82e10","tid":1532943,"uid":175326,"like":0,"dislike":0,"score":0,"quote":{"pid":"8bc2d5828fa06751290e52f0ed2008bb0d9ab057","tid":1532943,"uid":55378,"like":0,"dislike":0,"score":0,"quote":{"pid":"038da0b2af2ab6a97