.eservice-hk.net%2Fupload%2F2018%2F05%2F21%2F141122_9db7593bb47910a192d31789af9f4abd.jpeg&h=05d3cde3&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/05/21/141128_9f4c8534c623503e135c6157b6e6d3bd.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F21%2F141128_9f4c8534c623503e135c6157b6e6d3bd.jpeg&h=3c3ea363&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/05/21/141134_94cdc88a9d8903bb6bfc9a19cc19c78d.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F21%2F141134_94cdc88a9d8903bb6bfc9a19cc19c78d.jpeg&h=83cc0708&s={SIZE}\" /><br />\n<br />\n總括而言，佢招牌菜唔太出色，似乎亦唔多客，轉做甜品可能仲好啲......<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/05/21/141251_3b379d7a8d8ba76d163de6ee83b60267.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F21%2F141251_3b379d7a8d8ba76d163de6ee83b60267.jpeg&h=47aeb128&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/05/21/141258_18d9017167d79a2d93ef7f03c1e4df68.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F21%2F141258_18d9017167d79a2d93ef7f03c1e4df68.jpeg&h=39a9f7ce&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-05-21T06:15:29.000Z","msg":"上次咪叫左你唔駛試"},{"pid":"8c51ac400073c8228d84c6382b52cfa86f0cdb06","tid":672562,"uid":181719,"like":0,"dislike":0,"score":0,"quote":{"pid":"3a5d293a5d7b8e3941c86ed46aa3b52487012046","tid":672562,"uid":20784,"like":0,"dislike":0,"score":0,"quote":{"pid":"2627e070541193b810fc384ba9478d2942092f05","tid":672562,"uid":181719,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-21T06:14:11.000Z","msg":"最近又一次去九龍城諗住食泰菜，結果又失敗咗，因為經過呢間野，見佢個原味雞同醬烤骨拼盤好似幾吸引，結果泰國菜又要等下次喇。<br />\n<br />\n上菜之後係有啲失望嘅，因為半隻雞，本來諗住好豐富，點知成隻乳鴿咁細，食落口感亦唔特別香口，最多話佢好住家風味咁啦。<br />\n<br />\n<img src=\"https://img.eservice-hk.net