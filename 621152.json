et%2Fupload%2F2018%2F04%2F08%2F163557_3f717b78cef56b0deb1ac91da0a2ffef.png&h=51ae08b7&s={SIZE}\" /><br />\n我之前都會，髮型師介紹用相個隻洗頭水之後就冇，前排用晒懶出去買，樓下買支施巴，開頭都仲可以，用一排就唔得，最後出去買返呢隻"},{"pid":"835a7ea780b9ccb7a6a1c1a75e9eb294b03d13e7","tid":621152,"uid":53577,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2018-04-08T08:49:16.000Z","msg":"啲咩head and shoulders, 潤髮乾髮，全部都冇用架，因為長期甩頭皮係真菌感染，普通洗頭水係唔得嘅。"},{"pid":"cdd23d7ba5d166f91ff860e4cd1f4122803197a0","tid":621152,"uid":53577,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-04-08T08:50:21.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/04/08/165005_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F08%2F165005_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=793139e7&s={SIZE}\" /><br />\n<br />\n呢隻。"},{"pid":"249ad9f15e4ca10a9ecaf740504566d4e5ddf9df","tid":621152,"uid":27129,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-08T08:53:17.000Z","msg":"會唔會係啲水太熱 搞到頭皮超乾"},{"pid":"57c942e52ca60476c5e2720b1afcec00a22ee3e7","tid":621152,"uid":92397,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-08T08:53:29.000Z","msg":"自己Google search 下之前消委會出既報告<br />\n市面上得十幾隻無致敏成份<br />\n我就用緊其中一隻 <br />\n一用其佢就頭痕 又多頭皮"},{"pid":"995920cbf64ce97f6ed3f406c25289d18c85c557","tid":621152,"uid":59684,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-08T08:54:05.000Z","msg":"Me<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"1d6bc75bbc3b9bdf75a450e9c3977ce687b9633c","tid":621152,"uid":48887,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-08T08:54:26.000Z","msg":"唔好用熱水洗 換隻乾性頭皮既洗頭水"},{"pid":"7f4037465fe97aca3022ef7dd160eaf8efb2c26d","tid":621152,"uid":15826,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-08T08:58:15.000Z","msg":"我都係咁 用普通洗頭水會洗到好撚多頭皮<br />\n而家用緊limola 好似係咁串<br />\nso far 用完好返哂 不過一轉洗頭水又嚟料"},{"pid":"6756306bf7c8e6d855536055fcec33d1a5bdec74","tid":621152,"uid":63326,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-08T08:59:45.000Z","msg":"樓主個頭有冇紅點 有嘅話係皮炎機會大"},{"pid":"e19b07e7467791941c1bffec44e4b17210c23430","tid":621152,"uid":21907,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-08T09:06:25.000Z","msg":"我之前都係<br />\n其實用咩洗頭水都一樣 你只要殘留咗啲化學物質就會好痕同跌頭皮<br />\n<br />\n之後我睇咗幾篇文話一路洗一路梳頭 幫你啲化學物質由頭皮梳返出黎<br />\n<br />\n然而真係好咗 你可以試下<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bcdce5fd73f0859df2a45eaf6c523e2b53b06fa4","tid":621152,"uid":61050,"like":0,"dislike":0,"score":0,"quote":{"pid":"cdd23d7ba5d166f91ff860e4cd1f4122803197a0","tid":621152,"uid":53577,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-04-08T08:50:21.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/04/08/165005_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F08%2F165005_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=793139e7&s={SIZE}\" /><br />\n<br />\n呢隻。"},"citedBy":1,"replyTime":"2018-04-08T09:08:38.000Z","msg":"呢隻長期用唔係咁好"},{"pid":"04c77594a65102a85eaa3482d22b4da022b459c4","tid":621152,"uid":60052,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-04-08T09:10:56.000Z","msg":"試下用日本洗頭水 Success 藍色的 幾有用"},{"pid":"d87bb8eede2d5b76c57cccd4c9213989719d4f2a","tid":621152,"uid":61050,"like":0,"dislike":0,"score":0,"quote":{"pid":"d40e69664d74c7039e4a78877dce0203054b8eef","tid":621152,"uid":31613,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2018-04-08T08:40:15.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/04/08/163557_3f717b78cef56b0deb1ac91da0a2ffef.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F08%2F163557_3f717b78cef56b0deb1ac91da0a2ffef.png&h=51ae08b7&s={SIZE}\" /><br />\n我之前都會，髮型師介紹用相個隻洗頭水之後就冇，前排用晒懶出去買，樓下買支施巴，開頭都仲可以，用一排就唔得，最後出去買返呢隻"},"citedBy":1,"replyTime":"2018-04-08T09:11:20.000Z","msg":"邊到買平 想試<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"62a154df0443180da516a672a795f2dd84bf5ad8","tid":621152,"uid":2321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-08T09:13:44.000Z","msg":"留名待醫，濕疹撚"},{"pid":"934178c5f82fbe13a1e59ef9359276b79a83d046","tid":621152,"uid":4575,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2018-04-08T09:18:30.000Z","msg":"我女友有濕疹，而家D頭皮好大塊又多又痕，R到損哂"},{"pid":"71ce9771efa422043b817424fcf4f680b410c705","tid":621152,"uid":17646,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-08T09:21:02.000Z","msg":"lm"},{"pid":"4e054f7a1f3c09a8ac0a38ce39da5a3cc36840bf","tid":621152,"uid":148195,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-08T09:26:17.000Z","msg":"我都係咁<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n搞到副眼鏡成日都有頭皮<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"b1e27ef7de6bcb007d1f45e6d6450ed21dc1e1fa","tid":621152,"uid":134367,"like":2,"dislike":0,"score":2,"quote":{"pid":"e0b1a36edc1cd52f82f23240a157d7c19cbd871b","tid":621152,"uid":83576,"like":43,"dislike":8,"score":35,"citedBy":2,"replyTime":"2018-04-08T05:42:02.000Z","msg":"以前都試過<br />\n嗰時發現係關洗頭水事<br />\n樓主試吓換第二隻<br />\n我自己最後用咗head and shoulders<br />\n有明顯改善"},"citedBy":0,"replyTime":"2018-04-08T09:30:18.000Z","msg":"我就係用head and shoulders出事<br />\n去頭皮個隻愈去愈多<br />\n<br />\n可以用上次個張冇致癌物洗頭水list"},{"pid":"a531ae05c2cfabe5817954404bcd56566f813dd7","tid":621152,"uid":7376,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-04-08T09:33:02.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/04/08/173140_80716bfb85f7ed5acce39123be88c6d9.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F08%2F173140_80716bfb85f7ed5acce39123be88c6d9.png&h=cb9242ae&s={SIZE}\" /><br />\n<br />\n我用藍色果枝<br />\n每星期用三次 其他時間用返普通洗頭水<br />\n用返幾個月就冇事"},{"pid":"0317dafc630e5e266c14ea1f4d5a370bae872cff","tid":621152,"uid":33130,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-04-08T09:33:13.000Z","msg":"仲有建議大家洗完頭點都要吹頭<br />\n<br />\n個頭濕住好易滋生細菌，有菌就好易出油同有頭皮"},{"pid":"d2cd6148945db686d9ad7d5196ead4a406420f84","tid":621152,"uid":16949,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-04-08T09:42:38.000Z","msg":"我以前都好似樓主咁<br />\n不過撞正有次肚痾<br />\n日痾夜痾咁<br />\n每次痾完都沖一次涼<br />\n個陣大概一日洗3次頭<br />\n持續幾日 <br />\n然後就冇咗頭皮困擾<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" /> <br />\n不過樓主都係試下啲頭皮專用洗頭水好啲"},{"pid":"2e19ab70a5f0ea83fbf4926d7fa204f6e38c76f1","tid":621152,"uid":22231,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2018-04-08T09:42:51.000Z","msg":"剷光頭斷尾"},{"pid":"af5c24fea42831bea0926937acbb342fd06e1a71","tid":621152,"uid":179426,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-04-08T09:45:32.000Z","msg":"曾經濕疹嚴重嗰陣R到有好多頭皮<br />\n用左avalon organics 3個月好左好多<img src=\"/assets/faces/big/like.gif\" class=\"hkgmoji\" />"},{"pid":"6ff902a24672ceee101e510de605a052a0437f11","tid":621152,"uid":98386,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-04-08T09:48:28.000Z","msg":"剷光頭冇煩惱<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"80f51d5d336f63bf05b24ff3eec82f2b91774a86","tid":621152,"uid":32887,"like":2,"dislike":9,"score":-7,"citedBy":1,"replyTime":"2018-04-08T09:54:17.000Z","msg":"我曾經同你一樣 晚晚洗兩三次頭都勁多頭皮  最辛苦都唔係頭皮 係痕到仆街 又多油 上網爬左好多文 發現好多人推薦大陸一隻叫康王復方酮康既產品 果陣真係太辛苦 抱住死馬當活醫既心態 好衝動咁係淘寶買左支黎試下  屌 用左兩次已經明顯好左勁多 一個月已經完全好晒 之後keep住每星期用一次 用左半枝左右 到而家半年無用過 都無番發既現像<br />\n認真 唔係話吹奏大陸產品 但如果真係好難頂 買枝番黎試下 可能真係幫到你"},{"pid":"cafb0ddddf91c87aae74b4efcf3b551340aec3c6","tid":621152,"uid":151187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-08T10:08:28.000Z","msg":"東風夜放花千樹，更吹落星如雨<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"97cf3a1ae4b59d3f78d8d6b780786c8242b87c7b","tid":621152,"uid":58140,"like