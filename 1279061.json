BMwQbarqDBIsRc7P2tejZlako6KwT%2FyznMNw%3D&h=eb162c81\" target=\"_blank\">https://www.reo.gov.hk/pdf/form/REO-1(C).pdf</a><br />\n<br />\n<strong><span style=\"color: red;\">交表</span></strong><br />\n<a href=\"https://www.reo.gov.hk/ch/voter/vrsubmit.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.reo.gov.hk%2Fch%2Fvoter%2Fvrsubmit.htm&d=DMh58HXBMwQbarqDBIsRc7P2tejZlako6KwT%2FyznMNw%3D&h=c51c6a3e\" target=\"_blank\">https://www.reo.gov.hk/ch/voter/vrsubmit.htm</a><br />\n<span style=\"color: red;\"><strong>用email/fax交 今晚1200截</strong></span><br />\n<span style=\"color: violet;\">如你持有有效的香港郵政或電子核證服務有限公司的電子核證（個人）證書 &lt;- 呢個基本冇人有，所以唔使試</span><br />\n<br />\n<strong><span style=\"color: red;\">免費傳真方法 </span></strong><br />\nHelloFax 免費黑白5張 / FAX.PLUS 免費黑白10張<br />\n<br />\n【教學】選民登記7月2日截止仲未搞？ 教你手機內3分鐘完成手續<br />\n<a href=\"https://unwire.hk/2019/06/17/votersubmit/software/android-app/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Funwire.hk%2F2019%2F06%2F17%2Fvotersubmit%2Fsoftware%2Fandroid-app%2F&d=DMh58HXBMwQbarqDBIsRc7P2tejZlako6KwT%2FyznMNw%3D&h=48c4cb19\" target=\"_blank\">https://unwire.hk/2019/06/17/votersubmit/software/android-app/</a><br />\n<br />\n[置頂]2019選民登記 推爆佢 7月2號截止<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1263306\" data-auto-link target=\"_blank\">https://lih.kg/1263306</a><br />\n[/麻煩大家幫手share出去<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />]"},{"pid":"ca031b17f69e9ed22d21bfab23e9c5d256e12678","tid":1279061,"uid":87571,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T15:16:13.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets