src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"a6ece17e0f8b1793c36fd35c5991691fee901763","tid":1943353,"uid":216867,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T15:54:14.000Z","msg":"留名<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"5bdbd58a7eeb5adcf54fd9d36f908e47cb87e5ce","tid":1943353,"uid":159033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T16:15:29.000Z","msg":"留名!!"},{"pid":"030ecde55462485cd1f2513bf369051679b9b793","tid":1943353,"uid":145957,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T16:21:58.000Z","msg":"留名<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n小組嘅話見過一次之後就可以<br />\n1.<br />\n2.<br />\n3.<br />\n4.<br />\n咁大家自己填名 齊人之後就寄<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"74d73859a41ff63d41e1478a27c8a3642ed1c653","tid":1943353,"uid":49456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T16:30:39.000Z","msg":"Lm <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"90493ba7118ac3552e494819901f8474bf79fda4","tid":1943353,"uid":243216,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-25T16:32:40.000Z","msg":"留名<img src=\"/assets/faces/mouse/smile.gif\" class=\"hkgmoji\" /><br />\n埋花入地下配對呢個方法幾好，但一對一配對有點尷尬。可以分兩隻色，變成4人一組的筆友。一段時間再番黎配過<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"6ac4857da0133c5a02085ed64eb4a83a7a79dd9d","tid":1943353,"uid":50185,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-25T16:35:15.000Z","msg":"我覺得可以四人一組互相寄幾好，一嚟交流得多會易啲知道對方中意咩，二嚟唔一定每一日都寄，兩三日一次，咁都會輕鬆啲。可以定期換一次都得。"},{"pid":"f57248762f14181f418871d0b02ebf12e80079d6","tid":1943353,"uid":5765,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T16:51:43.000Z","msg":"Lm<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"d08cd8dd79b2fb3cbf241f7d096001a5d7f53bbc","tid":1943353,"uid":320340,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T16:56:41.000Z","msg":"lm<img src=\"/assets/faces/fs/good.gif\" class=\"hkgmoji\" />"},{"pid":"bcd9ea977e5e8f1be9e232dae99336a26bc9e886","tid":1943353,"uid":4279,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T17:09:33.000Z","msg":"lm<br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"137220b6a6b5d349675e40c0a35a5b9326a28ae9","tid":1943353,"uid":235810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T22:01:34.000Z","msg":"Lm"},{"pid":"ac789b4fe42ed9455335e0e9175c0646c0cd71b0","tid":1943353,"uid":106521,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-26T05:14:49.000Z","msg":"今晚再定好details <br />\n開始試玩<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"af0a075e7c160b5d4e104347b82b24005370fbe3","tid":1943353,"uid":339022,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-26T05:27:31.000Z","msg":"不如開個google excel俾大家加好友？"},{"pid":"4913c17d458303dbef748605f316bdbe92d173eb","tid":1943353,"uid":243216,"like":0,"dislike":0,"score":0,"quote":{"pid":"af0a075e7c160b5d4e104347b82b24005370fbe3","tid":1943353,"uid":339022,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-26T05:27:31.000Z","msg":"不如開個google excel俾大家加好友？"},"citedBy":0,"replyTime":"2020-03-26T05:30:55.000Z","msg":"其實只要上一次島見一次面，就加到好友，唔使打code又唔會搞亂啲fd(因為遊戲加好友會顯示係咩遊戲識，但打code唔會)"},{"pid":"340e3858d0de298fedb122b16fc73a07d9f8da1e","tid":1943353,"uid":117238,"like":0,"dislike":0,"score":0,"quote":{"pid":"ac789b4fe42ed9455335e0e9175c0646c0cd71b0","tid":1943353,"uid":106521,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-26T05:14:49.000Z","msg":"今晚再定好details <br />\n開始試玩<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-26T05:33:47.000Z","msg":"參考大家意見 暫定玩法喺<br />\n<br />\nhost準備定兩set唔同色嘅花 （四個 1set)<br />\n將花用花紙包好埋喺地下<br />\n喺連登按次序加定好友然後開朋友島比第一組人入<br />\n排隊抽花 同色嘅就係筆友group<br />\n之後大家要留名同加好友<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 順便可以齊齊戴住花影張相<br />\n如果人數多可能要開多次島<br />\n因為host可能都會join 所以有啲組會係3個人一組<br />\n<br />\n確定左筆友group後就可以互相寫信 忙嘅朋友可以兩三日寫一次 一到兩星期後會再約時間開島抽筆友<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n有冇人想host或者有其他野補充<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"88e989065964bf1ecd2d60903770c671e139e115","tid":1943353,"uid":50185,"like":0,"dislike":0,"score":0,"quote":{"pid":"340e3858d0de298fedb122b16fc73a07d9f8da1e","tid":1943353,"uid":117238,"like":0,"dislike":0,"score":0,"quote":{"pid":"ac789b4fe42ed9455335e0e9175c0646c0cd71b0","tid":1943353,"uid":106521,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-26T05:14:49.000Z","msg":"今晚再定好details <br />\n開始試玩<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-26T05:33:47.000Z","msg":"參考大家意見 暫定玩法喺<br />\n<br />\nhost準備定兩set唔同色嘅花 （四個 1set)<br />\n將花用花紙包好埋喺地下<br />\n喺連登按次序加定好友然後開朋友島比第一組人入<br />\n排隊抽花 同色嘅就係筆友group<br />\n之後大家要留名同加好友<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 順便可以齊齊戴住花影張相<br />\n如果人數多可能要開多次島<br />\n因為host可能都會join 所以有啲組會係3個人一組<br />\n<br />\n確定左筆友group後就可以互相寫信 忙嘅朋友可以兩三日寫一次 一到兩星期後會再約時間開島抽筆友<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n有冇人想host或者有其他野補充<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-26T05:46:15.000Z","msg":"好<img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" />"},{"pid":"c4828acb76cca7745da6f39038a5beb9972a8002","tid":1943353,"uid":145957,"like":0,"dislike":0,"score":0,"quote":{"pid":"88e989065964bf1ecd2d60903770c671e139e115","tid":1943353,"uid":5018