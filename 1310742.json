id":1310742,"uid":249366,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-12T23:44:11.000Z","msg":"黃衛兵係咩意思"},{"pid":"2cf111a280af9c412602b33bc1382e4f9a3169c2","tid":1310742,"uid":25002,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T23:49:46.000Z","msg":"此回覆已被刪除"},{"pid":"8f7744baaed3486576ca8e10eff0388b069beef5","tid":1310742,"uid":249366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T23:56:18.000Z","msg":"咁應該都有藍衞兵"}]}