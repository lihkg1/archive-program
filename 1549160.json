全部都係<strong><ins>獨立思考嘅個體</ins></strong>！<br />\n<br />\n<strong><span style=\"font-size: large;\"><span style=\"color: limegreen;\">我地聚得埋一齊係因為都有一個共同目標呀喂！</span></span></strong><br />\n<br />\n【溫提】大家間中要諗返呢啲嘢呀<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1549152\" data-auto-link target=\"_blank\">https://lih.kg/1549152</a>"},{"pid":"f9c7cf622c5c4c88e88e93c01bb13d1ac1272423","tid":1549160,"uid":67425,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T08:43:38.000Z","msg":"32/40"},{"pid":"cd9f43441b2fd8e58e1e9ae7bb67465fbe18c145","tid":1549160,"uid":67425,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T08:44:01.000Z","msg":"33/40 多謝你<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"fc6224b8ec9f86e3ffcc7d266d36e86c5000a250","tid":1549160,"uid":67425,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T08:44:18.000Z","msg":"34/40"},{"pid":"c6b8c1fa51be84de42323b600f8c643ecec827e4","tid":1549160,"uid":67425,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T08:44:28.000Z","msg":"35/40"},{"pid":"55453fdcb6b0f54b8d3c5570410f4bbcb3b92c24","tid":1549160,"uid":250979,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T08:44:43.000Z","msg":"推"},{"pid":"b59d11995e4484ec5cbdde24323b56fb2fb70f3c","tid":1549160,"uid":67425,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T08:44:46.000Z","msg":"36/40"},{"pid":"df94e9196d5853562f4a91112a662f71821def10","tid":1549160,"uid":106870,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T08:44:46.000Z","msg":"推集中討論"},{"pid":"14ace1069a9c301764125b4fe9176e3d4b030566","tid":1549160,"uid":117906,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T08:44:57.000Z","msg":"[警世][最終文宣] 喚醒對中共既不信任 聯合世界圍堵#Chinazi<br />\n<a href=\"https://lih.kg/1548891\" data-auto-link target=\"_blank\">https://lih.kg/1548891</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<img src=\"https://na.cx/i/3E7OjKb.gif\" data-th