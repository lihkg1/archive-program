umbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2019%2F09%2F02%2F9dojRG.png&h=baf47345&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/JXMrzU3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJXMrzU3.jpg&h=4fd76574&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/uZFWW8o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuZFWW8o.jpg&h=4196affc&s={SIZE}\" />"},{"pid":"d22c016cab72a52127ee9b2c8d9837a36ca32377","tid":1538721,"uid":269753,"like":0,"dislike":0,"score":0,"quote":{"pid":"cbb28a0c6eaa49275f436c96bd4c66aa6719bc98","tid":1538721,"uid":1821,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2019-09-04T07:42:01.000Z","msg":"處決 7黑警賠返7條命 <br />\n賠返2隻眼 (近距離用布袋彈射謝振同ER ER SIR)<br />\n捉返1100個速龍防暴同監禁"},"citedBy":0,"replyTime":"2019-09-04T07:45:55.000Z","msg":"冇可能啦，佢做呢樣野，班犬唔會放過佢"},{"pid":"ade2953e83f199ea2e0b6ce47f2b619212883135","tid":1538721,"uid":269363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T07:47:20.000Z","msg":"五大訴求, 決一不可!"},{"pid":"2dd1c80d29e06a79286317cadbc4ac5d718248a9","tid":1538721,"uid":67232,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T07:47:28.000Z","msg":"唔撚好再問埋D on9問題啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"b7055c78cca40333674b6d6c50d928509a932426","tid":1538721,"uid":4559,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T07:48:02.000Z","msg":"此回覆已被刪除"},{"pid":"1c9af7a6f92c67a847cc6326fbb8d6adca5ffb0b","tid":1538721,"uid":132918,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-04T07:51:11.000Z","msg":"無用，問題係制度。<br />\n就算處決1000 隻速龍，政府都可以係29000隻警犬訓練多另外1000隻。<br />\n真正要改革<br />\n1.普選特首<br />\n2.擴大ICAC架構，處長要同大法官一樣係國際搜羅人選<br />\n3.增加民選檢控官職位"},{"pid":"8e3ef2198e17104fa6835b4ca5c8de2296ac0875","tid":1538721,"uid":235025,"like":0,"dislike":0,"score":0,"citedBy"