死咪又可以重逢，唔使咁<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"75e7c6826e21b0cedd36cb91fcd71fd1eb9ad204","tid":2429670,"uid":384355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-04T20:08:31.000Z","msg":"Btw 頂住"}]}