like":0,"score":0,"quote":{"pid":"6efdaf54fe242837612c2c10664b1d9c99c85128","tid":2498381,"uid":156652,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-04-21T06:25:45.000Z","msg":"英國人睇得好透"},"citedBy":0,"replyTime":"2021-04-21T07:29:59.000Z","msg":"民主大國 <img src=\"/assets/faces/cow/gold.gif\" class=\"hkgmoji\" />"},{"pid":"cc3fd74d2e180bd4c8efbfd873146fc6622c9c79","tid":2498381,"uid":51271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-21T07:55:23.000Z","msg":"根本無晒排泄孔"},{"pid":"2d1e2b86828799a794755cafacd5e5e75159fff6","tid":2498381,"uid":214502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-21T08:10:40.000Z","msg":"所以邊有人鐘意支那<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />乜撚都夾硬黎<br />\n唔識食腦解決問題"},{"pid":"b00d260b8fba9954abb65fb9d40f5d775e7987d0","tid":2498381,"uid":26770,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-21T08:13:27.000Z","msg":"夏博義咪就係話香港法棺好專業,反駁香港存有司法迫害果條撚樣<br />\n<br />\n支那攪夏博義唔係因為呢條友捍衛普世價值,係覺得大律師公會唔夠藍"}]}