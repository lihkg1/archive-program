ih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgKCZ1X5.jpg&h=b89008e8&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/F584pg9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FF584pg9.jpg&h=28cc0f64&s={SIZE}\" /><br />\n<span style=\"color: violet;\"><span style=\"font-size: large;\">禮賢會彭學高紀念中學<br />\n一路比人恰 <br />\n最後好似衰非禮 </span></span><br />\n<br />\n<img src=\"https://na.cx/i/r787265.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fr787265.jpg&h=cbc18066&s={SIZE}\" /><br />\n<br />\n<br />\n去左慕光英文書院<br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: medium;\">點知，因為遲到被留級，懷恨在心</span></span><img src=\"/assets/faces/lomoji/33.png\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://na.cx/i/VO0M04s.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVO0M04s.jpg&h=208e9714&s={SIZE}\" /><br />\n<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: x-large;\">在多年之後，懷疑冒認慕光英文書院某老師，<br />\n想呃天馬車去學校做表演嘉賓報復，因智力不足，<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n被馬車識破奸計，至今生死未卜。</span></span><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=0A-iHj1dtP4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D0A-iHj1dtP4&d=vTNdr7lgiRBdtcQZ4wg6zxOFz4pMHIf1Ti9x7C0XgVU%3D&h=b9136ad3\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=0A-iHj1dtP4</a><br />\n<br />\n<img src=\"http://upload.lsforum.net/users/public/n130891x220.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fupload.lsforum.net%2Fusers%2Fpublic%2Fn130891x220.jpg&h=5dfcb766&s={SIZE}\" /><br />\n<br />\n^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^"},{"pid":"03b847810dfb63180edb67823e4e8dba37b73241","tid":235763,"uid":19493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-09T08:59:18.000Z","msg":"醬囝係琴晚6點左右上水之後，<br />\n再無出現，<img src=\"/assets/faces/lomoji/32.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/32.png\" class=\"hkgmoji\" /> <br />\n<br />\n懷疑佢又想智破皇家雞場，<br />\n點知智力不足，而家被困係邪骨之中，<br />\n生死未卜。<br />\n<img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://na.cx/i/WJk4Y9a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWJk4Y9a.jpg&h=8a0ba9be&s={SIZE}\" /><br />\n<br />\n <blockquote>[長有長玩]有冇巴打仲未試過上青樓? (9)<br />\n<a href=\"https://lihkg.com/thread/184625/page/7\" target=\"_blank\">https://lihkg.com/thread/184625/page/7</a><br />\n<br />\n堂堂一個開國元帥要走去叫雞做雞蟲<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n真係好撚陰公 <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />  希望佢唔好變成文員仔2號喇 <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n好膽心佢安危 <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> </blockquote><br />\n<br />\n<br />\n有冇巴絲知道蔣介石 (叫雞) 下落<img src=\"/assets/faces/lomoji/32.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/32.png\" class=\"hkgmoji\" /> ??<br />\n<br />\n<img src=\"https://na.cx/i/4QcimxM.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4QcimxM.jpg&h=9a77bef7&s={SIZE}\" /><br />\n<br />\n<blockquote>蔣帝創業未半，而性病崩殂。今連登三分，波台, CC 疲弊，此誠危急存亡之秋也。 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> </blockquote><br />\n<br />\n<br />\n<img src=\"https://na.cx/i/Qw80D5O.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQw80D5O.jpg&h=11381d0f&s={SIZE}\" /><br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">醬囝捨生取義 <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> </span></span>"},{"pid":"67ddb1977276db8f907c3c1798d1c615b6f25053","tid":235763,"uid":19493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-09T08:59:39.000Z","msg":"<img src=\"https://na.cx/i/F584pg9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FF584pg9.jpg&h=28cc0f64&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/cKG658T.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcKG658T.jpg&h=b13d3988&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/gKCZ1X5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgKCZ1X5.jpg&h=b89008e8&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/84rz1bQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F84rz1bQ.jpg&h=b225cf83&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/r787265.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fr787265.jpg&h=cbc18066&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/558V0W1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F558V0W1.jpg&h=d5146ac4&s={SIZE}\" /><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">原來醬囝嘅過去係咁</span></span><br />\n<br />\n天將降大任於斯人也，必先苦其心志，勞其筋骨，餓其體膚，空乏其身，行拂亂其所為，所以動心忍性，增益其所不能。<br />\n<br />\n<br />\n<img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" />"},{"pid":"797856229d1742676bd84a2e306deaf0335bb7fc","tid":235763,"uid":19493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-09T09:00:35.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2017/05/04/205904_134204b71e49ba66f9923