class=\"hkgmoji\" />"},{"pid":"5e1e64bad1a5269d079f8f3ae222e820b21d8d28","tid":1188032,"uid":220431,"like":0,"dislike":1,"score":-1,"quote":{"pid":"4a874223df826779e22de70d4f417e858f8d5776","tid":1188032,"uid":111425,"like":1,"dislike":0,"score":1,"quote":{"pid":"c5e9998124c927d475fb86679929551b1d66f982","tid":1188032,"uid":43785,"like":0,"dislike":1,"score":-1,"quote":{"pid":"97faff7c6a08a3ac96baeb2f09485631e6c78946","tid":1188032,"uid":173952,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-06-06T04:32:33.000Z","msg":"條女係咪美斯請黎陰佢，影響佢打美洲盃?"},"citedBy":1,"replyTime":"2019-06-06T05:12:58.000Z","msg":"擺明裝鳩佢"},"citedBy":1,"replyTime":"2019-06-06T05:23:55.000Z","msg":"放撚埋cam 明裝佢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-06T06:03:47.000Z","msg":"係法庭到 messi就攬住個條女一路食雪卡睇尼馬坐監"},{"pid":"b489319dcfb181c05384b8a6e37707f97262ffe0","tid":1188032,"uid":173952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-06T06:04:23.000Z","msg":"巴西和卡塔爾在今天上午進行了一場熱身賽，雖然巴西2-0贏波，但他們的頭牌尼馬卻重傷了。如今巴西足協官方宣佈，尼馬嚴重，無緣接下來的美洲盃賽事。<br />\n<br />\n受傷瞬間<br />\n<br />\n  巴西足協聲明寫道：「對陣卡塔爾的比賽，尼馬右腳踝受傷，賽後他接受了影像學檢查，結果發現腳踝韌帶斷裂。由於尼馬傷病的嚴重性，這意味著他將無緣接下來的美洲盃賽事。」接下來，巴西足協將會選入尼馬的後備。<br />\n<br />\n場下痛哭<br />\n<br />\n  對陣卡塔爾的比賽第18分鐘，尼馬拿球過人，阿卜杜拉完全跟不上尼馬節奏。結果他直接抬起右腳，狠狠踹向尼馬右腳腳踝和小腿處，這一下讓尼馬直接受傷，只能被換下場。"},{"pid":"7674f204f355c0355ffa302ae6e45330ee92bccf","tid":1188032,"uid":173952,"like":0,"dislike":0,"score":0,"quote":{"pid":"5e1e64bad1a5269d079f8f3ae222e820b21d8d28","tid":1188032,"uid":220431,"like":0,"dislike":1,"score":-1,"quote":{"pid":"4a874223df826779e22de70d4f417e858f8d5776","tid":1188032,"uid":111425,"like":1,"dislike":0,"score":1,"quote":{"pid":"c5e9998124c927d475fb86679929551b1d66f982","tid":1188032,"uid":43785,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-06-06T05:12:58.000Z","msg":"擺明裝鳩佢"},"citedBy":1,"replyTime":"2019-06-06T05:23:55.000Z","msg":"放撚埋cam 明裝佢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"