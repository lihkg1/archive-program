F23%2F011717_8d6cf94f0709fbb918ae3259b843c6a8.jpg&h=b348c8aa&s={SIZE}\" /></blockquote><br />\n好鬼pro<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n紅色燈係有咩特別功效？"},{"pid":"81765919119e18895ef7b3187759e03754a192de","tid":253722,"uid":9707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-23T15:36:26.000Z","msg":"<blockquote><blockquote>留名支持！<br />\n<br />\n我下輪都諗住種返生菜<img src=\"https://img.eservice-hk.net/upload/2017/05/23/011717_8d6cf94f0709fbb918ae3259b843c6a8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F23%2F011717_8d6cf94f0709fbb918ae3259b843c6a8.jpg&h=b348c8aa&s={SIZE}\" /></blockquote><br />\n好鬼pro<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n紅色燈係有咩特別功效？</blockquote><br />\n<br />\n我玩果隻係水耕黎，盞燈係紫外燈黎"},{"pid":"e9ca26989c2453f64776b5c13a3574a3466f5717","tid":253722,"uid":8820,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-24T16:17:32.000Z","msg":"Day 3 <br />\n<br />\n火箭仔出咗少少草啦<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/05/25/001525_4ece5e36048394b628b79f4152f89d9d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F25%2F001525_4ece5e36048394b628b79f4152f89d9d.jpg&h=d8fa1208&s={SIZE}\" /><br />\n<br />\n蘿蔔仔就無乜動靜<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/05/25/001626_e9b7cccfb18447d444d48a7d63f33342.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F25%2F001626_e9b7cccfb18447d444d48a7d63f33342.jpg&h=c4ce7ec3&s={SIZE}\" /><br />\n<br />\n我睇話日日淋水好易浸壞，所以尋日無淋，今日影完呢張相先淋返<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n睇嚟火箭仔收成指日可待<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"}]}