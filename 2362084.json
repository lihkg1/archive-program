aces/big/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"86debc54eb4b695f60e4524dd7aedc0cc439447d","tid":2362084,"uid":52006,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-11T14:15:26.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"29d9adce79a5a0af65831b7d1e75f923a4ae8a38","tid":2362084,"uid":327169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-11T14:25:40.000Z","msg":"<img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /><br />\n竟然。。。。係咁???????????"},{"pid":"b6ed20e8fe0fac82af4a1ae0ee90cf6bd09b9f68","tid":2362084,"uid":24160,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-11T14:27:57.000Z","msg":"61 都叫老翁?<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />"}]}