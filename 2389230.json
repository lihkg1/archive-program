1a1d4906faa3fde","tid":2389230,"uid":73567,"like":0,"dislike":0,"score":0,"quote":{"pid":"12401cb26f551192ccc5f5788943d0b699a9460d","tid":2389230,"uid":127052,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-31T17:34:44.000Z","msg":"<a href=\"https://nhsvolunteerresponders.org.uk/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnhsvolunteerresponders.org.uk%2F&d=NiOc6rc%2FE9fikVhzT7%2F1GwQPoALeJAOsJ3HVvkpnkS8%3D&h=da2c6348\" target=\"_blank\">https://nhsvolunteerresponders.org.uk/</a><br />\n<br />\n做咗幾個月 <br />\n其實都幾輕鬆<br />\n我個Role係幫人去買餸 <br />\n去藥方拎藥 幫醫院送吓物資<br />\n通常你收到Order 可以揀做唔做<br />\n做就打個電話過去 問佢要乜<br />\n真係花30分鐘左右 就做完一個Task<br />\n<br />\n最近有時間 專登做多幾單<br />\n喺Volunteer個Profile提吓自己係香港人<br />\n我諗英國人知道 我哋唔係嚟拎褔利 <br />\n我哋都想融入社會 作出貢獻<br />\n<br />\n未Sign Up嘅手足可以Sign Up<br />\n程序好簡單<br />\n同埋 基本上有車 就做到佢大部份嘅Role<br />\n通常都係 10 Miles 以內 <br />\n有時幾日先一個Call 因為都唔少Volunteer<br />\n同埋有啲Expenses可以Claim返 <br />\n<br />\n有興趣知嘅 留個言<br />\n可以答吓問題 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-31T17:41:52.000Z","msg":"如果冇車咁可唔可以做?"},"citedBy":1,"replyTime":"2021-01-31T17:46:13.000Z","msg":"可以啊 不過有啲Task未必接到<br />\n例如話要送幾袋Grocery<br />\n<br />\n但如果係拎藥嗰啲 步兵應該都得<br />\n或者單車都OK<br />\n<br />\n佢冇寫明話要 有車 先做得<br />\n不過有啲Task冇車比較麻煩"},"citedBy":1,"replyTime":"2021-01-31T22:53:06.000Z","msg":"<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},{"pid":"1b4ae5d21fd31ba81ab4fbf76200bd2ca7e9e77b","tid":2389230,"uid":127052,"like":0,"dislike":0,"score":0,"quote":{"pid":"64ffdb1cc0824eb1a777a4040713ce5fb85ee3a9","tid":2389230,"uid":268059,"like":0,"dislike":0,"score":0,"quote":{"pid":"9981d69468581fd0c17c14568856e16623e81c9b","tid":2389230,"uid":127052,"like":0,"dislike":5,"score":-5,"quote":{"pid":"93ef608e2cb10851e3cf020935c9fe060d722bae","tid":2389230,"uid":268059,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-31T22:37:52.000Z","msg":"有興趣！但冇車 絲打一個 又有d驚<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-31T22:40:15.000Z","msg":"絲打可以Volunteer淨係服務我 <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-31T22:45:31.000Z","msg":"做volunteer既volunteer ?! <img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-31T22:53:10.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"63bca99f1b1da8f974403750c2a7b6c4b80d8c7b","tid":2389230,"uid":127052,"like":1,"dislike":0,"score":1,"quote":{"pid":"e0998c167f3711b8e54f15ab150fe459a1d8590e","tid":2389230,"uid":83874,"like":0,"dislike":0,"score":0,"quote":{"pid":"5790b3ab9f3d0946b94b9eaa1ab480d492601863","tid":2389230,"uid":127052,"like":6,"dislike":1,"score":5,"quote":{"pid":"c6b1eab9b70ad10496275cca61a1d4906faa3fde","tid":2389230,"uid":73567,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-31T17:41:52.000Z","msg":"如果冇車咁可唔可以做?"},"citedBy":1,"replyTime":"2021-01-31T17:46:13.000Z","msg":"可以啊 不過有啲Task未必接到<br />\n例如話要送幾袋Grocery<br />\n<br />\n但如果係拎藥嗰啲 步兵應該都得<br />\n或者單車都OK<br />\n<br />\n佢冇寫明話要 有車 先做得<br />\n不過有啲Task冇車比較麻煩"},"citedBy":1,"replyTime":"2021-01-31T22:53:06.000Z","msg":"<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-31T22:58:33.000Z","msg":"其實Volunteer Responder係散工咁<br />\n有任務接 通常一日一單<br />\n<br />\n如果要做啲服務性重嘅<br />\n可以等佢開返Stewart Volunteer再Apply<br />\n<br />\n同埋佢要所有Volunteer做Criminal Background Check<br />\n申請定先冇壞<br />\n我以前喺大學有義務教中學生<br />\n都會做Background Check"},{"pid":"d20a9023cb4db57257547b40e63526a806075056","tid":2389230,"uid":242613,"like":1,"dislike":1,"score":0,"quote":{"pid":"75d48409078da6de2aa814b6f3c50f63b08aaca1","tid":2389230,"uid":127052,"like":42,"dislike":2,"score":40,"quote":{"pid":"4bef0eb81e0e3aae4d7daf85bb356d9cf1ef0c01","tid":2389230,"uid":65790,"like":1,"dislike":1,"score":0,"quote":{"pid":"92bd534bfffdeefe1689051bf36ab54fb18a7250","tid":2389230,"uid":127052,"like":4,"dislike":1,"score":3,"citedBy":3,"replyTime":"2021-01-31T17:47:09.000Z","msg":"咁抽象好難答你<br />\n<br />\n利申 喺英國八年 溝唔到女 <br />\n如果問食鬼妹 咁你要問第二個了"},"citedBy":1,"replyTime":"2021-01-31T17:55:09.000Z","msg":"我想知英國人點睇香港遮<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n去英國旅行，中年個d都知香港咩事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2021-01-31T18:00:39.000Z","msg":"好多都好支持<br />\n<br />\n有個Master同學<br />\n都係律師嚟<br />\n佢前幾個月 冇端端話WhatsApp我<br />\n話 我支持你哋㗎 我哋英國好歡迎你哋<br />\n我知你道嚟係想要好啲嘅生活 同貢獻社會<br />\n你有困難記得同我講啊<br />\n<br />\n跟住 我之前舊公司<br />\n我幾個月前仲有係連登教英文嗰陣<br />\n我同公司同事提起<br />\n佢哋話 如果你要人一齊幫你教 幫你同學生練習 同Local傾計<br />\n同我哋講 話會抽時間出嚟 同手足練Oral 分享吓日常嘢<br />\n不過我之後冇再教英文 所以冇咗件事<br />\n<br />\n有時都有鬼仔問起 我都會解釋來龍去脈<br />\n其實好多人都好歡迎<br />\n<br />\n英國嘅左膠係真心左膠嚟<br />\n好多都好博愛<br />\n我試過喺街到 架車死火 都會有幾個人自發走嚟推車<br />\n搭巴士冇錢會幫你俾<br />\n當然都有壞人啦 但好人一定多啲"},"citedBy":0,"replyTime":"2021-01-31T22:59:06.000Z","msg":"好認同英國左膠係真心左膠，試過有露宿者扮NHS呃錢，啲local話武肺搞到經濟唔好，啲人走投無路要呃錢其實好慘<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n希望到埗嘅香港人都好好對local啦，有啲擔心"},{"pid":"6ee840f25ea65d3bf8361d1f37e3c56297071606","tid":2389230,"uid":83874,"like":0,"dislike":0,"score":0,"quote":{"pid":"75d48409078da6de2aa814b6f3c50f63b08aaca1","tid":2389230,"uid":127052,"like":42,"dislike":2,"score":40,"quote":{"pid":"4bef0eb81e0e3aae4d7daf85bb356d9cf1ef0c01","tid":2389230,"uid":65790,"like":1,"dislike":1,"score":0,"quote":{"pid":"92bd534bfffdeefe1689051bf36ab54fb18a7250","tid":2389230,"uid":127052,"like":4,"dislike":1,"score":3,"citedBy":3,"replyTime":"2021-