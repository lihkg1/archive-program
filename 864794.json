na.cx%2Fi%2Fze4iJ4X.jpg&h=3e0aff49&s={SIZE}\" />"},{"pid":"70a2e7c27c995211d1baa6251f1af27b5e47180e","tid":864794,"uid":187,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-10-16T20:12:06.000Z","msg":"食左個PIZZA就訓, 第2日倒香咁早就坐火車去LVIV<br />\n<br />\n大家會問點解唔第一日晚上就坐overnight 火車去LVIV &gt;&gt; 因為我廢, 坐左15個鐘飛機, 再訓火車隨時死<br />\n<br />\n<img src=\"https://na.cx/i/M1U6SZD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FM1U6SZD.jpg&h=059d912f&s={SIZE}\" />"},{"pid":"c4abc7005275b3b89779a8c67e07f9e81b4701b9","tid":864794,"uid":187,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-10-16T20:27:37.000Z","msg":"值得一提就係咁早上車有度好<br />\n<br />\n<img src=\"https://na.cx/i/XRtSODG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXRtSODG.jpg&h=21bd2735&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/zBOjtDL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzBOjtDL.jpg&h=4255bf90&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/yA6kXw8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyA6kXw8.jpg&h=91541203&s={SIZE}\" />"},{"pid":"77e2ff18654b97f9274e79d786442946c50e0a08","tid":864794,"uid":187,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-10-16T20:32:24.000Z","msg":"坐5個鐘火車之後<br />\n<br />\n坐架世界級黃色小巴去airbnb<br />\n<br />\n抵, 5蚊烏錢, 不過我地有2個行李箱, 架車爆滿之後, 每個站都有廢老表演縮骨功上車<br />\n<br />\nD行李仲比d廢老口UPUP怨鳩我<br />\n<br />\n唉屌我都知我地衰, 真係唔會再拎行李上呢d世界級小巴<br />\n<br />\n坐uber震興lviv<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"9f722c96eed393985caa4a78d32ab5367a147fc0","tid":864794,"uid":187,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-10-16T20:35:37.000Z","msg":"我地個HOUSE係舊地區邊界位, 地理位置超好<br />\n<br />\n成個building 都非常古典, 係無lift, 條木梯每一級都會發出音樂<br />\n<br />\n<img src=\"https://na.cx/i/GJeKENp.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FGJeKENp.jpg&h=71131e36&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/XRdrS7s.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXRdrS7s.jpg&h=9f8c592f&s={SIZE}\" />"},{"pid":"5d695b458336a41188dc8bdcdf243feffa5a0cce","tid":864794,"uid":2169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-16T20:40:08.000Z","msg":"快d出文"},{"pid":"b56e911eb1f5cd28971ed477c8c5918f98befebc","tid":864794,"uid":187,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-10-16T20:48:17.000Z","msg":"去到LVIV好重要要做既事係去歌劇芭蕾舞劇院買飛<br />\n<br />\n屌你正啊喂, 想睇芭蕾, 要等到星期3, 即係我已經走左Kiev<br />\n<br />\n咁無理由去劇院到唔睇架, 就買左&quot;Carmen&quot; D飛<br />\n<br />\n<img src=\"https://na.cx/i/evNcOLD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FevNcOLD.jpg&h=ad75023b&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/SDcz15H.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSDcz15H.jpg&h=294ea0ef&s={SIZE}\" />"},{"pid":"dbf57ba40dc52136ae035213f0f197114f7de811","tid":864794,"uid":187,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-10-16T21:01:18.000Z","msg":"講起由自可, 一講由把幾火, 我係劇院拎住單反, 諗住影女<br />\n<br />\n有個阿嬸同我講一陣唔好影, OK FINE, 我原本都諗住好好欣賞下Carmen<br />\n<br />\n仆你個街, Carmen 有4幕, 每一幕都有d仆街影相, 不特止, 仲要開閃光燈<br />\n<br />\n<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://na.cx/i/uTLhZVp.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuTLhZVp.jpg&h=2e1106f6&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/xt6hftN.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fxt6hftN.jpg&h=aa67dd11&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/YZnXftR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FYZnXftR.jpg&h=8a9d4070&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/Def9Q2e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDef9Q2e.jpg&h=4425b2f3&s={SIZE}\" /><br />\n<br />\nBTW1, 藍女唔係女主角, 我最初以為佢係Carmen, 點知係白衫女人先係<br />\n<br />\nBTW2, 白衫女人唱得最好<br />\n<br />\nBTW3, 有個外國肥婆叫我幫佢影相, 我幫佢影到佢好滿意<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\nBTW4, 好彩外國肥婆同我地講解Carmen係一個咩故仔, 否則真係訓全場"},{"pid":"f2ff6e6030836363cba6637f6c651e9433e7b1a6","tid":864794,"uid":127358,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-16T21:05:20.000Z","msg":"lm"},{"pid":"b240d51c3dea58cf755459ff1ba269fbb26baa86","tid":864794,"uid":187,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-10-16T21:11:16.000Z","msg":"LVIV舊城區晚上真係好好FEEL<br />\n<br />\n有隊賣唱既, 2女1男band, 唱得好落力, 好有heart<br />\n<br />\n我自己都課左10蚊烏$$比佢地<br />\n<br />\n<img src=\"https://na.cx/i/uaVRjZ3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuaVRjZ3.jpg&h=3178faed&s={SIZE}\" />"},{"pid":"0cd236544bd350839c36fb1e0415db86494a2ec5","tid":864794,"uid":187,"like":4,"dislike":0,"score":4,"quote":{"pid":"b240d51c3dea58cf755459ff1ba269fbb26baa86","tid":864794,"uid":187,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-10-16T21:11:16.000Z","msg":"LVIV舊城區晚上真係好好FEEL<br />\n<br />\n有隊賣唱既, 2女1男band, 唱得