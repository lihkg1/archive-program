ormal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8eb6942586681ea37b157fcf899ac37e4fa57952","tid":1155523,"uid":10503,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2019-05-15T08:40:23.000Z","msg":"高列巴尼對住垃圾阿狗都守唔住又og<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5ee372e4568b0a20a064ed9ad464e8a22755659e","tid":1155523,"uid":158755,"like":0,"dislike":0,"score":0,"quote":{"pid":"c69f21a9e6c9dc9e6631f96e9395f4d06a232507","tid":1155523,"uid":85774,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-05-15T07:55:43.000Z","msg":"Sancho 同 Bissaka之前人地已經表態左話唔想加盟曼狗啦  update 少少好冇"},"citedBy":1,"replyTime":"2019-05-15T08:55:29.000Z","msg":"鏝之前都話想簽Sancho<br />\n係人都識揀啦"},{"pid":"3f74cf636773c813406e90e925049d1e7563af4a","tid":1155523,"uid":37757,"like":0,"dislike":2,"score":-2,"quote":{"pid":"368e00c6b1ac3aab38152bb2fae521f1594b704d","tid":1155523,"uid":64464,"like":0,"dislike":3,"score":-3,"citedBy":2,"replyTime":"2019-05-15T07:28:33.000Z","msg":"邊撚個辛祖"},"citedBy":0,"replyTime":"2019-05-15T09:01:04.000Z","msg":"英仔黎<br />\n踢多蒙特"},{"pid":"416387ec394635a1b6306e45be8f1a5896dd62bd","tid":1155523,"uid":37757,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-15T09:07:32.000Z","msg":"03月13日(三) 20:02<br />\n蘇斯克查下季坐正曼聯帥位已經冇懸念，下一步就係為下季組軍做準備，會方亦全力作出配合，根據英國《獨立報》爆料，曼聯增兵取得重大進展，即將以8000萬鎊(約8.3億港元)簽入多蒙特翼鋒查頓辛祖，並會畀件7號球衣佢。<br />\n<br />\n上月已傳出曼聯想用7000萬鎊收購呢位即將19歲嘅英格蘭新星，但報價未到多蒙特要求，於是決定加碼至8000萬鎊。據悉，曼聯代表團已經接近說服多蒙特放人，而且查頓辛祖亦希望返回祖國搵食。<br />\n<br />\n查頓辛祖今季喺德甲表現一鳴驚人，已有8球進帳，無論係速度、爆炸力、傳球、射門、控制比賽節奏，都屬於德甲球員之中首屈一指，甚至被譽為同法國新星基利安麥巴比同級數，並已經晉身英格蘭大國腳。曼聯對查頓辛祖志在必得，認為佢可以將球隊傳奇7號重新發揚光大。<br />\n<br />\n值得一提，查頓辛祖出身曼城青年軍，如果佢真係加盟曼聯，唔知曼城領隊哥迪奧拿有乜感受呢？"},{"pid":"7007fe7d148d9087ae0f84d643fc8c25fbeaf442","tid":1155523,"uid":186292,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-15T09:09:17.000Z","msg":"<blockquote>　　曼聯賽季收官階段表現糟糕，蘇斯克查（O.Solskj&aelig;r）的執教能力受到了不少質疑。球隊今夏繼續對陣容進行重塑，以支持蘇帥實現他的戰術構想。不過曼聯今夏的收購情況並不樂觀，球隊下季沒有歐聯可踢，加上蘇斯克查沒有出名教頭聲望，想要收購困難重重。<br />\n<br />\n　　BBC記者大衛-奧恩斯坦在節目中透露了曼聯的三大收購目標，分別是高列巴尼（K.Koulibaly），萬比沙卡（A.Wan-Bissaka）和辛祖（J.Sancho）。奧恩斯坦表示，曼聯非常喜歡高列巴尼，而萬比沙卡一直在曼聯的收購雷達上。［red]辛祖加盟的希望則有50%，[/red]要看他自己的決定。<br />\n<br />\n　　按照這位名記的說法，如果辛祖轉會英超，那麼曼聯將會是他的第一選擇，不過辛祖想踢歐聯，而曼聯不穩定的近況也讓他有所顧慮，他希望有個穩定的環境，爭取冠軍。辛祖今夏如果入市，轉會費將超過1億英鎊。<br />\n<br />\n　　無論從技戰術類型還是場上位置上，辛祖都非常符合蘇斯克查的要求。蘇帥快速反擊，曼聯在右翼鋒的位置上一直缺少一個鐵主力，辛祖剛好可以填補這個空缺。不過目前這筆交易的難度很大，曼聯首先要提出一個讓多蒙特難以拒絕的報價來讓他們放人，而蘇斯克查要說服辛祖在沒有歐聯的情況下加盟球隊。</blockquote><br />\n一係去一係唔去<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"aa0dc3570cc9b13d7fc03002dd21bbf0e7563fcf","tid":1155523,"uid":131551,"like":1,"dislike":0,"score":1,"quote":{"pid":"416387ec394635a1b6306e45be8f1a5896dd62bd","tid":1155523,"uid":37757,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-15T09:07:32.000Z","msg":"03月13日(三) 20:02<br />\n蘇斯克查下季坐正曼聯帥位已經冇懸念，下一步就係為下季組軍做準備，會方亦全力作出配合，根據英國《獨立報》爆料，曼聯增兵取得重大進展，即將以8000萬鎊(約8.3億港元)簽入多蒙特翼鋒查頓辛祖，並會畀件7號球衣佢。<br />\n<br />\n上月已傳出曼聯想用7000萬鎊收購呢位即將19歲嘅英格蘭新星，但報價未到多蒙特要求，於是決定加碼至8000萬鎊。據悉，曼聯代表團已經接近說服多蒙特放人，而且查頓辛祖亦希望返回祖國搵食。<br />\n<br />\n查頓辛祖今季喺德甲表現一鳴驚人，已有8球進帳，無論係速度、爆炸力、傳球、射門、控制比賽節奏，都屬於德甲球員之中首屈一指，甚至被譽為同法國新星基利安麥巴比同級數，並已經晉身英格蘭大國腳。曼聯對查頓辛祖志在必得，認為佢可以將球隊傳奇7號重新發揚光大。<br />\n<br />\n值得一提，查頓辛祖出身曼城青年軍，如果佢真係加盟曼聯，唔知曼城領隊哥迪奧拿有乜感受呢？"},"citedBy":1,"replyTime":"2019-05-15T09:16:26.000Z","msg":"03月13日<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n03月13日 個時獌都唔太差<br />\n<br />\n而家確定無歐冠踢  唔好發夢啦<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"8411e52af3d06df643da487736d4fd1985a2a1c3","tid":1155523,"uid":37757,"like":0,"dislike":0,"score":0,"quote":{"pid":"aa0dc3570cc9b13d7fc03002dd21bbf0e7563fcf","tid":1155523,"uid":131551,"like":1,"dislike":0,"score":1,"quote":{"pid":"416387ec394635a1b6306e45be8f1a5896dd62bd","tid":1155523,"uid":37757,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-15T09:07:32.000Z","msg":"03