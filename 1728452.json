絲廢老搞事就過去圍攻聲援手足<br />\n<br />\n11點-12點<br />\n食lunch<br />\n<br />\n12點-4點<br />\n參與各區和你lunch 如果去到中環就盡量揸中環呢個大春袋<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n前線手足行動時戴口罩作背景支援<br />\n做街坊哨提醒手足仼何突發情況<br />\n開遮俾前線手足換衫/行動 <br />\n完場時留意是否所有blackbloc手足都換曬衫同離開先好離場<br />\n<br />\n4點-7點<br />\n留意自己區既tg grp消息 參與各區隨機開花<br />\n同上<br />\n黎明行動好重要 <br />\n希望和理非可以積極參與<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"dab09370a84ae1f0e11fc762984f860cae9f027c","tid":1728452,"uid":253921,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T01:55:47.000Z","msg":"push"},{"pid":"4329024a885451dc3158f04954bac9cc58ecc76d","tid":1728452,"uid":78039,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b1b5f8b0c58ce7de09af399c8676c35c82e0564","tid":1728452,"uid":95138,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-17T01:39:17.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-17T01:56:59.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"413079da1995d850f352f9ae2a3066262627c84a","tid":1728452,"uid":191556,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T01:57:28.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"51c2655a2f7a4f615803879acb7b0aebb92abb62","tid":1728452,"uid":254235,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T01:58:11.000Z","msg":"push"},{"pid":"c4f82eacb43ad2801b53a39193c198250411a7f6","tid":1728452,"uid":270619,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T02:02:15.000Z","msg":"<img src=\"https://na.cx/i/Gn4citE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FGn4citE.jpg&h=ba06b3af&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/Q8sEHcf.jpg\" data-thumbnail-src=\