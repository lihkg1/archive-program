uAghWR75VkZoMWgf8%3D&h=ff21bb81\" data-auto-link target=\"_blank\">https://www.polyu.edu.hk/as/hkdse/admission_figures.pdf</a><br />\n<br />\nSource: <a href=\"https://lihkg.com/thread/438657/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/438657/page/1</a><br />\n<br />\n一個資歷的價值根本就唔應該由佢資歷架構Level幾决定<br />\n<br />\n否則能仁＞all<br />\n<br />\n警察F5升督察，自動QF5＞all"},{"pid":"b85f139b6b5a541390e16174f5ed25c5c3840f54","tid":530392,"uid":51250,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-01-15T17:31:45.000Z","msg":"甘你老母"},{"pid":"f306a1c18ebc6b118b10304e13750704d947b278","tid":530392,"uid":166815,"like":0,"dislike":1,"score":-1,"quote":{"pid":"b85f139b6b5a541390e16174f5ed25c5c3840f54","tid":530392,"uid":51250,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-01-15T17:31:45.000Z","msg":"甘你老母"},"citedBy":1,"replyTime":"2018-01-15T17:41:13.000Z","msg":"警察學院:督察受訓36周即成學士<br />\n<a href=\"http://news.wenweipo.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.wenweipo.com&d=QO%2BpW4VwUfY1%2B8WOlimGx9r9upuAghWR75VkZoMWgf8%3D&h=ceb8707c\" data-auto-link target=\"_blank\">http://news.wenweipo.com</a> [2014-08-09]<br />\n<br />\n【文匯網訊】香港警察學院引入資歷認可的新訓練課程，提升警隊的專業形象。8日，首批在這資歷認可架構下畢業的學警及見習督察進行就職宣誓，正式加入警隊。<br />\n<br />\n據新華網報道，在黃竹坑警察學院舉行的就職宣誓儀式上，207名學警和37名見習督察宣誓承諾維護法紀，確保香港成為世界上其中一個最安全和穩定的社會。<br />\n<br />\n主持宣誓儀式的警務處副處長馬維騄表示，新課程已於6月26日取得香港學術及職業資歷評審局香港資歷架構的認可資格。他指訓練課程艱辛且密集，包括警務知識、實務技巧和正面的價值觀。<br />\n<br />\n據香港警察學院副院長朱明寶總警司介紹，新課程加強學警及見習督察處理遊行示威的訓練，甚至聯同警察機動部隊一同進行演習。<br />\n<br />\n朱明寶指出，在資歷架構下，見習督察經過36星期的訓練，獲頒的警務領導及管理專業文憑，相等於學術評審的學士學位;而學警經過27星期的訓練課程，獲頒的警務專業文憑，則相等於學術評審的副學士及高級文憑。<br />\n<br />\n資歷架構秘書處總經理彭炳鴻說，警察部門是第一個政府部門獲得資歷架構認證舉辦新課程，及後也有計劃將這推廣至其他紀律部隊及政府部門。<br />\n<br />\n<br />\n<a href=\"https://forum.hkgolden.com/view.aspx?type=CA&amp;message=5305041\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforum.hkgolden.com%2Fview.aspx%3Ftype%3DCA%26message%3D5305041&d=QO%2BpW4VwUfY1%2B8WOlimGx9r9upuAghWR75VkZoMWgf8%3D&h=a21d9257\" data-auto-link target=\"_blank\">https://forum.hkgolden.com/view.aspx?type=CA&amp;message=5305041</a>"},{"pid":"74b36ac35bbdab045d0b4a908460165b55883fb5","tid":530392,"uid":36857,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2018-01-15T18:02:00.000Z","msg":"次條撚咩<br />\n有啲Asso仔dse十幾分照升三大<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <br />\n條友仲揸住個垃圾OU degree on99咁喳<br />\n<br />\nTaught Master洗底？發下夢好啦"},{"pid":"89a9fa839133f0e6a1382d703e9bd36380f39287","tid":530392,"uid":37240,"like":11,"dislike":0,"score":11,"citedBy":1,"replyTime":"2018-01-15T18:08:21.000Z","msg":"又無講錯既<br />\nAsso hd升到上大學咪叻<br />\n但升唔返渣住個asso/hd cert或者top up<br />\n咁ou仔真係勁過佢地既<br />\n起碼叫大學<br />\n<br />\n仲講dse分咩，除非你好標青好多星星，否則都係睇個學位架啦"},{"pid":"e6908f47f63668e9a1e2057962a818a0f66dd812","tid":530392,"uid":51250,"like":1,"dislike":0,"score":1,"quote":{"pid":"f306a1c18ebc6b118b10304e13750704d947b278","tid":530392,"uid":166815,"like":0,"dislike":1,"score":-1,"quote":{"pid":"b85f139b6b5a541390e16174f5ed25c5c3840f54","tid":530392,"uid":51250,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-01-15T17:31:45.000Z","msg":"甘你老母"},"citedBy":1,"replyTime":"2018-01-15T17:41:13.000Z","msg":"警察學院:督察受訓36周即成學士<br />\n<a href=\"http://news.wenweipo.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.wenweipo.com&d=QO%2BpW4VwUfY1%2B8WOlimGx9r9upuAghWR75VkZoMWgf8%3D&h=ceb8707c\" data-auto-link target=\"_blank\">http://news.wenweipo.com</a> [2014-08-09]<br />\n<br />\n【文匯網訊】香港警察學院引入資歷認可的新訓練課程，提升警隊的專業形象。8日，首批在這資歷認可架構下畢業的學警及見習督察進行就職宣誓，正式加入警隊。<br />\n<br />\n據新華網報道，在黃竹坑警察學院舉行的就職宣誓儀式上，207名學警和37名見習督察宣誓承諾維護法紀，確保香港成為世界上其中一個最安全和穩定的社會。<br />\n<br />\n主持宣誓儀式的警務處副處長馬維騄表示，新課程已於6月26日取得香港學術及職業資歷評審局香港資歷架構的認可資格。他指訓練課程艱辛且密集，包括警務知識、實務技巧和正面的價值觀。<br />\n<br />\n據香港警察學院副院長朱明寶總警司介紹，新課程加強學警及見習督察處理遊行示威的訓練，甚至聯同警察機動部隊一同進行演習。<br />\n<br />\n朱明寶指出，在資歷架構下，見習督察經過36星期的訓練，獲頒的警務領導及管理專業文憑，相等於學術評審的學士學位;而學警經過27星期的訓練課程，獲頒的警務專業文憑，則相等於學術評審的副學士及高級文憑。<br />\n<br />\n資歷架構秘書處總經理彭炳鴻說，警察部門是第一個政府部門獲得資歷架構認證舉辦新課程，及後也有計劃將這推廣至其他紀律部隊及政府部門。<br />\n<br />\n<br />\n<a href=\"https://forum.hkgolden.com/view.aspx?type=CA&amp;message=5305041\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforum.hkgolden.com%2Fview.aspx%3Ftype%3DCA%26message%3D5305041&d=QO%2BpW4VwUfY1%2B8WOlimGx9r9upuAghWR75VkZoMWgf8%3D&h=a21d9257\" data-auto-link target=\"_blank\">https://forum.hkgolden.com/view.aspx?type=CA&amp;message=5305041</a>"},"citedBy":0,"replyTime":"2018-01-15T18:12:21.000Z","msg":"你做緊乜嘢？"},{"pid":"da44e0583b80a34c40f55df91beb86a6f816ef0e","tid":530392,"uid":166815,"like":0,"dislike":1,"score":-1,"quote":{"pid":"89a9fa839133f0e6a1382d703e9bd36380f39287","tid":530392,"uid":37240,"like":11,"dislike":0,"score":11,"citedBy":1,"replyTime":"2018-01-15T18:08:21.000Z","msg":"又無講錯既<br />\nAsso hd升到上大學咪叻<br />\n但升唔返渣住個asso/hd cert或者top up<br />\n咁ou仔真係勁過佢地既<br />\n起碼叫大學<br />\n<br />\n仲講dse分咩，除非你好標青好多星星，否則都係睇個學位架啦"},"citedBy":1,"replyTime":"2018-01-15T18:15:42.000Z","msg":"勿會升唔倒咩?<br />\n<br />\n大不了OU遙距年滿十七歲補30-60個學分or搵間收生不足的自資院校Top上去。<br />\n<br />\n畢竟，能仁大都係大，QF 5的學士課程嘛<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" />"},{"pid":"40ccee70ca721cfe40626be71e3ac040c018e6ee","tid":530392,"uid":3302,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-15T18:24:24.000Z","msg":"笑撚死<br />\n大家都係垃圾 爭咩呀"},{"pid":"08ce6e74621eb341d427c974b8e6e6b6c4b8a5a8","tid":530392,"uid":37240,"like":0,"dislike":0,"score":0,"quote":{"pid":"da44e0583b80a34c40f55df91beb86a6f816ef0e","tid":530392,"uid":166815,"like":0,"dislike":1,"score":-1,"quote":{"pid":"89a9fa839133f0e6a1382d703e9bd36380f39287","tid":530392,"uid":37240,"like":11,"dislike":0,"score":11,"citedBy":1,"replyTime":"2018-01-15T18:08:21.000Z","msg":"又無講錯既<br />\nAsso hd升到上大學咪叻<br />\n但升唔返渣住個asso/hd cert或者top up<br />\n咁ou仔真係勁過佢地既<br />\n起碼叫大學<br />\n<br />\n仲講dse分咩，除非你好標青好多星星，否則都係睇個學位架啦"},"citedBy":1,"replyTime":"2018-01-15T18:15:42.000Z","msg":"勿會升唔倒咩?<br />\n<br />\n大不了OU遙距年滿十七歲補30-60個學分or搵間收生不足的自資院校Top上去。<br />\n<br />\n畢竟，能仁大都係大，QF