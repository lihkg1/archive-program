s/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-18T11:57:06.000Z","msg":"太慢+自己懶<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />不良生活習慣嘅話，基本上朝朝七點先訓，然後三至四點起身，一日食一餐咁<img src=\"/assets/faces/mouse/smile.gif\" class=\"hkgmoji\" />最近做埋煙鏟"},{"pid":"0e08188f2fb157ff530e127bb8a344b55d294e7a","tid":1885423,"uid":2409,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T12:16:42.000Z","msg":"食益生菌"},{"pid":"ff3eb9aa90a63963f30105a82916471679ca9d6b","tid":1885423,"uid":19437,"like":0,"dislike":0,"score":0,"quote":{"pid":"0e08188f2fb157ff530e127bb8a344b55d294e7a","tid":1885423,"uid":2409,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T12:16:42.000Z","msg":"食益生菌"},"citedBy":2,"replyTime":"2020-02-18T12:23:05.000Z","msg":"X2有無食過益生菌"},{"pid":"9b38a661eb1d6e27e6587d9ebdec2cd7f55d5880","tid":1885423,"uid":98431,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff3eb9aa90a63963f30105a82916471679ca9d6b","tid":1885423,"uid":19437,"like":0,"dislike":0,"score":0,"quote":{"pid":"0e08188f2fb157ff530e127bb8a344b55d294e7a","tid":1885423,"uid":2409,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T12:16:42.000Z","msg":"食益生菌"},"citedBy":2,"replyTime":"2020-02-18T12:23:05.000Z","msg":"X2有無食過益生菌"},"citedBy":1,"replyTime":"2020-02-18T12:29:26.000Z","msg":"加做運動<br />\n<br />\n少食難消化 同會有脹氣既野"},{"pid":"ef72cc41c0b22b66f3202bed1877a6a75662bec5","tid":1885423,"uid":313222,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T12:39:31.000Z","msg":"食少d菜，每餐食8成飽，嚼多幾下嚼碎d先吞，之後做多d運動同飲寶礦力，冇胃口就飲寶礦力<br />\n上年嘔左成個月，都係好多胃氣冇咩胃口咁，睇完西醫食止嘔藥同跟佢教咁做就慢慢好返"},{"pid":"2b7ad916b85b78d2b1fbccc53f3b8daf362e5b15","tid":1885423,"uid":345371,"like":0,"dislike":0,"score":0,"quote":{"pid":"08df1b3a55957075b0455d76546eca422dd2581b","tid":1885423,"uid":164845,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-02-18T11:13:01.000Z","msg":"之前試過睇專科 叫唔好食香口膠eclipse 嗰啲嘢<br />\n話人個胃消化唔到曬駱駝<br />\n食完會勁多胃氣<br />\n<img src=\"/assets/faces/cat/stare.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-18T12:42:33.000Z","msg":"所以我都冇再食香口膠好耐，連飲管都戒緊<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"8481d74c341d459e7f0f1e61a15521d48b38fdb8","tid":1885423,"uid":345371,"like":0,"dislike":0,"score":0,"quote":{"pid":"86f3aa253205ccf1b710500aa47df143bd0be4f8","tid":1885423,"uid":258809,"like":1,"dislike":0,"score":1,"quote":{"pid":"2f3e6b864125d58a88a9178ef585686a86f19b64","tid":1885423,"uid":345371,"like":0,"dislike":0,"score":0,"quote":{"pid":"603371a772bb1059123e38e26cfa9b3bcd10c8cb","tid":1885423,"uid":258809,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T10:23:15.000Z","msg":"我都係腸胃廢既人，以前胃氣脹到腰都企唔直。我西醫睇過好左排都係冇用（始終食西藥真係唔太好）就去左睇中醫，都睇左兩年一星期一次，之後就一個月兩次，講真好左好多。加上本身我濕疹底要用藥都要就住，佢主要話我個人唔夠氣消化唔好，成日叫我十點前好訓，唔好再食垃圾（公仔麵同麥記個啲垃圾）btw有啲容易有胃氣同難消化既野都係唔好食。主要我都建議你睇番中醫，我個中醫要熟人介紹，而且唔收新症，幫你唔到了<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />但中醫都要睇岩唔岩人，唔同人又唔同講法"},"citedBy":2,"replyTime":"2020-02-18T10:29:33.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />我就係因為唔知揾邊個先夾到自己，所以就冇再去睇中醫，我都知要戒口，最近冇再食朱古力都叫好左少少，不過戒口真係好難<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />好多好好食既野都多胃氣<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />涷野刺身個d我係咪呢世都冇機會再食<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-18T11:13:41.000Z","msg":"我明啊 好食既又係垃圾既最易出事<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n食少啲辣野會刺激腸胃，我中醫都睇過兩個，睇左兩年係第三個，所以真係要時間搵，有冇用真係要睇兩三個月就會有明顯改善。明白中醫好貴，我先前睇過啲好貴都冇用，反而我個個一星期藥少少，平既係醫我最岩個個。凍野刺身個啲未搵到醫生之前都少食為妙，但你睇中醫好既真係要keep住睇，我睇個個一星期一次都係follow住，有時身體變化先轉下藥咁。介紹過有啲朋友睇下唔睇又唔食藥就想好真係痴線，搞到醫生好嬲<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />搞到我家下唔敢再介紹（當然佢都唔想收<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />佢覺得好攰）<br />\n但醫生話我唔夠訓食幾多藥都冇用，反而我濕疹個啲佢冇特別叫我介口，佢話身體好自然食得敏感反應都好快消。佢最後講既係：你明知邊啲食完唔舒服就唔好食啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n我食薯仔油份多辣野凍野都好易出事<br />\n特別熱熱一次過飲好多凍野，同食生冷野飲凍飲<br />\n食飯邊食邊飲野我都會出問題<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n唔夠訓=人休息唔到=唔夠氣=胃易易唔舒服<br />\n不過生冷野真係少食為妙，又唔一定乾淨，細個on9成日飲冰水都影響好大<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-18T12:45:25.000Z","msg":"多謝你既意見，我決定專心d去揾個中醫試反幾個月先<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />你講得好岩，我通完頂之後特別吾舒服，夠訓真係好重要。希望大家一齊快d好反<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"4188a58fbe0478455e0a0375cc6534d990eff93b","tid":1885423,"uid":345371,"like":0,"dislike":0,"score":0,"quote":{"pid":"a0240247a5b4e6cd0b111662c774c5da82f14015","tid":1885423,"uid":258809,"like":0,"dislike":0,"score":0,"quote":{"pid":"704058d8f889642e3fe822646d0e7f1ad800430a","tid":1885423,"uid":46752,"like":0,"dislike":0,"score":0,"quote":{"pid":"2f3e6b864125d58a88a9178ef585686a86f19b64","tid":1885423,"uid":345371,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-02-18T10:29:33.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />我就係因為唔知揾邊個先夾到自己，所以就冇再去睇中醫，我都知要戒口，最近冇再食朱古力都叫好左少少，不過戒口真係好難<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />好多好好食既野都多胃氣<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />涷野刺身個d我係咪呢世都冇機會再食<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-18T11:03:41.000Z","msg":"夾唔夾個d理論好垃圾，係勁嘅全部都夾<img src=\"/assets/faces/big/angry.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-02-18T11:16:06.000Z","msg":"我中醫都同我講夾唔夾之論，要病人肯聽醫生講，又要醫生有心去睇<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />我醫生話唔岩既話，比錢我都唔會睇，門口係個邊慢行<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-18T12:46:07.000Z","msg":"個醫生夠直接 好正<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"4fe58d448e3193c1c81125d990c78a39e663c716","tid":1885423,"uid":345371,"like":0,"dislike":0,"score":0,"quote":{"pid":"0040fa19e3576ea9587bef1449cca3358a995d92","tid":1885423,"uid":4379,"like":0,"dislike":0,"score":0,"quote":{"pid":"41e3d9d008d5cafd1442b29d48d75d95b3e7b15b","tid":1885423,"uid":345371,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d8d4579e81f538fd0eb7bde73b577f2c6d39e3a","tid":1885423,"uid":4379,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-02-18T10:19:20.000Z","msg":"無呀，次次都係睇就得一唔睇就唔得，最尾都放棄左<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-18T10:27:10.000Z","msg":"咁點解你唔繼續睇，d人話最緊要配合埋改變生活習慣先改善到，你有冇咩壞既飲食習慣<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-18T11:57:06.000Z","msg":"太慢+自己懶<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />不良生活習慣嘅話，基本上朝朝七點先訓，然後三至四點起身，一日食一餐咁<img src=\"/assets/faces/mouse/smile.gif\" class=\"hkgmoji\" />最近做埋煙鏟"},"citedBy":0,"replyTime":"2020-02-18T12:47:17.000Z","msg":"你咁樣一定吾得啦<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />要快d戒，我覺得自己2 3點先訓已經過份<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"702f0f025c8b72e9d2eef455f08903296d48b806","tid":1885423,"uid":345371,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff3eb9aa90a63963f30105a82916471679ca9d6b","tid":1885423,"uid":19437,"like":0,"dislike":0,"score":0,"quote":{"pid":"0e08188f2fb157ff530e127bb8a344b55d294e7a","tid":1885423,"uid":2409,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-0