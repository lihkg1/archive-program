c=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"2da3c26d496686eb88faf7b01eff0dcc781a53b4","tid":2160842,"uid":134071,"like":0,"dislike":0,"score":0,"quote":{"pid":"8ce2bb8896fcbb5c1d07a02541b24c2388de5a83","tid":2160842,"uid":37802,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-08-17T09:49:27.000Z","msg":"推<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-17T09:50:12.000Z","msg":"填問卷<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"755903ccf81a299e7767759a58428974af2ab7dd","tid":2160842,"uid":47352,"like":0,"dislike":0,"score":0,"quote":{"pid":"c26cf2cc4a3ff7760c563b2bcafc43ac365376b8","tid":2160842,"uid":134071,"like":5,"dislike":0,"score":5,"quote":{"pid":"a105c518d3fad9bd5274c3c38930bc9315036983","tid":2160842,"uid":243188,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-08-17T08:50:18.000Z","msg":"點投票<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-17T08:52:11.000Z","msg":"<em>有別於全港抽樣的特首民望民調，香港民研今次民調屬「我們香港人」計劃下，向意見群組發出問卷。副行政總監鍾劍華向眾新聞解釋，他們在大約10萬人的群組中發放網上問卷，每次大約收回1萬份回覆，雖然不屬於全港性抽樣，但同樣會加權作為參考。他表示，有關做法偏差會較全港性抽樣較大，「所以是一個indicative survey（參考性調查），而不是conclusive survey（決定性調查）」。他表示，同樣意見群組調查方法亦見諸外國選舉及初選，但調查未必直接決定民主派議員的選擇。<br />\n<br />\n<strong>對於部分民主派私下質疑民調方式</strong>，鍾劍華強調，明白民主派面對很大壓力，不想因為民調而騎虎難下，但作為民調機構無法考慮個別派別盤算，正如「特首都未必鐘意我哋特首民望調查，但我哋唔會因此唔做」。</em>"},"citedBy":0,"replyTime":"2020-08-17T09:50:28.000Z","msg":"<a href=\"https://www.pori.hk/wehkers-index\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.pori.hk%2Fwehkers-index&d=F9sYfJh4wRYjdPScc1OpRoL97yTsFD7TFgzLZRxFgWk%3D&h=95a7725e\" target=\"_blank\">https://www.pori.hk/wehkers-index</a>"}],"pinned":{"pid":"34efc5e3d499804a3a668216e8f97c829e11ae28","tid":2160842,"uid":134071,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-08-17T09:38:21.000Z","msg":"問卷網頁<br />\n<a href=\"https://lihkg.com/thread/2160944/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/2160944/page/1</a>"}}