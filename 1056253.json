src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-11T06:51:06.000Z","msg":"係咪呢單<a href=\"http://ca.ntdtv.com/xtr/b5/2018/09/25/a1392878.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fca.ntdtv.com%2Fxtr%2Fb5%2F2018%2F09%2F25%2Fa1392878.html&d=JC%2BoF4fRaZyKvWcl7nla%2FNqeVONt7zbw7GHn8%2FjWPdo%3D&h=b7fead9a\" target=\"_blank\">http://ca.ntdtv.com/xtr/b5/2018/09/25/a1392878.html</a>"},{"pid":"d07dcdb3327a5f2fa436cf56fa6012946f3438d0","tid":1056253,"uid":119478,"like":0,"dislike":0,"score":0,"quote":{"pid":"bba0b04e292e45f2c027ea0b7dcedf82ed492089","tid":1056253,"uid":130575,"like":1,"dislike":0,"score":1,"quote":{"pid":"90265da9a37a6ca09396febe56d743ebc6a2b68f","tid":1056253,"uid":119478,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-03-11T05:32:46.000Z","msg":"我想睇返受害者掉返轉賣個拐子婆去做雞單新聞<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-11T06:51:06.000Z","msg":"係咪呢單<a href=\"http://ca.ntdtv.com/xtr/b5/2018/09/25/a1392878.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fca.ntdtv.com%2Fxtr%2Fb5%2F2018%2F09%2F25%2Fa1392878.html&d=JC%2BoF4fRaZyKvWcl7nla%2FNqeVONt7zbw7GHn8%2FjWPdo%3D&h=b7fead9a\" target=\"_blank\">http://ca.ntdtv.com/xtr/b5/2018/09/25/a1392878.html</a>"},"citedBy":1,"replyTime":"2019-03-11T07:02:53.000Z","msg":"係 呢單痴鳩線 求其係街都撞到拐子佬<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"037f2f82d55531bf61113088a359e29ba27e0dad","tid":1056253,"uid":177778,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-03-11T07:30:24.000Z","msg":"上得大陸 人地衡量過風險架啦 洗你操心咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"06f9f44b705eb9c1ee755db7ac55c820c8750b5b","tid":1056253,"uid":9053,"like":0,"dislike":0,"score":0,"quote":{"pid":"d07dcdb3327a5f2fa436cf56fa6012946f3438d0","tid":1056253,"uid":119478,"like":0,"dislike":0,"score":0,"quote":{"pid":"bba0b04e292e45f2c027ea0b7dcedf82ed492089","tid":1056253,"uid":130575,"like":1,"dislike":0,"score":1,"quote":{"pid":"90265da9a37a6ca09396febe56d743ebc6a2b68f","tid":1056253,"uid":119478,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-03-11T05:32:46.000Z","msg":"我想睇返受害者掉返轉賣個拐子婆去做雞單新聞<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-11T06:51:06.000Z","msg":"係咪呢單<a href=\"http://ca.ntdtv.com/xtr/b5/2018/09/25/a1392878.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fca.ntdtv.com%2Fxtr%2Fb5%2F2018%2F09%2F25%2Fa1392878.html&d=JC%2BoF4fRaZyKvWcl7nla%2FNqeVONt7zbw7GHn8%2FjWPdo%3D&h=b7fead9a\" target=\"_blank\">http://ca.ntdtv.com/xtr/b5/2018/09/25/a1392878.html</a>"},"citedBy":1,"replyTime":"2019-03-11T07:02:53.000Z","msg":"係 呢單痴鳩線 求其係街都撞到拐子佬<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-11T08:13:51.000Z","msg":"所有角色身份都拐子佬<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"0b6e523fdd511f209bce3221994083aaadf50c62","tid":1056253,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-11T08:22:11.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}