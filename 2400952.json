oNMEkSG0DzaVerHR9pE4rwCb4%3D&h=787d4577\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.reuters.com%2Farticle%2Fus-usa-fed-mester-idUSKBN2A823E&h=37cb50a3\" data-auto-link target=\"_blank\">https://www.reuters.com/article/us-usa-fed-mester-idUSKBN2A823E</a><br />\n<br />\n<br />\n有排玩😅😅😅<br />\n<br />\n<img src=\"https://na.cx/i/MSihz6p.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FMSihz6p.png&h=25dc7cae&s={SIZE}\" />"},{"pid":"b545e63902eb142c383a96905177ddaf7a02b943","tid":2400952,"uid":297835,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-09T18:36:57.000Z","msg":"啲人成日好幾年就一個cycle根本鳩up<br />\n之前又話tech 會收皮買value<br />\n又話gold係時候爆升<br />\n又話美股有cycle 係時候入發展中國家股"},{"pid":"ea7354d855645b92215fa6630955ca7e457ba85f","tid":2400952,"uid":8113,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-09T19:00:45.000Z","msg":"停止印錢時你就要小心 <img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" />"}]}