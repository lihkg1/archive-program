6fc002c3959c67e7b71d","tid":1725253,"uid":130228,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T16:48:10.000Z","msg":"<img src=\"https://na.cx/i/nrm2uDZ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fnrm2uDZ.jpg&h=5953cb5c&s={SIZE}\" />"},{"pid":"25b3ee4c5476494964f9c3dfb91e504b2016596a","tid":1725253,"uid":238532,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T16:49:11.000Z","msg":"推"},{"pid":"15745a9f0ea10fb328228a0b6f264d2dfa8ef4e8","tid":1725253,"uid":312114,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-15T16:50:59.000Z","msg":"點可以唔提浪費物資呢點? 大量物資滯棄在內，未用過的豬嘴隨處可見，絕對絕對可以改善。"},{"pid":"0f4897e87ae3fcd0e948554b46d5994bafb4dd2f","tid":1725253,"uid":185056,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T16:52:34.000Z","msg":"不割蓆 不分化"},{"pid":"0068886eda0079b59f8abd9b149b297bd0ceca7d","tid":1725253,"uid":259618,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T16:59:18.000Z","msg":"五大訴求 缺一不可<br />\n光復香港 時代革命"},{"pid":"8a239545168430d7867b7c05efac99356ba0dafc","tid":1725253,"uid":251397,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T17:01:23.000Z","msg":"各位中大生，唔知幫唔到大家<br />\n<br />\n呢條片係一位科學教授講述催淚彈嘅嚴重性<br />\n<br />\n中大釋放左咁多催淚彈，環境已經係極度污染<br />\n<br />\n有些同學睡在運動場，很危險，因為就算沒有味道，有毒化學物質在空氣裏充斥着，快則可以見到皮膚紅腫，慢則幾十年後出現癌症。<br />\n<br />\n我在此擔心各位中大人的安危，請大家考慮撤離或不撤離。 <br />\n<br />\n催淚彈害人不淺，禍及環境，禍及下一代！<br />\n<br />\n<a href=\"https://www.facebook.com/179179469403545/posts/453229281998561?vh=e&amp;d=n&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F179179469403545%2Fposts%2F453229281998561%3Fvh%3De%26d%3Dn%26sfns%3Dmo&d=1ryX%2BwltUSTIgmnFzyWg%2BNqeVONt7zbw7GHn8%2FjWPdo%3D&h=210836d5\" data-auto-link target=\"_blank\">https://www.facebook.com/179179469403545/posts/453229281998561?vh=e&amp;d=n&amp;sfns=mo</a>"},{"pid":"c3b3aa2f46027e941068e902a760f9d3bf0d83b1","tid":1725253,"uid":35420,"like":0,"dislike":0,"score":0,"quote":{"pid":"654b34d30911e8874abc66fa541076eaf7a484a6","tid":1725253,"uid":2864,"like":0,"dislike":0,"score":0,"quote":{"pid":"b8f03f85e59779a0177eb299990fccaff75234b5","tid":1725253,"uid":214261,"like":1,"dislike":0,"score":1,"quote":{"pid":"56c8e3b5413c8d4d1006de8a035c6a6fdfb799e0","tid":1725253,"uid":2864,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-15T16:42:07.000Z","msg":"啱 <br />\n停止互屌同分化"},"citedBy":2,"replyTime":"2019-11-15T16:44:09.000Z","msg":"有固定地點就會開始互屌同分化<br />\n所以唔好有固定地點<br />\nBe water 唔止係口號"},"citedBy":1,"replyTime":"2019-11-15T16:45:16.000Z","msg":"不割蓆都唔止口號<br />\n有互屌嘅人反省下<br />\n對住手足洗唔洗下下都起晒鋼"},"citedBy":0,"replyTime":"2019-11-15T17:03:50.000Z","msg":"就係你呢班乜柒都話不割不分化既人<br />\n先令到中大 可以比到班mk為所欲為"},{"pid":"05598b9fd914522d03441e8382e98b0813fa1e0f","tid":1725253,"uid":31320,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T17:06:08.000Z","msg":"林鄭最驚全民天光開花，最希望示威者夜晚集中一點打陣地<br />\n<a href=\"https://lih.kg/1724972\" data-auto-link target=\"_blank\">https://lih.kg/1724972</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"c63f5f2bba027274ccf078f1388dfb05dc19454b","tid":1725253,"uid":214261,"like":0,"dislike":0,"score":0,"quote":{"pid":"15745a9f0ea10fb328228a0b6f264d2dfa8ef4e8","tid":1725253,"uid":312114,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-15T16:50:59.000Z","msg":"點可以唔提浪費物資呢點? 大量物資滯棄在內，未用過的豬嘴隨處可見，絕對絕對可以改善。"},"citedBy":1,"replyTime":"2019-11-15T17:31:32.000Z","msg":"依家物資其實係咪無撤走"},{"pid":"9e5cc5dd7085a62f03ffbc7fc09b75f7e9a189a1","tid":1725253,"uid":258696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T17:34:31.000Z","msg":"推唔郁"},{"pid":"dd2e194182a75762c73e817e2031edcc5c5e7446","tid":1725253,"uid":312114,"like":0,"dislike":0,"score":0,"quote":{"pid":"c63f5f2bba027274ccf078f1388dfb05dc19454b","tid":1725253,"uid":214261,"like":0,"dislike":0,"score":0,"quote":{"pid":"15745a9f0ea10fb328228a0b6f264d2dfa8ef4e8","tid":1725253,"uid":312114,"like":0,"dislike":0,"score":0,"citedBy":1,"r