a0bac0585f221952997d16d0d66d49ab2dc5b1b","tid":1416153,"uid":264626,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-05T15:52:59.000Z","msg":"好燃催淚，thx"},"citedBy":1,"replyTime":"2019-08-05T15:56:12.000Z","msg":"唔駛客氣<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n我哋唔可以放棄心裡面嘅呢團火<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n呢個政府已經爛到入骨<br />\n一定要將整個制度改變，香港先有未來"},"citedBy":1,"replyTime":"2019-08-05T15:57:58.000Z","msg":"希望依家就已經係黎明前最黑暗既時候，真係唔知再黑會點 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-05T15:58:45.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />希望快手啲出老解"},{"pid":"bb2e5cb0987bd8020983bd0d027e064aa478b32f","tid":1416153,"uid":147248,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T16:00:47.000Z","msg":"光復香港"},{"pid":"1aaa4f9b24af8ea14ad9ec090eb09b8544cbe5a7","tid":1416153,"uid":266706,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-08-05T16:14:09.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"28fb02ef48461cd9cf8bd53ad2e8dc84d611370f","tid":1416153,"uid":54125,"like":1,"dislike":0,"score":1,"quote":{"pid":"1aaa4f9b24af8ea14ad9ec090eb09b8544cbe5a7","tid":1416153,"uid":266706,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-08-05T16:14:09.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-05T16:27:58.000Z","msg":"無錯<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n無人知邊隻藥啱<br />\n前後左右都唔俾行<br />\n咁仲點樣救香港<br />\n唔通真係等被打懵仔針咩<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n我哋比新疆有優勢，就係中共無咗香港個殼唔得，所有一直想趕走香港人<br />\n<br />\n我哋連自己都唔肯企出嚟叫自己做香港人<br />\n咁仲有邊個可以救我哋<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n嗰啲叫人唔好嗌口號嘅理由係外國唔會幫<br />\n<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />人哋外國都一直出緊呢句口號啦<br />\n美國而家咪加中國關稅，定佢為貨幣操控國囉<br />\n國會咪提出緊香港人權法囉<br />\n仲咩講到外國會割蓆啫<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n慘在好多人信啊<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n我哋唔可以自己消滅自己嘅信念<br />\n香港時日無多架喇<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n而家一句嘢都接受唔到<br />\n以後就乜都唔駛旨意講<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"6d45d3b671fb9053f256bc163dece6b1fdda9392","tid":1416153,"uid":54125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T16:28:53.000Z","msg":"推"},{"pid":"eafbb900851eaa29bc2d012fdb61a7ee1ebe5671","tid":1416153,"uid":54125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T16:29:17.000Z","msg":"推"},{"pid":"426102aadac9d906ae353e6310011ac20106aff3","tid":1416153,"uid":54125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T16:30:25.000Z","msg":"推"}]}