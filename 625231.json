om/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20150813%2F19253597&d=9Q56bAYsZhWDnGmmLrhNDi7bS0i5kAixZS1hjGmvpwM%3D&h=52c7faee\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20150813%2F19253597&h=5de9b69a\" target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20150813/19253597</a>"}]}