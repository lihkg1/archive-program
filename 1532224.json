8ca92fc0d6f473046de405c5d8","tid":1532224,"uid":130168,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T04:40:58.000Z","msg":"831"},{"pid":"866de02cc261f3d114f71df690d94e0883c0b205","tid":1532224,"uid":289649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T04:43:05.000Z","msg":"明白大家呢排嘅士氣經過<span style=\"font-size: xx-large;\"><span style=\"color: red;\">831恐襲</span></span>同<span style=\"font-size: xx-large;\"><span style=\"color: blue;\">901大撤退</span></span>之後好低落<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><br />\n我同大家一樣都係<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n但越係呢啲時候<br />\n<span style=\"font-size: x-large;\">我地就越要堅持下去，<span style=\"color: limegreen;\">團結一致</span></span><br />\n唔好比林鄭見我地冇士氣而去捉多啲人<br />\n<br />\n以下兩篇文章<span style=\"font-size: x-large;\">無論<span style=\"color: gold;\">和理非</span>，定係<span style=\"color: red;\">勇武</span>，都應該入黎，打返枝<span style=\"color: violet;\">強心針</span></span><br />\n<br />\n希望可以幫到大家<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><br />\n記得share比身邊因近日事件而唔開心嘅朋友仔<img src=\"/assets/faces/dog/on_hold.gif\" class=\"hkgmoji\" /><br />\n<br />\n［全部人同我入黎］《致眾表》望各位香港市民出自己的一份綿力<br />\n<a href=\"https://lih.kg/1532967\" data-auto-link target=\"_blank\">https://lih.kg/1532967</a><br />\n<br />\n灰心喪志，是因為你看不見抗爭的前路<br />\n<a href=\"https://lih.kg/1533741\" data-auto-link target=\"_blank\">https://lih.kg/1533741</a>"},{"pid":"46bae6c9fac6b689269af6b8a2c1fc9efc965b6c","tid":1532224,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T04:46:58.000Z","msg":"推"},{"pid":"6ffe29b7af6a5376df2713cb51a43564f1f1cc9a","tid":1532224,"uid":52566,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-03T04:48:21.000Z","msg":"<div style=\"text-align: center;\"><strong>9月7日 (六) 1PM<br />\n機場交通壓力測試 (重考)</strong></div><br />\n<br />\n香港市民：<br />\n✅ 以遊客身份入機場觀賞飛機升降 <br />\n<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><br />\n<br />\n✅ 唔識路就坐多幾轉車 <br />\n<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><br />\n<br />\n✅ 必需繳付車資乘坐黨鐵<br />\n<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n其他國藉居民：<br />\n各有各做, 自由發揮 <br />\n<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/nyixFQQ.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnyixFQQ.png&h=cc1f24a6&s={SIZE}\" /><br />\n<br />\n<br />\n<div style=\"text-align: center;\"><strong>9月8日 (日) 2PM<br />\n香港人權與民主法案集會<br />\n美國駐港澳總領事館</strong></div><br />\n<img src=\"https://na.cx/i/2GKH20p.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F2GKH20p.png&h=6178433f&s={SIZE}\" />"},{"pid":"4e6ab60b05263385cc1a4fc6b0b11c486ea13ac0","tid":1532224,"uid":278723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T04:50:52.000Z","msg":"D100 節目有聽眾phone in <br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=arZXhRcfEKw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DarZXhRcfEKw&d=aS0Zid%2FrEVnhaHfkh5i1av8K46P7%2BXxs1F7ZCKkfkQw%3D&h=1855ec79\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=arZXhRcfEKw</a><br />\n<br />\n<br />\n可以skip去4分鐘開始<br />\n<br />\n有講到點解有班藍C在車<br />\n封站原因係班黑警上錯車打錯人所以要毀屍滅跡⋯⋯<br />\n自己慢慢聽"},{"pid":"980ad71426f522e6334ebc8675df098d7d8c63e4","tid":1532224,"uid":83336,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T04:58:22.000Z","msg":"黑警 落地獄"},{"pid":"d2fa568cd9a6b6ca2199fba61ff3d1ea965c4418","tid":1532224,"uid":53379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T05:00:55.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" c