c100150f584880d","tid":650773,"uid":96218,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-13T13:58:03.000Z","msg":"留名 畫畫人想試嚟攞靈感<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a32c0455373f0956a192cbe66e735a58692d2510","tid":650773,"uid":129660,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-13T14:11:37.000Z","msg":"有種變得好脆弱既感覺"},{"pid":"7c41be5d5e24a7ca70073310a8505112b092af8b","tid":650773,"uid":71441,"like":0,"dislike":0,"score":0,"quote":{"pid":"293999219f522ad98200fc5381161bee152b7669","tid":650773,"uid":84432,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-03T13:43:19.000Z","msg":"聽歌直情入左首歌到<br />\n正到仆街"},"citedBy":1,"replyTime":"2018-05-13T14:51:05.000Z","msg":"隊band 好似特登為你唱咁"},{"pid":"8e5cde5f231efd66155a21a6d7bebdfdd914d34e","tid":650773,"uid":84432,"like":0,"dislike":0,"score":0,"quote":{"pid":"7c41be5d5e24a7ca70073310a8505112b092af8b","tid":650773,"uid":71441,"like":0,"dislike":0,"score":0,"quote":{"pid":"293999219f522ad98200fc5381161bee152b7669","tid":650773,"uid":84432,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-03T13:43:19.000Z","msg":"聽歌直情入左首歌到<br />\n正到仆街"},"citedBy":1,"replyTime":"2018-05-13T14:51:05.000Z","msg":"隊band 好似特登為你唱咁"},"citedBy":0,"replyTime":"2018-05-13T14:58:22.000Z","msg":"聽迷幻band真係上左太空 直頭有失重feel"},{"pid":"79f55e35b8eb2077f9ce6730f37335b2b16b629d","tid":650773,"uid":14715,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-14T14:13:22.000Z","msg":"食完睇 dr strange <img src=\"/assets/faces/lomoji/11.png\" class=\"hkgmoji\" />"},{"pid":"56964fb00214abb48859191e4a644780d34ebc4f","tid":650773,"uid":71019,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-14T14:15:36.000Z","msg":"真心 上次食完做philo功課a咗"},{"pid":"2ea89a92e96063634b3917ef0d0cb7d3c5d1e6e8","tid":650773,"uid":14715,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-14T14:18:28.000Z","msg":"good trip 天人合一<br />\nbad trip 比黑洞吸入去咁款<img src=\"/assets/faces/normal/de