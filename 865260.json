faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7e25525b79195e903135ebd1b36d214eea5bfad0","tid":865260,"uid":165683,"like":1,"dislike":0,"score":1,"quote":{"pid":"08786844c4aa669401b979a2462ae4afb461fed4","tid":865260,"uid":11323,"like":0,"dislike":0,"score":0,"quote":{"pid":"b8608525e9fbe6617a23efd9cfc45a67306e6213","tid":865260,"uid":78512,"like":0,"dislike":0,"score":0,"quote":{"pid":"f059be20f02fcd75ceb17a7ae83e6f8736c3d09b","tid":865260,"uid":56969,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-19T04:35:55.000Z","msg":"想問下巴打覺得未來m&amp;a嘅trend會係點?"},"citedBy":1,"replyTime":"2018-10-19T04:47:49.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-10-19T21:15:45.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-19T22:47:24.000Z","msg":"<a href=\"http://www2.hkej.com/instantnews/china/article/1970283\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww2.hkej.com%2Finstantnews%2Fchina%2Farticle%2F1970283&d=UvGwKXXtoiGJJSbm9hgHqL%2BnoHux5cIPnxEj5ZZbdh4%3D&h=db18b794\" data-auto-link target=\"_blank\">http://www2.hkej.com/instantnews/china/article/1970283</a><br />\n<br />\n內地嚴控敏感行業海外併購，房地產為重災區，隨着貿易戰升溫，美國海外投資委員會(CFIUS)亦加強審核海外資金收購美國資產交易。<br />\n<br />\n普衡律師事務所合夥人管榮表示，內地的資本管制未有放鬆跡象，除非以「一帶一路」旗號投資，而內地資金的收購目的地，亦從美國轉至東南亞、歐洲等地。<br />\n<br />\n該行另一名合夥人Derek Roth表示，愈來愈多美國賣家憂慮與中國買家交易，會因為審批時間延長，甚至資金不獲允許出境而增加不確定性，甚至有買家因此選擇出價較低者，只為避開中國對手方。至於中國買家，亦傾向不再追求極受注目的大刁(Trophy deals)，而轉向作較小型的戰略性投資。<br />\n<br />\n即使中國收購減少，美國併購的交易作價亦獲其他海外買家承接。普衡律師事務所全球地產業務前主席Philip Feder指出，日本政府退休金投資公司(GPIF)及挪威、南韓等地的機構投資者，正積極參與美國物業市場「填補空隙」"},{"pid":"8f03170e1f7b6438a9b737a8df33983d079d47b7","tid":865260,"uid":11323,"like":0,"dislike":0,"score":0,"quote":{"pid":"4ef62b9b83822b4bef1ed5b70c050edb9e22e4ab","tid":865260,"uid":165683,"like":0,"dislike":0,"score":0,"quote":{"pid":"08786844c4aa669401b979a2462ae4afb461fed4","tid":865260,"uid":11323,"like":0,"dislike":0,"scor