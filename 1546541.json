rc=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/xQ6rr7H.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxQ6rr7H.gif&h=2e882f27&s={SIZE}\" /><br />\n<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/ch4X7sO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fch4X7sO.jpg&h=971c9013&s={SIZE}\" />"},{"pid":"48aaaa906e91d045f79033126c3028750a03d70c","tid":1546541,"uid":215501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:32:01.000Z","msg":"又可以入去瘋狂遊S線<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},{"pid":"3a0d8bea3cfafd69b51400d11984ada395df89bc","tid":1546541,"uid":49847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:32:36.000Z","msg":"Push"},{"pid":"7b6ecaa81f5d1ff4f8a3b131fc4479cd81c81e1e","tid":1546541,"uid":34468,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:32:37.000Z","msg":"<span style=\"font-size: x-large;\"><span style=\"color: red;\">街坊裝去行街</span></span><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},{"pid":"b902823bc18dbf9c10767fb64c3f720e8b79f16d","tid":1546541,"uid":35266,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:34:23.000Z","msg":"入去做乜鳩<br />\n塞香港站咪成條癱瘓<br />\n到時車路都會自然塞死埋"},{"pid":"0ca8e04aff1b5bfdbd6bc5b768899546967496ac","tid":1546541,"uid":160147,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:34:44.000Z","msg":"上次碼頭抄左牌嘅手足<br />\n今次冇野驚啦"},{"pid":"7dadc33730a08324e84a05a830092b76e2c5fe5f","tid":1546541,"uid":42215,"like":0,"dislike":0,"score":0,"quote":{"pid":"525beb1c6a50df04ebc66dfb543ab06aaa2e100d","tid":1546541,"uid":51271,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-06T10:17:46.000Z","msg":"同埋係往機場方向只可以由香港站上車，應該有狗狗會駐重兵喺香港站"},"citedBy":0,"replyTime":"2019-09-06T10:36:52.000Z","msg":"又無話去香港站一定要搭機鐵既<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},{"pid":"c17961b7b99a21f3edb5018770ebaa8202a6d832","tid":1546541,"uid":28951,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:37:03.000Z","msg":"各位關注民主自由的朋友：<br />\n<br />\n我們是一群來自香港的示威者。<br />\n由六月初至今，反對[送中惡法]抗爭開始至今，已踏入第三個月。<br />\n過百萬位香港人多次以和平、理性、非暴力方式向政府表達我們的五個訴求。<br />\n更有7名義士的不惜犧牲自己，以死相諫，試圖喚醒當權者僅餘的良知。<br />\n可惜，在中國共產黨全面控制下的香港區政府堅拒回應市民的訴求，更借助香港警察的軍事力量，歪曲事實的假消息，無形的白色恐怖，意圖消滅所有示威者。<br />\n<br />\n我們在此向獨裁政權表明，如此卑劣性之手段絕對無法令香港人退縮或認輸，直至答應廣大市民的五個訴求。<br />\n<br />\n一、徹底撤回逃犯條例修訂<br />\n二、收回至今所有反送中抗爭之暴動定性<br />\n三、撤銷所有反送中抗爭者之控罪 <br />\n四、成立獨立調查委員會，徹底追究警察濫暴<br />\n五、以行政命令解散立法會，立即實行真正的雙普選<br />\n<br />\n香港當前面對的已經不只[送中惡法]的政治問題。<br />\n<br />\n執法：<br />\n721元朗事件，831太子事件，刻意暴力攻擊示威者，濫捕。<br />\n警權之大，前所未見，己達至軍政府統治下的戒嚴狀態。<br />\n<br />\n司法：<br />\n為達到中共維穩目標，公然遣背法律公平公正的原則。<br />\n不斷政治檢控示威者/區議員/立法會議員。<br />\n<br />\n行政：<br />\n放仼警方使用過份武力，更加直接表明支持。<br />\n散播白色恐怖，打壓一齊反對聲音。<br />\n<br />\n人道：<br />\n凌辱及暴力對待被捕人未，包括性暴力。<br />\n故意攻擊救援人員，阻止救援人員為傷者進行急救。<br />\n<br />\n中共勢力已全面入侵香港，徹底違反《中英聯合聲明》所承諾的一國兩制。<br />\n解決當前的政治問題已不能令千瘡百孔的香港重回正軌，我們必須重新建設整個政府體制，實現民選政府。<br />\n<br />\n為對抗如此醜惡的政權，香港人經歷了無數血與汗的洗禮，然而面前的高牆已非我們可以獨自打破。<br />\n所以，我們在在呼籲各支持民主自由的國家/組織/市民積極介入，以不同的方式協助香港對抗極權國家，或制裁支持極權的人士。<br />\n<br />\n包括：<br />\n凍結個別人士在國外的資產，以經濟方式懲罰<br />\n禁止個別人士及其親屬入境，以外交方式懲罪<br />\n派員協助香港人籌組新民選政府<br />\n給予政治庇護/公民身份<br />\n<br />\n不自由，毋寧死。香港人定必採取一切可行手段，使香港邁進成為民主、自由、公義的社會。<br />\n<span style=\"color: red;\"><span style=\"font-size: medium;\">以上參考過往的宣言</span></span><br />\n<br />\n<span style=\"font-size: large;\">唔知有冇用，但我覺得要向外國講出我地嘅要求同現況，有冇可能係星期日試吓？</span>"},{"pid":"287e76b198fb5fcd035393013918e0fe0ff3f720","tid":1546541,"uid":103095,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-06T10:37:23.000Z","msg":"即係啲狗入曬博覽館站<br />\n有咩事就用機鐵運兵"},{"pid":"5d1432f1356b63a83083590a18e84ad3c5e1b3a4","tid":1546541,"uid":263778,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T10:38:09.000Z","msg":"五個站嘅線停左四個站<br />\n剩返一個即係點<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"5901710bc755ab036a4a268ceeafc24badeab70e","tid":1546541,"uid":214502,"like":0,"dislike":0,"score":0,"quote":{"pid":"e4cd4431251d3a400960b1672186da02144896ff","tid":1546541,"uid":33418,"like":0,"dislike":0,"score":0,"quote":{"pid":"f3278e338e3a2fc8cf075e20ba6bd5f33c04ce5c","tid":1546541,"uid":214502,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-06T10:27:00.000Z","msg":"馬路塞左咪仆街?<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-06T10:27:58.000Z","msg":"上次葵涌a32入去都差唔多塞咗兩粒鐘<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-06T10:38:15.000Z","msg":"塞車坐坐下要CALL白車咪更仆街??<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"aa14f0cd9867a32ab27accf4df03e8e90daac063","tid":1546541,"uid":25183,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-06T10:38:17.000Z","msg":"得返港島至機場特急<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><br />\n九龍人就要塞巴士<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"fab7c31a9492ea5ca5ea0a0d98ada31aa051d176","tid":1546541,"uid":33418,"like":2,"dislike":0,"score":2,"quote":{"pid":"aa14f0cd9867a32ab27accf4df03e8e90daac063","tid":1546541,"uid":25183,"like":0,"dislike":0,"score