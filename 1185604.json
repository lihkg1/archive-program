://ppt.cc/f3EiAx\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fppt.cc%2Ff3EiAx&d=nhC78NoCA6QB0w8lKR9CgnhUmc0vP2awQoWdJLgJf%2FY%3D&h=e8d02ba3\" data-auto-link target=\"_blank\">https://ppt.cc/f3EiAx</a>"},{"pid":"f3ae2c0edc729391b20d1bcc30d808e675bd366a","tid":1185604,"uid":142348,"like":1,"dislike":4,"score":-3,"quote":{"pid":"080c476e2ddefc53437b474416e97a2759f8a0cd","tid":1185604,"uid":142348,"like":12,"dislike":16,"score":-4,"citedBy":1,"replyTime":"2019-06-04T11:01:35.000Z","msg":"這是我們這代人的職責"},"citedBy":0,"replyTime":"2019-06-04T11:27:51.000Z","msg":"每一個香港人嘅職責。"},{"pid":"1956bb942e9a2cad170c49fa5f5c826ef7bbf329","tid":1185604,"uid":142348,"like":1,"dislike":3,"score":-2,"quote":{"pid":"75954722491351108912819c8fd396604ea16c27","tid":1185604,"uid":137789,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-06-04T11:26:32.000Z","msg":"<a href=\"https://m.facebook.com/story.php?story_fbid=10155866796676065&amp;id=46251501064\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2Fstory.php%3Fstory_fbid%3D10155866796676065%26id%3D46251501064&d=nhC78NoCA6QB0w8lKR9CgnhUmc0vP2awQoWdJLgJf%2FY%3D&h=02a19557\" data-auto-link target=\"_blank\">https://m.facebook.com/story.php?story_fbid=10155866796676065&amp;id=46251501064</a><br />\n<br />\n一個國家文明與否，端視於政府怎麼對待人民、怎麼對待過去的錯誤。<br />\n　　<br />\n今年是「六四」三十週年，全世界的焦點，都在關注當年天安門前，上千名青年喪失寶貴生命的真相，以及現在中國對香港自由的侵蝕。<br />\n　　<br />\n幾天前，前往香港參與六四紀念活動的當年學運領袖封從德先生，在機場遭到遣返。中國的國防部長，更向國際社會大肆宣稱鎮壓和屠殺無辜人民是正確決定。這都顯示出，中國政府不僅沒有打算反省當年的錯誤，還想繼續遮掩真相。我相信全世界追求自由民主的人們，都不可能同意這樣的做法。<br />\n　　<br />\n還有許許多多自由倒退的例子，證明了「一國兩制」下的香港，「一國」正不斷侵蝕「兩制」。這個現象，也凸顯了民主和威權兩種制度，並不可能共存在一個國家內部。<br />\n　　<br />\n今年六四，我要特別對所有愛好自由的香港朋友、中國朋友說一句加油。也請你們放心，台灣絕對會守住民主、守住自由，無論威脅、滲透，只要我當一天總統，台灣絕對不會在壓力下屈服。<br />\n　　<br />\n謝謝 爵爵&amp;貓叔的畫，完整版在這邊：<a href=\"https://ppt.cc/f3EiAx\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fppt.cc%2Ff3EiAx&d=nhC78NoCA6QB0w8lKR9CgnhUmc0vP2awQoWdJLgJf%2FY%3D&h=e8d02ba3\" data-auto-link target=\"_blank\">https://ppt.c