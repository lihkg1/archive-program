"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"057566cf4744ee2ceeedae9d3e6a793b79df156b","tid":376784,"uid":28412,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-27T11:20:51.000Z","msg":"<blockquote>原來一田$11.9 <br />\n我死次買$14.x</blockquote><br />\n<br />\n邊到買貴咁多<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"a44e6129f559291a14318ffe46af3e1084cd32a7","tid":376784,"uid":120386,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-27T14:00:04.000Z","msg":"<blockquote><blockquote>原來一田$11.9 <br />\n我死次買$14.x</blockquote><br />\n<br />\n邊到買貴咁多<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n巴打可唔可以share 小王子wallpaper ??<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"}]}