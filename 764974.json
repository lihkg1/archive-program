g.eservice-hk.net%2Fupload%2F2018%2F08%2F07%2F103940_e73202f4db8580f1ab95ef992bcfeec4.png&h=1b60e667&s={SIZE}\" /><br />\n早幾日去"},{"pid":"ac2087c6ce2144f0feed458ff6263c783216a668","tid":764974,"uid":8478,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-07T02:42:03.000Z","msg":"二戰時期攞嚟實驗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"441500bffbd41222854e569a3fdab3636603ddf7","tid":764974,"uid":197098,"like":1,"dislike":0,"score":1,"quote":{"pid":"16d5234c86ee97b3ba33f5a5b1c54263fa83731a","tid":764974,"uid":130225,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-08-07T02:36:31.000Z","msg":"<img src=\"https://www.rabbitsonline.net/proxy.php?image=http%3A%2F%2Fwww.therabbithouse.com%2Fbehaviour%2Fimages%2Feardirection.gif&amp;hash=688b90f1ad88900e8c7520d216f6cb83\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rabbitsonline.net%2Fproxy.php%3Fimage%3Dhttp%253A%252F%252Fwww.therabbithouse.com%252Fbehaviour%252Fimages%252Feardirection.gif%26hash%3D688b90f1ad88900e8c7520d216f6cb83&h=e8ca53ce&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-08-07T02:42:58.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<span style=\"font-size: large;\">兔子驚慌的時候，耳朵會平放在後面、耳口向側、坐姿蹲下(除了你撫摸他牠們的時候或牠們正在睡覺, 所以要看當時的情況來判斷)。一個舒適的兔仔會躺下、手腳伸展出來。以下圖片可以看到兔子驚慌：</span><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/07/104255_83b5009e040969ee7b60362ad7426573.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F07%2F104255_83b5009e040969ee7b60362ad7426573.jpeg&h=9d479dee&s={SIZE}\" />"},{"pid":"dc31ca286c64be5dd72d90309dc3af75d7706431","tid":764974,"uid":197098,"like":1,"dislike":0,"score":1,"quote":{"pid":"cd9ef0f2f617054221f0425a3a1f15c92eb9f03e","tid":764974,"uid":28920,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-07T02:40:11.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/07/103938_5aa27be4c4c1495e88be755f051db201.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F07%2F103938_5aa27be4c4c1495e88be755f051db201.png&h=8abd0725&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/08/07/103938_f922a7458eeb6d981c6478e06c4ae070.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F07%2F103938_f922a7458eeb6d981c6478e06c4ae070.png&h=cafea21d&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/08/07/103939_f922a7458eeb6d981c6478e06c4ae070.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F07%2F103939_f922a7458eeb6d981c6478e06c4ae070.png&h=22e932bc&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/08/07/103940_e73202f4db8580f1ab95ef992bcfeec4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F07%2F103940_e73202f4db8580f1ab95ef992bcfeec4.png&h=1b60e667&s={SIZE}\" /><br />\n早幾日去"},"citedBy":0,"replyTime":"2018-08-07T02:44:00.000Z","msg":"<img src=\"/assets/faces/big/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/good.gif\" class=\"hkgmoji\" />"},{"pid":"b43e231269f35163007e68371b2b079afefc0d22","tid":764974,"uid":57513,"like":1,"dislike":0,"score":1,"quote":{"pid":"ac2087c6ce2144f0feed458ff6263c783216a668","tid":764974,"uid":8478,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-07T02:42:03.000Z","msg":"二戰時期攞嚟實驗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-07T02:45:09.000Z","msg":"好似話其實已經轉晒,原本做實驗既後代應該無晒咁濟。"},{"pid":"1eef17e6a9ecd7e4f020bcf6129134a2020b5560","tid":764974,"uid":24465,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-08-07T02:47:26.000Z","msg":"屋企隻兔唔鍾意俾人抱 但係又好想抱<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"fc9966862b3ea38fd472bcae8f306e8c299cfb62","tid":764974,"uid":197098,"like":4,"dislike":0,"score":4,"quote":{"pid":"1eef17e6a9ecd7e4f020bcf6129134a2020b5560","tid":764974,"uid":24465,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-08-07T02:47:26.000Z","msg":"屋企隻兔唔鍾意俾人抱 但係又好想抱<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-07T02:55:37.000Z","msg":"<span style=\"font-size: large;\"><strong>抱是沒問題的。但如果主人的目的是叫兔子回到籠裡，可以用以下的方法：</strong><br />\n<br />\n兔子是被捕獵的動物(prey animal), 在大自然內是每個捕獵者(predatory animals)的目標，沒有自然本能去攻擊他人。牠們是脆弱的動物，很容易受驚。因此，兔子不喜歡被抱來抱去。當牠逃跑的時候，你還去追住抱，會令兔子和主人的信任更差。最好的方法去叫牠入籠是每晚(比如：22:00）搖零食樽或pellet 樽幾下，再引牠進入籠吃。幾天後，兔子就會記得零食樽的聲音知道是時候回到籠吃。習慣後，牠會自動22:00左右提主人你是時候回到籠裡吃東西。<br />\n<br />\n以下video 有教：<br />\n<a href=\"https://youtu.be/RJcvi7o4YXA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FRJcvi7o4YXA&d=PweQtpxxUf4jGkbaBIHExQHuyxefasl%2FZxVLfhQSBMM%3D&h=3366a2b0\" data-auto-link target=\"_blank\">https://youtu.be/RJcvi7o4YXA</a> </span><br />\n<br />\n<span style=\"font-size: x-large;\"><strong><ins><em>領養兔仔：</em></ins></strong><a href=\"http://www.hkrabbit.org/?page_id=114\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.hkrabbit.org%2F%3Fpage_id%3D114&d=PweQtpxxUf4jGkbaBIHExQHuyxefasl%2FZxVLfhQSBMM%3D&h=3fb51a32\" data-auto-link target=\"_blank\">http://www.hkrabbit.org/?page_id=114</a><br />\n更多關於兔子的身體語言(開心、憂愁、憤怒、驚慌)： <a href=\"http://rabbitspeak.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Frabbitspeak.com&d=PweQtpxxUf4jGkbaBIHExQHuyxefasl%2FZxVLfhQSBMM%3D&h=a87ed879\" data-auto-link target=\"_blank\">http://rabbitspeak.com</a> <br />\n兔子深入資訊：<a href=\"http://rabbit.org\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Frabbit.org&d=PweQtpxxUf4jGkbaBIHExQHuyxefasl%2FZxVLfhQSBMM%3D&h=702d66c0\" data-auto-link target=\"_blank\">http://rabbit.org</a></span>"},{"pid":"f4af9445170f20fb8bd4ea8e3f3ea7985cc905ba","tid":764974,"uid":197098,"like":1,"dislike":0,"score":1,"quote":{"pid":"4d40f9b6151b36df3f860ec585580492e8d4307e","tid":764974,"uid":22590,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-08-07T01:56:01.000Z","msg":"新手兔奴留名<br />\n佢終於識小便但大便都係周圍柯<br />\n係咪要不停執晒佢?"},"citedBy":0,"replyTime":"2018-08-07T03:32:49.000Z","msg":"<span style=\"font-size: large;\">補充之前回應你的問題：<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 兔子在籠裡大便是正常的，是表示這個籠牠的地盤。</span><br />\n<br />\n<span style=\"font-size: large;\">你隻兔仔是什麼品種？幾多歲？有沒有照片分享？😊👍👍<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> </span>"},{"pid":"4d0591bee51df62064383af1123c4fdd976a5cef","tid":764974,"uid":197958,"like":1,"dislike":0,"score":1,"quote":{"pid":"4d40f9b6151b36df3f860ec585580492e8d4307e","tid":764974,"uid":22590,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-08-07T01:56:01.000Z","msg":"新手兔奴留名<br />\n佢終於識小便但大便都係周圍柯<br />\n係咪要不停執晒佢?"},"citedBy":1,"replyTime":"2018-08-07T05:11:43.000Z","msg":"我果隻有一排夜晚唔關籠比佢周圍走<br />\n日頭會周圍痾，後來夜晚關返籠就無事"},{"pid":"9818a46169586f8d7547987ef8552914f1030c4f","tid":764974,"uid":197098,"like":1,"dislike":0,"score":1,"quote":{"pid":"4d0591bee51df62064383af1123c4fdd976a5cef","tid":764974,"uid":197958,"like":1,"dislike":0,"score":1,"quote":{"pid":"4d40f9b6151b36df3f860ec585580492e8d4307e","tid":764974,"uid":22590,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-08-07T01:56:01.000Z","msg":"新手兔奴留名<br />\n佢終於識小便但大便都係周圍柯<br />\n係咪要不停執晒佢?"},"citedBy":1,"replyTime":"2018-08-07T05:11:43.000Z","msg":"我果隻有一排夜晚唔關籠比佢周圍走<br />\n日頭會周圍痾，後來夜晚關返籠就無事"},"citedBy":2,"replyTime":"2018-08-07T05:19:22.000Z","msg":"<span style=\"font-size: large;\">你隻兔仔是什麼品種？幾多歲？有沒有照片分享？😊👍👍<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></span>"},{"pid":"cf12370d46ee197b81183ef7e0dc4dda96bb462d","tid":764974,"uid":197098,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-07T10:38:22.000Z","msg":"<span style=\"font-size: xx-large;\">怎樣可簡單訓練兔子去廁所? <strong><ins>(補充)</ins></strong>🐰🐰😊</span><br />\n<br />\n<span style=\"font-size: large;\">訓練兔仔🐰去廁所是很簡單的。糞便是沒有臭味的，而且是乾的，所以通常可以拿上來放回兔子的廁所（牠們便會知道要去廁所大小便）然後洗手。尿有時會有少少味，最好把白醋加水放入噴霧樽，然後清洗地板，這樣的話會立刻清除味道及減少牠們在這裏小便。兔子在籠裡大便是正常的，是表示這個籠是牠的地盤。<br />\n<br />\n每次兔子在籠外隨地大小便，大聲說No, 然後輕輕地帶牠回到廁所，讓牠知道是不可以的。將隨地的大便放回廁所內，以及隨地的小便以廁紙抹完放入廁所內，牠便會知道要在廁所內大小便。每次牠在廁所內大小便，就給他零食作獎勵。選擇獎勵，不要懲罰。記住不要打兔子，牠們與狗和貓不同，如果打，牠永遠不會忘記，令到與主人關係和信任差。壓力(stress) 亦可以會令兔子生病。兔子是被捕獵的動物(prey animal), 是大自然內每個捕獵者(predatory animals)的目標。他們是脆弱的動物，很容易受驚。狗吠聲、雷暴、消防車叫聲等也會驚嚇兔子。當牠們受驚時，groom(撫摸和親吻)牠們是很重要，令牠們冷靜下來和知道是沒事的。<br />\n<br />\n當然，<strong><ins>兔子要絕育才可以訓練去廁所</ins></strong>，因為霸地盤(territorial marker), 絕育後會大大減少霸地盤。另外，兔子是很容易患上生殖器疾病的動物，所以絕育也會令牠們更健康和長命！<br />\n<br />\n當然，有時候牠們不開心不聽話或者少少霸地盤原因也會隨地大便。<br />\n<br />\n以下3個videos 有教, 步驟簡單:<br />\n<a href=\"https://www.youtube.com/watch?v=zsB7SILsOns\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DzsB7SILsOns&d=PweQtpxxUf4jGkbaBIHExQHuyxefasl%2FZxVLfhQSBMM%3D&h=e79d3782\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=zsB7SILsOns</a> <br />\n<a href=\"https://www.youtube.com/watch?v=gP4IaOQsKl4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DgP4IaOQsKl4&d=PweQtpxxUf4jGkbaBIHExQHuyxefasl%2FZxVLfhQSBMM%3D&h=dca3a359\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=gP4IaOQsKl4</a> <br />\n<a href=\"https://www.youtube.com/watch?v=0GHRkf5z6EQ\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D0GHRkf5z6EQ&d=PweQtpxxUf4jGkbaBIHExQHuyxefasl%2FZxVLfhQSBMM%3D&h=98a1678d\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=0GHRkf5z6EQ</a> </span><br />\n<br />\n<span style=\"font-size: x-large;\"><strong><em><ins>領養兔仔：</ins></em></strong><a href=\"http://www.hkrabbit.org/?page_id=114\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.hkrabbit.org%2F%3Fpage_id%3D114&d=PweQtpxxUf4jGkbaBIHExQHuyxefasl%2FZxVLfhQSBMM%3D&h=3fb51a32\" data-auto-link target=\"_blank\">http://www.hkrabbit.org/?page_id=114</a> </span>"},{"pid":"744b84393fbcdf885d26d5a86e68bc59fab077ef","tid":764974,"uid":197958,"like":0,"dislike":0,"score":0,"quote":{"pid":"9818a46169586f8d7547987ef8552914f1030c4f","tid":764974,"uid":197098,"like":1,"dislike":0,"score":1,"quote":{"pid":"4d0591bee51df62064383af1123c4fdd976a5cef","tid":764974,"uid":197958,"like":1,"dislike":0,"score":1,"quote":{"pid":"4d40f9b6151b36df3f860ec585580492e8d4307e","tid":764974,"uid":22590,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-08-07T01:56:01.000Z","msg":"新手兔奴留名<br />\n佢終於識小便但大便都係周圍柯<br />\n係咪要不停執晒佢?"},"citedBy":1,"replyTime":"2018-08-07T05:11:43.000Z","msg":"我果隻有一排夜晚唔關籠比佢周圍走<br />\n日頭會周圍痾，後來夜晚關返籠就無事"},"citedBy":2,"replyTime":"2018-08-07T05:19:22.000Z","msg":"<span style=\"font-size: large;\">你隻兔仔是什麼品種？幾多歲？有沒有照片分享？😊👍👍<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></span>"},"citedBy":1,"replyTime":"2018-08-07T13:56:45.000Z","msg":"荷蘭賓尼，已經走左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"5eecc1b332ef45769608345e7312897eb45d0fa2","tid":764974,"uid":197098,"like":0,"dislike":0,"score":0,"quote":{"pid":"744b84393fbcdf885d26d5a86e68bc59fab077ef","tid":764974,"uid":197958,"like":0,"dislike":0,"score":0,"quote":{"pid":"9818a46169586f8d7547987ef8552914f1030c4f","tid":764974,"uid":197098,"like":1,"dislike":0,"score":1,"quote":{"pid":"4d0591bee51df62064383af1123c4fdd976a5cef","tid":764974,"uid":197958,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-07T05:11:43.000Z","msg":"我果隻有一排夜晚唔關籠比佢周圍走<br />\n日頭會周圍痾，後來夜晚關返籠就無事"},"citedBy":2,"replyTime":"2018-08-07T05:19:22.000Z","msg":"<span style=\"font-size: large;\">你隻兔仔是什麼品種？幾多歲？有沒有照片分享？😊👍👍<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></span>"},"citedBy":1,"replyTime":"2018-08-07T13:56:45.000Z","msg":"荷蘭賓尼，已經走左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-07T14:43:04.000Z","msg":"幾多歲走左？"},{"pid":"0bd94e503b79e21ec3cb7772a1c7320617ba7026","tid":764974,"uid":43594,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-07T15:07:14.000Z","msg":"兔仔島真係好正<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <br />\n上年六月去過<br />\n平地d兔仔大部分都食飽曬 唔會主動親近人<br />\n但沿住山路一路上 <br />\n沿途都勁多兔仔聽到有人聲知有野食就衝出黎"},{"pid":"ac338598ef5fc74a6bf2898c0d63126c0153464a","tid":764974,"uid":58321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-07T15:09:28.000Z","msg":"rachmaninoff"},{"pid":"09313316a666b2f4aa4c30a128e62cf61bfdcc55","tid":764974,"uid":37399,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-08-07T15:16:52.000Z","msg":"keep住每年都去1-2次<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n好記得兩年幾前係上山條路見到隻被棄養嘅獅子兔<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n好撚q，同佢玩左好耐<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n之後上年去都睇唔返佢<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />  好擔心，以為佢瓜左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n今年年頭去嘅時候都冇乜希望見返佢啦，點知去到冇耐就見到佢<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />  一開始都認唔出，係靠佢個花紋先認到<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <br />\n真係感動到喊左<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n<br />\n希望來緊去又會見返佢啦<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"4e69cd0c873bd5ab73f6e7488ada53b93e26ef83","tid":764974,"uid":150036,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-08-07T16:20:39.000Z","msg":"每一次去到都唔捨得走<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n依家Keep住每半年就去一次広島<br />\n就係為左探佢地<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <br />\n今年6月去果陣<br />\n見到比之前多左好多兔bb<br />\n得意到呢<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/07.png\" class=\"hkgmoji\" />"},{"pid":"7f3132f6408aa052cd9bca7b3958f80ab44cabf8","tid":764974,"uid":22590,"like":1,"dislike":0,"score":1,"quote":{"pid":"9818a46169586f8d7547987ef8552914f1030c4f","tid":764974,"uid":197098,"like":1,"dislike":0,"score":1,"quote":{"pid":"4d0591bee51df62064383af1123c4fdd976a5cef","tid":764974,"uid":197958,"like":1,"dislike":0,"score":1,"quote":{"pid":"4d40f9b6151b36df3f860ec585580492e8d4307e","tid":764974,"uid":22590,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-08-07T01:56:01.000Z","msg":"新手兔奴留名<br />\n佢終於識小便但大便都係周圍柯<br />\n係咪要不停執晒佢?"},"citedBy":1,"replyTime":"2018-08-07T05:11:43.000Z","msg":"我果隻有一排夜晚唔關籠比佢周圍走<br />\n日頭會周圍痾，後來夜晚關返籠就無事"},"citedBy":2,"replyTime":"2018-08-07T05:19:22.000Z","msg":"<span style=\"font-size: large;\">你隻兔仔是什麼品種？幾多歲？有沒有照片分享？😊👍👍<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></span>"},"citedBy":1,"replyTime":"2018-08-08T00:19:10.000Z","msg":"荷蘭垂耳兔 2個幾月<br />\n尋日試過掉晒D大便入廁所佢好似減少左周圍柯!"},{"pid":"2134b562246afbd1a75f95bd83cb7ce361f2f908","tid":764974,"uid":76143,"like":2,"dislike":0,"score":2,"quote":{"pid":"110692f262d8388b490a8f99837c421b25d87959","tid":764974,"uid":41368,"like":18,"dislike":37,"score":-19,"citedBy":2,"replyTime":"2018-08-02T11:34:46.000Z","msg":"突然好想食兔肉"},"citedBy":0,"replyTime":"2018-08-08T00:21:30.000Z","msg"