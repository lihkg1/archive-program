s/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"467a7769f9a9abe81174387c83dda3cf6abeb284","tid":2489723,"uid":41411,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d92519a7847266b98d0d1080f8375fde0a7e751","tid":2489723,"uid":7854,"like":1,"dislike":0,"score":1,"quote":{"pid":"d87636f73d4739ffa5fa16d76b6e324b11be7a8f","tid":2489723,"uid":26253,"like":3,"dislike":6,"score":-3,"citedBy":3,"replyTime":"2021-04-15T06:30:26.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />又幾件 就嚟無位喇"},"citedBy":2,"replyTime":"2021-04-15T06:34:18.000Z","msg":"曱甴唔番去savehk同班廢老互含 出黎做乜<img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-15T06:38:02.000Z","msg":"唔洗理班五毛賤種"},{"pid":"4998139ec418b726a5082f147c69f32e76e10055","tid":2489723,"uid":60785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-15T06:41:10.000Z","msg":"痴撚線<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"9139f5b2fdae3f6184ce42f473bdcacf17faca11","tid":2489723,"uid":160592,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d92519a7847266b98d0d1080f8375fde0a7e751","tid":2489723,"uid":7854,"like":1,"dislike":0,"score":1,"quote":{"pid":"d87636f73d4739ffa5fa16d76b6e324b11be7a8f","tid":2489723,"uid":26253,"like":3,"dislike":6,"score":-3,"citedBy":3,"replyTime":"2021-04-15T06:30:26.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />又幾件 就嚟無位喇"},"citedBy":2,"replyTime":"2021-04-15T06:34:18.000Z","msg":"曱甴唔番去savehk同班廢老互含 出黎做乜<img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-15T06:45:09.000Z","msg":"條友即刻de哂record<br />\n淆到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8b7a12c7a6acf9f71b9434ccce98bbc9495f513e","tid":2489723,"uid":13993,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-15T17:22:08.000Z","msg":"推"}]}