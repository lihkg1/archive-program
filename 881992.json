islike":0,"score":2,"quote":{"pid":"c85820afbc0b9ead3534a29f634e549608005ce1","tid":881992,"uid":73269,"like":23,"dislike":1,"score":22,"citedBy":1,"replyTime":"2018-10-30T03:24:12.000Z","msg":"乜嘢你凍未條？"},"citedBy":0,"replyTime":"2018-10-30T07:34:42.000Z","msg":"原來唔係得我唔明<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"80d813455417e83fd098abdaaf13bbfca145d5b7","tid":881992,"uid":36820,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-30T07:35:39.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> more"},{"pid":"28701d77f14d1dd42fc62f8e2433dfdd88258a23","tid":881992,"uid":167506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-30T08:09:12.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"b0a1338abaac8751af31e350db67b2c4434f34a8","tid":881992,"uid":167506,"like":0,"dislike":0,"score":0,"quote":{"pid":"a75cdfdf3a2fad25409cc9b8b8342561c94df7aa","tid":881992,"uid":111370,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-10-30T05:00:51.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-30T08:16:53.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"dc9a5b01dccce578791924bc72eafc8f51b9c641","tid":881992,"uid":210088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-30T08:17:22.000Z","msg":"<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" />"},{"pid":"38e61ade3c1c6466c802332b25168aa6091ad887","tid":881992,"uid":181625,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-10-30T08:33:28.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2018/10/30/085530_0cc1c1f34a4cb58a59293ef088bc3292.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F30%2F085530_0cc1c1f34a4cb58a59293ef088bc3292.png&h=c7317e16&s={SIZE}\" /><br />\n<br />\n大部分人對於摔角的印象，應該都是兩個男選手在擂台上進行較量，先將對方給壓制住的另一方就獲勝，但日本近來也積極發展女子摔角，其中一名女摔角手便在推特上引起討論，因為她的身材實在是太火辣了！<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/10/30/085558_c47fd86095263bb52fc49a1a690acf03.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F30%2F085558_c47fd86095263bb52fc49a1a690acf03.png&h=6cc8f682&s={SIZE}\" /><br />\n<br />\n這名女摔角手叫做上福雪，本名上福佑季，是出生於日本神奈川縣的海歸子女，從小在美國生活，因此英語會話對她來說並不困難，在大學時曾參加過「東洋大學小姐選拔」，一路殺進準決賽，之後也有參加過「Miss Action 2017」和「Miss FLASH 2018」等選美比賽，是被認證過的高顏值。<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/10/30/085642_ce5c53269dfdc60f052e0fea4a3b9b87.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F30%2F085642_ce5c53269dfdc60f052e0fea4a3b9b87.png&h=05c8bf02&s={SIZE}\" /><br />\n<br />\n憑藉著漂亮的臉蛋、傲人的身材以及<span style=\"color: red;\">173的大長腿</span>，上福雪從事了模特兒的行業，在因緣際會之下又加入了職業摔角界，讓她成為身兼寫真模特的女子摔角手，擁有這樣雙重身分的反差形象，讓網友們都身陷她的魅力之中，直呼：「還沒開始看比賽就先噴鼻血了啦！」。<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/10/30/085732_f661648c75803471f0c057c0bd6420ca.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F30%2F085732_f661648c75803471f0c057c0bd6420ca.png&h=8d1b866a&s={SIZE}\" /></blockquote><br />\n<br />\n淨係大長腿都高過我<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"098225beca90cd0db724fc8676cc41ec9554b797","tid":881992,"uid":45613,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-30T09:06:28.000Z","msg":"G"}]}