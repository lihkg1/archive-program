{"tid":1738012,"cid":5,"subCid":0,"title":"大雄因為怕比胖虎打，所以匿埋唔敢同胖虎打棒球，去玩其他野","createTime":"2019-11-19T06:15:44.000Z","updateTime":"2019-11-19T06:47:23.000Z","uid":127735,"like":26,"dislike":1,"uniUserReply":13,"replies":[{"pid":"1fbbb7211ac61c1cc049e338da7daabc76876a16","tid":1738012,"uid":127735,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-19T06:15:44.000Z","msg":"但係之後佢會搵多啦A夢拎法寶玩番胖虎轉頭，唔係就再出街周圍搵野玩<br />\n胖虎知道左會嬲到痴筋，追住大雄黎打到佢番屋企<br />\n但時間耐左之後，胖虎發覺大雄總係唔放棄咁玩自己，胖虎最後都係放棄<br />\n<br />\n明知唔夠佢打，明知佢係到，所以唔去同佢玩<br />\n所以搵新玩具搵殘佢，一係就去第二度玩其他野<br />\n<br />\n兒時學到既道理，幾時都係咁有用<br />\n明既明就明，唔明都無辦法<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f7320f299b9c8a4b909da0b1daba2cf15bdfa031","tid":1738012,"uid":159448,"like":0,"dislike":3,"score":-3,"citedBy":2,"replyTime":"2019-11-19T06:16:46.000Z","msg":"解決方法係做個好朋友<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"5e326cf98fff7198f1167bc60366eca1c2bcecc6","tid":1738012,"uid":127735,"like":1,"dislike":0,"score":1,"quote":{"pid":"f7320f299b9c8a4b909da0b1daba2cf15bdfa031","tid":1738012,"uid":159448,"like":0,"dislike":3,"score":-3,"citedBy":2,"replyTime":"2019-11-19T06:16:46.000Z","msg":"解決方法係做個好朋友<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-19T06:17:41.000Z","msg":"我打出黎係想講，留意自己係咩階段<br />\n同咩方法先係最有用"},{"pid":"d2ed693cb3db9f30193a947c093a8e52e5f73477","tid":1738012,"uid":93986,"like":1,"dislike":0,"score":1,"quote":{"pid":"f7320f299b9c8a4b909da0b1daba2cf15bdfa031","tid":1738012,"uid":159448,"like":0,"dislike":3,"score":-3,"citedBy":2,"replyTime":"2019-11-19T06:16:46.000Z","msg":"解決方法係做個好朋友<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-11-19T06:19:21.000Z","msg":"做好朋友<br />\n之後日日返學俾人玩俾人迫交保護費"},{"pid":"d015ee985b8e5a7b897f965271e1215693841772","tid":1738012,"uid":127735,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T06:19:27.000Z","msg":"大家明唔明呀"},{"pid":"