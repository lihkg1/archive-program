{"tid":1594783,"cid":30,"subCid":0,"title":"食Dinner嗰陣讚同事個熱狗好精緻，點知比佢嬲咗摵左我粒lin一下","createTime":"2019-09-25T17:19:02.000Z","updateTime":"2019-09-26T00:37:01.000Z","uid":44748,"like":0,"dislike":4,"uniUserReply":7,"replies":[{"pid":"4fd929e15e08eb414ea68c1e47ec3becc64f0778","tid":1594783,"uid":44748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T17:19:02.000Z","msg":"話說啱啱同成堆同事Team dinner食美國野<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<br />\n同其中一個台仔同事幾熟<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n咁佢叫左個小食，咖哩味乜乜乜熱狗<br />\n<br />\n咁個嚟到我見賣相唔差<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><br />\n<br />\n個廚師界條司華力腸界得好靚想讚下<br />\n<br />\n但一時load錯講左:&ldquo;你條香腸反哂皮，好特別啊<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />&rdquo;<br />\n<br />\n全部同事都聽到喺到忍笑，結果佢嬲到想喊咁<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n然後就摵左我粒lin一下，想問我應該點同佢道歉<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n利申:無知少女一名<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"3a984df09d5ea9593c08cee3e5b41899f196022d","tid":1594783,"uid":74990,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T17:19:52.000Z","msg":"甜故"},{"pid":"65d6e91b559c758e8131e5d236da7b219a9618ff","tid":1594783,"uid":431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T17:21:17.000Z","msg":"搞到我都想俾人搣吓<img src=\"/assets/faces/mf/frown.gif\" class=\"hkgmoji\" />"},{"pid":"c8763a74e88f2e7faf13cb02b61e30dfdbe44619","tid":1594783,"uid":38904,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-25T17:23:51.000Z","msg":"你俾佢搣返你條JJ<img src=\"/assets/faces/mf/smile.png\" class=\"hkgmoji\" />"},{"pid":"f8d7d894288e88fc1294f3c262ce718e8d9b7894","tid":1594783,"uid":317282,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T17:24:20.000Z","msg":"呢個係甜故定科幻故事<img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmo