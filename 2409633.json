ormal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1f96cad13f97fdaafb5d41baa8249a473883e7d4","tid":2409633,"uid":236171,"like":0,"dislike":0,"score":0,"quote":{"pid":"578ac6a7905d208fbf4a76bceaea85257c79b52a","tid":2409633,"uid":177089,"like":24,"dislike":1,"score":23,"quote":{"pid":"d476399c6bbf2c55b72ac25a8945de32c0b7fb87","tid":2409633,"uid":53062,"like":18,"dislike":1,"score":17,"citedBy":1,"replyTime":"2021-02-16T03:42:08.000Z","msg":"留名鞭屍"},"citedBy":3,"replyTime":"2021-02-16T04:18:46.000Z","msg":"早在2017年，登特就預警未來三年，金融市場將迎來最糟糕時刻，美國股市甚至可能出現70%-90%的跌幅。<br />\n<br />\n已經鞭緊<img src=\"/assets/faces/mouse/potion.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-16T05:18:00.000Z","msg":"延遲之後仲跌少咗<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"a2fed998db2d9311154579d9b3b6e91d1624c3a5","tid":2409633,"uid":198952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-16T05:20:43.000Z","msg":"繼續印錢咪得囉"},{"pid":"4e5dbb8885a61f42b2e1bd09ca3acfee3451d277","tid":2409633,"uid":117729,"like":4,"dislike":0,"score":4,"quote":{"pid":"1ca2d6e8cdace0ef5b9c3699f667392770968554","tid":2409633,"uid":119512,"like":10,"dislike":1,"score":9,"citedBy":2,"replyTime":"2021-02-16T03:52:31.000Z","msg":"睇左Harvey Dent <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-16T05:21:45.000Z","msg":"公係跌，字係唔跌"},{"pid":"620a999d3365e2d5996f0a9aad86c2692f3d2f0c","tid":2409633,"uid":109462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-16T05:24:13.000Z","msg":"如果疫情之下仲要出現一個咁大幅度嘅回調同埋破產潮，我諗拜登政府嘅刺激經濟措施規模會去到星球大戰級別，地氈式轟炸放水<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dcacc096c49e5d076b90b84a044cb89415cf2f02","tid":2409633,"uid":20820,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-02-16T05:36:13.000Z","msg":"呢條友中過一次就打哂飛機<br />\n就算唔中都拗到自己中<br />\n利申年少無知買左佢本書，dump左落堆填區"},{"pid":"9aa17e56f8493fa3fd6d635925b7d43f02541a00","tid":2409633,"uid":177039,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-16T05:36:18.000Z","msg":"上年好似又有人咁講過<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a2e131332de868c69e949232813d9a6e8ae8c98f","tid":2409633,"uid":90077,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-16T05:38:52.000Z","msg":"<blockquote><img src=\"https://x0.ifengimg.com/res/2020/19EF93C0C169D3AB9B9F6611BB5B6D1C72004E38_size48_w553_h369.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fx0.ifengimg.com%2Fres%2F2020%2F19EF93C0C169D3AB9B9F6611BB5B6D1C72004E38_size48_w553_h369.jpeg&h=4da7c593&s={SIZE}\" /><br />\n<br />\n財聯社（上海，編輯周玲）訊，近期美股再次高漲，雖然大摩等機構已預警了回調風險，但還沒有哪個機構給出如此驚人的回調幅度&mdash;&mdash;40%。美股&ldquo;大空頭&rdquo;、著名經濟學家、HS Dent投資管理公司創始人登特（Harry Dent）近日接受采訪時表示，美股12月之後將開啟跌勢，4月前將出現40%的回調，且幾十年都不會完全恢復過來。<br />\n<br />\n上週摩根士丹利警告稱，由疫苗推動的漲勢已結束，在年底前的最後一次調整中，標普500指數的跌幅可能高達12%。而摩根大通上周亦表示，因機構投資者一般在年底面臨再平衡調整，這可能導致資金在今年年底前從全球股市撤出約3,000億美元。<br />\n<br />\n&ldquo;如果股市再創新低，我預計道指、標普指數、納指、生物科技股等都難以再創下新高。幾十年內，你不會看到任何東西創下新高。&rdquo;登特近日接受媒體採訪時表示，就好比&ldquo;我們在1929年（大蕭條）之後的24年裡，都沒有見過新高。&rdquo;<br />\n<br />\n登特指出，經濟復甦已經走到盡頭，股市很快就會認識到這一點。<br />\n<br />\n他表示：&ldquo;有相當大一部分是難以恢復的，我認為有80%的經濟沒有受到永久性破壞，且已經實現了V型複蘇，但還有15%-20%的經濟不會恢復。&rdquo;<br />\n<br />\n登特認為，隨著嬰兒潮一代進入退休年齡，消費支出也將保持疲軟。<br />\n<br />\n&ldquo;從2023年開始，千禧一代將推動我們前進。但在那之前並不會，因此人口結構仍然疲弱，債務依然沉重。我要說，我們永遠不會完全從這次危機中恢復過來，到明年年初我們就會意識到這一點。&rdquo;<br />\n<br />\n登特補充道，下一次股市崩盤不會像今年3月的拋售那樣簡單地反彈。登特指出，新一輪崩盤的導火索是更多的企業破產。<br />\n<br />\n&ldquo;新冠肺炎事件在今年早些時候出現&hellip;&hellip;我認為要等到9到12個月後，你才能真正感受到小企業和殭屍公司(倒閉)的影響。它們不會一夜之間消失。股市可能會像過去一樣在一夜之間下跌，但破產需要時間。&rdquo;登特稱。<br />\n<br />\n他強調，&rdquo;我認為，到明年一季度，你會看到更多公司破產，這將是導火索。&rdquo;<br />\n<br />\n<span class=\"red\">早在2017年，登特就預警未來三年，金融市場將迎來最糟糕時刻，美國股市甚至可能出現70%-90%的跌幅。</span><br />\n<br />\n他當時稱，他所追踪的四大長期趨勢均在過去幾年見頂，目前已經處於下行區間，這種趨勢可能會持續到2020年前後。</blockquote><br />\n<br />\n專家變磚家<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />年年講一次總會中，本多終勝<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"9b5ea92f6366690cd4e9fe2f9edb0685e570f155","tid":2409633,"uid":93615,"like":0,"dislike":0,"score":0,"quote":{"pid":"1ca2d6e8cdace0ef5b9c3699f667392770968554","tid":2409633,"uid":119512,"like":10,"dislike":1,"score":9,"citedBy":2,"replyTime":"2021-02-16T03:52:31.000Z","msg":"睇左Harvey Dent <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-16T05:44:18.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"94f1f761f663eada9bd265906429cb4d8eeeb9bd","tid":2409633,"uid":235174,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2021-02-16T05:49:04.000Z","msg":"<img src=\"https://na.cx/i/1fJRMSD.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1fJRMSD.png&h=c7261a47&s={SIZE}\" />"},{"pid":"c5aa72ada41950201e4b5b105a510d0e159dae34","tid":2409633,"uid":344307,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-16T05:50:28.000Z","msg":"上年3月<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"c7439b5d3a0620a67570980f6294fc8795877435","tid":2409633,"uid":109629,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-16T05:50:58.000Z","msg":"咁佢自己沽左空未<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"171708bd4628b8c971c4e24472453a96f15ccfb1","tid":2409633,"uid":44980,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2021-02-16T05:55:58.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n今次仆街<img src=\"/assets/faces/cow/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c07be7609e9a1a267adf6e8437d93fc596084946","tid":2409633,"uid":11148,"like":0,"dislike":0,"score":0,"quote":{"pid":"171708bd4628b8c971c4e2