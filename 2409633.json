=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e321b2480a6c5087940c6705789f6c2381b71fa7","tid":2409633,"uid":86467,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-18T13:25:20.000Z","msg":"股joy黎啦<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"7dc2788a595777518816d850a311ec5cf15f7149","tid":2409633,"uid":89227,"like":0,"dislike":0,"score":0,"quote":{"pid":"67a204a5bfd2f8e042b2ee432b732659eaa516fe","tid":2409633,"uid":355392,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-16T12:17:54.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-18T13:26:12.000Z","msg":"美國沈大師黎<br />\n佢除左日本個次中過一次，其他都係燈<br />\n不過都唔可以排除佢今次中<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"77d8bb5352a249ae613d0a00e0ccc4fac9a75d59","tid":2409633,"uid":62842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-18T13:28:15.000Z","msg":"又想呃貨 <img src=\"/assets/faces/cow/arrogant.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/arrogant.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/arrogant.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/arrogant.gif\" class=\"hkgmoji\" />"},{"pid":"13c41dd5cef088695c61528672c4ffe202104f50","tid":2409633,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-18T15:48:00.000Z","msg":"<img src=\"/assets/faces/lm2lny/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2lny/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2lny/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2lny/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"2e58af6df7be02d9fdb120940522fb775f27cf31","tid":2409633,"uid":203305,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c40834b20b03bb524bd2a9ba71cfc2377780467","tid":2409633,"uid":215755,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-16T03:39:26.000Z","msg":"<img src=\"https://x0.ifengimg.com/res/2020/19EF93C0C169D3AB9B9F6611BB5B6D1C72004E38_size48_w553_h369.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fx0.ifengimg.com%2Fres%2F2020%2F19EF93C0C169D3AB9B9F6611BB5B6D1C72004E38_size48_w553_h369.jpeg&h=4da7c593&s={SIZE}\" /><br />\n<br />\n財聯社（上海，編輯周玲）訊，近期美股再次高漲，雖然大摩等機構已預警了回調風險，但還沒有哪個機構給出如此驚人的回調幅度&mdash;&mdash;40%。美股&ldquo;大空頭&rdquo;、著名經濟學家、HS Dent投資管理公司創始人登特（Harry Dent）近日接受采訪時表示，美股12月之後將開啟跌勢，4月前將出現40%的回調，且幾十年都不會完全恢復過來。<br />\n<br />\n上週摩根士丹利警告稱，由疫苗推動的漲勢已結束，在年底前的最後一次調整中，標普500指數的跌幅可能高達12%。而摩根大通上周亦表示，因機構投資者一般在年底面臨再平衡調整，這可能導致資金在今年年底前從全球股市撤出約3,000億美元。<br />\n<br />\n&ldquo;如果股市再創新低，我預計道指、標普指數、納指、生物科技股等都難以再創下新高。幾十年內，你不會看到任何東西創下新高。&rdquo;登特近日接受媒體採訪時表示，就好比&ldquo;我們在1929年（大蕭條）之後的24年裡，都沒有見過新高。&rdquo;<br />\n<br />\n登特指出，經濟復甦已經走到盡頭，股市很快就會認識到這一點。<br />\n<br />\n他表示：&ldquo;有相當大一部分是難以恢復的，我認為有80%的經濟沒有受到永久性破壞，且已經實現了V型複蘇，但還有15%-20%的經濟不會恢復。&rdquo;<br />\n<br />\n登特認為，隨著嬰兒潮一代進入退休年齡，消費支出也將保持疲軟。<br />\n<br />\n&ldquo;從2023年開始，千禧一代將推動我們前進。但在那之前並不會，因此人口結構仍然疲弱，債務依然沉重。我要說，我們永遠不會完全從這次危機中恢復過來，到明年年初我們就會意識到這一點。&rdquo;<br />\n<br />\n登特補充道，下一次股市崩盤不會像今年3月的拋售那樣簡單地反彈。登特指出，新一輪崩盤的導火索是更多的企業破產。<br />\n<br />\n&ldquo;新冠肺炎事件在今年早些時候出現&hellip;&hellip;我認為要等到9到12個月後，你才能真正感受到小企業和殭屍公司(倒閉)的影響。它們不會一夜之間消失。股市可能會像過去一樣在一夜之間下跌，但破產需要時間。&rdquo;登特稱。<br />\n<br />\n他強調，&rdquo;我認為，到明年一季度，你會看到更多公司破產，這將是導火索。&rdquo;<br />\n<br />\n早在2017年，登特就預警未來三年，金融市場將迎來最糟糕時刻，美國股市甚至可能出現70%-90%的跌幅。<br />\n<br />\n他當時稱，他所追踪的四大長期趨勢均在過去幾年見頂，目前已經處於下行區間，這種趨勢可能會持續到2020年前後。"},"citedBy":0,"replyTime":"2021-02-18T15:50:02.000Z","msg":"好撚掛住侵侵<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ab0329988e520b18cc2a83fd29c8665ff04707f3","tid":2409633,"uid":83228,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-18T15:51:37.000Z","msg":"1929之後就ww2<br />\n佢買打仗<br />\n咁仲short乜9<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"7a232bf39e3d47169d1efe3c3b5379e9078b066