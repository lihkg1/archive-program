 class=\"hkgmoji\" />"}],"pinned":{"pid":"272a605ae8d6e494a054532e1e9fa98e7276ced1","tid":2416304,"uid":30,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-21T02:48:09.000Z","msg":"人算不如天算<br />\n<br />\n香港在近兩年經歷很多風雨，有人形容香港愈來愈變得病態，社會不同症狀令香港人困擾。很多人正面對人生十字路，究竟留下等待病況好轉？抑或離開患病中的香港？新一代風水命理師希望為香港人指點迷津。<br />\n周璞初Gary成長於風水術數之家，這一年的疫情、社會動盪及政治環境變化，客人所關心的不再只是自身感情、健康或財富，而是考慮移居他方。懷恩Ryan成為全職風水命理師約兩年，他利用社交媒體及網絡平台幫人占卜解難，也免費為犯了官非的年輕人趨吉避凶。同為香港人的Gary及Ryan，又會怎樣抉擇？<br />\n<br />\n<img src=\"https://www.rthk.hk/oldassets/images/rthk/dtt31/hkstories48//originals/mfile_9129_725546_9_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fhkstories48%2F%2Foriginals%2Fmfile_9129_725546_9_l.jpg&h=3789766b&s={SIZE}\" /><br />\n<img src=\"https://www.rthk.hk/oldassets/images/rthk/dtt31/hkstories48//originals/mfile_9129_725546_10_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fhkstories48%2F%2Foriginals%2Fmfile_9129_725546_10_l.jpg&h=e353f244&s={SIZE}\" /><br />\n<img src=\"https://www.rthk.hk/oldassets/images/rthk/dtt31/hkstories48//originals/mfile_9129_725546_1_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fhkstories48%2F%2Foriginals%2Fmfile_9129_725546_1_l.jpg&h=245e369f&s={SIZE}\" /><br />\n<img src=\"https://www.rthk.hk/oldassets/images/rthk/dtt31/hkstories48//originals/mfile_9129_725546_2_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fhkstories48%2F%2Foriginals%2Fmfile_9129_725546_2_l.jpg&h=cf698d9c&s={SIZE}\" /><br />\n<img src=\"https://www.rthk.hk/oldassets/images/rthk/dtt31/hkstories48//originals/mfile_9129_725546_3_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fhkstories48%2F%2Foriginals%2Fmfile_9129_725546_3_l.