c=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" />"},{"pid":"c9323ca2cda2bcaadad587bebcb54b41ebe86a88","tid":865054,"uid":216992,"like":0,"dislike":0,"score":0,"quote":{"pid":"6a494cfa7e23c3bb637a7c1975c48518367fe2f1","tid":865054,"uid":38651,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-20T09:09:13.000Z","msg":"同華仔比人網絡欺凌<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-20T09:18:50.000Z","msg":"哇 巴打好快手"},{"pid":"15450039790fc2dce0f7ec107f3c17197fb52674","tid":865054,"uid":216992,"like":0,"dislike":0,"score":0,"quote":{"pid":"e9d4da397982fb5510fc45839857fa33ccc65e14","tid":865054,"uid":153087,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-20T08:44:19.000Z","msg":"唔好用馬主席嘅囗吻同我講野<img src=\"/assets/faces/lomoji/33.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-20T09:20:27.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"f37822918e71d1f7ac8889574f6788322e331da6","tid":865054,"uid":216992,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-20T09:29:04.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote>持續更新中<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">最新版</span></span><img src=\"/assets/faces/fs/shocking.gif\" class=\"hkgmoji\" /> <br />\n-新增「命令篇」！<br />\n<br />\n<br />\n<span style=\"font-size: large;\"><em><span style=\"color: limegreen;\">詞語篇</span></em></span><br />\n1.體諒<br />\n2.準確<br />\n3.客觀<br />\n4.持平<br />\n5.願景<br />\n6.新思維<br />\n7.有決心<br />\n8.天竺<br />\n<br />\n<br />\n<span style=\"font-size: large;\"><em><span style=\"color: limegreen;\">四字詞語篇</span></em></span><br />\n1.互諒互讓<br />\n2.安然度過<br />\n3.不可推翻<br />\n4.重中之中<br />\n5.言之尚早<br />\n6.一錘定音<br />\n7.暢有成效<br />\n8.預期之內<br />\n9.不盡不實<br />\n10.開放態度<br />\n11.迎難而上<br />\n12.上綱上線<br />\n13.切實可行<br />\n14.行之有效<br />\n15.清楚明白<br />\n16.勿踩紅線<br />\n<br />\n<span style=\"color: limegreen;\"><br />\n<span style=\"font-size: large;\"><em>句子篇</em></span></span><br />\n1.辦法總比困難多<br />\n2.透過呼籲係最有效方法<br />\n3.無人可一生一世<br />\n4.時間過得好快，度月如日<br />\n5.官到無求膽自大<br />\n6.我認為呢個唔係一個數字問題<br />\n<br />\n<br />\n<span style=\"font-size: large;\"><em><span style=\"color: limegreen;\">社會篇</span></em></span><br />\n1.有好多討論空間<br />\n2.今日唔踏出一步，過幾年就出現困局<br />\n3.政府係好願意聽市民嘅意見<br />\n4.要有理性討論<br />\n5.政府係唔會做傷害市民嘅工作<br />\n6.我有魄力，但唔忍心見到香港社會受傷<br />\n7.唔好太多陰謀論<br />\n8.政府冇既定立場<br />\n9.民意對我黎講唔重要<br />\n10.去為社會做事<br />\n11.你哋啲陰謀論有陣時真係令到我哋啲官員唔敢做嘢<br />\n<br />\n<br />\n<span style=\"font-size: large;\"><em><span style=\"color: limegreen;\">個人篇</span></em></span><br />\n1.完全可以體會到市民等車好傍偟<br />\n2.不能不重新考慮我自己的情況<br />\n3.如果反對我嘅人比支持我嘅人多，我會辭職<br />\n4.我同劉德華早前都成為網絡欺凌目標<br />\n<br />\n<br />\n<span style=\"font-size: large;\"><em><span style=\"color: limegreen;\">發悔氣篇</span></em></span><br />\n1.攞特首出下氣係冇問題<br />\n2.特首係可以比人鬧嘅 哈哈<br />\n3.冇嘢可以強制，你瞇埋眼咪睇唔到囉<br />\n4.唔答呢啲咁無聊嘅問題<br />\n5.大家鐘意點講就點講<br />\n6.見慣呢啲激烈嘅講法<br />\n7.呢個係言論自由，總之唔好做啲令人不安嘅事就得啦<br />\n8.講任何數字俾大家聽都冇意思<br />\n<br />\n<br />\n<span style=\"font-size: large;\"><em><span style=\"color: limegreen;\">宗教篇</span></em></span><br />\n1.我作為一個天主教徒，我每一日都會為香港嘅年輕人祈禱<br />\n2.上帝叫<br />\n3.天堂已經預留左位置比我<br />\n<br />\n<br />\n<span style=\"font-size: large;\"><em><span style=\"color: limegreen;\">讚賞篇</span></em></span><br />\n1.習近平的言行愈來愈有魅力及令人欽佩<br />\n<br />\n<br />\n<span style=\"font-size: large;\"><em><span style=\"color: limegreen;\">命令篇</span></em></span><br />\n1. 唔好用呢啲馬主席嘅口吻同我講<br />\n<br />\n<br />\n我只係憑記憶打出黎 <br />\n如果有錯漏嘅話 歡迎各位巴絲提供及指證<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /></blockquote></blockquote></blockquote></blockquote></blockquote>"}]}