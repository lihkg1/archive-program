f2e5a","tid":1364591,"uid":105976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T23:38:00.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"45c49e7ab079a1ccf221ec60969ed28a48f3bde2","tid":1364591,"uid":105976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T23:44:49.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2e33bd81544c9d0221873e7c4679a3706b2767b0","tid":1364591,"uid":105976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T00:05:52.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"16283945dae290e3b53140980ef5a8cfbd0e9351","tid":1364591,"uid":18245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T00:08:15.000Z","msg":"<div style=\"text-align: center;\"><code>（瞄準政權）上環黑警36槍企圖殺害抗爭者 中共策劃元朗恐襲</code></div><br />\n<div style=\"text-align: center;\">所有嘢都係中共係背後策劃<br />\n如果呢個政權係仆街係十惡不赦<br />\n咁擁護佢嘅黑警 黑社會都一樣咁仆街<br />\n咁十惡不赦 但唔好浪費咁多時間係呢<br />\n班卒仔到 <br />\n主力打大佬 瞄準返中共 唔好out focus唔係就真係對唔住咁多位被呢個政權殺害嘅戰友</div><br />\n<img src=\"https://na.cx/i/4LYjFvR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4LYjFvR.jpg&h=d444c005&s={SIZE}\" /><br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><div style=\"text-align: center;\">義士宣言：不排除成立臨時立法會</div></span></span><br />\n<span style=\"font-size: x-large;\"><span style=\"color: gold;\">721宣言</span></span>  <br />\n    <a href=\"https://youtu.be/zfNKZRPQHZk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FzfNKZRPQHZk&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=736a365a\" target=\"_blank\">https://youtu.be/zfNKZRPQHZk</a><br />\n<span style=\"font-size: small;\"><a href=\"https://lih.kg/1350879\" data-auto-link target=\"_blank\">https://lih.kg/1350879</a><br />\n</span><br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><div style=\"text-align: center;\">[長文] 時代周刊直指港府失去管治香港能力嘅分析</div></span></span><br />\n<span style=\"font-size: small;\"><a href=\"https://lih.kg/1356861\" data-auto-link target=\"_blank\">https://lih.kg/1356861</a><br />\n</span><br />\n<span style=\"color: gold;\"><div style=\"text-align: center;\"><span style=\"font-size: xx-large;\"><strong>支持前線所有決定</strong></span></div></span><br />\n民情，輿論，選票，呢啲唔洗我哋去諗，點去收拾所謂嘅殘局，就交比啲政治人物去煩啦<br />\n<div style=\"text-align: center;\"><strong><span style=\"font-size: xx-large;\">我哋要做嘅係我哋認為啱嘅事</span></strong></div><br />\n<code>「人民不應該害怕他們的政府，政府應該害怕它的人民。」（People should not be afraid of their governments. Governments should be afraid of their people.）</code><br />\n<div style=\"text-align: center;\"><br />\n<pre><code data-type=\"\">五大訴求，勿忘初衷\n遍地開花，不撤不散\n打倒軍權，反對國家恐怖主義\n光復香港，時代革命</code></pre><br />\n<pre><code data-type=\"\">&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash; 八大訴求 &mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;\n一、徹底撤回修例\n二、收回暴動定義\n三、撤銷對今為所有反送中抗爭者控罪\n四、徹底追究警隊濫權情況\n五、以行政命令解散立法會，立即實行雙真普選\n六、要求永不落實「社會信用評分系統」\n七、要求移除全港「多功能智慧燈柱」\n八、追究元朗鄉黑暴徒及警察失蹤</code></pre><br />\n<span style=\"color: gold;\"><strong><span style=\"font-size: xx-large;\">警察戰線:</span></strong></div></span><br />\n<img src=\"https://na.cx/i/7gq6kYx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7gq6kYx.jpg&h=1f5648e1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/hY7P3bT.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhY7P3bT.jpg&h=5c1777d4&s={SIZE}\" /><br />\n定性721黑警上環血腥鎮壓，元朗黑社會恐怖襲擊，警黑合作散播中國國家恐怖主義:<br />\n警察冇預警下開槍射36發橡膠彈，有人爆頭，警察已無視通例，已失去合法性<br />\n警察放任黑社會打市民，完全冇制止，並假指無發現武器收隊，傳媒發現雙方實有公開溝通<br />\n警察公然無視電話求助，元朗警署落閘，違反警隊職責<br />\n<div style=\"text-align: center;\"><br />\n<span style=\"color: gold;\"><span style=\"font-size: xx-large;\">黑社會戰線:</span></div></span><br />\n<img src=\"https://na.cx/i/d7DWJcw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fd7DWJcw.jpg&h=92c6a934&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/idEKR5S.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FidEKR5S.jpg&h=e6380dff&s={SIZE}\" /><br />\n拉攏任何政治冷感市民，有錢人，元朗問題非個別事件，收錢恐襲任何區都會發生，任何人都有機會中招<br />\n俾藍絲睇到佢地支持何君堯即係支持黑社會打人斬人，令藍絲同何君堯反面<br />\n<span style=\"color: gold;\"><div style=\"text-align: center;\"><span style=\"font-size: xx-large;\">國際戰線:</span></div></span><br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\">攬炒巴團隊</span></div><br />\n<img src=\"https://media.giphy.com/media/RhkvtuUcntXSuoVzay/giphy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2FRhkvtuUcntXSuoVzay%2Fgiphy.gif&h=254e8117&s={SIZE}\" /><br />\nLink:<br />\nFacebook:<br />\n<a href=\"https://www.facebook.com/standwithhk/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fstandwithhk%2F&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=551c67d8\" target=\"_blank\">https://www.facebook.com/standwithhk/</a><br />\nTwitter:<br />\n<a href=\"https://twitter.com/Stand_with_HK\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2FStand_with_HK&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=c555e367\" target=\"_blank\">https://twitter.com/Stand_with_HK</a><br />\nInstagram:<br />\n<a href=\"https://www.instagram.com/standwithhk_/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fstandwithhk_%2F&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=e660d54e\" target=\"_blank\">https://www.instagram.com/standwithhk_/</a><br />\nYouTube:<br />\n<a href=\"https://www.youtube.com/channel/UCyi42Y5o1ksO_yFItyHW7Jw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fchannel%2FUCyi42Y5o1ksO_yFItyHW7Jw&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=33d6e9e1\" target=\"_blank\">https://www.youtube.com/channel/UCyi42Y5o1ksO_yFItyHW7Jw</a>[/quote]<br />\n<blockquote><br />\n[我都要攬炒][時事台]一齊上twitter將黑警濫權揚威國際，警告遊客不要來港旅遊！！！<br />\n<a href=\"https://lih.kg/1325723\" data-auto-link target=\"_blank\">https://lih.kg/1325723</a><br />\n攬炒巴登報呢場仗未完!! 大家快D上Twitter!!<br />\n<a href=\"https://lih.kg/1360410\" data-auto-link target=\"_blank\">https://lih.kg/1360410</a><br />\n</blockquote><br />\n向外國抗議中國政府散播國家恐怖主義<br />\n向外媒及各國投訴香港警察包庇黑社會合作各自無差別打人，違反通例無預警開槍，已失去合法性<br />\n港鐵作為國際地鐵聯盟之一公然妄顧市民安危強逼市民離開車廂被打<br />\n黑社會涉嫌在元朗發動恐襲襲擊，主腦直指中共政府<br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">自發治安戰線:</span></span></div><br />\n<img src=\"https://na.cx/i/sf52DMn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fsf52DMn.jpg&h=ecc7650f&s={SIZE}\" /><br />\n<blockquote><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /></blockquote><br />\n<blockquote><strong><span style=\"font-size: large;\">香港防衛隊  正式成立<br />\n<a href=\"https://lih.kg/1342844\" data-auto-link target=\"_blank\">https://lih.kg/1342844</a><br />\n【HKSDF】香港自衛隊<br />\n<a href=\"https://lih.kg/1352390\" data-auto-link target=\"_blank\">https://lih.kg/1352390</a><br />\n民間保衛隊初形 公民團結行公義 任何抗命運動適用<br />\n<a href=\"https://lih.kg/1351343\" data-auto-link target=\"_blank\">https://lih.kg/1351343</a><br />\n【元朗恐襲】真心，如果眾籌，成立「香港自衛隊保安公司」優先過登報<br />\n<a href=\"https://lih.kg/1346745\" data-auto-link target=\"_blank\">https://lih.kg/1346745</a><br />\n</span></strong></blockquote><br />\n<span style=\"color: gold;\"><div style=\"text-align: center;\"><span style=\"font-size: xx-large;\">思想革命戰線:</span></div></span><br />\n平民遊戲工作室出條政治片十分值得思考<br />\n<a href=\"https://lih.kg/1357566\" data-auto-link target=\"_blank\">https://lih.kg/1357566</a><br />\n劉細良 香港內戰<br />\n<a href=\"https://youtu.be/QbJTdHbdGIU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FQbJTdHbdGIU&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=97c1ce60\" data-auto-link target=\"_blank\">https://youtu.be/QbJTdHbdGIU</a><br />\n梁天琦 本土自治勇武抗爭嘅理由<br />\n<a href=\"https://youtu.be/36olyar0wHE\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F36olyar0wHE&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=73fca9f6\" data-auto-link target=\"_blank\">https://youtu.be/36olyar0wHE</a><br />\n梁天琦 革命<br />\n<a href=\"https://youtu.be/VEUhAVki0DA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FVEUhAVki0DA&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=99ffd2b2\" data-auto-link target=\"_blank\">https://youtu.be/VEUhAVki0DA</a><br />\n<span style=\"color: gold;\"><div style=\"text-align: center;\"><span style=\"font-size: xx-large;\"><strong>罷工罷課戰線</strong></span></div></span><br />\n<img src=\"https://na.cx/i/O63r9zV.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FO63r9zV.png&h=3f49d80d&s={SIZE}\" /><br />\n［要人］全 港 罷 工 點 解 咁 少 人 響 應 ？<br />\n<a href=\"https://lih.kg/1360282\" data-auto-link target=\"_blank\">https://lih.kg/1360282</a><br />\n各位公務員，罷工啦，post張證同memo無用架<br />\n<a href=\"https://lih.kg/1360210\" data-auto-link target=\"_blank\">https://lih.kg/1360210</a><br />\n致所有高級公務員， 請立即帶頭罷工表示抗議<br />\n<a href=\"https://lih.kg/1359336\" data-auto-link target=\"_blank\">https://lih.kg/1359336</a><br />\n[文宣有圖] 729全港大罷工<br />\n<a href=\"https://lih.kg/1357296\" data-auto-link target=\"_blank\">https://lih.kg/1357296</a><div style=\"text-align: center;\"><span style=\"color: gold;\"><br />\n<span style=\"font-size: xx-large;\">港鐵戰線:</span></div></span><br />\n<img src=\"https://na.cx/i/F4hpgc9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FF4hpgc9.jpg&h=372e2d1d&s={SIZE}\" /><br />\n全面係所有車站招貼: 元朗站逼市民落車被打，妄顧安危<br />\n全面不合作運動，再加宣傳市民全面罷坐港鐵<br />\n<blockquote><br />\n<blockquote><br />\n<strong>[置頂] 724 725 三罷交癱</strong><br />\n大group:<br />\n<a href=\"http://t.me/mtr723\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ft.me%2Fmtr723&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=7a6c93a3\" target=\"_blank\">http://t.me/mtr723</a><br />\n<a href=\"https://lih.kg/1353127\" data-auto-link target=\"_blank\">https://lih.kg/1353127</a><br />\n</blockquote><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\"><br />\n</blockquote><br />\n[gold]<div style=\"text-align: center;\">[size=6]其他紀律部隊戰線:</span></div></span><br />\n拉攏非警察的紀律部隊，要求表態，為違反紀律部隊職責的警察投訴<br />\n<blockquote><br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\"><strong>TG香港本土化<br />\n</strong></span></div><br />\n<a href=\"https://t.me/localization_hk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Flocalization_hk&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=2fa5029e\" data-auto-link target=\"_blank\">https://t.me/localization_hk</a><br />\n香港話<br />\ntg://setlanguage?lang=hongkonger<br />\nChannel list<br />\n<a href=\"http://t.me/hkstandstrong_promo\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ft.me%2Fhkstandstrong_promo&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=9de79f2b\" data-auto-link target=\"_blank\">t.me/hkstandstrong_promo</a><br />\n<a href=\"https://t.me/reminder612\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Freminder612&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=5f57da68\" data-auto-link target=\"_blank\">https://t.me/reminder612</a><br />\n<a href=\"https://t.me/scottscout\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fscottscout&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=9eb291a7\" data-auto-link target=\"_blank\">https://t.me/scottscout</a><br />\n<a href=\"https://t.me/Dadfindboy\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FDadfindboy&d=5pfOjvQv%2F9K29PXjFwfL6c0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=58c80b9b\" data-auto-link target=\"_blank\">https://t.me/Dadfindboy</a><br />\n</blockquote><br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">近期活動：</span></span></div><br />\n<img src=\"https://na.cx/i/e3cgTES.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fe3cgTES.png&h=439e757f&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/7PBQ2yE.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7PBQ2yE.png&h=dba1a54a&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/ckf2PH1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fckf2PH1.png&h=13f53c48&s={SIZE}\" /><br />\n<strong><span style=\"color: gold;\"><span style=\"font-size: xx-large;\">歡迎轉發及引用推Post</span></span></strong>"},{"pid":"3d212b852c25de3bb5e8c2c1fa512b63755b6e07","tid":1364591,"uid":105976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T00:15:33.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1a3132ffe213a80f8fcf9ce9156678d90fe6820f","tid":1364591,"uid":265068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T00:19:41.000Z","msg":"推"},{"pid":"751c8f8be064d66a08da5ae145246e07b25157e5","tid":1364591,"uid":105976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T00:21:27.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ecd8ee003e377375a67650527e4c1543303bf107","tid":1364591,"uid":61463,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-26T00:59:12.000Z","msg":"發夢實測uvex 100%氣密 舒適度 10分 <br />\n四眼仔有機鏡片起霧"},{"pid":"89d18d466c1ae10d7c0c32750dfae5f3d4f0073a","tid":1364591,"uid":105976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T01:32:46.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"192cc2ae2450e007b89fe56b802c9740c280e7ed","tid":1364591,"uid":105976,"like":0,"dislike":0,"score":0,"quote":{"pid":"ecd8ee003e377375a67650527e4c1543303bf107","tid":1364591,"uid":61463,"like":0,"dislike":0,"score":0,"citedBy":1,"reply