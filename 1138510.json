EmbS2k%3D&h=d08bbd8d\" data-auto-link target=\"_blank\">https://hk.on.cc/hk/bkn/cnt/news/20190504/bkn-20190504220424350-0504_00822_001.html</a>"},"citedBy":0,"replyTime":"2019-05-04T19:28:09.000Z","msg":"因署=因休班警經常犯法而多次震怒的警務署"},{"pid":"fb3f5d08a9763ac42636251504ce4e6225906ac1","tid":1138510,"uid":16419,"like":1,"dislike":0,"score":1,"quote":{"pid":"3bf509585d9175ebcb541f5bdc9c0a28f599fbcc","tid":1138510,"uid":89803,"like":0,"dislike":0,"score":0,"quote":{"pid":"eb0718bf163538f82d095945ca5861cb6f9c3199","tid":1138510,"uid":14067,"like":2,"dislike":1,"score":1,"quote":{"pid":"e336506846e4ef297766f1a355c290adbc593d92","tid":1138510,"uid":89803,"like":35,"dislike":0,"score":35,"citedBy":1,"replyTime":"2019-05-04T18:22:46.000Z","msg":"<img src=\"/assets/faces/lm2/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bomb.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/hT6JUCd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhT6JUCd.jpg&h=00797620&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-05-04T18:34:41.000Z","msg":"新相?<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-04T18:39:00.000Z","msg":"係<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-05-04T19:47:01.000Z","msg":"有冇多d新相提供<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"0f97e496b2604257211feb33f334819148be116d","tid":1138510,"uid":27616,"like":14,"dislike":1,"score":13,"citedBy":1,"replyTime":"2019-05-04T19:47:30.000Z","msg":"<img src=\"https://na.cx/i/6xzLoYO.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6xzLoY