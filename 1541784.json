a7e2e1f8e696ca3c880fbd4fd8e4dfd7754","tid":1541784,"uid":268725,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T16:27:51.000Z","msg":"<img src=\"https://na.cx/i/8B39Niu.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8B39Niu.png&h=c9eeccd1&s={SIZE}\" /><br />\n<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"3f06f4f5021fb1c6fe2b8b14d7b3417ca394d589","tid":1541784,"uid":236799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T16:29:05.000Z","msg":"大大聲同人講<span style=\"font-size: xx-large;\">政府認可</span>"},{"pid":"f4e308f1ed5d0aaee8b46862a34bded92f4a14e6","tid":1541784,"uid":211578,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T16:29:34.000Z","msg":"6月9撤回同9月4撤回分別係邊呀?<br />\n<br />\n分別在於:<br />\n3隻眼<br />\n2次地鐵恐襲<br />\n2人被刀手斬至重傷<br />\n8人離世<br />\n超過100人被檢控<br />\n超過1000人被捕<br />\n受傷, 逃亡不計其數<br />\n<br />\n淨係計以上的分別, 已經好明顯。<br />\n還有整個警隊及制度的不公義已暴露。<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">五大訴求，缺一不可！<br />\n光復香港，時代革命！</span></span><br />\n<img src=\"https://na.cx/i/OkC3deC.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOkC3deC.jpg&h=34367fd0&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/D2LPVhj.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FD2LPVhj.jpg&h=35c3dac3&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/C4TBAhk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FC4TBAhk.jpg&h=05bdd3d9&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/t8LoZ1q.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Ft8LoZ1q.jpg&h=fac47d55&s={SIZE}\" />"},{"pid":"22759a2ad4fbf9c6fe5f21c0d7cedb89a0b17901","tid":1541784,"uid":236799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T16:31:59.000Z","msg":"大大力鍚春袋<img src=\"/assets/faces/big/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"545598ba3e45c09c635b861468556cd447cf6293","tid":1541784,"uid":307268,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T16:33:19.000Z","msg":"推"},{"pid":"239b005a84059d141ac78edbede4b50bf93d6f90","tid":1541784,"uid":72730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T16:33:31.000Z","msg":"<span style=\"color: red;\"><strong><span style=\"font-size: xx-large;\">對外講真雙普選，對內講追究警暴</span></strong></span>"},{"pid":"f79f05022dd73144b274244c74416e29bfa2bfaf","tid":1541784,"uid":9049,"like":0,"dislike":0,"score":0,"quote":{"pid":"680a63a68d7dcb6c9a8867e6543c50b6eabe991c","tid":1541784,"uid":285165,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T16:23:11.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-04T16:33:31.000Z","msg":"推<br />\n<br />\n8/9 14:00 美領事館<br />\n<br />\n各地區連儂要人，網上文宣要人！！！<br />\n急急急！！！<br />\n<br />\n<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" /><br />\n全民抗爭，長久戰、拖垮邪惡、打倒腐敗<br />\n<br />\n每日任務：<br />\n1. 抵制支持「邪惡」「無良」的商店，例如cctvb廣告、黨鐵商埸、黑社會、打壓員工的店鋪、減少淘寶<br />\n2. 安全情況下跳閘，免費搭港鐵<br />\n3. 夜晚十點咆哮！！！<br />\n4. 做運動，身體健康，鬥長命<br />\n4. 每日一個post，社交媒體戰（Twitter, IG, Facebook, Reddit) #HongKongProtest<br />\n#FreeHongKong #HongKongProtests #Chinazi<br />\n5. 不要說推，試著將呢段訊息copy and paste嚟推post<br />\n<br />\n每星期任務：<br />\n1. 罷買Bye Buy Day：星期日、星期五(唔買非必需品）<br />\n2. 每星期做孝子，關心下老母老豆老人家，自己老母自己救<br />\n3. 每星期去連儂牆貼3張文宣<br />\n<br />\n每月任務：<br />\n1. 出糧換美金、買美股、少掂中港股票<br />\n2. MPF都買美股<br />\n3. 搵多幾個人參與<br />\n或者做唔足，但我會堅持到尾，Best effort，你呢？<br />\nVersion 2019.09.04"},{"pid":"546d458ef7617b929fcf97053630720df08cf096","tid":1541784,"uid":236799,"like":0,"dislike":0,"score":0,