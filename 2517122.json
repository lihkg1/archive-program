v-RbgoV77hAKW8_6erdH4XW62lxyXAt1TuQ&d=d89kjzbMxLru5B8Znw6mn51DrXAeA17tgS6Eh9jzous%3D&h=78b96822\" data-auto-link target=\"_blank\">https://businessfocus.io/article/162323/%E4%B8%AD%E5%9C%8B%E7%96%AB%E8%8B%97-who?fbclid=IwAR1jGPkc4zXE3fQl4GZICT4wv-RbgoV77hAKW8_6erdH4XW62lxyXAt1TuQ</a>"},"citedBy":0,"replyTime":"2021-05-05T06:46:37.000Z","msg":"港共政府：跟定唔跟好<br />\n<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7c640889afc2cbd803a531114bb9d8a5a99bf839","tid":2517122,"uid":264683,"like":1,"dislike":0,"score":1,"quote":{"pid":"58dc5aaa348fee403929f57b85a5ce3d37130ae7","tid":2517122,"uid":103654,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-05T06:42:06.000Z","msg":"7婆唔係好鍾意拎世衛出嚟擋子彈咩<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />今次提都唔提？我屌你老母呀"},"citedBy":0,"replyTime":"2021-05-05T06:48:54.000Z","msg":"會淨係提 獲得世衛組織的緊急使用授權 呢句<br />\n咩冇關鍵數據 就係政治化"},{"pid":"f1d8a7207cc0f13f7a5d6d53c71b68c680441a45","tid":2517122,"uid":3241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-05T06:49:39.000Z","msg":"翠翠又夠數科水交保護費"},{"pid":"a6d1ea84c327df0957b4bafd4fd1eb9430486fb9","tid":2517122,"uid":251732,"like":0,"dislike":0,"score":0,"quote":{"pid":"9bb33c19c7d7f73a8607839177c24487f9dc94dc","tid":2517122,"uid":249242,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-05T06:46:17.000Z","msg":"保護費未收齊喎"},"citedBy":0,"replyTime":"2021-05-05T06:49:50.000Z","msg":"淨係交到短期數<img src=\"/assets/faces/lm2/frownsmile.gif\" class=\"hkgmoji\" />"},{"pid":"c1676059da3338e1a6cb25473ab275712920d45f","tid":2517122,"uid":198841,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-05T06:50:00.000Z","msg":"冇老人數據一直都知啦，笑恥唔知係咪屎忽痕叫老人打先啫"},{"pid":"84b6be73a5d520186c12b013bf184a736a60494a","tid":2517122,"uid":9542,"like":0,"dislik