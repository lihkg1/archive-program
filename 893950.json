/na.cx/i/01qw48J.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F01qw48J.jpg&h=00ddd080&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-11-08T06:23:46.000Z","msg":"如果問左HR 都冇反映 就去勞工處問下 <br />\n但建議準備轉工吧"},{"pid":"399c9739d10b52c412bdf59be8b820afa453cf1a","tid":893950,"uid":19990,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-08T06:26:44.000Z","msg":"我都做過政府外判，頭三個月好似公眾假期無錢，同埋公眾假期唔係全部有錢，要法定假日先有，<br />\n屍match啲人係態度差既，話人無禮貌佢地都無禮貌啦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"950066c2f646fa4135786c7573d6633e6af2ecdf","tid":893950,"uid":152604,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-11-08T06:31:37.000Z","msg":"外判會食你頭3個月嘅假期<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n同埋簽時有無問跟勞工假定銀行假?如果你勞工假聖誕節又比人扣錢喇<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"3ebe0a70c1d5d4fd8114dce05322276ff6734281","tid":893950,"uid":19990,"like":0,"dislike":0,"score":0,"quote":{"pid":"950066c2f646fa4135786c7573d6633e6af2ecdf","tid":893950,"uid":152604,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-11-08T06:31:37.000Z","msg":"外判會食你頭3個月嘅假期<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n同埋簽時有無問跟勞工假定銀行假?如果你勞工假聖誕節又比人扣錢喇<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-08T06:35:28.000Z","msg":"我無記錯係咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n頭三個月公眾假期無錢"},{"pid":"55a484579f297e58c96b9673c12063be9a380dc9","tid":893950,"uid":152604,"like":0,"dislike":0,"score":0,"quote":{"pid":"3ebe0a70c1d5d4fd8114dce05322276ff6734281","tid":893950,"uid":19990,"like":0,"dislike":0,"score":0,"quote":{"pid":"950066c2f646fa4135786c7573d6633e6af2ecdf","tid":893950,"uid":152604,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-11-08T06:31:37.000Z","msg":"外判會食你頭3個月嘅假期<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n同埋簽時有無問跟勞工假定銀行假?如果你勞工假聖誕節又比人扣錢喇<img src=\"