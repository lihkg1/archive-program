oji\" />"},{"pid":"297ac6d57b872ca6fc55b512952f9ed737ab0df2","tid":476403,"uid":77769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T04:22:25.000Z","msg":"推"},{"pid":"5aaf92a2d06f8dcab013f695342f178bd7acfbf5","tid":476403,"uid":6247,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T04:31:55.000Z","msg":"推"},{"pid":"ccb3f28cc3914c7c4e68121e09be6d131c42ca17","tid":476403,"uid":9412,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T04:59:41.000Z","msg":"樓主<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"ed13a605a208523b25b2baf3332516c758669567","tid":476403,"uid":86938,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:05:18.000Z","msg":"應該有30左右 雖然出哂毛但唔係好大。。野生真係唔知俾咩佢食好<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 我手養果D 未學識食 瓜子肉蛋黃素之前都係人手沖D鳥用專奶粉佢地飲，不過天氣涼唔注意佢地既保暖"},{"pid":"51f25113c6165535f3c9a43a294a150482f635bf","tid":476403,"uid":34515,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-22T05:11:24.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/11/22/130956_c7c48b2c826e4deaba4e00577654d842.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F22%2F130956_c7c48b2c826e4deaba4e00577654d842.jpg&h=750f4dc1&s={SIZE}\" /><br />\n呢堆嘢有奶粉熟蛋麥皮熱糖水"},{"pid":"4487943e5b580814b4a3fcbe9a586fc0c1cd5e32","tid":476403,"uid":34515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:11:57.000Z","msg":"推"},{"pid":"223e3a7a820cbca3cf3adbcc0799863e80965c6e","tid":476403,"uid":63075,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:26:13.000Z","msg":"雀b 每兩三粒鐘就要食野<br />\n消化得好快<br />\n都市人好難養<br />\n買d"},{"pid":"b9db07bf261c8760b1bac30528befcdf01bd3f97","tid":476403,"uid":34515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:26:14.000Z","msg":"餵咗一次雜食又訓左<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <br />\n好似有啲太痴gep 加翻少少奶粉一陣再試"},{"pid":"fbd134aa51ff33fa2f30fec6212dafbb8928b50a","tid":476403,"uid":154702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:29:03.000Z","msg":"肯食？"},{"pid":"9aea71c2f2197e2b1b8e7df2065d9b0f3f8b5e31","tid":476403,"uid":81995,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-11-22T05:30:05.000Z","msg":"樓主好波，多謝你出手救左條生命"},{"pid":"5c2460dd9bbca7a43c69ba0adfcc8d9145e55eec","tid":476403,"uid":149566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:33:21.000Z","msg":"<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> pish"},{"pid":"34e8578ebb12065e4129e07bed393d3486bc0a85","tid":476403,"uid":34515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:40:25.000Z","msg":"<blockquote>肯食？</blockquote><br />\n肯食呀 佢訓醒開眼之後會周圍望下<br />\n我就攞支牙簽拮嗰粒嘢食俾佢 係佢面前郁下郁下就會擘大口食"},{"pid":"d55103ee6a555a09decd6837817d78c84281e42f","tid":476403,"uid":34515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:41:30.000Z","msg":"<blockquote>雀b 每兩三粒鐘就要食野<br />\n消化得好快<br />\n都市人好難養<br />\n買d</blockquote><br />\n暫時嚟講都得閒嘅呢幾日<br />\n會同屋企人輪流照顧"},{"pid":"055494b3dc15f87fc186fc637138740776a06860","tid":476403,"uid":115644,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-11-22T05:41:37.000Z","msg":"珍惜眼前人，勿摸活家禽"},{"pid":"f3b6438bb907dee2148fee0d14ce2ecac8317162","tid":476403,"uid":34515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:42:28.000Z","msg":"又輕輕一推<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"96e30e0feb3ed22317c93908a477afc1770d09c9","tid":476403,"uid":33190,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:42:56.000Z","msg":"呢個好笑"},{"pid":"035034dae73e51e82e256dfa7f08d86fc7f0f3ba","tid":476403,"uid":27568,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:45:08.000Z","msg":"老豆成日執雀<br />\n雀仔最好食蟲<br />\n否則就雀糧浸軟俾佢食<br />\n再無就生果、麵包、飯<br />\n要整到好細份<br />\n用飲筒斜切一下，不俾佢食<br />\n一小時要餵3~4次<br />\n想餵佢時細力搖下裝佢個杯的邊<br />\n佢就會以為雀媽降落<br />\n擘大個口，就可以塞食物俾佢<br />\n不過太大件可能哽死的<br />\n<br />\n<span style=\"color: red;\">但雀最好都係食蟲，否則可能會影響佢發育</span>"},{"pid":"b67d14502b05b0312bb3b7e3f2943bcd338fa6d1","tid":476403,"uid":27568,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:47:29.000Z","msg":"<blockquote>老豆成日執雀<br />\n雀仔最好食蟲<br />\n否則就雀糧浸軟俾佢食<br />\n再無就生果、麵包、飯<br />\n要整到好細份<br />\n用飲筒斜切一下，不俾佢食<br />\n一小時要餵3~4次<br />\n想餵佢時細力搖下裝佢個杯的邊<br />\n佢就會以為雀媽降落<br />\n擘大個口，就可以塞食物俾佢<br />\n不過太大件可能哽死的<br />\n<br />\n<span style=\"color: red;\">但雀最好都係食蟲，否則可能會影響佢發育</span></blockquote><br />\n補充<br />\n麥皮蟲要整死先餵<br />\n草蜢要切好細細粒唔係哽死<br />\n如果你可以用手餵食物<br />\n佢大個會比較親你"},{"pid":"9c46622dab76127db58a4c8c6984c39e0134f2fd","tid":476403,"uid":34515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:48:11.000Z","msg":"<blockquote>老豆成日執雀<br />\n雀仔最好食蟲<br />\n否則就雀糧浸軟俾佢食<br />\n再無就生果、麵包、飯<br />\n要整到好細份<br />\n用飲筒斜切一下，不俾佢食<br />\n一小時要餵3~4次<br />\n想餵佢時細力搖下裝佢個杯的邊<br />\n佢就會以為雀媽降落<br />\n擘大個口，就可以塞食物俾佢<br />\n不過太大件可能哽死的<br />\n<br />\n<span style=\"color: red;\">但雀最好都係食蟲，否則可能會影響佢發育</span></blockquote><br />\n係呀係呀<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> 模仿雀媽降落佢醒嗰下超得意"},{"pid":"77beecfaf22c346844590877262b3693ff444847","tid":476403,"uid":34515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-22T05:52:15.000Z","msg":"<blockquote><blockquote>老豆成日執雀<br />\n雀仔最好食蟲<br />\n否則就雀糧浸軟俾佢食<br />\n再無就生果、麵包、飯<br />\n要整到好細份<br />\n用飲筒斜切一下，不俾佢食<br />\n一小時要餵3~4次<br />\n想餵佢時細力搖下裝佢個杯的邊<br />\n佢就會以為雀媽降落<br />\n擘大個口，就可以塞食物俾佢<br />\n不過太大件可能哽死的<br />\n<br />\n<span style=\"color: red;\">但雀最好都係食蟲，否則可能會影響佢發育</span></blockquote><br />\n補充<br />\n麥皮蟲要整死先餵<br />\n草蜢要切好細細粒唔係哽死<br />\n如果你可以用手餵食物<br />\n佢大個會比較親你</blockquote><br />\n咁如果我養咗佢 佢係咪就會失去獨立生存嘅能力 <br />\n定係 去到某個階段佢會