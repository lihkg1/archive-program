g src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"537294512d953000a64c46c28ea9420ee1ddd741","tid":1846651,"uid":92353,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-27T18:23:10.000Z","msg":"每日150個垃圾"},{"pid":"a30bf717e8a9ab281ce81131c3a7e4562d18b907","tid":1846651,"uid":39550,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T18:23:40.000Z","msg":"直接送去牆角度"},{"pid":"a57ed4a601b14927dcf00abaf7d06d3623dcb2cd","tid":1846651,"uid":303054,"like":0,"dislike":0,"score":0,"quote":{"pid":"6c685534cd54589f2938b6ac6492a849c61840d9","tid":1846651,"uid":312526,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2020-01-27T17:22:39.000Z","msg":"洗唔洗加埋黎明行動 有有少少掛住"},"citedBy":0,"replyTime":"2020-01-27T18:23:55.000Z","msg":"會有"},{"pid":"934373d3a0f806a4f215e1f20615c7723b404c2a","tid":1846651,"uid":38563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T18:24:12.000Z","msg":"黎明行動送頭<br />\n港島遊行集會送頭<br />\n深夜整連儂牆送頭<br />\n派傳單都會畀藍絲割肚不了<br />\n<br />\n而家我哋打旗號叫政府封關阻肺炎呀<br />\n民建聯都唔會夠膽出聲反對啦 粉嶺單野政府都hea應啦<br />\n<br />\n另外想問工會過咗咁多個月有幾多人入咗會？<br />\n全民大三罷？<br />\n唔好話無限期啦 就算一日 短期內我都睇唔出我哋有咩條件做得到 到時幾多生化人入咗關？再搞無限期三罷已經遲<br />\n<span style=\"color: red;\">因為到時已經有唔少香港人奶咗野 咁醫護仲點罷工呀</span><br />\n<br />\n醒下啦送頭<br />\n你話畀我知唔送頭仲可以點"},{"pid":"486b03dc89fb1246a7790a371a051ffef5953992","tid":1846651,"uid":173191,"like":14,"dislike":0,"score":14,"citedBy":1,"replyTime":"2020-01-27T18:25:07.000Z","msg":"<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">有精神病直接打鎮靜劑<br />\n唔洗講咁多嘢<br />\n邊條仆街中國人<br />\n係度嘈嘈閉<br />\n就打鎮定劑 麻醉針<br />\n屌你老母閪 <br />\n依家唔係老奉要醫你</span></span></strong>"},{"pid":"f9ca2e48328d0c081499391ebca516b3453794f9","tid":1846651,"uid":184500,"like":0,"dislike":0,"score":0,"quote":{"pid":"0ea438c544395bd937fa47eaf044798e183fcc78","tid":1846651,"uid":331861,"like":67,"dislike":0,"score":67,"