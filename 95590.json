b9f11ae06f96c48add19c841ffbcf46f","tid":95590,"uid":25483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T07:11:30.000Z","msg":"以前玩過反曲打開18米<br />\n等樓主留tg"},{"pid":"936fcc8c6f0da81551d2eb545c7733d4a1285cc9","tid":95590,"uid":20815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T07:12:42.000Z","msg":"<blockquote><blockquote>點瞄準</blockquote><br />\n現代弓有瞄準器<br />\n<img src=\"http://www.k-archery.com.au/shop/images/products/sights/ss_ultimaRC_mv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.k-archery.com.au%2Fshop%2Fimages%2Fproducts%2Fsights%2Fss_ultimaRC_mv.jpg&h=6009bbdd&s={SIZE}\" /></blockquote><br />\n有個識射箭既朋友教我手動瞄準，即係舉起手指公同望住座山，但我無論focus座山定手指公 都有重影<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> (focus 手指，山有重影；focus 山，手指有重影) sorry 1999 總之我都唔係好明點瞄<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"774f45ae936da73c68ec84eb1c8e4b519d5dfc98","tid":95590,"uid":1593,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T07:13:11.000Z","msg":"淨係有興趣日本既弓道<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"386db797b015ffa833ae7d78f849720c27bb00a7","tid":95590,"uid":53151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T07:16:36.000Z","msg":"Guys Whatsapp only please cause we only have whatsapp group"},{"pid":"1edfc4f341004caffc100ec8e2d90ede13e180f6","tid":95590,"uid":25676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T07:18:16.000Z","msg":"<blockquote>Guys Whatsapp only please cause we only have whatsapp group</blockquote><br />\n我whatsapp 咗你，但你無覆我"},{"pid":"c88ed86cb7a75c9ae0ebd4485c02a8a142b68a1e","tid":95590,"uid":1246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T07:27:21.000Z","msg":"<blockquote><blockquote><blockquote>點瞄準</blockquote><br />\n現代弓有瞄準器<br />\n<img src=\"http://www.k-archery.com.au/shop/images/products/sights/ss_ultimaRC_mv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.k-archery.com.au%2Fshop%2Fimages%2Fproducts%2Fsights%2Fss_ultimaRC_mv.jpg&h=6009bbdd&s={SIZE}\" /></blockquote><br />\n有個識射箭既朋友教我手動瞄準，即係舉起手指公同望住座山，但我無論focus座山定手指公 都有重影<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> (focus 手指，山有重影；focus 山，手指有重影) sorry 1999 總之我都唔係好明點瞄<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n你個friend玩開咩弓，射出去既箭係有拋物線，用𣈴準器可以調突高低左右黎令到支箭落到你𣈴準既位置，但手指每次都係同一個位置，佢會唔會唔係𣈴中心位<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bcd18fd710e8d4e022cc81aeb399f3bc156b2c53","tid":95590,"uid":20815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T07:30:22.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>點瞄準</blockquote><br />\n現代弓有瞄準器<br />\n<img src=\"http://www.k-archery.com.au/shop/images/products/sights/ss_ultimaRC_mv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.k-archery.com.au%2Fshop%2Fimages%2Fproducts%2Fsights%2Fss_ultimaRC_mv.jpg&h=6009bbdd&s={SIZE}\" /></blockquote><br />\n有個識射箭既朋友教我手動瞄準，即係舉起手指公同望住座山，但我無論focus座山定手指公 都有重影<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> (focus 手指，山有重影；focus 山，手指有重影) sorry 1999 總之我都唔係好明點瞄<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n你個friend玩開咩弓，射出去既箭係有拋物線，用𣈴準器可以調突高低左右黎令到支箭落到你𣈴準既位置，但手指每次都係同一個位置，佢會唔會唔係𣈴中心位<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n佢應該係高手黎，收錢教人果啲<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" /> 可能佢想教我啲基本野唔好靠瞄準器"},{"pid":"44504e216d4955a8e38cd8196c9cf9916649954f","tid":95590,"uid":53151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T07:46:39.000Z","msg":"<img src=\"https://i.ytimg.com/vi/PiX5g7zjbWE/maxresdefault.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.ytimg.com%2Fvi%2FPiX5g7zjbWE%2Fmaxresdefault.jpg&h=14c8a25e&s={SIZE}\" />"},{"pid":"c59238170390c1f40c4fef058a67516bb4af5b75","tid":95590,"uid":53151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T10:46:31.000Z","msg":"<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"},{"pid":"af55e8bbdb2e21e9d74f411fea8293df5384ee92","tid":95590,"uid":53151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T17:11:24.000Z","msg":"<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0ece50bcd4169ea6c4be658861315caf059ae1d0","tid":95590,"uid":56690,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T02:41:22.000Z","msg":"留名 <img src=\"/assets/faces/big/lomore_bouncer.gif\" class=\"hkgmoji\" />"},{"pid":"3718407782c6c2fb3b10584e83642c7a87c1f6e7","tid":95590,"uid":15282,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T03:35:24.000Z","msg":"好奇問下 條弦會唔會彈親塊面？"},{"pid":"2c395499f4299f54d4967e5fca2f1981e8471bb6","tid":95590,"uid":56697,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T03:40:43.000Z","msg":"<blockquote>好奇問下 條弦會唔會彈親塊面？</blockquote><br />\n<br />\n正常唔會嘅，但放嘅位置唔啱可能會打親嘴"},{"pid":"94904bcabfc3dcff37670cd03ddcb4c5afd70ae6","tid":95590,"uid":342,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T03:45:07.000Z","msg":"長期潛水但想知多啲入唔入得<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"933c515d02207d46abed6d554db0bd6f18f4d9ad","tid":95590,"uid":53151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T08:46:25.000Z","msg":"<blockquote>長期潛水但想知多啲入唔入得<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoj