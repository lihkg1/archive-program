url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.google.com%2Famp%2Fs%2Fnews.ltn.com.tw%2Famp%2Fnews%2Fworld%2Fbreakingnews%2F2946314&d=P9V%2Fg5HR%2BYIczjwvlITT9PG%2BV2qV11Yco%2FuAlnZU2is%3D&h=33d35184\" target=\"_blank\">https://www.google.com/amp/s/news.ltn.com.tw/amp/news/world/breakingnews/2946314</a>"},{"pid":"1185b0622a9cf8c802e12b69e20f10c163490f20","tid":1655144,"uid":103325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T05:32:01.000Z","msg":"中央唔俾香港人當兵，就係怕你地武裝同佢對抗&hellip;而家班差佬真係中晒呢個死穴，完事後仲唔清算你地咩"}]}