normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ccb951d62c08161ed613a346ff4817a28b6a466b","tid":273713,"uid":16590,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-06T19:24:28.000Z","msg":"<blockquote>紅樹林<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n仲有仙跡岩<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1545803447813fc9527849cb0104c35a1594cbf8","tid":273713,"uid":16590,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-06-06T19:26:41.000Z","msg":"<blockquote>睇錯yahoo</blockquote><br />\nyahoo同yoho一樣咁撚廢<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"3893599b37fd9ec44653fe25de64355fb5f4a3b3","tid":273713,"uid":32721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-06T19:27:34.000Z","msg":"一期商場條走廊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n拎黎練短跑就啱晒"},{"pid":"a69f3dc36f599344df50fb23bb4a1af662a86e8a","tid":273713,"uid":16590,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-06T19:33:11.000Z","msg":"<blockquote>一期商場條走廊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n拎黎練短跑就啱晒</blockquote><br />\n一期即係邊到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 唔識分新元中同midtown係邊期打邊期<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1a97f6123ade3981ab949494991e567fd35b5c32","tid":273713,"uid":30565,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-06T19:58:41.000Z","msg":"<blockquote><blockquote>一期商場條走廊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n拎黎練短跑就啱晒</blockquote><br />\n一期即係邊到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 唔識分新元中同midtown係邊期打邊期<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n新元中2期 midtown 1"},{"pid":"6978c16fb7827f9785934415b6209814540791df","tid":273713,"uid":14595,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-06T20:10:05.0