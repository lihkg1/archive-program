:"做特別服務的保安就應該加人工<br />\n好過全港保安為期四個月每月多一千<br />\n<br />\n講真做客服、牙醫仲危險過保安<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8707e989413802a681bdbe0a4ae3e120355b0f64","tid":1886461,"uid":200663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-21T16:06:21.000Z","msg":"push"},{"pid":"61d3e314009038bef88e9addf331f2f059f7f5c0","tid":1886461,"uid":209390,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-21T16:07:50.000Z","msg":"Popo直頭入去住"}]}