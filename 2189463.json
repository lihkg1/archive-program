humbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FT7mkfRv.jpg&h=3e79e263&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/sq05rYc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fsq05rYc.jpg&h=9bef53cd&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/sjb8pKY.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fsjb8pKY.jpg&h=413b365f&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-09-05T12:21:31.000Z","msg":"團費幾錢? 800美金?"},"citedBy":1,"replyTime":"2020-09-05T12:57:10.000Z","msg":"每日250美金"},"citedBy":1,"replyTime":"2020-09-05T13:30:28.000Z","msg":"去4日3夜岩唔岩?"},{"pid":"99d15e78844ca031ef66b65807764595e14f9c88","tid":2189463,"uid":370202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-05T14:31:32.000Z","msg":"Lm"},{"pid":"42b596239b92079f16dc28e4e1fb0d0757509a76","tid":2189463,"uid":45044,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-05T18:10:30.000Z","msg":"可唔可以list個洗費表出黎？想參考下"},{"pid":"8858dc49f5a2745f44993874618ed7a817cf64f8","tid":2189463,"uid":199392,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-05T19:08:17.000Z","msg":"其實香港啲旅行社係咪食水好深？我見至少2萬"},{"pid":"c9423fd54177605b0b7199726651f5aa6a6af4ca","tid":2189463,"uid":323949,"like":0,"dislike":0,"score":0,"quote":{"pid":"c5f456c5ed1fb66c642bfe9de9668af21696c657","tid":2189463,"uid":75597,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-05T13:02:56.000Z","msg":"有冇行上虎穴寺？行到想死但好正<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-09-05T19:44:50.000Z","msg":"無去 離遠見到"},{"pid":"b358599a99a3b5c4f3b248d8802844cd6808542d","tid":2189463,"uid":323949,"like":0,"dislike":0,"score":0,"quote":{"pid":"986110c69fb425f0eb85cd34a5a35ec65b26e602","tid":2189463,"uid":6833,"like":0,"dislike":0,"score":0,"quote":{"pid":"169989cf416d388c54889ff3b2ecb0c54001b0d9","tid":2189463,"uid":75597,"like":0,"dislike":0,"score":0,"quote":{"pid":"38f93019b4258ce38473e519a9