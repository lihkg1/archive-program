es/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f3b6ac64739d3da7fd5a7185a1d702afaa784d3c","tid":1575512,"uid":173427,"like":0,"dislike":0,"score":0,"quote":{"pid":"a43d25363da69548289fb861b36e4ae32f63b7de","tid":1575512,"uid":286792,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-09-17T03:01:03.000Z","msg":"火車點會有婚外情啊<img src=\"/assets/faces/dog/zzz.gif\" class=\"hkgmoji\" /><br />\n<br />\n如果有人噉唸係佢自己9<br />\n唔需要港人一齊陪佢"},"citedBy":0,"replyTime":"2019-09-17T04:38:35.000Z","msg":"可能身有屎<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"9e5b56ff5f83f1b896ac5fb0518f1283360bae2b","tid":1575512,"uid":181318,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T04:39:47.000Z","msg":"咩人諗咩野"},{"pid":"247502b05f9973981b5fef406791f1d3d185994d","tid":1575512,"uid":111372,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-17T04:41:41.000Z","msg":"斬腳趾避沙蟲，明明出軌係本意，婚外情只係俗既用法，因而讓路，同香港政府一9樣。"},{"pid":"3e016c1ced1c3f47ca34293c68bc8e4f59d75803","tid":1575512,"uid":100882,"like":0,"dislike":0,"score":0,"quote":{"pid":"c48a86357352d72f5d75e16c8d105d38b0a242a7","tid":1575512,"uid":95138,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-09-17T01:27:48.000Z","msg":"2018-4-7 16:28字體： A A A<br />\n立法會今日就高鐵「一地兩檢」草案舉行公聽會，運輸及房屋局局長陳帆在會上將高鐵出軌事件形容為「甩轆事件」，引起民主及建制派議員不滿。<br />\n<br />\n陳帆當時表示，「就住頭先所講嘅所謂『甩轆』事件呢，的而且確廠方已經喺星期四派員嚟到香港」。經民聯林健鋒其後批評，「依家『甩轆』咩？你又答『甩轆』事件，係咪有件咁嘅嘢啊？歪理講得多就變真㗎啦，唔該你陣間澄清同埋矯正」。公民黨譚文豪亦指，現時列車明顯「出軌」，「咁咪講『出軌』囉」。<br />\n<br />\n陳帆解釋自己為何將事件稱為「甩轆」時，他指自己口中的「甩轆」代表小瑕疵，而非形容車輪分離，「detachment of wheel」。至於為何不用「出軌」，則因為有關詞語的英文可以翻譯為「affairs」，即婚外情，所以不想用這個字。<br />\n<br />\n然而將事件形容成「甩轆」而非「出軌」，亦不代表事件的嚴重性會大大減低。香港不時發生涉及「甩轆」的交通意外，2015年一輛紅色小巴於牛頭角「甩轆」後，飛出的輪胎更擊中路過的女途人，她最終傷重不治死亡。兩日前，牛頭角亦發生「甩轆」事件，一名路過的老婦被擊中，受傷送院。"},"citedBy":0,"replyTime":"2019-09-17T05:02:41.000Z","msg":"嚴重可以死好多人，咁都話小瑕疵<img src=\"/assets/faces/mf/angry.gif\" class=\"hkgmoji\" />"},{"pid":"e2645aa5aa3eb39a3bb65c8ada35896c0cf10a1f","tid":1575512,"uid":59447,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T05:03:51.000Z","msg":"崩口人？<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"d53d858943f735a152822a2d7ffb0a2afdda0bcf","tid":1575512,"uid":175731,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T05:05:23.000Z","msg":"小學畢業<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"174cffe3a9219f64a80e0a1bd11cefdf3f193d8b","tid":1575512,"uid":295699,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T05:14:50.000Z","msg":"咩事呀<br />\n崩口人忌崩口碗呀宜家<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"}]}