023ba96","tid":1059100,"uid":160807,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-03-14T12:17:12.000Z","msg":"推"},{"pid":"51e51c705ce66b71f043f896f46c8bd90b983886","tid":1059100,"uid":47147,"like":1,"dislike":7,"score":-6,"citedBy":0,"replyTime":"2019-03-14T12:24:11.000Z","msg":"此回覆已被刪除"},{"pid":"c240aaadd506c6aae9e7fd9c74aef2f7084df260","tid":1059100,"uid":27116,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-03-14T12:30:12.000Z","msg":"時任校監 陳之望<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://nextplus.nextmedia.com/article/2_403024_0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnextplus.nextmedia.com%2Farticle%2F2_403024_0&d=WTugOjWmLb2R3dS25JBA%2BRnxOJLX742lx1SCoot1iYY%3D&h=58f83c0b\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnextplus.nextmedia.com%2Farticle%2F2_403024_0&h=5938a1b6\" data-auto-link target=\"_blank\">https://nextplus.nextmedia.com/article/2_403024_0</a><br />\n<br />\n反圍標大聯盟召集人林卓廷<span style=\"color: red;\">不願評論浩熙及相關公司是否涉及圍標</span>，「只能夠講，浩熙喺行內非常出名」。他亦指出顧問費超低及在招標準則中特定條款，做法令人質疑。他更指假如其餘六座大樓同樣需要維修，<span style=\"color: red;\">天價工程費隨時會令法團一億元儲備基金都乾塘。 </span><br />\n<br />\n本刊記者曾致電浩熙，希望了解如何以超低價完成合約，以及回應今次被點名事件，公司暫時未有回覆。公司註冊處資料就顯示，浩熙共有兩間，分別是浩熙建築工程顧問公司及浩熙建築（集團）有限公司，由同一批人士出任董事，包括陳之望、王劭祥、姚偉祥及黃寶基。其中，<span style=\"color: red;\">陳之望是培正中、小學校監，他同時亦是浸信會聯會董事</span>、香港中山學會主席及浸會愛群社會服務處主席。<br />\n<br />\n上樑不正下樑歪<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/rAHURja.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrAHURja.png&h=1452ce02&s={SIZE}\" />"},{"pid":"e4660d52f8039429cc03d8a9395d840965a4effe","tid":1059100,"uid":161684,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-03-14T13:02:33.000Z","msg":"推"}]}