,"msg":"Gum 9?"},{"pid":"aaa7637f53fd78243d51579636a1f3a1bfd20a32","tid":1302822,"uid":161990,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T07:58:15.000Z","msg":"sentttttt"},{"pid":"18d5d3c02a26f78d002217fcfcc91a0709998923","tid":1302822,"uid":266378,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T08:04:43.000Z","msg":"推"},{"pid":"9611353ba276f1c008880f4514a441a647551f24","tid":1302822,"uid":161990,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T09:14:38.000Z","msg":"推"},{"pid":"0daa20ee7fbff2cb34370240cd862f1b3ecebc3c","tid":1302822,"uid":272196,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T09:15:02.000Z","msg":"push"},{"pid":"f16e5e6d75810bc48b90201024f2ea52835d58ab","tid":1302822,"uid":192997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T09:19:34.000Z","msg":"Sent<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c651d09a1f0bc41b4c27c60f2215b6fa2e496958","tid":1302822,"uid":104171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T10:11:14.000Z","msg":"講真最主要係兩樣野<br />\n<br />\n1. 用「真誠」呢個主觀字眼任佢判決<br />\n本身參選人都要簽聲明架喇<br />\n但問題係聲明具法律效力<br />\n本身平時d聲明都係架啦 簽嘅就簽<br />\n唔會要求真誠地簽<br />\n真心又唔得 誠心又唔得 全心全意又唔得<br />\n法律野唔應該加呢d主觀字眼<br />\n<br />\n2. 選舉主任作最後定奪冇得上訴<br />\n呢個又係香港d權力過大嘅問題<br />\n本身個聲明有法律效力<br />\n你告佢違反聲明都要交由法庭審<br />\n所以更加唔應該比選舉主任話DQ就DQ<br />\n<br />\n例如d過激言論或者強烈爭取民主，都並非代表參選人效忠咗其他國家/政府，參選人仍然係為左香港好，冇得亂咁話人違反聲明<br />\n<br />\n<br />\n利申：send了"},{"pid":"09b9fd72c3c8458d61fc46be0ac9f901f11ca8d3","tid":1302822,"uid":104171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T10:11:24.000Z","msg":"推推推"},{"pid":"1eaaf85c283a239ff517841a519669ea9b81977d","tid":1302822,"uid":104171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T10:11:40.000Z","msg":"呢個係個好嚴峻嘅問題"}]}