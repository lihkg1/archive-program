-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fww4.sinaimg.cn%2Flarge%2F006ajBdMly1fvejctvedlg30dw09enpk.jpg&h=71a37be0&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-02-03T17:26:13.000Z","msg":"<img src=\"/assets/faces/lny/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/hoho.gif\" class=\"hkgmoji\" /> 圖報好嘢"},{"pid":"76f068feb5ee567bcea8f244754457703a6f5278","tid":1007364,"uid":7699,"like":0,"dislike":0,"score":0,"quote":{"pid":"8607d5957892fc86286896301175cd06a9b64924","tid":1007364,"uid":34643,"like":8,"dislike":0,"score":8,"quote":{"pid":"5fe50fcf262f78b9a7bc527d4d832406c39ccf47","tid":1007364,"uid":7699,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2019-02-03T17:03:20.000Z","msg":"對腳<img src=\"/assets/faces/lny/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/bomb.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-03T17:20:26.000Z","msg":"<img src=\"https://t1.daumcdn.net/cfile/tistory/245EFF3D5714910830?orignal\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ft1.daumcdn.net%2Fcfile%2Ftistory%2F245EFF3D5714910830%3Forignal&h=2c770d56&s={SIZE}\" /><br />\n<img src=\"https://66.media.tumblr.com/38dfe43e89a8ae4b2151169d28d5b529/tumblr_o97dwhAfXa1rlzlwyo1_1280.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2F66.media.tumblr.com%2F38dfe43e89a8ae4b2151169d28d5b529%2Ftumblr_o97dwhAfXa1rlzlwyo1_1280.jpg&h=58021bba&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-02-03T17:43:25.000Z","msg":"晚晚都俾我一個奶<img src=\"/assets/faces/lm2lny/lick.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2lny/lick.gif\" class=\"hkgmoji\" />"},{"pid":"d9a964017db4c18cf3d33e71e006f363229c3ed4","tid":1007364,"uid":197857,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-02-03T17:44:35.000Z","msg":"IU我老婆<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"4b33831f9994536619586ab6ac3bdf433f009ca9","tid":10073