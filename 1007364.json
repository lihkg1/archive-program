sen%2Fnews_photo%2F2014%2F10%2F16%2F201410161108172010_1.jpg&h=6489d8c5&s={SIZE}\" />"},{"pid":"8851892e991cc3332af5cf37c735ac0dcb27b235","tid":1007364,"uid":180124,"like":0,"dislike":0,"score":0,"quote":{"pid":"2beba7bf99754cc78d87f7125e12a0c50bd81046","tid":1007364,"uid":34643,"like":0,"dislike":9,"score":-9,"quote":{"pid":"d478ba2be1d3603479224e74d689073be19a043d","tid":1007364,"uid":76098,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-03T17:09:47.000Z","msg":"右腳損左既"},"citedBy":1,"replyTime":"2019-02-03T17:11:51.000Z","msg":"都係我唔好, 果日玩腳玩得肉緊果頭整損左<img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-03T18:54:02.000Z","msg":"我果日玩佢屎眼整損佢<br />\n唔關你事"},{"pid":"1c0ec4f3c441c07f9c9125c12e2dc8229803e719","tid":1007364,"uid":34643,"like":0,"dislike":0,"score":0,"quote":{"pid":"8851892e991cc3332af5cf37c735ac0dcb27b235","tid":1007364,"uid":180124,"like":0,"dislike":0,"score":0,"quote":{"pid":"2beba7bf99754cc78d87f7125e12a0c50bd81046","tid":1007364,"uid":34643,"like":0,"dislike":9,"score":-9,"quote":{"pid":"d478ba2be1d3603479224e74d689073be19a043d","tid":1007364,"uid":76098,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-03T17:09:47.000Z","msg":"右腳損左既"},"citedBy":1,"replyTime":"2019-02-03T17:11:51.000Z","msg":"都係我唔好, 果日玩腳玩得肉緊果頭整損左<img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-03T18:54:02.000Z","msg":"我果日玩佢屎眼整損佢<br />\n唔關你事"},"citedBy":0,"replyTime":"2019-02-03T20:02:40.000Z","msg":"<img src=\"/assets/faces/lny/clown3.gif\" class=\"hkgmoji\" />"},{"pid":"95a8490c7b9216bc345652b99f9cd1d7d42ea756","tid":1007364,"uid":227503,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-03T20:41:57.000Z","msg":"淫腳<img src=\"/assets/faces/lny/pig1.gif\" class=\"hkgmoji\" />"},{"pid":"a733fd6f75ee8c64505d0aad77cf6b7d953ea8b1","tid":1007364,"uid":555,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-03T21:33:14.000Z","msg":"正撚到"},{"pid":"0553154800c0e0101d80287d4f3f9c5c94638a53","tid":1007364,"uid":34643,"like":13,"dislike":1,"score":12,"quote":{"pid":"95a8490c7b9216bc345652b99f9cd1d7d42ea756","tid":1007364,"uid":227503,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-03T20:41:57.000Z","msg":"淫腳<img src=\"/assets/faces/lny/pig1.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-03T21:37:02.000Z","msg":"天寒地凍，我躺臥在地毯上玩手機，突然感覺褲襠上有東西碰了一下，抬頭一看，原來是IU的那雙小腳，不過她卻不得要領，而且動作還比較生硬。沒辦法，看來我只能慢慢教她了。<br />\n<br />\n當我把她那雙白皙細膩的小腳握在手裏的時候，感覺真的沒法說，就覺得自己手裏握著是一小堆嫩肉，細膩而且柔滑......<br />\n<br />\n<img src=\"https://i.pinimg.com/originals/a9/18/52/a91852cba54099686abb23661f027b32.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.pinimg.com%2Foriginals%2Fa9%2F18%2F52%2Fa91852cba54099686abb23661f027b32.gif&h=5dc73192&s={SIZE}\" /><br />\n<br />\n「來，把右腳貼住我的褲襠，慢慢的上、下揉搓。」說到這裏，我還是怕她不明白，於是輕輕捉住她的右腳，在我的褲襠上上、下揉搓。<br />\n<br />\n當IU的右腳開始隔著褲子上、下摩擦肉棒的時候，我感覺肉棒突然間像充滿電一樣，慢慢的硬了起來，頂著褲子，非常難受。於是我捉住的IU右腳，示意她先停一下，然後我把手伸進內褲裏，把陰莖攥在手裏，並且調整了個角度，讓陰莖豎直的貼在我的小腹上，這樣的話，有內褲的彈性包著陰莖，並且不讓陰莖筆直的挺起，這樣更容易感受足交的快感。<br />\n<br />\n調整完以後，我示意IU可以繼續動作了......<br />\n<br />\n「啊，用腳感覺還真是很大啊！」IU說道。<br />\n<br />\n「那是！我可是血氣方剛的男人啊」<br />\n<br />\n「切！你就是一變態......」<br />\n<br />\n「哈哈哈......」<br />\n<br />\n說歸說，IU的腳卻沒有停，她不停的上下摩擦著我的陰莖，偶爾還用腳背托著我的陰囊，另一隻腳腳尖輕輕撫弄陰囊，再從陰莖根部向上揉搓，這種感覺真是太爽了。<br />\n<br />\n「喂，你怎麼這麼有經驗了？」我強忍著IU這雙美足帶給我的快感問道。<br />\n<br />\n「那誰叫你這麼變態呢，居然喜歡這樣另類的ＳＥＸ！我現在正在網上看關於足交的要點呢。」<br />\n<br />\n<img src=\"https://t1.daumcdn.net/cfile/tistory/2110B350560168FB1D?original\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ft1.daumcdn.net%2Fcfile%2Ftistory%2F2110B350560168FB1D%3Foriginal&h=4f1c3ef8&s={SIZE}\" /><br />\n<br />\n不一會，我明顯的感覺到自己快不行了，於是示意IU停下，伸手把陰莖掏了出來，然後再讓IU繼續；當IU的美足碰到我赤裸在外的陰莖的時，她猶豫的停了一下，然後就又開始在我的陰莖上運動著。<br />\n<br />\n我可以感覺到從龜頭上滲出的液體已經沾濕了IU的美足，可以肯定，IU也一定感覺到了，不過IU並沒有停止，反而加快了足交的速度，有時還故意用她那一排美麗的腳趾在我脹大的龜頭上輕輕的遊走，弄的我渾身酥麻......<br />\n<br />\n「IU，我快射了，把你今天穿的鞋給我，我要射在裏面！」<br />\n<br />\n「別射在這裏好嗎？我可以讓你射在另一雙高跟鞋裏，這雙鞋是我出入正式場合穿的，可以嗎？」<br />\n<br />\n「好的。」<br />\n<br />\n說完，IU便把這雙鞋遞到了我手裏。看到這裏，然後用手捉住IU的那雙美足，讓IU的美足輕輕夾住我的陰莖套弄。<br />\n<br />\n不一會，我感覺龜頭一陣酥麻，馬眼一松，大量濃濃的精液噴湧而出。就在射精的一瞬間，我把IU的那雙高跟鞋對準了陰莖，只見大量的精液湧進了IU的鞋裏......<br />\n<br />\n「啊，你射的還真多啊！」當我把鞋遞還給IU的時候，她看著鞋裏的精液說道。<br />\n<br />\n「沒辦法啊，你實在是太誘人了！」我說的是實話。<br />\n<br />\n<img src=\"http://cfile7.uf.tistory.com/original/2509C74B585A38981BF666\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcfile7.uf.tistory.com%2Foriginal%2F2509C74B585A38981BF666&h=27797f11&s={SIZE}\" />"},{"pid":"716b7391a67d187ead7675cfa669f10db56208dd","tid":1007364,"uid":227503,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0553154800c0e0101d80287d4f3f9c5c94638a53","tid":1007364,"uid":34643,"like":13,"dislike":1,"score":12,"quote":{"pid":"95a8490c7b9216bc345652b99f9cd1d7d42ea756","tid":1007364,"uid":227503,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-03T20:41:57.000Z","msg":"淫腳<img src=\"/assets/faces/lny/pig1.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-03T21:37:02.000Z","msg":"天寒地凍，我躺臥在地毯上玩手機，突然感覺褲襠上有東西碰了一下，抬頭一看，原來是IU的那雙小腳，不過她卻不得要領，而且動作還比較生硬。沒辦法，看來我只能慢慢教她了。<br />\n<br />\n當我把她那雙白皙細膩的小腳握在手裏的時候，感覺真的沒法說，就覺得自己手裏握著是一小堆嫩肉，細膩而且柔滑......<br />\n<br />\n<img src=\"https://i.pinimg.com/originals/a9/18/52/a91852cba54099686abb23661f027b32.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.pinimg.com%2Foriginals%2Fa9%2F18%2F52%2Fa91852cba54099686abb23661f027b32.gif&h=5dc73192&s={SIZE}\" /><br />\n<br />\n「來，把右腳貼住我的褲襠，慢慢的上、下揉搓。」說到這裏，我還是怕她不明白，於是輕輕捉住她的右腳，在我的褲襠上上、下揉搓。<br />\n<br />\n當IU的右腳開始隔著褲子上、下摩擦肉棒的時候，我感覺肉棒突然間像充滿電一樣，慢慢的硬了起來，頂著褲子，非常難受。於是我捉住的IU右腳，示意她先停一下，然後我把手伸進內褲裏，把陰莖攥在手裏，並且調整了個角度，讓陰莖豎直的貼在我的小腹上，這樣的話，有內褲的彈性包著陰莖，並且不讓陰莖筆直的挺起，這樣更容易感受足交的快感。<br />\n<br />\n調整完以後，我示意IU可以繼續動作了......<br />\n<br />\n「啊，用腳感覺還真是很大啊！」IU說道。<br />\n<br />\n「那是！我可是血氣方剛的男人啊」<br />\n<br />\n「切！你就是一變態......」<br />\n<br />\n「哈哈哈......」<br />\n<br />\n說歸說，IU的腳卻沒有停，她不停的上下摩擦著我的陰莖，偶爾還用腳背托著我的陰囊，另一隻腳腳尖輕輕撫弄陰囊，再從陰莖根部向上揉搓，這種感覺真是太爽了。<br />\n<br />\n「喂，你怎麼這