g.eservice-hk.net%2Fupload%2F2018%2F09%2F12%2F090133_5650ca6133d63662c3cfa9f006e0719d.png&h=ece49599&s={SIZE}\" /><br />\n<br />\n用緊data up住3張先<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"3d80219f1d1e0d008842628cdfab3884e62287ec","tid":815210,"uid":7131,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-09-12T01:30:58.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"6a2134d5f3815e88a6eb4d86e8282b60bd42a01d","tid":815210,"uid":159293,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-12T03:27:05.000Z","msg":"靚撚到痴線<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n巴打去咗幾耐？有冇乜奇怪特別嘢分享下<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"5d61e29dae9eea45d22692ec04f72d11a52145b8","tid":815210,"uid":7131,"like":13,"dislike":0,"score":13,"quote":{"pid":"6a2134d5f3815e88a6eb4d86e8282b60bd42a01d","tid":815210,"uid":159293,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-12T03:27:05.000Z","msg":"靚撚到痴線<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n巴打去咗幾耐？有冇乜奇怪特別嘢分享下<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-12T09:28:50.000Z","msg":"一個月<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n有樣野幾得意 <br />\n去完北面Myvatn就諗住落東面<br />\n咁有位先生好好心就肯車我，開左一陣就停左係個地熱溫泉隔離<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n之後佢就係地底拎左兩條蛋糕出黎 原來係冰島人用地熱焗既面包<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <br />\n試下一舊 覺得似蛋糕多過面包 之後落車仲送左條煙熏魚俾我<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"10dec836bdf4f21b39c7364ed51bb522a4fe76da","tid":815210,"uid":7131,"like":25,"dislike":0,"score":25,"citedBy":1,"replyTime":"2018-09-12T09:35:52.000Z","msg":"仲有一樣野幾得意就係 <br />\n係Skaftafell等緊好心人個陣 有另外兩個hitchhiker又係到等緊 係個呀哥帶住個細佬<br />\n呀哥應該27歲左加 細佬睇個樣應該仲讀緊中學<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" /> <br />\n跟住有一架載遊客去行冰川既van仔一野車晒我地去下一個地方<img src=\"/assets/faces/lomoji/36.png\" class=\"hkgmoji\" /> <br />\n<br />\n出賣佢兩兄弟先<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/09/12/173532_500c9cdf0c0666b8fd27309a5f9efa46.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F12%2F173532_500c9cdf0c0666b8fd27309a5f9efa46.png&h=8bec5e89&s={SIZE}\" />"},{"pid":"f8e20b15f6a2a361bcf63f4b5e31609dce256d5a","tid":815210,"uid":7131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-12T12:50:52.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"be1aebcead67001aec3f3b3c56dfc529274bd9b8","tid":815210,"uid":33777,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-12T13:58:35.000Z","msg":"點Hitchhiking法?"},{"pid":"018798b2090ac575d0f800b781e09cc242d300dc","tid":815210,"uid":7131,"like":0,"dislike":0,"score":0,"quote":{"pid":"be1aebcead67001aec3f3b3c56dfc529274bd9b8","tid":815210,"uid":33777,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-12T13:58:35.000Z","msg":"點Hitchhiking法?"},"citedBy":1,"replyTime":"2018-09-12T16:10:37.000Z","msg":"由首都Rekjavik出發，去左Westfjord, Akureyri, Husavik, Egilsstadir, Skaftafell, Vik<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"17cf011ec9c36eda2cb2f42d7ce49c19108d138d","tid":815210,"uid":7131,"like":0,"dislike":0,"score":0,"quote":{"pid":"018798b2090ac575d0f800b781e09cc242d300dc","tid":815210,"uid":7131,"like":0,"dislike":0,"score":0,"quote":{"pid":"be1aebcead67001aec3f3b3c56dfc529274bd9b8","tid":815210,"uid":33777,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-12T13:58:35.000Z","msg":"點Hitchhiking法?"},"citedBy":1,"replyTime":"2018-09-12T16:10:37.000Z","msg":"由首都Rekjavik出發，去左Westfjord, Akureyri, Husavik, Egilsstadir, Skaftafell, Vik<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-12T16:10:54.000Z","msg":"仲有Myvatn<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"e787dd78fe1c861c593bf1ddfcb1c012ffe8ee33","tid":815210,"uid":133896,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-12T16:15:10.000Z","msg":"巴打好勇敢，係咩驅使你走出comfort zone? 我每日就係返工放工<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"160d3a64b1538c4535cf2dcd255fc06e7a07bb88","tid":815210,"uid":7131,"like":7,"dislike":0,"score":7,"quote":{"pid":"e787dd78fe1c861c593bf1ddfcb1c012ffe8ee33","tid":815210,"uid":133896,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-12T16:15:10.000Z","msg":"巴打好勇敢，係咩驅使你走出comfort zone? 我每日就係返工放工<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-13T00:23:06.000Z","msg":"人一世物一世 咩都試下<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n冇信心就試等一程順風車 一程巴士咁<br />\n試試下就ok架啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"489d59c01ef005cdb74a662c84422c69e6521f4c","tid":815210,"uid":7131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-13T04:38:00.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"75630bd091e68dce128243aee521b40554d9ff9b","tid":815210,"uid":183708,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-13T05:12:46.000Z","msg":"好彩UO 無直飛咋，唔係呢個post 一定上熱門"},{"pid":"3934e6357a1fdd4054b98f0874f72953e67ee02b","tid":815210,"uid":7131,"like":1,"dislike":0,"score":1,"quote":{"pid":"75630bd091e68dce128243aee521b40554d9ff9b","tid":815210,"uid":183708,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-13T05:12:46.000Z","msg":"好彩UO 無直飛咋，唔係呢個post 一定上熱門"},"citedBy":0,"replyTime":"2018-09-13T06:30:16.000Z","msg":"其實而家去平過同易過以前好多了<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"fad5c650d961908de8dc41f356f5e88a8fb2630d","tid":815210,"uid":7131,"like":0,"dislike":0,"score":0,"citedBy