/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"10cb1501b943b7130e3ce7e1a4d863884616e923","tid":832760,"uid":47663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-24T17:29:20.000Z","msg":"食野油膩？<br />\n有飲凍野？<br />\n<br />\n個人濕就會咁"},{"pid":"7dfee2db3ce2857132ab716d8c9b44b47a53a23b","tid":832760,"uid":55835,"like":1,"dislike":0,"score":1,"quote":{"pid":"171db461e20b2216b029d66023777037cb59b230","tid":832760,"uid":204429,"like":2,"dislike":3,"score":-1,"quote":{"pid":"15cc18471fadcb81309c81bfe369c3b61eb11ecf","tid":832760,"uid":188310,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-23T04:32:38.000Z","msg":"試下飲益力多，唔得就要睇醫生<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-24T17:24:10.000Z","msg":"膠都廢事比<img src=\"/assets/faces/mf/clown.gif\" class=\"hkgmoji\" />   益力多得糖咋 有菌都死埋啦運送中途"},"citedBy":1,"replyTime":"2018-09-24T17:30:51.000Z","msg":"肚痛post LM<img src=\"/assets/faces/mf/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\n我都有呢個情況，自己係iherb 訂益生菌，大約食左一個月左右，開始調較到腸胃<br />\n<br />\n二黎要留一下自己平時飲食習慣，睇下少食多餐有無幫助，或者似少幾杯奶茶檸茶，消化力弱自然會多屎<img src=\"/assets/faces/mf/z.gif\" class=\"hkgmoji\" /> <br />\n<br />\n仲有就係一定要&ldquo;介&rdquo;凍飲，之前睇中醫話係胃寒所致<br />\n<br />\n而家我久唔久腸胃都會作反，但慢慢都找到個原因係邊，叫做慢慢改善緊<img src=\"/assets/faces/mf/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"8589fef00fd89aa4f1f36a0c6626323cf1a2fd24","tid":832760,"uid":211385,"like":0,"dislike":0,"score":0,"quote":{"pid":"3ab83eb069a6ef057b88eaa19dc90a6214ff773c","tid":832760,"uid":63760,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-24T17:17:48.000Z","msg":"大便有冇潺?"},"citedBy":0,"replyTime":"2018-09-24T19:28:17.000Z","msg":"唔知潺係點解<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n但好多時唔係一舊舊"},{"pid":"14b0c08edf25ea83de3cb04668eb5bc8fdd3e5d2","tid":832760,"uid":211385,"like":0,"dislike":0,"score":0,"quote":{"pid":"