經過4,5間中原<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"04c0b70808c2a4e9b94f208fbc2078832fadc756","tid":874584,"uid":33868,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-25T02:23:41.000Z","msg":"你廢丫嘛，你無用丫嘛，你唔開單你番黎做乜撚野呀？"},{"pid":"2e93d6cf6a4a8dd5e5fc7af636ad37e915743079","tid":874584,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-30T09:48:31.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"1255ec9a103cb879008db11f504cbe95b87ca72d","tid":874584,"uid":156652,"like":0,"dislike":0,"score":0,"quote":{"pid":"04c0b70808c2a4e9b94f208fbc2078832fadc756","tid":874584,"uid":33868,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-25T02:23:41.000Z","msg":"你廢丫嘛，你無用丫嘛，你唔開單你番黎做乜撚野呀？"},"citedBy":0,"replyTime":"2018-10-30T09:49:36.000Z","msg":"<img src=\"https://na.cx/i/DeoUB6a.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDeoUB6a.gif&h=ffaf68c8&s={SIZE}\" />"}]}