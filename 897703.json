ormal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"13f553a26a4affb68e42e379d642293caeea5f17","tid":897703,"uid":133319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-11T09:40:41.000Z","msg":"做乜鳩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cc9747f76bea1f6994e89df6acf49ec610735a53","tid":897703,"uid":931,"like":0,"dislike":0,"score":0,"quote":{"pid":"9a4ef281ddeb49efc5c7cfc6356b2db9365092b8","tid":897703,"uid":42188,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-11-11T07:01:10.000Z","msg":"蘋果公司推出的iPhone XS、iPhone XS Max及iPhone XR新手機將於明日（21日）在港公開發售，其中以6.5吋屏幕的iPhone XS Max最觸目，但該款手機近日被女權分子批評屏幕過大，不適合雙手纖細的女性，屬性別歧視。蘋果公司暫時未回應批評，不過有網民指巿面有很多款手機，何不購買其他牌子的智能手機。<br />\n<br />\n蘋果公司在香港時間上周四（13日）舉行發布會，介紹新手機iPhone XS、XS Max及XR，屏幕大小分別是5.8吋、6.5吋及6.1吋，比過往iPhone更大，同時在官方網站剔除4款舊型號手機，包括4吋屏幕的iPhone SE，意味會停產。<br />\n<br />\n消息傳出後，除了有炒家關注新iPhone能否「炒得起」外，更引起女權分子的不滿。女權分子卡洛琳（Caroline Criado Perez）在英國倫敦國會廣場內、一座約百年前當地女權運動領導人福西特夫人（Millicent Fawcett）的雕像後方向傳媒表示：「當我使用iPhone 6（屏幕4.7吋）時患上『重複性勞損』，但轉用iPhone SE，情況得到改善。」她認為「手機屏幕大小的確會影響女性手部健康，而女性比男性買更多iPhone，我感到很困惑，為何蘋果公司沒有為女性著想」。她認為女性應該為此感到憤怒，「我們和男人付相同價錢，但產品不利我們」。<br />\n<br />\n卡洛琳指智能手機十分重要，「但現時我需要作出選擇︰在適合普遍女性手部大小、2年前舊iPhone產品停產前將手機升級，還是買一部會導致你會有『重複性勞損』的新iPhone。」她指在21世紀的今天，有關情況是不能接受。<br />\n<br />\n英國工黨國會議員傑斯（Jess Phillips）亦認為，科技設計公司所發明的產品都是以男性標準為主，公司應搞清楚他們所認為的「正常標準」囊括所有顧客，包括女性。<br />\n<br />\n女性平權黨主席蘇菲（Sophie Walker）則指，蘋果公司英國總部的兩性員工薪酬相差24%，而花紅上，男性員工更較女性員工高出57%，她不認為男性管理層在考慮產品時會考慮女性顧客，亦覺得若蘋果公司沒有女性管理層，以至女性在商業、政治及其他公共領域上都沒有得到平等待遇，她們的需要多數被忽視。<br />\n<br />\n婦女權利組織福西特協會執行長山姆．史穆德（Sam Smethers）認為，無論是服務、產品還是世界各地的工作，若由女性負責設計，對象亦針對女性，將改善她們的生活。<br />\n<br />\n新款iPhone被指歧視女性的言論起網民討論，有人在卡洛琳的Twitter帳號留言，指「這是否笑話？如果不是，我感到震驚」；亦有人稱「市面上有不同屏幕尺寸的智能手機可供選擇」；有網民指「如果iPhone不適合普遍女性的手部大小，蘋果公司是限制了自己的市場」，但同時批評卡洛琳愚蠢，質疑她為何不購買Android手機。"},"citedBy":0,"replyTime":"2018-11-11T10:05:01.000Z","msg":"要取消用lighting 頭，會令女權聯想被插的感覺<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b66cf864300295d81b700aa2d5964f22aee60fa8","tid":897703,"uid":31028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-11T10:25:22.000Z","msg":"女性明明比男性更鐘意用大機<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e1d4666f6953f4313e824b332328bdd6c3d40db2","tid":897703,"uid":58604,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-11-11T11:04:20.000Z","msg":"Ipad直頭歧視人類<br />\n明顯比巨人族用<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2ba959dbe35ab45538b56b1701bf7acd29c09ed0","tid":897703,"uid":72608,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-11T11:30:22.000Z","msg":"今個世紀人類最大倒退 : 女權撚"},{"pid":"2e1026ab0446e215b914e0a9ff3e93b6f59dba3a","tid":897703,"uid":145277,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-11T11:35:22.000Z","msg":"明明係d女人想要大mon睇片appl先出大mon機，班偽女權又喺度拎存在感"},{"pid":"8e0a286698296403283145a6521d86bed834380e","tid":897703,"uid":145277,"like":0,"dislike":0,"score":0,"quote":{"pid":"9a4ef281ddeb49efc5c7cfc6356b2db9365092b8","tid":897703,"uid":42188,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-11-11T07:01:10.000Z","msg":"蘋果公司推出的iPhone XS、iPhone XS Max及iPhone XR新手機將於明日（21日）在港公開發售，其中以6.5吋屏幕的iPhone XS Max最觸目，但該款手機近日被女權分子批評屏幕過大，不適合雙手纖細的女性，屬性別歧視。蘋果公司暫時未回應批評，不過有網民指巿面有很多款手機，何不購買其他牌子的智能手機。<br />\n<br />\n蘋果公司在香港時間上周四（13日）舉行發布會，介紹新手機iPhone XS、XS Max及XR，屏幕大小分別是5.8吋、6.5吋及6.1吋，比過往iPhone更大，同時在官方網站剔除4款舊型號手機，包括4吋屏幕的iPhone SE，意味會停產。<br />\n<br />\n消息傳出後，除了有炒家關注新iPhone能否「炒得起」外，更引起女權分子的不滿。女權分子卡洛琳（Caroline Criado Perez）在英國倫敦國會廣場內、一座約百年前當地女權運動領導人福西特夫人（Millicent Fawcett）的雕像後方向傳媒表示：「當我使用iPhone 6（屏幕4.7吋）時患上『重複性勞損』，但轉用iPhone SE，情況得到改善。」她認為「手機屏幕大小的確會影響女性手部健康，而女性比男性買更多iPhone，我感到很困惑，為何蘋果公司沒有為女性著想」。她認為女性應該為此感到憤怒，「我們和男人付相同價錢，但產品不利我們」。<br />\n<br />\n卡洛琳指智能手機十分重要，「但現時我需要作出選擇︰在適合普遍女性手部大小、2年前舊iPhone產品停產前將手機升級，還是買一部會導致你會有『重複性勞損』的新iPhone。」她指在21世紀的今天，有關情況是不能接受。<br />\n<br />\n英國工黨國會議員傑斯（Jess Phillips）亦認為，科技設計公司所發明的產品都是以男性標準為主，公司應搞清楚他們所認為的「正常標準」囊括所有顧客，包括女性。<br />\n<br />\n女性平權黨主席蘇菲（Sophie Walker）則指，蘋果公司英國總部的兩性員工薪酬相差2