7%2F04%2F26%2F092807_649c7e996caf6272ea36675781cce96d.jpg&h=47491604&s={SIZE}\" /><img src=\"https://na.cx/i/WifkjDg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWifkjDg.jpg&h=b511b2b7&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/04/26/092810_4dea66c3e66caa3b0ee3efc832bb08e8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F04%2F26%2F092810_4dea66c3e66caa3b0ee3efc832bb08e8.jpg&h=7cda48b6&s={SIZE}\" /><br />\n<br />\n雖然比唔上而家既game <br />\n1個ser入得千幾個ac<br />\n一個人又百幾個分身<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n<br />\n但係都想玩番<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n你望下依家吞食天地三先啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n就算佢再點樣出我都唔會再玩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n又膠又唔好笑<br />\n童年嘅回憶已經冇咗<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"4e50d43e71ea8f55b45333fbe7dc386c5911af38","tid":217584,"uid":5148,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-26T01:41:10.000Z","msg":"飄流咪出左<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3a3f4e2f95c23e9a85b7736f1bce60cd8cfc9af6","tid":217584,"uid":12438,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-04-26T01:41:23.000Z","msg":"我指吞1出手機版<br />\n吞2-3我玩左前期就冇玩<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"db8d9b1749173ed32ae44fda203d8dafc80eea4e","tid":217584,"uid":73426,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-04-26T01:45:20.000Z","msg":"吞1真係世界級<br />\n係我最鍾意既online game<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"2ee20b5e9f7a01d1addee56359f3d4dd8f7e3790","tid":217584,"uid":12438,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-26T03:30:10.000Z","msg":"<blockquote>飄流咪出左<img src=\"/assets/faces/normal/