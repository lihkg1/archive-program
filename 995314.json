d":995314,"uid":50310,"like":2,"dislike":0,"score":2,"quote":{"pid":"8b464cdba9ed467833196bcd02e90f23564feda0","tid":995314,"uid":20867,"like":0,"dislike":0,"score":0,"quote":{"pid":"a06e64285ae16fb03fc95bc393f42b18871d3f36","tid":995314,"uid":8776,"like":1,"dislike":1,"score":0,"quote":{"pid":"b937460a570256751717c64b0550f433acb746e8","tid":995314,"uid":103230,"like":106,"dislike":1,"score":105,"citedBy":8,"replyTime":"2019-01-25T11:03:09.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://attach.setn.com/newsimages/2018/08/18/1502652-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2018%2F08%2F18%2F1502652-XXL.jpg&h=4541bc0b&s={SIZE}\" /><br />\n<br />\n點車仔面咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2019-01-25T14:50:17.000Z","msg":"Tick A罩杯，大乳量會點？"},"citedBy":1,"replyTime":"2019-01-25T21:47:29.000Z","msg":"個芡汁要分開上"},"citedBy":0,"replyTime":"2019-01-26T03:59:13.000Z","msg":"考眼力反打格挑戰：<br />\n口爆<br />\n顏射<br />\n二王一后<br />\n後門<br />\n無套做<br />\n可中出<br />\n<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},{"pid":"105d174674153f8e2a32761767d8fcaa6595af23","tid":995314,"uid":76310,"like":0,"dislike":0,"score":0,"quote":{"pid":"b937460a570256751717c64b0550f433acb746e8","tid":995314,"uid":103230,"like":106,"dislike":1,"score":105,"citedBy":8,"replyTime":"2019-01-25T11:03:09.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://attach.setn.com/newsimages/2018/08/18/1502652-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2018%2F08%2F18%2F1502652-XXL.jpg&h=4541bc0b&s={SIZE}\" /><br />\n<br />\n點車仔面咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-26T04:01:57.000Z","msg":"一見到笑鬼左 車仔麵咁<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"ccfd0a50143976396e6b2796db2995d15a8ff22f","tid":995314,"uid":35648,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-26T04:25:55.000Z","msg":"日本古代潮文關羽炒飯<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /> <br />\n<br />\n今日、バイトを終えて家に帰ったら、何故か台所に関羽がいた。 <br />\n　　　　　関羽は、チャーハンを炒めながら俺に <br />\n　　　　　「やあ、おかえり」と微笑みかけた。 <br />\n　　　　　俺は、なぜ俺の家の台所に関羽がいるのかわからずに当惑したが <br />\n　　　　　「た、ただいま」 <br />\n　　　　　とぎこちなく微笑みかえした。 <br />\n　　　　　その後、関羽が作ったチャーハンを食べた。 <br />\n　　　　　うまかった。 <br />\n<br />\n　　　　　そんだけ。 <br />\n<br />\n關羽邊炒著炒飯邊微笑著對我說「呀，你回來啦」。<br />\n雖然對關羽為什麼會出現在我家廚房而感到困惑，<br />\n還是生硬的微笑著答到「我、我回來了」。<br />\n之後，吃了關羽做的炒飯。<br />\n很好吃。<br />\n就這樣。"},{"pid":"a00218a638d91544b487bf7551d73d67a1428b71","tid":995314,"uid":40588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-26T04:36:26.000Z","msg":"陸遜我ok"}]}