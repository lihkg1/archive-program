/i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.seegc.com.tw%2F%2Fseegc%2Fwp-content%2Fuploads%2F2016%2F10%2FIMG_1933.jpg&h=d30c3bdb&s={SIZE}\" />"},{"pid":"90c61461a3197ba478c0cfc4fd16d94140872ce5","tid":995314,"uid":208722,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-25T11:43:12.000Z","msg":"有無解格嘅點心紙望望<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"964861ca2489e02ef0cd3ee04b7e68bdaa258a18","tid":995314,"uid":11148,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2019-01-25T11:48:23.000Z","msg":"乳暈大小顏色深淺都有得揀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"61c854484be005d4cfd4765ecf732db1ffd60775","tid":995314,"uid":192311,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-01-25T11:54:03.000Z","msg":"佢啲格打左同無打差唔多啫<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n屌但係都有人可以二皇一后睇做二女一杯<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"84391289615860d76a119b43913377fdbb1d549d","tid":995314,"uid":196310,"like":0,"dislike":2,"score":-2,"quote":{"pid":"8f5e697980f6fd6a6607c431af5812d717c5e653","tid":995314,"uid":32511,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-25T10:37:26.000Z","msg":"雖然警方持續積極掃黃，但應召站仍如雨後春筍一般湧出，且他們為了攬到更多客人，招數更是推陳出新，不只用低價取勝、女明星名字當花名，還出現音樂老師、三國應召站和「毒龍絕技」等噱頭，讓人看了不禁瞠目結舌。<br />\n<br />\n<img src=\"https://attach.setn.com/newsimages/2017/02/15/810329-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2017%2F02%2F15%2F810329-XXL.jpg&h=ebfcd297&s={SIZE}\" /><br />\n<br />\n<img src=\"https://attach.setn.com/newsimages/2017/02/15/810331-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2017%2F02%2F15%2F810331-XXL.jpg&h=30667dec&s={SIZE}\" /><br />\n<br />\n音樂老師給你特別處罰<br />\n <br />\n新北市土城分局去年出曾發現有論壇出現「依蝶音樂學院」招生訊息，不料點進去竟看到數張女子性感清涼照，還留下「嚴格的老師會給壞壞的你特別的處罰唷！」等字句，暗中從事色情交易，專案人員即刻前往查緝。結果警方到了現場，發現裡面的小姐是聘用印尼籍逃逸外勞，和前來按摩的男客從事性交易。<br />\n<br />\n<img src=\"https://attach.setn.com/newsimages/2018/05/21/1367975-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2018%2F05%2F21%2F1367975-XXL.jpg&h=d9807b9e&s={SIZE}\" /><br />\n<br />\n三國應召站<br />\n <br />\n台北市萬華分局在去年執行網路巡邏時，發現應召站在網路論壇刊登廣告，並利用正妹清涼照攬客，接著再仲介對方前往商務旅館性交易。事後在警方跟監蒐證下，果然逮捕6名應召女子，但詭異的是裡面女子的名字竟是「關羽、小喬、陸遜」等三國人物的名稱。<br />\n<br />\n<img src=\"https://attach.setn.com/newsimages/2018/06/21/1411149-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2018%2F06%2F21%2F1411149-XXL.jpg&h=db6d2d16&s={SIZE}\" /><br />\n<br />\n仿效荷蘭櫥窗女郎<br />\n <br />\n去年6月警方發現，外籍女子大舉入侵基隆鐵支路進行性交易，後來才知道業者攬客招數推陳出新，近年來吸引不少外國女子來台賣淫，並讓這些女子站在紅磚平樓內，仿效荷蘭櫥窗女郎，且要求她們模仿日韓妝髮，增加嫖客戀愛感。<br />\n<br />\n<img src=\"https://attach.setn.com/newsimages/2018/08/18/1502651-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2018%2F08%2F18%2F1502651-XXL.jpg&h=3358464d&s={SIZE}\" /><br />\n<br />\n<img src=\"https://attach.setn.com/newsimages/2018/08/18/1502652-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2018%2F08%2F18%2F1502652-XXL.jpg&h=44c694bd&s={SIZE}\" /><br />\n<br />\n「毒龍絕技」攬客<br />\n <br />\n2名女高職生去年暑假找打工時，意外應徵到應召站的工作，隨後她們緊急想辦法脫身報警。之後警方前往該處攻堅時，發現裡面大多是越南女子來台賣淫，為了吸引客人，還主打雙飛、輕功、毒龍等獨門絕技吸引客人，甚至可以依照嫖客需求，讓他們自由勾選喜歡的小姐類型和招數。<br />\n<br />\n<img src=\"https://attach.setn.com/newsimages/2019/01/24/1752231-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2019%2F01%2F24%2F1752231-XXL.jpg&h=f08beb37&s={SIZE}\" /><br />\n<br />\n高價位玩到爽<br />\n <br />\n不少色情業者會打出超低價吸引嫖客，但日前移民署北區事務大隊機動隊在網路巡邏時，發現有應召集團招募大陸及泰國籍女子利用自由行觀光機會，讓她們來台賣淫。而警方深入集團內部搜索時，發現其中一名身材火辣女子是裡面的紅牌「G奶蜜桃」，且該集團還主打加價無套性交易、大玩SM性虐待，配合度超高的服務也讓價格高達7800元。"},"citedBy":1,"replyTime":"2019-01-25T11:55:36.000Z","msg":"小弟才疏學淺， 請問乜嘢 叫做輕功呢"},{"pid":"d5aaf8e8ce61f05ecef61fa71e18ca3ee84545df","tid":995314,"uid":3189,"like":0,"dislike":0,"score":0,"quote":{"pid":"90c61461a3197ba478c0cfc4fd16d94140872ce5","tid":995314,"uid":208722,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-25T11:43:12.000Z","msg":"有無解格嘅點心紙望望<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-25T11:56:22.000Z","msg":"我都想睇"},{"pid":"037f37338f521683251cc2fa9b2f5b9752ea2613","tid":995314,"uid":202340,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-25T11:57:16.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"6b205b8659d8df2330bda0a555496654e491f547","tid":995314,"uid":43173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-25T11:58:32.000Z","msg":"以為去咗食車仔麵"},{"pid":"235f5cc6dba2f80ea01fbd77f389a870d74bcc63","tid":995314,"uid":113626,"like":0,"dislike":0,"score":0,"quote":{"pid":"b937460a570256751717c64b0550f433acb746e8","tid":995314,"uid":103230,"like":106,"dislike":1,"score":105,"citedBy":8,"replyTime":"2019-01-25T11:03:09.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://attach.setn.com/newsimages/2018/08/18/1502652-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2018%2F08%2F18%2F1502652-XXL.jpg&h=4541bc0b&s={SIZE}\" /><br />\n<br />\n點車仔面咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-25T12:01:35.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"294532fbf23aea3659ef798752a89247cb9e3d54","tid":995314,"uid":210992,"like":1,"dislike":0,"score":1,"quote":{"pid":"61c854484be005d4cfd4765ecf732db1ffd60775","tid":995314,"uid":192311,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-01-25T11:54:03.000Z","msg":"佢啲格打左同無打差唔多啫<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n屌但係都有人可以二皇一后睇做二女一杯<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-25T12:03:24.000Z","msg":"佢唔係睇錯， 係佢既深層慾望黎"},{"pid":"2833cec340c78690b46d8da94c286ef02057bb70","tid":995314,"uid":200,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-01-25T12:07:19.000Z","msg":"屌你老味 打機開新角色咁撚樣<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"a06e64285ae16fb03fc95bc393f42b18871d3f36","tid":995314,"uid":8776,"like":1,"dislike":1,"score":0,"quote":{"pid":"b937460a570256751717c64b0550f433acb746e8","tid":995314,"uid":103230,"like":106,"dislike":1,"score":105,"citedBy":8,"replyTime":"2019-01-25T11:03:09.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://attach.setn.com/newsimages/2018/08/18/1502652-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2018%2F08%2F18%2F1502652-XXL.jpg&h=4541bc0b&s={SIZE}\" /><br />\n<br />\n點車仔面咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2019-01-25T14:50:17.000Z","msg":"Tick A罩杯，大乳量會點？"},{"pid":"a3d08d1bc7a2d388598fdd4785aab42fd1b1f234","tid":995314,"uid":156363,"like":0,"dislike":0,"score":0,"quote":{"pid":"a06e64285ae16fb03fc95bc393f42b18871d3f36","tid":995314,"uid":8776,"like":1,"dislike":1,"score":0,"quote":{"pid":"b937460a570256751717c64b0550f433acb746e8","tid":995314,"uid":103230,"like":106,"dislike":1,"score":105,"citedBy":8,"replyTime":"2019-01-25T11:03:09.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://attach.setn.com/newsimages/2018/08/18/1502652-XXL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fattach.setn.com%2Fnewsimages%2F2018%2F08%2F18%2F1502652-XXL.jpg&h=4541bc0b&s={SIZE}\" /><br />\n<br />\n點車仔面咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2019-01-25T14:5