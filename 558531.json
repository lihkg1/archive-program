00309_ca90295315a9eadf2a414d041abf4832.png&h=1a1d40a1&s={SIZE}\" /><br />\n<br />\n係時候走人 轉車去浅草<br />\n喺月台見到個奇怪既洗手間<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/200510_de6dce3f69f9e2830562ebff90a06607.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F200510_de6dce3f69f9e2830562ebff90a06607.png&h=22323f64&s={SIZE}\" />"},{"pid":"85de32abbde4af770b8001f7f0ece2240f6e054c","tid":558531,"uid":147233,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-12T12:06:59.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"424883cd82c664e429f508c064d251e6285b0af5","tid":558531,"uid":44814,"like":2,"dislike":2,"score":0,"quote":{"pid":"85de32abbde4af770b8001f7f0ece2240f6e054c","tid":558531,"uid":147233,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-12T12:06:59.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-12T12:10:29.000Z","msg":"甘你老母<br />\n同埋紅白波波都講得出<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 你真係唔知咩黎？"},{"pid":"0f06a175f4c287529faa011f79d1ae31d2572fef","tid":558531,"uid":147233,"like":0,"dislike":0,"score":0,"quote":{"pid":"424883cd82c664e429f508c064d251e6285b0af5","tid":558531,"uid":44814,"like":2,"dislike":2,"score":0,"quote":{"pid":"85de32abbde4af770b8001f7f0ece2240f6e054c","tid":558531,"uid":147233,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-12T12:06:59.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-12T12:10:29.000Z","msg":"甘你老母<br />\n同埋紅白波波都講得出<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 你真係唔知咩黎？"},"citedBy":1,"replyTime":"2018-02-12T12:20:03.000Z","msg":"草間彌生 我叫佢紅白波波係咪務犯左你？"},{"pid":"6746e41e65cf0c4811d56efb01334c87331e9eb1","tid":558531,"uid":147233,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2018-02-12T12:27:45.000Z","msg":"Day 2<br />\n<br />\n相信大家去日本都用轉乘app 不過入淺草入左好耐都入吾到 原來日本名係浅草 自膠<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/202330_833b5c0c14ca26e50b55d2a6e4316c4f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F202330_833b5c0c14ca26e50b55d2a6e4316c4f.png&h=4d862ecd&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/202331_833b5c0c14ca26e50b55d2a6e4316c4f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F202331_833b5c0c14ca26e50b55d2a6e4316c4f.png&h=a591be6c&s={SIZE}\" /><br />\n<br />\n淺草雷門 停左雪開始天光返 終於可以影下靚相<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/202401_150b8c3fb2d8f0db8a7bee6c3bb457de.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F202401_150b8c3fb2d8f0db8a7bee6c3bb457de.png&h=b6b45d23&s={SIZE}\" /><br />\n<br />\n可能依兩日落雪 人唔太多 可以輕鬆行走 不過依d手信街 京都見唔少 冇咩興趣<br />\n食下小食好過<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/202434_99b402d5a635c32bc4982e4ff3b1a986.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F202434_99b402d5a635c32bc4982e4ff3b1a986.png&h=29cc580f&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/202435_6343c795aa140fb727dc01b256680f24.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F202435_6343c795aa140fb727dc01b256680f24.png&h=da114304&s={SIZE}\" /><br />\n<br />\n入寺 原來唔洗入場費<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n求左支凶 不過講真 隨機既野冇咩特別<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/202517_53294aa4bb01f3c1c57cdd398b5979ed.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F202517_53294aa4bb01f3c1c57cdd398b5979ed.png&h=9a7b7795&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/202518_ee48b097b958a6d42ba386373fb665cf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F202518_ee48b097b958a6d42ba386373fb665cf.png&h=62fcfdfa&s={SIZE}\" /><br />\n<br />\n寺旁有d熟食店 唔知係咪有活動先有定長期有 好似行年宵咁<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/202553_4064e5c069a18fcfdf4430db788c2d03.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F202553_4064e5c069a18fcfdf4430db788c2d03.png&h=e28d5441&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/202554_35694e53eaa193fb7f9f4a134d5a8ab1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F202554_35694e53eaa193fb7f9f4a134d5a8ab1.png&h=5724c12a&s={SIZE}\" /><br />\n<br />\n跟住去左間叫宇奈既鰻魚店 一入去已經好濃炭爐味 成身都係<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/202640_0bdb41a5c5fda03a67f9b4f2bba3265d.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F202640_0bdb41a5c5fda03a67f9b4f2bba3265d.png&h=5ce6eaa2&s={SIZE}\" /><br />\n依間出名平價鰻魚飯 又幾平又好味 有幾間分店 好似遲下香港都開分店 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"68665bfc78455180ba0c60fb91cdef8d744763d8","tid":558531,"uid":80046,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-12T12:32:39.000Z","msg":"推"},{"pid":"71f4d29997f4df732d9c9844da9d92f546afca6e","tid":558531,"uid":147233,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-12T12:46:27.000Z","msg":"Day 2<br />\n<br />\n行左去河邊影相 依度影skytree 好清楚<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/204119_d0a76c112077a9ac9b109ec398e6221d.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204119_d0a76c112077a9ac9b109ec398e6221d.png&h=76956a45&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/204121_d59eb62ab267e2654c734102802812bd.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204121_d59eb62ab267e2654c734102802812bd.png&h=99be6d16&s={SIZE}\" /><br />\n<br />\n同patpat小姐影下相<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/204154_8d59bcb6722a95e0d0396144802b4e2c.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204154_8d59bcb6722a95e0d0396144802b4e2c.png&h=4702929f&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/204158_3585625e8201c0d99bfd883091f0941f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204158_3585625e8201c0d99bfd883091f0941f.png&h=2fc5cbf5&s={SIZE}\" /><br />\n<br />\n經過吾妻橋行去skytree<br />\n<br />\n今日冇諗過上塔頂 因為好天會好多人 今日唔好天又冇野睇<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/204240_a8049c4f4c01d760b2bb35611d8a3247.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204240_a8049c4f4c01d760b2bb35611d8a3247.png&h=31e7e111&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/204241_00b0f51cd6f14641399831cea39481e2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204241_00b0f51cd6f14641399831cea39481e2.png&h=c3d043a7&s={SIZE}\" /><br />\n<br />\n塔下有個公園有條好長既滑梯 之前杜如風介紹過已經好想黎<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/204427_ee9b2c8d1c2ee6397a78383c81d0c272.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204427_ee9b2c8d1c2ee6397a78383c81d0c272.png&h=2899ef3f&s={SIZE}\" /><br />\n條梯濕哂 不過黎到 死就死 <br />\n<br />\n滑完條褲濕到渣出水 底褲都冇了 今次仆街了 <br />\nPatpat小姐同我都決定入商場買褲<img src=\"/assets/faces/lomoji/20.png\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/204456_68eb38f842278f2a0498ee030a088e92.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204456_68eb38f842278f2a0498ee030a088e92.png&h=2d54d9b0&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/02/12/204457_a19e6124d2b2baceea0fe384b713c5bb.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204457_a19e6124d2b2baceea0fe384b713c5bb.png&h=628bb622&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/02/12/204458_7ef54bdc19455bb7d0eb28663b24d8f7.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204458_7ef54bdc19455bb7d0eb28663b24d8f7.png&h=d82c108d&s={SIZE}\" /><br />\n<br />\n個商場好大好多個區域 我最愛既有一區賣日本傳統工藝產品 買左d手信<img src=\"/assets/faces/lomoji/14.png\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/204538_76e06165bc8bcf89adbecd3d8a380cf0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204538_76e06165bc8bcf89adbecd3d8a380cf0.png&h=ecec9f6e&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/204539_815afefb18a1d513be3468f91ebdf6cf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F204539_815afefb18a1d513be3468f91ebdf6cf.png&h=8c8ca338&s={SIZE}\" /><br />\n出返黎天黑 返上野食晚飯 順便放低d野 拎左成日<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},{"pid":"d84e51a630f394968001e75825934079ea44839d","tid":558531,"uid":157728,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-12T12:56:06.000Z","msg":"就快去<br />\n留明"},{"pid":"902fc5c139d14ff75190df20a68d3aa022f72c2c","tid":558531,"uid":44814,"like":7,"dislike":0,"score":7,"quote":{"pid":"0f06a175f4c287529faa011f79d1ae31d2572fef","tid":558531,"uid":147233,"like":0,"dislike":0,"score":0,"quote":{"pid":"424883cd82c664e429f508c064d251e6285b0af5","tid":558531,"uid":44814,"like":2,"dislike":2,"score":0,"quote":{"pid":"85de32abbde4af770b8001f7f0ece2240f6e054c","tid":558531,"uid":147233,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-12T12:06:59.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-12T12:10:29.000Z","msg":"甘你老母<br />\n同埋紅白波波都講得出<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 你真係唔知咩黎？"},"citedBy":1,"replyTime":"2018-02-12T12:20:03.000Z","msg":"草間彌生 我叫佢紅白波波係咪務犯左你？"},"citedBy":0,"replyTime":"2018-02-12T12:57:58.000Z","msg":"主要係你字都未打得好<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\nbtw冒犯"},{"pid":"7ffd374f7b950b2690080a56541bd5a3fb3bc11c","tid":558531,"uid":147233,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-02-12T13:08:12.000Z","msg":"Day 2<br />\n喺御徒町搵食 揾左間普通焼肉食<br />\n<br />\n唔太差既 外觀有d乾<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/210417_742eadb8886c3b4dfd50c84257e163c7.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F210417_742eadb8886c3b4dfd50c84257e163c7.png&h=eef3240f&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/210417_d5e5dbb7110f6ddd0e30a30956c8a827.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F210417_d5e5dbb7110f6ddd0e30a30956c8a827.png&h=a110f80e&s={SIZE}\" /><br />\n<br />\n日本差極都叫和牛既 <img src=\"/assets/faces/lomoji/16.png\" class=\"hkgmoji\" /> <br />\n食完見仲早 行去秋葉原諗住夾下公仔<br />\n<br />\n<br />\n一路行一路行<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/210454_56cbba5b86d7a62ddb6ab1566cd25dd0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F210454_56cbba5b86d7a62ddb6ab1566cd25dd0.png&h=aa9b11ef&s={SIZE}\" /><br />\n<br />\n去到電氣街好熱鬧<img src=\"/assets/faces/lomoji/14.png\" class=\"hkgmoji\" /> <br />\n<br />\n電器公司最正當然係玩具果層<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/210537_c253ecf3d85ea93b92cc87eb2e56ea5b.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F210537_c253ecf3d85ea93b92cc87eb2e56ea5b.png&h=b29ddf5d&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/210538_f4eefafa44429015675d7395d1fb1559.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F210538_f4eefafa44429015675d7395d1fb1559.png&h=f5bdabd8&s={SIZE}\" /><br />\n<br />\n屎眼仔我唔太好動漫玩具 細個最鍾情數碼暴龍<br />\n<br />\n變形玩具呀 宜家出到咁靚 不過價錢都好靚 算啦 回憶就由佢繼續回憶 好過出套tri破壞左佢<br />\n<br />\n<br />\nParpat 小姐一心夾公仔 我既一排100円都準備好 <br />\n<br />\n不過秋葉原既夾公仔機會否太毒<br />\n全部都係毒毒公仔<br />\n五六間舗都係 唉 我地想夾可愛公仔呀<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/210456_ae4665139f7b1e19d571d69f8035b4e8.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F210456_ae4665139f7b1e19d571d69f8035b4e8.png&h=d2f03e0a&s={SIZE}\" /><br />\n<br />\n<br />\n放棄走人 行到jr入口見到著名綠色大廈 一於入去見識下 <img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/210643_4a0c5639226715154937cf8ae1eb75f5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F210643_4a0c5639226715154937cf8ae1eb75f5.png&h=e8f675c0&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/210644_50007cf2a48cb6a204dfa3e22902db77.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F210644_50007cf2a48cb6a204dfa3e22902db77.png&h=09b22ba0&s={SIZE}\" /><br />\n哇d假尻令我地大開眼界 推介比大家 <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <br />\n唔好性都入去參觀下 patpat小姐睇得好開心<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/210721_3f710e60c99d1abd5ede5ca091640cc4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F210721_3f710e60c99d1abd5ede5ca091640cc4.png&h=79af4a73&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/210722_de016ed3c0e057b60b47cbd9e08373b9.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F210722_de016ed3c0e057b60b47cbd9e08373b9.png&h=1e59ad6e&s={SIZE}\" />"},{"pid":"d62a79da99188a3cc9a05099d54765b9d80e6bf3","tid":558531,"uid":1398,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-12T13:16:36.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1af2f0afad454525a6e07b063f3b3c97f3f6264b","tid":558531,"uid":80503,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-12T13:21:57.000Z","msg":"lm"},{"pid":"031e16cd21d1c44af305db28a60261d7335caefa","tid":558531,"uid":147233,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-12T13:26:30.000Z","msg":"Day3<br />\n今日一早我地就離開上野 去離酒店兩分鐘步程既豐田租車公司 前往河囗湖<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/212414_7ac83f9d05a09ccd3fe220163f394426.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F212414_7ac83f9d05a09ccd3fe220163f394426.png&h=234ec005&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/212415_e67b5e7853fb70656289ba8af3ad842c.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F212415_e67b5e7853fb70656289ba8af3ad842c.png&h=b08178de&s={SIZE}\" /><br />\n<br />\n今次四日三夜自駕最主要就係富士山<br />\n我地會圍住富士山走一個圈<br />\n唔同角度睇富士山既姿態<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n預先已經book左備有雪軚既五人車 坐三個已經係極限 因為行李箱比較細 要預埋放行李<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/212458_fe307d9fbc0144d0926710063574df6a.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F212458_fe307d9fbc0144d0926710063574df6a.png&h=707f71b7&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/212459_7cff712753aa1ae9f337f087986355ce.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F212459_7cff712753aa1ae9f337f087986355ce.png&h=5bc08b3a&s={SIZE}\" /><br />\n<br />\n不過日本人渣車真係好斯文 唔會好似香港趕頭趕命<br />\n<br />\n睇富士山一定要好好天冇雲先可以 因為佢太高範圍大 遠睇先會完整 冬天去最有機會見到 <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/212546_823061dabe4913c539c5610dad80fb27.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F212546_823061dabe4913c539c5610dad80fb27.png&h=a763f2f4&s={SIZE}\" /><br />\n積雪<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/212546_75b6d82f44d77f991343ee46983d511f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F212546_75b6d82f44d77f991343ee46983d511f.png&h=b1cdcd79&s={SIZE}\" /><br />\n<br />\n一路走以為會好快見到 原來冇架 臨到十分鐘先見到 但係...<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"804a93be3237275bc1f01e748638ae883b36211f","tid":558531,"uid":147233,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-02-12T13:39:45.000Z","msg":"Day 3<br />\n前進去我地今日既目的地－ 河口湖<br />\n睇左半分鐘先肯定係富士山 但佢粒住左個codom <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/213804_dcdd7ea8f480e3614329971fd56493bf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F213804_dcdd7ea8f480e3614329971fd56493bf.png&h=00e70ea7&s={SIZE}\" /><br />\n<br />\n舊codom仲好厚咁 應該冇甘快會散 所以先去食個lunch先<br />\n我地去左一間河囗湖名物 不動烏冬<br />\n十個去河口湖 八個都會去食<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/213833_2d020b9c464f514e4ad0effb36e4a021.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F213833_2d020b9c464f514e4ad0effb36e4a021.png&h=ddaab4a1&s={SIZE}\" /><br />\n<br />\n依間野喺河口湖好多分店 我地去左東戀路外型好特別既分店<br />\n<br />\n佢既主打就係依碗大過我塊面既南瓜烏冬 同埋馬肉刺身<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/213907_a35a0ebc92218eb67dd43b847d7dfd0f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F213907_a35a0ebc92218eb67dd43b847d7dfd0f.png&h=90500696&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/213908_e17287a4e418c8ca7a875a2487205775.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F213908_e17287a4e418c8ca7a875a2487205775.png&h=8daa95d0&s={SIZE}\" /><br />\n<br />\n烏冬就冇咩特別 好味夠熱 分量二人都覺得飽<br />\n<br />\n馬肉刺身 好似生食肥牛 冇咩味道 所以主要點豉油同蒜<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/213942_df91b54fc76d73fdd6318fc5441eb4ba.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F213942_df91b54fc76d73fdd6318fc5441eb4ba.png&h=c86dec72&s={SIZE}\" /><br />\n食完富士山仲未除codom 所以先去一個見唔到富士山既景點"},{"pid":"544bb2a10f87df3649eb92d2976ba1ae3ae4d868","tid":558531,"uid":107577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-12T13:58:00.000Z","msg":"馬肉<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n你描述到個味好似怪怪地<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"6d0f72b900bef1ae4ec2f427fd42084012a2490d","tid":558531,"uid":147233,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-02-12T14:05:32.000Z","msg":"Day3<br />\n我地黎左河口淺間神社 河囗淺間神社雖然冇大社 新倉山果d神社咁大人氣 但好似9世紀後已經興建 歷史悠久<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/220346_3db55c403b4a89f50db9bf9d5a6fe1f2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F220346_3db55c403b4a89f50db9bf9d5a6fe1f2.png&h=b84dd79f&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/220347_2f4b09171633192b065963666351e8d0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F220347_2f4b09171633192b065963666351e8d0.png&h=7a600112&s={SIZE}\" /><br />\n<br />\n入到去已經見到高45米粗過撚既古樹群 加埋d雪景 好有靈氣呀<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/220418_8b40f6e98dbb7a463cdb3da8ed95ed13.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F220418_8b40f6e98dbb7a463cdb3da8ed95ed13.png&h=9e531c7b&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/220419_fa43c7b3947277b432ceed906a1045af.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F220419_fa43c7b3947277b432ceed906a1045af.png&h=9265d9f5&s={SIZE}\" /><br />\n一個冇咩人既神社先有果種神聖既感覺 你唔會去淺草寺感受到<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/220504_dc4cabe5db43bce1c78ea9671b3578e6.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F220504_dc4cabe5db43bce1c78ea9671b3578e6.png&h=b7f30f14&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/220505_21f87ac0546c42f5fa9926fee0f6fd3e.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F220505_21f87ac0546c42f5fa9926fee0f6fd3e.png&h=5689bffa&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/220506_ab088b49ef4cb842cb4ad2556ec356cc.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F220506_ab088b49ef4cb842cb4ad2556ec356cc.png&h=1c329ed9&s={SIZE}\" />"},{"pid":"8fc6be0de7cce666eb041dc3451b05dc75adab6a","tid":558531,"uid":147233,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-12T14:31:18.000Z","msg":"Day3<br />\n上返車去下個景點 大石公園 今日主要都係河口湖周邊 因為四點要checkin <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/222925_ab686504fdf0eee96190127004f9e2ba.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F222925_ab686504fdf0eee96190127004f9e2ba.png&h=7f8cf067&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/222926_46eaa7e2ec117c08e2d4ac20b7cc3ad8.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F222926_46eaa7e2ec117c08e2d4ac20b7cc3ad8.png&h=a4831781&s={SIZE}\" /><br />\n依度係河口湖睇富士山最靚既地方 <br />\n<br />\n哇 舊雲開始消啦 <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/223013_b32a25c792b4bd339382c0ee64e4e7f5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F223013_b32a25c792b4bd339382c0ee64e4e7f5.png&h=a47dce38&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/223013_d866aa3f694ccd22e5ff1ad62fbc6746.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F223013_d866aa3f694ccd22e5ff1ad62fbc6746.png&h=d4717338&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/223014_4678f88d4e43ef07a81ec08998bee2c2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F223014_4678f88d4e43ef07a81ec08998bee2c2.png&h=75b6844b&s={SIZE}\" /><br />\n<br />\n周圍影下相 睇下手信已經半個鐘 完整既富士山出黎啦<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/12/223056_a64bfad8055d8964933ea17f723d212c.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F12%2F223056_a64bfad8055d8964933ea17f723d212c.png&h=0fbdc6a5&s={SIZE}\" /><br />\n好撚靚呀<br />\n<br />\n河口湖既角度係最有人氣既 基本上所有人睇佢都係去河口湖 所以我反而期待之後既角度多d<br />\n<br />\n影左個半鐘 係時候走人 見仲有一個小時 去多個人氣景點"}]}