rc=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"5da09c1531f5c3e1ee76ae8b5c5963e273216f82","tid":1672790,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-25T05:56:07.000Z","msg":"大家幫幫手完善佢啦<br />\n<img src=\"https://na.cx/i/XJfSX1A.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXJfSX1A.png&h=eb2e3c73&s={SIZE}\" />"},{"pid":"3776db0a4357d5e5f3b23de7a6045565c2e473ad","tid":1672790,"uid":224561,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-25T06:01:39.000Z","msg":"我他媽推爆"},{"pid":"b7ffed66f22922db55a58fc303151761624e5d0b","tid":1672790,"uid":284480,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-25T06:08:06.000Z","msg":"<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"9397e471d808d9be194d26f61e33632daa5c9cd5","tid":1672790,"uid":192456,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-25T06:12:55.000Z","msg":"有冇搞事論<br />\n老母成日話我地搞事，講過係對面搞先我地先還擊，但效果唔夠好<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"e8493a01ebd46a273d80954739a4e0c0b547b917","tid":1672790,"uid":71237,"like":1,"dislike":0,"score":1,"quote":{"pid":"9397e471d808d9be194d26f61e33632daa5c9cd5","tid":1672790,"uid":192456,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-25T06:12:55.000Z","msg":"有冇搞事論<br />\n老母成日話我地搞事，講過係對面搞先我地先還擊，但效果唔夠好<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-25T06:23:09.000Z","msg":"我開咗依一頁，交畀其他連登巴打幫手反駁。<br />\n<a href=\"https://debate.fandom.com/zh-hk/wiki/示威者搞事論\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdebate.fandom.com%2Fzh-hk%2Fwiki%2F%E7%A4%BA%E5%A8%81%E8%80%85%E6%90%9E%E4%BA%8B%E8%AB%96&d=pzn6Hq8jxzH2PmSSbZvUoSEyVFbloTKGHdwbQdNTMZo%3D&h=aebdc4c0\" target=\"_blank\">https://debate.fandom.com/zh-hk/wiki/示威者搞事論</a>"},{"pid":"9a10eaf42c395e53f8785332ef94ed58fad170b8",