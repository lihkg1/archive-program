ike":0,"score":0,"quote":{"pid":"b0eb62ffdc14e1ddfec6f63dbae0e28ca1640306","tid":1419472,"uid":113373,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-06T16:22:00.000Z","msg":"推"},"citedBy":0,"replyTime":"2019-08-06T16:29:39.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"7a1c6a3c30c20e00d61d561435623db665d1b55f","tid":1419472,"uid":83161,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T16:50:03.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"9604ad7a02ff933c9830a6f99726d5d9138e0ab1","tid":1419472,"uid":144942,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T16:50:40.000Z","msg":"<img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" />"},{"pid":"1cd61f45c699316c00cee0f1fc322fb23847bfbb","tid":1419472,"uid":157619,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T16:51:01.000Z","msg":"推"},{"pid":"2251c82996f5509b613f70ea7c9ec2f0940a6787","tid":1419472,"uid":260037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T16:51:08.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"af95333d3574af5e04384a5477e22d3dcbdc4b2d","tid":1419472,"uid":102787,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T16:51:53.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ec758b7c8dedf7cdac4912a52b407763124f5e36","tid":1419472,"uid":264201,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-06T16:53:11.000Z","msg":"4/8落機，係機場想airdrop 文宣比D遊客，但搵唔到文宣<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"58c646a004f976d78e78cf1d9eb977a5a0117657","tid":1419472,"uid":300521,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T16:54:42.000Z","msg":"香港良心經濟圈，正式成立 (和非理進場)<br />\n<a href=\"https://lih.kg/1421924\" data-auto-link target=\"_blank\">https://lih.kg/1421924</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"bb230ee6c87d254797ab3a730202ceb20c8683fe","tid":1419472,"uid":181981,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T16:55:12.000Z","msg":"推"},{"pid":"b083102300661e1db169a486c24c39f4cef5f9eb","tid":1419472,"uid":26013,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec758b7c8dedf7cdac4912a52b407763124f5e36","tid":1419472,"uid":264201,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-06T16:53:11.000Z","msg":"4/8落機，係機場想airdrop 文宣比D遊客，但搵唔到文宣<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-06T18:35:53.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"afe107f12eb9d74918fc1870d46777c00b88f18b","tid":1419472,"uid":279145,"like":0,"dislike":0,"score":0,"quote":{"pid":"39796d075841425dff7ce0b9e995e8144eba8966","tid":1419472,"uid":26013,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-06T01:30:56.000Z","msg":"打咗兩個月<br />\n大家生理心理都去得好盡<br />\n但我哋唔可以比情緒控制住<br />\n得閒檢討一下先可以走得遠<br />\n<br />\n<br />\n1. 去機場集會要準備更多英文文宣同口號<br />\n雖然琴日係有fight for freedom stand with hong kong<br />\n但都仲有好多時間講香港人加油 光復香港嗰啲<br />\n記住我哋去機場要好好利用我哋國際城市嘅優勢<br />\n係要將我哋嘅message spread出去<br />\n所以應該用更多非廣東話<br />\n對鬼佬講英文 對支那人講普通話<br />\n同埋啲banner 嗰啲可以再多啲英文version<br />\n琴日見有好大部份都仲係黃色反送中<br />\n啲鬼佬見到會好奇<br />\n但唔會第一時間收到我哋要講嘅嘢<br />\n大部份人嚟得香港都會知咩事<br />\n但仲係會有少部份不問世事冇乜腦嘅<br />\n我哋要連佢哋都知道<br />\n我明白大叫光復香港呢啲會好熱血<br />\n但記住我哋集會講口號唔係圍爐 <br />\n係要令全世界知道<br />\n<br />\n2 得閒去下上水站/上水區搞終極和理非行動<br />\n可以派下傳單，幾個幾個貼口號喺身喺水貨區行<br />\n貼下貼紙落gip，放傳單入人哋袋<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><br />\n唔使踼gip唔使屌人<br />\n要用最和善方式將香港嘅革命思想傳上去大陸<br />\n要令大陸人知道我哋唔係屌9佢哋<br />\n我哋係追求民主、自由同和平<br />\n香港人可以搞 大陸人都可以試<br />\n<br />\n3. 勇武人士態度要和善啲<br />\n首先喺到多謝你哋咁唔怕死去救香港<br />\n但我都留意到有啲勇士態度唔太好<br />\n明白大家都有情緒都會燥<br />\n但如果我哋唔好好克制同檢討<br />\n就會變成大家好討厭嘅黑警一樣<br />\n影相呢樣嘢<br />\n其實係會幫到件事再spread out<br />\n如果佢唔係影你大頭你根本唔使屌佢<br />\n你上得街你有責任要保護自己<br />\n己經兩個月 所有人應該要識隱藏身份<br />\n何況要影你大頭都唔會咁公然比你發現到啦<br />\n<br />\n4. 盡量理清目標先好勇武<br />\n勇武手足你哋少一個就係少一個<br />\n我唔會責怪你哋<br />\n但希望你哋諗清楚我哋嘅目標係咩<br />\n黑警、黑社會當然仆街<br />\n一定要清算<br />\n但記住我哋宜家要對準政權先<br />\n比人攻擊要狠狠還擊我絕對讚同<br />\n有手足比狗捉我哋去圍我都好讚同<br />\n但係有時我哋純粹為報復而貿貿然衝上去送頭<br />\n我唔會話你哋蠢<br />\n但我會好心痛同埋香港人又少多個手足可以一齊上<br />\n<br />\n5. be water<br />\n好似立法會、中聯辨呢啲有象徵性嘅地方大家玩死守係ok<br />\n但如果只係普通一個街口<br />\n我哋硬碰硬通常一下就冇咗幾十個手足<br />\n就算我哋成功令狗仔攻唔入<br />\n咁樣會對政府回應訴求有咩幫助<br />\n記住有力唔好一次放哂<br />\n『亢龍有悔，盈不可久』，因此有發必須有收。打出去的力道有十分，留在自身的力道卻還有二十分。<br />\n進可攻退可守先會玩得長玩得完<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n不分化 不割席 但要識反思<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-06T18:38:39.000Z","msg":"推"},{"pid":"8d550d6a9c0b2f11e8f53e46cad75afcc472c315","tid":1419472,"uid":67223,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:38:46.000Z","msg":"be water be humble"},{"pid":"6fcd024f988572c7ad3ccd3e93f65058c462631a","tid":1419472,"uid":279145,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:38:50.000Z","msg":"垫"},{"pid":"3f01c454a0b5cd570cb7bd93e542d6a06bb27eb9","tid":1419472,"uid":279145,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-06T18:39:00.000Z","msg":"推"},{"pid":"e7a1f3af64b3e6870d22f988b5ad25c3986ef461","tid":1419472,"uid":279145,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:39:10.000Z","msg":"推"},{"pid":"448fc7329ec3f2932eec2c5b283bbbcb4390072a","tid":1419472,"uid":279145,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"