dfc92","tid":2371334,"uid":15473,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-01-18T18:33:34.000Z","msg":"此回覆已被刪除"},{"pid":"6f2032ad09e4312b6f347d70e1ccf5420ed74e33","tid":2371334,"uid":300918,"like":0,"dislike":0,"score":0,"quote":{"pid":"21c3cdb4b4ed9c88182488266d521033c3bdfc92","tid":2371334,"uid":15473,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-01-18T18:33:34.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2021-01-18T18:36:37.000Z","msg":"yes, boss<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"77be83d175dfe2822b94de006d1e5ce94450afa4","tid":2371334,"uid":148622,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-18T18:39:36.000Z","msg":"有冇修煉嘅方法嘅？"},{"pid":"719a1721362caef431ac4fe3459e87120c75e9f9","tid":2371334,"uid":373438,"like":0,"dislike":0,"score":0,"quote":{"pid":"859bb296117dbd23f26c600d860ab626ccbea9b3","tid":2371334,"uid":300918,"like":0,"dislike":0,"score":0,"quote":{"pid":"07e884d9b99fecf390cc0e15e458580714ba0ef5","tid":2371334,"uid":373438,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2021-01-18T18:14:23.000Z","msg":"咁都係好事嚟嘅<br />\n不過你要不停咁提自己<br />\n你只係一個普通人<br />\n咁你就唔會走火入魔"},"citedBy":1,"replyTime":"2021-01-18T18:23:34.000Z","msg":"係<br />\n呢排開始feel到自己越黎越傲慢"},"citedBy":2,"replyTime":"2021-01-18T18:46:33.000Z","msg":"意識到自己傲慢其實先係開始<br />\n靈性係唔會令到一個人變得高等<br />\n知道再多真相你一樣唔會識飛<br />\n因為你嘅存在必然建基於某啲限制<br />\n如果你擺脫左嗰啲限制你就已經唔存在<br />\n當你唔受任何事物約束又冇私欲，就代表你已經失去自我<br />\n就好似當你冇咗對父母親情嘅枷鎖<br />\n咁你就已經唔再係你父母嘅仔女<br />\n希望呢個比喻令你明白嗰個道理<br />\n<br />\n所以了解自己嘅限制再了解其他人嘅限制就明白思想係冇啱同錯，你認為人哋錯只係因為對方喺你嘅對立面、只係因為佢機緣巧合下佢為咗滿足自己而迫不得已得罪你。所有對立都係逼不得已、仇恨係冇必要。"},{"pid":"63f5a9504d73972dbe356f51b0b14e9178cdb8e0","tid":2371334,"uid":373438,"like":0,"dislike":0,"score":0,"quote":{"pid":"719a1721362caef431ac4fe3459e87120c75e9f9","tid":2371334,"uid":373438,"like":0,"dislike":0,"score":0,"quote":{"pid":"859bb296117dbd23f26c600d860ab626ccbea9b3","tid":2371334,"uid":300918,"like":0,"dislike":0,"score":0,"quote":{