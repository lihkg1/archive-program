/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"ed0d89ff498ec97c8564774c62b7e5c3a8511d53","tid":1182402,"uid":163350,"like":6,"dislike":8,"score":-2,"citedBy":1,"replyTime":"2019-06-02T07:27:04.000Z","msg":"此回覆已被刪除"},{"pid":"77089f75d465f47eb694e07dcfa8df88458a6596","tid":1182402,"uid":196924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-02T07:32:43.000Z","msg":"得返一個月<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"2ffdf5d01d15c54bd8870c491d24997cd8f0b588","tid":1182402,"uid":22675,"like":17,"dislike":1,"score":16,"citedBy":0,"replyTime":"2019-06-02T07:34:43.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">內地係共產中文！！！！係中國啊！！！</span></span>"},{"pid":"a5b9d665cb315e8e92c03febc30fae0d3be1050e","tid":1182402,"uid":239294,"like":5,"dislike":0,"score":5,"quote":{"pid":"ed0d89ff498ec97c8564774c62b7e5c3a8511d53","tid":1182402,"uid":163350,"like":6,"dislike":8,"score":-2,"quote":{"pid":"d83d18a76ea91470c945ca14405a1be7d70dfbd1","tid":1182402,"uid":112124,"like":1,"dislike":1,"score":0,"quote":{"pid":"ba6e266cad6b1d21d2c50eb78cbf8654fe1b661a","tid":1182402,"uid":163350,"like":2,"dislike":8,"score":-6,"citedBy":2,"replyTime":"2019-06-02T07:22:30.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-06-02T07:24:23.000Z","msg":"咁咪由佢囉<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-02T07:27:04.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-06-02T08:50:34.000Z","msg":"乜救自己，救身邊的人，需要計值唔值得咩，<br />\n結果香港可唔可以擺脫中共命運你我都唔知，但我知唔做，就乜都無，同你買六合彩一樣"},{"pid":"03c4c8119bd477e2f5c8495ad0dfc2fee09ffc15","tid":1182402,"uid":245484,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-06-02T08:53:46.000Z","msg":"28日都唔知有冇啦仲28年 <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"a57ec6501167fa4b1acaa1779b4605fe2c79c656","tid":1182402,"uid":163350,"like":3,"dislike":7,"score":-4,"citedBy":1,"replyTime":"2019-06-02T08:55:07.000Z","msg":"此回覆已被刪除"},{"pid":"c1a8852870b8ab04fa7e489b6917f72beceb00e0","tid":1182402,"uid":239294,"like":32,"dislike":1,"score":31,"quote":{"pid":"5efc1ae805d565c68e6658620b831ecb7b4572ea","tid":1182402,"uid":256383,"like":262,"dislike":5,"score":257,"citedBy":2,"replyTime":"2019-06-02T07:11:52.000Z","msg":"原來仲有人信50年不變<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-02T08:56:35.000Z","msg":"我認為呢50年係比香港準備，一係延續特別行政區，一係變成香港市，一係變成香港國，上一輩做太多柒事，我地係要企出黎，而唔係同流合污"},{"pid":"7c9d41372810cbcb254436ac9c8f3cec7ea9080c","tid":1182402,"uid":239294,"like":1,"dislike":0,"score":1,"quote":{"pid":"be5e4052d899248bca4768579606ff052c7808ba","tid":1182402,"uid":226955,"like":114,"dislike":4,"score":110,"citedBy":2,"replyTime":"2019-06-02T07:11:53.000Z","msg":"何謂遊行：<br />\n遊行並唔係指行完就算，而係話比當權者，我宜家街上有（假設）五十萬人，如果你唔聽我地講野，我唔擔保呢幾十萬人會做啲咩野<br />\n<br />\n<br />\n愛因斯坦 (Albert Einstein)：「The world will not be destoryed by those who do evil, but by these who watch them without doing anything.(這個世界不會被那些作惡多端的人毀滅，而是冷眼旁觀、選擇保持緘默的人)」；鄭有傑(導演):「良心的沉默是邪惡的幫兇。」<br />\n<br />\n<br />\n好多時歷史中嘅轉折位都係由表面上微不足道嘅小事/小人物而形成嘅，所以我地更加唔可以睇小自己<br />\n<br />\n6月9號一齊去遊行！<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-02T09:01:21.000Z","msg":"我地應該以史為鑑，絕不重蹈覆徹<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},{"pid":"d6698ac3661e8d4e057cceeed9bf3b9360d656fc","tid":1182402,"uid":239294,"like":3,"dislike":1,"score":2,"quote":{"pid":"a57ec6501167fa4b1acaa1779b4605fe2c79c656","tid":1182402,"uid":163350,"like":3,"dislike":7,"score":-4,"quote":{"pid":"a5b9d665cb315e8e92c03febc30fae0d3be1050e","tid":1182402,"uid":239294,"like":5,"dislike":0,"score":5,"quote":{"pid":"ed0d89ff498ec97c8564774c62b7e5c3a8511d53","tid":1182402,"uid":163350,"like":6,"dislike":8,"score":-2,"citedBy":1,"replyTime":"2019-06-02T07:27:04.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-06-02T08:50:34.000Z","msg":"乜救自己，救身邊的人，需要計值唔值得咩，<br />\n結果香港可唔可以擺脫中共命運你我都唔知，但我知唔做，就