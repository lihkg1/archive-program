kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVpnnupT.png&h=bf703274&s={SIZE}\" />"},{"pid":"4e8cad16b47b6bbcee2a32ee4bcec4f25a2c43f3","tid":1430090,"uid":89898,"like":0,"dislike":0,"score":0,"quote":{"pid":"b1db9afb7e7a3e399995fc9576173e5b10db19d3","tid":1430090,"uid":74355,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-07T16:05:28.000Z","msg":"司徒華借屍還魂？<br />\n建設民主中國？"},"citedBy":0,"replyTime":"2019-08-07T16:07:14.000Z","msg":"佢有冇民主唔關我事呀，但係事實係而家我地係同中共博弈緊，你唔直接搞鳩佢，殺晒全港三萬隻狗都解決唔到件事"},{"pid":"93b1ee53cce1b11d0f60c3b5dd3189ff0a755198","tid":1430090,"uid":259812,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T16:09:09.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n各有各做<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"b11f06f4e70877c1cfa8d54c82efe9162cb63995","tid":1430090,"uid":20867,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-07T16:10:35.000Z","msg":"我地會睇住香港個場ga la<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/lihkg.gif\" class=\"hkgmoji\" /><br />\n<br />\n泛民快D去中國成立大台<br />\n然後支援愛國民主運動<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"503dfeeef70d1780e9094dd98771ba6d79bd5328","tid":1430090,"uid":89898,"like":0,"dislike":0,"score":0,"quote":{"pid":"b11f06f4e70877c1cfa8d54c82efe9162cb63995","tid":1430090,"uid":20867,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-07T16:10:35.000Z","msg":"我地會睇住香港個場ga la<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/lihkg.gif\" class=\"hkgmoji\" /><br />\n<br />\n泛民快D去中國成立大台<br />\n然後支援愛國民主運動<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-07T16:11:55.000Z","msg":"<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />睇晒全文先屌啦<br />\n圍魏救趙<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><br />\n中共唔亂呢單嘢完唔到<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"6373fde8a7b1c4b87a860ed70f8e38a078198b86","tid":1430090,"uid":292536,"like":0,"dislike":0,"score":0,"quote":{"pid":"cd4b1a9c02c873542ac6a0cc4bf7d846beca8f39","tid":1430090,"uid":89898,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-07T15:59:26.000Z","msg":"大家玩完一日Laser都要返返嚟成個運動本身。喺我眼中，呢幾個星期係一次又一次揭露咗<span style=\"font-size: x-large;\"><span style=\"color: red;\">中共插手香港事務</span></span>嘅例子，時間線可以遠至種票操縱立法機關、控制司法機構法官嘅委任、把持監警會變相警權變大、干預大專學府高層賣港維穩；近至元朗恐襲同葉虎嘅瓜葛、疑似有內地人員混入執法機構、海量網軍混入連登Facebook洗版等等。<br />\n<br />\n近兩個月令到呢堆問題浮晒上面，而我地要做嘅唔應該只係每星期叫個口號衝一次，我地要直視<span style=\"font-size: x-large;\"><span style=\"color: red;\">中共干政</span></span>嘅事實。<br />\n<br />\n利申唔係大中華膠，但係大家要諗諗成件事嘅Endpoint有乜可能性：<br />\n<br />\n(1) 運動失敗，五大訴求落空，香港赤化步伐加快<br />\n(2) 港共同警隊崩潰，無視中共，直接實行五大訴求<br />\n(3) 港共同警隊崩潰，中共武力強硬接管香港<br />\n(4) 中共忍受唔住香港嘅管治成本，由得港府落實訴求<br />\n(5) 外國（包括英美）用經濟迫使中共讓步<br />\n(6) 中共倒台<br />\n<br />\n假設我地想贏呢場仗，考慮到香港對中共嘅經濟地位太特殊，又中共對面子嘅渴求又咁大，而家係得(4)(5)(6)三條路可以行。邊條都好，都意味住我地要<span style=\"font-size: x-large;\"><span style=\"color: red;\">圍魏救趙</span></span>先成到事。<br />\n<br />\n你見呢幾星期中共不停出招<span style=\"font-size: x-large;\"><span style=\"color: red;\">對大陸維穩</span></span>，包括7.7尖咀遊行叫旅客唔好嚟遊行地區、包括7.21之後幫個國徽笠condom強調無損主權、包括7.29將事件定義為治安問題而非管治問題、包括8.3之後搞咩我是護旗手、包括8.5將成場運動包裝到係港獨，全部都係做畀大陸人睇，話香港人搞港獨搞衰中國，你地唔好亂埋一份。<br />\n<br />\n所以我建議，而家文宣同行動除咗原有嘅五大訴求同聲訴警黑之外，重要重槌出撃中共干涉香港事務，要輸出革命<span style=\"font-size: x-large;\"><span style=\"color: red;\">燒中共後欄</span></span>。<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">對內：</span></span><br />\n➤ 深究葉虎門真相，劍指中聯辦、鄉黑、警隊勾結（同時可以將保皇派拉埋落「恐襲」呢潭死水度，重擊選情）<br />\n➤ 善用長輩圖/連儂牆，宣傳屠夫政權嘅惡行，包括新疆集中營、武漢鎮壓，又或者用民生例子，例如成都食堂醜聞、隱瞞非洲豬瘟疫情等等，令「政治唔關我事」嘅人知度呢個政權有幾可怕<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">對外：</span></span><br />\n➤ 善用8.9-8.11機場集會，用外國（包括大陸）遊客介紹中聯辦點干預香港事務、介紹中共政權有幾不堪<br />\n➤ 用返7.7尖沙咀輸出革命嘅方法進行之後嘅遊行（如紅土），定期喺遊客區（例如尖咀、沙田、老銅、迪士尼）快閃，就算輸出唔到革命都令到旅行團怕咗送人落嚟<br />\n➤ （好似有少少膠味）喺大陸嘅手機遊戲、淘寶客服等等輸出以上意識<br />\n<br />\n真係眼見而家勇武同和理非都去到個樽頸位，大家都開始唔知喺香港可以做到啲咩，所以先提議返<span style=\"font-size: x-large;\"><span style=\"color: red;\">全力火燒後欄</span></span>呢招。個口號純粹反攻返中共扣港獨帽子亂作嘅，等大家出師有名，唔知大家有冇咩其他諗法？<br />\n<br />\n利申：愛國愛港，擁護基本法<br />\n<br />\n<img src=\"https://na.cx/i/kjq4Hze.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fkjq4Hze.jpg&h=f540e9a1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/7s8h2ze.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7s8h2ze.jpg&h=f529c8f0&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-08-07T16:15:17.000Z","msg":"真係要開中共呢條戰線，夠薑就解放軍落來隻抽，唔係嘅呢個戰線先至可以捉正中共嘅春袋。一定要快速斷佢哋米路，揸正喉嚨乜都得。<br />\n<br />\n有一點唔同意嘅就係關於啲政治冷感嗰班。對佢哋講政府恐怖冇用，要講錢。同佢哋講，每年有幾多你納稅人嘅錢係去咗佢哋手上而且喺財過光棍手一去冇回頭嗰種，佢啲就會驚。要起晒中聯辦嘅吸水網絡，我哋知道三中書局已經係中聯辦嘅囊中物，一定有更多，而且要係啲涉及好多錢嘅嘢。"},{"pid":"ef12505c3deb8dbd960734e0f0da9f37b5624882","tid":1430090,"uid":11049,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T16:15:34.000Z","msg":"<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" />"}]}