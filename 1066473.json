57.000Z","msg":"<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},{"pid":"4c7f438b3a85a7e5d276175e9fde214bca22b294","tid":1066473,"uid":184679,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-03-18T04:05:21.000Z","msg":"連登仔：你會開始愛上澳洲佬的俠義風骨"},{"pid":"35daeec69f12d593907d3d2982ceb6864d9de502","tid":1066473,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-18T05:00:56.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"84c78fa3b01948afa4548586c3ce6050b480ef90","tid":1066473,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-18T05:12:48.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f662fb6851bb1df55018d236893ce5ef180b930b","tid":1066473,"uid":184679,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2019-03-18T07:51:30.000Z","msg":"<img src=\"https://cdn.discuss.com.hk/t/c8c3dc/f/800x0/https://img.discuss.com.hk/d/attachments/day_151117/151117_6db8dfbca0d268f9a1c86e9bf3e2da1b\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.discuss.com.hk%2Ft%2Fc8c3dc%2Ff%2F800x0%2Fhttps%3A%2F%2Fimg.discuss.com.hk%2Fd%2Fattachments%2Fday_151117%2F151117_6db8dfbca0d268f9a1c86e9bf3e2da1b&h=239b8ff1&s={SIZE}\" /><br />\n<br />\n我想講嘅野已經講完。<br />\n我打過的comment已經充分表達我思我想。<br />\n好高興找到不少有見地，客觀理性，和平，非斷章取義，非人生攻擊，參考多方的媒體資訊而非單從高登蘋果得知新聞，即使持不同立場亦願意聆聽接納他人意見的文明討論者。<br />\n根據個人觀察，肯接納，態度開明的文明討論者，他們不約而同都有較多人生閱歷，或對國際時局有更多元化更全面的認識。<br />\n非理性的不文明討論者，我為香港未來痛心，因為若果有朝一日香港實行全民普選，不文明非理性的選民或選舉參與者只會拖垮香港的前途。中國人話，仁義禮智猶如人之四肢，仁居首，智居末，或許你認為我缺乏智，但你在人身攻擊之時，就把更重要的仁和禮置諸度外了。<br />\n我非聖人，我不認為我的一字一句是完美，有時我太utopian或用錯語氣，亦無想過出位，我只希望各位能夠對事不對人地對這個世界反思。這是悲天憫人的藝術工作者生來就肩負的使命。<br />\n為了關心緊張擔心我的朋友我決定完post了。<br />\n最後送一句Steve Jobs的quote給各位：<br />\nBeing the richest man in the cemetery doesn't matter to me. Going to bed at night saying we've done something wonderful... that's what matters to me.<br />\nBest wishes"},{"pid":"2511267746658f288eb1f18b041c1b8aaf2830c9","tid":1066473,"uid":20816,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-03-18T09:38:38.000Z","msg":"唔夠講又開新po<br />\n<br />\n紐西蘭大屠殺是一場恐怖襲擊<br />\n<a href=\"https://lih.kg/1065384\" data-auto-link target=\"_blank\">https://lih.kg/1065384</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"d7de823f5c67120b4ebe890203b54c6f73a8585e","tid":1066473,"uid":184679,"like":1,"dislike":4,"score":-3,"quote":{"pid":"2511267746658f288eb1f18b041c1b8aaf2830c9","tid":1066473,"uid":20816,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-03-18T09:38:38.000Z","msg":"唔夠講又開新po<br />\n<br />\n紐西蘭大屠殺是一場恐怖襲擊<br />\n<a href=\"https://lih.kg/1065384\" data-auto-link target=\"_blank\">https://lih.kg/1065384</a><br />\n- 分享自 LIHKG 討論區"},"citedBy":0,"replyTime":"2019-03-18T09:46:08.000Z","msg":"耶撚真係好撚煩"},{"pid":"8b06d9fcaa9b919c8e861213fbd2f155c6521284","tid":1066473,"uid":2772,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-03-18T09:48:19.000Z","msg":"將伊斯蘭人轉做支那人<br />\n個觀感就FIT哂<br />\n<br />\n根本冇做錯<br />\n好地地留係自己地方餅埋一二邊唔影響其他地方冇人會唔鍾意你"},{"pid":"7e76eaf700012fd0b381870d44f465f6466dbf9f","tid":1066473,"uid":184679,"like":0,"dislike":4,"score":-4,"quote":{"pid":"8b06d9fcaa9b919c8e861213fbd2f155c6521284","tid":1066473,"uid":2772,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-03-18T09:48:19.000Z","msg":"將伊斯蘭人轉做支那人<br />\n個觀感就FIT哂<br />\n<br />\n根本冇做錯<br />\n好地地留係自己地方餅埋一二邊唔影響其他地方冇人會唔鍾意你"},"citedBy":1,"replyTime":"2019-03-18T09:56:54.000Z","msg":"本來鎖國好地地，白人係都要強迫開放門戶，自作業<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1ac1801c5090e7175d44197768b01ee999d11be1","tid":1066473,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-18T11:03:08.000Z","msg":"<img src=\"/assets/faces/lm2/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"467da18ee1b02e49cae76e04857167033a2de4c9","tid":1066473,"uid":195714,"like":0,"dislike":0,"score":0,"quote":{"pid":"7e76eaf700