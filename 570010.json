rticle/20160520-dailynews-china-fifty-cent-party-internet/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftheinitium.com%2Farticle%2F20160520-dailynews-china-fifty-cent-party-internet%2F&d=qq2rvVQARFkR%2BmWLtzNVBhv1o3X72Fc8dbph17rWX2c%3D&h=4d846908\" target=\"_blank\">https://theinitium.com/article/20160520-dailynews-china-fifty-cent-party-internet/</a>"},{"pid":"52df406c06bdbf3e2db520802d9aec26e9934374","tid":570010,"uid":53223,"like":0,"dislike":21,"score":-21,"quote":{"pid":"2c1e6a37370f83313eb772b7836bb6ff9503b1ab","tid":570010,"uid":171257,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2018-02-23T08:52:05.000Z","msg":"殲滅支那狗共<br />\n還給香港人獨立建國"},"citedBy":1,"replyTime":"2018-02-23T08:53:00.000Z","msg":"港獨狗想獨立建國只係癡心妄想，唔好將香港人同港獨狗混為一談"},{"pid":"27b2ccf956ccaf94744f5e8a10d06db64cfab1cc","tid":570010,"uid":19126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-23T08:54:02.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2992075aa31403f13a3deac507c680ecb1240343","tid":570010,"uid":60545,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2018-02-23T08:56:25.000Z","msg":"艾未未於2011年對一名「五毛黨」的採訪中，對方也<span style=\"color: red;\">承認他們會通過多種方式轉移焦點，包括製造虛假辯論、扮演不同角色、岔開話題轉移注意力</span>、連續發布廣告刷屏等。"},{"pid":"4e7ca0cea835c484e1f19d20107ed60e333ada48","tid":570010,"uid":146535,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-02-23T08:57:57.000Z","msg":"細緻入微係真"},{"pid":"0b2790ddc26dc2c66c82ec15af07514369e68249","tid":570010,"uid":86841,"like":1,"dislike":8,"score":-7,"citedBy":1,"replyTime":"2018-02-23T09:00:35.000Z","msg":"此回覆已被刪除"},{"pid":"bd43c978f9804aa915309451bc6920a64cee2e92","tid":570010,"uid":60545,"like":9,"dislike":0,"score":9,"quote":{"pid":"0b2790ddc26dc2c66c82ec15af07514369e68249","tid":570010,"uid":86841,"like":1,"dislike":8,"score":-7,"citedBy":1,"replyTime":"2018-02-23T09:00:35.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-02-23T09:03:44.000Z","msg":"人地講A你講B 又大量謬論 之後話人地唔理你就話人駁