384f44e228a","tid":2101311,"uid":69095,"like":1,"dislike":2,"score":-1,"quote":{"pid":"8847b645cf1f82c91d52f1d192da2f7c54b14d54","tid":2101311,"uid":87511,"like":2,"dislike":0,"score":2,"quote":{"pid":"d8984040f60402b2eed261d65909669b55ec53a4","tid":2101311,"uid":69095,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-09T16:50:36.000Z","msg":"某U = 邊間？<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n心態決定境界<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-07-09T16:51:03.000Z","msg":"係三大我就爭住自爆啦<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-07-09T16:53:03.000Z","msg":"你覺得自己懷才不遇？<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-09T16:56:14.000Z","msg":"絕對唔係<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />點解你會咁講？"},{"pid":"a5bf98778a5a55f1b86938f6a25887cd50096a16","tid":2101311,"uid":315798,"like":30,"dislike":1,"score":29,"citedBy":1,"replyTime":"2020-07-09T16:57:44.000Z","msg":"未有反送中運動之前已經plan緊移民<br />\n香港實在太大競爭，咩都爭一餐<br />\n未出世就要爭床位，出咗世就要爭奶粉、學位<br />\n投身社會之後又要爭工作機會、住屋<br />\n老咗又要爭醫療，死咗連骨灰位都要爭<br />\n自己本身唔係一個進取嘅人，完住唔鍾意爭嘢<br />\n剩係想過一啲平靜嘅生活"},{"pid":"e608cce3ab65b1127865ad760f7ee183a5231ad8","tid":2101311,"uid":33583,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-07-09T17:02:51.000Z","msg":"唔知講咩好<br />\n比唔到咩意見<br />\n但係見巴打上面打既野覺得巴打平時都幾唔開心<br />\n希望你可以早日搵到自己條出路<br />\n同埋真係太辛苦就要休息下<br />\n始終條路仲有好長<br />\n加油<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"3dc8cd44c28337d74365aab0315ff9475299d8f4","tid":2101311,"uid":88228,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-07-09T17:04:24.000Z","msg":"真係 我走既原來係因為香港工作太on9<br />\n一早想走抗爭前已經"},{"pid":"24e960c5dfd00dcf44f8b7ad667e66fbb2f749c9","tid":2101311,"uid":256286,"like":5,"dislike":1,"score":4,"citedBy":0,"replyTime":"2020-07-09T17:09:33.000Z","msg":"如果你捱得下<br />\n移民都冇輸<br />\n因為香港係最趕最貴最要爭既地方，從呢個地方出黎都勁<br />\n只係盡量唔好去倫敦呢d大城市"},{"pid":"13440637d598a5fadd1bb3618d118e59c5adc91c","tid":2101311,"uid":224510,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-07-09T17:09:42.000Z","msg":"想走好耐<br />\n搵埋都追唔到樓價<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"6c77af0825f66159632da4489fee0789fb015bbf","tid":2101311,"uid":14494,"like":1,"dislike":1,"score":0,"quote":{"pid":"e8952143c792e0d1276646d766ccf8320c22a353","tid":2101311,"uid":87511,"like":6,"dislike":1,"score":5,"quote":{"pid":"ac79491843bd1ca69eae2c15d1f7c28852981e68","tid":2101311,"uid":132585,"like":11,"dislike":4,"score":7,"citedBy":1,"replyTime":"2020-07-09T16:42:05.000Z","msg":"自己香港謀生能力都冇，仲話想去外國生活，屌你老母啦笑撚死人咩<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-07-09T16:44:26.000Z","msg":"有道理<br />\n我而家思考緊一樣嘢<br />\n男人老狗有手有腳學一技之長只要唔怕辛苦，真係唔會餓死<br />\n<br />\n好似我腦細咁廢，純粹有錢開廠做生意，然後唔撚理間公司<br />\n淨係做回頭客都個個月有錢賺"},"citedBy":1,"replyTime":"2020-07-09T17:16:00.000Z","msg":"我咁睇啦 就算冇乜技能<br />\n去到外國打份最基層既工，例如水電媒都夠貨屋"},{"pid":"b0ddd5e40d3b46a62d44da1ad307337595bd739e","tid":2101311,"uid":87511,"like":1,"dislike":1,"score":0,"quote":{"pid":"6c77af0825f66159632da4489fee0789fb015bbf","tid":2101311,"uid":14494,"like":1,"dislike":1,"score":0,"quote":{"pid":"e8952143c792e0d1276646d766ccf8320c22a353","tid":2101311,"uid":87511,"like":6,"dislike":1,"score":5,"quote":{"pid":"ac79491843bd1ca69eae2c15d1f7c28852981e68","tid":2101311,"uid":132585,"like":11,"dislike":4,"score":7,"citedBy":1,"replyTime":"2020-07-09T16:42:05.000Z","msg":"自己香港謀生能力都冇，仲話想去外國生活，屌你老母啦笑撚死人咩<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/ass