Fbfsozav.jpg&h=c6afd384&s={SIZE}\" />"},{"pid":"ce4cab35f0fa4f8f77fa8afc273fb9de127b9e89","tid":1697374,"uid":50595,"like":3,"dislike":0,"score":3,"quote":{"pid":"7610fdf5f43a0caff06bb52d3ed7b8e19bfd61b8","tid":1697374,"uid":187489,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-07T01:10:15.000Z","msg":"幾歲？"},"citedBy":1,"replyTime":"2019-11-07T02:23:29.000Z","msg":"後生女, 無論如何 R.I.P.<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"8445f764c34899124341571f7941ee23bc543bfa","tid":1697374,"uid":152944,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-07T02:24:10.000Z","msg":"大圍豐盛苑發生火警，一名女子死亡，另外兩人受傷。<br />\n<br />\n新界東消防區長洪重穆表示，火警在清晨4時42分發生，消防在5分鐘後到場，豐盛苑富盛閣9樓一個單位首先起火，現場火勢猛烈，其後蔓延至樓上兩個單位，消防人員進入單位內後，在燒毀情況較嚴重的房間內，發現一具燒焦女性屍體，並在另一間房間救出男戶主，他吸入濃煙感不適送院，單位女戶主在鄰居協助下逃生，手部輕傷送院。<br />\n<br />\n洪重穆證實起火樓層的消防喉無水，但表示大廈的消防閂系統無問題，大廈的消防系統和設備亦在去年12月檢查和在今年7月完成維修，相關部門會研究涉事樓層消防喉無水的原因。<br />\n<br />\n他表示，在火警中，消防出動48名消防員、12輛消防車和6輛救護車到場，並派出2隊煙帽隊和2條喉協助灌救，過程中有600名住客自行疏散，消防協助10名住客離開。<br />\n<br />\nRTHK"},{"pid":"b90214f349347d13ade6d35418a34574610e2ce0","tid":1697374,"uid":91511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-07T02:26:07.000Z","msg":"POPO表示要用水炮車啲催淚水救火<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />然後ff自己獲得市民尊重"},{"pid":"c56ce13d1a4b89718a511d0a249c63f2cb79911e","tid":1697374,"uid":326784,"like":0,"dislike":0,"score":0,"quote":{"pid":"ce4cab35f0fa4f8f77fa8afc273fb9de127b9e89","tid":1697374,"uid":50595,"like":3,"dislike":0,"score":3,"quote":{"pid":"7610fdf5f43a0caff06bb52d3ed7b8e19bfd61b8","tid":1697374,"uid":187489,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-07T01:10:15.000Z","msg":"幾歲？"},"citedBy":1,"replyTime":"2019-11-07T02:23:29.000Z","msg":"後生女, 無論如何 R.I.P.<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-07T02:26:27.000Z","msg":"好似話係20幾歲，戶主個女"},{"pid":"1dffaa5089209c8fd707383583dce744cf884271","tid":1697374,"uid":152944,"like":