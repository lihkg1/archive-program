d":"7672e0d7d045fd63307e13ad7a33cc9ee4f71e90","tid":303830,"uid":34934,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-02T13:00:09.000Z","msg":"【熱血鳳凰計劃　協助義士重生】<br />\n<br />\n熱血公民副主席 鄭錦滿 已到修頓街站宣傳「熱血鳳凰計劃」。<br />\n<br />\n#熱血鳳凰計劃<br />\n＃2017七一<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/07/02/210005_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F02%2F210005_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=17ac5c79&s={SIZE}\" />"}]}