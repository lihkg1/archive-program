"a517128b0fd0ca03881ffa3f27323284954d725f","tid":1528302,"uid":276734,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T13:50:09.000Z","msg":"搵定律師幫手?"},{"pid":"d60024a99f96238d22a41bbc231df737e6ee4dff","tid":1528302,"uid":126214,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T13:51:24.000Z","msg":"幫推"},{"pid":"096a0dc0f08b1a73d86c547e68ed0db41d448d28","tid":1528302,"uid":2031,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-01T13:51:30.000Z","msg":"<a href=\"https://www.pcpd.org.hk/tc_chi/data_privacy_law/amendments_2012/files/offence_disclosing_c.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.pcpd.org.hk%2Ftc_chi%2Fdata_privacy_law%2Famendments_2012%2Ffiles%2Foffence_disclosing_c.pdf&d=3Z9ZeYaQzwHPi2iIp4702DcyzTZykTUlxRhnZlW9F%2Bg%3D&h=79d1bdc3\" target=\"_blank\">https://www.pcpd.org.hk/tc_chi/data_privacy_law/amendments_2012/files/offence_disclosing_c.pdf</a><br />\n<br />\n問5 網民正常及無惡意的瀏覽活動會否受影響<br />\n答: 應不會，這項新增罪行不會影響網民正常及無惡意的瀏覽活動。<br />\n從互聯網下載個人資料，及後轉發有關資料的人，如他合理地相信資料使用者已同意有關披露，可以此作為免責辯護。<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">但</span></span>如果有關資料是在互聯網上洩露。該人理應知道進一步披露或散播該資料是未得資料使用者同意的，情況會截然不同。"},{"pid":"b1ceb4a0996eb44d4702034e196836a0f3d8ca96","tid":1528302,"uid":301666,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-01T13:53:39.000Z","msg":"<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"c67f547025121631b42146ecf06f659f59d79c95","tid":1528302,"uid":205098,"like":0,"dislike":0,"score":0,"quote":{"pid":"096a0dc0f08b1a73d86c547e68ed0db41d448d28","tid":1528302,"uid":2031,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-01T13:51:30.000Z","msg":"<a href=\"https://www.pcpd.org.hk/tc_chi/data_privacy_law/amendments_2012/files/offence_disclosing_c.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.pcpd.org.hk%2Ftc_ch