":2189280,"uid":103156,"like":2,"dislike":3,"score":-1,"citedBy":0,"replyTime":"2020-09-04T19:41:33.000Z","msg":"敵進我就退住先"},{"pid":"8d205c974043a8dd5b267251ade93dc23b03086e","tid":2189280,"uid":170866,"like":3,"dislike":3,"score":0,"citedBy":0,"replyTime":"2020-09-04T19:43:13.000Z","msg":"煩夠未"},{"pid":"5e415415336ed5825d153906e9e663e29ca7d6ef","tid":2189280,"uid":311583,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-09-04T20:12:41.000Z","msg":"拉"},{"pid":"37dfcb121f445640be0bfec05b83f9609aa193dc","tid":2189280,"uid":311583,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-09-04T20:13:24.000Z","msg":"拉"},{"pid":"5f1e23a89b59014774e06203e5cd5f805b20a2b8","tid":2189280,"uid":359022,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-04T21:36:17.000Z","msg":"星期六咁早晨<img src=\"/assets/faces/mouse/smile.gif\" class=\"hkgmoji\" />"},{"pid":"30572b3d5f9884c25cf3d5ffcae5da83f1fa3743","tid":2189280,"uid":346806,"like":3,"dislike":5,"score":-2,"citedBy":1,"replyTime":"2020-09-04T22:49:07.000Z","msg":"睇完<br />\n其實寫得有道理<br />\n佢意思係唔係咁多香港人有覺悟嘅情況下出嚟只會害死嗰班出嚟示威嘅人"},{"pid":"5040dc3e73e0df5b7db6e173dfd4ed23ce0a88f8","tid":2189280,"uid":219007,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-09-05T06:16:33.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"e42bc1d71336b8fb626ecdcf4255b84f4f2ac543","tid":2189280,"uid":346260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-05T06:26:04.000Z","msg":"唔該借個位嚟<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><br />\n<br />\n實用 post ,樓主可唔可以置頂？唔該曬 <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><br />\n<br />\n真係想保護自己同埋身邊嘅人？即刻入嚟睇吓!<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n[實用文] 教您點先可以保障私隱、網絡安全