 src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"40197f6bbe304ab757a1301ba7659aa6db3a46dc","tid":2500562,"uid":272569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T21:53:39.000Z","msg":"push"},{"pid":"76e614307ad72aa361af0487ca47710e3a0defda","tid":2500562,"uid":133534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T21:59:48.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"5382dbdeba1fe9100121938a0cc752a72e92eae0","tid":2500562,"uid":83052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T22:02:06.000Z","msg":"<img src=\"/assets/faces/fs/smile_big.gif\" class=\"hkgmoji\" />"},{"pid":"895fe9d5aef0e3ae31b09ac88d2b027efec32522","tid":2500562,"uid":162268,"like":0,"dislike":0,"score":0,"quote":{"pid":"b3b5bcc3f2a08c87cc4bde21190d54e5019af035","tid":2500562,"uid":13503,"like":8,"dislike":3,"score":5,"quote":{"pid":"bcc5392f79e7e714eb3b7955a4a1294f51df446a","tid":2500562,"uid":125727,"like":5,"dislike":51,"score":-46,"citedBy":2,"replyTime":"2021-04-22T18:10:01.000Z","msg":"律師有料  就唔洗個個坐567碌"},"citedBy":2,"replyTime":"2021-04-22T18:16:53.000Z","msg":"打甩都無用律政師會無限上訴，所以所有同示威有關嘅政治檢控一定無得甩甚至已經有晒判刑標準，之前有法官都講如果佢輕判俾律政師上訴會判得更重<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-22T22:09:50.000Z","msg":"所以捐612會改唔改變到現況？"},{"pid":"1fa34a2cea27aa13e9bf7a00f3c7a147d8d0eea0","tid":2500562,"uid":218652,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T22:09:52.000Z","msg":"Push"},{"pid":"0c104b765c4a9d88fc6e13e3be385e35b980ffae","tid":2500562,"uid":49370,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T22:11:26.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"73297ebab3d58e0dd5e80d2767a45f361badb346","tid":2500562,"uid":83910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T22:11:32.000Z","msg":"push"},{"pid":"9cbdba138fe3c56eccd3490393a2458d1a5d33b2","tid":2500562,"uid":257211,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T22:19:42.000Z","msg":"推"},{"pid":"68a35fbca48014c93bc59623cf2d28f6c2742f92","tid":2500562,"uid":242262,"like":0,"dislike":0,"score":0,"quote":{"pid":"40458adb81c8dfa330bfc6636a99b64dbcf663bb","tid":2500562,"uid":214051,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04-22T18:00:34.000Z","msg":"朋友好早期就已經比狗咬<br />\n經歷過保釋、踢保、再被正式掟上法庭<br />\n而家孭住幾宗罪，經過咗無數次嘅押後<br />\n嚟緊即將到正式審訊嘅日子，一直都係612提供支援<br />\n但因為而家612嘅資金短缺，朋友被通知可能會有變數<br />\n暫時仲研究緊係會點樣嘅安排，原諒我太仔細嘅事唔敢喺到講<br />\n<br />\n我好少開post，我亦都好怕講得太多<br />\n但我好想喺到分享一下，好想喺到借助一下連登嘅力量，希望手足可以幫幫手<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n我知有啲朋友仲會攞音響基金嚟恥笑612<br />\n但一路陪住朋友上庭嘅我真心想喺到分享一下<br />\n朋友由被咬第一日開始、包括保釋、提堂、修訂、押後、上律師樓開會，612全程都安排一個大狀同一個事務律師跟進，我呢個朋友錢唔多，初初搵612幫手時仲好擔心唔知需唔需要比錢，甚至乎佢曾經諗過想慳返啲資源比其他手足而打算簡簡單單認咗佢就算<br />\n但係，係612嘅律師話佢知叫佢唔好放棄，佢哋同我朋友講，錢銀方面唔使擔心，要打就只要拎個信念出嚟就可以<br />\n<br />\n的而且確，由第一日到而家，612都包辦晒朋友官司嘅所有費用，我相信612對其他手足嘅支援都係一樣。<br />\n無論出面嘅人點講，真實感受過嘅就會知，612的確係好多被捕手足嘅一線希望，由其係負擔唔起高昂律師費嘅手足<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />。612提供嘅，唔係求其派一個律師比你，而係提供一幫比到手足希望嘅律師團隊<br />\n<br />\n我唔知會唔會引起大家嘅反感，唔知會唔會有人話我係打手，但係我唔知我仲可以點樣幫到一班被捕手足同我朋友，所以喺呢到，我想懇求一下各位，可以幫幫忙嗎<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />我知武肺影響咗好多朋友仔生計，有能力捐錢嘅當然係最直接嘅方法，即使唔方便嘅，都懇請幫忙推下po，幫忙share下可以嗎，哪怕係ig fb share一下612嘅post，希望都可以有一個機會幫到一眾手足<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />感謝<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://612fund.hk/zh/donate\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2F612fund.hk%2Fzh%2Fdonate&d=0rs6uxY5NhpkL%2Fcp6PdBrSrXKCTJ71YGEIw5q99tfRY%3D&h=001dd6d7\" target=\"_blank\">https://612fund.hk/zh/donate</a>"},"citedBy":0,"replyTime":"2021-04-22T23:00:52.000Z","msg":"推，希望你朋友冇事"},{"pid":"2b8649235c39165d09ba7a8f0cb4e6278afaa9b8","tid":2500562,"uid":98431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T23:02:01.000Z","msg":"一齊頂住"},{"pid":"5f2c6f4d46af82a62884f8cb41cd73202c1646ef","tid":2500562,"uid":122402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T23:02:14.000Z","msg":"Pish"},{"pid":"c56031c00a9bce07d8c0109ab3660fe448c07b55","tid":2500562,"uid":342828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T23:05:25.000Z","msg":"Push."},{"pid":"e831f76764b440e8898328cb42f909bbf2474916","tid":2500562,"uid":47355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T23:18:34.000Z","msg":"一向都支持同捐"},{"pid":"a78a2834d8b570b44af01e4ccf8da801559a5ea3","tid":2500562,"uid":293539,"like":0,"dislike":0,"score":0,"quote":{"pid":"40458adb81c8dfa330bfc6636a99b64dbcf663bb","tid":2500562,"uid":214051,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04-22T18:00:34.000Z","msg":"朋友好早期就已經比狗咬<br />\n經歷過保釋、踢保、再被正式掟上法庭<br />\n而家孭住幾宗罪，經過咗無數次嘅押後<br />\n嚟緊即將到正式審訊嘅日子，一直都係612提供支援<br />\n但因為而家612嘅資金短缺，朋友被通知可能會有變數<br />\n暫時仲研究緊係會點樣嘅安排，原諒我太仔細嘅事唔敢喺到講<br />\n<br />\n我好少開post，我亦都好怕講得太多<br />\n但我好想喺到分享一下，好想喺到借助一下連登嘅力量，希望手足可以幫幫手<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n我知有啲朋友仲會攞音響基金嚟恥笑612<br />\n但一路陪住朋友上庭嘅我真心想喺到分享一下<br />\n朋友由被咬第一日開始、包括保釋、提堂、修訂、押後、上律師樓開會，612全程都安排一個大狀同一個事務律師跟進，我呢個朋友錢唔多，初初搵612幫手時仲好擔心唔知需唔需要比錢，甚至乎佢曾經諗過想慳返啲資源比其他手足而打算簡簡單單認咗佢就算<br />\n但係，係612嘅律師話佢知叫佢唔好放棄，佢哋同我朋友講，錢銀方面唔使擔心，要打就只要拎個信念出嚟就可以<br />\n<br />\n的而且確，由第一日到而家，612都包辦晒朋友官司嘅所有費用，我相信612對其他手足嘅支援都係一樣。<br />\n無論出面嘅人點講，真實感受過嘅就會知，612的確係好多被捕手足嘅一線希望，由其係負擔唔起高昂律師費嘅手足<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />。612提供嘅，唔係求其派一個律師比你，而係提供一幫比到手足希望嘅律師團隊<br />\n<br />\n我唔知會唔會引起大家嘅反感，唔知會唔會有人話我係打手，但係我唔知我仲可以點樣幫到一班被捕手足同我朋友，所以喺呢到，我想懇求一下各位，可以幫幫忙嗎<img src=\"/assets/faces/norm