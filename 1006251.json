ang.com/uploadfile/2019/0130/20190130040152751.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fm1.aboluowang.com%2Fuploadfile%2F2019%2F0130%2F20190130040152751.jpg&h=172c8e31&s={SIZE}\" /><br />\n▼這種薄膜外表就像保鮮膜，但在顯微鏡下，能夠看到內部有許多直徑僅8微米的玻璃珠，外面則包著透明塑膠。<br />\n<img src=\"https://m1.aboluowang.com/uploadfile/2019/0130/20190130040153389.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fm1.aboluowang.com%2Fuploadfile%2F2019%2F0130%2F20190130040153389.jpg&h=fde30d69&s={SIZE}\" /><br />\n▼薄膜由一種名為TPX的塑膠製成。這樣的結構能將陽光反射回去，防止熱量向下滲透。薄膜會將接收的熱量以8到14微米的電磁波形式發射出去。<br />\n<img src=\"https://m1.aboluowang.com/uploadfile/2019/0130/20190130040153260.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fm1.aboluowang.com%2Fuploadfile%2F2019%2F0130%2F20190130040153260.jpg&h=c5aca6ee&s={SIZE}\" /><br />\n▼這種波長的紅外線不會被大氣層反射、吸收或散射。也就是說，薄膜散發出去的熱量幾乎不會被地球再次吸收，自然就能緩解地球變暖的現象了。<br />\n<img src=\"https://m1.aboluowang.com/uploadfile/2019/0130/20190130040153893.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fm1.aboluowang.com%2Fuploadfile%2F2019%2F0130%2F20190130040153893.jpg&h=83b8fe15&s={SIZE}\" /><br />\n▼這種薄膜的降溫效果非常好。實驗證明，將20㎡的薄膜鋪在屋頂上，在室外37&deg;C的情況下，室內可以保持在20&deg;C左右。薄膜的成本非常低，每平方公尺只需要50美分（約台幣15元）。<br />\n<br />\n<a href=\"https://youtu.be/0zvINP6BIj4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F0zvINP6BIj4&d=6VpbUQS5Cy4QwgKrD6%2Fp7gNVisxpnNpADW7ISUiLTyw%3D&h=1f48210b\" target=\"_blank\">https://youtu.be/0zvINP6BIj4</a><br />\n<br />\n這種薄膜的製作工藝並不難，很快就能大規模生產，並投入到市場中。這一發明發表到頂級科技雜誌《Science》後，引起了全世界的關注。<br />\n<br />\n<a href=\"https://hk.aboluowang.com/2019/0130/1239107.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.aboluowang.com%2F2019%2F0130%2F1239107.html&d=6VpbUQS5Cy4QwgKrD6%2Fp7gNVisxpnNpADW7ISUiLTyw%3D&h=1f44f420\" data-auto-link target=\"_blank\">https://hk.aboluowang.com/2019/0130/1239107.html</a>"},"citedBy":1,"replyTime":"2019-02-03T01:25:45.000Z","msg":"<span style=\"font-size: xx-large;\">你即將進入內容農場：<br />\n<a href=\"http://hk.aboluowang.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.aboluowang.com&d=6VpbUQS5Cy4QwgKrD6%2Fp7gNVisxpnNpADW7ISUiLTyw%3D&h=0282a3d2\" data-auto-link target=\"_blank\">hk.aboluowang.com</a><br />\n要繼續嗎？若是感到厭煩，放棄也是一種選擇啊。</span>"},{"pid":"7f32d4fdf4822f3838b78c97ae91f835022f678a","tid":1006251,"uid":36478,"like":25,"dislike":1,"score":24,"citedBy":0,"replyTime":"2019-02-03T01:25:58.000Z","msg":"<img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" />"},{"pid":"c934ddde5c324de4234d3f3be5469baacfe8b799","tid":1006251,"uid":170490,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-02-03T01:25:59.000Z","msg":"&quot;塑膠&quot; 膜<img src=\"/assets/faces/lny/dead.gif\" class=\"hkgmoji\" /><br />\n一定俾環保撚屌死<br />\n識唔識走塑呀<img src=\"/assets/faces/lny/fire.gif\" class=\"hkgmoji\" /><br />\n所以話啲美國科學家真係垃燃圾<img src=\"/assets/faces/lny/donno.gif\" class=\"hkgmoji\" />"},{"pid":"c55d1b6ab92cb3b2b3a561e8dc66a7b01d15c0ed","tid":1006251,"uid":22329,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-02-03T01:32:20.000Z","msg":"香港都唔會用得著啦 除左有錢佬<br />\n<br />\n無可能成層樓整"},{"pid":"e3daee9508704f5ac47a04cbc07a0a5bfc6cf180","tid":1006251,"uid":37918,"like":0,"dislike":1,"score":-1,"quote":{"pid":"69c5c5b2745d7732893256ea59db3dbadd24d640","tid":1006251,"uid":36478,"like":82,"dislike":2,"score":80,"quote":{"pid":"e27227cc282481011e4683865540aa1b960f78dc","tid":1006251,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-02T22:09:39.000Z","msg":"不知不覺間，冬天已經過了一大半。今年的冬天這麼暖和，接下來的夏天會怎麼樣？簡直不敢想像！天氣熱的時候，很多人選擇待在房間里吹冷氣。但一天24小時吹冷氣太耗電，對身體不好，對環境也不好。有什麼簡單、便宜的方法降溫呢？<br />\n<br />\n▼美國科羅拉多大學的2位華裔教授，楊榮貴和尹曉波，發明了一種神奇的薄膜，將它鋪在屋頂，就能輕鬆降溫。<br />\n<img src=\"https://m1.aboluowang.com/uploadfile/2019/0130/20190130040152751.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fm1.aboluowang.com%2Fuploadfile%2F2019%2F0130%2F20190130040152751.jpg&h=172c8e31&s={SIZE}\" /><br />\n▼這種薄膜外表就像保鮮