>\nd黑警拉完你係旺角警署老強<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},{"pid":"9c2ef6bc0048f05f437f197f1bd928d91c12ea9a","tid":1293434,"uid":108756,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-07-07T16:21:08.000Z","msg":"戇撚鳩 你地未查過風化案？非禮偷拍強姦香港無發生過？<br />\n記唔記得舊年先有啟德色魔？做公務員真係活係平行時空<br />\n癡撚線 你放佢分分鐘都仲有外國人無知吹奏下你有人情味 明白旅遊人仕唔熟香港地方法例<br />\n所以話毅進咪就係呢啲囉 用下腦你都搵到位吹奏下自己啦都唔撚識"},{"pid":"90d409bfcbe37b0fc6711075bcae8e2e7f9c0c06","tid":1293434,"uid":117276,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-07-07T16:21:48.000Z","msg":"香港需要槍權<br />\n槍權就係美國強大嘅其中一個因素"},{"pid":"96b26edac03f0f3f48cb92f3d82679faeaff832a","tid":1293434,"uid":14918,"like":4,"dislike":0,"score":4,"quote":{"pid":"90d409bfcbe37b0fc6711075bcae8e2e7f9c0c06","tid":1293434,"uid":117276,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-07-07T16:21:48.000Z","msg":"香港需要槍權<br />\n槍權就係美國強大嘅其中一個因素"},"citedBy":0,"replyTime":"2019-07-07T16:24:29.000Z","msg":"市民強大<br />\n國家就會強大<br />\n但東方有個國家唔信呢套，所以成千年來，塊土地只孕育出極權腐敗國家"},{"pid":"a41fdae49478149e1669568b8a86d8335455e0ca","tid":1293434,"uid":33053,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-07T16:24:41.000Z","msg":"黑警同休班警唔係度咪安全囉"},{"pid":"80bcb465cc3be4dfd3a192c5fbb38b616429cd61","tid":1293434,"uid":70888,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-07T16:26:24.000Z","msg":"1"},{"pid":"71751d0c915f0ebc0ee2d2392aee274278701881","tid":1293434,"uid":58841,"like":0,"dislike":0,"score":0,"quote":{"pid":"9cac13808a7bf2e50dad45383f3f5cfdbe85f9e0","tid":1293434,"uid":60393,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-07T16:19:03.000Z","msg":"一年前<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-07T16:29:17.000Z","msg":"即係話<br />\n一年前已經係咁撚樣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}