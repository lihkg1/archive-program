2Fpics.dmm.co.jp%2Fdigital%2Fvideo%2Fsoe00339%2Fsoe00339pl.jpg&d=KnvXPE3nScOl%2BNY7DWqCyp4f2li5K%2Fs6EGgmwhpeblA%3D&h=5ebd69e7\" target=\"_blank\">http://pics.dmm.co.jp/digital/video/soe00339/soe00339pl.jpg</a>"},{"pid":"4ce410ed794a28de317e008185981173faf6cbaa","tid":939483,"uid":79563,"like":0,"dislike":0,"score":0,"quote":{"pid":"afba682ad012c5c18541369de13c76e7cc94789d","tid":939483,"uid":114751,"like":3,"dislike":1,"score":2,"quote":{"pid":"d236a36bc745383cef78d3b7e2af334b68033d33","tid":939483,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-13T07:35:56.000Z","msg":"<a href=\"https://tw.appledaily.com/new/realtime/20181211/1481230/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.appledaily.com%2Fnew%2Frealtime%2F20181211%2F1481230%2F&d=KnvXPE3nScOl%2BNY7DWqCyp4f2li5K%2Fs6EGgmwhpeblA%3D&h=46c55e1c\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftw.appledaily.com%2Fnew%2Frealtime%2F20181211%2F1481230%2F&h=ad7cda75\" target=\"_blank\">https://tw.appledaily.com/new/realtime/20181211/1481230/</a><br />\n<br />\n<img src=\"https://img.appledaily.com.tw/images/ReNews/20181211/640_08328af9f195cb33e982ae543becbb8e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.appledaily.com.tw%2Fimages%2FReNews%2F20181211%2F640_08328af9f195cb33e982ae543becbb8e.jpg&h=436d3dce&s={SIZE}\" /><br />\n<br />\n出道16年的前日本AV女優蒼井空，今天和老公DJ NON相偕訪台，舉行感謝記者會，宣布全新計畫啟動，這也是夫妻倆今年元旦閃婚後首度同台亮相，DJ NON也在記者會上獻出打碟秀熱鬧開場，夫妻合體公開曬恩愛。她在記者會上羞認懷孕5個月，表示：「我很激動，也很感恩， 希望我的寶寶能感受到大家的祝福，一路以來我是個幸福的人，也希望繼續努力堅持做自己，謝謝大家！」<br />\n <br />\n蒼井空結婚生子的夢想完成一半，婚後積極「做人」，但之前檢查後發現自己不容易受孕，一直努力吸收治療不孕症的資訊。她透露自己卵子發育不佳，荷爾蒙檢查的數值低到「絕望」，深深體會到年紀大了。35歲的蒼井空曾是日本AV界的代表性人物，拍過的床戰動作片不計其數，也曾為日本性感女團「惠比壽麝香葡萄」初代成員之一。2010年11月11日她在生日當天開設新浪微博帳號，短短50分鐘內引發3萬博友圍觀，微博帳號粉絲已逾1900多萬，近年來更經常往來中國大陸全方位發展。<br />\n <br />\n去年1月18日，她在個人推特上回覆網友提問，表示已告別AV女優身分，也不再拍攝相關作品，事實上她從2011年7月後便沒再拍過AV，等同從AV業界引退。晉升人妻的她，婚後仍寄情於工作，今天在記者會上也宣佈明年自己的XGX計劃正式啟動，屆時透過網路平台與虛擬貨幣和粉絲互動，去實現夢想的計劃。她說：「未來我也會減少演藝工作，幫助這個計劃盡快完成。」<br />\n<br />\n蒼井空受訪表示，因為今天難得和老公同台，心情上一直很緊張，得知懷孕後，她和老公都嚇一跳，雖然孕吐很嚴重，但還是很開心。她說：「我的體質不容易懷孕，之前有去看醫生調養身體，雖然還不知道小孩的性別，但和老公都叫baby小non。」她也坦言想生2、3個孩子，最好是1女2男，她大讚老公很溫柔，自從她確定懷孕後，家裡打掃、洗衣服等家事，全由老公一手包辦，會一輩子感謝他，她也希望自己能成為理解小孩、親子互動良好的媽媽。<br />\n<br />\n蒼井空今年7月受邀出席雲南的一場公益活動，擔任「助學使者」，卻因戴有在中國富有政治意涵的紅領巾，遭中國官方批評「歪曲、醜化、褻瀆英雄烈士」，邀請她的上海臻海公司還因此公開向全中國人民道歉，表示誤用紅領巾，傷害了中國廣大人民的感情，保證今後不會再發生類似事件。中國相關部門最近則對該企業開罰100萬元人民幣（約455萬元新台幣）。"},"citedBy":1,"replyTime":"2018-12-13T10:08:52.000Z","msg":"真心祝佢幸福<br />\n<br />\n今晚搵佢啲片汁返劑賀賀佢<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-12-13T10:53:47.000Z","msg":"慢慢揀, 好多都大平賣<img src=\"/assets/faces/big/sosad.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"http://www.dmm.co.jp/digital/videoa/-/list/=/article=actress/id=3996/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.dmm.co.jp%2Fdigital%2Fvideoa%2F-%2Flist%2F%3D%2Farticle%3Dactress%2Fid%3D3996%2F&d=KnvXPE3nScOl%2BNY7DWqCyp4f2li5K%2Fs6EGgmwhpeblA%3D&h=788af9c6\" target=\"_blank\">http://www.dmm.co.jp/digital/videoa/-/list/=/article=actress/id=3996/</a>"},{"pid":"a0944afb4cfd9557764376d6fc1664b172acf17c","tid":939483,"uid":48631,"like":1,"dislike":1,"score":0,"quote":{"pid":"fedbf4a6a7c1046e1373cadb3f42df01cb3aa05d","tid":939483,"uid":8308,"like":1,"dislike":1,"score":0,"quote":{"pid":"06e468f06a083dcfcc99e0d65baa3af209c44630","tid":939483,"uid":79563,"like":28,"dislike":4,"score":24,"quote":{"pid":"cd1535fdfb10b77675c3adedf75bcf70164aaa4c","tid":939483,"uid":8850,"like":15,"dislike":21,"score":-6,"citedBy":1,"replyTime":"2018-12-13T08:11:09.000Z","msg":"生個女出黎 個女再拍過<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-12-13T08:12:23.000Z","msg":"母女共演?"},"citedBy":4,"replyTime":"2018-12-13T08:13:29.000Z","msg":"到時50路 不了<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-13T11:07:39.000Z","msg":"過4,5年後都未到50路<img src=\"/assets/faces/lomoji/04.png\" class=\"hkgmoji\" />"},{"pid":"