h=f84d114c\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210209%2FIOK43BNBFJBODGN7CP6FKOD4WA%2F&h=48e220bb\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20210209/IOK43BNBFJBODGN7CP6FKOD4WA/</a>"},{"pid":"385dc07af77ee0f82c9eabbc2cb5e5a3ea358bf7","tid":2400732,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-09T10:22:46.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"d89e2c12403cc69a57904434eacf0b12963698eb","tid":2400732,"uid":191588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-09T10:28:37.000Z","msg":"Post"},{"pid":"094fbeaba734fe3d27fa6bab5eacecd3dfb4cf5c","tid":2400732,"uid":191588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-09T10:29:05.000Z","msg":"Push"},{"pid":"e426c56b40830aa3d9e34badefd4740bfefb8659","tid":2400732,"uid":238828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-09T10:33:27.000Z","msg":"一日比一日cls"},{"pid":"42222a6b3e68394e622b440da8d765500f411ee8","tid":2400732,"uid":56115,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-09T10:41:52.000Z","msg":"裁判官又指譚不理警告，<span class=\"red\">用鐳射筆照警署，裁定阻差辦公罪成</span>；至於在公眾地方管有攻擊性武器罪，官指本案沒有直接證據顯示謝至禮的意圖，須以環境證供推論。她指鐳射筆常見於示威現場，涉案鐳射筆放在謝至禮的褲袋，是伸手可取的位置。當時眾人行為針對警方，<span class=\"red\">謝亦在人群內，可見他有意圖傷害警員，終裁定罪名成立。</span><br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />講完自己有冇笑<br />\n<br />\n<a href=\"https://www.thestandnews.com/court/8-11-%E5%B0%87%E8%BB%8D%E6%BE%B3-%E9%9D%9E%E6%B3%95%E9%9B%86%E7%B5%90%E7%AD%89%E7%BD%AA%E6%88%90-%E9%A4%90%E5%BB%B3%E7%B6%93%E7%90%86%E5%88%A4%E5%9B%9A-5-%E5%80%8B%E6%9C%88-%E7%94%B7%E5%AD%B8%E7%94%9F%E5%88%A4%E5%85%A5%