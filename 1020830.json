},{"pid":"8bc933532fae33f64489fb50dbc80b44d07dc1cc","tid":1020830,"uid":65320,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-14T02:53:16.000Z","msg":"姊弟型人<img src=\"/assets/faces/lm2lny/sosad.gif\" class=\"hkgmoji\" /> <br />\n召喚軍官<img src=\"/assets/faces/lm2lny/support.gif\" class=\"hkgmoji\" />"},{"pid":"de2f2b5bc23122c4b1bb9b21797fee31f1c63580","tid":1020830,"uid":35143,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-14T02:56:21.000Z","msg":"真人講句 咁係你廢姐 比你家姐食住..."},{"pid":"b6504c48c20a9e4820fdff295eb29b60078a4029","tid":1020830,"uid":129660,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-14T03:02:13.000Z","msg":"樓主係男定女<br />\n佢擺明恰鳩你<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6ceae223d3c0fa26fead4a6e3c05ce6efd000675","tid":1020830,"uid":37919,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-14T04:04:04.000Z","msg":"Sorry啊，我真係好幸福<img src=\"/assets/faces/lny/smile2.gif\" class=\"hkgmoji\" />"},{"pid":"3da215625e5baa994ce8fb9035827f04af53a023","tid":1020830,"uid":163435,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-14T04:26:33.000Z","msg":"點解同我家姐一樣<img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" /> <br />\n我做細妹做到家姐咁咩都就晒佢<img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" />"},{"pid":"c324129d6d48ccc8023fda1cb6d793c5679c0d95","tid":1020830,"uid":102994,"like":0,"dislike":0,"score":0,"quote":{"pid":"de2f2b5bc23122c4b1bb9b21797fee31f1c63580","tid":1020830,"uid":35143,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-14T02:56:21.000Z","msg":"真人講句 咁係你廢姐 比你家姐食住..."},"citedBy":0,"replyTime":"2019-02-14T04:27:29.000Z","msg":"而家就係唔忍先成日嘈<img src=\"/assets/faces/lny/donno.gif\" class=\"hkgmoji\" />"},{"pid":"c25f56ce7823fbdca3a714f2cf8ba4440277d86a","tid":1020830,"uid":102994,"like":1,"dislike":0,"score":1,"quote":{"pid":"b6504c48c20a9e4820fdff295eb29b60078a4029","tid":1020830,"uid":129660,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTi