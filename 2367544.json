/faces/lm2/@.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"0c0a141daf4f8b7acbba58ecfceb2b69fcfc8fcd","tid":2367544,"uid":39666,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2021-01-16T07:20:10.000Z","msg":"你食過臭茜 請即刻漱口<br />\n把口臭柒過老鼠屎沒有<br />\n抑鬱的茜味沾滿你口<br />\n你賤過狗 而我卻在受<br />\n<br />\n你令我作嘔 陣味湧入喉<br />\n湯底已散落邪毒臭茜 我怎接受<br />\n我祝福你無朋友 臭茜啪撚到滅口<br />\n閪水都發臭"}}