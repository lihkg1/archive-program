464_1260.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.muji.net%2Fimg%2Fitem%2F4550002994464_1260.jpg&h=1cef3a58&s={SIZE}\" />"},{"pid":"1f369924076b8221afb8537a83001087b0464bf5","tid":1794311,"uid":75760,"like":7,"dislike":0,"score":7,"quote":{"pid":"11181d2db620b9556d421aa7b737c7c532e48310","tid":1794311,"uid":102999,"like":18,"dislike":1,"score":17,"citedBy":2,"replyTime":"2019-12-23T05:24:20.000Z","msg":"如果剩係得手足用呢個袋好易比人target到<br />\n要做就真係做到全民一齊用，日用夜用，返工返學都用，裝自己野又好乜都好，和理非無敏感野比人搜都唔怕，咁先可以掩到真正手足善用呢個袋<img src=\"/assets/faces/pigxm/lihkg.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-23T05:53:04.000Z","msg":"Agree<br />\n所以其實我覺得可以有兩樣野做<br />\n<br />\n1. 眾籌果個page開埋賣一個 唔洗sponsor多一個比手足嘅Option<br />\n<br />\n我讀緊書 六百蚊個袋 少許貴 我到依家都猶豫緊買唔買好<br />\n三百 （或者mark up少少到400 一齊籌啲比手足）我會狗沖<br />\n<br />\n所以留多個option 想捐可以捐，無能力捐呀 唔想付出咁多呀 想打卡呀 總之個價值佢地比到三百幾一個嘅人 就單買一個 做大啲人數base先， 人多就有cover<br />\n<br />\n2. 可以market呢個袋係一個多功能運動袋 將佢嘅function同社運脫勾 然後主動聯絡下運動店舖 或者類似logon呢類嘅雜貨店去寄賣<br />\n個袋設計唔講功能其實都幾好 我正正常常行街 或者落街做運動都想有個咁嘅細袋袋衣物 鞋 同水樽<br />\n定價三百左右我都會想買個<br />\n最理想係 呢個袋 就好似jansport啲背囊咁 <br />\n學生番學咩 唔知情嘅藍絲咩黎番工出門行山<br />\n<br />\n咁唔通我係狗 見到個咁common嘅袋就查咩"},{"pid":"735cc1c11abd0d852366d41023a068a8234e544a","tid":1794311,"uid":12912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-23T05:56:05.000Z","msg":"推"},{"pid":"b03addfac559428169b0be5ce49a99bf93438c18","tid":1794311,"uid":200550,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-23T05:56:33.000Z","msg":"推"},{"pid":"2d42a0b0eb829a690477055e187a9c6647c71939","tid":1794311,"uid":69334,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-23T05:57:01.000Z","msg":"幫推<br />\n<br />\n<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n-----------------<br />\n香港獨立，唯一出路<br />\n<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"b6d595b9ac0942a4b8bcd26c