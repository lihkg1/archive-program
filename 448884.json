3Wv%2FuCJwdwWxT4%3D&h=03d64019\" target=\"_blank\">http://www1.ozp.tpb.gov.hk/gos/?x=835209.9324506689&amp;y=815301.7753767486&amp;z=8&amp;b=basemap_0&amp;l=14-1-0-0.7%2C18-1-1-0.0%2C19-1-0-0.7%2C7-1-0-0.7%2C20-1-0-0.7</a> <br />\n<img src=\"http://www1.ozp.tpb.gov.hk/arcgis/rest/directories/arcgisoutput/ExportExtractPlan_GPServer/_ags_WebMap_503ab7f0-ba8d-11e7-8297-c81f66d37e31.PNG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww1.ozp.tpb.gov.hk%2Farcgis%2Frest%2Fdirectories%2Farcgisoutput%2FExportExtractPlan_GPServer%2F_ags_WebMap_503ab7f0-ba8d-11e7-8297-c81f66d37e31.PNG&h=31ff1610&s={SIZE}\" /></blockquote><br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> <br />\n想問點解堅尼地道會拉直咗嘅<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /></blockquote><br />\n都話份OZP係反映正義道連接堅尼地道嘅規劃, 點解未起唔好問我</blockquote><br />\n[edit] 留意 More Info 正義道延伸連接中環P2路(龍和道)同待設計嘅正義道-堅尼地道路口 <br />\n<a href=\"http://www.epd.gov.hk/eia/register/report-bc/eia126/fr.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.epd.gov.hk%2Feia%2Fregister%2Freport-bc%2Feia126%2Ffr.pdf&d=iJE0eaRx9joIX8Y%2Bte0ApwhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=83c1fca2\" target=\"_blank\">http://www.epd.gov.hk/eia/register/report-bc/eia126/fr.pdf</a> <br />\n<a href=\"http://www.legco.gov.hk/yr05-06/english/panels/plw/papers/plw1025cb1-118-5e-scan.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.legco.gov.hk%2Fyr05-06%2Fenglish%2Fpanels%2Fplw%2Fpapers%2Fplw1025cb1-118-5e-scan.pdf&d=iJE0eaRx9joIX8Y%2Bte0ApwhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=fd02c94d\" target=\"_blank\">http://www.legco.gov.hk/yr05-06/english/panels/plw/papers/plw1025cb1-118-5e-scan.pdf</a></blockquote><br />\n[edit] 唔係你估而家正義道-金鐘道交匯處個 system trumpet 同OZP畫嗰個 four-way trumpet interchange 起嚟把撚, 本應興建沙中線重建夏慤花園係個好嘅工程時機可能可以同期進行配合施工, 如果話等金鐘廊重建噉都唔係好關事 <br />\n反而中環繞道灣仔出入口連接路同中區擴展部分OZP(S/H24/8)撻用途未定80mPD高嘅GIC(2)地就牽連到, 中環海濱堆行人天橋又唔知幾時起"},{"pid":"dc434a8175c7c079701be5e926e9106ef9bc5e14","tid":448884,"uid":55732,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-26T22:51:10.000Z","msg":"既然佢成日都大灣區大灣區咁鳩叫，又話整合資源，咁第一件事應該送撚晒班支那軍上廣東，騰出地方俾香港發展"},{"pid":"f6bb9faa1ac0c5050800d1e387dc0115bfd9f81f","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-26T23:08:43.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote>槍會山軍營要成個交, 中環軍營有威爾斯親王大廈留得, 奧斯本軍營可以交北面大半面積</blockquote><br />\n威爾斯親王大廈留嚟改做甲級商厦啦</blockquote><br />\n香港國防部想擺邊? 唔理添馬艦, 中環軍營西半做政府大廈就幾好 <br />\n收咗正義道軍營先, 搞掂亞洲協會條路連接返堅尼地道 <br />\n金鐘站夏慤花園同軍器廠街警察總部個規劃又麻麻 (黃竹坑警察學院直頭阻住晒)</blockquote><br />\n如果你假設脫離中國之後需要總部的話，拆西環中聯辦再起過座囉</blockquote><br />\n中国或其領土繼承國家唔使大使館? 拆咗原址都可以起過棟</blockquote><br />\n踢去洪水橋啦"},{"pid":"aeaf8b59b74ac3755308ba9b125641aa500755a1","tid":448884,"uid":56015,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2017-10-26T23:20:53.000Z","msg":"<blockquote>又黎自high post<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n咩叫自high?<br />\n中國軍隊阻撚住晒唔屌得？"},{"pid":"3e7ea218ca85010416214eb5c5e7561ede9d21d1","tid":448884,"uid":52595,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-26T23:26:23.000Z","msg":"此回覆已被刪除"},{"pid":"255d8c65c78b216b76c8213dc3dca9821ab8f9d5","tid":448884,"uid":53223,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-10-26T23:32:38.000Z","msg":"港島九龍地區只會留返，政府唔會輕易攞嚟起樓"},{"pid":"5d6c90eac81e2796b835ea10e922511da8cddbfe","tid":448884,"uid":56015,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-26T23:46:38.000Z","msg":"<blockquote>港島九龍地區只會留返，政府唔會輕易攞嚟起樓</blockquote><br />\n中國軍隊嘔返晒啲地出嚟先講啦"},{"pid":"b88e50d5b918d52af4074d0e27ef6bf82b53c513","tid":448884,"uid":8009,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2017-10-26T23:48:27.000Z","msg":"支持解放軍行咇<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"1cf8190f1ec0699e66a3822ec54657d629f3ceb5","tid":448884,"uid":34103,"like":0,"dislike":7,"score":-7,"citedBy":0,"replyTime":"2017-10-26T23:52:38.000Z","msg":"此回覆已被刪除"},{"pid":"63620eb0883d7eef04b158f662eb44a4d78bb8c8","tid":448884,"uid":56015,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-10-26T23:57:19.000Z","msg":"<blockquote>點用要交番出黎？<br />\n有咩事我地香港人需要解放軍</blockquote><br />\n香港人就要趕去大灣區，靚地留畀中國？食屎啦<br />\n香港人唔需要中國軍隊，返深圳河以北啦垃圾"},{"pid":"abd29c21ff31170e76b9eaedaed87a87ed8ab029","tid":448884,"uid":56015,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-26T23:57:47.000Z","msg":"<blockquote>支持解放軍行咇<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /></blockquote><br />\n返深圳河以北行飽佢"},{"pid":"917577fc1454e082d4bc9025bff23558d399cb48","tid":448884,"uid":40828,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-27T00:04:48.000Z","msg":"而家錦田石崗一帶起樓有高度限制，就係因為軍營有條跑道要比飛機升降。呢啲野搬走佢啦"},{"pid":"b30d0b1907d67d28588215260cdee9160973e85a","tid":448884,"uid":91931,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-10-27T00:06:32.000Z","msg":"最撚威脅香港人就係支拿解放軍<br />\n當年邊個喊打喊殺話收唔番就打"},{"pid":"8ee80bffbf187282168314ad90e6f78efc095b38","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T00:16:41.000Z","msg":"<blockquote>而家錦田石崗一帶起樓有高度限制，就係因為軍營有條跑道要比飛機升降。呢啲野搬走佢啦</blockquote><br />\n搬走佢，錦田做副都心可能都唔錯，好過咩都逼晒喺九龍港島北"},{"pid":"f890fc121c6a92208b28dfc7fb0d4759029aee76","tid":448884,"uid":2383,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T00:23:25.000Z","msg":"要啦班垃圾日日係度鳩fing"},{"pid":"3d5aca20260bba90b25315e2e05edcea062bf23d","tid":448884,"uid":53026,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-10-27T00:41:28.000Z","msg":"覺唔覺中國人應該返回中國？"},{"pid":"5567baf345867b98183bfd24d6c09080c6174c14","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T00:57:35.000Z","msg":"<blockquote>要啦班垃圾日日係度鳩fing</blockquote><br />\n咪就係"},{"pid":"07a6847044c25138e7567b5d963b27e4b5a9f7ea","tid":448884,"uid":56015,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-10-27T01:38:32.000Z","msg":"<blockquote>最撚威脅香港人就係支拿解放軍<br />\n當年邊個喊打喊殺話收唔番就打</blockquote><br />\n所以仲有人話需要中國軍隊, 黐線"},{"pid":"125e91298a6e266e04d85720cdf3d2d3a4191800","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T03:37:10.000Z","msg":"<blockquote><blockquote>而家錦田石崗一帶起樓有高度限制，就係因為軍營有條跑道要比飛機升降。呢啲野搬走佢啦</blockquote><br />\n搬走佢，錦田做副都心可能都唔錯，好過咩都逼晒喺九龍港島北</blockquote><br />\n好好地利用個錦上路站<br />\n(但屯門元朗多人上西鐵, 真係要諗諗其他方法)"},{"pid":"17b867dd2912663c3b076e6d6bccb6ab186e3cf8","tid":448884,"uid":92301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T03:44:35.000Z","msg":"俾返英軍is ok"},{"pid":"4e1575b1ad7d0d471a27f635db0e0009c5c16166","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T03:54:42.000Z","msg":"<blockquote>俾返英軍is ok</blockquote><br />\n假設回歸英國都好, 九龍塘, 中環,槍會山呢堆, 點都要嘔返出嚟啦, 搬遠啲啦大佬.<br />\n<br />\n好似以前咁, 九龍公園就係英軍交還畀香港政府"},{"pid":"57f00f39bbad5ca04435476ff99550d80946998b","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T04:21:15.000Z","msg":"<blockquote><blockquote>俾返英軍is ok</blockquote><br />\n假設回歸英國都好, 九龍塘, 中環,槍會山呢堆, 點都要嘔返出嚟啦, 搬遠啲啦大佬.<br />\n<br />\n好似以前咁, 九龍公園就係英軍交還畀香港政府</blockquote><br />\n九龍公園前身是威菲路軍營，1967年，駐港英軍停止使用該軍營後，市政局於1970年2月於原來地址改為興建公園，佔地11.79公頃，並且在1970年6月24日，第24任香港總督戴麟趾爵士主持揭幕[1]。公園曾經在1980年代初由前英皇御准香港賽馬會耗資達3億港元進行重新興建工程，並且在1989年2月完成擴建，面積擴展至13.3公頃，新增了室內游泳池及運動場設施。另外，兒童歷奇樂園仍然有當年軍營炮台的遺跡。<br />\n<a href=\"https://zh.wikipedia.org/wiki/%E4%B9%9D%E9%BE%8D%E5%85%AC%E5%9C%92\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E4%25B9%259D%25E9%25BE%258D%25E5%2585%25AC%25E5%259C%2592&d=iJE0eaRx9joIX8Y%2Bte0ApwhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=20a8ab5b\" target=\"_blank\">https://zh.wikipedia.org/wiki/%E4%B9%9D%E9%BE%8D%E5%85%AC%E5%9C%92</a>"},{"pid":"a2f057f01aced158b53828e80e558e05ee1e2339","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T04:26:41.000Z","msg":"深水埗軍營是香港昔日一個英軍軍營，位於九龍深水埗近東京街一帶。<br />\n<br />\n深水埗軍營建於1927年，在香港日佔時期曾被日軍用作囚禁戰俘的集中營，囚禁的戰俘包括英國、加拿大及印度人。二次世界大戰後，深水埗軍營重新被英軍使用，1977年軍營關閉，部份營房曾成為難民營，收容當時湧入的越南難民，而部份土地其後則改建成麗閣邨及深水埗公園。"},{"pid":"188b0995cd77c314edabf5c30d9c5e2ceb722bc7","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T04:27:49.000Z","msg":"高希馬軍營 - 位處新界大埔仔，現址為香港科技大學。"},{"pid":"490aa9cb295c46737cf5ce9acddf275933bd59f2","tid":448884,"uid":34103,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-10-27T04:31:51.000Z","msg":"此回覆已被刪除"},{"pid":"3575b77d85acf8853914ea6f3ca7ba10534965ce","tid":448884,"uid":56015,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-10-27T04:33:30.000Z","msg":"<blockquote><blockquote><blockquote>點用要交番出黎？<br />\n有咩事我地香港人需要解放軍</blockquote><br />\n香港人就要趕去大灣區，靚地留畀中國？食屎啦<br />\n香港人唔需要中國軍隊，返深圳河以北啦垃圾</blockquote><br />\n你地10%人又想代表我地成個香港唔需要中國軍隊<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /></blockquote><br />\n10%? 你作就係呀? 香港係未經公投而被中國佔領.<br />\n<br />\n<a href=\"http://www.vjmedia.com.hk/articles/2014/01/10/59941/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.vjmedia.com.hk%2Farticles%2F2014%2F01%2F10%2F59941%2F&d=iJE0eaRx9joIX8Y%2Bte0ApwhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=573fdc42\" target=\"_blank\">http://www.vjmedia.com.hk/articles/2014/01/10/59941/</a><br />\n 82年香港革新會民調：只有4%港人希望回歸中國<br />\n<br />\n<a href=\"https://lihkg.com/thread/445990/page/1\" target=\"_blank\">https://lihkg.com/thread/445990/page/1</a>"},{"pid":"5b836ba874572112954742a2400cf8d56cdcd2c4","tid":448884,"uid":60977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T04:38:48.000Z","msg":"石崗個面其實幾空下"},{"pid":"41eefa1f06eb2bfe8253b9fd1bf0c87df0493431","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T06:05:40.000Z","msg":"<blockquote>石崗個面其實幾空下</blockquote><br />\n所以如果搬走個軍營用嚟發展應該唔錯"},{"pid":"771575e535bd78d09c69c46fbae915c0edbadb05","tid":448884,"uid":82720,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T06:17:04.000Z","msg":"<blockquote>點用要交番出黎？<br />\n有咩事我地香港人需要解放軍</blockquote><br />\n收啦你隻支那狗撚係香港人"},{"pid":"bc90531467d9d91380220b41fb331e61c2e55652","tid":448884,"uid":56015,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-27T06:24:48.000Z","msg":"<blockquote><blockquote>點用要交番出黎？<br />\n有咩事我地香港人需要解放軍</blockquote><br />\n收啦你隻支那狗撚係香港人</blockquote><br />\n需要解放軍就返中國囉咁簡單"},{"pid":"b3206ff954f0ceb51d0c27c63b6d8e7e3cdabe20","tid":448884,"uid":56015,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-27T07:30:51.000Z","msg":"當年英軍都會交返啲軍營畀香港人用。而家班中國軍隊？食屎啦"},{"pid":"a0ed2037df05449f02e24e351886d6b66d7f3737","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T10:03:10.000Z","msg":"<blockquote>中國軍隊應該交哂啲地比美軍</blockquote><br />\n畀返晒香港先真"},{"pid":"7e3e50c65f7675f7987d0ede56eaa35cdf1833ee","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T11:23:23.000Z","msg":"呢個post都幾少親中嘅入嚟，有少少估唔到"},{"pid":"28bfabf01d89eae127276608eec613c427931306","tid":448884,"uid":86841,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2017-10-27T11:44:19.000Z","msg":"此回覆已被刪除"},{"pid":"e5c9e00c62fae22701fd7e0b5271e1f737797d10","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T12:33:41.000Z","msg":"<blockquote>香港房屋問題都唔係土地唔夠，又借D意spin落中國到</blockquote><br />\n邊忽係&ldquo;借啲意spin落中國度？&rdquo;香港房屋問題點會唔關中國事？"},{"pid":"3e551279cc55215f8559a1ddacb56f9a7eee3ea2","tid":448884,"uid":56015,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-10-27T12:37:29.000Z","msg":"<blockquote><blockquote>香港房屋問題都唔係土地唔夠，又借D意spin落中國到</blockquote><br />\n邊忽係&ldquo;借啲意spin落中國度？&rdquo;香港房屋問題點會唔關中國事？</blockquote><br />\n港中殖民政府就中國選出嚟嘅。<br />\n84年英中聯合聲明Land Leasing Annex III 限制每年賣地50公頃又係中國要求嘅。<br />\n軍事用地又係中國佔據嘅<br />\n<br />\n邊忽唔關中國事？講事實叫spin?"},{"pid":"a51b2b200b4d1a972e0293ff722e644aaf515fca","tid":448884,"uid":22858,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-29T05:54:08.000Z","msg":"<strong><span style=\"font-size: xx-large;\">屌你老母連狗尼住個仆街冚家鏟，以為搬鳩曬啲post去站務台就解決咗個問題。五毛根本係時事台災難，佢哋撚會搞其它台咩，所以反五毛唔柒係會員糾紛呀戇鳩。鴕鳥政策轉移視線正正突顯荒謬，實際上你係同流合污狼狽為奸！</span></strong><br />\n<br />\n<img src=\"/assets/faces/big/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"91490d96ca7a6e51982bc9ea079848c9eae87970","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-29T13:41:27.000Z","msg":"<blockquote><blockquote><blockquote>香港房屋問題都唔係土地唔夠，又借D意spin落中國到</blockquote><br />\n邊忽係&ldquo;借啲意spin落中國度？&rdquo;香港房屋問題點會唔關中國事？</blockquote><br />\n港中殖民政府就中國選出嚟嘅。<br />\n84年英中聯合聲明Land Leasing Annex III 限制每年賣地50公頃又係中國要求嘅。<br />\n軍事用地又係中國佔據嘅<br />\n<br />\n邊忽唔關中國事？講事實叫spin?</blockquote><br />\n邊忽唔關中國事？搵到未?"},{"pid":"39b3de9399d8fdfd52998b80b6ebd9e007124eca","tid":448884,"uid":16915,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-29T13:43:43.000Z","msg":"得罪講句，有可能咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9b4bc1ad65f17034a74d1049cc448ab1803b5710","tid":448884,"uid":60977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-29T13:47:13.000Z","msg":"推"},{"pid":"a6ad9d6b355d3b00810d4bff49cb96e86d7c869b","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-29T13:47:31.000Z","msg":"<blockquote>得罪講句，有可能咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n可唔可能同應唔應該, 就兩回事嚟嘅.<br />\n但講都唔講, 只會更唔可能"},{"pid":"eb12836d8499f7db2c75f7f57256d0209c845ae9","tid":448884,"uid":20227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-29T13:47:40.000Z","msg":"此回覆已被刪除"},{"pid":"7ab72b7fecf48e1e0f038bc4b3104de30d76770d","tid":448884,"uid":60977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-29T14:04:15.000Z","msg":"睇下有邊個政客搵到好少少既籍口可以做議題"},{"pid":"dd5ba23d04f6f40838045563899ea2bed83cbe7e","tid":448884,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-29T15:05:53.000Z","msg":"覺"},{"pid":"75b8b8815e4e207f46f203b68041e9a720fe8c5a","tid":448884,"uid":124363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-29T15:07:15.000Z","msg":"成班on9得把口 傻仔 發咁乜夢啊"},{"pid":"6acddb6ad0cc18e9e6316f53b4266ba204c86772","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-31T00:28:15.000Z","msg":"<blockquote>睇下有邊個政客搵到好少少既籍口可以做議題</blockquote><br />\n呢啲議題，得本土派會提嘅啫。<br />\n仲有邊個本土派喺議會？"},{"pid":"69bb02d11d2a69701f0697ea9d7bfef23a1bf689","tid":448884,"uid":23221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-31T00:43:01.000Z","msg":"<blockquote>有責任保護香港人架</blockquote><br />\n<br />\n<br />\n洗撚佢地陀地喇 ！"},{"pid":"fc63b0f8fc1f82258e9c80e822b1be2d4e8f792c","tid":448884,"uid":23221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-31T00:43:47.000Z","msg":"有9隻中國狗比左負皮"},{"pid":"be3e9f00a6300e16d93bcfa022c23d8c986f11eb","tid":448884,"uid":56015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-31T01:23:39.000Z","msg":"<blockquote><blockquote>點用要交番出黎？<br />\n有咩事我地香港人需要解放軍</blockquote><br />\n有咩用？<br />\n打風執垃圾？</blockquote><br />\n<a href=\"http://www.appledaily.com.tw/realtimenews/article/new/20170825/1190627/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.appledaily.com.tw%2Frealtimenews%2Farticle%2Fnew%2F20170825%2F1190627%2F&d=iJE0eaRx9joIX8Y%2Bte0ApwhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=e20b48d0\" target=\"_blank\">http://www.appledaily.com.tw/realtimenews/article/new/20170825/1190627/</a><br />\n解放軍首度赴澳門救災　4人熱到中暑抽搐<br />\n<br />\n<img src=\"http://img.appledaily.com.tw/images/ReNews/20170825/420_a3eff2e91a60eff66fda2dd60a45b67a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.appledaily.com.tw%2Fimages%2FReNews%2F20170825%2F420_a3eff2e91a60eff66fda2dd60a45b67a.jpg&h=89aa6bd7&s={SIZE}\" />"}