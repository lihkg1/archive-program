ecc11ed17c70","tid":1840241,"uid":269622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T19:40:23.000Z","msg":"<img src=\"https://na.cx/i/P8Vg1HZ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FP8Vg1HZ.jpg&h=a3fb9a47&s={SIZE}\" /><img src=\"https://na.cx/i/8nNZZuJ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8nNZZuJ.jpg&h=d63897c4&s={SIZE}\" />"},{"pid":"44f4967e89afa2f85ec6fd8015198ab25cc1f984","tid":1840241,"uid":249924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T19:46:12.000Z","msg":"[封殺高鐵] 高鐵不封 ! 港人必亡 ! 封印高鐵大行動 !  香港封關 ! 置頂 !<br />\n<a href=\"https://lih.kg/1838537\" data-auto-link target=\"_blank\">https://lih.kg/1838537</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"7473a272b544d8070563f035bcf75d51b9d9821c","tid":1840241,"uid":36088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T19:54:22.000Z","msg":"up"},{"pid":"d00a875b35f7d55932d4f2bc4777eb2b1385f182","tid":1840241,"uid":142249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T20:00:30.000Z","msg":"推！"},{"pid":"78ba19e4fed3a62f6fb418f95ec60f184f834c8d","tid":1840241,"uid":40827,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T20:07:22.000Z","msg":"推完post 人都要出呀！<img src=\"/assets/faces/dog/bark.gif\" class=\"hkgmoji\" />"},{"pid":"86d8a546dbd828ca6e524cdd2a0ebc0cad3bca73","tid":1840241,"uid":2110,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T20:13:07.000Z","msg":"封關<br />\n不讓香港成為另一個疫區<br />\n不給國家添麻煩<br />\n不給國家做成負擔<br />\n才是最大的愛國<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n將上面段說話廣傳/整成長輩圖，我地要借助藍絲既愛國之心，先可以更容易保衛香港"},{"pid":"87816ddd7070006730c881ed6d08d6af47a41642","tid":1840241,"uid":225488,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T20:26:39.000Z","msg":"推"},{"pid":"f88a4e467492c623ad27982cca933f21e73fb6c4","tid":1840241,"uid":157117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T20:30:09.000Z","msg":"喂推啊"},{"pid":"a4b3ff9f938f1a03da9710368309daa653720225","tid":1840241,"uid":157117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T20:31:08.000Z","msg":"上"},{"pid":"49c5b7287c6f1b32cefcdd4314b69166cd80979e","tid":1840241,"uid":330823,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T20:32:58.000Z","msg":"港共不會封關有如白衣人血洗元朗,只是今次用隻病毒血洗全香港"},{"pid":"9da89de3eeca622c2ae2130dbd30dd25a0f7f0a1","tid":1840241,"uid":225828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T21:59:40.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"81d48f41587f8f0aa1b5f5f68505be1d4144cc5c","tid":1840241,"uid":263197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T22:35:02.000Z","msg":"<img src=\"/assets/faces/lny/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"ad71e1c2bc8e215ca9a72b201f23d164384cba08","tid":1840241,"uid":39043,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T23:05:47.000Z","msg":"<img src=\"/assets/faces/lny/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"52a70492361ba2051c94d48e32cfa22becbd7821","tid":1840241,"uid":39043,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T23:05:58.000Z","msg":"<img src=\"/assets/faces/cat/sneeze.gif\" class=\"hkgmoji\" />"},{"pid":"e525673937a198617d7e444991fad120dc56a62a","tid":1840241,"uid":225828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T23:30:15.000Z","msg":"唔好意思，唔識用將個Post嘅標題quote過嚟功能<img src=\"/assets/faces/lny/cry.gif\" class=\"hkgmoji\" /><br />\n唯有喺度貼文<br />\n~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<br />\n大家睇過人玩或者玩過生化危機嘅都知<br />\n赤手空拳係冇可能打得贏喪屍(你唔係一拳超人<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" />)<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: gold;\">係一定要有武器先可以打得死班喪屍怪物！！！</span></strong></span><br />\n<br />\n石器時代嘅時候人類可以打得贏野獸係靠石器同火器<br />\n換句話講即係靠武器<img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><br />\n<br />\n大家都睇過扯口罩嗰段片，武漢嗰啲人癲起上嚟係真係唔係人咁品，隨時扮喪屍咬鳩你都不為過<img src=\"/assets/faces/dog/treat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bark.gif\" class=\"hkgmoji\" /><br />\n<br />\n除咗去包圍GAO 鐵站之外<br />\n<br />\n對付喪屍不得不準備一啲防身武器<br />\n<br />\n用刀嗰啲太殘忍因為大家都唔係殺人狂魔<br />\n<br />\n<span style=\"font-size: xx-large;\"><strong>但係如果好似之前同犬隻對陣嘅時候掉野遠攻班喪屍呢<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /></strong></span><br />\n<br />\n要記住其實如果佢哋攻入嚟我哋真係會命仔玩完<br />\n<br />\n已經唔係政唔政治一回事<br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">係俾佢成班喪屍衝入嚟香港一定淪陷<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /></span></strong></span><br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: gold;\">保衞香港嘅唔係靠政府<br />\n唔係靠犬隻<br />\n更加唔係靠蝙蝠俠<br />\n<br />\n係靠熱愛香港嘅一眾香港人<img src=\"/assets/faces/dog/lihkg.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /></span></strong></span><br />\n<br />\n當啲喪屍想係Gao鐵上面沖過嚟香港睇霸王醫生<br />\n<span style=\"font-size: xx-large;\">我哋要做嘅就係要掉到佢驚！<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><br />\n掉到佢退！<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><br />\n掉到佢哋懷疑人生！<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /></span><br />\n<br />\n要清楚比到個訊息佢哋：<span style=\"font-size: xx-large;\"><strong>就算落嚟香港都唔會幫到佢哋嘅病<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /></strong></span><br />\n逼佢地返返去自己個狗竇<img src=\"/assets/faces/dog/escape.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n逼支那政府自己拆返掂壇嘢<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><br />\n香港話晒都係我哋自己地頭<img src=\"/assets/faces/fs/superman.gif\" class=\"hkgmoji\" /><br />\n冇理由自己地頭都比人哋恰鳩<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><br />\n<br />\n當你覺得佢都係人嘅時候<br />\n<br />\n諗下佢哋點樣虐待啲寵物<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><br />\n<br />\n諗下佢哋變態到連人類BB都食<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><br />\n<br />\n諗下佢哋點樣恩將仇報對所有幫過佢嘅人包括醫護<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><br />\n<br />\n你就知道佢哋已經唔係人係喪屍<br />\n<br />\n而如果到而家一刻都唔攞起自己嘅武器去保護自己嘅時候<br />\n<br />\n換來嘅結果<span style=\"font-size: xx-large;\"><span style=\"color: red;\">只會係疫症會喺香港社區大爆發<br />\n<br />\n會造成大量嘅香港人死亡<br />\n<br />\n甚至係你地嘅親人同埋最愛嘅人都會受到傷害</span></span><br />\n<br />\n唔通你真係忍心見到你哋心愛嘅人要遭受到武漢人嘅結果咩<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: xx-large;\">去圍GAO 鐵嘅時候,帶定幾罐罐裝雀巢咖啡又好、罐裝可口可樂又好、甚至係叔一燒都好<br />\n我哋嘅目的好簡單：<br />\n至少係依段時間要打到班喪屍唔敢再衝落嚟香港！<br />\n要逼到香港政府封關！<br />\n要令到香港呢個地方唔好再因為肺炎造成不必要傷亡</span><br />\n<br />\nSorry for 1999, 好耐冇打篇咁長嘅文<img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n祝香港同香港人<img src=\"/assets/faces/lny/devil.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: gold;\">願平安歸香港<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" /></span></span><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\"><strong>香港人，起嚟啦<img src=\"/assets/faces/lomoji/33.png\" class=\"hkgmoji\" /></strong></span></span>"},{"pid":"8c61c0862314939fd9c473506e96da060e96c5c3","tid":1840241,"uid":139676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T23:35:40.000Z","msg":"<img src=\"/assets/faces/lny/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/@.gif\" class=\"hkgmoji\" />"},{"pid":"67d1a39347a0033e57afe818d5b07937e8866906","tid":1840241,"uid":90328,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T23:36:31.000Z","msg":"好驚"},{"pid":"c2be637463d14f05dfae226bd9dc038359ae6aa0","tid":1840241,