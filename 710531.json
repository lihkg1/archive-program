ih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F21%2F080412_e2aea8f0f8d09d4e313291a84f69850a.jpeg&h=03966590&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/21/080416_baa45433f23fc8848eb86f5de3c3e98e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F21%2F080416_baa45433f23fc8848eb86f5de3c3e98e.jpg&h=9aa58c1d&s={SIZE}\" /><br />\n<br />\n<a href=\"https://hk.news.appledaily.com/local/daily/article/20180617/20423163\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20180617%2F20423163&d=wlsr4Qli7HxnravKwskRtS7bS0i5kAixZS1hjGmvpwM%3D&h=72e732e9\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20180617%2F20423163&h=e81618a3\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20180617/20423163</a>"},"citedBy":1,"replyTime":"2018-06-21T00:05:41.000Z","msg":"埃及主帥：若沙拿沒傷　結果將不同<br />\n<br />\n埃及於Ａ組次輪賽事以1:3不敵東道主俄羅斯，分組賽兩戰兩敗，晉級機會渺茫。教練古柏表示若前鋒穆罕默德沙拿於歐聯決賽沒受傷，這兩場比賽結果或會不同。<br />\n<br />\n古柏賽後表示：「無人可以否認沙拿對球隊的重要性，我相信他的狀態很好，只是在歐聯決賽受傷之後，白白失去了予星期的訓練。最主要問題是，他大部份時間只能獨操，無法回到大隊集訓。」沙拿今仗於73分鐘搏得12碼後親自操刀破蛋，射入球隊今屆首球。<br />\n<br />\n英格蘭前射手舒利亞指，沙拿受傷之後未有時間完全回復，未能發揮最佳水準，估計他只得6至7成狀態。"},{"pid":"9f4bb580d84618bcf5bd94cb46fc0751c85aeac1","tid":710531,"uid":15647,"like":0,"dislike":1,"score":-1,"quote":{"pid":"fa7801fee21cc6597e01591eba4053d639275f83","tid":710531,"uid":186431,"like":0,"dislike":4,"score":-4,"quote":{"pid":"baf4a17237a8c56b76be2762eef5509e043dd892","tid":710531,"uid":186431,"like":1,"dislike":4,"score":-3,"quote":{"pid":"42763b82e35a3df2682a470f56b4c701344d9617","tid":710531,"uid":64156,"like":151,"dislike":6,"score":145,"citedBy":2,"replyTime":"2018-06-20T22:23:30.000Z","msg":"你憎一個球員嘅原因竟然係based on傳媒同連登d人點講一個球員<br />\n<br />\n你都係返鄉下啦"},"citedBy":2,"replyTime":"2018-06-21T00:04:29.000Z","msg":"<img src=\"https://img.eservice-