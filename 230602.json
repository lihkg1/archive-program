=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"d4cc23c7e6f1fec945271ea6ab414ae7ae1d9736","tid":230602,"uid":35370,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-05T22:19:35.000Z","msg":"惟政府沒有正面回應。<br />\n<br />\n<br />\n<br />\n<strong>-END-</strong>"},{"pid":"46665ffd567ec9d3c58e86450630613958102ed8","tid":230602,"uid":1886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-06T00:55:36.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"1a003605c3377e4b458bb696dceed59b915d3e23","tid":230602,"uid":55533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-06T01:02:31.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"fa39990ab825c1f3818af5ee1a62ea4a80dd78f8","tid":230602,"uid":19501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-06T01:27:20.000Z","msg":"許sir同消防處出嚟匯報下，阻到幾多消防救護車"},{"pid":"66b0177e02cd817351f667696ac6d0b3dcd69594","tid":230602,"uid":35370,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-06T01:29:34.000Z","msg":"<blockquote>許sir同消防處出嚟匯報下，阻到幾多消防救護車</blockquote><br />\n荷李活道開始多人<br />\n<br />\n_ _ _ _，_ _ _ _！"},{"pid":"4a095fbc882c574637b5489eeb9654724719d92f","tid":230602,"uid":73092,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-06T01:30:15.000Z","msg":"佔中<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"9c3ebee4c1b1f789ffd23202eccec9391b5b51e4","tid":230602,"uid":56698,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-06T01:34:22.000Z","msg":"區議員無開名<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /> 建制議員<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}