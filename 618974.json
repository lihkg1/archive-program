暫時包尾。<br />\n<br />\n我會咁排<br />\n象島&gt;PH&gt;明哥篇&gt;大媽篇&gt;魚人島"},{"pid":"45a569a31be9ed49d2f8edfa328b32784f53a955","tid":618974,"uid":82404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-06T13:03:41.000Z","msg":"打cp9"},{"pid":"79678c49e61f2a40fb01a828ffcf0e60dc4b027e","tid":618974,"uid":96826,"like":0,"dislike":0,"score":0,"quote":{"pid":"cd6d5d733eacbc77f973dfa908efc2d1eb4a641a","tid":618974,"uid":147789,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d2f61b735c26e25d95a959b4412b2872475fdbe","tid":618974,"uid":693,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-04-06T08:56:21.000Z","msg":"明哥都講幾年<br />\n<br />\n前後反睇左明哥3次佢個篇先完<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-04-06T09:00:57.000Z","msg":"其實一次過睇又唔係真係咁差<br />\n但係逐話咁追真係好辛苦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-06T13:20:51.000Z","msg":"係 所以儲起黎睇最好"},{"pid":"ac30f379037a1cae0f213ce100f9f23055771abb","tid":618974,"uid":147789,"like":0,"dislike":0,"score":0,"quote":{"pid":"79678c49e61f2a40fb01a828ffcf0e60dc4b027e","tid":618974,"uid":96826,"like":0,"dislike":0,"score":0,"quote":{"pid":"cd6d5d733eacbc77f973dfa908efc2d1eb4a641a","tid":618974,"uid":147789,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d2f61b735c26e25d95a959b4412b2872475fdbe","tid":618974,"uid":693,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-04-06T08:56:21.000Z","msg":"明哥都講幾年<br />\n<br />\n前後反睇左明哥3次佢個篇先完<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-04-06T09:00:57.000Z","msg":"其實一次過睇又唔係真係咁差<br />\n但係逐話咁追真係好辛苦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-06T13:20:51.000Z","msg":"係 所以儲起黎睇最好"},"citedBy":0,"replyTime":"2018-04-06T13:46:10.000Z","msg":"但係睇完一話又好想睇下一話<br />\n睇完下一話又唔知睇咗啲咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class