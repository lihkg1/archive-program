ces/mf/angry.gif\" class=\"hkgmoji\" />"},{"pid":"647567aeba1f0ab38035caf13cdf13a2dbbe317e","tid":1570091,"uid":98431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T02:10:01.000Z","msg":"其實唔鳩圍 唔對線 被捕風險就會減低好多<br />\n<br />\n大家與期等人救 不如先減低受傷機會"},{"pid":"4a0e1ee5749a8b60ae8b7b85cd3d44aeef070b65","tid":1570091,"uid":69221,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-15T02:10:20.000Z","msg":"咪撚再俾人起三角road black"},{"pid":"69fd2ad9a521f6a797b4ccb667a7557a5be3eee8","tid":1570091,"uid":9448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T02:10:53.000Z","msg":"推"},{"pid":"b1b696c4fdcd98feb0c5a85a2bbcbabbb8d5e7f9","tid":1570091,"uid":76078,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T02:11:36.000Z","msg":"pish"},{"pid":"7a961eaf7fc7dbe9a56a885da8e56c9aa6947990","tid":1570091,"uid":151616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T02:12:36.000Z","msg":"對住無gear狗一定救人"},{"pid":"b25ed789b71d1d5dd08a4247206c2448107a2619","tid":1570091,"uid":282267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T02:14:43.000Z","msg":"同埋被狗捉既手足都請你地大聲叫其他人救你，香港人要踢一下先識郁<img src=\"/assets/faces/mf/angry.gif\" class=\"hkgmoji\" />"},{"pid":"58a475bb5570ed81bb93f78e6d09040ec391a8a0","tid":1570091,"uid":76674,"like":0,"dislike":0,"score":0,"quote":{"pid":"4a0e1ee5749a8b60ae8b7b85cd3d44aeef070b65","tid":1570091,"uid":69221,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-15T02:10:20.000Z","msg":"咪撚再俾人起三角road black"},"citedBy":0,"replyTime":"2019-09-15T02:15:03.000Z","msg":"真,呢個係等拉象徵"}]}