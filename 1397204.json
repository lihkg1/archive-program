ng\" class=\"hkgmoji\" />"},{"pid":"596070d777510185742e3a77ec854280f5f4113a","tid":1397204,"uid":262736,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-02T11:43:00.000Z","msg":"有冇辦法可以勾結靈界既力量干預香港內政<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"1349ae596797cd2a40dc19eb05c5ef3fc164a509","tid":1397204,"uid":263058,"like":9,"dislike":1,"score":8,"citedBy":1,"replyTime":"2019-08-02T11:44:30.000Z","msg":"此回覆已被刪除"},{"pid":"5ef25e7e293af2b62c6641b72d1ac8ba8e0f5466","tid":1397204,"uid":263058,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2019-08-02T11:45:24.000Z","msg":"此回覆已被刪除"},{"pid":"f2bd4822b3bdecc302b08a03e039b10cd92c63a9","tid":1397204,"uid":263058,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T11:47:03.000Z","msg":"此回覆已被刪除"},{"pid":"317fe0034cf729d7d2b9fc1a8b7c93118edf854e","tid":1397204,"uid":263058,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-02T11:48:49.000Z","msg":"此回覆已被刪除"},{"pid":"5c89036cfe275d6122cc8acc3dc4d6a66894144f","tid":1397204,"uid":21678,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-08-02T11:50:23.000Z","msg":"我覺得好快有燒街衣telegram group<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"60cf2a442763f8a31355d161745528afdc9e6ee7","tid":1397204,"uid":51124,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T11:55:24.000Z","msg":"this really works"},{"pid":"5b39ad1e3140836efc027ea583cf783cfe4159c9","tid":1397204,"uid":263058,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-08-02T13:04:38.000Z","msg":"此回覆已被刪除"},{"pid":"92e94528a51ea62398eb27bd77842bba424a4541","tid":1397204,"uid":263058,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T13:06:27.000Z","msg":"此回覆已被刪除"},{"pid":"904ec2b0fb3387e8bd37a8bf8307fc0ab673bf87","tid":1397204,"uid":120772,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-02T13:10:48.000Z","msg":"靈界kol<img src=\"/assets/faces/normal/adore.gif\" class=\"h