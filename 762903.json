url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fimages1.epochhk.com%2Fpictures%2Fimages-epochhk-com%2F20140207-c8-9%401200x1200.jpg%3Furl%3Dhttp%3A%2F%2Fimages.epochhk.com%2F20140207%2Fc8-9.jpg&d=gmgtEOZmSAjDtREC1KdSgTCdMQr7etzq9tFbjrA%2B72k%3D&h=8e64a6c1\" data-auto-link target=\"_blank\">http://images1.epochhk.com/pictures/images-epochhk-com/20140207-c8-9@1200x1200.jpg?url=http://images.epochhk.com/20140207/c8-9.jpg</a><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/01/001858_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F01%2F001858_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=6ed24802&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/01/001900_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F01%2F001900_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=4cf5bf60&s={SIZE}\" /><br />\n<br />\nsource: <a href=\"http://www.gznf.net/column/1014.html?from=singlemessage\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.gznf.net%2Fcolumn%2F1014.html%3Ffrom%3Dsinglemessage&d=gmgtEOZmSAjDtREC1KdSgTCdMQr7etzq9tFbjrA%2B72k%3D&h=877ea1b7\" data-auto-link target=\"_blank\">http://www.gznf.net/column/1014.html?from=singlemessage</a>"},{"pid":"e3ba698a4c83ca0a6d20bd60fdf42feb4331b861","tid":762903,"uid":195027,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-31T16:25:14.000Z","msg":"支持巴打<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n有圖配埋字會簡單易明啲"},{"pid":"219d41831f6638d38234591e4d7159222a5b4158","tid":762903,"uid":73163,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-31T16:52:04.000Z","msg":"多謝你咁有心機分享<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"316ff0cd19ae131979d9d862ef4d1665ccce7f64","tid":762903,"uid":193915,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-31T18:15:11.000Z","msg":"樓主個名自爆左係英華女<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f7262544826fd6cdc5a82312e93be858e0d46931","tid":762903,"uid":2023,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-31T18:23:25.000Z","msg":"咁姐係有咩分別...<br />\n成堆字好惡啃..."},{"pid":"02ae32f2ace0bb2d6ec5248d85924070d9ea2b15","tid":762903,"uid":191443,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-31T18:25:49.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"212398d830891a319874ab578dcb4a3d36322437","tid":762903,"uid":101110,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-31T21:16:31.000Z","msg":"中學都係長衫<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"adff52255119bb68d67b2b8de762b12f4e4d7db1","tid":762903,"uid":165113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-31T21:23:43.000Z","msg":"冇長衫學生妹點吸引child登仔睇你寫咩<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"9784f5aff717841575d6a6150834572817e2b809","tid":762903,"uid":173502,"like":5,"dislike":2,"score":3,"citedBy":0,"replyTime":"2018-08-01T01:27:18.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/01/091914_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F01%2F091914_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=44000c63&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/01/091922_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F01%2F091922_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=61d9ee15&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/01/092055_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F01%2F092055_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=2a9edf60&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/01/092621_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F01%2F092621_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=a7ee6aaa&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/01/092622_234c50d755a7bdf4dd5b45bf9ebe228a.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F01%2F092622_234c50d755a7bdf4dd5b45bf9ebe228a.jpeg&h=2084926c&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/01/092624_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F01%2F092624_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=5945b40d&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/01/092625_234c50d755a7bdf4dd5b45bf9ebe228a.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F01%2F092625_234c50d755a7bdf4dd5b45bf9ebe228a.jpeg&h=f1ca0064&s={SIZE}\" /><br />\n<br />\n對唔住而家補啲圖"},{"pid":"9b77c6b073f3244509ec66873058759ecefe633d","tid":762903,"uid":49905,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-01T05:23:29.000Z","msg":"寫得好詳細<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}