rc=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"671764baa63cd635201737ddbc149f85c52ed543","tid":140932,"uid":70877,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-02T16:15:22.000Z","msg":"我個主人都會咁 醫生話食下吐毛膏就冇事<br />\n我之後買左化毛膏比佢 等佢屙啲毛出嚟 佢依家小左咁樣 但我見唔到佢啲屎有毛痴住<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b54d4c5ace9c114e5b22c0c1fa4881274141b191","tid":140932,"uid":6657,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-06T00:34:27.000Z","msg":"我果隻都係咁，好似好辛苦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"6b4e30c9bc83da75e033d239f6af3303ebf5bd76","tid":140932,"uid":9153,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-06T00:56:04.000Z","msg":"食左太多毛<br />\n比吐毛膏佢食"}]}