ike":0,"dislike":0,"score":0,"quote":{"pid":"75d34446c61cb45aa8f18fb796106f2c8e16aa3b","tid":2494453,"uid":62226,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-04-18T15:24:10.000Z","msg":"好求其咁google同wiki過<br />\n你啲半衰期好似錯晒<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-04-18T15:25:12.000Z","msg":"碳14多咗個萬字啫<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"753b3b7709b74733bbd6f65c3d24f8f7177024de","tid":2494453,"uid":69841,"like":0,"dislike":0,"score":0,"quote":{"pid":"9ad112a1f28c69180e207392d47b58ba63ab2caf","tid":2494453,"uid":97979,"like":0,"dislike":0,"score":0,"quote":{"pid":"75d34446c61cb45aa8f18fb796106f2c8e16aa3b","tid":2494453,"uid":62226,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-04-18T15:24:10.000Z","msg":"好求其咁google同wiki過<br />\n你啲半衰期好似錯晒<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-04-18T15:25:12.000Z","msg":"碳14多咗個萬字啫<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-18T15:26:43.000Z","msg":"鈷60都多咗個萬字喺前面<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"65d24564ff87bd5d58c5a8c0cf172fe22a0b948a","tid":2494453,"uid":51183,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-04-18T15:26:46.000Z","msg":"<a href=\"https://www.dw.com/zh/%E5%90%AB%E6%B0%9A%E6%A0%B8%E5%BA%9F%E6%B0%B4%E7%9C%9F%E7%9A%84%E4%B8%8D%E4%BC%9A%E5%8D%B1%E5%AE%B3%E5%81%A5%E5%BA%B7/a-57184856?fbclid=IwAR174NOUVRod2_yowmnC9zqn1gyT5dxybFiscsZXrDPiSCWG8yAX8i8AzQA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.dw.com%2Fzh%2F%25E5%2590%25AB%25E6%25B0%259A%25E6%25A0%25B8%25E5%25BA%259F%25E6%25B0%25B4%25E7%259C%259F%25E7%259A%2584%25E4%25B8%258D%25E4%25BC%259A%25E5%258D%25B1%25E5%25AE%25B3%25E5%2581%25A5%25E5%25BA%25B7%2Fa-57184856%3Ffbclid%3DIwAR174NOUVRod2_yowmnC9zqn1gyT5dxybFiscsZXrDPiSCWG8yAX8i8AzQA&d=ZGEEaRoo4ZESsTiVlrSVprZiocJRpRWN%2FMrNqpcM%2BY8%3D&h=e7322ecd\" data-auto-link target=\"_blank\">https://www.dw.com/zh/%E5%90%AB%E6%B0%9A%E6%A0%B8%E5%BA%9F%E6%B0%B4%E7%9C%9F%E7%9A%84%E4%B8%8D%E4%BC%9A%E5%8D%B1%E5%AE%B3%E5%81%A5%E5%BA%B7/a-57184856?fbclid=IwAR174NOUVRod2_yowmnC9zqn1gyT5dxybFiscsZXrDPiSCWG8yAX8i8AzQA</a><br />\n<br />\n日本政府強調，福島第一核電廠的核廢水在排放前會先經過稀釋，將濃度降低至日本國家標准的1/40，以及世界衛生組織規定的飲用水標准1/7。東電也表示，核污水經過多核素去除裝置（ALPS）處理，可以過濾掉62種放射性物質，只有氚無法被去除。若過濾後的數值仍然超標，則會重復過濾程序。<br />\n<br />\n美國伍茲霍爾海洋研究所自身科學家比塞勒（Ken Buesseler）也認為，氚不是唯一的問題。他對德新社表示，儲水槽中還有其他放射性同位素，部分的半衰期更長，更容易殘留在海洋生物體內或成為海洋沉積物。比塞勒指出，同氚相比，這些物質會通過復雜的途徑，對人類和環境構成潛在威脅。<br />\n<br />\n<span class=\"red\">在東京電力公司的官方網站上詳細列出了各個儲水槽目前的放射性核素值目前有多高，以及應該達到的標准。</span>但對外行人而言，相關指控以及這些數值都無法得到證實。"},{"pid":"68e4061404e3779e6c9b97fb8a50fc51076d95de","tid":2494453,"uid":98232,"like":0,"dislike":3,"score":-3,"quote":{"pid":"bf0c57b95832b5c21c1ed1ada84fda6d7ea40c8a","tid":2494453,"uid":156363,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-04-18T15:21:52.000Z","msg":"咪咁幼稚啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />人講你就信"},"citedBy":0,"replyTime":"2021-04-18T15:29:35.000Z","msg":"東電都講過大話 你又信佢？<br />\n2003年4月，在發現虛假的安全文件後日本政府命令東京電力關閉所有核反應爐以進行安全檢查，很快地爆出的醜聞導致該公司的高層辭職，隨之而來的是國家政策被迫減慢對核燃料循環的進度。2007年1月31日，東京電力公司在向經濟產業省提交的調查報告書中承認，從1977年起在對下屬福島第一核電站、福島第二核電站和柏崎刈羽核電站的13座反應爐總計199次定期檢查中，曾竄改數據，隱瞞安全隱患"},{"pid":"f9cf9bb3e5534845d27ecf503cbf3d6431588b23","tid":2494453,"uid":26506,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2021-04-18T15:31:21.000Z","msg":"請善用起底功能"},{"pid":"67486a245b52b46ff42f2a02155517f742ae799a","tid":2494453,"uid":97979,"like":2,"dislike":0,"score":2,"quote":{"pid":"f9cf9bb3e5534845d27ecf503cbf3d6431588b23","tid":2494453,"uid":26506,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2021-04-18T15:31:21.000Z","msg":"請善用起底功能"},"citedBy":0,"replyTime":"2021-04-18T15:31:54.000Z","msg":"唔駛用都認得個名啦"},{"pid":"1cf526f759ef2b468bde666e3acf5ad73f427a8e","tid":2494453,"uid":51183,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-18T15:32:04.000Z","msg":"倫敦帝國學院分子病理學專家湯瑪斯（Geraldine Thomas）表示，氚「完全不會構成健康風險」，況且核廢水放入太平洋後也會產生稀釋效應。她表示，碳14也不會危及健康，<span class=\"red\">反倒是目前海水中所含的汞「應該比任何福島產品」更讓消費者憂慮</span>。她強調，她會「毫不猶豫」食用福島海產。"},{"pid":"11a52134f325db8dc6198c9cc6f18c59ae076c8a","tid":2494453,"uid":98232,"like":0,"dislike":3,"score":-3,"quote":{"pid":"f9cf9bb3e5534845d27ecf503cbf3d6431588b23","tid":2494453,"uid":26506,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2021-04-18T15:31:21.000Z","msg":"請善用起底功能"},"citedBy":0,"replyTime":"2021-04-18T15:32:19.000Z","msg":"我隻狗用碌輻射鳩屌得你老母爽唔爽呀"},{"pid":"e66942567ab58e8f60975edd81c659649576cab7","tid":2494453,"uid":98232,"like":0,"dislike":3,"score":-3,"quote":{"pid":"1cf526f759ef2b468bde666e3acf5ad73f427a8e","tid":2494453,"uid":51183,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-18T15:32:04.000Z","msg":"倫敦帝國學院分子病理學專家湯瑪斯（Geraldine Thomas）表示，氚「完全不會構成健康風險」，況且核廢水放入太平洋後也會產生稀釋效應。她表示，碳14也不會危及健康，<span class=\"red\">反倒是目前海水中所含的汞「應該比任何福島產品」更讓消費者憂慮</span>。她強調，她會「毫不猶豫」食用福島海產。"},"citedBy":0,"replyTime":"2021-04-18T15:33:06.000Z","msg":"點解美國又會禁日本核食既"},{"pid":"4fa17e9f25bf85567432a292d4cd39c9c7d91678","tid":2494453,"uid":362754,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-04-18T15:35:19.000Z","msg":"返大陸共享支那人嘅榮耀啦，上連登把撚咩垃圾五毛<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"b81bfc3d31c3dcbadbe5697155a0da0762f15b11","tid":2494453,"uid":98232,"like":0,"dislike":2,"score":-2,"quote":{"pid":"4fa17e9f25bf85567432a292d4cd39c9c7d91678","tid":2494453,"uid":362754,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-04-18T15:35:19.000Z","msg":"返大陸共享支那人嘅榮耀啦，上連登把撚咩垃圾五毛<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\"