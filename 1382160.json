{"tid":1382160,"cid":5,"subCid":0,"title":"聽朝730有冇大西北手足一齊坐西鐵","createTime":"2019-07-29T11:53:12.000Z","updateTime":"2019-07-29T18:51:47.000Z","uid":45299,"like":18,"dislike":0,"uniUserReply":9,"replies":[{"pid":"53a2a3a7c6c67e469e867814511c6aef0617c411","tid":1382160,"uid":45299,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T11:53:12.000Z","msg":"調景嶺真係好撚遠<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n屯元天巴打會唔會一齊行動<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"ec1c839645b492bfb0973539c51d1eeadfe4c45a","tid":1382160,"uid":45299,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T11:53:27.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"cdc2e61700651528b5621f72f869bcb3e254caba","tid":1382160,"uid":45299,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-29T11:53:47.000Z","msg":"8月5日大罷工"},{"pid":"4f37bcd4f0fb092a6f36a793d39a75453905a216","tid":1382160,"uid":45299,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T11:54:43.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b7ab89f98a62c03b7cec57094e8c031f01c00378","tid":1382160,"uid":45299,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T11:54:53.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"7d1f88eed86e4769e67b8ab9e65ebd38a8cd22c3","tid":1382160,"uid":45299,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T11:55:25.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"74ad61fb5e9de6eca9378340ac08ce80685dd0f9","tid":1382160,"uid":202730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T11:55:32.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/face