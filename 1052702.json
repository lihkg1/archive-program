uote":{"pid":"93994419b92d82862b0d6a61e2be4bb2238464cf","tid":1052702,"uid":9708,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-08T14:06:38.000Z","msg":"一把𠝹刀$8 啪到十幾塊刀片入信封就寄得<br />\n電鋸貴成幾十倍 要封箱郵費貴 仲要嚇唔到人益埋仇家<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-08T14:25:51.000Z","msg":"因為塞唔入郵筒寄<br />\n要去郵局排隊寄<br />\n時間成本又高<br />\n又留得證據多"},{"pid":"4ed0d09a3ec87b407c2eaf0aafada8a1fb3e96ba","tid":1052702,"uid":27568,"like":5,"dislike":0,"score":5,"quote":{"pid":"78c88a135686d0743b3aef28a3b1c33338ba35d2","tid":1052702,"uid":51039,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-03-08T13:53:21.000Z","msg":"宮崎駿寄過武士刀俾人"},"citedBy":0,"replyTime":"2019-03-08T14:26:37.000Z","msg":"目的係恐嚇定送禮?<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><br />\n快點恐嚇我<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"0d74497f2054e33f17d2646d20aa8d4a6fd47979","tid":1052702,"uid":27568,"like":8,"dislike":0,"score":8,"quote":{"pid":"78c88a135686d0743b3aef28a3b1c33338ba35d2","tid":1052702,"uid":51039,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-03-08T13:53:21.000Z","msg":"宮崎駿寄過武士刀俾人"},"citedBy":0,"replyTime":"2019-03-08T14:29:25.000Z","msg":"<a href=\"https://www.pixpo.net/post367872\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.pixpo.net%2Fpost367872&d=fEJCtfATBeMWJ6YDVJZPMlm6lgSi2KDQroqMKj6vOm8%3D&h=54eed7b2\" target=\"_blank\">https://www.pixpo.net/post367872</a><br />\n<br />\n搵到了<br />\n最近最近好萊塢大佬哈維&middot;溫斯坦出事了<br />\n<br />\n多名公司員工爆料曾糟蹋他的性騷擾<br />\n<br />\n這位好萊塢大佬在美國電影界可以說是位高權重<br />\n<br />\n他參與製作和發行過的電影，已經累計有300多項奧斯卡<br />\n<br />\n被稱為「奧斯卡背後的男人」<br />\n<br />\n他曾參與過發行很多在美國名氣不是那麼大的電影<br />\n<br />\n並且會用自己的方式對電影進行大幅度刪減<br />\n<br />\n雖然他刪減過的電影，最終都能比較受歡迎<br />\n<br />\n但仍然有電影創作者不喜歡這種做法，覺得傷害了作品<br />\n<br />\n宮崎駿就是其中一個<br />\n<br />\n當年幽靈公主在美國上映的時候<br />\n<br />\n發行商就是哈維&middot;溫斯坦的公司<br />\n<br />\n宮崎駿應該也聽到過這位被稱為「剪刀手」的好萊塢大佬的威名<br />\n<br />\n給哈維&middot;溫斯坦寄去了一個包裹<br />\n<br />\n他打開一看，竟然是一個武士刀<br />\n<br />\n裡面還有一張小紙條：不許刪減，你敢剪我就跟你拚命<br />\n而事實上，當時幽靈公主裡由於有一些血腥，和斷肢的鏡頭<br />\n<br />\n被美國評級為PG-13，這對一個以青少年為主的動漫電影是很不利的<br />\n<br />\n但在宮崎駿的堅持下，美國版的幽靈公主最終上映的時候也沒有刪減<br />\n<br />\n不知道是不是那把武士刀起了作用"},{"pid":"fb96283135e3641de55b5d21adeca51e2b53d9b3","tid":1052702,"uid":46943,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-08T14:35:42.000Z","msg":"寄核彈好過<br />\n利申原袓金"},{"pid":"fd538d07a8c7e72f3eaa9830638ff96e352624d1","tid":1052702,"uid":51346,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-11T09:31:23.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f5e67c250606f732cbed4794a86a150ae44e078b","tid":1052702,"uid":2404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-11T09:36:49.000Z","msg":"寄屎"},{"pid":"1479fce68f79bc8dbd73f56c2a09d1b911eca400","tid":1052702,"uid":9726,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2019-03-11T10:13:45.000Z","msg":"此回覆已被刪除"},{"pid":"0d71f0025c7c8e5b35ef00832413af2b1919bf35","tid":1052702,"uid":80982,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-03-11T12:37:00.000Z","msg":"放樓主張相個殺傷力大d"}]}