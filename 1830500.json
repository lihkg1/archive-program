d1f4b4867dfcf778281b18b5b035687d8b","tid":1830500,"uid":84308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-20T05:29:16.000Z","msg":"經"},{"pid":"428c4c1cdc8622485434b766b8aabda0fb1ba915","tid":1830500,"uid":84308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-20T05:29:26.000Z","msg":"濟"},{"pid":"da5c76edfcfa947a258f13fd5a62972c1b841acb","tid":1830500,"uid":84308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-20T05:29:42.000Z","msg":"圈"},{"pid":"d8f736d198b8219307ee789ed71ec5a4673444c4","tid":1830500,"uid":188035,"like":0,"dislike":0,"score":0,"quote":{"pid":"bec9404c4add89146881f21c2cf1ce03a731e9d5","tid":1830500,"uid":84308,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-19T15:54:27.000Z","msg":"<img src=\"https://na.cx/i/7JrSDec.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7JrSDec.jpg&h=ea9bcd06&s={SIZE}\" /><br />\n<br />\n<a href=\"https://www.facebook.com/115482059813870/posts/175283247167084?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F115482059813870%2Fposts%2F175283247167084%3Fsfns%3Dmo&d=3W3ENIgnTPsh0%2B1doSs%2BPyq0XD4M5CHb8byFtBYuAsM%3D&h=48a8f89c\" data-auto-link target=\"_blank\">https://www.facebook.com/115482059813870/posts/175283247167084?sfns=mo</a><br />\n<br />\n【#年宵見 &ndash; 倒數4日！】<br />\n黎緊年廿九至年三十就係觀塘年宵見既日子啦，記得留意住年宵見tg channel，每日都會介紹至少三檔黃店架，大家準備好瘋狂懲罰接近一百檔黃色小店未呢？！<br />\n　　<br />\n知道因為太多資訊，好多街坊都未必明白咩叫「流水式」年宵？到底喺邊搞？有咩特別？所以我地特意準備左一堆FAQ，各位一齊瘋傳啦 &lt;3 要個個觀塘人，香港人都知！<br />\n　　<br />\n【FAQ】<br />\n問：咩叫「流水式」年宵？<br />\n答：流水式即是我地喺觀塘開源道側既多個工廠大廈，都會有年宵場地，各位街坊可以拎住地圖去唔同工廈尋寶😉 去晒咁多個地點，仲有機會拎到年宵見紀念品添～　<br />\n　　　<br />\n問：有咩檔？<br />\n答：接近100檔黃店，唔少係DIY自家製嘅手作商品，亦有小食/飲品檔等等～<br />\n　　<br />\n問：洗唔洗入場費？<br />\n答：我地年宵見活動費用全免，無論係檔主定街坊黎行宵，都唔洗錢架，等大家留返啲錢去買檔主既貨啦！<br />\n　　<br />\n問：到底地點喺邊到？<br />\n答：為左確保場地可以喺活動當日正常開放，亦因為安全問題，我地暫時不會公開確實地址，請見諒。密切留意住我地tg channel，到時公佈地址，就可以即時知道詳情啦！<br />\n　　<br />\n問：點樣支援抗爭運動？<br />\n答：「年宵見」係採取中央收費模式，做到每個場地既收入完全透明。當日收益既其中10%會捐至支援抗爭既機構（如：612/星火/立場/獨媒/守護孩子等)；另外10%會預留作行政及雜費開支，扣除開支後亦會全數捐出。<br />\n　　<br />\n問：仲招唔招檔主？<br />\n答：檔主招募已經截止，好抱歉！<br />\n　　<br />\n- 日期：1月23-24日（年廿九至三十）<br />\n- 時間：下午3點至晚上10點，年三十晚會開放至午夜<br />\n- 地點：成業街＋興業街＋鴻圖道＋巧明街＋駿業里（確實地點容後公佈）<br />\n- 數量：合共接近100檔黃色小店<br />\n　　　<br />\n&mdash;&mdash;&mdash;<br />\n最新資訊，請Subscribe<br />\nTelegram Channel：<a href=\"https://t.me/SeeYouInFlowerMarket\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FSeeYouInFlowerMarket&d=3W3ENIgnTPsh0%2B1doSs%2BPyq0XD4M5CHb8byFtBYuAsM%3D&h=2f4619ed\" data-auto-link target=\"_blank\">https://t.me/SeeYouInFlowerMarket</a><br />\n公海：<a href=\"https://t.me/seeyouinflowermarketKT\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FseeyouinflowermarketKT&d=3W3ENIgnTPsh0%2B1doSs%2BPyq0XD4M5CHb8byFtBYuAsM%3D&h=2c0ebc30\" data-auto-link target=\"_blank\">https://t.me/seeyouinflowermarketKT</a><br />\n　　　<br />\n一班乖孫<br />\n<a href=\"https://www.facebook.com/ptgwaisuen/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fptgwaisuen%2F&d=3W3ENIgnTPsh0%2B1doSs%2BPyq0XD4M5CHb8byFtBYuAsM%3D&h=e597c19b\" data-auto-link target=\"_blank\">https://www.facebook.com/ptgwaisuen/</a><br />\n<a href=\"http://instagram.com/ptgwaisuen\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Finstagram.com%2Fptgwaisuen&d=3W3ENIgnTPsh0%2B1doSs%2BPyq0XD4M5CHb8byFtBYuAsM%3D&h=241af3b9\" data-auto-link target=\"_blank\">http://instagram.com/ptgwaisuen</a><br />\n　　　<br />\n凝聚觀塘<br />\n<a href=\"https://www.facebook.com/CohesionKwunTong/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FCohesionKwunTong%2F&d=3W3ENIgnTPsh0%2B1doSs%2BPyq0XD4M5CHb8byFtBYuAsM%3D&h=b917e68a\" data-auto-link target=\"_blank\">https://www.facebook.com/CohesionKwunTong/</a><br />\n<a href=\"https://t.me/cohesionkwuntong\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fcohesionkwuntong&d=3W3ENIgnTPsh0%2B1doSs%2BPyq0XD4M5CHb8byFtBYuAsM%3D&h=2e4b7da7\" d