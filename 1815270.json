ets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},{"pid":"5126d4dc2b02cdbb978a406e8f2a6cc17d1068ec","tid":1815270,"uid":165752,"like":2,"dislike":2,"score":0,"citedBy":0,"replyTime":"2020-01-07T11:39:13.000Z","msg":"澳洲山火經已持續多月，超過一萬公頃土地遭到焚毀，即係成一百個香港咁大，催毀緊當地嘅生態系統，又有大量氣體排放，加劇全球暖化。大自然非常脆弱，好需要你嘅幫忙。<br />\n<br />\n一班喺澳洲嘅香港人好有心整咗個眾籌，畀大家捐錢，幫澳洲盡快控制場火。<br />\n<a href=\"https://www.gofundme.com/f/support-australia-rural-firefighters?fbclid=IwAR3y0C3D0Y6Q5dvtigFIVkf-O2Z_5Tk15eH3KF8-rq0ySgKL0VJ-YyWQXyk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.gofundme.com%2Ff%2Fsupport-australia-rural-firefighters%3Ffbclid%3DIwAR3y0C3D0Y6Q5dvtigFIVkf-O2Z_5Tk15eH3KF8-rq0ySgKL0VJ-YyWQXyk&d=rLp99s1CaA%2FTm5LA4NL6TfjlBAU1VhUdv3lOLHlSYeE%3D&h=8ca700c7\" target=\"_blank\">https://www.gofundme.com/f/support-australia-rural-firefighters?fbclid=IwAR3y0C3D0Y6Q5dvtigFIVkf-O2Z_5Tk15eH3KF8-rq0ySgKL0VJ-YyWQXyk</a><br />\n<br />\n<img src=\"https://cdn.hk01.com/di/media/images/cis/5e0ee42223ab170deb421918.mp4/Oxr16ZPY_-gs71EAKSRdZirpTKvu7rHD1QqVf9UKlX8\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fcis%2F5e0ee42223ab170deb421918.mp4%2FOxr16ZPY_-gs71EAKSRdZirpTKvu7rHD1QqVf9UKlX8&h=b79bb84c&s={SIZE}\" /><br />\n<img src=\"https://cdn.hk01.com/di/media/images/cis/5e0dc339b66f770df1c1d0b5.jpg/wz93QmTx1u-aFFV1CWfEhLxFMZbHmX_awGjiTsBo4k4\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fcis%2F5e0dc339b66f770df1c1d0b5.jpg%2Fwz93QmTx1u-aFFV1CWfEhLxFMZbHmX_awGjiTsBo4k4&h=66d9774d&s={SIZE}\" /><br />\n<img src=\"https://www.hk01.com/%E5%8D%B3%E6%99%82%E5%9C%8B%E9%9A%9B/417218/%E6%BE%B3%E6%B4%B2%E5%B1%B1%E7%81%AB-%E9%9D%A2%E7%A9%8D%E6%9C%89%E5%A6%8245%E5%80%8B%E9%A6%99%E6%B8%AF-%E8%A1%9B%E6%98%9F%E5%9C%96%E5%83%8F%E9%A1%AF%E7%A4%BA%E6%BE%B3%E6%B4%B2%E4%B8%8A%E7%A9%BA%E4%B8%80%E7%89%87%E7%B4%85#media_id=3794934\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.hk01.com%2F%25E5%258D%25B3%25E6%2599%2582%25E5%259C%258B%25E9%259A%259B%2F417218%2F%25E6%25BE%25B3%25E6%25B4%25B2%25E5%25B1%25B1%25E7%2581%25AB-%25E9%259D%25A2%25E7%25A9%258D%25E6%259C%2589%25E5%25A6%258245%25E5%2580%258B%25E9%25A6%2599%25E6%25B8%25AF-%25E8%25A1%259B%25E6%2598%259F%25E5%259C%2596%25E5%2583%258F%25E9%25A1%25AF%25E7%25A4%25BA%25E6%25BE%25B3%25E6%25B4%25B2%25E4%25B8%258A%25E7%25A9%25BA%25E4%25B8%2580%25E7%2589%2587%25E7%25B4%2585%23media_id%3D3794934&h=6ac17d41&s={SIZE}\" /><br />\n<img src=\"https://cdn.hk01.com/di/media/images/cis/5e12c007b66f770df1c1daaf.jpg/6B1QSqPk9TE8ZslmsP04gekPHLDsNyZiV2y5l1dsuZc\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fcis%2F5e12c007b66f770df1c1daaf.jpg%2F6B1QSqPk9TE8ZslmsP04gekPHLDsNyZiV2y5l1dsuZc&h=b4453031&s={SIZE}\" /><br />\n<img src=\"https://cdn.hk01.com/di/media/images/cis/5e12c00823ab170deb421fa0.jpg/v7JKKifHW7JjFWFZj9ujpleLSJ7kns34h8h4B4fIeAc\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fcis%2F5e12c00823ab170deb421fa0.jpg%2Fv7JKKifHW7JjFWFZj9ujpleLSJ7kns34h8h4B4fIeAc&h=32d89c39&s={SIZE}\" />"},{"pid":"ee02d4a18917bb75d29aaa91be5c859d9991db22","tid":1815270,"uid":165752,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-01-07T12:08:15.000Z","msg":"<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},{"pid":"a23709e32b2a6d22b9c74db94e5022a5da64c8bb","tid":1815270,"uid":265192,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2020-01-07T12:12:38.000Z","msg":"【借位，與主題無關】<br />\n<br />\n<br />\n試下用<strong><span style=\"color: red;\">「沒有普選，唯有獨立」</span></strong>做口號<br />\n<br />\n牌面上你係爭取緊無人有異議既雙普選。實質上你提供緊清晰既路徑，解釋緊點解要獨立、以及為獨立提供正當性。<br />\n<br />\n對於和理非，一開始可以則重係「雙普選」上面。但潛移默化地灌輸佢地獨立既可行性。對於獨派，亦解決左「時機」問題；因為嚴格上口號並唔係直接提倡獨立，但同時宣傳緊獨立。"},{"pid":"66dabdbafd3019d3b9b3e6f4c725e35a4788771e","tid":1815270,"uid":23169,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-01-07T12:27:39.000Z","msg":"支持 做咗冇死<br />\n好心你班仆街咪咁肉酸話人抵死<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"314693f69e767cf9ae393667d6a76e6a5c393f5d","tid":1815270,"uid":40666,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-07T12:28:32.000Z","msg":"<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" />"},{"pid":"e9d825e78b0a6e2f92121046af4d17ffb21578d5","tid":1815270,"uid":185066,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-07T12:42:32.000Z","msg":"好啊 少少地捐住先<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},{"pid":"5b4662b27fd35cd176479235aa51760151f249e2","tid":1815270,"uid":165752,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e9d825e78b0a6e2f92121046af4d17ffb21578d5","tid":1815270,"uid":185066,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-07T12:42:32.000Z","msg":"好啊 少少地捐住先<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-07T13:12:25.000Z","msg":"多謝絲打支持<img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" />"},{"pid":"cd371c7bd20b3e60a14c99487d82299b81336a89","tid":1815270,"uid":193215,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-07T13:14:47.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"d8c9f89359374302ad12b1e8f5182e49b738a3e1","tid":1815270,"uid":290973,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-07T13:40:36.000Z","msg":"pish"},{"pid":"9f03164a2509b506d01ed5c0a61094f2794220b5","tid":1815270,"uid":251732,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2020-01-07T13:46:40.000Z","msg":"仲有澳洲手足Avi Yemini 幫手組織集會支持香港<img src=\"/assets/faces/lm2/love.gif\" class=\"hkgmoji\" /><img s