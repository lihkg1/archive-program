d":2236563,"uid":143257,"like":14,"dislike":0,"score":14,"quote":{"pid":"7aed232538407b880110bf1e310ec50d29a8010f","tid":2236563,"uid":23189,"like":0,"dislike":0,"score":0,"quote":{"pid":"643185d499c160da399959493794b669e70c1fc2","tid":2236563,"uid":143257,"like":0,"dislike":0,"score":0,"quote":{"pid":"9fb1cc3aeac53b2ff27dcd01628b540e2c49000b","tid":2236563,"uid":23189,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-09T14:44:25.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2020-10-09T14:49:11.000Z","msg":"我個日都好似有係到"},"citedBy":1,"replyTime":"2020-10-09T14:51:42.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2020-10-09T14:59:57.000Z","msg":"講曬，驚人唔去<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n依加係到講<br />\n黑白個個係用咗一個月嘅七份唔同報紙（東方，星島，大公，文匯，SCMP，明報，蘋果），將報紙上嘅黑白位撕落去黎，貼成一幅全黑，一幅全白。但開燈後你會發現黑白背後仲有其他嘢（⋯）。<br />\n<br />\n係想講，唔同媒體嘅黑白定義都唔同⋯⋯<br />\n<img src=\"https://na.cx/i/rxwhsHL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrxwhsHL.jpg&h=028b3bf9&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/DmuSgA7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDmuSgA7.jpg&h=6c1b69fa&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/QQs8znQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQQs8znQ.jpg&h=169d35a5&s={SIZE}\" />"},{"pid":"60b6a93e5f5a3a1aa5c0ec3c4d80699bfee74140","tid":2236563,"uid":311128,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-09T15:02:18.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"e65e8005e3ea5b41772b90ab0b277fa31c196c21","tid":2236563,"uid":23189,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-09T15:04:50.000Z","msg":"此回覆已被刪除"},{"pid":"a689ab1168bd796b1c962f8529200e0140fd821b","tid":2236563,"uid":23189,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-10-09T15:05:00.000Z","msg":"此回覆已被刪除"},{"pid":"9d874f4961043ae824daf15134f7fc004e8b7207","tid":22