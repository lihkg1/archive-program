R7BmJTbZh4%3D&h=f0f86a68\" data-auto-link target=\"_blank\">https://calendar.google.com/calendar/r?pli=1</a><br />\n<br />\n2. 左手邊 &quot;其他日曆&quot; 按 &quot;+&quot;, 選 &quot;加入日曆網址&quot;<br />\n<br />\n3. 貼上網址.<br />\n<a href=\"https://calendar.google.com/calendar/ical/madqhamdimnq91i1ql50dmg7fg@group.calendar.google.com/public/basic.ics\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fcalendar.google.com%2Fcalendar%2Fical%2Fmadqhamdimnq91i1ql50dmg7fg%40group.calendar.google.com%2Fpublic%2Fbasic.ics&d=2aT02SOmMwK2whwg3zZG19ey%2FoW3U1ZMpR7BmJTbZh4%3D&h=6c49b73f\" data-auto-link target=\"_blank\">https://calendar.google.com/calendar/ical/madqhamdimnq91i1ql50dmg7fg@group.calendar.google.com/public/basic.ics</a><br />\n<br />\n4. 成功後, <br />\n&quot;其他日曆&quot; 多了一個 &quot;香港人日程表&quot;, <br />\n<br />\n5. 不用時, 可以UNTICK 或DEL 香港人日程表. <br />\n就會回復你原本的CALENDAR"}]}