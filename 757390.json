":757390,"uid":63154,"like":3,"dislike":0,"score":3,"quote":{"pid":"3271a75444de7217b2f7669a23328f6df6f04c06","tid":757390,"uid":30122,"like":6,"dislike":0,"score":6,"quote":{"pid":"e7d77943ba9fbca317e8f4a8b3f19ecabd8b02cc","tid":757390,"uid":60238,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-27T00:50:45.000Z","msg":"孤立的治安事件<br />\n咩中文嚟"},"citedBy":1,"replyTime":"2018-07-27T00:57:48.000Z","msg":"<span style=\"color: red;\">獨立</span>係咪變左敏感詞<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-27T01:37:03.000Z","msg":"學香港用&rdquo;個別&rdquo;咪得，但北佬唔知有冇呢個詞語"},{"pid":"c8d791e5fa2cba7aae4b99522231b458d66b0b30","tid":757390,"uid":159734,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-27T02:12:59.000Z","msg":"<span style=\"color: blue;\">北京市公安局的微博在內，官方只提及事發地區的路名，只說是在朝陽區天澤路和安家樓路的路口，避免提及美國駐中國大使館</span><br />\n<br />\n正一此地無銀三百兩<br />\n唔係以為唔講係美國大使館外就過到骨啊?<br />\n當人係盲嘅?<br />\n<br />\n另外，有冇巴絲知道當日受訪民眾同埋轉發影片嘅人有冇被失蹤?<br />\n聽講有轉發呢單新聞影片嘅人都被人拉咗"},{"pid":"cb1cda0c1d1117cd8be69db7942e28047bf036cb","tid":757390,"uid":10538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-27T02:35:30.000Z","msg":"好恐怖 最尾拉個女人上車 但無人幫到佢"},{"pid":"0c80b0729a9bb10bf7c1115fd9a1266ae31fc003","tid":757390,"uid":145762,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-27T03:02:43.000Z","msg":"對失敗的行動，糞組織不會承認的！"}]}