26b3d","tid":1506073,"uid":27203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:24:51.000Z","msg":"推"},{"pid":"0847e69922427df6f9c485e3d013d2ba3ca84997","tid":1506073,"uid":168250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:26:11.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">企開啲，企散啲，留空間</span></span>"},{"pid":"439212e7e4a447cd03a9d9638dea39f88f6b9360","tid":1506073,"uid":283686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:26:55.000Z","msg":"推"},{"pid":"563b14b4cbb209191567a66850741969c89814e8","tid":1506073,"uid":27203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:27:54.000Z","msg":"推"},{"pid":"ad9a1487c674ab8e0b3a48caf1bd953e2436718b","tid":1506073,"uid":27203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:28:04.000Z","msg":"推"},{"pid":"fe38090c669afb95f09d69671496d6ec89f1019f","tid":1506073,"uid":27203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:28:57.000Z","msg":"推"},{"pid":"7475306163e6f2f201be939a84a62cd39c065aa2","tid":1506073,"uid":214276,"like":1,"dislike":0,"score":1,"quote":{"pid":"3b8aa322726a16e6989ac9ecc2f62795e5319316","tid":1506073,"uid":4298,"like":3,"dislike":0,"score":3,"quote":{"pid":"9b71f8a2b4878c9168463420e026c708b65767e2","tid":1506073,"uid":27203,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-08-25T16:57:19.000Z","msg":"每一日都見到前線因為中後排唔夠位而比人拉<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n中後排有佢既價值所以唔好唔出<br />\n但係指令可以清晰啲 <img src=\"/assets/faces/pig/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">唔好再嗌 走呀 製造不必要恐慌</span></span><br />\n大家唔會知要走幾快架<br />\n<br />\n不如統一指令啦各位 <br />\n<br />\n退=慢慢向後退 真係慢慢行 調整防線位置<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><br />\n跑= 同我用你最快既速度向後跑<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><br />\n散開啲= 每個人最少一隻手位 伸開手要掂唔到人 唔係不斷向後退呀唔該 今日退撚到大東北咁<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><br />\n<br />\n走個陣唔想走失就拉住前面個袋<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><br />\n<br />\n見到有好撚多人組左好多人既戰隊 一堆人企埋一齊<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />搞到根本逼撚埋一齊 散唔開<br />\n唔該就住性別 逃跑路線 同心態分2-3人一小隊咁企 2-3個人齊上齊落<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><br />\n咪撚再堆埋一齊/一字排開6-7條友<br />\n你咁樣走又阻頭阻勢<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\">永遠支持前線<br />\n核彈都唔割<br />\n光復香港 時代革命</span></span></span>"},"citedBy":1,"replyTime":"2019-08-25T17:07:01.000Z","msg":"推<br />\n中後排太多花生mode 戒備又低<br />\n真係要大力改善"},"citedBy":0,"replyTime":"2019-08-25T17:31:33.000Z","msg":"真<br />\n要跑嗰陣好多重喺度好奇緊前線咩事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5c1c2c63edf557bc6f0d321de862f59c4b183d37","tid":1506073,"uid":27203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:34:15.000Z","msg":"推"},{"pid":"d34db8bf4b5798aac966a105b34e4df1fa4c1552","tid":1506073,"uid":158404,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-25T17:38:15.000Z","msg":"唔該不斷提醒企鬆啲 企到成堆咁唔知做乜"},{"pid":"ea4f3c46e470ca6dc2a349c09c6fb76bdd8a8de8","tid":1506073,"uid":74083,"like":1,"dislike":0,"score":1,"quote":{"pid":"881a58255b79da4e2d295d0e75d4044930ab3bd7","tid":1506073,"uid":27203,"like":0,"dislike":0,"score":0,"quote":{"pid":"597297ed643c475dc7c882af90d21bef90d4f3b7","tid":1506073,"uid":74083,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-25T17:04:59.000Z","msg":"後面嘅朋友唔該企鬆啲<br />\n前線手足退嗰時會輕鬆好多"},"citedBy":1,"replyTime":"2019-08-25T17:06:52.000Z","msg":"佢地分唔到企鬆同退 同同一話企鬆啲就一排咁走<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-25T17:39:51.000Z","msg":"成日前線只係退後少少<br />\n但後面就全部走晒咁濟<img src=\"/assets/faces/normal/oh.gif\" class