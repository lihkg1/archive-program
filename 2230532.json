 src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dfc04f89c90c4cba2eb6d71f36abdd9c9f235366","tid":2230532,"uid":63350,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d8ecdca18dae84de773b8ee71dce224564b8143","tid":2230532,"uid":54712,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-10-21T15:15:54.000Z","msg":"睇完呢類POST真係明白點解香港咩尻代理都冇剩係得一堆轉賣淘寶既垃圾奸商<br />\n樓主你貼個頭3樣野都係同一舊野黎, 就係瑞典NUO 只係代理商改撚左個名佢<br />\n另外提一提NutroOne呢間野 見到佢D野全部都係轉賣淘寶價錢仲要翻3倍<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-23T10:21:33.000Z","msg":"新手買幾重好？ 想練下肌😂"},{"pid":"6a4135541894530a435385a795da3f03f3781b0c","tid":2230532,"uid":51734,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-25T03:05:57.000Z","msg":"<a href=\"https://www.accstoreonline.com/products/smart-adjustable-dumbbell-professional-home-gym-dumbbell-a208\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.accstoreonline.com%2Fproducts%2Fsmart-adjustable-dumbbell-professional-home-gym-dumbbell-a208&d=A6Q0GQr%2FGmLii1x5qL7rGNg1hcd%2FKl8HgBLPnoE2n08%3D&h=7d55c306\" target=\"_blank\">https://www.accstoreonline.com/products/smart-adjustable-dumbbell-professional-home-gym-dumbbell-a208</a><br />\n呢款個人覺得最好<br />\n因為佢低重量個啞鈴會細d  唔似其他可調重有條軸係到kick住哂"},{"pid":"5d81a0d46a5732b5dfb52954d15c34b4eeefc4a7","tid":2230532,"uid":143121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-25T04:48:56.000Z","msg":"迪卡濃8百幾蚊果個點睇<br />\n想買但對比你果d又平到離哂譜咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"62beed95a0d4cec90c516462b8a503cae88b6c4a","tid":2230532,"uid":197989,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-05T06:28:26.000Z","msg":"可能我講得唔清楚<br