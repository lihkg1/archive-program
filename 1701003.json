f01b6c672bda054760","tid":1701003,"uid":8014,"like":2,"dislike":1,"score":1,"quote":{"pid":"873aab717faad051552e2b053be55cc935fc9821","tid":1701003,"uid":104803,"like":0,"dislike":0,"score":0,"quote":{"pid":"381904479557c917f27ec8f9f9e5e2155589ce5e","tid":1701003,"uid":25468,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-11-08T19:58:58.000Z","msg":"原則上應該無燈先有利快閃 , 唔明你咩邏輯"},"citedBy":1,"replyTime":"2019-11-08T20:24:43.000Z","msg":"咁黑 記者點影 cam點影？<br />\n影唔到，點解保障到手足安全？"},"citedBy":1,"replyTime":"2019-11-08T20:31:25.000Z","msg":"乜而家有記者就代表安全？<br />\n<br />\n有記者影住咪一樣打撚到岳巴爆頭<br />\n<br />\n唔係同記者割 好尊重記者<br />\n<br />\n而係事實上班曱甴真係靠記者mon 住即時行踨同埋靠鏡頭秋後拉人<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"1821b2f353bc955d40758757822fa703d32af6c5","tid":1701003,"uid":34424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-08T20:36:24.000Z","msg":"根本快閃冇燈先最有利 你話打陣地就等於自殺姐"},{"pid":"74281ed048093153c232e63bfe6a955b862aa12f","tid":1701003,"uid":337731,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-08T20:36:33.000Z","msg":"要燒就要快閃 燒完一個又一個先得"},{"pid":"b3371aa7dc3bbc37835bc8b74eac005aaf3b09b2","tid":1701003,"uid":104803,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2019-11-08T21:03:24.000Z","msg":"快閃就唔使cam去傳遞真相？<br />\n快閃時我方有咩閃失 因為黑而影唔到的話 點算？<br />\n<br />\n要記得 雨傘七警都係因為有cam先被告<br />\n岳義士亦係有人影到，大家先知佢既事跡<br />\n所有暗角都係因為有cam影到先有得申怨<br />\n<br />\n環境夠光 對手足既保障未必係保護到佢即時安全 但影到的話 佢可以上訴！ 影唔到就乜都無 任得班狗9up話唔關佢事<br />\n<br />\n新屋嶺8月-10月其間完全無cam<br />\n亦係因為警犬都知cam影到就仆街<br />\n<br />\n保障自己人安全就唔好燒燈箱啦 咁暗cam影唔到真係<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"7f42d2c76c949da8ccfa06aa8c6adb11ac3ade2e","tid":1701003,"uid":220479,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-11-08T21:03:29.000Z","msg":"未必關電箱事<br />\n而家已經開返燈<br />\n懷疑係狗熄燈"},{"pid":"2229e5e349546d43075c9672cb5fcfb4118146f9","tid":1701003,"uid":104803,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-11-08T21:03:51.000Z","msg":"連登真係平行時空 <br />\n<br />\n現場我唔敢講100%但90%既聲音都係話都覺得燒左黑晒 <br />\n視野唔好 <br />\n記者又影唔到 <br />\n而且仲有可能誤傷自己人 <br />\n弊多於利 燒燈箱大家都屌 <br />\n搵極又搵唔到係邊個燒<br />\n<br />\n連登就就個個話快閃要關燈"},{"pid":"611a0b369efdb01fa96bdc9f49d88a1778342542","tid":1701003,"uid":71657,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-08T21:04:31.000Z","msg":"係手足做嘅？"},{"pid":"c80ebe0eb5996f4ecaf9c715634592f1cd81ccce","tid":1701003,"uid":214363,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-11-08T21:08:48.000Z","msg":"我係岩岩先走既手足<br />\n4點幾既時間d街燈開返<br />\n我原本都以為燒完電箱 d街燈有排都開唔到<br />\n點知岩岩就開返<br />\n所以燒電箱好似冇好大影響<br />\nbtw動靜真係太大"},{"pid":"22f46074e342474f1481f64cafee3ff7f6f02bce","tid":1701003,"uid":75556,"like":0,"dislike":0,"score":0,"quote":{"pid":"fe32e6b7620c5c87177c10f01b6c672bda054760","tid":1701003,"uid":8014,"like":2,"dislike":1,"score":1,"quote":{"pid":"873aab717faad051552e2b053be55cc935fc9821","tid":1701003,"uid":104803,"like":0,"dislike":0,"score":0,"quote":{"pid":"381904479557c917f27ec8f9f9e5e2155589ce5e","tid":1701003,"uid":25468,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-11-08T19:58:58.000Z","msg":"原則上應該無燈先有利快閃 , 唔明你咩邏輯"},"citedBy":1,"replyTime":"2019-11-08T20:24:43.000Z","msg":"咁黑 記者點影 cam點影？<br />\n影唔到，點解保障到手足安全？"},"citedBy":1,"replyTime":"2019-11-08T20:31:25.000Z","msg":"乜而家有記者就代表安全？<br />\n<br />\n有記者影住咪一樣打撚到岳巴爆頭<br />\n<br />\n唔係同記者割 好尊重記者<br />\n<br />\n而係事實上班曱甴真係靠記者mon 住即時行踨同埋靠鏡頭秋後拉人<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-08T22:56:30.000Z","msg":"呢樣真，係走唔到先靠記者"},{"pid":"9403edd727a0ca6daa76b931fa924064dd30e989","tid":1701003,"uid":75556,"like":0,"dislike":0,"score":0,"quote":{"pid":"b422d8705e9ec520f0bc84b3424d61e4a13e6cbf","tid":1701003,"uid":206482,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-08T20:05:17.000Z","msg":"唔係幾明<br />\n如果全黑既話 <br />\n但係popo有螢光棒係身 唔會仲有利咩？"},"citedBy":0,"replyTime":"2019-11-08T22:58:34.000Z","msg":"螢光棒又唔你熱成像<br />\n<br />\n仲要開住光比人睇到