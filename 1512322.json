":0,"score":0,"quote":{"pid":"cbed0726f02f959633bcbdbbd84ff4858cf84cde","tid":1512322,"uid":35790,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-08-28T00:08:56.000Z","msg":"釋法囉"},"citedBy":1,"replyTime":"2019-08-28T00:39:32.000Z","msg":"仲有皇室特權可以用"},"citedBy":2,"replyTime":"2019-08-28T00:43:32.000Z","msg":"英國就有英女皇<br />\n支那何來有皇室"},{"pid":"16e5e2f699371df32634492948fe3a7c6d6e0f1c","tid":1512322,"uid":53026,"like":0,"dislike":0,"score":0,"quote":{"pid":"5781e3385bd3b4063498a2a496a715599481b273","tid":1512322,"uid":35790,"like":0,"dislike":0,"score":0,"quote":{"pid":"44a675817de6840f05fa4fb860289b1e4ada80e4","tid":1512322,"uid":53026,"like":0,"dislike":0,"score":0,"quote":{"pid":"cbed0726f02f959633bcbdbbd84ff4858cf84cde","tid":1512322,"uid":35790,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-08-28T00:08:56.000Z","msg":"釋法囉"},"citedBy":1,"replyTime":"2019-08-28T00:39:32.000Z","msg":"仲有皇室特權可以用"},"citedBy":2,"replyTime":"2019-08-28T00:43:32.000Z","msg":"英國就有英女皇<br />\n支那何來有皇室"},"citedBy":1,"replyTime":"2019-08-28T00:44:47.000Z","msg":"但係香港法例尚有皇室特權可以用"},{"pid":"1a6316d846726897f8acdd2dc6eb4fb596da9d96","tid":1512322,"uid":35790,"like":0,"dislike":0,"score":0,"quote":{"pid":"16e5e2f699371df32634492948fe3a7c6d6e0f1c","tid":1512322,"uid":53026,"like":0,"dislike":0,"score":0,"quote":{"pid":"5781e3385bd3b4063498a2a496a715599481b273","tid":1512322,"uid":35790,"like":0,"dislike":0,"score":0,"quote":{"pid":"44a675817de6840f05fa4fb860289b1e4ada80e4","tid":1512322,"uid":53026,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-28T00:39:32.000Z","msg":"仲有皇室特權可以用"},"citedBy":2,"replyTime":"2019-08-28T00:43:32.000Z","msg":"英國就有英女皇<br />\n支那何來有皇室"},"citedBy":1,"replyTime":"2019-08-28T00:44:47.000Z","msg":"但係香港法例尚有皇室特權可以用"},"citedBy":0,"replyTime":"2019-08-28T00:47:40.000Z","msg":"基本法無皇室呢樣嘢<br />\n任何法律不能抵觸基本法"},{"pid":"c88a67dd370e8241f165b44eac389b2f4b9925be","tid":1512322,"uid":35790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08