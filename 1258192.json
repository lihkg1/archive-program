cism/</a>"},{"pid":"b7421c8e8fd678300f85320512d1658eb2485b00","tid":1258192,"uid":73092,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c6f0aa3ae580ecdf80cdc150f7b2eca4cd85a14","tid":1258192,"uid":7943,"like":73,"dislike":0,"score":73,"citedBy":1,"replyTime":"2019-06-26T03:49:24.000Z","msg":"佢哋算唔算外國勢力？"},"citedBy":0,"replyTime":"2019-06-26T04:05:25.000Z","msg":"首先是中國人<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5f4975262604b35d2183db04e5f85ed940dc0b8b","tid":1258192,"uid":58351,"like":13,"dislike":0,"score":13,"citedBy":0,"replyTime":"2019-06-26T04:05:38.000Z","msg":"擇名寄俾加拿大<br />\n<br />\nProtecting Canada's Immigration System Act<br />\n<br />\n如果佢地有人申請加籍嗰陣有失實資料，可以俾取消加籍<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ec3b96ffc32fbe41737bbe4f79a2f301d1e17e15","tid":1258192,"uid":22422,"like":18,"dislike":0,"score":18,"quote":{"pid":"2c111884d4fb1e96dfd70e0d584b5bc2f5eb958a","tid":1258192,"uid":10757,"like":182,"dislike":0,"score":182,"citedBy":5,"replyTime":"2019-06-26T03:45:38.000Z","msg":"<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-26T04:05:42.000Z","msg":"名單變墓碑<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"2912c2a79f62b805db3e216e0283607045e60d9e","tid":1258192,"uid":8048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-26T04:05:52.000Z","msg":"<img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" /><br />\n口說愛國代表團體"},{"pid":"280603950e7936c5ebbb8b62c3f78f67e7baa56e","tid":1258192,"uid":54226,"like":27,"dislike":0,"score":27,"quote":{"pid":"eaf21286970df338a568a659a1ecf04ee16a2996","tid":1258192,"uid":67771,"like":143,"dislike":0,"score":143,"quote":{"pid":"2c111884d4fb1e96dfd70e0d584b5bc2f5eb958a","tid":1258192,"uid":10757,"like":182,"dislike":0,"score":182,"citedBy":5,"replyTime":"2019-06-26