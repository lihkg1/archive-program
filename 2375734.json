l.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-22T10:14:02.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-22T10:17:22.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"656dafad87261a88d9f45a2d0dea683d250809d0","tid":2375734,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-22T10:26:04.000Z","msg":"辯方又指，本案首被告早前認罪獲判感化令，建議法庭判刑不應相差太遠，惟林官指出首被告沒有使用工具毀壞棺材，辯方回應指兩被告是夥同犯罪，林官反駁指判刑有不同考慮，又舉例指：「打劫金舖，入面揸槍嗰個，都會判得重過出面揸車嗰個。」<a href=\"https://hk.appledaily.com/local/20210122/MSBKAVSKLBGOPHCBI4LNM4I4ME/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210122%2FMSBKAVSKLBGOPHCBI4LNM4I4ME%2F&d=CT6PJiTX903K6YLxhzu4Tf3PLjr3aI%2Bxco%2FW%2FCjCBac%3D&h=736d9148\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210122%2FMSBKAVSKLBGOPHCBI4LNM4I4ME%2F&h=a4a2f5cc\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20210122/MSBKAVSKLBGOPHCBI4LNM4I4ME/</a>"}]}