 data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F23%2F230935_646239d61601adad1e355e2bcab6b54e.png&h=a7d9746c&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-02-23T18:06:22.000Z","msg":"去cabo de roca算<img src=\"/assets/faces/lny/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"f5f70fbb1c939d4f8ad9139809c2c66cbc1738ae","tid":565184,"uid":17052,"like":1,"dislike":0,"score":1,"quote":{"pid":"8c4b2baf1cb0b9bc74763e89989609d4a645f736","tid":565184,"uid":155601,"like":0,"dislike":0,"score":0,"quote":{"pid":"e0b279e4a18fa8d4af353dc5d8ed5aa34af56876","tid":565184,"uid":17052,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-23T15:01:44.000Z","msg":"而家係Lisbon 今朝行完sintra<br />\n但因為個人心情唔好同好黑仔咁搞到覺得好頹<br />\n係hostel hea緊"},"citedBy":1,"replyTime":"2018-02-23T18:05:36.000Z","msg":"發生咩事<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-24T00:05:53.000Z","msg":"一嚟唔夠瞓<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /> <br />\n一早起身想用ticket machine買day pass<br />\n第一次比完錢後入唔到閘<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n之後睇有個時間既train 去到月台又冇<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n早一日train又delay左成個鐘<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n鳩行左陣sintra又覺得自好哂錢<br />\n<br />\n<br />\n<br />\nbtw 如果你去Sintra pena palace<br />\nPark &euro;7.5 Park+Palace &euro;11.5<br />\nPark 都可以上到去Palace既底層外圍，已經好靚<br />\n對個籠冇興趣可以唔使比咁多錢<br />\nPena個範圍入埋有好多景點，但隔好撚遠，palace去有幾個隔成千幾米<br />\n分差路多指示牌又不足(Quinta乜乜個個都係)<br />\n所以想參觀哂又唔想行既建議比&euro;3.5 hop-on hop-off"},{"pid":"e736355bc589be1c1922d30b811f6967d140dd96","tid":565184,"uid":155601,"like":0,"dislike":0,"score":0,"quote":{"pid":"eb2a876faa047af34f74841fb37dce42e6e7df08","tid":565184,"uid":120654,"like":1,"dislike":0,"score":1,"quote":{"pid":"c5a530c3d17632c3c462d1ebe010ef3b557ec86d","tid":565184,"uid":155601,"like":0,"dislike":0,"score":0,"quote":{"pid":"