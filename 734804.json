img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"5b63a656e7e229c7c4e8451cbf76d244df43b168","tid":734804,"uid":17502,"like":0,"dislike":0,"score":0,"quote":{"pid":"8cf8c87965ed855593001b76dbd1ba81f399db7f","tid":734804,"uid":3223,"like":1,"dislike":3,"score":-2,"quote":{"pid":"c71bbb291687f0c7129412517d0a7e14871c46da","tid":734804,"uid":68794,"like":12,"dislike":0,"score":12,"citedBy":3,"replyTime":"2018-07-09T03:57:27.000Z","msg":"點解用右手會好過用左手？"},"citedBy":1,"replyTime":"2018-07-09T11:05:22.000Z","msg":"因為世界多人用右手，所以電話製造商 UI 同 hardware 嘅design 都會有利右手<br />\n<br />\n<br />\n<br />\n例：iOS 10 之前嘅slide to unlock<br />\n<br />\nmulitasking 向右拉<br />\nback 上一頁 向右拉"},"citedBy":1,"replyTime":"2018-07-09T11:50:46.000Z","msg":"我反而覺得更多嘅係西人閱讀習慣係左向右，揭書係右向左走向右"},{"pid":"41132507927a48f5b52be3ef1d57e5da003257f5","tid":734804,"uid":17502,"like":0,"dislike":0,"score":0,"quote":{"pid":"5b63a656e7e229c7c4e8451cbf76d244df43b168","tid":734804,"uid":17502,"like":0,"dislike":0,"score":0,"quote":{"pid":"8cf8c87965ed855593001b76dbd1ba81f399db7f","tid":734804,"uid":3223,"like":1,"dislike":3,"score":-2,"quote":{"pid":"c71bbb291687f0c7129412517d0a7e14871c46da","tid":734804,"uid":68794,"like":12,"dislike":0,"score":12,"citedBy":3,"replyTime":"2018-07-09T03:57:27.000Z","msg":"點解用右手會好過用左手？"},"citedBy":1,"replyTime":"2018-07-09T11:05:22.000Z","msg":"因為世界多人用右手，所以電話製造商 UI 同 hardware 嘅design 都會有利右手<br />\n<br />\n<br />\n<br />\n例：iOS 10 之前嘅slide to unlock<br />\n<br />\nmulitasking 向右拉<br />\nback 上一頁 向右拉"},"citedBy":1,"replyTime":"2018-07-09T11:50:46.000Z","msg":"我反而覺得更多嘅係西人閱讀習慣係左向右，揭書係右向左走向右"},"citedBy":0,"replyTime":"2018-07-09T11:56:53.000Z","msg":"揭書係右向左*<br />\n<br />\n同埋你講緊嘅係UX，唔係UI，UI係講緊粒制點解擺係左上角，UI係你見到嘅嘢，UX係原因。"}]}