/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"32a602d03ce6537692fcff96971436f92f56a453","tid":1218391,"uid":64743,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T00:48:35.000Z","msg":"要支持<br />\n班福音戰士意志好驚人"},{"pid":"5c4f976ed7484950bbc2b774f48f6110b800f5cd","tid":1218391,"uid":181727,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T00:51:41.000Z","msg":"支持加油"},{"pid":"e86a2fa579d42090dd09c3eddd1bb17e3180b54c","tid":1218391,"uid":218081,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T00:53:21.000Z","msg":"￼<br />\n<br />\n<a href=\"https://www.facebook.com/Lam1Hey/videos/877187595960923/UzpfSTEwMDAwNTkzNjIwMzE0MzoxMTU3OTM2MjAxMDgwOTA5/&nbsp;\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FLam1Hey%2Fvideos%2F877187595960923%2FUzpfSTEwMDAwNTkzNjIwMzE0MzoxMTU3OTM2MjAxMDgwOTA5%2F%C2%A0&d=BIOOYiAB7dh8oRe%2BrusdWX6wbxYc%2FTJ4q%2BCB20867y4%3D&h=29549465\" data-auto-link target=\"_blank\">https://www.facebook.com/Lam1Hey/videos/877187595960923/UzpfSTEwMDAwNTkzNjIwMzE0MzoxMTU3OTM2MjAxMDgwOTA5/&nbsp;</a><br />\n<br />\n覺得想幫手又承擔唔到風險的請參加和平的遊行，遊行人數都係好重要的輿論支持<br />\n<br />\n不要因為希望而堅持；<br />\n而係因為堅持才有希望。<br />\n香港加油💪🏻香港人加油💪🏻"},{"pid":"3384accd0a331cc330fcf42e7e22310509cfc513","tid":1218391,"uid":4739,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-14T01:02:12.000Z","msg":"聖經好有意思重覆睇幾次，再埋近日既事我節錄左少少，希望有巴打可以加D圖<br />\n再去金鐘佈道講經解釋比其他人知<br />\n<br />\n<br />\n申命記 28:50 這民的面貌兇惡，不顧恤年老的，也不恩待年少的<br />\n<br />\n<br />\n申命記 17:13 眾百姓都要聽見害怕，不再擅敢行事。<br />\n<br />\n<br />\n申命記 22:18 本城的長老要拿住那人，懲治他<br />\n<br />\n申命記17：5<br />\n你就要將行這惡事的男人或女人拉到城門外，用石頭將他打死。<br />\n<br />\n申命記 23:9 「你出兵攻打仇敵，就要遠避諸惡」<br />\n<br />\n申命記 20:2 你們將要上陣的時候，祭司要到百姓面前宣告<br />\n<br />\n申命記 19:21 你眼不可顧惜，要以命償命，以眼還眼，以牙還牙，以手還手，以腳還腳。」<br />\n<br />\n<br />\n申命記 19:20 別人聽見都要害怕，就不敢在你們中間再行這樣的惡了。<br />\n<br />\n申命記 20:9 官長對百姓宣告完了，就當派軍長率領他們。<br />\n<br />\n申命記 32:23 我要將禍患堆在他們身上，把我的箭向他們射盡。<br />\n<br />\n申命記 21:21 本城的眾人就要用石頭將他打死。這樣，就把那惡從你們中間除掉，以色列眾人都要聽見害怕。」<br />\n<br />\n申命記 20:12 若不肯與你和好，反要與你打仗，你就要圍困那城。<br />\n<br />\n出埃及記 15:7\t你大發威嚴、推翻那些起來攻擊你的、你發出烈怒如火、燒滅他們像燒碎一樣。<br />\n<br />\n記得唔好咁快放棄<br />\n<br />\n申命記 32:31 據我們的仇敵自己斷定，他們的磐石不如我們的磐石。<br />\n<br />\n有人比人捉記得救人<br />\n<br />\n申命記 24:7 「若遇見人拐帶以色列中的一個弟兄，當奴才待他，或是賣了他，那拐帶人的就必治死。這樣，便將 那惡從你們中間除掉。<br />\n<br />\n致廢老，愛國愛黨人士<br />\n<br />\n申命記 32:29 惟願他們有智慧，能明白這事，肯思念他們的結局。<br />\n<br />\n最後致天價賣生理鹽水既藥坊<br />\n<br />\n申命記 23:19 你借給你弟兄的，或是錢財或是糧食，無論什麼可生利的物，都不可取利。"},{"pid":"883a26295fa0ddf4deade0b2446c0fef7ef0ce36","tid":1218391,"uid":170135,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T01:29:11.000Z","msg":"In 福音戰士 we trust <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}