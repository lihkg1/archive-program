if\" class=\"hkgmoji\" />"},{"pid":"0b9a6e32d22ebefa5fe305ee07da6f63b08760b4","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:05:26.000Z","msg":"推推推推推<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},{"pid":"11c6446412b39e3897a1db474d10d19466cf6e60","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:09:53.000Z","msg":"高清微碼版：<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e525a385ea7527f6b93a6fc2ca94990f1fc966f3","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:12:38.000Z","msg":"一齊理性討論<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n[只限會員]<img src=\"https://na.cx/i/BdoJQE5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBdoJQE5.png&h=27617b67&s={SIZE}\" />[/只限會員]"},{"pid":"30d9db9ea2a03be4f0a87cbb8833ec8c847f178c","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:15:58.000Z","msg":"推啊啊啊啊<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"8c59396ad4c068c42dc57b09632bd29293fbc085","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:16:18.000Z","msg":"<blockquote>推</blockquote>"},{"pid":"38ac35cd696ae3869c9ef7fa0e2d9c675c6f9de7","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:17:48.000Z","msg":"推推推推推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"https://na.cx/i/yaf4z8U.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fyaf4z8U.gif&h=9da80101&s={SIZE}\" />"},{"pid":"3bbc93a66cf7edb91740c329e2fb5f40583f1a1d","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:30:33.000Z","msg":"幫手推下啦<br />\n推到手斷<img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" />"},{"pid":"90ab920c36f5758e6acbaccd29f7022e03a9f9ed","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:35:25.000Z","msg":"推下啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"b67cb7628e83316a4325e01e14da07ca89e819cc","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:35:38.000Z","msg":"5<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ed22bcc469e88185385d75083217ff05b3029c01","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:35:50.000Z","msg":"4<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"b7c2dcefbfcff0d30e2b8749dfe21b2361352222","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:36:00.000Z","msg":"3<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"8aa136d23536d787cc820cb88218896d370e8460","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:36:10.000Z","msg":"2<img src=\"/assets/faces/dog/beg.gif\" class=\"hkgmoji\" />"},{"pid":"5add48a95bf9498faf137e235e9f3990e369554d","tid":1425043,"uid":161551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T17:36:21.000Z","msg":"1<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"}]}