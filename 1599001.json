pid":"4df4e4ec28121b33f5cecbc0c9d8c05adf42b854","tid":1599001,"uid":40051,"like":0,"dislike":0,"score":0,"quote":{"pid":"601251f5b097f53e9299846be8da4e0c3e169119","tid":1599001,"uid":135638,"like":0,"dislike":0,"score":0,"quote":{"pid":"bfc590719425eb77051f9460e9beb26b8b3c04f6","tid":1599001,"uid":40051,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-09-27T17:39:00.000Z","msg":"無人推，搞緊乜？"},"citedBy":1,"replyTime":"2019-09-27T17:42:56.000Z","msg":"見唔見到熱門已經有po"},"citedBy":0,"replyTime":"2019-09-27T17:44:27.000Z","msg":"Sor 沉左無睇到，都可以繼續推"},{"pid":"5306d5af96c8908573379be5c8cd181a4410328f","tid":1599001,"uid":22691,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T17:47:24.000Z","msg":"推！"},{"pid":"ba0337885f1bc4e215517677f774681925967e4d","tid":1599001,"uid":56084,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T17:47:26.000Z","msg":"即係真係有強姦<img src=\"/assets/faces/mf/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/cry.gif\" class=\"hkgmoji\" />"},{"pid":"71eb7155f41a08c11362a51d0f89f75d484ffc6f","tid":1599001,"uid":62011,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-27T17:49:18.000Z","msg":"2152 #中環 #愛丁堡廣場 #聲援新屋嶺被捕者人權集會<br />\n該名男受害人因不願解鎖手機而被近距離噴胡椒噴霧。後來被送往新屋嶺，被關在一間暗房，期間聽見有其他男人的慘叫聲。<br />\n有警察將男受害者手腳綁在枱腳，再幫其戴上頭套施虐，並說：「乖乖地講出手機密碼咪冇事囉」。受害人為了保護其他聯絡人，最後亦沒有說出密碼。<br />\n該名受害人運往市區警署直至離開警署，亦未能接觸律師。其後得知有朋友曾尋找律師並嘗試接觸受害人不果。"},{"pid":"5201a3383758246433a78b9917bf9617edb05040","tid":1599001,"uid":197492,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T17:49:42.000Z","msg":"push"},{"pid":"7a5fe578b060c09abebad845b9e1ae67bfc41294","tid":1599001,"uid":197492,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T17:57:17.000Z","msg":"push"},{"pid":"1c6e286ed5d3a521ce0dde728a0500cf9d1b71a6","tid":1599001,"uid":235535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T18:28:30.000Z","msg":"推"},{"pid":"7919b589b5f3436313f3e89fe34ce9558f95d754","tid":1599001,"uid":204625,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T18:37:09.000Z","msg":"up"},{"pid":"0aa4bfd1479c0be79aed829468b1b4f286f4373d","tid":1599001,"uid":244318,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T19:03:29.000Z","msg":"推 手足頂住 係我地冇保護好你<img src=\"/assets/faces/mf/frown.gif\" class=\"hkgmoji\" />"},{"pid":"c56f36f947f909d56d5422ca053308c3ae613c1c","tid":1599001,"uid":268692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T19:03:50.000Z","msg":"入黎睇睇 岩幫手推推<br />\n<br />\n<br />\n101重點唔係一區定五區 目標先係重點<br />\n<a href=\"https://lih.kg/1599071\" data-auto-link target=\"_blank\">https://lih.kg/1599071</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"8a8e790481d30b057af53dc393df8ce5fd5599b4","tid":1599001,"uid":234352,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T19:30:01.000Z","msg":"推"},{"pid":"38c5a73783132c0f9ef6772e2343cb71258208fe","tid":1599001,"uid":216279,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T19:31:17.000Z","msg":"心態要調整<br />\n求幫推 或多或少有幫助<br />\n［反省］我發現好多人都搵唔到方向及定位 入嚟啦<br />\n<a href=\"https://lih.kg/1599090\" data-auto-link target=\"_blank\">https://lih.kg/1599090</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"6df37ceb696c76dc5ebddf0a7650e487f8085db5","tid":1599001,"uid":31437,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T19:32:24.000Z","msg":"仆街<img src=\"/assets/faces/mf/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"d77f1e3e0a89ee8bd9d585f6416d029b3a18a19c","tid":1599001,"uid":186431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-27T19:34:17.000Z","msg":"黑警<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />，下次要叫黑警強姦犯<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"8a1d4242adea313ab2303cccc99130cbdf391749","tid":1599001,"uid":234352,"like"