faces/normal/yipes.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-10-07T02:10:11.000Z","msg":"<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-07T02:12:06.000Z","msg":"<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},{"pid":"5de4fd0bdf83f5d7b1284837da367ad0e6e14ce6","tid":2233132,"uid":8392,"like":0,"dislike":0,"score":0,"quote":{"pid":"bbf7fcfbba0702a417158da62857694f2696790c","tid":2233132,"uid":293257,"like":0,"dislike":0,"score":0,"quote":{"pid":"06b92cf2f11bc6b51a9439d4a9c90cef844e662a","tid":2233132,"uid":53578,"like":0,"dislike":0,"score":0,"quote":{"pid":"2e3513095ec7aa5b45e06aea1d9f274e5194682f","tid":2233132,"uid":293257,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-07T02:01:54.000Z","msg":"<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-10-07T02:10:11.000Z","msg":"<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-07T02:12:06.000Z","msg":"<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-07T02:14:22.000Z","msg":"你咁後生咁快睇都咁<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"542abc63f0dd80a09790f64a5a09e32a17227edc","tid":2233132,"uid":179288,"like":2,"dislike":0,"score":2,"quote":{"pid":"1189edba29a9f7816ffa35bdf9636cb72ce525d4","tid":2233132,"uid":8392,"like":0,"dislike":0,"score":0,"quote":{"pid":"e1f9cacebd9ba73d9d2eda52801b14be0d6dcac8","tid":2233132,"uid":179288,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-07T02:02:27.000Z","msg":"生蛇係神經綫痛？ <br />\n啲燈應該照唔到呀嘛？"},"citedBy":1,"replyTime":"2020-10-07T02:06:39.000Z","msg":"我都覺得揾揾地笨<br />\n所以問吓先"},"citedBy":0,"replyTime":"2020-10-07T02:15:57.000Z","msg":"帶狀疱疹後神經痛（Postherpetic Neuralgia）<br />\n<br />\n帶狀疱疹後神經痛是由水痘帶狀疱疹病毒（俗稱『生蛇』）出現後所引致的併發症。五十歲以上的長者尤其容易患上。一但曾經出過水痘，病毒就會潛伏於神經線，在成人免疫力下降時發展成帶狀疱疹。病毒繼而會破壞神經線，引致神經痛症狀。若能及早治療帶狀疱疹，可紓緩神經痛的情況。<br />\n<br />\n若帶狀疱疹消失後三個月以上，在出現過帶狀疱疹的地方持續疼痛，或者再次覺得疼痛，便可能是帶狀疱疹後神經痛。症狀包括：<br />\n<br />\n&middot;         銳痛、灼痛或酸痛<br />\n&middot;         對接觸轉變感覺敏感<br />\n&middot;         痕癢及麻痺<br />\n<br />\n食神經線痛藥 應該係最快"}]}