ssets/faces/pigxm/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" />"},{"pid":"576e8f0da9309f48632de9ef1980e436733888a7","tid":1790252,"uid":58160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-20T10:20:38.000Z","msg":"<img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" />"},{"pid":"828d5770e4446fed8dd39701e188881037996b5f","tid":1790252,"uid":36088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-20T13:17:06.000Z","msg":"up"},{"pid":"729e3fac796a7839ef1e4737b6d52c46e80e6135","tid":1790252,"uid":36088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-20T13:17:19.000Z","msg":"<img src=\"/assets/faces/pigxm/argue.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"ba424e89bec6d78b81ddbd4f9ab6ade721d1b466","tid":1790252,"uid":325953,"like":10,"dislike":1,"score":9,"citedBy":0,"replyTime":"2019-12-20T01:11:51.000Z","msg":"警隊加薪問卷調查結果<br />\n想凍結香港人錢 仲要加黑警人工？<br />\n.<br />\n民間記者會就近日有關提高公務員包括警隊薪金的議案發起問卷調查，結果顯示近99%受訪反對警察加薪<img src=\"/assets/faces/pigxm/knife.gif\" class=\"hkgmoji\" />，92.4%受訪者認同警察和其他公務員的加薪議案應分開審議。多月來警察瀆職、濫暴濫捕，近九成半受訪者對警方評分繼續給予零分。民調結果各項數據均充分顯示警察並無加薪之理。<br />\n.<br />\n政府和保皇黨必須重新考慮加薪方案，分開審議警隊和其他公務員薪酬，並凍結或減少警員薪酬和津貼，停止將警隊提升為社會的特權階級，聆聽已經非常清晰的民意。<br />\n.<br />\n<img src=\"/assets/faces/pigxm/pointing.gif\" class=\"hkgmoji\" />問卷調查結果新聞稿：<br />\n<a href=\"https://bit.ly/36U8G1B\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F36U8G1B&d=1CRlZafk7JeE%2BAtxbqKu5XvcSryOYOd41eK7VOq09cM%3D&h=187f2f7e\" data-auto-link target=\"_blank\">https://bit.ly/36U8G1B</a>"}}