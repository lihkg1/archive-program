://na.cx/i/Fs9vBFu.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFs9vBFu.gif&h=ce493f5c&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/szCtokB.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FszCtokB.png&h=a2e2f19f&s={SIZE}\" />"},{"pid":"1f3703d2c2bd017e02381a8cf632206ef632c0a2","tid":1781220,"uid":3302,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-12-13T05:54:03.000Z","msg":"區諾軒對警隊領取逾9.5億津貼開支感震驚<br />\n<br />\n警隊過去半年領取逾時津貼開支涉9.5億元，議會陣線立法會議員區諾軒對此感到震驚，認為有時警方的行動並無需要，例如立法會大樓外站崗工作等，批評香港已變成「警察城市」。<br />\n<br />\n他又指出，如果以社區重點項目計劃撥款計算，有關開支足以在全港一半地區開展眼科或牙科檢查服務，或在西九龍興建三座天橋。<br />\n<br />\n對於當局稱，財委會已授權財政司司長可以追加逾時工作津貼的費用，不設限額，區諾軒認為財委會不應作出授權，形容猶如開出一張無限額支票，民主派未來會採取所有手段阻止和反對。<br />\n<a href=\"https://www2.hkej.com/landing/mobArticle2/id/2329017/區諾軒對警隊領取逾9.5億津貼開支感震驚\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww2.hkej.com%2Flanding%2FmobArticle2%2Fid%2F2329017%2F%E5%8D%80%E8%AB%BE%E8%BB%92%E5%B0%8D%E8%AD%A6%E9%9A%8A%E9%A0%98%E5%8F%96%E9%80%BE9.5%E5%84%84%E6%B4%A5%E8%B2%BC%E9%96%8B%E6%94%AF%E6%84%9F%E9%9C%87%E9%A9%9A&d=ZRuO0gn2PDb4CPS%2BM%2Fpj6koInKkgZqzseva8eQDkMF8%3D&h=78cac570\" target=\"_blank\">https://www2.hkej.com/landing/mobArticle2/id/2329017/區諾軒對警隊領取逾9.5億津貼開支感震驚</a>"},{"pid":"2eae90a1f2bc6711b5cac309b417ae4a5b5a8131","tid":1781220,"uid":61282,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-12-13T05:54:49.000Z","msg":"好似追dq議員人工咁追返黑警啲人工"},{"pid":"aeae6b229134a36df480f2f7c18a07973e26c7f3","tid":1781220,"uid":68598,"like":1,"dislike":0,"score":1,"quote":{"pid":"1a8e14e7d1f7cc26e1476623084490228d2c4a23","tid":1781220,"uid":3302,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2019-12-13T03:51:47.000Z","msg":"拉布有幾耐拖幾耐<br />\n睇到真係好撚嬲<br />\n每隻警犬每月拎多萬四蚊ot<br />\n香港人俾錢請人打自己<br />\n議員們一定要拖延撥款 有幾耐拖幾耐"},"citedBy":1,"replyTime":"2019-12-13T05:55:28.000Z","msg":"你最多拖所有公務員加薪<br />\n佢地出左嫁啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"2975d2a