36503d9edf82f384401d39c150e781ec&amp;oe=5BA0F5E7\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg3-2.fna.fbcdn.net%2Fv%2Ft1.0-9%2F34683778_1958517474158524_6563668136707489792_n.jpg%3F_nc_cat%3D0%26oh%3D36503d9edf82f384401d39c150e781ec%26oe%3D5BA0F5E7&h=ebf42e99&s={SIZE}\" />"},{"pid":"87bb948cf2a8c8ea450d7a0cfa5bd93a842c9523","tid":705143,"uid":33235,"like":0,"dislike":0,"score":0,"quote":{"pid":"d88288ae20fcee2b4faf80fb710c0350f0e9895b","tid":705143,"uid":20867,"like":26,"dislike":3,"score":23,"citedBy":1,"replyTime":"2018-06-17T01:59:11.000Z","msg":"我還記得，在2014九月底的一個傍晚，全港1%人口都去了金鐘為抗爭者吶喊助威。"},"citedBy":0,"replyTime":"2018-06-17T04:42:07.000Z","msg":"想喊<img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" />"},{"pid":"e29a94e9725de9c891dcadf3a44d1c062edd49fa","tid":705143,"uid":20867,"like":1,"dislike":0,"score":1,"quote":{"pid":"3db99cd53ffb92a52e16c3a6a78f7b3ae6c8a2be","tid":705143,"uid":35430,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-06-17T04:03:54.000Z","msg":"有冇諗過點解香港搞乜團體運動都死？<br />\n因為你係華人賤種走難基因"},"citedBy":0,"replyTime":"2018-06-17T04:48:28.000Z","msg":"「大一統」對團體運動不是更有優勢嗎？未必<br />\n<br />\n同樣是團體運動：<br />\n<br />\n中國在排球成績優異系因為<br />\n賽例造成排球需要六個功能相若的球員<br />\n<br />\n但足球需要十一個不同功能的球員互相配合<br />\n<span style=\"color: red;\">和而不同</span><br />\n<br />\n中國人（含香港人）做唔到<span style=\"color: red;\">和而不同</span>既「和」<br />\n退而求其次追求大一統既「同」<br />\n<br />\n因此大多數中國人（含香港人）最終選擇「大一統」<br />\n中國人 選擇 共產黨<br />\n香港人 選擇 ＴＶＢ"},{"pid":"ba938cb139999727b285f50ec4f9ab7a9056a7ab","tid":705143,"uid":15815,"like":0,"dislike":0,"score":0,"quote":{"pid":"b1cdcddf29bf0cf11d1c36caebfc316f9e49dc83","tid":705143,"uid":14349,"like":2,"dislike":4,"score":-2,"citedBy":1,"replyTime":"2018-06-17T02:39:44.000Z","msg":"香港人流住中國既血統<br />\n<br />\n所以呢一世都唔洗旨意可以好似人地咁叻"},"citedBy":0,"replyTime":"2018-06-17T06:18:23.000Z","msg":"支那人都分等級<br />\n多數黎香港一定係最劣質果隻"},{"pid":"854d9bbb90c183eed22e255fcc14f4f3b4c7dda8","tid":705143,"uid":153811,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-17T06:27:48.000Z","msg":"又黎個d中國人總結思維，懶係理解人地，點解華人咁撚鐘意出呢d文章？個個當哂自己係李白定杜府？"},{"pid":"7da25fc54041860665a5970db48b2c32c61387d9","tid":705143,"uid":15815,"like":0,"dislike":0,"score":0,"quote":{"pid":"96c62d8bf343c5725915556ce0103f1c78ce9929","tid":705143,"uid":60281,"like":2,"dislike":2,"score":0,"citedBy":1,"replyTime":"2018-06-17T04:41:03.000Z","msg":"香港人都有機會<img src=\"/assets/faces/fifa/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fifa/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fifa/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://scontent.fhkg3-2.fna.fbcdn.net/v/t1.0-9/34683778_1958517474158524_6563668136707489792_n.jpg?_nc_cat=0&amp;oh=36503d9edf82f384401d39c150e781ec&amp;oe=5BA0F5E7\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg3-2.fna.fbcdn.net%2Fv%2Ft1.0-9%2F34683778_1958517474158524_6563668136707489792_n.jpg%3F_nc_cat%3D0%26oh%3D36503d9edf82f384401d39c150e781ec%26oe%3D5BA0F5E7&h=ebf42e99&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-06-17T07:06:29.000Z","msg":"捧場<br />\n好似泰仔勁左好多<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}