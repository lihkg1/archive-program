kcnews.com%2Farticle%2F24280%2F%25E9%25A6%25AC%25E5%25AE%25A3%25E7%25AB%258B-%25E6%25B3%2595%25E9%2586%25AB-%25E9%2599%25B3%25E5%25BD%25A5%25E9%259C%2596-24287%2F%25E4%25BB%25BB%25E6%25B3%2595%25E9%2586%25AB30%25E5%25B9%25B4%25E9%25A6%25AC%25E5%25AE%25A3%25E7%25AB%258B%25EF%25BC%259A%25E5%25A7%25A6%25E6%25AE%25BA%25E6%25A1%2588%25E4%25BB%25A5%25E5%25A4%2596%25E7%2594%259A%25E5%25B0%2591%25E9%2581%25BA%25E9%25AB%2594%25E4%25B8%2580%25E7%25B5%25B2%25E4%25B8%258D%25E6%258E%259B-%25E5%25BF%2585%25E9%25A0%2588%25E5%259C%25A8%25E6%25AD%25BB%25E5%259B%25A0%25E5%25BA%25AD%25E8%25A7%25A3%25E9%2596%258B%25E7%2596%2591%25E5%259C%2598&d=X54jjuw0UQFZuhWzkrVO7kzlOXIvf7DEkQzrkg%2FJo1w%3D&h=a3c11683\" data-auto-link target=\"_blank\">https://www.hkcnews.com/article/24280/%E9%A6%AC%E5%AE%A3%E7%AB%8B-%E6%B3%95%E9%86%AB-%E9%99%B3%E5%BD%A5%E9%9C%96-24287/%E4%BB%BB%E6%B3%95%E9%86%AB30%E5%B9%B4%E9%A6%AC%E5%AE%A3%E7%AB%8B%EF%BC%9A%E5%A7%A6%E6%AE%BA%E6%A1%88%E4%BB%A5%E5%A4%96%E7%94%9A%E5%B0%91%E9%81%BA%E9%AB%94%E4%B8%80%E7%B5%B2%E4%B8%8D%E6%8E%9B-%E5%BF%85%E9%A0%88%E5%9C%A8%E6%AD%BB%E5%9B%A0%E5%BA%AD%E8%A7%A3%E9%96%8B%E7%96%91%E5%9C%98</a>"},{"pid":"fdc993fd9988f1385737d4d46c47f8290a149980","tid":2183601,"uid":36901,"like":28,"dislike":1,"score":27,"citedBy":4,"replyTime":"2020-09-01T05:11:21.000Z","msg":"<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1547190-20200901.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1547190-20200901.htm&d=X54jjuw0UQFZuhWzkrVO7kzlOXIvf7DEkQzrkg%2FJo1w%3D&h=34a697eb\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1547190-20200901.htm&h=f02eb778\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1547190-20200901.htm</a><br />\n<br />\n李毓樺說，死者的生殖器官沒有傷痕，子宮和盤骨正常，但很多時受性侵犯未必會在私處留下傷痕，因此不能證實死者生前有否被性侵犯。他又說，<span class=\"red\">有檢取死者的陰道拭子樣本交予警方</span>，轉交化驗所化驗有否精液成份，但他手上沒有這份報告資料。<br />\n<br />\n李毓樺說，遇溺可能是其中一個死亡原因，但不能完全確定，<span class=\"red\">又說一個懂得游水的人選擇跳海自殺並不常見。在死者右胸腔找到50毫升深紅色腐爛液體，左邊找到550亳升。醫管局大律師引述另一名專家證人馬宣立的報告指出，一般遇溺人士的左右兩邊肺部液體是平均分佈，問李毓樺為何陳彥霖遺體的左右胸腔液差距如此大。李毓樺說未能解釋原因。</span>"},{"pid":"6b1302eec19b01e3178b0c4afc2c7b0628ce8fc3","tid":2183601,"uid":59242,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-09-01T05:14:32.000Z","msg":"點會分唔到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />睇戲都有講啦"},{"pid":"03c91733b0fadaffd2e43aca6e6696316e4d42b5","tid":2183601,"uid":301152,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-09-01T05:22:31.000Z","msg":"<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1547190-20200901.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1547190-20200901.htm&d=X54jjuw0UQFZuhWzkrVO7kzlOXIvf7DEkQzrkg%2FJo1w%3D&h=34a697eb\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1547190-20200901.htm&h=f02eb778\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1547190-20200901.htm</a><br />\n<br />\n<br />\n李毓樺說，死者的生殖器官沒有傷痕，子宮和盤骨正常，但很多時受性侵犯未必會在私處留下傷痕，因此不能證實死者生前有否被性侵犯。他又說，<span class=\"red\">有檢取死者的陰道拭子樣本交予警方，轉交化驗所化驗有否精液成份，</span>但他手上沒有這份報告資料。<br />\n<br />\n李毓樺說，遇溺可能是其中一個死亡原因，但不能完全確定，又說一個<span class=\"red\">懂得游水的人選擇跳海自殺並不常見</span>。在<span class=\"red\">死者右胸腔找到50毫升深紅色腐爛液體，左邊找到550亳升</span>。醫管局大律師引述另一名專家證人馬宣立的報告指出，一般遇溺人士的左右兩邊肺部液體是平均分佈，問李毓樺為何陳彥霖遺體的左右胸腔液差距如此大。李毓樺說未能解釋原因。<br />\n<br />\n<br />\n<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><span class=\"x-large\"><span class=\"orange\"><br />\n點解要俾警方交化驗所驗</span></span><br />\n<br />\n<br />\n會唔會俾人灌水入去個肺？ <img src=\"/assets/faces/lm2/noodles.gif\" class=\"hkgmoji\" />"},{"pid":"2b6fb4fee4c9fcb6f4fc31cfa2518bb386458b81","tid":2183601,"uid":13663,"like":5,"dislike":0,"score":5,"quote":{"pid":"fdc993fd9988f1385737d4d46c47f8290a149980","tid":2183601,"uid":36901,"like":28,"dislike":1,"score":27,"citedBy":4,"replyTime":"2020-09-01T05:11:21.000Z","msg":"<a href=\