assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},{"pid":"9267200ae97583a283dd183cdf50d8699dd590ef","tid":2046311,"uid":61786,"like":0,"dislike":0,"score":0,"quote":{"pid":"8480f4cdcba8eb72a9b6a67545f4ec598bdb04f2","tid":2046311,"uid":26846,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-01T10:38:24.000Z","msg":"搞都唔係搞64啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-01T10:43:08.000Z","msg":"64係一個契機、一個號召嘅日子，連登仔唔係好鍾意用64民運踩單車去集會嘅gif咩？<br />\n<br />\n悼念唔止可以係死難者，係一個精神、一個普世價值嘅延續。64亦都係支共嘅痛腳，落鳩佢面，同時帶出更多嘅思想，耳濡目染下一代。<br />\n<br />\n支共對香港越來越高壓迫，你想香港成為下一個64嗎？<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},{"pid":"fd896200e87695ad71bfd62593665fdc3c6134a5","tid":2046311,"uid":61786,"like":0,"dislike":0,"score":0,"quote":{"pid":"ef38fe5261b545be9c8b69c89ec931f7f1344424","tid":2046311,"uid":146621,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-01T10:39:11.000Z","msg":"悼念當年嘅民主義士都ok<br />\n但鄰國嘅民主發展真係講黎都嘥氣"},"citedBy":0,"replyTime":"2020-06-01T10:44:15.000Z","msg":"理得支那人死唔死咩，當然死光最好啦。<br />\n呢個係一個抗爭精神嘅延續，推動抗爭日常化。"},{"pid":"1137b095456f2bfab8d84393e2c96e793a19ba01","tid":2046311,"uid":61786,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-01T10:45:51.000Z","msg":"推"},{"pid":"7b1638e35f53e16e8f7bff84068aed5726b506c5","tid":2046311,"uid":246832,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-01T10:46:24.000Z","msg":"推推"},{"pid":"65593032cedbb0c484d3e7f4dc48e6b2150c002a","tid":2046311,"uid":175511,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2020-06-01T10:46:38.000Z","msg":"64關香港人撚事 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"c02d029c5d9979d8bbb56d7f1a3c0b46bf1a44e2","tid":2046311,"uid":26846,"like":0,"dislike":0,"score":0,"quote":{"pid":"9267200ae97583a283dd183cdf50d8699dd590ef","tid":2046311,"uid":61786,"like":0,"dislike":0,"score":0,"quote":{"pid":"8480f4cdcba8eb72a9b6a67545f4ec598bdb04f2","tid":2046311,"uid":26846,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-01T10:38:24.000Z","msg":"搞都唔係搞64啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-01T10:43:08.000Z","msg":"64係一個契機、一個號召嘅日子，連登仔唔係好鍾意用64民運踩單車去集會嘅gif咩？<br />\n<br />\n悼念唔止可以係死難者，係一個精神、一個普世價值嘅延續。64亦都係支共嘅痛腳，落鳩佢面，同時帶出更多嘅思想，耳濡目染下一代。<br />\n<br />\n支共對香港越來越高壓迫，你想香港成為下一個64嗎？<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-01T10:47:04.000Z","msg":"覺得踩單車嗰條友有朝氣係一回事 欣賞佢 但64係大中華國族主義圖騰 我個人黎講係不了"},{"pid":"7b9d1ef0f1d621399ad08052fa9b8ffd66c6517a","tid":2046311,"uid":246832,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-01T10:47:05.000Z","msg":"個po好肥"},{"pid":"b2398bcebd9364dc6ba8b7d1b61fe8f138da00ae","tid":2046311,"uid":61786,"like":0,"dislike":0,"score":0,"quote":{"pid":"65593032cedbb0c484d3e7f4dc48e6b2150c002a","tid":2046311,"uid":175511,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2020-06-01T10:46:38.000Z","msg":"64關香港人撚事 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-01T10:50:15.000Z","msg":"香港抗爭運動關日本人撚事？"},{"pid":"86cf83d17a98a6f9929d2af2c7d9cb0752f28a1b","tid":2046311,"uid":268519,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-01T10:55:40.000Z","msg":"嗰日就係要唱衰中共衰嘢<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d19244f1f96d8111d04effbd7c4e3dee2940864f","tid":2046311,"uid":61786,"like":1,"dislike":0,"score":1,"quote":{"pid":"65593032cedbb0c484d3e7f4dc48e6b2150c002a","tid":2046311,"uid":175511,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2020-06-01T10:46:38.000Z","msg":"64關香港人撚事 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-01T11:02:00.000Z","msg":"冇架，其實學生、人民為自由抗爭，被暴政虐殺係他國嘅事，真係唔關香港人事。<br />\n20幾30年後嘅香港，抗爭精神逐漸挖起、成長，好多香港人對如何抗爭，何謂抗爭都好陌生。世界各地上都有唔同大大小小嘅民運、抗爭事件，甚至有啲已經成為歷史。<br />\n<br />\n我以前都覺得64集會不痛不癢，但今年 港共政府 黑警首次批反對通知書，我淨係知有啲野唔做，將來就會被遺忘。<br />\n<br />\n唔想香港成為下一個64，或者咁講，即使出現多一次64，後人都會記得我地曾經做過嘅行動同付出，繼續為信念而抗爭。<br />\n<br />\n抗爭精神除左食黃店，仲有好多唔同方法可以日常化同延續落去嘅。"},{"pid":"6cd35ccd255b7e53f864420afd787ed49d464aa1","tid":2046311,"uid":61786,"like":0,"dislike":0,"score":0,"quote":{"pid":"86cf83d17a98a6f9929d2af2c7d9cb0752f28a1b","tid":2046311,"uid":268519,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-01T10:55:40.000Z","msg":"嗰日就係要唱衰中共衰嘢<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-01T11:02:22.000Z","msg":"落鳩佢面<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"a18ddbb05069cb3aee75be0791dcf5efbc43c443","tid":2046311,"uid":61786,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-01T11:03:09.000Z","msg":"推"},{"pid":"4f0e2280b7728b7832fc58c4127c5b240fc3aba3","tid":2046311,"uid":61786,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-01T11:05:01.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"60b5b4f4f729ba23e0b0336290f3d6b87dec9c76","tid":2046311,"uid":97221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-01T11:06:39.000Z","msg":"推"},{"pid":"e179bf9e58cab2338dc2d1f2800cf3e7b3da19a1","tid":2046311,"uid":97221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-01T11:07:11.000Z","msg":"推"},{"pid":"6ca87d6f92ca66979eaf19bef32a827948288f0d","tid":2046311,"uid":61786,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-01T11:07:13.000Z","msg":"如何凝聚人心？如何保持信念？如何維持抗爭的熱度？<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"33c4f0a1ceb8083369a9ed26748610bacfe84a24","tid":2046311,"uid":97221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-01T11:07