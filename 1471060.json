,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T09:25:05.000Z","msg":"推呀"},{"pid":"5cbf025964e2b3d90f8de98a3528ba535197c279","tid":1471060,"uid":194609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T08:40:57.000Z","msg":"<blockquote><img src=\"https://na.cx/i/MSFdZD2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FMSFdZD2.png&h=bfd387f3&s={SIZE}\" /><br />\n我們別再犯五年前的錯，好嗎？<br />\n<a href=\"https://lih.kg/1477040\" target=\"_blank\">https://lih.kg/1477040</a><br />\n- 分享自 LIHKG 討論區</blockquote>"},{"pid":"2f12994b2b0b2f739316654fe61f249ff5e06598","tid":1471060,"uid":260695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T08:49:37.000Z","msg":"推"},{"pid":"f69efa8668cf700653aad2501d66d7bb5cb8c671","tid":1471060,"uid":260695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T08:50:47.000Z","msg":"推"}]}