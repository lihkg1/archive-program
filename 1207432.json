就唔係做突出個一個<br />\n<br />\n全民 BLACK BLOCK<br />\n<a href=\"https://lih.kg/1203119\" data-auto-link target=\"_blank\">https://lih.kg/1203119</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"d8d92b9d6dcd14531f99505a9263f25566260e29","tid":1207432,"uid":50801,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-12T06:42:58.000Z","msg":"留名睇後續"},{"pid":"f8b672371765e91defff95259826a8459e5be993","tid":1207432,"uid":23560,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T06:45:41.000Z","msg":"pish"},{"pid":"01df1916e8f1380149788218c46381308dc81694","tid":1207432,"uid":143343,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T06:45:44.000Z","msg":"你地想黎可以一齊"},{"pid":"5767766660b0c41b71a7901bf62418ab37a0080c","tid":1207432,"uid":49549,"like":0,"dislike":8,"score":-8,"citedBy":1,"replyTime":"2019-06-12T06:47:55.000Z","msg":"信德中心定招商局大廈唔記得幾多樓"},{"pid":"67f36b25578f2ffd23e7eaca4c88b899dea7d4e9","tid":1207432,"uid":143343,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T06:47:56.000Z","msg":"Push"},{"pid":"6ee4b7ecb900ea5aec66f12af4a109fdf1f8701c","tid":1207432,"uid":143343,"like":40,"dislike":0,"score":40,"quote":{"pid":"5767766660b0c41b71a7901bf62418ab37a0080c","tid":1207432,"uid":49549,"like":0,"dislike":8,"score":-8,"citedBy":1,"replyTime":"2019-06-12T06:47:55.000Z","msg":"信德中心定招商局大廈唔記得幾多樓"},"citedBy":1,"replyTime":"2019-06-12T06:48:58.000Z","msg":"金鐘道95號統一中心21樓"},{"pid":"0daa18480f20be59ed499336f1f0a99e216c7bb1","tid":1207432,"uid":24707,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-12T06:49:50.000Z","msg":"支持"},{"pid":"eefa5cbfcc68600e25083e1b91b807437eea0cd4","tid":1207432,"uid":82938,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T06:49:51.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"7e19bb6312217d35b6bcef2b0cc7aade37202a2e","tid":1207432,"uid":144611,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T06:50:05.000Z","msg":"Push"},{"