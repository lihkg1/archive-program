=\"_blank\">https://twitter.com/victortsang12</a>"},{"pid":"516a75622115dc67085e54e9aa99d0fce28b38be","tid":1055512,"uid":18385,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-10T17:02:00.000Z","msg":"<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},{"pid":"a4b7a3660e1865a1e59b1516e52e086a84ac76fd","tid":1055512,"uid":19501,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-03-10T17:10:31.000Z","msg":"rip<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"64a5ea3e0a1431f49a1bd089fb3a11abba2b94a9","tid":1055512,"uid":121255,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-03-10T17:11:30.000Z","msg":"r.i.p<img src=\"/assets/faces/fs/bye.gif\" class=\"hkgmoji\" />"},{"pid":"0abc54ad20b32856c69bc4ae5d4db9430133a149","tid":1055512,"uid":197640,"like":0,"dislike":2,"score":-2,"quote":{"pid":"516a75622115dc67085e54e9aa99d0fce28b38be","tid":1055512,"uid":18385,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-10T17:02:00.000Z","msg":"<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-10T17:20:37.000Z","msg":"主任<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"79411c55629debd684db8a9250decfb0e28bba1a","tid":1055512,"uid":14449,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-03-10T17:25:12.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"01bfdec8812c5699dc54b38d9ead7e4bff6f515b","tid":1055512,"uid":74058,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-03-10T17:25:21.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"173e458bd55ca5e70269827be2e8fa4317de36ed","tid":1055512,"uid":69806,"like":30,"dislike":1,"score":29,"quote":{"pid":"225a43e84f33017434be4e74c2bdaf5e40c0a379","tid":1055512,"uid":20933,"like":39,"dislike":0,"score":39,"citedBy":1,"replyTime":"2019-03-10T15:30:51.000Z","msg":"<strong>罹難港人熱愛非洲 妻子於UNESCO工作 一家三口定居肯雅</strong><br />\n<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20190310/large/1552228102_35b7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190310%2Flarge%2F1552228102_35b7.jpg&h=8a806517&s={SIZE}\" /><br />\n<br />\n埃塞俄比亞航空一架737-800MAX客機，今日在從首都亞的斯亞貝巴（Addis Ababa），飛往肯雅首都內羅比（Nairobi）途中墜毁，機上149名乘客及8名機組人員，全部罹難。據悉，罹難的8名中國人死者中，包括一名叫「曾成毅」的香港人。<br />\n<br />\n據悉，曾成毅在聯合國環境署工作，現年37歲，他早前前往羅馬探朋友，並在3日前在ig更新個人狀態，豈料今日經埃塞俄比亞轉機返回肯雅時出事。<br />\n<br />\n洋名Victor的曾成毅2000年在觀塘瑪利諾書院中七畢業，之後入讀中文大學工商管理學系，2004年畢業後赴笈倫敦升學，曾於意大利的聯合國糧食及農業組織工作，之後更遠赴非洲肯雅聯合國環境署的辦事處工作。<br />\n<br />\n在去年12月中大校友期刊中，曾成毅曾以校友身份，短暫返回中大擔任全球研究課程其中一節課的客席講師，與學生分享對可持續發展的看法。<br />\n<br />\n另外，曾成毅已婚，與姓張妻子育有一子，一家三口居住在非洲肯雅亞首都內羅比，他經常在fb及ig分享在當地的家庭合照、工作生活及探訪當地大學等照片，而且曾成毅更將自己的fb改名，以「home in nairobi」來表達對該塊非洲土地的鍾愛。<br />\n<br />\n至於，曾成毅的妻子亦在肯雅聯合國教科文組織（UNESCO）教育部門擔任知識管理及信息專家，其姨母曾於網上指曾成毅與妻子在教會結識，兩人一見鐘情，締結良緣，2016年雙雙派駐往肯雅工作，並在當地誕下一子。<br />\n<br />\n入境處根據當地機關提供予大使館的資料，暫時確認乘客名單上有一名香港居民，已主動聯絡其家人，並按當事人家屬意願提供一切可行協助，並透過外交部駐港特派員公署、中國駐埃塞俄比亞民主共和國大使館及有關航空公司了解情況，會繼續與公署、大使館、當事人家屬及航空公司保持聯繫。"},"citedBy":0,"replyTime":"2019-03-10T17:28:43.000Z","msg":"兩公婆都好勁<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"82ee83d1dc9da9ab82fea455e395844baf83a34b","tid":1055512,"uid":75442,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2019-03-10T17:30:02.000Z","msg":"中學師兄<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"b4ba53131b666eb4d40110d8e4b9a7bcbbdc94d7","tid":1055512,"uid":126510,"like":0,"dislike":5,"score":-5,"citedBy":0,"replyTime":"2019-