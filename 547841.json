e":0,"quote":{"pid":"531c0f39889dfca609e23bcd9318872382e40d24","tid":547841,"uid":106375,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-02T01:39:03.000Z","msg":"憎死佢"},"citedBy":1,"replyTime":"2018-02-02T01:39:47.000Z","msg":"可以點樣憎 佢無做過啲咩黑人憎<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-02T01:56:53.000Z","msg":"表白之後你會勁憎佢"},{"pid":"312b3982246e59d3835c9bf9ca4950788e7a80f4","tid":547841,"uid":169676,"like":0,"dislike":0,"score":0,"quote":{"pid":"cb84b00325accdaf185033d4efb535cfb00ed988","tid":547841,"uid":150634,"like":0,"dislike":2,"score":-2,"quote":{"pid":"a4ac04c8162a9b5adbcb898e6fe000337e3d68d4","tid":547841,"uid":169676,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-02T01:35:23.000Z","msg":"有幾唔應該鐘意？<img src=\"/assets/faces/fs/oh.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-02T01:38:47.000Z","msg":"有另一半 但係對第二個有好感<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-02T03:20:19.000Z","msg":"咁你同另一半有無一齊建立一啲共同目標？<br />\n<br />\n意思係「一齊去建立同一樣嘢，從而投放感情係個樣度，當完成後就可以彼此認同對方」<br />\n可以一齊參加啲興趣班、砌下模型砌下puzzle咁<br />\n總之就係搵個方法可以兩個人一齊專注做同一樣嘢<br />\n最好過程要有啲難度<br />\n太易會無乜成功感<br />\n咁樣除咗可以忽略第二個之外<br />\n仲可以加強到同另一半嘅感情連結<br />\n當你地經過一番努力完成個目標之後<br />\n就唔會咁輕易嫌棄對方<br />\n最好完成後再建立下一個目標<br />\nkeep住一直做落去<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"}]}