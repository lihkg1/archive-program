ets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-03T15:42:36.000Z","msg":"呢個好廢 會入TG 拿眼"},{"pid":"a407b9971ac10a9693d8de5e6dfe55a35f570f59","tid":1533733,"uid":293446,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T03:51:15.000Z","msg":"It has been a while. Are you doing ok? Hope this finds you well"},{"pid":"63d94964fcc45807121acfbc6dedee85ba41db1d","tid":1533733,"uid":358979,"like":0,"dislike":0,"score":0,"quote":{"pid":"068cc7a414646ff9b2238b70d8de2fd2bd12851d","tid":1533733,"uid":259557,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-02T20:04:19.000Z","msg":"我係香城online新手，之前一路都係睇人直播打呢隻game，但係見住愈嚟愈多玩家受傷，冇得落場玩，覺得再咁落去唔係辦法。<br />\n<br />\n<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" /><br />\n<br />\n9月2都去咗中大罷課，出過一次機場之後感受真係好唔同<br />\n我諗我之後都會成日on呢隻game，例如9月8一定出<br />\n<br />\n但係我預咗自己暫時唔會上前線，入黑後會早走<br />\n（我絲，體能唔好，跑得慢，留到太夜/係前線只會連累前線手足<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />）<br />\n<br />\n想問我宜家應該買咩裝備好？要買到幾高level嘅裝備先夠用？<br />\n有啲驚帶住裝到現場時比狗查袋會出事，但唔買裝又好似太危險<br />\n<br />\n對唔住 我都唔想做伸手黨，但係身邊一個會玩香城online嘅人都冇<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />好無助 唯有上嚟問下<br />\n<br />\n<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /><br />\n<br />\n順便問多句，有冇絲都係會單機出<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />自己冇乜朋友搵唔到隊友一齊出<br />\n<br />\nSorry for咁遲先開始玩，我都知自己衰，好後悔冇早啲加入<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />對唔住大家<br />\n<br />\n都Sorry for P牌，有咗大學email成年，但係之前覺得冇必要開ac所以一直冇開，係6月為咗睇發夢資訊先開嘅<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-21T17:46:18.000Z","msg":"樓主識唔識 <br />\n流輸畏？"}]}