=\"hkgmoji\" />"},{"pid":"b4a377c0bd61a4fc20d4cf29f486724add478474","tid":634431,"uid":3500,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a0dd980b14b74a791c8069859309069b6c11f9d","tid":634431,"uid":68708,"like":0,"dislike":0,"score":0,"quote":{"pid":"393b203b667bfb63178ea0565f2e90975d007a95","tid":634431,"uid":3500,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-04-19T12:23:32.000Z","msg":"各位加油啊<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<span style=\"font-size: x-small;\">上年5** </span>"},"citedBy":1,"replyTime":"2018-04-19T13:53:18.000Z","msg":"<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />  上年4左。今年希望有* <br />\nd史實基本上都8899！ 想問下仲有冇咩位要注意下咁？"},"citedBy":1,"replyTime":"2018-04-19T14:12:40.000Z","msg":"平常心面對 呢幾日重溫史實之後 溫pastpaper 卷二望下 諗下可唔可以apply番落去 有時間就寫下<br />\n最緊要既係 base on past paper 抽一條出黎 自己改完題目 可以係提問用語 亦都可以係課題內容 總知就變到一條你見都未見過 做都未做過既新題目 之後計時做 你試下就會大概get到考dse個時 面對卷二呢個boss所需要既心理與素同埋執生能力<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"}]}