kgmoji\" />"},{"pid":"6ee1e70c72941316ed308d2c01bb630d2a3e12c2","tid":2422024,"uid":105924,"like":0,"dislike":0,"score":0,"quote":{"pid":"6f36c9dfe21fc5f1347c21486f89e8d99ff6af7d","tid":2422024,"uid":68689,"like":30,"dislike":0,"score":30,"citedBy":1,"replyTime":"2021-02-25T02:22:33.000Z","msg":"<img src=\"https://hk.ulifestyle.com.hk/cms/images/topic/1024/201803/20180309195230_24_mi001.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.ulifestyle.com.hk%2Fcms%2Fimages%2Ftopic%2F1024%2F201803%2F20180309195230_24_mi001.JPG&h=c550370a&s={SIZE}\" />"},"citedBy":0,"replyTime":"2021-02-25T02:56:15.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f47e09fc8f925ef785487fda294a3b535154c9cb","tid":2422024,"uid":167658,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2021-02-25T03:29:26.000Z","msg":"<img src=\"https://na.cx/i/wWJLyEr.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwWJLyEr.gif&h=b11db772&s={SIZE}\" />"},{"pid":"ebdcf30d11a577ac1b17f5173af2a9bdf9b54470","tid":2422024,"uid":20867,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2021-02-25T03:38:47.000Z","msg":"<img src=\"http://i1.kknews.cc/SIG=2ruke8g/19s700006ps2nrronrns.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi1.kknews.cc%2FSIG%3D2ruke8g%2F19s700006ps2nrronrns.jpg&h=3174c81d&s={SIZE}\" /><br />\n<br />\n<img src=\"http://i2.kknews.cc/SIG=3da3cui/19s40001qr8n517s2093.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi2.kknews.cc%2FSIG%3D3da3cui%2F19s40001qr8n517s2093.jpg&h=539fe32f&s={SIZE}\" /><br />\n<br />\n<img src=\"https://media.rojaklah.com/wp-content/uploads/2017/09/13110801/huanghaoran.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.rojaklah.com%2Fwp-content%2Fuploads%2F2017%2F09%2F13110801%2Fhuanghaoran.jpg&h=73f546c1&s={SIZE}\" /><br />\n<br />\n<pre><code data-type=\"\">1997年得到杜琪峰的賞識，出演《十萬火急》而進入娛樂圈。之後又拍了好幾部電影，《新紮師妹》就是其中一部，因為神似張國榮俊美的長相和少有的高貴氣質以及淡淡的憂鬱氣質，因此獲得了「小張國榮」之稱。</code></pre><br />\n<br />\n<pre><code data-type=\"\">可惜電影之路並沒有讓他大紅，之後黃浩然加入了亞視，出演《情陷夜中環》《美麗傳說》都讓人印象深刻。可惜之後亞視搖搖欲墜，更是不再拍攝電視劇。</code></pre><br />\n<br />\n<pre><code data-type=\"\">於是2007年黃浩然轉投TVB，並且順利簽約，經過兩年的配角生涯，2009年開始升等做男主，並且和徐子珊主演了交通安全題材的電視劇《情越雙白線》，因為口碑良好。2012年TVB又開拍了姐妹篇《情越海岸線》，2010黃浩然主演了兩部熱播台慶劇《公主嫁到》和《巾幗梟雄之義海豪情》，最終憑藉巾幗梟雄中的楊陽，獲得「TVB飛躍進步男藝員」。</code></pre><br />\n<br />\n<pre><code data-type=\"\">自此黃浩然成為亞視過檔TVB發展最好的一位小生。因為劇集口碑以及演技過關，TVB也開始對他力捧。劇集一部接一部，2014年拍攝重頭劇《張保仔》之時，黃浩然卻突然患上罕見的「貝塞特氏症」導致停工，原本的男主角也被換成洪永城。</code></pre><br />\n<br />\n原文網址：<a href=\"https://71a.xyz/eG6wld\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2F71a.xyz%2FeG6wld&d=L6ZqOc%2BI4Gry4yTyS7cXFZzZIytzq3Xhz5Kp58Ixet8%3D&h=08c6e632\" data-auto-link target=\"_blank\">https://71a.xyz/eG6wld</a>"},{"pid":"fd93f3b8200f84928364c086eae033cf3e671c7c","tid":2422024,"uid":24457,"like":2,"dislike":1,"score":1,"quote":{"pid":"ebdcf30d11a577ac1b17f5173af2a9bdf9b54470","tid":2422024,"uid":20867,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2021-02-25T03:38:47.000Z","msg":"<img src=\"http://i1.kknews.cc/SIG=2ruke8g/19s700006ps2nrronrns.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi1.kknews.cc%2FSIG%3D2ruke8g%2F19s700006ps2nrronrns.jpg&h=3174c81d&s={SIZE}\" /><br />\n<br />\n<img src=\"http://i2.kknews.cc/SIG=3da3cui/19s40001qr8n517s2093.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi2.kknews.cc%2FSIG%3D3da3cui%2F19s40001qr8n517s2093.jpg&h=539fe32f&s={SIZE}\" /><br />\n<br />\n<img src=\"https://media.rojaklah.com/wp-content/uploads/2017/09/13110801/huanghaoran.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.rojaklah.com%2Fwp-content%2Fuploads%2F2017%2F09%2F13110801%2Fhuanghaoran.jpg&h=73f546c1&s={SIZE}\" /><br />\n<br />\n<pre><code data-type=\"\">1997年得到杜琪峰的賞識，出演《十萬火急》而進入娛樂圈。之後又拍了好幾部電影，《新紮師妹》就是其中一部，因為神似張國榮俊美的長相和少有的高貴氣質以及淡淡的憂鬱氣質，因此獲得了「小張國榮」之稱。</code></pre><br />\n<br />\