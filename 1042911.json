bcbd4eab4112101b5fc1","tid":1042911,"uid":23271,"like":14,"dislike":3,"score":11,"quote":{"pid":"ea84bea6b8dee240ee22cf15bf5dcae2d85d53ad","tid":1042911,"uid":235880,"like":7,"dislike":1,"score":6,"quote":{"pid":"d8761ced514698f29f1002fa71c8e7138df76ad2","tid":1042911,"uid":10089,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-03-02T08:51:30.000Z","msg":"點解咁多負皮<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-02T08:54:30.000Z","msg":"我都唔知<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />可能大家覺得天水圍行出荃灣太廢"},"citedBy":1,"replyTime":"2019-03-02T09:48:13.000Z","msg":"連登仔係咁架啦<br />\n只識會用長度做標準<br />\n唔會諗行40km平路用你8個鐘<br />\n行10km山路一樣都可以用你8個鐘<br />\n<br />\n行嗰堆又係<br />\n一味最東去最西 最南去最北咁去吸引人睇<br />\n觀感上好似行得特別遠咁<br />\n但路最後又係得嗰幾條<br />\n次次都係煮同一味飯<br />\n悶唔悶啲?<br />\n環九龍一個圈夠過50km啦<br />\n又唔見有人做<br />\n<br />\n行石屎路嚟講<br />\n40-50km搵個正常後生仔點都捱到<br />\n只係用幾多個鐘嘅分別<br />\n長度根本只係同時間掛勾<br />\n而唔係同難度掛勾<br />\n以石屎路嚟講真係普通料<br />\n連地圖都唔需要識睇<br />\n同喺運動場行有咩分別?<br />\n但永遠啲live post都係放打卡相<br />\n嘩去過呀!!!去到邊呀!!!!!<br />\n想搵張靚相 搵啲特別野睇下都無<br />\n我倒不如睇人跑馬拉松 快啲完場唔好?<br />\n<br />\n當人人都做到嘅時候<br />\n我又真係唔明點解咁多人開post話挑戰自己<br />\n<br />\n(隔籬觀塘去天水圍個post畀我負評嗰啲<br />\n我屌晒你地老母呀<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />)"},{"pid":"96961a63b1b26eab5d375afda2384dc1472ac276","tid":1042911,"uid":67225,"like":2,"dislike":0,"score":2,"quote":{"pid":"1a02754687f8390ecb0cf490668d9b72b2a3e88d","tid":1042911,"uid":94047,"like":1,"dislike":5,"score":-4,"citedBy":2,"replyTime":"2019-03-02T06:22:58.000Z","msg":"咁撚近都上到熱門<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n基本都行到觀塘啦要"},"citedBy":0,"replyTime":"2019-03-02T10:52:59.000Z","msg":"等你出post"},{"pid":"8258175e65dbe9d772426b8d7efbf5e56b33b8e6","tid":1042911,"uid":235880,"like":0,"dislike":1,"score":-1,"quote":{"pid":"96bc34ff97c923914925bcbd4eab4112101b5fc1","tid":1042911,"uid":23271,"like":14,"dislike":3,"score":11,"quote":{"pid":"ea84bea6b8dee240ee2