lass=\"hkgmoji\" />"},{"pid":"cd78f67c950b127af7a6b136bb695706e1670390","tid":730261,"uid":160094,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-05T10:42:15.000Z","msg":"華人dna<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"e93912fd52eb6ef35cbd86d880f7f3a5abf61934","tid":730261,"uid":58998,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-07-05T10:45:48.000Z","msg":"佢係手炒果到衰失實陳述啫<br />\n機炒又唔會難飲過手炒，加色素又唔會對人體有額外害處<br />\n其實對我嚟講唔會覺得有乜大問題<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n福喜就真係衰好多"},{"pid":"38eee0a9aa3fb9bf83e6329252f83382df0fc94d","tid":730261,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-05T10:47:36.000Z","msg":"正常都知邊有咁好死"},{"pid":"6731d08bf4b0e478a143dce55471c56c626d007e","tid":730261,"uid":11973,"like":0,"dislike":0,"score":0,"quote":{"pid":"41f92fb0477b9b80fd764cacedeb028d52cbd851","tid":730261,"uid":121580,"like":0,"dislike":0,"score":0,"quote":{"pid":"7e3a0b3604c2b1fef537478b84460a7d88a99b5e","tid":730261,"uid":22675,"like":0,"dislike":0,"score":0,"quote":{"pid":"f2703342ac6894db31b2bd38904288bae69ee1e0","tid":730261,"uid":4574,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-05T09:26:43.000Z","msg":"福喜事件"},"citedBy":1,"replyTime":"2018-07-05T09:42:49.000Z","msg":"最後香港人真係有抵制"},"citedBy":1,"replyTime":"2018-07-05T09:45:48.000Z","msg":"但影響唔大,睇下家陣已經個個都唔記得哂<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-05T14:24:48.000Z","msg":"抵制?<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /> <br />\n香港人呢隻叫 &quot;戒口&quot; 唔係叫抵制<br />\n人哋日本仔嗰隻搞到人哋最後要摺131間分店<br />\n再要個話事人出嚟鞠躬道歉先至叫做 &quot;抵制&quot;"},{"pid":"fc0bf2bcd74ff1b24a2b732c9f94ac658af78596","tid":730261,"uid":172390,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-05T14:51:10.000Z","msg":"呃完你 就搞promotion引班傻仔係大熱天時排長龍買<br />\n班staff就開心啦 做到狗咁<img src=\"/assets/