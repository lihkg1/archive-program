F0WJNXpvw%3D&h=f2390037\" target=\"_blank\">https://line.me/R/ti/p/@snp0516q</a><br />\nInstagram : <a href=\"https://www.instagram.com/justin_yu_1/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fjustin_yu_1%2F&d=%2BnNreoHSAT5xh0CxqRKFY%2F%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=ad32e298\" target=\"_blank\">https://www.instagram.com/justin_yu_1/</a><br />\nTwitter : <a href=\"https://twitter.com/justin_yu_1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Fjustin_yu_1&d=%2BnNreoHSAT5xh0CxqRKFY%2F%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=6c150638\" target=\"_blank\">https://twitter.com/justin_yu_1</a><br />\n<img src=\"https://i.imag.cx/FR9gM.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FFR9gM.png&h=28783526&s={SIZE}\" /><br />\nDead by daylight呢隻GAME,係一隻4 VS 1既GAME,4個人類一邊維修發電機一邊避開個殺手,維修夠發電機開大門走佬;玩殺手既就係盡量殺D人,唔俾佢地走到佬<br />\n可惜,呢隻GAME,外國好多人玩,偏偏淨係香港冇人玩<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> 好多係身在外國既香港人,都同我講呢隻GAME外國係勁多人玩,普遍香港人個STEAM都設定係香港,所以香港人買左,馬上開GAME,幾乎係肯定冇場,因為香港SER根本冇人,已經真係有玩開GAME既人,都已經轉哂SER去其他國家玩,而依家最多人既SER而又唔會太LAG既地方,係轉去台灣泰國日本韓國呢D地方既SER玩<br />\n<img src=\"https://i.imag.cx/HdDRQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FHdDRQ.jpg&h=300ec0a8&s={SIZE}\" /><br />\n<a href=\"https://youtu.be/TKEUxPYvRfI?list=PLSow1H3Pe09MwgV9rjsjfYx4FiIKrNU4a\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FTKEUxPYvRfI%3Flist%3DPLSow1H3Pe09MwgV9rjsjfYx4FiIKrNU4a&d=%2BnNreoHSAT5xh0CxqRKFY%2F%2F4Bxi6eTjWtF%2F0WJNXpvw%3D&h=ee091be0\" target=\"_blank\">https://youtu.be/TKEUxPYvRfI?list=PLSow1H3Pe09MwgV9rjsjfYx4FiIKrNU4a</a><br />\n由於係香港開CAM開台而又玩呢隻GAME既人,係得我一個台,所以呢隻GAME官方果邊都俾左呢一件twitch台台主先有既SKIN我<br />\n<img src=\"https://i.imag.cx/hBFf8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FhBFf8.jpg&h=fe9aa4b7&s={SIZE}\" /><br />\n<img src=\"https://i.imag.cx/hBXlI.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FhBXlI.jpg&h=32290e7c&s={SIZE}\" /><br />\n<img src=\"https://i.imag.cx/vHoXA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FvHoXA.jpg&h=1fb87b30&s={SIZE}\" /><br />\n下面呢個係隨便台Official LINE群,有咩突發消息,開台通知,我都會係呢度公布<br />\n<img src=\"http://qr-official.line.me/L/aqio2VXZLo.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fqr-official.line.me%2FL%2Faqio2VXZLo.png&h=03fd5638&s={SIZE}\" />"},{"pid":"989871141d22dbed98c4e014ab354aff88ca8a48","tid":390154,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-07T00:55:15.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ec005733b6baffbda14ac833b6939eeac0a3c7a9","tid":390154,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-07T01:32:05.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"91d8aa9199ccdd1c3aaab0076a6dc0ad1b19b589","tid":390154,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-07T02:01:28.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b25a482f82de8a6db3cc20bd1df1e0d296185d71","tid":390154,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-07T02:09:16.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1c7f3f64ea5eafcb4bc96f899883bf197b4bdab1","tid":390154,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-07T02:16:38.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0fa5744791ef22f1e74d5e1ff2ef9f6dad4423af","tid":390154,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-07T02:33:32.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/a