e":0,"citedBy":0,"replyTime":"2021-03-05T12:00:52.000Z","msg":"晏啲cap圖<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"faad4c00529828a5fd22d16acfa25681ca495dae","tid":2434080,"uid":48796,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-05T12:50:23.000Z","msg":"最簡單講即係站立左樁、高樁、用掌打、少少腳, 埋身纏抱, 落地地鎖<br />\n唔知同詠春打會點呢<img src=\"/assets/faces/cow/power.gif\" class=\"hkgmoji\" /> 不過而家都唔太hit"}],"pinned":{"pid":"3576d43d80bb2548b98f4277fdb0c21a8687b554","tid":2434080,"uid":302696,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-05T16:31:01.000Z","msg":"<img src=\"https://na.cx/i/qXhqc6x.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqXhqc6x.jpg&h=78eb193c&s={SIZE}\" /><br />\n呢張唔get<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"}}