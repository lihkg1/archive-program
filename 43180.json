yfong91/S29TP12_zpsgoamwdqu.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi77.photobucket.com%2Falbums%2Fj64%2FTyfong91%2FS29TP12_zpsgoamwdqu.png&h=b1128bcf&s={SIZE}\" /><br />\n<img src=\"http://i77.photobucket.com/albums/j64/Tyfong91/S29TP17_zpsk6l2qsrp.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi77.photobucket.com%2Falbums%2Fj64%2FTyfong91%2FS29TP17_zpsk6l2qsrp.png&h=03590199&s={SIZE}\" /><br />\n<img src=\"http://i77.photobucket.com/albums/j64/Tyfong91/S29TP21_zpswznwy7ov.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi77.photobucket.com%2Falbums%2Fj64%2FTyfong91%2FS29TP21_zpswznwy7ov.png&h=e851d14d&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n就如百獸之王一樣<br />\n<br />\n究竟是什麼喚醒了沉睡的獅子？<br />\n<img src=\"http://i77.photobucket.com/albums/j64/Tyfong91/S26TP16_zpsircdscdj.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi77.photobucket.com%2Falbums%2Fj64%2FTyfong91%2FS26TP16_zpsircdscdj.png&h=ccedfc85&s={SIZE}\" /><br />\n<br />\n<br />\n<span style=\"color: teal;\"><span style=\"font-size: xx-large;\"><br />\n《人機合一》三十一話 - KING AND LIONHEART</span></span><br />\n<br />\n<br />\n<br />\n<br />\n與你細說獅子心。<br />\n<br />\n<br />\n<br />\n<ins>作者的話</ins> <br />\n初來乍到，睇睇效果先，漫畫隨後獻上<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <br />\n<br />\n<ins>引言</ins><br />\n<br />\n廿一世紀最偉大的發明 - 神念系統。 <br />\n<br />\n所謂「神」，即是用植入於身體內的超級電腦晶片去尋找最佳的神經脈衝傳遞方式，從而最有效率地活動。由此，人類的協調力、速度、力量等都有突破性的進步。 <br />\n<br />\n所謂「念」，即利用腦電波控制機械活動。 <br />\n<br />\n能夠將兩者充份發揮，並且相輔相乘，就能達到人機合一的境界 <br />\n<br />\n<br />\n<ins>FACEBOOK PAGE</ins> <br />\n<a href=\"https://www.facebook.com/pages/aooac&amp;#376;a&amp;#144;&amp;#710;a﹐/1462408737419954?fref=ts\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fpages%2Faooac%26%23376%3Ba%26%23144%3B%26%23710%3Ba%EF%B9%90%C2%80%2F1462408737419954%3Ffref%3Dts&d=sbZZacstX33JwCJXEIgXl0sIbL4fERhwM0ZRx9Zc9p0%3D&h=2c67af81\" target=\"_blank\">https://www.facebook.com/pages/aooac&amp;#376;a&amp;#144;&amp;#710;a﹐/1462408737419954?fref=ts</a><br />\n包含最新情報、第一至第二十九話，喜歡既巴絲就請比個LIKE<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />dw <br />\n<br />\n<ins>章節</ins><br />\n第一話至第十一話 ~ 捉迷藏篇<br />\n第十二話至第二十二話 ~ 飛行棋篇<br />\n第二十三話至第？話 ~ 最新篇[/quote]"},{"pid":"a87afa41bdaca0b7daa1b2d281a8ec4175b3a9fb","tid":43180,"uid":46717,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-17T14:20:37.000Z","msg":"比你fake左入來"},{"pid":"d23ded4a22365e96b57c11df36630b66ed9a8f2f","tid":43180,"uid":35668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-17T16:27:34.000Z","msg":"<span style=\"color: teal;\"><span style=\"font-size: xx-large;\"><br />\n《人機合一》三十一話 - KING AND LIONHEART</span></span><br />\n<br />\n<img src=\"http://i77.photobucket.com/albums/j64/Tyfong91/S31TP1_zpssgidzyqg.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi77.photobucket.com%2Falbums%2Fj64%2FTyfong91%2FS31TP1_zpssgidzyqg.png&h=12b20791&s={SIZE}\" /><br />\n<img src=\"http://i77.photobucket.com/albums/j64/Tyfong91/S31TP2_zpshdqqeg4r.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi77.photobucket.com%2Falbums%2Fj64%2FTyfong91%2FS31TP2_zpshdqqeg4r.png&h=8564413b&s={SIZE}\" /><br />\n<img src=\"http://i77.photobucket.com/albums/j64/Tyfong91/S31TP3_zpssx0sv5ev.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi77.photobucket.com%2Falbums%2Fj64%2FTyfong91%2FS31TP3_zpssx0sv5ev.png&h=d164974c&s={SIZE}\" /><br />\n<img src=\"http://i77.photobucket.com/albums/j64/Tyfong91/S31TP4_zpsqqpng5wf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi77.photobucket.com%2Falbums%2Fj64%2FTyfong91%2FS31TP4_zpsqqpng5wf.png&h=883f4260&s={SIZE}\" /><br />\n<img src=\"http://i77.photobucket.com/albums/j64/Tyfong91/S31TP5_zpsio4peg0m.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi77.photobucket.com%2Falbums%2Fj64%2FTyfong91%2FS31TP5_zpsio4peg0m.png&h=51931b