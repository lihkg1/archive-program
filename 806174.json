/04/202922_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F04%2F202922_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=5e0a4441&s={SIZE}\" /></blockquote><br />\n<br />\n好野緊要傳千里"},{"pid":"4dd21b24db2040f91c9c1fe81d93cbf0b7abce71","tid":806174,"uid":53349,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2018-09-06T06:15:51.000Z","msg":"&quot;港話&quot;係一個咩term? <br />\n係咪我太out<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"3cc77afae2c35764ddbe9532c360fa592895ebaa","tid":806174,"uid":2988,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-06T06:23:31.000Z","msg":"所有幫支那蝗講說話既都block哂"},{"pid":"96d133d8398195ad72a4212523420604c2e1d332","tid":806174,"uid":156781,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-06T06:25:11.000Z","msg":"支那人比人支那人撚落黎玩個d傳銷，比幾萬銀，食就食幾十銀。<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"19ad216c7595643ac13e0f28f3e69d816e66236e","tid":806174,"uid":33645,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-06T06:25:34.000Z","msg":"著到咁撚高貴咪又係食譚仔. 八婆"},{"pid":"11aa04f6e2f22885e5210291dd5beb2e889740a2","tid":806174,"uid":129350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-06T06:27:45.000Z","msg":"淨係識偷偷地影人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8b1c1a99783baeecb28d1afecb36df3032a31bc6","tid":806174,"uid":207328,"like":2,"dislike":0,"score":2,"quote":{"pid":"0389315b91e9cba31515b9137c623bc42c404f76","tid":806174,"uid":82532,"like":343,"dislike":3,"score":340,"citedBy":1,"replyTime":"2018-09-04T12:38:07.000Z","msg":"睇樣都知咩格<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-06T06:28:06.000Z","msg":"相由心生"},{"pid":"72c905e26c634eb97c510f32d4643dd752b64382","