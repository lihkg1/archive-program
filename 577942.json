like":0,"score":0,"quote":{"pid":"815a4369db1a16a2370981d4d77bc6b67cdd51f6","tid":577942,"uid":15724,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-03-02T16:28:45.000Z","msg":"托利斯呢 全季只輸兩場"},"citedBy":1,"replyTime":"2018-03-02T16:42:17.000Z","msg":"只輸兩場都贏唔到英超咁慘？<br />\n認真問<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-02T17:17:58.000Z","msg":"和波多 比獌贏"},"citedBy":0,"replyTime":"2018-03-02T17:18:41.000Z","msg":"不過果年已經係同so9果年一樣係最近嫁啦"},{"pid":"c14dff250c739d70ada50de3dd5d83f622e449b8","tid":577942,"uid":15724,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-03-02T17:28:02.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />  <br />\n不過沙拿 so9 托利斯都可以爭 古就真係未夠班爭 <br />\n<br />\n沙拿左腳記錄保持者 翼鋒但入波多 不過帶起隊波未見到有得爭冠軍 睇佢做唔做到英超神射手今年 依家牌面真係最差<br />\n<br />\nSo9唔駛講 拎左金靴 英超年度最佳 果年carry一堆垃圾差啲拎冠 講牌面贏晒<br />\n<br />\n托利斯 當年有份carry到猁全季英超只輸2場 歐聯對皇炒4球 但當年有黃金中場 沙謝馬 講功勞冇so9咁大 不過佢果年都入左24球 成為首季踢英超入波既多既人 只係輸比果年30幾球既牙朗  不過都不足以贏so9 但托利斯有樣野贏晒 就係佢好撚<span style=\"font-size: xx-large;\"><span style=\"color: red;\">靚仔</span></span>  當年成班港女唔睇波都會印torres 講商業價值 torres幫猁吸左唔少女<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4c57860489f01638f1338c7f8b4fb24bde34dd81","tid":577942,"uid":15724,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-02T17:28:41.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2c3f2d724aca8e17464774af762f1152d03e7f7a","tid":577942,"uid":15724,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-02T17:29:22.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a548fc73b87b95d84f503676d2ff43ddcf3f6ae9","tid":577942,"uid":124667,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e60236d44c56566130676674004b4b735af3d2c6","tid":577942,"uid":67225,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-03-02T10:16:52.000Z","msg":"屌唔好成日單單打打啦"},"citedBy":0,"replyTime":"