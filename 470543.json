.net/upload/2017/11/16/202445_3c0e5e7c0e3e5d770be2bfbbca14df5b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F16%2F202445_3c0e5e7c0e3e5d770be2bfbbca14df5b.jpg&h=0bc9a66f&s={SIZE}\" />"},{"pid":"c57889021dce660fb5f88e105d4a7d548a777717","tid":470543,"uid":20362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-16T12:32:38.000Z","msg":"世界級分鏡"},{"pid":"b6c78529cd60b746060534182d1a519d58ff87cf","tid":470543,"uid":11285,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-16T12:34:32.000Z","msg":"爛尾偶像A"},{"pid":"5fd92c24844ef146cff28ece216cbca158895051","tid":470543,"uid":96308,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-11-16T12:37:27.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/11/16/203622_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F16%2F203622_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=5cc49f51&s={SIZE}\" /><br />\n有陣時睇多幾次會理解唔同嘅野，一開始會睇表面覺得係講緊棒球。慢慢睇多兩次會覺得佢語帶相關，放棄埋爭青葉。"},{"pid":"140f5408a3752ce16bdea5882e0981c67e6637eb","tid":470543,"uid":113250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-16T12:39:29.000Z","msg":"動畫版睇完之後<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"049dc574ead406d739b70d6a37ddbc0d6c2da8cf","tid":470543,"uid":34395,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-16T13:11:54.000Z","msg":"對白好正，句句都有意思咁"},{"pid":"8fc9b55d59d79f8d8f06178326c6e4613c0f936c","tid":470543,"uid":16511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-16T14:16:14.000Z","msg":"CROSS GAME ,  KATSU! , H2 , TOUCH , ROUGH 都好正 , <br />\n<br />\n仲有D 舊野SLOW STEP 同超能力美空都幾正"},{"pid":"3cfd378af369304222c724cc50b285ee63c943fc","tid":470543,"uid":2818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-16T16:53:09.000Z","msg":"H2<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"04206fd2f18666ec4f02f1f3b932702ac432b86b","tid":470543,"uid":136216,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-16T16:55:20.000Z","msg":"Touch and H2 !"},{"pid":"25ed121f35b942652afc1abc2f64ec728a162cc5","tid":470543,"uid":129866,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-16T17:24:44.000Z","msg":"印象最深刻係H2，不過雖然知個結局係想講青春要有遺憾，但我就接受唔到<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> ，所以我咁多年都一直FF比呂同雅玲之後會一齊。<br />\n<br />\nRough我就覺得係安達充最清新嘅作品，大和圭介係安達充咁多男主入面最唔優柔寡斷嘅一個。<br />\n<br />\nTouch我覺得開頭勁好睇，後面就中規中矩。原田同達也係和也最後一場比賽嘅時候個段對白睇到起哂雞皮<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <br />\n<br />\nKatsu!同Q&amp;A就比較sad，一套係寫寫下佢阿哥過咗身；另一套就係佢為咗緬懷阿哥而寫。<br />\n<br />\nShort Program短篇入面我覺得最正係&ldquo;近況&rdquo;同埋&ldquo;逝去的春天&ldquo;兩篇"},{"pid":"ba7e5eea9d4080e7c349071c3cc4c18b749549c2","tid":470543,"uid":136883,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-16T17:31:43.000Z","msg":"東 : 其實你地失去既都係一樣 一個好鍾意 初戀既女仔<br />\n分別只係兩情相悅同單戀"},{"pid":"2808a30152ba83be672b813b27ec397f7fa7b53e","tid":470543,"uid":3762,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-16T22:42:36.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"86a3a5568421bf9d26084ac5f336f22c5b6315a7","tid":470543,"uid":3762,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-16T23:24:13.000Z","msg":"<blockquote>印象最深刻係H2，不過雖然知個結局係想講青春要有遺憾，但我就接受唔到<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> ，所以我咁多年都一直FF比呂同雅玲之後會一齊。<br />\n<br />\nRough我就覺得係安達充最清新嘅作品，大和圭介係安達充咁多男主入面最唔優柔寡斷嘅一個。<br />\n<br />\nTouch我覺得開頭勁好睇，後面就中規中矩。原田同達也係和也最後一場比賽嘅時候個段對白睇到起哂雞皮<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <br />\n<br />\nKatsu!同Q&amp;A就比較sad，一套係寫寫下佢阿哥過咗身；另一套就係佢為咗緬懷阿哥而寫。<br />\n<br />\nShort Program短篇入面我覺得最正係&ldquo;近況&rdquo;同埋&ldquo;逝去的春天&ldquo;兩篇</blockquote><br />\n近況真係好正<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <br />\n好認同rough 係最清新，個埋尾幾神<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> 係炒車有d 老土<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n好中意katsu!, 可惜個尾爛爛地<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"d3c5cc4c4f34ba5e8bd23ac6f9e927c5e73a896f","tid":470543,"uid":4955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-23T06:48:30.000Z","msg":"<blockquote><blockquote>印象最深刻係H2，不過雖然知個結局係想講青春要有遺憾，但我就接受唔到<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> ，所以我咁多年都一直FF比呂同雅玲之後會一齊。<br />\n<br />\nRough我就覺得係安達充最清新嘅作品，大和圭介係安達充咁多男主入面最唔優柔寡斷嘅一個。<br />\n<br />\nTouch我覺得開頭勁好睇，後面就中規中矩。原田同達也係和也最後一場比賽嘅時候個段對白睇到起哂雞皮<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <br />\n<br />\nKatsu!同Q&amp;A就比較sad，一套係寫寫下佢阿哥過咗身；另一套就係佢為咗緬懷阿哥而寫。<br />\n<br />\nShort Program短篇入面我覺得最正係&ldquo;近況&rdquo;同埋&ldquo;逝去的春天&ldquo;兩篇</blockquote><br />\n近況真係好正<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <br />\n好認同rough 係最清新，個埋尾幾神<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> 係炒車有d 老土<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n好中意katsu!, 可惜個尾爛爛地<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /></blockquote><br />\n岩睇完rough 青春就喺人生既rough design個段點得好到位<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> <br />\n個結尾又喺睇到人意猶未盡 一貫風格<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"fd469488e5573fd0028f445941d4991c064195f7","tid":470543,"uid":64689,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-23T07:12:32.000Z","msg":"孝太郎: 自從和也死後，樓主就壟斷了幸福<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"b6eb481080a6e0009ab6f36891684fcd4ddaa2e4","tid":470543,"uid":4575,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-23T07:17:48.000Z","msg":"Touch 最正，而且決賽既設計都係咁多套最緊張，其他作品最後決賽冇咁緊張"},{"pid":"a5580a72baeeed6179121fd4f370c0fd5a2f2942","tid":470543,"uid":96308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-24T18:15:52.000Z","msg":"<blockquote>Touch 最正，而且決賽既設計都係咁多套最緊張，其他作品最後決賽冇咁緊張</blockquote><br />\n最後果球三振熱血度爆燈<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <br />\n雖然h2最後都係類似嘅巔峰對決，不過反而冇咁熱血。"},{"pid":"287d72101f932bf48fa6d555e9e8e1e8cd5d3804","tid":470543,"uid":56810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-24T18:28:59.000Z","msg":"又愛又恨,每本都鍾意,但每本都好短"},{"pid":"90c45a2764e3ae7657280254d1c08c8b5d34e926","tid":470543,"uid":48152,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-24T18:30:24.000Z","msg":"好鐘意睇 安達充d漫畫睇完會有種意猶未盡既失落感<br />\n最鐘意touch H2 cross game呢三套"},{"pid":"acdf902b74d781cf02a627bbfe7af52362c5790c","tid":470543,"uid":67237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-24T18:36:03.000Z","msg":"<blockquote>又愛又恨,每本都鍾意,但每本都好短</blockquote><br />\n唔算短啦?<br />\n可能我睇CROSS GAME先追舊果D, 我覺得17本已經好多, 減左水輝呢個角色又可以少幾話.."},{"pid":"a207a8209c50271e38954652996891cc49ee26a3","tid":470543,"uid":96308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-24T18:37:02.000Z","msg":"<blockquote>好鐘意睇 安達充d漫畫睇完會有種意猶未盡既失落感<br />\n最鐘意touch H2 cross game呢三套</blockquote><br />\n每一本都唔想佢完<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\