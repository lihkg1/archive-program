{"tid":1833242,"cid":5,"subCid":0,"title":"呢位外國記者幫香港文宣出盡奶力 一齊支持入吓","createTime":"2020-01-21T18:18:56.000Z","updateTime":"2020-01-21T18:28:39.000Z","uid":122044,"like":16,"dislike":0,"uniUserReply":7,"replies":[{"pid":"4731a41031b177e19e960e59f27d00ebe3800075","tid":1833242,"uid":122044,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-21T18:18:56.000Z","msg":"<a href=\"https://youtu.be/4wu_fZOAc9w\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F4wu_fZOAc9w&d=fvWYig%2FFXUG8IHhaG2JvmAUT8Qe%2F7ZKEe33%2FbaB1Hos%3D&h=2cf1bb94\" target=\"_blank\">https://youtu.be/4wu_fZOAc9w</a><br />\n<br />\n<br />\n我諗好多手足都睇過佢係澳洲啲採訪片段 <br />\n撚到啲支那人駁都駁唔到<br />\n佢8月果時仲特登黎香港報導真實情況帶返去外國<br />\n小弟金就課唔到啦<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n上黎連登宣傳吓一齊支持返佢 <img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"fb9fcd5ccdce3735fdcdbea59f52f38a90a80563","tid":1833242,"uid":122044,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-21T18:19:03.000Z","msg":"推"},{"pid":"9f5a215713dcf564b37b4d63966549ae570bc94f","tid":1833242,"uid":122044,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-21T18:19:13.000Z","msg":"推"},{"pid":"e1b29f011d64b712b6cabfc0c99fa5da0c25683a","tid":1833242,"uid":90743,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-21T18:19:31.000Z","msg":"推"},{"pid":"e221c4b67e2894049bd103ce8d070a0d995527be","tid":1833242,"uid":122044,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-21T18:19:42.000Z","msg":"推"},{"pid":"e1cc49c8e2533de6707c7208f3c364728fda780d","tid":1833242,"uid":122044,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-21T18:19:53.000Z","msg":"推"},{"pid":"19d8055400ff625f8e392ec612965639ddb6e35a","tid":1833242,"uid":122044,"like":0,"dislike":0,"score":0,"quote":{"pid":"e1b29f011d64b712b6cabfc0c99fa5da0c25683a","tid":1833242,"uid":90743,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-21T18:19:31.000Z","msg":"推"