al/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-27T02:09:23.000Z","msg":"屌你老母閪香港納稅人交稅支助大學教大陸狗<br />\n因為香港學生廢 <img src=\"/assets/faces/mf/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-27T02:24:12.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-09-27T02:41:24.000Z","msg":"垃圾得過你？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n老老實實大家都有份交税養大學<br />\n<br />\n然後人地14000學生，成2000個外地人<br />\n其中唔知幾多人會留港搵食，唔知幾多人遲下拎身份證<br />\n同香港人爭樓爭工作爭資源<br />\n<br />\n合唔合理你話喇<br />\n覺得笑人讀唔成書重要過大是大非，我都吹你唔漲既"},{"pid":"b8c956a3b25ccd0a5a0aa01e6ad7c5f0bdff9053","tid":838112,"uid":34525,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-27T02:42:31.000Z","msg":"吾城<img src=\"/assets/faces/mf/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c73834ae60df226f3269cc55411c6783075ee3c8","tid":838112,"uid":201284,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-09-27T02:45:40.000Z","msg":"含大呢<img src=\"/assets/faces/mf/cry.gif\" class=\"hkgmoji\" />"},{"pid":"9002cf346c220f7661aa174fbbc25e0f5c005e09","tid":838112,"uid":45660,"like":8,"dislike":1,"score":7,"quote":{"pid":"edd1b25718e2e7a741154f538d605506516b6682","tid":838112,"uid":175598,"like":24,"dislike":5,"score":19,"quote":{"pid":"93482792c08f4620c00f69b634bcb7179daa1b43","tid":838112,"uid":29270,"like":7,"dislike":6,"score":1,"citedBy":1,"replyTime":"2018-09-27T01:37:24.000Z","msg":"當一堆人想讀大學讀唔到既時候<br />\n<br />\n收咁撚多大陸狗<img src=\"/assets/faces/mf/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-09-27T01:38:47.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-09-27T02:57:57.000Z","msg":"呢個年代連8大都入唔到真係垃圾都不如"},{"pid":"544136306b355a58db661f9ba12ccc0b47cf3e09","tid":838112,"uid":175598,"like":6,"dislike":4,"score":2,"citedBy":1,"replyTime":"2018-