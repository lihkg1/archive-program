":928711,"uid":12696,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-05T05:14:56.000Z","msg":"都唔知咁搶口JM9"},{"pid":"725c40bea60714c57b77227a45053cd52274c11b","tid":928711,"uid":26467,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a40a512148987958ba432a8774ef840abd138db","tid":928711,"uid":10503,"like":26,"dislike":0,"score":26,"citedBy":2,"replyTime":"2018-12-05T05:13:47.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/12/05/131329_e05ef819b5093c5cd1f06338416612d5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F12%2F05%2F131329_e05ef819b5093c5cd1f06338416612d5.png&h=3550b8e0&s={SIZE}\" /><img src=\"https://na.cx/i/wxML3zc.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwxML3zc.png&h=8dc5e0b4&s={SIZE}\" /><img src=\"https://na.cx/i/O5C3Qed.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FO5C3Qed.png&h=c7ae6e3c&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-12-05T05:17:55.000Z","msg":"唔係自拍唔計<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"c32b5152f3247d5b22904f20552c81ccd0886c47","tid":928711,"uid":19527,"like":1,"dislike":0,"score":1,"quote":{"pid":"725c40bea60714c57b77227a45053cd52274c11b","tid":928711,"uid":26467,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a40a512148987958ba432a8774ef840abd138db","tid":928711,"uid":10503,"like":26,"dislike":0,"score":26,"citedBy":2,"replyTime":"2018-12-05T05:13:47.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/12/05/131329_e05ef819b5093c5cd1f06338416612d5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F12%2F05%2F131329_e05ef819b5093c5cd1f06338416612d5.png&h=3550b8e0&s={SIZE}\" /><img src=\"https://na.cx/i/wxML3zc.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwxML3zc.png&h=8dc5e0b4&s={SIZE}\" /><img src=\"https://na.cx/i/O5C3Qed.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FO5C3Qed.png&h=c7ae6e3c&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-12-05T05:17:55.000Z","msg":"唔係自拍唔計<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-05T05:20:11.000Z","msg":"下年捧盃果陣影架"},{"pid":"d3b2eba622097d112792febc0df8ff6aca6d3763","tid":928711,"uid":1009,"like":47,"dislike":0,"score":47,"citedBy":3,"replyTime":"2018-12-05T05:20:33.000Z","msg":"連拖肥教頭都大量過你，真係閪球會配閪教練<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n利物浦領隊高普或因在對愛華頓一役絕殺後衝入場慶祝被罰款，但拖肥領隊馬高施華就認為高普沒有做錯。<br />\n<br />\n「當時作為領隊都不能去想會否罰錢，那時是慶祝的時候。我知過去兩日大家都談及此事，但我認為沒大不了。」<br />\n<br />\n「如果禁止這樣的球隊及球迷慶祝，禁止除衫慶祝，禁止一切可以禁止的東西又如何，慶祝是很重要，罰款算不了甚麼。」<br />\n<br />\n「我看不到高普做甚麼，就如我賽後說，這是個開心的時刻，只是對於我不是。」<br />\n<br />\n「現在我知道當時發生甚麼事，對我來說高普不用解釋，我也不能告訴你如果換轉是我會怎樣。這是一場特別的打吡戰，當然不會預期會有這樣的入球出現。」"},{"pid":"f0d8046d0f80da9099b236c7c7c3d56b38f2e45c","tid":928711,"uid":67252,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-12-05T05:20:43.000Z","msg":"咁熱狗一世都唔使po相<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"08f8e7c57f527cd2eeeb0e6f98a96bd473618a7f","tid":928711,"uid":34970,"like":4,"dislike":0,"score":4,"quote":{"pid":"0f644970c16a3c8414cef4684dd5e773bb19abd2","tid":928711,"uid":19552,"like":85,"dislike":0,"score":85,"citedBy":4,"replyTime":"2018-12-05T05:09:36.000Z","msg":"<img src=\"https://pbs.twimg.com/media/DSEhuTLX4AE2K9I.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fpbs.twimg.com%2Fmedia%2FDSEhuTLX4AE2K9I.jpg&h=eacdcd8f&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-12-05T05:23:36.000Z","msg":"唔係有傑志盃咩"},{"pid":"29637889aec1df0195d9c486b689081f1aecda0a","tid":928711,"uid":6070,"like":0,"dislike":0,"score":0,"quote":{"pid":"d3b2eba622097d112792febc0df8ff6aca6d3763","tid":928711,"uid":1009,"like":47,"dislike":0,"score":47,"citedBy":3,"replyTime":"2018-12-05T05:20:33.000Z","msg":"連拖肥教頭都大量過你，真係閪球會配閪教練<img src=\"/assets/fa