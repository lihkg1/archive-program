cx%2Fi%2FaqhXJYA.jpg&h=7d73fb26&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-08-21T23:56:52.000Z","msg":"美國國歌當然要照唱🇺🇸🇺🇸🇺🇸"},{"pid":"f7aaabcfefe82679e6b5190f8506536f5d3389b6","tid":1494893,"uid":15224,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T23:58:59.000Z","msg":"舉美帝&amp;黑白風車旗就夠"},{"pid":"2a5b3bc07d0bbc2f6342ad08a3c80e516f0e06e0","tid":1494893,"uid":273256,"like":5,"dislike":1,"score":4,"quote":{"pid":"f95425dfdbdf52466c82c2586024da31442c72a2","tid":1494893,"uid":42884,"like":8,"dislike":5,"score":3,"quote":{"pid":"66e7b30799e6927afa1f88bcb609a8aec53f4f8a","tid":1494893,"uid":273256,"like":34,"dislike":2,"score":32,"citedBy":1,"replyTime":"2019-08-21T23:43:16.000Z","msg":"你地究竟知唔知呢支旗代表嘅國民黨係親中集團，呢支旗對好多台灣人黎講係當年白色恐怖同威權嘅歷史，無一個台灣年輕人會肯拎呢支旗出黎<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-21T23:51:02.000Z","msg":"呢個緊係知啦<br />\n枝旗代表左台灣228事件，四十幾年戒嚴白色恐怖嘅歷史<br />\n<br />\n但係台灣人爭取到咁多年，依家嘅中華民國已經唔再再當年中華民國，反而係代表華人區唯一有民主自由嘅國家<br />\n蔡英文都肯稱呼自己做中華民國總統<br />\n<img src=\"https://na.cx/i/yxT76c5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyxT76c5.png&h=7fef72c1&s={SIZE}\" /><br />\n<br />\n<br />\n<a href=\"https://youtu.be/aP69Ss9hf6c\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FaP69Ss9hf6c&d=qWTZpUodHfCf2bB0mbfn060EM2ZTCgB2Df5M2YAuo3Y%3D&h=9b4586bf\" target=\"_blank\">https://youtu.be/aP69Ss9hf6c</a>"},"citedBy":1,"replyTime":"2019-08-22T00:12:38.000Z","msg":"無錯名義上係叫中華民國，但台灣年輕人會唔會叫自己中華民國人呀？會唔會愛中華民國到拎支旗出黎呀？台灣就台灣啦，支旗代表嘅白色恐怖唔會因為民主自由而消失ga，因為呢樣嘢已經係台灣中年人仲未平反嘅惡夢，而且台灣係咪真係民主自由咁簡單呢？其實係好複雜好難講，現時係睇國民黨會唔會執政，但台灣都有好多國民黨員同台豬，睇上年九合一選舉就知，國民黨大勝，大家都好驚呢班智障會推返國民黨上去。<br />\n<br />\n利申: 前台灣留學生"},{"pid":"caf6264ab0de736b10f04562e11fefab9b2c4e0c","tid":1494893,"uid":229886,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-22T00:33:54.000Z","msg":"英美旗啦屌"},{"pid":"ecc172f9f861a6be6ef8bed58879dc8df7b4f8df","tid":1494893,"uid":191815,"like":0,"dislike":0,"score":0,"