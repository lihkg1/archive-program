e851444","tid":1851102,"uid":175194,"like":0,"dislike":0,"score":0,"quote":{"pid":"7f754d6ee94e8d0bee69a33c6524122a4abda630","tid":1851102,"uid":326037,"like":0,"dislike":0,"score":0,"quote":{"pid":"5a4af5eee8563216e8ee8260032b9e50d40ddae6","tid":1851102,"uid":175194,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-30T01:48:37.000Z","msg":"無哂口罩 但仲要番工 點算"},"citedBy":1,"replyTime":"2020-01-30T11:32:16.000Z","msg":"將用過的口罩係干燥的地方放7日，再帶出街?"},"citedBy":1,"replyTime":"2020-01-30T11:34:30.000Z","msg":"真定假？"},{"pid":"0d2ac569ca1d30a492ac3ad96367cca27aeb2390","tid":1851102,"uid":108236,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-30T11:36:30.000Z","msg":"帶住條女個奶罩 頂住先<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},{"pid":"0d6f4444b394dd1521fa535b41e388b6c0822ba1","tid":1851102,"uid":326037,"like":0,"dislike":0,"score":0,"quote":{"pid":"b31a812f462a33964906f2d602e685a2ce851444","tid":1851102,"uid":175194,"like":0,"dislike":0,"score":0,"quote":{"pid":"7f754d6ee94e8d0bee69a33c6524122a4abda630","tid":1851102,"uid":326037,"like":0,"dislike":0,"score":0,"quote":{"pid":"5a4af5eee8563216e8ee8260032b9e50d40ddae6","tid":1851102,"uid":175194,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-30T01:48:37.000Z","msg":"無哂口罩 但仲要番工 點算"},"citedBy":1,"replyTime":"2020-01-30T11:32:16.000Z","msg":"將用過的口罩係干燥的地方放7日，再帶出街?"},"citedBy":1,"replyTime":"2020-01-30T11:34:30.000Z","msg":"真定假？"},"citedBy":0,"replyTime":"2020-01-30T11:39:01.000Z","msg":"9up<br />\n<br />\n其實帶口罩防唔到，最重要係唔好出街<br />\n<br />\n(黃色經濟戰)其實開黃店製造口罩等人類保護產品可永續民運<br />\n<a href=\"https://lihkg.com/thread/1847247/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1847247/page/1</a><br />\n<br />\n(留家罷工)唔出街先係抗武肺重點X唔係買口罩X<br />\n<a href=\"https://lihkg.com/thread/1851168/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1851168/page/1</a><br />\n<img src=\"https://na.cx/i/0dRAyHA.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0dRAyHA.png&h=00188738&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/qLbdknA.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqLbdknA.png&h=0481b64a&s={SIZE}\" />"},{"pid":"1632008cdb6e1f2aa953d5f4c4dc8205231a0c60","tid":1851102,"uid":240637,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T11:42:34.000Z","msg":"同醫護、救護員一齊罷工<img src=\"/assets/faces/lny/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"941648a3462f3313d4983c673573b8c73da9602d","tid":1851102,"uid":82815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T11:45:23.000Z","msg":"我都打算冇口罩就請no pay leave<br />\n命就得一條 你自己諗"},{"pid":"80a73cb41b984212780b64c6e5af9defe0fd9a8b","tid":1851102,"uid":293838,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T12:07:51.000Z","msg":"罷工"},{"pid":"25679ad29b667f7267458bae85fb71134294f3ec","tid":1851102,"uid":160622,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-01-30T12:16:05.000Z","msg":"必須嚴正聲明，工作場所內提供口罩係僱主責任，唔係由僱員自備。<br />\n<br />\n根據《職業安全及健康條例》，僱主有責任提供安全工作環境。職業安全健康局出版嘅刊物亦提到，僱主必須備有足夠口罩供僱員使用。<br />\n參考<a href=\"http://www.oshc.org.hk/oshc_data/files/HotTopic/Workplace\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.oshc.org.hk%2Foshc_data%2Ffiles%2FHotTopic%2FWorkplace&d=Ey%2FAc8I3uyYuTLy5d8l3rBfhc2i76iEVsdTpjF8%2BTp8%3D&h=d01c5bda\" data-auto-link target=\"_blank\">http://www.oshc.org.hk/oshc_data/files/HotTopic/Workplace</a> Influ leaflet 09 New.pdf<br />\n<br />\n如果僱主要求你喺某個場所內工作，例如office，而不提供足夠口罩，佢有可能已經犯法。<br />\n<br />\n咁嘅情況，你可以向勞工處舉報。下面係職安健投訴表格<br />\n<a href=\"https://eform.one.gov.hk/form/ld0001/tc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Feform.one.gov.hk%2Fform%2Fld0001%2Ftc&d=Ey%2FAc8I3uyYuTLy5d8l3rBfhc2i76iEVsdTpjF8%2BTp8%3D&h=69cf5257\" data-auto-link target=\"_blank\">https://eform.one.gov.hk/form/ld0001/tc</a>"},{"pid"