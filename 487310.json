wqHexo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FqZEbjwqHexo&d=NztypxuZbm0QUhDvt%2FI62xv1o3X72Fc8dbph17rWX2c%3D&h=d57c9169\" target=\"_blank\">https://youtu.be/qZEbjwqHexo</a><br />\n17:13 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n如果依家公務員咁樣對市民會點<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n90年代之前啲公務員個個都係咁架啦<br />\n打後九鐵已經改革咗好多啦，個個講到臨合併仲係90年代咁款<br />\n九鐵啲職員起碼友善過依家啲閪面廢鐵職員</blockquote><br />\n改革成功就唔會兵變啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n基本上係田北辰改革失敗加速兩鐵合併"},{"pid":"3faa8df57cef0cc6808050ecee6a2a9369cf6c52","tid":487310,"uid":41818,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-12-03T13:20:45.000Z","msg":"當年地鐵又真係管理得好過kcr好多"},{"pid":"577cfe2641fd4a483d7cbd0974738b282f635d60","tid":487310,"uid":27458,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-03T13:21:32.000Z","msg":"留名"},{"pid":"3bd47d238f45914af5c371594cdcdd3cf320e6b8","tid":487310,"uid":550,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-12-03T14:55:07.000Z","msg":"<blockquote>當年地鐵又真係管理得好過kcr好多</blockquote><br />\n個陣東鐵列車車底有裂紋要用人手駕駛<br />\n西鐵又火燭又成日壞<br />\n嚇死唔少人"},{"pid":"f58925ef539f3aa0aaf0ffc4440ee128dca39ec4","tid":487310,"uid":47674,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2017-12-03T16:39:16.000Z","msg":"<blockquote><blockquote>當年地鐵又真係管理得好過kcr好多</blockquote><br />\n個陣東鐵列車車底有裂紋要用人手駕駛<br />\n西鐵又火燭又成日壞<br />\n嚇死唔少人</blockquote><br />\n東鐵始終係九廣鐵路通勤化，車站要原地擴大動線唔夠完善，鐵路沿線未必處處整到隔音搞到要慢駛，黃頭又冇預計chur到咁盡，總之問題多多<br />\n西鐵就係規劃問題，要市鎮邊緣設站，搞到初期客量低下，議員質疑係大白象，仲有補貼西門子單嘢"},{"pid":"952c9180a71f14a27384c8c1cc8cf4708c1ae24b","tid":487310,"uid":42629,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-12-03T18:02:35.000Z","msg":"<blockquote><blockquote>當年地鐵又真係管理得好過kcr好多</blockquote><br />\n個陣東鐵列車車底有裂紋要用人手駕駛<br />\n西鐵又火燭又成日壞<br />\n嚇死唔少人</blockquote><br />\n講到而家好好咁<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 西鐵係少左壞<br />\n但而家到觀塘線成日壞<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"467126c4a63e95b54a04bf4db70e7f93cd4f626f","tid":487310,"uid":15984,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2017-12-03T18:04:39.000Z","msg":"<blockquote>10年前既廣告入面油雞飯先18蚊<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n貴到咁都好吹奏<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n1973年一碟油雞飯$4.9"},{"pid":"7c74eef540ea9544fb865955255492401b6ffcfb","tid":487310,"uid":31219,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-12-03T18:07:03.000Z","msg":"<blockquote><blockquote>10年前既廣告入面油雞飯先18蚊<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n貴到咁都好吹奏<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n1973年一碟油雞飯$4.9</blockquote><br />\ne加都有機會搵到18蚊既"},{"pid":"f220e27df4ca579805193f6b74005d8de4f399b2","tid":487310,"uid":28765,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-03T18:11:12.000Z","msg":"原來得十年到 以為好耐歷史<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"f2bb44ecb775ba0733edf3a6253a16788e48c068","tid":487310,"uid":42629,"like":9,"dislike":1,"score":8,"citedBy":0,"replyTime":"2017-12-03T18:31:55.000Z","msg":"<blockquote>當年地鐵又真係管理得好過kcr好多</blockquote><br />\n門面睇落係地鐵好，但你問實際住喺前九鐵沿線特別係西鐵嘅人, 一定大部分都覺得合併前好D。<br />\n-寬敞嘅西鐵站同豆腐潤咁細嘅地鐵站比較已經係笑話, 屋企咁細都唔夠, D地鐵站(就算係新起)都係咁細。新起嘅地鐵站裝修十年不變，毫無美感。<br />\n-合併後不斷喺西鐵站加鋪頭，將通道收窄，令我地再要做沙甸魚。<br />\n-每個站都有入閘機拆走，部份車站闊閘機本身每方向2部變左雙向使用，影響人流<br />\n-多個車站關閉部份客務中心，本身唔同出口可以喺就近位置可以搵倒客務中心，變到要行好遠，仲有閘內閘共用一個，大部份時間得一個職員，咁岩多人果陣要等好耐。大規模<br />\n-大規模縮減車站人手，而家隨左繁忙時間(波板糖人又係廢嘅)，邊會喺月台/大堂搵倒一個職員?<br />\n<br />\n仲有好多不能盡列，而上所有改變都反影地鐵係亳無人性，只向減省成本，收益最大化看，唔重視乘客感受/舒適。"},{"pid":"d3bffb4b2777b367ffc486c41d56df1eeb66b84b","tid":487310,"uid":43189,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2017-12-03T22:49:11.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><blockquote><blockquote><br />\n印象中當年九鐵分咗兩個部門<br />\n東鐵就十足政府咁<br />\n西鐵就私人公司咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /></blockquote><br />\n記得好多年前鏗鏘集有集講九鐵服務問題<br />\n節目訪問一個女乘客，佢覺得售票處某服務員態度有問題，打算投訴佢，於是問佢叫咩名<br />\n個職員咁答佢：「我做咩要話我個名你知啫，而家又唔係同你對親家」<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /></blockquote><br />\n<a href=\"https://youtu.be/qZEbjwqHexo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FqZEbjwqHexo&d=NztypxuZbm0QUhDvt%2FI62xv1o3X72Fc8dbph17rWX2c%3D&h=d57c9169\" target=\"_blank\">https://youtu.be/qZEbjwqHexo</a><br />\n17:13 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n如果依家公務員咁樣對市民會點<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n90年代之前啲公務員個個都係咁架啦<br />\n打後九鐵已經改革咗好多啦，個個講到臨合併仲係90年代咁款<br />\n九鐵啲職員起碼友善過依家啲閪面廢鐵職員</blockquote><br />\n改革成功就唔會兵變啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n基本上係田北辰改革失敗加速兩鐵合併</blockquote><br />\n成唔成功睇你點睇，但九鐵後期的確係透明咗，最出名咪8分鐘通報機制<br />\n但一樣可以係田北辰自己太過急進而搞到所謂失敗<br />\n而且九鐵比依家既廢鐵更願意同大眾溝通，例如以前九鐵間唔中都搞下車廠開放日<br />\n依家廢鐵根本係唔憂做心態，仲駛乜同你地打好關係者"},{"pid":"797bc7ddb8792cc320cbc0a6126fcb3c54671292","tid":487310,"uid":43189,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2017-12-03T22:57:50.000Z","msg":"<blockquote><blockquote><blockquote>當年地鐵又真係管理得好過kcr好多</blockquote><br />\n個陣東鐵列車車底有裂紋要用人手駕駛<br />\n西鐵又火燭又成日壞<br />\n嚇死唔少人</blockquote><br />\n講到而家好好咁<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 西鐵係少左壞<br />\n但而家到觀塘線成日壞<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n以前九鐵有8分鐘通報機制，人地主動報告你咪覺得成日壞囉<br />\n地鐵就鍾意收埋遲一遲先報<br />\n結果合併後就風水輪流轉，地鐵成日壞仲要收收埋埋唔公佈"},{"pid":"c524eed3a44b3ab32bd0d7a6c06fd900213d77fc","tid":487310,"uid":117793,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-12-04T00:56:16.000Z","msg":"十年都未慣叫港鐵"},{"pid":"6cd7558371d2158a3648e81ed411d48200e721b0","tid":487310,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-04T01:07:49.000Z","msg":"<blockquote><blockquote>當年地鐵又真係管理得好過kcr好多</blockquote><br />\n門面睇落係地鐵好，但你問實際住喺前九鐵沿線特別係西鐵嘅人, 一定大部分都覺得合併前好D。<br />\n-寬敞嘅西鐵站同豆腐潤咁細嘅地鐵站比較已經係笑話, 屋企咁細都唔夠, D地鐵站(就算係新起)都係咁細。新起嘅地鐵站裝修十年不變，毫無美感。<br />\n-合併後不斷喺西鐵站加鋪頭，將通道收窄，令我地再要做沙甸魚。<br />\n-每個站都有入閘機拆走，部份車站闊閘機本身每方向2部變左雙向使用，影響人流<br />\n-多個車站關閉部份客務中心，本身唔同出口可以喺就近位置可以搵倒客務中心，變到要行好遠，仲有閘內閘共用一個，大部份時間得一個職員，咁岩多人果陣要等好耐。大規模<br />\n-大規模縮減車站人手，而家隨左繁忙時間(波板糖人又係廢嘅)，邊會喺月台/大堂搵倒一個職員?<br />\n<br />\n仲有好多不能盡列，而上所有改變都反影地鐵係亳無人性，只向減省成本，收益最大化看，唔重視乘客感受/舒適。</blockquote><br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> 地鐵缺乏人性化係近年先突然顯著<br />\n真係風水輪流轉"},{"pid":"0c2ad060096b1bb40e1ccf2244c49fbc220ef269","tid":487310,"uid":35430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-04T04:26:12.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>兩鐵合併 車費即減<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"https://youtu.be/cE1ngKT6rCE\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FcE1ngKT6rCE&d=NztypxuZbm0QUhDvt%2FI62xv1o3X72Fc8dbph17rWX2c%3D&h=ce5f7c5b\" target=\"_blank\">https://youtu.be/cE1ngKT6rCE</a></blockquote><br />\n跟住幾年加返10幾個巴仙<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src