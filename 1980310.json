pid":"8cf95dfb41e5cd95469483911ffcdd77663dcc6c","tid":1980310,"uid":7439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-20T05:16:51.000Z","msg":"深水埗YOYO可化身為康健中心<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1886953\" data-auto-link target=\"_blank\">https://lih.kg/1886953</a><br />\n<blockquote>深水埗和黃大仙地區康健中心營運服務招標期延長<br />\n＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊<br />\n  食物及衞生局今日（二月十七日）宣布，提供深水埗和黃大仙地區康健中心營運服務的招標期延長至四月二十四日中午十二時。<br />\n  地區康健中心營運者透過醫社合作和公私合營的模式提供由政府補貼的基層醫療服務，包括健康推廣、健康評估、慢性疾病管理和社區復康，藉以提升市民的自我管理健康能力，並為長期病患者在社區內提供支援。</blockquote>"},{"pid":"2148b03e18496d3b42af75b92a2f70632ba37db2","tid":1980310,"uid":5549,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-20T05:47:44.000Z","msg":"蓋兄呢期去開邊道叫雞？"},{"pid":"316cb74566a2d1b858661968cb76d52657f8f811","tid":1980310,"uid":44171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-20T05:49:31.000Z","msg":"我只係想捉棋可以嗎？"},{"pid":"1490f9237e9d8b73eefd42efe8beb988d1d01d51","tid":1980310,"uid":19552,"like":0,"dislike":0,"score":0,"quote":{"pid":"2148b03e18496d3b42af75b92a2f70632ba37db2","tid":1980310,"uid":5549,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-20T05:47:44.000Z","msg":"蓋兄呢期去開邊道叫雞？"},"citedBy":1,"replyTime":"2020-04-20T05:51:06.000Z","msg":"緊火打飛機咪算"},{"pid":"c928170dba28ac00e9c21e739772c41736b30dd5","tid":1980310,"uid":52571,"like":0,"dislike":0,"score":0,"quote":{"pid":"1490f9237e9d8b73eefd42efe8beb988d1d01d51","tid":1980310,"uid":19552,"like":0,"dislike":0,"score":0,"quote":{"pid":"2148b03e18496d3b42af75b92a2f70632ba37db2","tid":1980310,"uid":5549,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-20T05:47:44.000Z","msg":"蓋兄呢期去開邊道叫雞？"},"citedBy":1,"replyTime":"2020-04-20T05:51:06.000Z","msg":"緊火打飛機咪算"},"citedBy":2,"replyTime":"2020-04-20T05:58:34.000Z","msg":"2和b失戀 比幾個場佢啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"6c9072c3a780622ec9ecb11