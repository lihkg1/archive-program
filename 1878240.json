h"},{"pid":"28def35a1ba2f8df8a1aeafd4c0453402ada0fb8","tid":1878240,"uid":139294,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-13T13:36:57.000Z","msg":"Push"},{"pid":"b3427e4df0e25f46d971ee365692877769476812","tid":1878240,"uid":265949,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-13T13:41:08.000Z","msg":"gogogo"}],"pinned":{"pid":"28aa0ba5fe5d4750ff97877ad28afa96f636bec9","tid":1878240,"uid":292499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-13T13:18:23.000Z","msg":"【司法機關政務處公告】- 11/02/2020<br />\n<br />\n基於公共衞生的考慮，由 2020 年 2 月 13 日起司法機構 將實施以下安排:-<br />\n<br />\n<strong>體溫檢測</strong><br />\n- 所有人均須接受體溫檢測<br />\n- 發燒或拒絕接受檢測人士不得進入<br />\n<br />\n<strong>法庭座位安排</strong><br />\n- 公眾席的座位數目將減少約一半<br />\n- 取消站立旁聽聆訊<br />\n- 將會使用較大的法庭，並在可行情況下進行廣播"}}