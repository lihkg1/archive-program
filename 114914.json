id":"8f6d6f5e174e93091628a2c5a226ceb5ecdb76dd","tid":114914,"uid":18685,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T07:41:05.000Z","msg":"鰻魚飯<br />\n朝日啤酒廠"},{"pid":"01d774238e26b80c33afa1b327cbac14f73339be","tid":114914,"uid":23021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T07:41:38.000Z","msg":"食燕窩月餅"},{"pid":"fdee238bdd4d7c1130456340eac370caffd222e7","tid":114914,"uid":49344,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T07:42:57.000Z","msg":"金津園"},{"pid":"5c43ff8e43307170de9bce7bb40b6dea93586974","tid":114914,"uid":44783,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T08:15:08.000Z","msg":"4月有legoland~"},{"pid":"48863fd2c79c924ab35b451bd082bfc157fc1be9","tid":114914,"uid":74171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T08:19:22.000Z","msg":"汽車博物館<br />\nbetween, 名古屋啲女幾高質(同大阪比較)"},{"pid":"72447c905bb270729648a35df4600f259c781b3f","tid":114914,"uid":75537,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T08:47:51.000Z","msg":"名古屋本身景點唔算好多<br />\n多數都係以名古屋做中心去其他地方玩<br />\n<br />\n白川鄉<br />\n高山<br />\n上高地<br />\n立山黑部<br />\n金澤等等<br />\n<br />\n不過睇你玩幾多日<br />\n如果要去其他地方盡量排好啲次序唔好浪費太多時間喺交通上面<br />\n當然全程留名古屋市都可以啦"},{"pid":"2616d5da63d30bedf0c78dc333ac59e51a61d37f","tid":114914,"uid":19029,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T09:21:09.000Z","msg":"<blockquote>名古屋本身景點唔算好多<br />\n多數都係以名古屋做中心去其他地方玩<br />\n<br />\n白川鄉<br />\n高山<br />\n上高地<br />\n立山黑部<br />\n金澤等等<br />\n<br />\n不過睇你玩幾多日<br />\n如果要去其他地方盡量排好啲次序唔好浪費太多時間喺交通上面<br />\n當然全程留名古屋市都可以啦</blockquote><br />\n<br />\n我去5日4夜<br />\n女朋友想去比較冷門地方<br />\n<br />\n金澤聽講好正<br />\nSearch下先<br />\n多謝巴打"},{"pid":"46c8e6c775611b8970dae4581052250e612825f0","tid":114914,"uid":24863,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T09:37:24.000Z","msg":"榮"},{"pid":"5b360e13a3100bfb15a4273efa204ec92b3070d6","tid":114914,"uid":833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-16T07:34:41.000Z","msg":"年尾去八日七夜<br />\n<br />\n<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n<br />\n未去過<br />\n<br />\n好似好hea 咁<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"3722d65e1b9a2a2e13f3cbd5a5933e3180e52c70","tid":114914,"uid":70262,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-16T09:13:54.000Z","msg":"上個月去完<br />\n3日2夜<br />\n見咁短時間淨係留左係名古屋裡面玩<br />\n市內無咩特別<br />\n名古屋站/榮站同伏見站 就最多百貨公司/遊客<br />\n<br />\n如果對鐵路/新幹線/火車有興趣既<br />\n可以去鐵路博物館<br />\n係金城_頭站附近<br />\n非鐵膠都覺得幾有趣<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"9b5728ea6a81e04208a3cbc71c26f727f20fc20d","tid":114914,"uid":7026,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-16T10:15:12.000Z","msg":"<blockquote>食燕窩月餅</blockquote><br />\n<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}