l1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=42546ef1\" target=\"_blank\">http://www.acrylicosvallejo.com/model-paints</a><br />\n尤其 FAQ, 解答到好多問題 <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> , 呢點做得好過日本仔, 唔洗唔識日文估估吓, 以訛傳訛<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><br />\n<a href=\"http://www.acrylicosvallejo.com/en_US/model-paints/faqs/3\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.acrylicosvallejo.com%2Fen_US%2Fmodel-paints%2Ffaqs%2F3&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=a83198f8\" target=\"_blank\">http://www.acrylicosvallejo.com/en_US/model-paints/faqs/3</a><br />\nQ：想問下手既關節可以點樣分件黎做手臂位既無縫？<br />\nc 型分法？套番落去之後會唔會鬆？<br />\nA：<img src=\"https://i.lihkg.com/540/http://i.imgur.com/8AYaEOe.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttp%3A%2F%2Fi.imgur.com%2F8AYaEOe.png&h=f35279d4&s={SIZE}\" /><br />\n(by -AMURO- )<br />\nQ：巴打們, 想問下點貼水貼, 先會自然d, 貼完好似油上去咁?<br />\n有時貼d水貼, 貼完佢d反光同個模型本身好唔同<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><br />\nA：link:<br />\n[url][/url]<br />\n(by -AMURO- )<br />\nLED 電壓；電阻測量結果 ( by 柒中之柒)<br />\n<a href=\"http://forum13.hkgolden.com/view.aspx?message=6191940&amp;page=14\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fforum13.hkgolden.com%2Fview.aspx%3Fmessage%3D6191940%26page%3D14&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=8976feac\" target=\"_blank\">http://forum13.hkgolden.com/view.aspx?message=6191940&amp;page=14</a>"},{"pid":"98d1af9cd7d170dc173e21442ce11509a3db6011","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-07T23:58:04.000Z","msg":"Finisher 油資料(by 世尊 )<br />\nFinisher web page, 好麻煩啲油無編號嘅 得日文字<br />\n[url]<a href=\"http://finishers.jp/page003.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ffinishers.jp%2Fpage003.html&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=85f6e236\" data-auto-link target=\"_blank\">http://finishers.jp/page003.html</a><br />\n[/url]<br />\n叫做有個 英文 page, 唔太 update<br />\n<a href=\"http://finishers.jp/page007.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ffinishers.jp%2Fpage007.html&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=836044ee\" target=\"_blank\">http://finishers.jp/page007.html</a><br />\n呢隻油嘅色 多係配製比模型車用, 不過啲色靚, 見不少日本仔用嚟噴 Gundam. 係油性油漆, 可以用 Mr Hobby 或者 Gaia thinner 開稀<br />\n香港就 皆旺 21/F 同 YM Studio 有番貨<br />\n旺角模型及工具舖最新資料<br />\n註：工具係指一般如剪鉗、筆之類<br />\n情景/改造用品係指膠片、膠條、蝕刻片之類<br />\n英明<br />\n洗衣街135號<br />\n軍模：有<br />\n高達：有<br />\n工具：有<br />\n情景/改造用品：有<br />\n油：郡仕(Mr Color) 、佳亞(Gaia)、田宮(Tamiya)、IPP、Italeri<br />\n短評：算係一間比較齊全嘅模型舖，唯Bandai 模型會比其他稍貴<br />\n千里達<br />\n洗衣街127號<br />\n軍模：有<br />\n高達：有<br />\n工具：有<br />\n情景/改造用品：有<br />\n油：郡仕(Mr Color) 、田宮(Tamiya)、Testor<br />\n短評：亦係一間比較全面嘅模型舖，軍模方面艦船好似比英明多，但油就一定唔及英明齊全"},{"pid":"254ad801aba252e7bbdc91f14ed36ceeb978561a","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-07T23:58:24.000Z","msg":"Man66 Hobby<br />\n皆旺商業大廈6樓601室<br />\n軍模：無<br />\n高達：有<br />\n工具：有<br />\n情景/改造用品：有<br />\n油：佳亞(Gaia)、Modo<br />\n短評：高達類為主，有時會有嘅中古/罕有嘅舊模型，有開班教砌模型<br />\n富聯首辦美勞原料店<br />\n皆旺商業大廈21樓2101室<br />\n軍模：無<br />\n高達：無<br />\n工具：有<br />\n情景/改造用品：有<br />\n油：少量<br />\n短評：工具用品十分齊全嘅舖，好多其他舖冇嘅呢度都可能搵到，但模型油就唔係齊款，通常只有個別牌子嘅特別色先有，而且冇噴槍用品賣<br />\n肥青蛙模型<br />\n亞皆老街80-86號昌明大廈3樓I室（黑布街入）<br />\n軍模：少量<br />\n高達：無<br />\n工具：無<br />\n情景/改造用品：有<br />\n油：無<br />\n短評：以前響富聯隔離只開星期六，而家搬咗開星期一至六，地方大咗。有大量軍模及車模用嘅蝕刻片及樹脂件賣，可以去尋寶<br />\nRX88<br />\n德發商場地庫<br />\n軍模：有<br />\n高達：無<br />\n工具：有<br />\n情景/改造用品：有<br />\n油：MIG 、AV 、Alclad、Italeri、Gaia<br />\n短評：近年比較進取嘅模型舖，從以前以高達類為主，到而家漸漸走向軍模為主。油方面以MIG為主，另外玩燈嘅亦可以搵到用品"},{"pid":"a03e305f4c515aca033c9b89d6200c69aa78ca86","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-07T23:58:48.000Z","msg":"YM Studio<br />\n中僑商業大廈16樓1602室<br />\n軍模：有<br />\n高達：有<br />\n工具：有<br />\n情景/改造用品：有<br />\n油：AV、AK interactive 、Gaia、郡仕、Citadel<br />\n短評：又係一間幾進取嘅模型舖，油方面牌子都好多好齊(係冇MIG，fade out 中）<br />\n模型唔算話好多，叫做樣樣有啲，但戰棋就<br />\n真係多，似乎變成主打<br />\n有得租場噴油同有模型班<br />\n仲有女僕......<br />\n環球<br />\n分店：廣華街15-33號<br />\n總店：窩打老道63號地下<br />\n軍模：有<br />\n高達：無<br />\n工具：有<br />\n情景/改造用品：有<br />\n油：郡仕、田宮<br />\n短評：老牌模型舖，但好似越來越縮。模型偏貴，要買多啲先會平啲啲<br />\n另外只有總店有雜誌及蝕刻片賣<br />\n總店業己結<br />\n宏記<br />\n窩打老道35號A地下<br />\n軍模：有<br />\n高達：有<br />\n工具：有<br />\n情景/改造用品：有<br />\n油：田宮、郡仕<br />\n短評：賣田宮嘢多，田宮油平啲<br />\n現代模型公司<br />\n登打士街仁安大廈地下<br />\n軍模：好似冇<br />\n高達：有<br />\n工具：有<br />\n情景/改造用品：無<br />\n油：郡仕、田宮<br />\n短評：一半賣模型一半賣槍，模型及用品唔算特別多，大路嘢為主 ( by 柒中之柒)<br />\n生暉模型<br />\n旺角15－23號煙廠街安康大廈地下4號鋪<br />\npm store<br />\n地址：九龍深水埗青山道64號名人商業中心902室<br />\n致力為大家搜羅各式各樣的噴油工具, 主要銷售噴筆, 氣泵, 模型油漆及模型工具。<br />\n產品包括以下品牌:<br />\nHarder &amp; Steenbeck<br />\nBadger Air-Brush<br />\nSparmax<br />\nAnest Iwata<br />\nMr.Hobby<br />\nAcrylicos Vallejo<br />\nGaianotes<br />\nHobbyZone<br />\nSujiborido, OLFA, TAMIYA 等等"},{"pid":"9ae6118de5585f804a08d762c28b0fd75c25d855","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-07T23:59:17.000Z","msg":"由血小販提供既RG短評：<br />\n01.RX-78-2 外型吸引，但成身裝甲鬆散，唔上膠水會玩到爆粗，關節冇乜力<br />\n02.紅渣 裝甲較鬆，關節唔夠緊,動力管要自己砌,水口有排你玩<br />\n03.空突 幾靚仔，除左關節冇乜力之外冇乜缺點<br />\n04.綠渣 換色紅渣<br />\n05.自由 幾靚仔，但對翼真係好易散，好易散同好易散，關節一般rg水平<br />\n06.空中霸王 劍裝炮裝配件包，買左空突唔係唔買埋啊？<br />\n07.黑MK II 可以換裝做測試mode,兼顧造型同可動，關節力度係水準以上<br />\n08.白MKII 除左冇換裝，其他一樣<br />\n09.正義 掛槍掛盾掛劍都好鬆，外形同動畫較大出入，仲有seed系列通病--後面太重好難企定定，腳底有連接槽俾部幻影00<br />\n10.zeta 好撚型，但部分件過緊，冇做過修改嘅話，變形後斷手機會極高<br />\n11.命運 一般, 對腳好怪,揸劍不舉<br />\n12.gp01 因為遷就變形，胸部構成唔夠緊，玩果陣比較易解體<br />\n13.gp01fb 同gp01<br />\n14.突自 得對翼係電鍍係最大敗筆，有做埋龍騎兵準備釋放模式<br />\n15.exia 兩把gn blade同gn sword都係電鍍，面相好睇過mg<br />\n16.魔蟹 隻手有得揀三爪/四爪型態，全新骨架可動一般<br />\n17.飛翼零式ew 好難擺雙炮發射經典動作,整體華麗高可動,偏纖瘦體形<br />\n18.OO riser 關節係水準之上，送d特效件幾有心，頭部表情比較怪（望多左唔覺）<br />\n19.紅迷 造型幾靚,個表情好呆，把菊一文字係電鍍<br />\n20.飛翼ew 同零式差唔多<br />\n21.OOQ 幾靚,同MG版造型差唔多,面型較靚仔<br />\n22.新安洲 全身好軟，不舉，裝甲似跑車果隻拋光，多左少少原創展開裝甲嘅地方，幾靚仔<br />\n23. build strike full package 關節一係太緊一係太鬆，腳板好易甩，每次裝返開頭都好緊，一陣就鬆過老江湖<br />\n24.金天蜜娜 拋光裝甲，除左機體骨架冇電鍍，冇乜好挑剔.(有錢可以買限定電鍍版,不過內骨架都係屎黃色仲要6舊水)<br />\n25.獨角獸 完全變形，關節好緊，砌果陣一用錯力，九成會斷，都幾靚<br />\n26.紅渣（真紅閃電） 紅渣換少少甲，換個徽章出嚟呃錢而出（應該出係pb)<br />\n27.報喪女妖 同1號機一樣<br />\n28.杜魯基斯 用少左成形骨架，加左啲mg都冇嘅裝甲展開，關節緊得嚟恰到好處。<br />\n29.沙薩比 最高水準RG(暫),非常少成形骨同較少色差分色,掛住RG名嘅MG,關節十分實淨高可動.砌果陣要小心關節接駁<br />\n30.FA獨角獸 兼用前者繼承優點,肩部比例略大。係唯一一隻可以變形又可以係全裝形態下擺任何POSE又保持堅挺嘅獨角獸。裝備分件大部分比較細,但冇咩分色。<br />\n31.叉骨X1 小體形MS,差唔多大細但比WING難砌,因為大部分成形骨冇左,要當MG砌。部分零件超細件,眼花手殘者可略過此作。整體實淨,除左面部血痕之外都完美分色。<br />\n32. NU gundam 掛住RG名嘅MG,超變態可動性,實淨全PS骨架,揹住排牛油炮一樣可以唔上架站立,腿部有唔少裂甲加連動設計"},{"pid":"075e1ccae1643f874b547cb678f95fd3740bcf0e","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-07T23:59:35.000Z","msg":"由血小販提供既Hirm短評：<br />\nHirm共通：成品骨架。細節同分色無可挑剔，超過9成以上水口係隱藏設計，神剪一刀流好快砌好。造型風格比較另類，一款比一款少金屬成份，性價比並唔高。<br />\n巴巴托斯4th form：唔少電鍍件(電鍍藍、金、紅)槍鐵色嘅刀、珍珠白嘅外甲同金屬件，骨架好睇但唔少小問題,膝關節鬆得好緊要但髖關節又過緊，可動性亦一般,髖關節安裝亦唔一定水平。<br />\n巴巴托斯6th form:pb限定，兼用4TH,價錢夠原價買隻mb,大部分兼用，多左套甲，原先電鍍件得返金色果part,膝關節同其他骨架問題都有改善。<br />\nWing zero:可動性幾高，部分外裝甲比較易甩（尤其心口），可以上膠水解決,可以變飛機。<br />\nWing EW:兼用wing zero,好多剩餘零件可以根據自己喜好搭配分色,有送水貼。<br />\n紅迷：超高可動性，設定把刀由太刀變打刀,關節非常實淨。送嘅膠貼好撚薄同埋剪裁到好貼,基本上唔追求完美嘅就咁貼就OK。<br />\n黑迷：理所當然兼用紅迷主體，肌肉猛男風格，係對角同腳尖改左。兩把電鍍太刀分別刻左菊一文字同虎徹，九成出埋紅。背包完全新規，比mg版detail得多，可動關節十分多又硬淨，除左翼炮個c字型扣（j1-7),呢個位好脆弱，用力不當輕則鬆晒，重則斷裂。<br />\n神高：最靚仔嘅神高，肌肉猛男風，骨架扎實，擁有痴撚線嘅可動性，裝左外甲會有些少干涉。有少少預塗裝，金屬部件近乎冇，有送彩虹圓圈特效。手臂藍色裝甲要還原返普通mode時個c 字扣好易甩，心口打開經過特別設計，唔似其他版本(包括mg),咁遮埋個面。"},{"pid":"a6accdaf89babed0450260cc496d1f8e6da6d3fc","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T00:00:18.000Z","msg":"由 落地喊三聲巴打 建議既片<br />\n素組JJ們如果有心想進一步去提升模型質素但又未有力又唔想搞咁大陣仗去噴筆，睇晒啲堆片佢，塞錢入你袋。<br />\n想入門舊化既人士亦都會有得著。<br />\n<a href=\"https://youtu.be/oOYj7eYdYCQ\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FoOYj7eYdYCQ&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=53e55954\" data-auto-link target=\"_blank\">https://youtu.be/oOYj7eYdYCQ</a><br />\n<a href=\"https://youtu.be/_ELsT3_8PVQ\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F_ELsT3_8PVQ&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=05351fae\" data-auto-link target=\"_blank\">https://youtu.be/_ELsT3_8PVQ</a><br />\n<a href=\"https://youtu.be/xJAFGUbFAfY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FxJAFGUbFAfY&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=f8b3ea76\" data-auto-link target=\"_blank\">https://youtu.be/xJAFGUbFAfY</a><br />\n<a href=\"https://youtu.be/slTwuW1TM14\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FslTwuW1TM14&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=5dc37bfa\" data-auto-link target=\"_blank\">https://youtu.be/slTwuW1TM14</a><br />\n<a href=\"https://youtu.be/Wp2GLumPKuw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FWp2GLumPKuw&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=18257de5\" data-auto-link target=\"_blank\">https://youtu.be/Wp2GLumPKuw</a><br />\n<a href=\"https://youtu.be/al-yzZVp1cY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fal-yzZVp1cY&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=62a0833f\" data-auto-link target=\"_blank\">https://youtu.be/al-yzZVp1cY</a><br />\n<a href=\"https://youtu.be/P0pduwkVn8g\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FP0pduwkVn8g&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=469ea476\" data-auto-link target=\"_blank\">https://youtu.be/P0pduwkVn8g</a><br />\n<a href=\"https://youtu.be/UzT23s7UXLk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FUzT23s7UXLk&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=c7139878\" data-auto-link target=\"_blank\">https://youtu.be/UzT23s7UXLk</a><br />\n<a href=\"https://youtu.be/NGbJPkWeyx4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FNGbJPkWeyx4&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=f58fcc1b\" data-auto-link target=\"_blank\">https://youtu.be/NGbJPkWeyx4</a><br />\n<a href=\"https://youtu.be/6pgjtCBpJ9o\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F6pgjtCBpJ9o&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=1e6fdc59\" data-auto-link target=\"_blank\">https://youtu.be/6pgjtCBpJ9o</a><br />\n<a href=\"https://youtu.be/Q-hwk2_-IMA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FQ-hwk2_-IMA&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=df5d25c5\" data-auto-link target=\"_blank\">https://youtu.be/Q-hwk2_-IMA</a>"},{"pid":"b88e74f50d83283e72973481f3d2ca4e9b7e5883","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T00:00:38.000Z","msg":"由 落地喊三聲巴打 自拍既片<br />\n洗筆<br />\n<a href=\"https://youtu.be/pa_fXFlLM3w\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fpa_fXFlLM3w&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=c3d1cd11\" data-auto-link target=\"_blank\">https://youtu.be/pa_fXFlLM3w</a><br />\n油：雙星<br />\n洗筆水：玻璃水<br />\n抺緊走杯入面啲油先<br />\n再入水谷鎗<br />\n谷完倒左佢<br />\n重覆兩三次<br />\n再係杯入面有洗筆水既情况下扭鬆支針，<br />\n前後Chok下同轉<br />\n整甩針尾(即杯後你見唔到既地方)既油<br />\n再谷一次唔見有色就得。<br />\n貼水貼<br />\n<a href=\"https://youtu.be/VVUdUHXO234\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FVVUdUHXO234&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=2a33bb07\" data-auto-link target=\"_blank\">https://youtu.be/VVUdUHXO234</a><br />\n簡簡單單例範下貼水貼<br />\n片尾有show我用邊隻水貼softener(公認市面上最好既水貼軟化劑）同只係用濕水紙巾黎代替全浸落水。<br />\n<a href=\"https://youtu.be/gakl6ZW9m-I\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fgakl6ZW9m-I&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=4e3761a3\" data-auto-link target=\"_blank\">https://youtu.be/gakl6ZW9m-I</a><br />\n介紹用銼同沙紙<br />\n<a href=\"https://youtu.be/4DmlXvdvY10\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F4DmlXvdvY10&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=025255d0\" data-auto-link target=\"_blank\">https://youtu.be/4DmlXvdvY10</a><br />\n打磨入門<br />\n<a href=\"https://youtu.be/oe6aqeWpVsY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Foe6aqeWpVsY&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=ad5f8241\" data-auto-link target=\"_blank\">https://youtu.be/oe6aqeWpVsY</a><br />\n噴電鍍油<br />\nMasking 技巧 (Shared by RX-78-2)<br />\n岩岩睇左一條日本仔既有效率masking方法:<br />\n<a href=\"https://www.youtube.com/watch?v=mrnKIDfVLXE&amp;t=761s\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DmrnKIDfVLXE%26t%3D761s&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=64f1748b\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=mrnKIDfVLXE&amp;t=761s</a><br />\n用極幼既masking tape (1-2mm) 做好個邊先, 呢隻tape可以做到好順既曲線, 之後上大範圍既masking tape, 剩底既用masking solution<br />\n條邊sharp過自己cut masking tape好多<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c0d6e208beff6faec5adebb02b6dd0769ca36ef2","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T00:01:03.000Z","msg":"黃化問題 （由福仔759巴打提供）<br />\n先講講個黃化問題先<br />\n參考過外國論壇話用陽光曬一日至一個禮拜<br />\n視乎你塊嘢有幾黃同你嗰邊有幾耐日照咁啦<br />\n原link: <a href=\"https://uamf.org.uk/viewtopic.php?f=94&amp;t=9252\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fuamf.org.uk%2Fviewtopic.php%3Ff%3D94%26t%3D9252&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=10d4f813\" target=\"_blank\">https://uamf.org.uk/viewtopic.php?f=94&amp;t=9252</a><br />\n但你都知香港喱啲石屎森林你屋企唔係西斜都幾難搵到陽光<br />\n咁有人就用gel甲嗰啲UV燈射佢老味<br />\n<img src=\"https://na.cx/i/Ai0hhNH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAi0hhNH.jpg&h=d04876d9&s={SIZE}\" /><br />\n效果都幾明顯, 飛一飛邊啲透明位就冇事<br />\n但如果想勁到連透明邊位都白埋又得唔得呢<br />\n係有嘅, 可以睇下喱個日本網站教學, 用一支叫Kitchen hunter(?)嘅清潔劑原液唔開稀直接浸佢老味<br />\n<img src=\"https://na.cx/i/PxoZv9D.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPxoZv9D.jpg&h=8687e934&s={SIZE}\" /><br />\n咁呢就連透明邊位都只係剩返極少黃漬<br />\n而我自己都同你一樣好懷疑, 唔係應該會愈射愈黃架咩?<br />\n實驗心態驅使之下我去老鴨買咗支UV燈返嚟, 順便可以射埋我啲3D parts<br />\n壓著射咗兩晚, 真係白返, 因為我本身都唔係好信會Work所以冇影到相<br />\n原本十字架嘅白邊同你張嘢差唔多黃<br />\n<img src=\"https://na.cx/i/T6bsE4L.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FT6bsE4L.jpg&h=1a508e51&s={SIZE}\" /><br />\n變成而家咁白<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><br />\n我相信原理係UV將成層Oxidized咗嘅催化劑(即係黃色嗰層嘢)「蒸發」咗<br />\n但做完喱一步唔可以即刻落水, 因為我相信你喱啲舊水貼唔只黃, 仲會碎<br />\n要用水貼修補液<br />\n日本個教學link<br />\n<a href=\"http://www.1mokei.jp/html/work_09.htm\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.1mokei.jp%2Fhtml%2Fwork_09.htm&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=70d7709f\" data-auto-link target=\"_blank\">http://www.1mokei.jp/html/work_09.htm</a><br />\n <br />\n另一個教學<br />\n<a href=\"https://blog.xuite.net/jnm.g028035/1/28583954-%E6%B0%B4%E8%B2%BC%E7%B4%99%E4%BF%AE%E8%A3%9C%E6%B6%B2\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fblog.xuite.net%2Fjnm.g028035%2F1%2F28583954-%25E6%25B0%25B4%25E8%25B2%25BC%25E7%25B4%2599%25E4%25BF%25AE%25E8%25A3%259C%25E6%25B6%25B2&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=82996153\" data-auto-link target=\"_blank\">https://blog.xuite.net/jnm.g028035/1/28583954-%E6%B0%B4%E8%B2%BC%E7%B4%99%E4%BF%AE%E8%A3%9C%E6%B6%B2</a><br />\n喱啲舊水貼黃化同脆化基本上係打孖咁嚟<br />\n支修補液其實就係一層好薄好薄嘅膠<br />\n本身就係用嚟做水貼最面嗰層嘅, 用嚟鎖著啲墨水喺水貼紙上面<br />\n而家用喺舊水貼嘅作用其實差唔多, 只不過係鎖實啲望落冇咩但實際上已經失去拉伸能力甚麼本身已經碎開咗嘅水貼<br />\n我喺富聯買就70蚊支, budget喱啲就交俾巴打你諗"},{"pid":"b1fa1d2e382367ffd19bfcb081ebb0417ecf925e","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T00:01:19.000Z","msg":"舊化教學（由福仔759巴打提供）<br />\n我以前砌飛機嘅經驗嚟講呢<br />\n就係好睇你個水貼圖案有幾粗/幼<br />\n如果個圖案太幼又飛咗邊搞到成張嘢都好細就唔建議即刻撳佢<br />\n因為好易碎然後痴上支棉花棒到<br />\n拎嚟實際case嚟睇啦, 紅色箭嘴個位就係我炒咗要補色嘅位喇<br />\n<img src=\"https://na.cx/i/7t2LrVk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7t2LrVk.jpg&h=bbddbeb9&s={SIZE}\" /><br />\n好似喱啲咁細條嘅就唔建議亂嚟<br />\n但如果好似圖入面隔離啲日之丸就撳佢啦,唔好太大力同扭支棉花棒<br />\n <br />\n但正所謂預防治療<br />\n我就建議如果你如果要痴喱啲幼水貼又唔想搞到咁進退兩難呢<br />\n最好都係落咗mark setter先, 我就用開好普通嗰隻<br />\n<img src=\"https://na.cx/i/NQp9TCA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNQp9TCA.jpg&h=ce3ad7b3&s={SIZE}\" /><br />\n用完會更加貼伏,自然落完softer都少啲凸起,撳佢都冇咁易爛<br />\n回歸返你一開始個case,如果係我就會等啲softer乾晒之後喺邊位浸少少setter入去先再撳實, 一般都冇死<br />\n撳嘅時候唔好亂掃或者扭支棉花棒就應該冇問題"},{"pid":"f43afe4c4c3054131206d053ec20448709e1d617","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T00:01:37.000Z","msg":"滲線,漬洗,輕量舊化（由福仔759巴打提供）<br />\n我係有啲Alternative嘅推介, 就係用油彩(畫油畫嗰啲)同水溶性木顏色<br />\n<a href=\"https://www.youtube.com/watch?v=FXerpuOthXk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DFXerpuOthXk&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=ca9ee553\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=FXerpuOthXk</a><br />\n油彩開稀之後個質地同琺瑯油差好遠, 會更稀更慢乾<br />\n其中一個我鍾意喱個方法嘅原因係琺瑯滲線未必食到嘅淺坑油彩都會食到<br />\n其二就係可以順便做埋漬洗, 可以當係一個極低要求嘅陰影效果<br />\n另外就係未必一定要用X-20, 開稀可以用亞麻仁油, 抹可能就咁搵吸油紙捽都得<br />\n但唔好處就係要乾好耐, 一定要乾過夜<br />\n<a href=\"https://youtu.be/pCLHe8a8ugU?t=217\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FpCLHe8a8ugU%3Ft%3D217&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=a93becb8\" data-auto-link target=\"_blank\">https://youtu.be/pCLHe8a8ugU?t=217</a><br />\n油彩做舊化又有另一個好處就係佢比琺瑯油更好blend開啲顏色<br />\n做出嚟我覺得比開稀咗嘅琺瑯油更加自然, 邊界位會更burr更融和於底色<br />\n不過手感就同開稀琺瑯油差好多, 但摸熟掃法之後就會明顯發現油彩係比琺瑯油更加好控制, 唔滿意又可以即刻抆走佢<br />\n非常方便, 但都係嗰句, 要乾好耐<br />\n<a href=\"https://www.youtube.com/watch?v=6311Cb9jN8s\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D6311Cb9jN8s&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=b6e1bf56\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=6311Cb9jN8s</a><br />\n水溶性木顏色其實某程度上同乾粉彩好似<br />\n但佢遇水即刻捽得甩,非常易控制, 拎嚟做變色甩青效果一流<br />\n不過要留意佢係要喺消光面上面用,如果唔係會咬唔入<br />\n所以用之前要留意清楚自己仲有冇步驟未做完先噴消光再落筆<br />\n有興趣嘅睇下片, j下先, PLASMO喱個捷克channel真係極高質<br />\n啟發咗我好多"},{"pid":"6d7f3c0df2fa197c67a90d0d79ebb30558e9b4f4","tid":1914930,"uid":10900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T00:01:57.000Z","msg":"乾粉彩舊化教學（由福仔759巴打提供）<br />\n<a href=\"https://www.youtube.com/watch?v=qWI7xxfpDOU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DqWI7xxfpDOU&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=52b13631\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=qWI7xxfpDOU</a><br />\n乾粉彩其實又係一個好好控制嘅嘢嚟<br />\n主要步驟有<br />\n1. 溝粉, 直接撈成你想要嘅色<br />\n2. 搽X-20, 係一種半黏著嘅步驟, 主要係你撻啲粉上去之後好啲作修正<br />\n3. 搽Pigment fixer, 喱個就真係痴著啲粉咁濟, 其實就係溶返開啲粉等佢痴著個面<br />\n4. 用筆掃佢老味, 你可以就咁乾掃上去, 又可以濕少少上面兩隻嘢嚟掃<br />\n5. 成碌上, 刮上去<br />\n而且改變步驟嘅先後次序出到嚟嘅效果又可以好唔同, 自由度好高<br />\n即係例如你想做沙漠乾燥少少嘅, 風沙感覺嘅, 我自己當初做西線沙漠戰鬥機就用筆點少少粉乾掃上去, 薄薄地有層粉好似有少少朦朧感覺<br />\n就慢慢點啲fixer上去,盡量唔好打亂個層次<br />\n但如果你想做叢林野戰feel多淤泥嘅, 咁就要落咗fixer喺表面先, 隨心加,重手少少都得, 反正都係要見到佢結埋一舊咁<br />\n如果想做啲泥石刮上去啲膝頭位就最好成碌刮佢老味喇<br />\n但其實我覺得漬洗做得好呢,後者就隨便做都好有feel<br />\n如果要有噴筆想挑戰下自己, 可以試下做雨痕<br />\n<a href=\"https://www.youtube.com/watch?v=tFVRH27DSEk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DtFVRH27DSEk&d=z2r7XlCbtqTRl1EuzFzNuI26uSpwD1fkwqqc2qDkc5E%3D&h=80f52e19\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=tFVRH27DSEk</a><br />\n落鹽整到好似炒菜咁"},{"pid":"ac56707b2b802fa075cd7bb810b9be469dc24474","tid":1914930,"uid":8447,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T00:07:09.000Z","msg":"請問如果用白色蓋嘅Av 油噴油，係咪要好多thinner?<br />\n因為本身白色嘅存貨比較多，定直接再買黑色蓋好啲"},{"pid":"4e136a9fd0e0fa84f3b687f2330de4ea5e7e4a5d","tid":1914930,"uid":90535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T01:03:33.000Z","msg":"Gaia支光油是咪伏？<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><br />\n噴咗好似消光咁<img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" /><br />\n定係我唔識用<img src=\"/assets/faces/lm2/frownsmile.gif\" class=\"hkgmoji\" />"},{"pid":"3e6970a5c5ceafa4b6cf93097b301ffa19689cc4","tid":1914930,"uid":37458,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-08T02:53:38.000Z","msg":"深水保spn120幾錢<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"850700efbef2b4e9598e284244180ee33f7f4fc0","tid":1914930,"uid":14992,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-08T03:08:34.000Z","msg":"巴打 想問下<br />\nPG鳳凰燈組 係自己有1set 定係同1,2號機同set?<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n知唔知大概幾錢左右<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"8be8469ad8229e79caa56290a251b722e16293d8","tid":1914930,"uid":4850,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T04:48:36.000Z","msg":"哇上個post有巴打買咗架車好靚咁<br />\n都成十年冇砌過雙星車<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3411997a34b4c6c51fc9fc8f4178063168414bd4","tid":1914930,"uid":28397,"like":0,"dislike":0,"score":0,"quote":{"pid":"3e6970a5c5ceafa4b6cf93097b301ffa19689cc4","tid":1914930,"uid":37458,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-08T02:53:38.000Z","msg":"深水保spn120幾錢<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-09T00:27:35.000Z","msg":"$370-380"},{"pid":"e1b9e6b75650f2012896b4523e0cf77daf566407","tid":1914930,"uid":198317,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime"