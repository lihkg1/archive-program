normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1177dcb106b7ac32163aa04d63dcd77aba695105","tid":1056683,"uid":4026,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-11T12:29:34.000Z","msg":"以前一啲所謂激進既申訴方法 <br />\n遊行 絕食<br />\n政府 財團已經見怪不怪<br />\n過多幾年分分鐘你自殺都唔會有人理<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"8dd5a22d7af5a49331d7bb7380dd6a80b742f45a","tid":1056683,"uid":118677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-11T12:32:19.000Z","msg":"一句講晒, 奴性夠重先有飯食呀<br />\n唔夠咪比人屌, 比人排囉"},{"pid":"efe67772185065d0a4e47cce2437cfd35cddc96c","tid":1056683,"uid":118677,"like":0,"dislike":0,"score":0,"quote":{"pid":"1b29f9c3013d08c5a67119c6970ab12dc8f96729","tid":1056683,"uid":10692,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-11T12:07:02.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-03-11T12:34:22.000Z","msg":"福氣黎架, 屌你, 識唔撚識呀"},{"pid":"a28e716d634f5f4f439523c750a9e806f9296807","tid":1056683,"uid":33972,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-03-11T12:37:03.000Z","msg":"都要睇吓點自殺法。我估如果老師唔係返咗學校跳，成件事未必有咁大迴響"}]}