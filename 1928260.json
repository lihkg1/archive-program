n係嚟緊9月立法會我哋除咗守住功能組別 <br />\n同直選議席之餘<br />\n我哋仲應該主動進攻 <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-16T10:13:44.000Z","msg":"推"},{"pid":"6cff85b9ee1526d9ae83a07bf6e13d4a9e9530cc","tid":1928260,"uid":63639,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T10:15:00.000Z","msg":"推"},{"pid":"86c38bf092b6704fb4803f575aa549205e66c0ee","tid":1928260,"uid":63639,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T10:18:30.000Z","msg":"推上去"},{"pid":"ab5c51cfea3c26bf327295b629151f6aaa3c790d","tid":1928260,"uid":98431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T10:20:03.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"a95beee2e2ba390ec3e3d5304733228d20f290c1","tid":1928260,"uid":63639,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T10:20:27.000Z","msg":"推推"},{"pid":"de6501a3ed6365b96501df57f7d4272f5cd16d71","tid":1928260,"uid":63639,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T10:20:42.000Z","msg":"要光復香港呀"},{"pid":"4779d23923a21fa6700bf32991cc6127090078be","tid":1928260,"uid":63639,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T10:21:49.000Z","msg":"推上去"},{"pid":"fa72499424be8eb648e740bf79209f777b3ff184","tid":1928260,"uid":63639,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T10:23:40.000Z","msg":"光復立法會"},{"pid":"7103598988baea5533a88fd26316cc111a502273","tid":1928260,"uid":231583,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T10:24:30.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6839b5ad0dd0c80039c153c8ebf29528dc4b8aa3","tid":1928260,"uid":63639,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T10:25:13.000Z"