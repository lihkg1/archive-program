ly.com%2Flocal%2F20191108%2FVZ653GGDE6IZUHD3MUBGYUWLAY%2F&d=nCDZGLdcAmB0c2Oxl6asXMdEKmWGZzYthIwftZf8Bt0%3D&h=3683ec3d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20191108%2FVZ653GGDE6IZUHD3MUBGYUWLAY%2F&h=7825b2a0\" target=\"_blank\">https://hk.appledaily.com/local/20191108/VZ653GGDE6IZUHD3MUBGYUWLAY/</a><br />\n<br />\n<br />\n===<br />\n<br />\n<strong>與上述案例無關，只係巴絲打睇一睇：</strong><img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://youtu.be/BufF8VPWDZg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FBufF8VPWDZg&d=nCDZGLdcAmB0c2Oxl6asXMdEKmWGZzYthIwftZf8Bt0%3D&h=fec9b33b\" target=\"_blank\">https://youtu.be/BufF8VPWDZg</a>"},{"pid":"ccb305ec25180b5055420e0d2b9f8444fc793189","tid":2092440,"uid":117837,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2020-07-03T08:16:27.000Z","msg":"藏鐳射筆15歲少年罪成 官改控罪為「有意圖而管有攻擊性武器」 議員憂引發濫告<br />\n<br />\n少年原被控「管有適合作非法用途的工具罪」及「在公眾地方管有攻擊性武器罪」，署理總裁判官蘇惠德在裁決前提出修改控罪，將針對鐳射筆的「管有適合作非法用途的工具罪」，改作「有意圖而管有攻擊性武器」。<br />\n<br />\n蘇惠德曾審理多宗案件，包括判處潘樂陶僭建罪成罰款2萬元；傘運佔領期間男子於海富中心外襲警一案，判處10個月監禁；就旺角衝突襲警案判處熱血公民成員陳柏洋9個月；原審吳文遠三文治案時判囚3周等。蘇惠德亦是審理9.29暴動案的裁判官。<br />\n<br />\n<a href=\"https://www.hkcnews.com/article/24680/%E9%90%B3%E5%B0%84%E7%AD%86-921%E5%B1%AF%E9%96%80%E8%A1%9D%E7%AA%81-%E8%98%87%E6%83%A0%E5%BE%B7-24680/%E8%97%8F%E9%90%B3%E5%B0%84%E7%AD%8615%E6%AD%B2%E5%B0%91%E5%B9%B4%E7%BD%AA%E6%88%90-%E5%AE%98%E6%94%B9%E6%8E%A7%E7%BD%AA%E7%82%BA%E3%80%8C%E6%9C%89%E6%84%8F%E5%9C%96%E8%80%8C%E7%AE%A1%E6%9C%89%E6%94%BB%E6%93%8A%E6%80%A7%E6%AD%A6%E5%99%A8%E3%80%8D-%E8%AD%B0%E5%93%A1%E6%86%82%E5%BC%95%E7%99%BC%E6%BF%AB%E5%91%8A\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hkcnews.com%2Farticle%2F24680%2F%25E9%2590%25B3%25E5%25B0%2584%25E7%25AD%2586-921%25E5%25B1%25AF%25E9%2596%2580%25E8%25A1%259D%25E7%25AA%2581-%25E8%2598%2587%25E6%2583%25A0%25E5%25BE%25B7-24680%2F%25E8%2597%258F%25E9%2590%25B3%25E5%25B0%2584%25E7%25AD%258615%25E6%25AD%25B2%25E5%25B0%2591