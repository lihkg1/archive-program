 />"},{"pid":"70660a94ee1d0dd694365a9e9b6dec0499e0e57c","tid":1919311,"uid":6115,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-10T23:22:43.000Z","msg":"不要暗戀"},{"pid":"79be4624a76f10669f390ec5d0a3d64275d04e67","tid":1919311,"uid":165409,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2020-03-10T23:34:29.000Z","msg":"表白無用架<br />\n唔好比咁多膠劇同森美表白節目影響到 浪漫化<br />\n如果你既暗戀成份係有曖昧既<br />\n就更加唔洗表白<br />\n大部分人都鍾意果種好朋友之間但又有點甜既曖昧關係<br />\n大部人都係鍾意果種「未完待續」好想發展落去既關係 表白左等如自己熄左成個game咁<br />\n拆穿左咁然後呢？就無然後架啦<br />\n<br />\n其實兩個人岩既話就會慢慢地同步一齊<br />\n根本唔需要再表白<br />\n同埋表白 大多數時候就好似你哂冷咁<br />\n如果你自己太著重得失 患得患失既就更加唔好<br />\n因為你唔會想像到自己有幾難放低<br />\n<br />\n過來人經驗<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"dfc4edf9ead5978c3372f552096654d247d107b1","tid":1919311,"uid":192075,"like":2,"dislike":1,"score":1,"quote":{"pid":"a445b9c3c175e722f4f5d3e68cee6e3debedf0c6","tid":1919311,"uid":67425,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2020-03-10T22:10:10.000Z","msg":"搵唔到身份去為佢做事.<br />\n為唔到佢做事 即零價值.<br />\n零價值 即係唔好表白.<br />\n人哋生活精彩不必有我."},"citedBy":0,"replyTime":"2020-03-11T01:37:02.000Z","msg":"呢個好中<br />\n唔知自己咩身份定位"},{"pid":"e3eed19d4cf56db7bdf75239df21d3afda2873ce","tid":1919311,"uid":166996,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-03-11T03:07:15.000Z","msg":"因為唔想比人拒絕自己受傷"},{"pid":"a101aa71602e71759bac9f932c32d7386290fc49","tid":1919311,"uid":225118,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-03-11T04:10:06.000Z","msg":"高攀唔起 寧願做一世朋友"},{"pid":"e499985cd5b783ec14f19ba4dc4e37f8f2252f0a","tid":1919311,"uid":338603,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-03-11T05:21:42.000Z","msg":"覺得對方唔鐘意自己"},{"pid":"ad0d4021b735c95ed0a1d1108b41e6c627a7d7f5","tid":1919311,"uid":30565,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6d119ca405e6924455de602e00d9b296603f9cc9","tid":1919311,"uid":92334,"like":0,"dislike":0,"score":0,"quote":{"pid":"3abc3ae387e30cc147fa0b0dc66edace99e27ef5","tid":19