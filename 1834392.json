 class=\"hkgmoji\" />"},{"pid":"62391707302e08b1a20d961cf872a53a006d1bfd","tid":1834392,"uid":81140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T11:58:26.000Z","msg":"push"},{"pid":"5221876516a00c3dd2edf254febf631ef400faee","tid":1834392,"uid":81140,"like":0,"dislike":0,"score":0,"quote":{"pid":"41e7bbfbd7c5ab4d0533007bcedb6eff74ad4585","tid":1834392,"uid":58287,"like":5,"dislike":1,"score":4,"quote":{"pid":"52d0c2c686e9cb6f491da953a2b5b1f49dfecc78","tid":1834392,"uid":158499,"like":7,"dislike":1,"score":6,"quote":{"pid":"a9d25ae0c2320a90ec82f0fb8232a3f2fa9e47de","tid":1834392,"uid":58287,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-22T11:04:38.000Z","msg":"洗手間水渠隔氣彎管須有足夠貯水，Sars時就係因為淘大花園的隔氣乾枯令病毒可以速速蔓延整座大廈：<br />\n<br />\n<img src=\"https://www.moonskyedu.com/furniture/%E6%B0%B4%E5%96%89%E6%BD%94%E5%85%B7/%E7%B6%B2%E9%A0%81%E5%9C%96%E7%89%87/%E9%9A%94%E6%B0%A3%E7%A8%AE%E9%A1%9E.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.moonskyedu.com%2Ffurniture%2F%25E6%25B0%25B4%25E5%2596%2589%25E6%25BD%2594%25E5%2585%25B7%2F%25E7%25B6%25B2%25E9%25A0%2581%25E5%259C%2596%25E7%2589%2587%2F%25E9%259A%2594%25E6%25B0%25A3%25E7%25A8%25AE%25E9%25A1%259E.jpg&h=6daf8ab0&s={SIZE}\" /><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=9xuKvFgFOkA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D9xuKvFgFOkA&d=UWp4lduD54HchuVgBglmzfRe10cHvJvhFGsNMWslaGA%3D&h=774903d2\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=9xuKvFgFOkA</a>"},"citedBy":1,"replyTime":"2020-01-22T16:36:31.000Z","msg":"隔氣點會枯乾<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n當年係話因為佢棟大廈用U型去水位所以有，但詳情好似唔係樓主嗰嘅咁"},"citedBy":2,"replyTime":"2020-01-22T17:05:02.000Z","msg":"根據當局與淘大花園居民的面 談，涉及廁所內<br />\n散發臭味的投訴十分普遍，顯示接駁一些單位的 U 形<br />\n聚水器可能未有發揮其應有功用。由於水廁、洗手盆、<br />\n浴缸是常用的，所以與其相連的 U 形聚水器大部分時<br />\n間應是有貯水的，並應能發揮隔氣功用。不過，由於大<br />\n部 分 住 戶 清 潔 浴 室 地 面 時，慣 性 以 拖 把 抹 地 而 不 是 用 水<br />\n沖洗，所以大部分連接地台排水口的 U 形聚水器很可<br />\n能因乾涸而未能發揮隔氣作用。事實上，當局曾在 E<br />\n座 一 個 單 位 內 進 行 測 試，發 現 當 浴 室 的 抽 氣 扇 啟 動 後 ，<br />\n空 氣 會 從 污 水 管 經 地 台 排 水 口 倒 流 進 入 浴 室。我 們 推 測<br />\n這氣流可能把存於污水管內的帶病毒液滴散發至浴室<br />\n內，而 浴 室 的 抽 氣 扇 亦 可 能 把 這 些液滴排放至分隔相鄰<br />\n單位的天井，最後帶病毒的滴液通過窗戶進入其他單位<br />\n<br />\nquote: <a href=\"https://www.info.gov.hk/info/sars/pdf/amoy_c.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.info.gov.hk%2Finfo%2Fsars%2Fpdf%2Famoy_c.pdf&d=UWp4lduD54HchuVgBglmzfRe10cHvJvhFGsNMWslaGA%3D&h=70e0cd98\" data-auto-link target=\"_blank\">https://www.info.gov.hk/info/sars/pdf/amoy_c.pdf</a>"},"citedBy":0,"replyTime":"2020-01-24T11:59:35.000Z","msg":"push la"},{"pid":"fce46232000bbf5584284fe64c80bfae14e1b994","tid":1834392,"uid":58287,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T16:06:02.000Z","msg":"推"},{"pid":"79134567c6fd163cc9e835826d8a220a82b15228","tid":1834392,"uid":345458,"like":0,"dislike":0,"score":0,"quote":{"pid":"65b773354aad1c8853b5818954799bc1dfd58460","tid":1834392,"uid":150742,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-24T10:49:32.000Z","msg":"要倒幾多？<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-25T04:26:11.000Z","msg":"有人話一日兩支1:99 lol"},{"pid":"71cdea157abc6fa24c1d3be9ebd5d7a7446f622d","tid":1834392,"uid":58287,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T12:18:03.000Z","msg":"push"},{"pid":"ec5a9e7115693e07e217e8f3b5cb4f60114aab91","tid":1834392,"uid":104961,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T16:35:26.000Z","msg":"推"},{"pid":"8662a9ef003f0a0b0ba7b112884d81e95bf20c0e","tid":1834392,"uid":29167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T16:44:09.000Z","msg":"收到，即做"},{"pid":"541eba8b1d6022371095514a6f946e255888fc95","tid":1834392,"uid":274368,"like":0,"dislike":0,"score":0,"quote":{"pid":"72d5a2dfe62d7a8d687089