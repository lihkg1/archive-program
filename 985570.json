e50d1b39","tid":985570,"uid":213607,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-01-19T13:53:51.000Z","msg":"幾鐘意刻畫到黑幫唔係得惡"},{"pid":"45e40580ba2a117a48c2cdc0065b01df91dff253","tid":985570,"uid":124262,"like":0,"dislike":0,"score":0,"quote":{"pid":"d0cf9ec17343db12c24e45c17036b3b5e50d1b39","tid":985570,"uid":213607,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-01-19T13:53:51.000Z","msg":"幾鐘意刻畫到黑幫唔係得惡"},"citedBy":0,"replyTime":"2019-01-19T15:28:18.000Z","msg":"講得好啱<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" />"},{"pid":"ba96ce4b0cc3fe08cd840c0d475339f3c54f4d34","tid":985570,"uid":213607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-20T06:46:08.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"1d41f290c632aff05064d122fc393347749301ee","tid":985570,"uid":159266,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-01-20T06:55:12.000Z","msg":"絕對好睇, 2019第一套遺珠<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n Clint eastwood個角色寫得太好, 望落去平平無奇既老人家, 可以控制黑白兩道, 但都敵唔過屋企既遺憾"},{"pid":"81d239388fac15a4b0a1608e778d8b2eeb359e23","tid":985570,"uid":11914,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-20T07:46:36.000Z","msg":"Sir eastwood 既戲一定要睇<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"beeb24d8724645a286a24b2ac1d4db55a82f2131","tid":985570,"uid":28435,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-20T08:01:03.000Z","msg":"收得太快"},{"pid":"b85eac652c0b91201abaaeab47252bafb7b8f9af","tid":985570,"uid":19990,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-01-20T08:35:24.000Z","msg":"外國帶一次粉做毒騾好好搵，不過做幾次就好收<br />\n片中黑幫都比阿伯見好就收<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"36b562a9fa056969dff6c543dea1559d17900df0","tid":985570,"uid":213607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-20T12:45:01.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"0b10f76809cfc92cddeed55c893c41cab139d827","tid":985570,"uid":226231,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-21T02:43:30.000Z","msg":"準備睇第二次<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"39cb20f37b04f917f80059084cccccb91f40fda9","tid":985570,"uid":39576,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-01-21T03:50:00.000Z","msg":"個片名改得幾好，同夾番佢以前獨行俠都係押鏢運貨，但同時怕套片名錯誤吸引左人入場為睇槍戰片，我見最尾30mins同場有最少3個人睇手機睇幾點，加上睇完戲再睇trailer，覺得trailer剪得好緊張呃到下人，實際睇戲咩咖啡壺個d太明顯唔緊張，但其實套戲最精彩係文戲<br />\n首先奇連伊士活成差唔多90歲仲拍到演到真係好癲，雖然動作場面唔多，但你香港搵個90歲仲行得走得，仲要睇佢上個月既訪問片對答思路清晰，香港真係好少見<br />\n另外套戲佢教曉點為之一個男人，係家庭永遠放第一，就算你錯左八十幾年都可以仲有機會開竅改過<br />\n同埋片尾播首歌好好聽，作歌既人之前問奇連點keep住咁有活力，佢答話堅持每日出街行下做下野，Don&rsquo;t let the old man in<br />\n最後睇奇連既戲最舒服放心係唔駛擔心係d左膠大愛政治正確既戲，戲入面都出下教d女同志整車，好主動咁幫d黑人手整車，好平常無惡意咁叫佢negros黑鬼，但對方好敏感咁叫話佢地叫開blacks黑人"},{"pid":"50c8f537fa07bcf7b8c2be099afe8ad14d0c1648","tid":985570,"uid":213607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-21T12:22:25.000Z","msg":"推比人睇<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"a67939db4f18ecf37bfab32b6c1355ebff6e4e74","tid":985570,"uid":16676,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-01-22T05:28:23.000Z","msg":"帶出果種人與人之間既互動情感<br />\n鄰里親情既感覺<br />\n<br />\n係現今智能電話既世代已經難求<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">SMS text</span></span>既影響<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n<br />\n套戲好多肢體語言<br />\n突顯全人類都開始稀有, 唔剩止係華人"},{"pid":"5d41e8d7ef2cfa6b7b45c056386bfb08391de5da","tid":985570,"uid":162073,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-22T08:54:56.000Z","msg":"我估大家要有90歲先好評價<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"92e9aa9a97ce3bdf044f9ba7bb4a3b21858217a2","tid":985570,"uid":92376,"like":0,"dislike":0,"score":0,"citedBy":0,"