Fwww.imi.buzz%2Fimages%2F2017%2F05%2F20%2FIMG_20170430_171413.jpg&h=1cb65bfb&s={SIZE}\" />"},{"pid":"9e56d5a966e75d912db3c7765dcf84c7317fb332","tid":250242,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-20T02:40:09.000Z","msg":"當晚去左青年旅館訓, 幾乾淨, 但心諗將床 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"http://www.imi.buzz/images/2017/05/20/IMG_20170430_182753.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.imi.buzz%2Fimages%2F2017%2F05%2F20%2FIMG_20170430_182753.jpg&h=411b4884&s={SIZE}\" /><br />\n<img src=\"http://www.imi.buzz/images/2017/05/20/IMG_20170430_182802.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.imi.buzz%2Fimages%2F2017%2F05%2F20%2FIMG_20170430_182802.jpg&h=362d56d8&s={SIZE}\" /><br />\n<br />\nDinner去左附近一間餐廳,<br />\n咖喱烏東幾好食<br />\n<img src=\"http://www.imi.buzz/images/2017/05/20/IMG_20170430_185618.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.imi.buzz%2Fimages%2F2017%2F05%2F20%2FIMG_20170430_185618.jpg&h=87647b63&s={SIZE}\" /><br />\n<br />\n夜晚係青年旅館地下間Bar到同老細吹水,<br />\n佢點點下貨攞左支野出黎<br />\n<img src=\"http://www.imi.buzz/images/2017/05/20/IMG_20170430_193810.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.imi.buzz%2Fimages%2F2017%2F05%2F20%2FIMG_20170430_193810.jpg&h=3958d649&s={SIZE}\" /><br />\n<br />\n另一層嘅Common Area,<br />\n第二朝搭早車, 見到有個鬼仔半裸訓左係地下,<br />\n原來幾個鬼仔琴晚飲酒吹水吹通宵<br />\n<img src=\"http://www.imi.buzz/images/2017/05/20/IMG_20170501_062437.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.imi.buzz%2Fimages%2F2017%2F05%2F20%2FIMG_20170501_062437.jpg&h=7e4e2a35&s={SIZE}\" />"},{"pid":"30977e572bdf2c7909ee23c93ecc58887c69dda6","tid":250242,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-20T02:44:16.000Z","msg":"太早, 冇咩野食, 求其買少少野做早餐<br />\n<img src=\"http://www.imi.buzz/images/2017/05/20/IMG_20170501_062929.jpg\" data-thumbnail-src=\"https