/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"48cf118ffd363b7f7206f3be5b6bf2add3008f72","tid":672361,"uid":30006,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-05-21T05:37:27.000Z","msg":"後生成個溫兆倫咁"},{"pid":"80e55117e45ac3a7715ad3eb770fa51f521f9429","tid":672361,"uid":13250,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2018-05-21T05:40:58.000Z","msg":"人工20萬一個月,退休加埋退休金,長糧<br />\n做老細都未必搵到咁多<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"8e2e8586e04497ac1af72f58b5479a532e7c7527","tid":672361,"uid":2638,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-21T05:46:30.000Z","msg":"廢老..."},{"pid":"eb8bdf4752b98d242df470b2e1116cf7319d5768","tid":672361,"uid":16676,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-05-21T05:51:56.000Z","msg":"佢踩住幾多後生仔而上位, 升官進爵 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e7ba0992895f2dfccb815f8ce3a992de2d352816","tid":672361,"uid":56462,"like":17,"dislike":0,"score":17,"citedBy":2,"replyTime":"2018-05-21T05:53:27.000Z","msg":"<blockquote>人工20萬一個月,退休加埋退休金,長糧<br />\n做老細都未必搵到咁多<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /></blockquote><br />\n根本舊制公務員福利正到癲<br />\n我朋友老豆係總助理<br />\n佢老母係教育局主任<br />\n<br />\n退休金夠買兩層樓"},{"pid":"e8f5089dfc714bdd66166fd1c4d604f59c073690","tid":672361,"uid":102096,"like":2,"dislike":9,"score":-7,"citedBy":0,"replyTime":"2018-05-21T06:06:34.000Z","msg":"此回覆已被刪除"},{"pid":"047a7f5e963f460af13e94a0dfcb9979d61f2e47","tid":672361,"uid":12701,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-05-21T06:42:24.000Z","msg":"以前高登有嗰post反串惡搞又幫佢整fans club 又乜又剩 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e334944f72ea93abffd1e761cbca2be154f20845","tid":672361,"uid":19126,"like":7,"dislike":1,"score":6,"citedBy":0,"replyTime":"2018-05-21T06:49:25.000Z","msg