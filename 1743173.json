 class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"e94287e5263ecd75f713d2a80eae294a1d929d5f","tid":1743173,"uid":155137,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-11-21T07:53:48.000Z","msg":"開心就閂一兩個站<br />\n唔開心就閂多兩三個站<br />\n客量點會唔跌<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5f8d2d082d12f0be7f2f1965d1533d87bc0e9cb9","tid":1743173,"uid":136766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T07:59:08.000Z","msg":"跌就理所當然啦，升就驚姐<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ccc6ffaf4e64c343fcc1b76d3ee9a74d2d70aa7f","tid":1743173,"uid":238370,"like":0,"dislike":0,"score":0,"quote":{"pid":"660b433bbaaadb292cf18d93c3329af5504b4366","tid":1743173,"uid":24045,"like":0,"dislike":1,"score":-1,"quote":{"pid":"26a44788a3737bd9925ae6f45f50055f55ce8125","tid":1743173,"uid":8040,"like":5,"dislike":1,"score":4,"citedBy":2,"replyTime":"2019-11-21T05:59:56.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-21T06:01:35.000Z","msg":"一個月一億喎"},"citedBy":1,"replyTime":"2019-11-21T08:01:43.000Z","msg":"一個月一億係東海道同京滬先做到嘅級數"},{"pid":"1d07ea3cfa08b85e1bfc96534f6cfe584b5f9129","tid":1743173,"uid":289442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T08:07:53.000Z","msg":"一方面有唔開鐵<br />\n另一方面有罷搭<br />\n再加黎明行動，令到本身以準時為賣點既黨鐵無晒優勢<br />\n市民遲早轉晒坐巴士，有排你跌呀 黨鐵<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"}]}