sg":"黑警日日4點既歪理會，政府無視過去受傷既學生抗爭者 唔通就堵路就指責佢地 良心過唔過意得去"},{"pid":"892f209f5ab74e3a1aeaca52fc623d3e7e69f05e","tid":1728743,"uid":259993,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T04:37:37.000Z","msg":"推"}]}