 src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1be8d59a3a160cf03930ce2076d418001a272117","tid":16292,"uid":34701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T10:40:52.000Z","msg":"渣ga"},{"pid":"1b25c72247fb6cd6978aba7f9cfb7339f0360853","tid":16292,"uid":41174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T12:24:35.000Z","msg":"用兩個瀏覽器是常識吧<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"a0fc3b55b7360151daabe5f0a2ffea5cb5711d56","tid":16292,"uid":61177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T13:13:38.000Z","msg":"睇一次笑一次<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8208892dec2525ed1daf0bcb223263a8ec0f2173","tid":16292,"uid":68185,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T13:15:59.000Z","msg":"係巴士笑撚左出聲<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"840c5ac48593321a5697e92242d62e9a0d179ef8","tid":16292,"uid":33489,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T13:17:16.000Z","msg":"測試新會員?"},{"pid":"db121e77a9430161e268052bbbd9bc7b928c0086","tid":16292,"uid":58254,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T13:49:24.000Z","msg":"渣ga"},{"pid":"fa8b880698a23d7da1c6ef2b2ac50369d70250ae","tid":16292,"uid":66213,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T14:23:33.000Z","msg":"渣ga"}]}