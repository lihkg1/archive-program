75f97c6c4b23","tid":2394111,"uid":52779,"like":0,"dislike":0,"score":0,"quote":{"pid":"2bef2811ada224605d15846ced13c60cbd2e03d6","tid":2394111,"uid":240362,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0f3bfbea7489447d736e337d89678f7990f59c80","tid":2394111,"uid":52779,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-04T03:20:09.000Z","msg":"又覆核"},"citedBy":1,"replyTime":"2021-02-04T03:25:39.000Z","msg":"<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-04T03:28:06.000Z","msg":"<img src=\"/assets/faces/cat/darkness.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/darkness.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/darkness.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/darkness.gif\" class=\"hkgmoji\" />"},{"pid":"34785e65a11af85ad2f43b9c2177b6b6a1364d2d","tid":2394111,"uid":110043,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-04T03:28:40.000Z","msg":"制裁le 3隻賤種狗官最撚好"},{"pid":"d3fdafbd81b1f6c4cf52d475018ee3cee2e2992f","tid":2394111,"uid":20459,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2021-02-04T03:30:56.000Z","msg":"好嬲 今日去柴灣食多幾間黃店幫佢出氣<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"02633d8bd629efe87fe140800d78a58200e1cc8e","tid":2394111,"uid":240362,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-04T03:30:57.000Z","msg":"15歲少年承認前年11月18日在柴灣已婚警察宿舍外擲汽油彈後被判處3年感化和宵禁令。上訴庭潘兆初首席法官，彭偉昌上訴庭法官，和潘敏琦法官上月應律政司申請批准刑期覆核裁定刑罰過輕，並下令少年扣押至今，上訴庭考慮過案件嚴重性以及更生作用後，改為判處少年教導所命令。<br />\n<br />\n代表少年的劉偉聰大律師引述各項報告，反映感化官和懲教署均同意少年有充分反省，建議法庭考慮更生中心或教導所命令，冀法庭判處更生中心令，當然實質長短由少年表現決定，至於教導所羈留期由半年至3年不等。<strong><span class=\"red\">法官潘兆初反問，長羈留期會否對少年更有幫助，坦言如果被告是成年人，誓必判囚以收阻嚇之用。</span></strong>劉大狀回應，現時是考慮刑期覆核，相信更生中心已足以提供警剔作用。<br />\n<br />\n律政司一方提醒法庭指，少年至今沒有回應他是否罔顧宿舍住客性命安全，<strong><span class=\"red\">潘敏琦法官批評少年欠缺同理心。</span></strong>"},{"pid":"be2979ca91f9a31ed40b6fa9fe70a9c34423c3c4","tid":2394111,"uid":121197,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-02-04T03:31:36.000Z","msg":"守行為&gt;感化&gt;社會服務令&gt;更生中心&gt;勞教中心&gt;教導所<br />\n屌你由第二種刑罰升到最高<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f490d66d1cecb7c7f3d9134d084f93a266014285","tid":2394111,"uid":240362,"like":2,"dislike":0,"score":2,"quote":{"pid":"be2979ca91f9a31ed40b6fa9fe70a9c34423c3c4","tid":2394111,"uid":121197,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-02-04T03:31:36.000Z","msg":"守行為&gt;感化&gt;社會服務令&gt;更生中心&gt;勞教中心&gt;教導所<br />\n屌你由第二種刑罰升到最高<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-04T03:32:36.000Z","msg":"潘兆初反問，長羈留期會否對少年更有幫助，坦言如果被告是成年人，誓必判囚以收阻嚇之用 <img src=\"/assets/faces/dog/beg.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beg.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beg.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beg.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beg.gif\" class=\"hkgmoji\" />"},{"pid":"cac6a3bf557ee8a24ab63df0ae33d7a6d2b43cd9","tid":2394111,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"3b3cf3e0ec1aca92da960319d27075f97c6c4b23","tid":2394111,"uid":52779,"like":0,"dislike":0,"score":0,"quote":{"pid":"2bef2811ada224605d15846ced13c60cbd2e03d6","tid":2394111,"uid":240362,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0f3bfbea7489447d736e337d89678f7990f59c80","tid":2394111,"uid":52779,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-04T03:20:09.000Z","msg":"又覆核"},"citedBy":1,"replyTime":"2021-02-04T03:25:39.000Z","msg":"<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/f