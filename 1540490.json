elves  will not forgive us, until 5 Declarations have be fulfilled."},{"pid":"f599c99d5981cd4863ea5e27984e7c3bd3ee0de6","tid":1540490,"uid":112391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:28:17.000Z","msg":"UP"},{"pid":"698c423bad4938864b4d686d47753914eb025955","tid":1540490,"uid":224755,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:29:29.000Z","msg":"We need more topic in eng thx bro"},{"pid":"ce1ec05075e502f063b6af3f273f7a558b636b5b","tid":1540490,"uid":112391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:45:12.000Z","msg":"up"},{"pid":"b84401d082ebdab219eab4785c9ecfc1489c887a","tid":1540490,"uid":266653,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:58:51.000Z","msg":"thanks, push"},{"pid":"6edf9532dc06cffa0050eeb0dbc06e6d60885081","tid":1540490,"uid":112391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:59:31.000Z","msg":"up"},{"pid":"359149f092de7b4e0345f61b64c03d67b8e26b41","tid":1540490,"uid":112391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T13:20:20.000Z","msg":"up"},{"pid":"9298ef0c40738502611280b627459bd6411a8eec","tid":1540490,"uid":112391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T13:25:18.000Z","msg":"pish"},{"pid":"b8edc3ada8529770d99ef504ae5025220473b70e","tid":1540490,"uid":112391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T13:49:10.000Z","msg":"push"},{"pid":"6333b4dea8e2265d34312ded68e749e07d19d112","tid":1540490,"uid":112164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T13:50:03.000Z","msg":"5 Declarations needs to be all full filled.<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},{"pid":"5d807bbb7f72946faf4274044f2e96cf58533fd0","tid":1540490,"uid":286499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T13:50:38.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/as