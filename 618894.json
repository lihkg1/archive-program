d":618894,"uid":40470,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-06T07:35:42.000Z","msg":"係d精"},{"pid":"c7d492056575e3af7206311afeb44adb9c7f5ffb","tid":618894,"uid":24570,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-06T07:36:38.000Z","msg":"係啲飯"},{"pid":"cc7813dc3afce1bcf929dac1be3ea9e58ce89854","tid":618894,"uid":28493,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-04-06T07:37:28.000Z","msg":"係篇文"},{"pid":"ba1dcff9c09252939f7c6efd88eb8f18a5d57f3e","tid":618894,"uid":144043,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-04-06T07:40:57.000Z","msg":"火腿煎蛋飯重點係啲咩？"},{"pid":"e17b3212c9d95977b612e473b1d8a6b7d05b0071","tid":618894,"uid":74171,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-06T07:41:48.000Z","msg":"條麻甩佬<br />\n靚女食成件事唔同曬"},{"pid":"b8ffc9ec909bb56742e467726835074d330e2a3c","tid":618894,"uid":4525,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-06T07:48:00.000Z","msg":"傳菜"},{"pid":"37f6a4b719e58eb2dce530c847e95f7ba4e7c7d9","tid":618894,"uid":60740,"like":14,"dislike":3,"score":11,"citedBy":1,"replyTime":"2018-04-06T07:55:54.000Z","msg":"你話精華係豆腐，係火腩，係飯，甚至係青島都好，根本都係錯撚哂<br />\n其實成個精髓係食豆腐火腩飯嘅人嗰陣佬味<br />\n試諗下一間茶記嘅角落，一個毛都未生齊嘅學生哥嗌：「豆...豆腐火腩飯呀唔該...」然後屈埋一角自己食，點睇都只係間茶餐廳嘅路人甲永遠都上唔到大枱。好聽啲叫斯斯文文，衰啲講句就叫斯斯縮縮。<br />\n再唔係你諗下一個西裝友入到茶記，又係大嗌：「豆腐火腩飯青島。」之後慢慢咁用杯啡色嘅水浸筷子同匙羹，再用紙巾慢慢咁抹，成件事就好似嫌棄緊茶記環境，表達出為左生活先屈就係度，有錢嘅話恨不得拎去高級餐廳拎住刀叉攬女鋸和牛。你又唔見佢地會係Ruby Tuesday浸同抹刀叉，所以根本就係格格不入。<br />\n唯獨是一個&ldquo;佬&rdquo;入到茶記，好霸氣咁坐係成個場最中間，個股嘅氣係一坐底已經可以壓制成個場，一眼就知係茶記嘅主角，嗌都唔撚洗嗌啲伙記已經醒水比個豆腐火腩飯青島佢。個陣佬味就好似一出世就同個飯係渾然天成咁，呢個先至係成個飯嘅精髓。"},{"pid":"6dc820bee1239ce5171a20495052837d1f0249f4","tid":618894,"uid":141656,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-06T07:57:59.000Z","msg":"係啲汁"},{"pid":"039c9640c2869c2ae4d22ef5ceff80b3d026ff64","tid":618894,"uid":6124,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-06T07:59:26.000Z","msg":"隔夜火腩再加埋酸臭豆腐 <img src=\"/assets/faces/normal/dead.gif\" class=