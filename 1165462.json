{"tid":1165462,"cid":5,"subCid":0,"title":"【魚蛋革命】黃台仰李東昇證實獲德國難民庇護","createTime":"2019-05-21T20:39:23.000Z","updateTime":"2019-05-21T21:01:54.000Z","uid":34522,"like":20,"dislike":0,"uniUserReply":2,"replies":[{"pid":"adef4396a812d8caea091bf6faafd62a998cf970","tid":1165462,"uid":34522,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-21T20:39:23.000Z","msg":"<a href=\"https://www.vjmedia.com.hk/articles/2019/05/22/194227/%E3%80%90%E9%AD%9A%E8%9B%8B%E9%9D%A9%E5%91%BD%E3%80%91%E9%BB%83%E5%8F%B0%E4%BB%B0%E6%9D%8E%E6%9D%B1%E6%98%87%E8%AD%89%E5%AF%A6%E7%8D%B2%E5%BE%B7%E5%9C%8B%E9%9B%A3%E6%B0%91%E5%BA%87%E8%AD%B7\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.vjmedia.com.hk%2Farticles%2F2019%2F05%2F22%2F194227%2F%25E3%2580%2590%25E9%25AD%259A%25E8%259B%258B%25E9%259D%25A9%25E5%2591%25BD%25E3%2580%2591%25E9%25BB%2583%25E5%258F%25B0%25E4%25BB%25B0%25E6%259D%258E%25E6%259D%25B1%25E6%2598%2587%25E8%25AD%2589%25E5%25AF%25A6%25E7%258D%25B2%25E5%25BE%25B7%25E5%259C%258B%25E9%259B%25A3%25E6%25B0%2591%25E5%25BA%2587%25E8%25AD%25B7&d=ruuHvkpDPTXA%2B6q4k3%2F6TRSGsERVwMiaoyLN1PNQjS0%3D&h=878118a6\" target=\"_blank\">https://www.vjmedia.com.hk/articles/2019/05/22/194227/%E3%80%90%E9%AD%9A%E8%9B%8B%E9%9D%A9%E5%91%BD%E3%80%91%E9%BB%83%E5%8F%B0%E4%BB%B0%E6%9D%8E%E6%9D%B1%E6%98%87%E8%AD%89%E5%AF%A6%E7%8D%B2%E5%BE%B7%E5%9C%8B%E9%9B%A3%E6%B0%91%E5%BA%87%E8%AD%B7</a><br />\n<br />\n據紐約時報報導，2016年農曆新年期間於旺角發生的警民衝突中被拘捕，其後被起訴及隨後棄保潛逃的黃台仰及李東昇，證實獲德國難民保護。<br />\n德國政府透過電郵回覆紐時記者，於上年批核兩名香港人難民庇護，但沒有透露姓名。<br />\n報導指引述黃台仰訪問指，「如果德國相信香港有司法獨立，就不會批准我們的難民庇護申請」。<br />\n香港律政司及警方拒絕評論事件。"},{"pid":"5be6a74415c108ce1ea07beacdf8382b1fa37e8c","tid":1165462,"uid":55913,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-21T21:01:54.000Z","msg":"叻仔"}]}