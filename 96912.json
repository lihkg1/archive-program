\" />"},{"pid":"4930a511442676d4a49751c96787e849219c5ac9","tid":96912,"uid":79912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-27T09:04:31.000Z","msg":"<img src=\"https://upload.cc/i2/XZSUzN.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi2%2FXZSUzN.jpg&h=fc86d46a&s={SIZE}\" /><br />\n<img src=\"https://upload.cc/i2/5GMT9r.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi2%2F5GMT9r.jpg&h=01d17f5b&s={SIZE}\" /><br />\n<img src=\"https://upload.cc/i2/8SQNUo.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi2%2F8SQNUo.jpg&h=806ad8c1&s={SIZE}\" /><br />\n<img src=\"https://upload.cc/i2/ZRcPfL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi2%2FZRcPfL.jpg&h=5c44219f&s={SIZE}\" /><br />\n<img src=\"https://upload.cc/i2/QAMJT5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi2%2FQAMJT5.jpg&h=97b5762f&s={SIZE}\" />"},{"pid":"4963ddc289ccd5e9e148167a3674e3a924c4afb9","tid":96912,"uid":79912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-27T09:05:17.000Z","msg":"Upload完了~<br />\n<br />\n謝謝支持!"},{"pid":"16aeff71f8fc442a73bfdb9e474dc57f1058c68c","tid":96912,"uid":79912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-27T14:15:34.000Z","msg":"推"},{"pid":"a6ef29b7e218c3b33348475ce26349021275a436","tid":96912,"uid":79912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T01:38:37.000Z","msg":"推"},{"pid":"f77c4ac5ad5038184f44a73baf583e74299dbcb1","tid":96912,"uid":37907,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T01:52:44.000Z","msg":"臭閪"},{"pid":"ee9988d46294eddb0b920cfc3a8c96ebae6531a7","tid":96912,"uid":828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T02:01:16.000Z","msg":"<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},{"pid":"16b7d4966afd40affb30eab4fd1727e93f02cf34","tid":96912,"uid":20210,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T02:17:25.000Z","msg":"<img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" />"},{"pid":"3b6e9d1014d12d66bc40e75c84caaf0d9658b7fb","tid":96912,"uid":65256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T02:25:58.000Z","msg":"點解佢要叫恐怖核心嘅<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"b52610d2a607e785fabc709f84866d4da36aa7c7","tid":96912,"uid":4917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T02:52:10.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> 咁悲傷"},{"pid":"a2f06e8e25a14145150d2a950ad36e9ba9c39a94","tid":96912,"uid":79912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-29T05:35:40.000Z","msg":"有些人問核心的名字怎來?<br />\n<br />\n好吧...是這樣的..<br />\n<br />\n本來書名是很普通的, 叫&quot;稻草人與小鳥&quot;.<br />\n但我寫故事的時候（我用英文作的，會快一點）寫錯了稻草人的英文....<br />\n由scarecrow 寫錯 scarecore.........<br />\n然後，嘛，就將錯就錯吧！<br />\n然後重畫他了.<br />\n<br />\n重畫後, 我發覺更有意思了.<br />\n'恐怖核心'就是外表很醜的人, 但內心很好.<br />\n小鳥就是看中這點, 所以，她最後毫不猶豫地弄死他 (因為對她來說是不痛不癢).<br />\n<br />\n於是,這就出來了另一個道理了：<br />\n無論你內心有多好，你是不能打動一個以貌取人的人的.<br />\n又或者客觀點說，心地好並不是讓人喜歡你的唯一條件.<br />\n<br />\n雖然較為黑暗，但我看到的世界就是這樣."},{"pid":"d81dd230358ae58c77f3a797ba097ff1bb9327fd","tid":96912,"uid":79912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-31T07:38:26.000Z","msg":"推"},{"pid":"4d29fa140ae9b8e00a5f3f9b0e889b196a625d19","tid":96912,"uid":7466,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-31T07:46:39.000Z","msg":"支持本地創作<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"f2e4bdde1f4d2fa3a50bbb8fc8835e97ad4189eb","tid":96912,"uid":79912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-31T07:59:05.000Z","msg":"嘛,都過了一星期了. 我見沒什麽人看...<br />\n看來也差不多是時候全部和盤托出了.<br />\n<br />\n那至少, 也讓我為這故事做一個後記.<br />\n<br />\n<br />\n首先, 我就是故事裡的雕像.<br />\n<br />\n情節很簡單,<br />\n雕像被鳥利用 然後鳥又跟別人跑了<br />\n從頭到尾 那隻鳥根本沒想過要報答過雕像<br />\n反而忘恩負義的殺死雕像<br />\n<br />\n其實故事本身蠻黑暗的, 但實在很符合現在的社會情形.<br />\n<br />\n被人騙, 我無話好說, 也不想去報復什麼.<br />\n我只想以自己的經歷, 畫成故事, 提醒他人我悟出的道理.<br />\n就是這樣."}]}