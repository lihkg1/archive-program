moji\" />"},{"pid":"6485bfff6af3c2ec916d03ccd69f9f0236375310","tid":2056594,"uid":185651,"like":0,"dislike":0,"score":0,"quote":{"pid":"be68c026c8c729a6acae2616fecec22a154affda","tid":2056594,"uid":321837,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-08T23:11:16.000Z","msg":"咁男人有男朋友又有幾奇?"},"citedBy":0,"replyTime":"2020-06-08T23:39:34.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"648b4059d706799a67a4b01f4ba959caa6c6fcc4","tid":2056594,"uid":318634,"like":11,"dislike":3,"score":8,"citedBy":0,"replyTime":"2020-06-08T23:43:13.000Z","msg":"你呢啲冚家剷<br />\n唔好話我人生攻擊<br />\n死撚左去算<br />\n<br />\n有啲人係唔係咁賤格<br />\n唔抵得人哋好過佢<br />\n祝你以後個個比帽你<br />\n我用最惡毒嘅詛咒你<br />\n祝<br />\n你<br />\n之<br />\n後<br />\n個<br />\n個<br />\n比<br />\n帽<br />\n你"},{"pid":"479f57501434c7d0318c1e750cab46154b078d37","tid":2056594,"uid":170249,"like":5,"dislike":1,"score":4,"citedBy":0,"replyTime":"2020-06-08T23:44:15.000Z","msg":"不要暗戀，去強姦。人生沒有那麼多時間給你演內心戲。愛她就去搞她，喜歡就去強姦。表白有什麼用還是會被拒絕。追不到就下藥，翻臉就發裸照。大不了蹲監獄，你連監獄都不敢蹲還好意思說愛她。出來之後找到她繼續強姦，強姦到讓她開始懷疑自己的人生，讓她覺得她人生的意義就是被你強姦。"},{"pid":"b13cadbb120c0a0328c8b49565f613927253a17f","tid":2056594,"uid":126603,"like":0,"dislike":0,"score":0,"quote":{"pid":"438eac3dfe3ba1ddaa96891b1ae4d41e02b00ad5","tid":2056594,"uid":138752,"like":1,"dislike":12,"score":-11,"quote":{"pid":"cbf2429f25ce0ae319102d073c219f11bf6cfc4a","tid":2056594,"uid":326758,"like":0,"dislike":0,"score":0,"quote":{"pid":"004fc5ee7d01f72db7fa690321f3e7f634f30f87","tid":2056594,"uid":138752,"like":5,"dislike":5,"score":0,"citedBy":1,"replyTime":"2020-06-08T20:31:43.000Z","msg":"原來基嘅<br />\n咁我返屋企㗎啦喎<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-08T20:40:30.000Z","msg":"返咗唔會搞到人地女朋友<img src=\"/assets/faces/mouse/solution.gif\" class=\"hkgmoji\" />"},"citedBy":5,"replyTime":"2020-06-08T20:41:17.000Z","msg":"已經搞咗了<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-09T00