f78bfd4a1e9d1","tid":1850260,"uid":217761,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T14:21:44.000Z","msg":"推 <img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"384fff18732ce43a2cbe5da290443d5caa525a22","tid":1850260,"uid":289946,"like":0,"dislike":0,"score":0,"quote":{"pid":"2a9ca5c524a41fca668382ccd1111184b5b611f5","tid":1850260,"uid":289946,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-29T13:09:00.000Z","msg":"800舊好貴，入完有咩用? 立法會投到工程界別?"},"citedBy":0,"replyTime":"2020-01-29T14:23:17.000Z","msg":"推到樓豬答"},{"pid":"c77ebf92b0770997e3dba5d6677476b3e4263820","tid":1850260,"uid":177243,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T14:37:41.000Z","msg":"<img src=\"/assets/faces/lny/smile3.gif\" class=\"hkgmoji\" />"},{"pid":"6527771f000e4190826b93e46fd550c748a8d64f","tid":1850260,"uid":111859,"like":0,"dislike":0,"score":0,"quote":{"pid":"8bdb6a4b54fad1e8dfaab273a008b53de81f9dc2","tid":1850260,"uid":111859,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-29T12:31:22.000Z","msg":"工程界因為白色恐怖﹐冇人夠膽起工會<br />\n但係一個新總會其實係一個月前成立咗<br />\n<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><br />\n雖然建造業太多工種﹐<br />\n大家既訴求可以好唔同<br />\n但為咗集結咗依個界別既力量<br />\n籌委們想起一個總會聚集到同路人先﹐<br />\n<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" /><br />\n然後大家就可以按自己行業開番分工會﹐<br />\n團結自己同一業界既力量。<br />\n<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n為聲援醫護行業﹐<br />\n我地都會現場宣傳抗疫資訊<br />\n同派發白絲帶俾大家<br />\n有興趣幫工會一臂之力既都可以即場同籌委們傾傾計﹐了解工會多啲<br />\n<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n創建工程總會街站暨撐醫護白絲帶行動🎗 <br />\n<br />\n首日街站詳情如下：<br />\n日期：2020年1月30日 (星期四)<br />\n時間：下午1時至7時<br />\n地點：鰂魚涌站A出口<br />\n<br />\n**各位準會員請配戴口罩，<br />\n注意個人衛生。<br />\n<br />\n各位有興趣加入工會人仕，<br />\n只要提供以下文件及現金，<br />\n便可即時入會。<br />\n另外，籌委同義工<br />\n亦非常樂意解答大家問題。<br />\n<br />\n所需文件：<br />\n1. 身份證明<br />\n - 身份證<br />\n<br />\n2. 工作證明 / 學生證明<br />\n - 職員證、聘用合約、糧單；或<br />\n - 列明建築及工程相關科目<br />\n    為主修科目的Transcript / <br />\n    E-Student截圖<br />\n<br />\n3. $100入會費及$400 / 800年費 <br />\n - 現時處於下半年度，<br />\n    理應只需要$400元正。<br />\n    但籌委們一致決定，<br />\n    只要繳付$800元正，<br />\n    會藉有效日期會<br />\n    由2020年3月31日<br />\n    延至2021年3月31日。<br />\n<br />\n#standwithmedic #whiteribbon<br />\n#與醫護同行 #白絲帶<br />\n<br />\n#創建工程總會 #HKCEU <br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\nTelegram Channel：<br />\n<a href=\"https://t.me/HKCEU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FHKCEU&d=m5XrLHEHhhS4xH%2BSicsBH4VlFhl8e2VpHQ9vpRm7Uxg%3D&h=39f221f6\" data-auto-link target=\"_blank\">https://t.me/HKCEU</a><br />\nFacebook：<br />\n<a href=\"https://www.facebook.com/HKCEU/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FHKCEU%2F&d=m5XrLHEHhhS4xH%2BSicsBH4VlFhl8e2VpHQ9vpRm7Uxg%3D&h=a12df8fc\" data-auto-link target=\"_blank\">https://www.facebook.com/HKCEU/</a><br />\nInstagram：<br />\n<a href=\"https://instagram.com/HKCEU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Finstagram.com%2FHKCEU&d=m5XrLHEHhhS4xH%2BSicsBH4VlFhl8e2VpHQ9vpRm7Uxg%3D&h=eea29500\" data-auto-link target=\"_blank\">https://instagram.com/HKCEU</a><br />\nOnline application form：<br />\n<a href=\"https://forms.gle/K3oRY1UWWDQTYNre8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2FK3oRY1UWWDQTYNre8&d=m5XrLHEHhhS4xH%2BSicsBH4VlFhl8e2VpHQ9vpRm7Uxg%3D&h=8cb184a4\" data-auto-link target=\"_blank\">https://forms.gle/K3oRY1UWWDQTYNre8</a><br />\n<br />\n<img src=\"https://na.cx/i/YCxgaeJ.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FYCxgaeJ.png&h=6a1c744f&s={SIZE}\" /><br />\n <img src=\"https://na.cx/i/jNOi71s.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjNOi71s.jpg&h=b4eb27ee&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-01-29T14:54:53.000Z","msg":"知道大家有好多疑問，我係依度統一回大家<br />\n<br />\n<br />\n1.點解搞工會<br />\n搞工會，最主要嘅用途係團結自己業界嘅力量，其他行業都有細工會，唯獨我哋依家行只有總會，就係因為冇人夠膽出黎，大家都非常驚白色恐怖，所以希望用總會嘅力量，團結左一堆同路人先，工會只係一個平台，比大家可以發聲同互相幫助，大家肯出錢出力嘅話，最後啲會費都係用係自己度。<br />\n2.會費問題<br />\n會費嘅用途包括日常營運開支、auditing 、搞活動、法律開支（如有需要）、支援基金（佔一半）<br />\n我哋係獨立工會，經濟上同行政人力上冇任何政黨包括括職工盟幫助，一切既然都要由頭開始<br />\n另外，其實其他國家嘅會費都係年薪嘅1%左右，如果唔係工業基金根本冇可能支撐到<br />\n<br />\n3.功能組別<br />\n工程界，建測規園界嘅功能組別，只有相關學會嘅成員先可以投到，加入工會唔會有票<br />\n<br />\n如果有其他問題，歡迎係Telegram公海問"},{"pid":"8672b97f2b871402829b3b3f62ccee948841447a","tid":1850260,"uid":177243,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T16:25:50.000Z","msg":"瞓前一推"},{"pid":"68320ca51d09ae9c5fd55f2459f8b66adb596df7","tid":1850260,"uid":107686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T17:03:13.000Z","msg":"<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},{"pid":"260c1266eea2db8c385d4b075680457537b157e6","tid":1850260,"uid":296369,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T17:17:28.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"6b06d15459f6dfaeb05e986fdb672adfe49983c5","tid":1850260,"uid":86545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T00:27:07.000Z","msg":"推<img src=\"https://na.cx/i/Z0Sgeqi.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZ0Sgeqi.jpg&h=8a43e084&s={SIZE}\" />"},{"pid":"3a8bc4179f5f6280405d672d9eb24ddf0e6b25fa","tid":1850260,"uid":262966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T00:53:01.000Z","msg":"推"},{"pid":"a85b1747289619fe07194f81bcaf3edf81fbfbf5","tid":1850260,"uid":177243,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T03:48:56.000Z","msg":"推"},{"pid":"0dab40fee4c83a4f128973a6bb81f5a0fb050933","tid":1850260,"uid":10628,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T05:45:09.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"718a16d04e45172db871fd81b88753bca6f77bf8","tid":1850260,"uid":10628,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T05:45:24.000Z","msg":"推撚爆你"},{"pid":"31166566196f5e335c48c399d17a575f0d19813f","tid":1850260,"uid":10628,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-30T05:45:35.000Z","msg":"光"},{"pid":"c186aaca00a5a13d90a0ef50105aedd9b5659c53","tid":1850260,"uid":223643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T05:45:44.000Z","msg":"【疫情展望】手足做好防護措施，去到 Phase II. 就仆街<br />\n<a href=\"https://lih.kg/1850403\" data-auto-link target=\"_blank\">https://lih.kg/1850403</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n推"},{"pid":"1bf8ea285aba1e3abd48f33ab09428c0860e1351","tid":1850260,"uid":10628,"like":0,"dislike":0,"score":0,"quote":