xgaeJ.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FYCxgaeJ.png&h=6a1c744f&s={SIZE}\" /><br />\n <img src=\"https://na.cx/i/jNOi71s.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjNOi71s.jpg&h=b4eb27ee&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-01-30T09:10:32.000Z","msg":"工作證明 卡片得唔得？"},"citedBy":0,"replyTime":"2020-01-30T14:49:03.000Z","msg":"有寫你職位就可以"},{"pid":"88ad1bfcc086b206315ae6d69f67fee1c1982db5","tid":1850260,"uid":9640,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T14:50:20.000Z","msg":"辛苦晒巴打<img src=\"/assets/faces/lny/cry.gif\" class=\"hkgmoji\" /><br />\n一個工會真係唔簡單<br />\n<br />\n借一借位<br />\n<br />\n//<br />\n<br />\n<span style=\"color: orange;\"><span style=\"font-size: x-large;\">有冇傳媒及出版嘅朋友<img src=\"/assets/faces/lny/cry.gif\" class=\"hkgmoji\" /><br />\n組織工會 全面罷工</span></span><br />\n- - -<br />\n<span style=\"font-size: small;\">［港共不封關，全港冚家剷］香港傳媒及出版職工會-籌組中<br />\n<a href=\"https://lih.kg/1847821\" target=\"_blank\">https://lih.kg/1847821</a><br />\n- 分享自 LIHKG 討論區<br />\n又一個工會準備誕生啦<img src=\"/assets/faces/lny/agree2.gif\" class=\"hkgmoji\" /><br />\n路過入黎幫手推個post  謝謝<br />\n</span>"},{"pid":"68724a36e8f6a6155cfc034abda3bc2a9b0409d9","tid":1850260,"uid":258758,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T14:51:09.000Z","msg":"Push"},{"pid":"f04311d0ad3b0be85f72c10bb5623be74c39f795","tid":1850260,"uid":258758,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T14:51:19.000Z","msg":"Push"},{"pid":"39f541fb966654620a2c8b86132ea36a914a2343","tid":1850260,"uid":60129,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T14:51:26.000Z","msg":"聽日元朗<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n一 定 到 ！"},{"pid":"34a76517d9afac317886f2fdefaad70e0f143663","tid":1850260,"uid":9640,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T14:51:58.000Z","msg":"順手睇下自己有冇中<img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n［緊急］選民住址核查既回覆期限 1月31日截止 查中你你又唔回 就會取消投票資格<br />\n<a href=\"https://lih.kg/1851207\" data-auto-link target=\"_blank\">https://lih.kg/1851207</a><br />\n- 分享自 LIHKG 討論區"}],"pinned":{"pid":"6527771f000e4190826b93e46fd550c748a8d64f","tid":1850260,"uid":111859,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T14:54:53.000Z","msg":"知道大家有好多疑問，我係依度統一回大家<br />\n<br />\n<br />\n1.點解搞工會<br />\n搞工會，最主要嘅用途係團結自己業界嘅力量，其他行業都有細工會，唯獨我哋依家行只有總會，就係因為冇人夠膽出黎，大家都非常驚白色恐怖，所以希望用總會嘅力量，團結左一堆同路人先，工會只係一個平台，比大家可以發聲同互相幫助，大家肯出錢出力嘅話，最後啲會費都係用係自己度。<br />\n2.會費問題<br />\n會費嘅用途包括日常營運開支、auditing 、搞活動、法律開支（如有需要）、支援基金（佔一半）<br />\n我哋係獨立工會，經濟上同行政人力上冇任何政黨包括括職工盟幫助，一切既然都要由頭開始<br />\n另外，其實其他國家嘅會費都係年薪嘅1%左右，如果唔係工業基金根本冇可能支撐到<br />\n<br />\n3.功能組別<br />\n工程界，建測規園界嘅功能組別，只有相關學會嘅成員先可以投到，加入工會唔會有票<br />\n<br />\n如果有其他問題，歡迎係Telegram公海問"}}