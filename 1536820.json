/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F2GKH20p.png&h=6178433f&s={SIZE}\" />"},{"pid":"26e71bf4b173c4822557ed916385ab8df0c0c11c","tid":1536820,"uid":94978,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-03T17:27:24.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"c811b43623aaa414c838b263847d45cf0e0e577c","tid":1536820,"uid":127929,"like":0,"dislike":0,"score":0,"quote":{"pid":"26e71bf4b173c4822557ed916385ab8df0c0c11c","tid":1536820,"uid":94978,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-03T17:27:24.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-03T17:30:20.000Z","msg":"呢啲post真係要日日開, 日日睇到個個識為止"},{"pid":"b78b65ec89e60378fcb94151372609b43ae9fb96","tid":1536820,"uid":127929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T17:32:18.000Z","msg":"<span style=\"color: red;\">無罪推斷</span><br />\n<br />\n香港係無罪推斷既，<span style=\"color: red;\">警察用有罪推斷先認定你已犯法叫你即場解釋係原則錯誤</span>，你係一個無犯法既<span style=\"color: red;\">良好市民，所以大家完全冇必要去答佢地啲無聊問題</span>(e.g. 你做咩有張小童八達通係身？做咩有法律支援字條係袋？做咩有gear係袋仲要係現場？係咪用黎參與非法集會？係咪預左比人拉？)"},{"pid":"8a68d263f2ea26bdcd05eb2a39baee54d0f3b78a","tid":1536820,"uid":143016,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-03T17:36:07.000Z","msg":"pish"},{"pid":"c1ce4aa8c067589f1ca0cbc1150121a95c8375f0","tid":1536820,"uid":127929,"like":0,"dislike":0,"score":0,"quote":{"pid":"8a68d263f2ea26bdcd05eb2a39baee54d0f3b78a","tid":1536820,"uid":143016,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-03T17:36:07.000Z",