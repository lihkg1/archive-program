f8a1e8b2a826e7","tid":2139654,"uid":181581,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-08-04T12:19:42.000Z","msg":"我要痾爛屎<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-04T12:23:33.000Z","msg":"0分重作 <img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" />"},{"pid":"99475272143ee523ed25a5cf3254aa4f7095f56e","tid":2139654,"uid":339751,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-04T12:23:34.000Z","msg":"想去大便"},{"pid":"45e57e589dd614ff5aefd25a1a193edd530bc627","tid":2139654,"uid":27664,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-04T12:25:03.000Z","msg":"去柯個石"},{"pid":"34f20d394497db8f4858fbe8be356923e7048320","tid":2139654,"uid":35930,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-04T12:25:05.000Z","msg":"我依家要去刺激下大腸, 令括約肌能夠棄置果d廢物同埋果d毒素呀!"},{"pid":"74f9c2141405a89b8ea30237d5213a8c6dacb3bd","tid":2139654,"uid":191338,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-04T12:26:32.000Z","msg":"帶細路落街去遊樂場放電<br />\n<br />\n帶小朋友入廁所撒黑傾 <img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n毋忘八三一<br />\n每日撒黑傾"},{"pid":"4fddc0bcf53183fafd1a3a3fb1714e16cbf52e30","tid":2139654,"uid":112997,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-04T12:29:18.000Z","msg":"解決生理需要，出吓嘢"},{"pid":"655aaea71c462d1093d852cf048e9e768238e696","tid":2139654,"uid":156913,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-04T12:33:19.000Z","msg":"出恭"},{"pid":"7410bb451052f35ba078fb1ebf864abc27994b70","tid":2139654,"uid":191338,"like":1,"dislike":0,"score":1,"quote":{"pid":"2f90e3b8ee2aebaec1058976dade5210a920c561","tid":2139654,"uid":55493,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-08-04T12:15:39.000Z","msg":"婉轉 出恭"},"citedBy":0,"replyTime":"2020-08-04T12:58:40.000Z","msg":"「出恭」這詞，原本和上廁所大小便沒有什麼關係，可為什麼後來成了上廁所的代名詞了呢？這還得從隋朝創立的科舉制開始說起。<br />\n<br />\n隋煬帝楊堅創立了科舉制度，對國家選拔人才、社會階層流動、社會和諧穩定，起到了非常重大的意義和作用。古代科考也和現在高考一樣，基本上就是一考定終身，無論國家、個人，都非常重視，所以科考場面也是非常壯大，盛況空前。當時科考都是每個人一個小房間，俗稱「號舍」，考試的這幾天，考生是不能輕易離開號舍的。據史料記載，位於南京的江南貢院是全國最大的科舉考場，有號舍20644間，也就是說同時可以容納兩萬多考生，再加上監考人員，這麼多人，上廁所就成了人們最頭痛的問題。<br />\n古代科舉考試的時候，也是允許大小便的，號舍內都備有一小桶，小便在號舍內自行解決，就怕遇到大便，那就有點麻煩了，還要把試卷交給考官，然後在監考人員陪同監督下去大便，完事再接着考。<br />\n<br />\n不過到後來，從元代起，科舉考場開始越來越人性化，考場內設有「出恭」、「入敬」牌子，以防止學子們擅離座位。學子們再要大小便，就不用監考人員陪同了，直接領塊牌子即可，上寫「出恭入敬」，憑牌就可以進出廁所和考場。好像古代衙門裏打出的「威武」、「肅靜」的牌子，主要為了表示莊嚴，恭敬。雖說是內急，但作為文人學子，還是要有文人的作風，就算去廁所，也要恭恭敬敬，不失禮儀，出入安靜，不能干擾他人，這也體現了國家對科考的恭敬和尊重。<br />\n<br />\n雖然這個牌子上的「出恭入敬」並不是去廁所的意思，但是大家一舉這個牌子，就知道是這人要上廁所了，所以慢慢大家就把上廁所看出「出恭入敬」了，四個字說起來又不順口，乾脆就直接取前面兩個字，於是，「出恭」一次慢慢就流傳開了。<br />\n「出恭」既然成了上廁所的代名詞，後來人們索性就把大便引申為「出大恭」，小便叫「出小恭」，放屁叫「出虛恭」，最後連馬桶都稱作「恭桶」了。<br />\n<br />\n<br />\n恭喜<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"1ec821af58d0cb5f6f490bed53192da5adefa285","tid":2139654,"uid":191338,"like":0,"dislike":0,"score":0,"quote":{"pid":"4fddc0bcf53183fafd1a3a3fb1714e16cbf52e30","tid":2139654,"uid":112997,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-04T12:29:18.000Z","msg":"解決生理需要，出吓嘢"},"citedBy":0,"replyTime":"2020-08-04T13:02:01.000Z","msg":"<span class=\"xx-large\"><strong><span class=\"maroon\">解放大雄</span></strong></span><br />\n<br />\n<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"a57cc823bd92d6a746cde683d1f864cd66d8e53e","tid":2139654,"uid":191338,"like":0,"dislike":0,"score":0,"quote":{"pid":"655aaea71c462d1093d852cf048e9e768238e696","tid":2139654,"uid":156913,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-04T12:33:19.000Z","msg":"出恭"},"citedBy":0,"replyTime":"2020-08-04T13:07:10.000Z","msg":"舊時啲皇帝成日話要出宮<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}