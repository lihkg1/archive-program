rc=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-07T05:35:04.000Z","msg":"你唔識用啟用？"},"citedBy":0,"replyTime":"2018-04-07T05:53:16.000Z","msg":"應該係通車"},{"pid":"77073ea26fb4dd64b95126489a1f127affa838a0","tid":619800,"uid":177590,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-07T06:10:57.000Z","msg":"白事紅事做嘛<br />\n中國人傳統"}]}