/faces/lny/dead.gif\" class=\"hkgmoji\" />"},{"pid":"a2ce93ef2b2af14acc23ba125b0748939a61929c","tid":1016620,"uid":147892,"like":27,"dislike":0,"score":27,"citedBy":1,"replyTime":"2019-02-11T02:54:25.000Z","msg":"車仔近年成績一直番唔到前列<br />\n就係因為成撚日轉領隊<br />\n你睇人地利物浦 曼城 係呀人腳係好好呀成績係有呀<br />\n但講緊高普係利已經教到第四第五年 而哥狗都教左曼城第三個年頭<br />\n而且班主亦有科水比佢地買人增兵 先可以達到咁既水平<br />\n屌你車仔近年半年唔夠成績差少少就嗌換領隊<br />\n班球迷輸一場兩場就#sarriout<br />\n班主又唔比錢買下人<br />\n咁你就唔好旨意有爭冠軍既實力啦<br />\n爭前四咪算囉<br />\n而家既車仔同一兩年前既阿記有咩分別?"},{"pid":"6ae2a77ab28b219de5bdd1a18867613f7aa41872","tid":1016620,"uid":37383,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-11T03:13:11.000Z","msg":"哥帥講話班主要絕對信任自己，個分別都已經好明顯"},{"pid":"91db0127171b65d1deda2b234423a1483fd080bd","tid":1016620,"uid":33775,"like":2,"dislike":4,"score":-2,"quote":{"pid":"a2ce93ef2b2af14acc23ba125b0748939a61929c","tid":1016620,"uid":147892,"like":27,"dislike":0,"score":27,"citedBy":1,"replyTime":"2019-02-11T02:54:25.000Z","msg":"車仔近年成績一直番唔到前列<br />\n就係因為成撚日轉領隊<br />\n你睇人地利物浦 曼城 係呀人腳係好好呀成績係有呀<br />\n但講緊高普係利已經教到第四第五年 而哥狗都教左曼城第三個年頭<br />\n而且班主亦有科水比佢地買人增兵 先可以達到咁既水平<br />\n屌你車仔近年半年唔夠成績差少少就嗌換領隊<br />\n班球迷輸一場兩場就#sarriout<br />\n班主又唔比錢買下人<br />\n咁你就唔好旨意有爭冠軍既實力啦<br />\n爭前四咪算囉<br />\n而家既車仔同一兩年前既阿記有咩分別?"},"citedBy":0,"replyTime":"2019-02-11T03:16:52.000Z","msg":"乾爹第一年就拎左英超<br />\n高普拎左咩? 英超挑戰盃?"},{"pid":"20b5b0c693765caf2d3c76c4a188a8a310ac655e","tid":1016620,"uid":55897,"like":0,"dislike":0,"score":0,"quote":{"pid":"21dc22f1b18edb760bf212191f8b74eced5f4ea9","tid":1016620,"uid":85284,"like":1,"dislike":78,"score":-77,"citedBy":4,"replyTime":"2019-02-11T00:51:38.000Z","msg":"恕我直言<br />\n呢啲就係貨真價實，真材實料，同流嘢嘅分別<br />\n有料嘅領隊／教練，喺平時日常嘅球隊訓練裡面<br />\n由陣式，陣法，打法<br />\n球員於進攻／防守，攻守轉換嘅企位，走位，補位<br />\n一來係經過長期一路修正<br />\n二來係因應現役球員特性，優／弱點<br />\n一下一下打造而成<br />\n當中嘅計算，係包括思考點樣用一個相同結構嘅陣法／戰術為基礎<br />\n嚟面對各式各樣不同戰術，陣法，特性嘅對手時<br />\n己隊都會相對容易站於有優勢嘅一面<br />\n而當中好多細節位<br />\n並唔係啲平庸領隊可以明白，理解同知曉<br />\n對我嚟講<br />\nSarri 同 Klopp 都係同一級別／類型嘅領隊<br />\n同 Guardiola 係完全唔同級數<br />\n呢啲唔係短線邊個贏輸嘅事<br />\n而係宏觀嘅事"},"citedBy":0,"replyTime":"2019-02-11T03:17:36.000Z","msg":"Klopp 買在人返來唔係即用,佢會TURN到佢踢到自己要求先出.唔夠人用傷在先會用人頂上.但佢換人都係慢,戰術其實佢都會變,但效果不大"},{"pid":"d4d2e9ab9c5e935b168ab3010f48be8d1ccd0060","tid":1016620,"uid":27591,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2019-02-11T03:21:16.000Z","msg":"kloop我覺得高sarri半班,因為拎過聯賽冠軍<br />\n但哥帥真係高,本來諗住淨係識得金錢攻擊,但其實唔係<br />\n睇下sterling,完全覺醒咁"},{"pid":"d59d1cf3f4f23078c57cc7be514f9a5c554c1e07","tid":1016620,"uid":5649,"like":0,"dislike":0,"score":0,"quote":{"pid":"d4d2e9ab9c5e935b168ab3010f48be8d1ccd0060","tid":1016620,"uid":27591,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2019-02-11T03:21:16.000Z","msg":"kloop我覺得高sarri半班,因為拎過聯賽冠軍<br />\n但哥帥真係高,本來諗住淨係識得金錢攻擊,但其實唔係<br />\n睇下sterling,完全覺醒咁"},"citedBy":0,"replyTime":"2019-02-11T03:22:54.000Z","msg":"Sarri 91分亞軍，講真當半個冠軍教頭啦"},{"pid":"b6f60986df56b9b2fbe669bf2f975c606228ded8","tid":1016620,"uid":26959,"like":8,"dislike":1,"score":7,"quote":{"pid":"97825906b7be56fbbc2478340d2483112fb2c6c9","tid":1016620,"uid":130060,"like":13,"dislike":0,"score":13,"citedBy":1,"replyTime":"2019-02-11T02:21:55.000Z","msg":"唔撚淨係講戰術啦 講人腳可能性<br />\n<br />\n你後備有odoi 意虎切同飲水 你唔諗下點用<br />\n<br />\n死攬佐真奴都夠你比人炒啦<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-11T03:27:33.000Z","msg":"哩三件點會好得過jorginho <br />\n咪玩"},{"pid":"58aa8737b6acd7095e1b23a0e4abd6176a66181a","tid":1016620,"uid":150781,"like":3,"dislike":0,"score":3,"quote":{"pid":"d4d2e9ab9c5e935b168ab3010f48be8d1ccd0060","tid":1016620,"uid":27591,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2019-02-11T03:21:16.000Z","msg":"kloop我覺得高sarri半班,因為拎過聯賽冠軍<br />\n但哥帥真係高,本來諗住淨係識得金錢攻擊,但其實唔係<br />\n睇下sterling,完全覺醒咁"},"citedBy":0,"replyTime":"2019-02-11T03:28:57.000Z","msg":"鏝嗰套戰術，同訓練太有系統，你睇啲走位，傳送，配合就知。"},{"pid":"f4f33b0901f7fd0c7ff42afb671836e0c847fa01","tid":1016620,"uid":37413,"like":1,"dislike":0,"score":1,"quote":{"pid":"2ba8