,"tid":543080,"uid":34103,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-01-28T08:08:21.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-01-28T08:26:32.000Z","msg":"<span style=\"font-size: xx-large;\">五毛dewi</span>"},{"pid":"65dc7975ec136ac8b283ee4e4828df0ad6f7ed50","tid":543080,"uid":34103,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-28T08:27:29.000Z","msg":"此回覆已被刪除"},{"pid":"e3b227e1afc9b6ecc9f8031da7ff1fdebf9bb138","tid":543080,"uid":128603,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-28T08:29:29.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/01/28/162922_81aba24c1af084ac1d23fea9f230c0e1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F28%2F162922_81aba24c1af084ac1d23fea9f230c0e1.jpg&h=1ee9e940&s={SIZE}\" />"},{"pid":"da66322e55199c273f4d99349645f69412391463","tid":543080,"uid":47359,"like":0,"dislike":0,"score":0,"quote":{"pid":"65dc7975ec136ac8b283ee4e4828df0ad6f7ed50","tid":543080,"uid":34103,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-28T08:27:29.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-01-28T08:32:13.000Z","msg":"五毛同泛民打手聯手呀？"},{"pid":"209a3902e414b142dda25d85b453f9d9fe38364d","tid":543080,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-28T09:02:30.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c5152ea703d50746c6fc416b785caa2f5a27dd99","tid":543080,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-28T09:57:44.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}