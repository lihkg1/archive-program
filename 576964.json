ews.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20180301%2F57891677&d=%2FZa3iQc4fltFCp5TNCbeKzPUa9iY%2BpOmOVTB4fMSqaQ%3D&h=f2c7bd2a\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20180301%2F57891677&h=15885739\" target=\"_blank\">https://hk.news.appledaily.com/local/realtime/article/20180301/57891677</a><br />\n<br />\n應該好大波<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /></blockquote><br />\n條女䦨痕點知條仔唔show佢惱羞成怒咋？"},{"pid":"d17c720b9a0a86e231b403048e8fafdeb4250613","tid":576964,"uid":63670,"like":39,"dislike":1,"score":38,"citedBy":1,"replyTime":"2018-03-01T12:01:36.000Z","msg":"又開被告名<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"8f88289347aacf03b957b175ef81dd2e9cb0cca0","tid":576964,"uid":101895,"like":9,"dislike":1,"score":8,"citedBy":1,"replyTime":"2018-03-01T12:03:33.000Z","msg":"只係渣左兩下點會告到上法庭丫. 肯能定有d 野傾唔掂數"},{"pid":"a969be4c30b9f548fef67f3db37a6d951baf2db8","tid":576964,"uid":105552,"like":4,"dislike":2,"score":2,"citedBy":0,"replyTime":"2018-03-01T12:05:32.000Z","msg":"<blockquote>只係渣左兩下點會告到上法庭丫. 肯能定有d 野傾唔掂數</blockquote><br />\n辯方：點解被告同你紋身你仲要收番佢錢?"},{"pid":"2bbdd0f24204fe391c1149647c8bb55fa5b931b7","tid":576964,"uid":102700,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-03-01T12:07:04.000Z","msg":"紋身師<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"c70de6ed7df5e5b3b195f500b70d8947d3a82f35","tid":576964,"uid":39177,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-03-01T12:10:14.000Z","msg":"呢個紋身都幾高質"},{"pid":"82dee0adf60ee4b657373346d6b62e3419f6abcb","tid":576964,"uid":12021,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-01T12:17:57.000Z","msg":"此回覆已被刪除"},{"pid":"c9e06cd0af63f5f98d95b0e1ab6c17882b65fdec","tid":576964,"uid":74751,"like":84,"dislike":13,"score":71,"citedBy":3,"replyTime":"2018-03-01T12:53:11.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/03/01/205305_35