verpool 同Birmingham睇下。<br />\n<br />\n我覺得到到差唔多<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />暫時遇到啲人都幾Nice。"},{"pid":"8462f029bf44e97fb1392bf83c97307a78da41ac","tid":2315432,"uid":39802,"like":0,"dislike":0,"score":0,"quote":{"pid":"7de02e36a8de80f3f2798d57354481a2ba08abf9","tid":2315432,"uid":146038,"like":0,"dislike":0,"score":0,"quote":{"pid":"76e365a7712956c559b1183700c8e35580c6d4f3","tid":2315432,"uid":26071,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-08T05:54:06.000Z","msg":"專業人士: London<br />\n非專業: Bristol / Edinburgh<br />\n<br />\n基層工倫敦係搵多少少<br />\n但係生活成本高 <br />\n日日喺zone 5/6逼underground入central真係不了"},"citedBy":2,"replyTime":"2020-12-08T14:37:23.000Z","msg":"Cheltenham, Reading 又好唔好呢?"},"citedBy":2,"replyTime":"2020-12-09T20:44:37.000Z","msg":"Cheltenham好架 睇你有幾錢<br />\n但係如果你火車出入london season ticket就唔野少"},{"pid":"8079848fa93befdabab8ec3c21b5ed975e905aa2","tid":2315432,"uid":368910,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d9e62dd2a7a46f5195a91fc2cb2e602110fb456","tid":2315432,"uid":218313,"like":2,"dislike":0,"score":2,"quote":{"pid":"17f8c8d7248bd2e10c3176b556677fde2457554d","tid":2315432,"uid":89388,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2020-12-07T12:44:58.000Z","msg":"伯明翰 聽講好平"},"citedBy":4,"replyTime":"2020-12-08T06:12:01.000Z","msg":"聽講治安好差 <img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-09T21:22:04.000Z","msg":"爆格<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b154e656d604456e3ea71c291fe063cc812c82f1","tid":2315432,"uid":73311,"like":0,"dislike":0,"score":0,"quote":{"pid":"abb10b1cbfe314ceaf7a33217589c883ca761563","tid":2315432,"uid":268516,"like":0,"dislike":1,"score":-1,"quote":{"pid":"d7d036cdadbf9392dd132bb33174d742ca04d59e","tid":2315432,"uid":73311,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d9e62dd2a7a46f5195a91fc2cb2e602110fb456","tid":2315