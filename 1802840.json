":"e19cd56b4c21a1ea9557e84050b73f2c0da42a0a","tid":1802840,"uid":325206,"like":0,"dislike":0,"score":0,"quote":{"pid":"d6eb320a27ec85c5218db452197ee0217605bbd4","tid":1802840,"uid":147651,"like":0,"dislike":0,"score":0,"quote":{"pid":"23a5fadb3704252d610ec761eb7edad65b6d369d","tid":1802840,"uid":300782,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-29T22:22:57.000Z","msg":"絲打你渣飛機架？<br />\n移民去邊呀？<br />\n<br />\n我都係一個人移民"},"citedBy":2,"replyTime":"2019-12-30T05:27:13.000Z","msg":"居然有巴打睇得出<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n巴打喺澳洲？？<br />\n<br />\n我去日本，打算坐5-10年移民監，攞埋護照先返嚟<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-05T00:41:13.000Z","msg":"<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-05T00:54:40.000Z","msg":"日本唔係無移民法攞唔到passport咩？"}]}