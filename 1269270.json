n9U6r9qhj6P8u-Gw3h09-I2Z-FiEeHva9sXAa2f0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fvimeo.com%2F345289386%3Ffbclid%3DIwAR0wV65rUm4U5wlMpAfn9U6r9qhj6P8u-Gw3h09-I2Z-FiEeHva9sXAa2f0&d=O1gn%2BLisHAK1lZrgQK9vXPjlBAU1VhUdv3lOLHlSYeE%3D&h=81725341\" target=\"_blank\">https://vimeo.com/345289386?fbclid=IwAR0wV65rUm4U5wlMpAfn9U6r9qhj6P8u-Gw3h09-I2Z-FiEeHva9sXAa2f0</a><br />\n<br />\n毆打襲擊和平示威者或者路人<br />\n<a href=\"https://www.facebook.com/pat.cheung.10/videos/10159553422809815/UzpfSTU0NDgzMTIwMDoxMDE1Njk3OTM3MjY5NjIwMQ/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fpat.cheung.10%2Fvideos%2F10159553422809815%2FUzpfSTU0NDgzMTIwMDoxMDE1Njk3OTM3MjY5NjIwMQ%2F&d=O1gn%2BLisHAK1lZrgQK9vXPjlBAU1VhUdv3lOLHlSYeE%3D&h=e4233ee3\" target=\"_blank\">https://www.facebook.com/pat.cheung.10/videos/10159553422809815/UzpfSTU0NDgzMTIwMDoxMDE1Njk3OTM3MjY5NjIwMQ/</a><br />\n<br />\n<a href=\"https://www.facebook.com/hk.nextmedia/videos/346650589360448/?q=%E9%A6%99%E6%B8%AF%E8%98%8B%E6%9E%9C%E6%97%A5%E5%A0%B1&amp;epa=SEARCH_BOX\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fhk.nextmedia%2Fvideos%2F346650589360448%2F%3Fq%3D%25E9%25A6%2599%25E6%25B8%25AF%25E8%2598%258B%25E6%259E%259C%25E6%2597%25A5%25E5%25A0%25B1%26epa%3DSEARCH_BOX&d=O1gn%2BLisHAK1lZrgQK9vXPjlBAU1VhUdv3lOLHlSYeE%3D&h=86bf481c\" target=\"_blank\">https://www.facebook.com/hk.nextmedia/videos/346650589360448/?q=%E9%A6%99%E6%B8%AF%E8%98%8B%E6%9E%9C%E6%97%A5%E5%A0%B1&amp;epa=SEARCH_BOX</a><br />\n<br />\n撐警市民不滿安排混亂 索性佔領馬路<br />\n<a href=\"https://na.cx/i/3zY05KZ.jpg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fna.cx%2Fi%2F3zY05KZ.jpg&d=O1gn%2BLisHAK1lZrgQK9vXPjlBAU1VhUdv3lOLHlSYeE%3D&h=c0fac427\" target=\"_blank\">https://na.cx/i/3zY05KZ.jpg</a><br />\n<br />\n口口聲聲話愛護香港 但隨地棄置大量垃圾<br />\n<a href=\"https://na.cx/i/r3SX7Yv.jpg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fna.cx%2Fi%2Fr3SX7Yv.jpg&d=O1gn%2BLisHAK1lZrgQK9vXPjlBAU1VhUdv3lOLHlSYeE%3D&h=a583e5af\" target=\"_blank\">https://na.cx/i/r3SX7Yv.jpg</a><br />\n<br />\n有撐警示威者向《蘋果》攝影記者及《立場新聞》女記者吐口水；其中女記者更被「藍絲」斥是性工作者、「做雞好過做人」。<br />\n<a href=\"https://na.cx/i/M40ScqH.png\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fna.cx%2Fi%2FM40ScqH.png&d=O1gn%2BLisHAK1lZrgQK9vXPjlBAU1VhUdv3lOLHlSYeE%3D&h=19c81566\" target=\"_blank\">https://na.cx/i/M40ScqH.png</a><br />\n<br />\n17:45 | 「撐警」示威者一度嘗試衝入立法會<br />\n<a href=\"https://lihkg.com/thread/1268519/page/1\" target=\"_blank\">https://lihkg.com/thread/1268519/page/1</a><br />\n<br />\n18:03 金鐘A出口衝突<br />\n<a href=\"https://lihkg.com/thread/1268317/page/1?post=1\" target=\"_blank\">https://lihkg.com/thread/1268317/page/1?post=1</a><br />\n<br />\n女途人被暴徒重錘打中後腦<br />\n<a href=\"https://na.cx/i/oYGRtak.gif\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fna.cx%2Fi%2FoYGRtak.gif&d=O1gn%2BLisHAK1lZrgQK9vXPjlBAU1VhUdv3lOLHlSYeE%3D&h=9414924d\" target=\"_blank\">https://na.cx/i/oYGRtak.gif</a><br />\n<br />\n警員被暴徒從後側襲<br />\n<a href=\"https://na.cx/i/98eGQpQ.gif\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fna.cx%2Fi%2F98eGQpQ.gif&d=O1gn%2BLisHAK1lZrgQK9vXPjlBAU1VhUdv3lOLHlSYeE%3D&h=06b5dd48\" target=\"_blank\">https://na.cx/i/98eGQpQ.gif</a>"},{"pid":"56f42cf4afd81db615eef483ef9a508cec2707dc","tid":1269270,"uid":191740,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T14:44:14.000Z","msg":"整合完，比外謀睇下班驚衛兵幾咁威風八面"},{"pid":"210a4e8cbf238a5c6d9b80b0ec1b22d9acad9385","tid":1269270,"uid":76286,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T14:44:38.000Z","msg":"<strong><strong><span style=\"font-size: xx-large;\">認同請分享!</span></strong></strong>"},{"pid":"e5fb04cece46d71585af8e449d729c7f3d9ff148","tid":1269270,"uid":76286,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T14:46:39.000Z","msg":"push"},{"pid":"07b79707d6808af909a3f4bbccac283d69a6547a","tid":1269270,"uid":76286,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T14:48:18.000