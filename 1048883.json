 whale vomit.[9]<br />\n<br />\n<br />\n<a href=\"https://en.m.wikipedia.org/wiki/Ambergris\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fen.m.wikipedia.org%2Fwiki%2FAmbergris&d=tUmqA7E7lgkQFc9zeVIKXugAExyYYV7WT87CuOwwBqU%3D&h=167c4ccc\" data-auto-link target=\"_blank\">https://en.m.wikipedia.org/wiki/Ambergris</a><br />\n<br />\n所以，細size 可以屙屎，大size 可以嘔屎<br />\n<br />\n打和<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"38868433815ca530c08fca9eddd91dee5720f9bc","tid":1048883,"uid":3835,"like":0,"dislike":1,"score":-1,"quote":{"pid":"329284956593616c8c93aa2672935d1a18cf1482","tid":1048883,"uid":2613,"like":160,"dislike":3,"score":157,"citedBy":1,"replyTime":"2019-03-06T02:10:22.000Z","msg":"400萬已經可以退休<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-06T05:54:32.000Z","msg":"咁人地本身可能已經有400萬呢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7eeba8de2eb18ac6669a2c6ecf865b17ee0b2fb7","tid":1048883,"uid":52701,"like":3,"dislike":0,"score":3,"quote":{"pid":"38868433815ca530c08fca9eddd91dee5720f9bc","tid":1048883,"uid":3835,"like":0,"dislike":1,"score":-1,"quote":{"pid":"329284956593616c8c93aa2672935d1a18cf1482","tid":1048883,"uid":2613,"like":160,"dislike":3,"score":157,"citedBy":1,"replyTime":"2019-03-06T02:10:22.000Z","msg":"400萬已經可以退休<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-06T05:54:32.000Z","msg":"咁人地本身可能已經有400萬呢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-06T05:55:56.000Z","msg":"泰國生活指數低咁多，400萬可以退休唔出奇"},{"pid":"12a9b87f32128a368b0c19e25c1b81ea0dcb669b","tid":1048883,"uid":5523,"like":0,"dislike":0,"score":0,"quote":{"pid":"3800d1708a6954ec1814ce07d8d160a0421b0b1e","tid":1048883,"uid":132957,"like":68,"dislike":1,"score":67,"quote":{"pid":"867797e9219ae2c2a2ccbccfed0bedb2fc27e389","tid":1048883,"uid":46042,"like":1151,"dislike":7,"score":1144,"citedBy":5,"r