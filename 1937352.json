id":"68957dea35360419ad70b9a46819bd258febc692","tid":1937352,"uid":292710,"like":0,"dislike":0,"score":0,"quote":{"pid":"42569f3ce2397282d9aec68f1962e2ec59fd9e47","tid":1937352,"uid":19552,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-03-21T23:59:47.000Z","msg":"美國就係一個有仇必報既國國家"},"citedBy":1,"replyTime":"2020-03-22T00:04:28.000Z","msg":"賠款+割地？"},"citedBy":0,"replyTime":"2020-03-22T02:33:17.000Z","msg":"可唔可以割香港俾佢？"},{"pid":"4caee960e3e6a58cdd72c3f7d0d77f2f2d526359","tid":1937352,"uid":28114,"like":0,"dislike":0,"score":0,"quote":{"pid":"373aa5b793b74036a5a8d9603d45cd7ed135c38c","tid":1937352,"uid":201036,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-03-22T00:22:04.000Z","msg":"班Democrat 左膠去撚咗邊？"},"citedBy":0,"replyTime":"2020-03-22T03:09:08.000Z","msg":"瞓緊<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"}]}