ick返Hong Kong<br />\nPostal code 成功例子參考<br />\n852 <br />\n0852 <br />\n00000 <br />\n000000<br />\n<br />\n再貼多次條Link:<br />\n<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=MqHS405OUPR0rJ167hdmPC%2B7EDXmwg1SXj7S5MqlT1o%3D&h=c9e254ad\" target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},"citedBy":0,"replyTime":"2019-08-18T04:48:57.000Z","msg":"推"},{"pid":"b9e065cd7aae5a8c22e8e37aab147ff17490606d","tid":1482234,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T05:10:33.000Z","msg":"重有3個站到銅鑼灣"},{"pid":"a2c8aa4a848d817902eb7f716672a4021705455c","tid":1482234,"uid":37959,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T05:12:56.000Z","msg":"唔好再早d講"},{"pid":"ba532903b95a646954867bea6d8b3140799e5460","tid":1482234,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-18T05:18:22.000Z","msg":"銅鑼灣站好多黑衣人"},{"pid":"71cb754ae9b8d9e7f1738661074d8bf8e90708b8","tid":1482234,"uid":25558,"like":0,"dislike":0,"score":0,"quote":{"pid":"ba532903b95a646954867bea6d8b3140799e5460","tid":1482234,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-18T05:18:22.000Z","msg":"銅鑼灣站好多黑衣人"},"citedBy":0,"replyTime":"2019-08-18T05:21:02.000Z","msg":"出記紀利佐治街同sogo嘅電梯口已經塞爆， 要排隊。"},{"pid":"60583affed3630c28daf9ee69a51cab6eddc0497","tid":1482234,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T05:30:19.000Z","msg":"13：25  記利佐治街現況<br />\n <img src=\"https://na.cx/i/DOdSNcd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDOdSNcd.jpg&h=ec6240cd&s={SIZE}\" /> <img src=\"https://na.cx/i/zX184Y3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzX184Y3.jpg&h=97e168d9&s={SIZE}\" />"},{"pid":"d6