gif\" class=\"hkgmoji\" />"},{"pid":"a89133bcc9aef9da56986dce88f7bf53fcf72766","tid":1798784,"uid":76115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T13:14:01.000Z","msg":"佢講野有咩參考價值?"},{"pid":"fc2483a2bcf83ae3b12989089b2bf3f1a67b6a35","tid":1798784,"uid":160506,"like":0,"dislike":0,"score":0,"quote":{"pid":"55166d48d9cd11fd39630b1c907323e01df0a06d","tid":1798784,"uid":142735,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-12-26T13:05:18.000Z","msg":"既然有九成專業, 警方內部就應該支持成立獨立調查委員會將剩低的1成垃圾的清理<img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-26T13:14:10.000Z","msg":"有成三千武裝暴徒失控<img src=\"/assets/faces/pigxm/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"8a4c0c095a616dd6fc23250d4f20573cbbaed0e1","tid":1798784,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T13:16:09.000Z","msg":"拉"},{"pid":"abb6be102b91e5dd17ad4ce20f9a8705c67d32b2","tid":1798784,"uid":51701,"like":0,"dislike":0,"score":0,"quote":{"pid":"f1b996b2306f1c0dc1839348b26e471509bbc0ee","tid":1798784,"uid":171506,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-26T13:12:06.000Z","msg":"咩事，招安咗？"},"citedBy":0,"replyTime":"2019-12-26T13:16:35.000Z","msg":"hk01"},{"pid":"78eccc041e7489a7a17e472cff65d30dc5599126","tid":1798784,"uid":51701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T13:16:47.000Z","msg":"hk01"},{"pid":"f129809616f4200f500f4a3bc24c871ae4630fe1","tid":1798784,"uid":11934,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T13:18:32.000Z","msg":"拉"},{"pid":"8485b432af4b25d805336a3be0d7b16ae63a77c3","tid":1798784,"uid":228955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T13:30:58.000Z","msg":"咁多人mon住全世界睇住梗係克制㗎"},{"pid":"833393d94f349c4988fdeff2181f49644d790870","tid":1798784,"uid":32655,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T13:36:05.000Z","msg":"01 拉"},{"pid":"319030e40c50ecd36268eea275ac8f765ef4ef15","tid":1798784,"uid":35084,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T13:58:57.000Z","msg":"佢曲到圓<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" />"}]}