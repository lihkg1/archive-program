,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-04T10:36:06.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n佢出一篇，就會有10個版本溝返淡，呢個策略好好！"},{"pid":"d3a8dd460d958c0c083c9aa0a5aef59b52df9cd2","tid":1284560,"uid":54228,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T10:39:46.000Z","msg":"<img src=\"https://na.cx/i/wF8MOUk.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwF8MOUk.png&h=6fe51bde&s={SIZE}\" />"},{"pid":"93c6c4b4f2e5da37270a43c27b5a07330cec8b63","tid":1284560,"uid":266375,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T10:40:14.000Z","msg":"我無野講!"},{"pid":"7b9a70272051405c98d5ddad8b7b63b370f66e27","tid":1284560,"uid":167956,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T10:42:52.000Z","msg":"我無野講<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"5b629a32810b7381668741c0d85fd19759d43822","tid":1284560,"uid":56926,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T10:42:54.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}