ces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"655c016729ae75ebf036025f45071c07dd73cb92","tid":1778781,"uid":54332,"like":0,"dislike":0,"score":0,"quote":{"pid":"a5b6ad3d1b969a1a4894e243b3a2a52e2087e695","tid":1778781,"uid":123323,"like":0,"dislike":0,"score":0,"quote":{"pid":"67fbd5229f3f76702c36e580d118e0aa4b5592f2","tid":1778781,"uid":66191,"like":0,"dislike":0,"score":0,"quote":{"pid":"45cd01cbb9656d51bd7a572d46a6b81454beb934","tid":1778781,"uid":123323,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-11T08:13:18.000Z","msg":"其實香港本地有冇RPG Maker嘅交流group之類嘅嘢<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n最近由0開始學點用RPG Maker系列嘅software, 基本用法等等<br />\n<br />\n為咗整到自己嘅RPG game, 小弟最近都甘願學電繪去自製 characters, tileset etc.<br />\n<br />\n生活雖然頗為忙碌，小弟都識少少programming嘢，亦都肯學肯做肯去了解<br />\n<br />\n但係冇交流group咁孤怜怜一個人作戰又真係好苦悶，我唔想自己對RPG maker嘅熱誠慢慢咁冇撚咗<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-12-15T23:54:00.000Z","msg":"其實以前都有人開過GROUP,不過冇哂聲氣<br />\n反而內地既藍光RPG仲有一大堆人<br />\nRPG MAKER 睇黎係真。HARDCORE"},"citedBy":1,"replyTime":"2019-12-17T20:36:28.000Z","msg":"有人覆呢個post已經好慶幸 <img src=\"/assets/faces/xm/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n但係按照呢個人數，就算開discord/tg似會係死城咁樣冇聲氣<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\ngroup就暫時唔開了，除非可以成風氣"},"citedBy":1,"replyTime":"2020-01-04T00:09:58.000Z","msg":"香港本身已經小人玩回合RPG<br />\n整完都無咩香港人會欣嘗<br />\n當年九龍魔法陣整得咁好又香港提材都唔多人識<br />\n所以無咩人會玩RPG maker 啦<br />\n台灣多人玩好多<br />\n<br />\nBtw 開group預埋我"},{"pid":"8ad57478269f7a3c008ce95bbb3b703988278c88","tid":1778781,"uid":90259,"like":0,"dislike":0,"score":0,"quote":{"pid":"655c016729ae75ebf036025f45071c07dd73cb92","tid":1778781,"uid":54332,"like":0,"dislike":0,"score":0,"quote":{"pid":"a5b6ad3d1b969a1a4894e243b3a2a52e2087e695","tid":1778781,"uid":123323,"like":0,"dislike":0,"score":0,"quote":{"pid":"67fbd5229f3f76702c3