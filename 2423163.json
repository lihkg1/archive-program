e77401f5e2","tid":2423163,"uid":364767,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-02-26T00:21:54.000Z","msg":"<img src=\"https://na.cx/i/PUv3vw7.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPUv3vw7.gif&h=95a072c1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/QsWQGOy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQsWQGOy.gif&h=bed7e4e2&s={SIZE}\" />"},{"pid":"020f5619ece76525507a2621454610c70b62b166","tid":2423163,"uid":69289,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc6d3d796f850f8cb6ca45ecab088849762cc313","tid":2423163,"uid":242537,"like":265,"dislike":3,"score":262,"quote":{"pid":"320c2278a8916b8adaadbf9b30c69f3dc946b84c","tid":2423163,"uid":242537,"like":392,"dislike":1,"score":391,"citedBy":3,"replyTime":"2021-02-25T17:45:20.000Z","msg":"佢老豆老母個山墳裝咗未？"},"citedBy":1,"replyTime":"2021-02-25T17:46:41.000Z","msg":"<img src=\"https://na.cx/i/iZzqK4T.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiZzqK4T.gif&h=180860bd&s={SIZE}\" />"},"citedBy":0,"replyTime":"2021-02-26T00:24:00.000Z","msg":"<img src=\"/assets/faces/pig/dance3.gif\" class=\"hkgmoji\" />"},{"pid":"6c3f3e568887e9f57c301001630f2de0bc8d094a","tid":2423163,"uid":283700,"like":0,"dislike":0,"score":0,"quote":{"pid":"2e735f0fb6d16c4e8e5462f6f78c55f3420f35cf","tid":2423163,"uid":381986,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-02-25T17:44:13.000Z","msg":"建制呻警察子女受校園欺凌 何君堯促全港課室加裝閉路電視<br />\n<br />\n<a href=\"https://www.inmediahk.net/node/1081063\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1081063&d=6DLEtCU0DjtZYWozPjwd6%2F7c%2B9HD3JYLAdxAiSxEDXo%3D&h=e84fb802\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1081063&h=0cb16a71\" target=\"_blank\">https://www.inmediahk.net/node/1081063</a><br />\n<br />\n（獨媒報導）立法會教育事務委員會下午召開特別會議，討論預防及處理校園欺凌的政策和支援策略。多名建制派議員大數身邊任職警務人員的「朋友」子女遭遇校園欺凌，何君堯更建議在全港中小學的走廊和課室安裝閉路電視，惟遭教育局副局長蔡若蓮拒絕。何君堯在會上多次發難，反問「安裝 CCTV 犯法㗎咩？唔係下話，任何屋苑裏面都有啦，行街都有啦」，又不滿蔡以「社會事件」形容反修例運動，要求局方定性為「暴動」或「顏色革命」，「做乜咁客氣？社乜鬼會事乜件！」<br />\n<br />\n何君堯促課室裝閉路防欺凌遭拒<br />\n<br />\n蔡若蓮一開始「照稿讀」匯報現時預防及處理校園欺凌的措施，被建制派大鬧重覆原則性措施欠缺效用。何君堯發言時怒轟文件「口號多於實際」、「100分裏面我俾15分」。他建議，於全港中小學的課室裝設閉路電視，強調措施能覆蓋校園9成範圍，有效防止學生被欺凌，「（學校）得6層高，1幢裝45部CCTV，500蚊一部，我同你計埋條數，2,250萬裝晒，計埋server 500萬落去，2,700萬點解唔做？」<br />\n<br />\n何君堯愈說愈激動，稱「有隻憤怒鳥出咗嚟！」他認為教育局應運用權力向學校下達指令，「學校嘅錢又唔係佢哋出，租金又唔洗俾，仲攞埋優質教學基金，個個老師都成4、5萬人工。」他又「燒埋」駐校社工，「1年花760億，特首俾多50億，生涯規劃乜鬼都有，宜家淨係bully都搞唔掂。」<br />\n<br />\n蔡若蓮反對做法，強調學校安裝閉路電視旨在防止罪案發生，但同時必須遵守《個人私隱條例》第468章與《閉路電視監察及使用航拍指引》，並認為加裝閉路電視不會令欺凌問題完全消失。<br />\n<br />\n何君堯突打斷其發言，要求蔡只需回應安裝與否，反問「安裝 CCTV 犯法㗎咩？唔係下話，任何屋苑裏面都有啦，行街都有啦。」蔡之後指建議在技術上沒有問題，但執行時需要教職員、學生和家長同意。何君堯再次發難，「有冇搞錯！佢同你打工你問佢同唔同意？最好一年放365日添啦！」"},"citedBy":0,"replyTime":"2021-02-26T00:28:00.000Z","msg":"家長都打工<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d0e87fd213b0a6585df66d60591cb489dbc329f4","tid":2423163,"uid":152705,"like":0,"dislike":0,"score":0,"quote":{"pid":"f3839d0a4aa7509bbdf20f86d121fe7af4934d60","tid":2423163,"uid":6347,"like":93,"dislike":1,"score":92,"citedBy":4,"replyTime":"2021-02-25T18:01:04.000Z","msg":"支持佢裝<br />\n迫中產帶埋個小朋友走<br />\n順手帶埋外匯走<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-26T00:45:23.000Z","msg":"港豬揾食點會走"},{"pid":"29d88fe854ba29423d256f8681aaff0215c3d00a","tid":2423163,"uid":2357,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T00:47:20.000Z","msg":"廁所要有，教員室都要，鼓勵互相舉報"},{"pid":"98e99f3adc56c64843fa223f596b635c4460c16e","tid":2423163,"uid":128763,"like":3,"dislike":0,"score":3,"quote":{"pid":"320c2278a8916b8adaadbf9b30c69f3dc946b84c","tid":2423163,"uid":242537,"like":392,"dislike":1,"score":391,"citedBy":3,"replyTime":"2021-02-25T17:45:20.000Z","msg":"佢老豆老母個山墳裝咗未？"},"citedBy":0,"replyTime":"2021-02-26T00:52:40.000Z","msg":"<img src=\"https://na.cx/i/gT4ODy