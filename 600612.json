水管內發現一具完整的嬰兒屍體，遂報警處理。<br />\n<br />\n<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"67f83d6107edf868b5783d2c3e63730687d3b935","tid":600612,"uid":9231,"like":0,"dislike":0,"score":0,"quote":{"pid":"94d8d152622cd9590ae48925d9733e15a2efc8e0","tid":600612,"uid":145529,"like":0,"dislike":0,"score":0,"quote":{"pid":"1445bc4f9eebd2b9beeb74e9a6c1e0ae54479d0f","tid":600612,"uid":9231,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-21T12:59:20.000Z","msg":"佢塞左佢問題啦<br />\n你點整到佢塞先"},"citedBy":1,"replyTime":"2018-03-21T13:04:16.000Z","msg":"痾完屎一沖就咁<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-21T13:14:40.000Z","msg":"咁就係佢問題啦<br />\n不過bum兩bum搞掂"},{"pid":"001930f59ce908efe54feabc9a27fd872fad75a6","tid":600612,"uid":145529,"like":0,"dislike":0,"score":0,"quote":{"pid":"704cdf270224925766e8fdc675847ca574bfce41","tid":600612,"uid":56999,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-21T13:08:08.000Z","msg":"廁紙係水會溶溶爛爛<br />\n<br />\n等半個鐘再沖下"},"citedBy":0,"replyTime":"2018-03-21T13:30:35.000Z","msg":"都係唔得<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"261cb989421ceff96b934c0718a236b75f9a122f","tid":600612,"uid":145529,"like":0,"dislike":0,"score":0,"quote":{"pid":"207d493b1e92ba85c4e45a3693c1ed95f1645c89","tid":600612,"uid":33868,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-21T13:09:49.000Z","msg":"退房走人"},"citedBy":0,"replyTime":"2018-03-21T13:32:00.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"1fe98c88786012342bc8ea422730d0cee4f4d677","tid":600612,"uid":145529,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1a9f7969939364e2a4085ad3abd9934168cc6a1","tid":600612,"uid":55924,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-21T13:09:37.000Z","msg":"用手啦"},"citedBy":0,"replyTime":"2018-03-21T13:33:57.000Z",