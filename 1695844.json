,"citedBy":0,"replyTime":"2019-11-09T03:51:25.000Z","msg":"推"},{"pid":"c05dda20b5a54a1b1c712d71b54fd68edacd22d3","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T08:16:09.000Z","msg":"推"},{"pid":"bdb35b9ca8bb906a106caf17ba01a1a4414369e0","tid":1695844,"uid":128202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T08:50:33.000Z","msg":"幫推"},{"pid":"f9abb31d3e6d3606fdb38bb4d6e9efd940662570","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-10T01:05:18.000Z","msg":"推"},{"pid":"5d4950bd09f90bb6b3a5eee76934091f969eb3ce","tid":1695844,"uid":156096,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-10T01:05:54.000Z","msg":"***眾籌***<br />\n唔好意思，仲係要借個位&amp;幫你推推POST<br />\n<br />\n鐘庭耀教授為今次運動發起了超大型全港性民調，長期追蹤今次運動大事件的民意 (eg. 721, 831) &amp; 證明香港人未放棄，然後做份國際文宣<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />, 話比全世界聽：5毛網軍不代表香港人<br />\n(<span style=\"color: red;\">眾籌到而家先58%</span><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />, 仲要大家支持)<br />\n<br />\n第三&amp;四期民調結果POST <span style=\"color: red;\">(new)</span><br />\n<a href=\"https://lihkg.com/thread/1696271/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1696271/page/1</a><br />\n第二期民調結果POST <br />\n<a href=\"https://lihkg.com/thread/1686054\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1686054</a><br />\n第一期民調結果POST<br />\n<a href=\"https://lih.kg/1675545\" data-auto-link target=\"_blank\">https://lih.kg/1675545</a><br />\n<br />\n眾籌link:  <a href=\"https://www.collaction.hk/project/story/1209\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.collaction.hk%2Fproject%2Fstory%2F1209&d=YDk3w6YkG5F4GHIJWz3fGB0Z1crOiE0eyIPSb4MeDzY%3D&h=3a773e33\" data-auto-link target=\"_blank\">https://www.collaction.hk/project/story/1209</a><br />\n官方link (我們香港人計劃) :<br />\n<a href=\"https://www.pori.hk/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.pori.hk%2F&d=YDk3w6YkG5F4GHIJWz3fGB0Z1crOiE0eyIPSb4MeDzY%3D&h=7463eba6\" data-auto-link target=\"_blank\">https://www.pori.hk/</a><br />\n<br />\n(對唔住，我知而家仲叫大家課金可能好反感，但我相信兄弟爬山，各有各做)<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"5f22beba59be14f6f438e9cd0417c61a815d1ad6","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-10T08:38:14.000Z","msg":"推"},{"pid":"08f2d12822b6ff91ba8b3ca5ad051e917d20aea8","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-10T16:02:18.000Z","msg":"推"},{"pid":"6909cbcbb4ccda34de3202244579229e10aa6ba8","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T04:13:10.000Z","msg":"推"},{"pid":"e7f6bdfc9f0f90410ea0a92abe5722e010759bcd","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:17:58.000Z","msg":"推"},{"pid":"d70eb49f7b40a7c24960358ab2eee513ac2d5561","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T06:44:23.000Z","msg":"推"},{"pid":"d4498586ce2e9427500ee5482fbd3e2ad7265242","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T17:35:07.000Z","msg":"推"},{"pid":"87327cc40cb737ea11f25fa0613c85059e8476a8","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T08:48:19.000Z","msg":"推"},{"pid":"a62001fad9d38481e1a6d1d2de5099604eb59e35","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T02:55:16.000Z","msg":"推"},{"pid":"10dd23847890864584eff1b3a96b84aed1147c8b","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T10:04:57.000Z","msg":"推"},{"pid":"c9dc733cbdb031c888e50cf17cc9f281deea4378","tid":1695844,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T00:30:59.000Z","msg":"推"},{"pid":"57