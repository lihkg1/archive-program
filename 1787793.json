xm/smile.gif\" class=\"hkgmoji\" />"},{"pid":"fdfba1250691ac057fa1fd52e00a066c74de030a","tid":1787793,"uid":48531,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-18T09:26:23.000Z","msg":"支那冇能力建太空軍咪強烈譴責<img src=\"/assets/faces/pigxm/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"71003095f8e4b3a287bf3e386e9bdb592c7456c7","tid":1787793,"uid":34189,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-18T09:27:22.000Z","msg":"幾時發宇宙通行證<img src=\"/assets/faces/xm/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"e9f717bcef176c97c6d294cdee403d0a9fd38895","tid":1787793,"uid":282118,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-18T09:37:31.000Z","msg":"只係正常嘅歷史潮流<br />\n唔明支那點解會笑尻人<br />\n<br />\n航母已經係二戰嘅產物<br />\n仲拎航母打飛機就等於七、八十年代拎戰列艦自慰<br />\n<br />\n2019先整到航母<br />\n人哋依家上太空玩喇"},{"pid":"363e9afbbf137ca1935ae1fe81a3d550bdd5e326","tid":1787793,"uid":282118,"like":0,"dislike":0,"score":0,"quote":{"pid":"f7dfd751f9e01c9ed684b4e3fa77d57c18394e4d","tid":1787793,"uid":123848,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-18T07:37:44.000Z","msg":"Space army<img src=\"/assets/faces/pigxm/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-18T09:38:27.000Z","msg":"係叫space force<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}