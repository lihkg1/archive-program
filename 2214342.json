s/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a45789bdcc3fc36c836299c155ff73d7cc86d53b","tid":2214342,"uid":137604,"like":1,"dislike":6,"score":-5,"citedBy":1,"replyTime":"2020-09-23T15:29:38.000Z","msg":"此回覆已被刪除"},{"pid":"d39eaf54d013e2cb26b58c0dc2ada55896c6850b","tid":2214342,"uid":48234,"like":4,"dislike":1,"score":3,"quote":{"pid":"8cc96819d609ce6e6375fa2e00e6803493af4b10","tid":2214342,"uid":133680,"like":9,"dislike":6,"score":3,"citedBy":2,"replyTime":"2020-09-23T15:14:18.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-09-23T16:15:58.000Z","msg":"<span class=\"xx-large\"><span class=\"gold\">連登日報&mdash;支持獨裁政權者，無權享有言論自由<br />\n<a href=\"https://lih.kg/1180589\" data-auto-link target=\"_blank\">https://lih.kg/1180589</a><br />\n<img src=\"https://na.cx/i/emWjmNa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FemWjmNa.jpg&h=c08f65f3&s={SIZE}\" /><br />\n請問沙皮狗(狗隻#133680)你屙尿嗰陣起左腳定右腳?<br />\n<a href=\"https://lih.kg/1863914\" data-auto-link target=\"_blank\">https://lih.kg/1863914</a><br />\n最近沙皮狗經常違反板規證據:<br />\n沙皮狗請回應 有冇報章轉載權； 請LIHKG嚴肅跟進#133680侵犯版權問題<br />\n<a href=\"https://lih.kg/2194433\" data-auto-link target=\"_blank\">https://lih.kg/2194433</a><br />\n<br />\n擁有分身證據:<br />\n舉報會員老鳳(#48234)開分身及不停洗版<br />\n<a href=\"https://lih.kg/qatBJRX\" data-auto-link target=\"_blank\">https://lih.kg/qatBJRX</a><br />\n喺佢自己惡意舉報post表示老鳳俾佢迫到傻咗,但係忘記切換帳號<br />\n而且俾佢特別置頂,等同明確承認開分身 R730(狗隻#137604)<br />\n<br />\n老鳳宣佈沙皮狗係終極奶共狗，必須將佢成個集團所有分身清除，否則連登必死<br />\n<a href=\"https://lih.kg/2123735\" data-auto-link target=\"_blank\">https://lih.kg/2123735</a><br />\n<img src=\"https://i.postimg.cc/GpbQh7RN/YOU.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.postimg.cc%2FGpbQh7RN%2FYOU.jpg&h=eacd9956&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/3KfmK5D.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3KfmK5D.jpg&h=2b495cb5&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/XcpCtDj.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXcpCtDj.png&h=d95fea7d&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/yaEZGYj.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyaEZGYj.png&h=6e12e1df&s={SIZE}\" /><br />\n<img src=\"https://i.imgur.com/j8uMrdt.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2Fj8uMrdt.png&h=9e16340d&s={SIZE}\" /><br />\n沙皮狗一吠，所有連登手足便都指著他笑，有的叫道，「沙皮狗，站務台又見到你罪證了！」他不回答，自言自語，「老鳳洗板，舉報佢開分身。」便開post亂鳩咁屈。他們又故意的高聲嚷道，「你一定又開了奶共的post了！」沙皮狗睜大眼睛吠，「你怎麼這樣憑空污狗清白&hellip;&hellip;」「什麼清白？我前天親眼見你開了奶共post，被追擊。」沙皮狗便漲紅了臉，額上的青筋條條綻出，爭辯吠，「文匯大公不能算奶共&hellip;&hellip;文匯大公！&hellip;&hellip;文匯大公報的事，能算奶共麼？」接連便是難懂的嗚咽聲，什麼「老鳳推人去死」，什麼「老鳳俾我迫到傻咗」之類，引得眾人都鬨笑起來：連登內外充滿了快活的空氣。</span></span>"},{"pid":"9d825fbf2275826de7c9862a70a6e54201424a0a","tid":2214342,"uid":48234,"like":1,"dislike":0,"score":1,"quote":{"pid":"a45789bdcc3fc36c836299c155ff73d7cc86d53b","tid":2214342,"uid":137604,"like":1,"dislike":6,"score":-5,"citedBy":1,"replyTime":"2020-09-23T15:29:38.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-09-23T16:16:44.000Z","msg":"<span class=\"xx-large\"><span class=\"gold\">好撚過你開分身唔小心自爆<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /><br />\n連登日報&mdash;支持獨裁政權者，無權享有言論自由<br />\n<a href=\"https://lih.kg/1180589\" data-auto-link target=\"_blank\">https://lih.kg/1180589</a><br />\n<img src=\"https://na.cx/i/emWjmNa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FemWjmNa.jpg&h=c08f65f3&s={SIZE}\" /><br />\n請問R730(狗隻#137604)你屙尿嗰陣起左腳定右腳?<br />\n<a href=\"https://lih.kg/2111627\" data-auto-link target=\"_blank\">https://lih.kg/2111627</a><br />\n此狗隻奶共證據:<br />\n出言侮辱同路人，近日又留言指「聽到仲有人講831，真係好尷尬」。<br />\n建議而家即刻係各大屈臣氏大叫政府無能 馬上封關<br />\n<a href=\"https://lih.kg/eOKtbT\" data-auto-link target=\"_blank\">https://lih.kg/eOKtbT</a><br />\n太子站幕門突然碎裂  玻璃跌入路軌<br />\n<a href=\"https://lih.kg/atgGEHV\" data-auto-link target=\"_blank\">https://lih.kg/atgGEHV</a><br />\n<br />\n懷疑此帳號原擁有者可能已經被殺,以前反CCTVB,而家做CCTVB打手<br />\n睇CCTVB死全家<br />\n<a href=\"https://lih.kg/794788\" data-auto-link target=\"_blank\">https://lih.kg/794788</a><br />\n<br />\n老鳳宣佈沙皮狗係終極奶共狗，必須將佢成個集團所有分身清除，否則連登必死<br />\n<a href=\"https://lih.kg/2123735\" data-auto-link target=\"_blank\">https://lih.kg/2123735</a><br />\n此狗隻為沙皮狗分身明顯證據:<br />\n舉報會員老鳳(#48234)開分身及不停洗版<br />\n<a href=\"https://lih.kg/qatBJRX\" data-auto-link target=\"_blank\">https://lih.kg/qatBJRX</a><br />\n喺佢自己惡意舉報post表示老鳳俾佢迫到傻咗,但係忘記切換帳號<br />\n而且俾佢特別置頂,明確承認開分身<br />\n<br />\n請問沙皮狗(狗隻#133680)你屙尿嗰陣起左腳定右腳?<br />\n<a href=\"https://lih.kg/1863914\" data-auto-link target=\"_blank\">https://lih.kg/1863914</a><br />\n<img src=\"https://i.postimg.cc/GpbQh7RN/YOU.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.postimg.cc%2FGpbQh7RN%2FYOU.jpg&h=eacd9956&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/3KfmK5D.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3KfmK5D.jpg&h=2b495cb5&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/XcpCtDj.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXcpCtDj.png&h=d95fea7d&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/yaEZGYj.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyaEZGYj.png&h=6e12e1df&s={SIZE}\" /><br />\n<img src=\"https://i.imgur.com/j8uMrdt.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2Fj8uMrdt.png&h=9e16340d&s={SIZE}\" /><br />\n成撚日話老鳳洗板,梗係啦,你啲罪證咁撚多,你出現已經等於迫老鳳洗板<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /><br />\n沙皮狗一吠，所有連登手足便都指著他笑，有的叫道，「沙皮狗，站務台又見到你罪證了！」他不回答，自言自語，「老鳳洗板，舉報佢開分身。」便開post亂鳩咁屈。他們又故意的高聲嚷道，「你一定又開了奶共的post了！」沙皮狗睜大眼睛吠，「你怎麼這樣憑空污狗清白&hellip;&hellip;」「什麼清白？我前天親眼見你開了奶共post，被追擊。」沙皮狗便漲紅了臉，額上的青筋條條綻出，爭辯吠，「文匯大公不能算奶共&hellip;&hellip;文匯大公！&hellip;&hellip;文匯大公報的事，能算奶共麼？」接連便是難懂的嗚咽聲，什麼「老鳳推人去死」，什麼「老鳳俾我迫到傻咗」之類，引得眾人都鬨笑起來：連登內外充滿了快活的空氣。</span></span>"},{"pid":"1b8a0cd243ef9c156416b36cf750e8d58afa3ef3