lass=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-14T09:33:54.000Z","msg":"<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-14T09:38:25.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-14T09:45:52.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"}]}