own.gif\" class=\"hkgmoji\" />"},{"pid":"cc061d432e1fae1dca8b96b0186e2ba22d34f324","tid":637824,"uid":12991,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-23T12:32:22.000Z","msg":"你老味之前細細聲講個電話都有人衝埋黎<br />\n依家搞音樂會 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"880bdb089ee2013585a41493479a75ec4ac65f9e","tid":637824,"uid":10540,"like":0,"dislike":3,"score":-3,"quote":{"pid":"07b834e26774923bed0f4c6aed97a55adbd063c6","tid":637824,"uid":34394,"like":51,"dislike":0,"score":51,"quote":{"pid":"be8154dc616f621952e2d215267cadc457a84f0f","tid":637824,"uid":136023,"like":145,"dislike":2,"score":143,"citedBy":2,"replyTime":"2018-04-23T04:32:36.000Z","msg":"呢樣野係 圖書館最高層果幾個度出嚟<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<br />\n話打改變訪客對圖書館嘅印象 唔好咁死板 唔係淨係睇書<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n利申：央館低級職員<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2018-04-23T04:35:10.000Z","msg":"圖書館唔係淨係睇書仲係圖書館？？？？"},"citedBy":2,"replyTime":"2018-04-23T12:32:43.000Z","msg":"其實外國唔少國家、台灣同日本d 圖書館唔係得睇書，有得煲Blu Ray 電影、mac lab 工作空間，有得打Xbox, ps4, 玩樂空間同廚房studio  得香港人仲keep住舊思維"},{"pid":"81ace4e4c267aa2dcdb706feafc405be883c1258","tid":637824,"uid":29093,"like":1,"dislike":7,"score":-6,"citedBy":0,"replyTime":"2018-04-23T12:34:22.000Z","msg":"唔創新又話死板<br />\n<br />\n創新啦又話 on 9"},{"pid":"4faf7649f3b8e67e4649b3edbdcd4fff4763e2c3","tid":637824,"uid":10540,"like":0,"dislike":0,"score":0,"quote":{"pid":"c5bd215df3a1936c32cb080e4b9ccf58bbf6f4dd","tid":637824,"uid":88366,"like":6,"dislike":1,"score":5,"citedBy":1,"replyTime":"2018-04-23T12:11:51.000Z","msg":"人地外國所謂唔死版圖書館係搞活動嘅同兒童圖書館一區，成人同study嘅一區，功能上冇乜衝突，中央圖書館大部分區域都一個井型超應聲根本冇得咁玩，諗果個都on99<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/23/200235_4b2912b94d1dea7ae17f819b9cf5e895.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F23%2F200235_4b