:"2021-02-18T12:41:30.000Z","msg":"你係咪叫左沙嗲牛炆米呀？"},{"pid":"24d7c1cc20abc9fe59b26f96c6e0363225a68768","tid":2412500,"uid":270966,"like":0,"dislike":0,"score":0,"quote":{"pid":"fdd82438bbf8a8a696a3226170a20a0d805b45ac","tid":2412500,"uid":45431,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-18T12:41:30.000Z","msg":"你係咪叫左沙嗲牛炆米呀？"},"citedBy":0,"replyTime":"2021-02-18T14:16:26.000Z","msg":"我一打開都以為係佢炒針<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n但係有湯底嘅<br />\n嗰pat汁就咁淋喺面"},{"pid":"f7a1c29ef92f42281d0fa9c03a7496fa8857165a","tid":2412500,"uid":35587,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e0d75f016294071e107a1667695f76914e091ec8","tid":2412500,"uid":270966,"like":0,"dislike":0,"score":0,"quote":{"pid":"f216fc7fc7616050c8df4ff8db2098ecd5b08e1c","tid":2412500,"uid":83874,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-02-18T11:57:40.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-18T12:03:03.000Z","msg":"我老婆都話碗粉好難食"},"citedBy":1,"replyTime":"2021-02-18T15:51:01.000Z","msg":"我都無食"},{"pid":"8b2dfe82dc8ca86ea7709bb9d18ddb3077f34ed1","tid":2412500,"uid":35587,"like":0,"dislike":0,"score":0,"quote":{"pid":"f216fc7fc7616050c8df4ff8db2098ecd5b08e1c","tid":2412500,"uid":83874,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-02-18T11:57:40.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-18T15:51:16.000Z","msg":"咩"},{"pid":"edcdaf1d411e65243ac85a56292cf5c743e50ac1","tid":2412500,"uid":270966,"like":0,"dislike":0,"score":0,"quote":{"pid":"f7a1c29ef92f42281d0fa9c03a7496fa8857165a","tid":2412500,"uid":35587,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e0d75f016294071e107a1667695f76914e091ec8","tid":2412500,"uid":270966,"like":0,"dislike":0,"score":0,"quote":{"pid":"f216fc7fc7616050c8df4ff8db2098ecd5b08e1c","tid":2412500,"uid":83874,"like":0,"dislike":0,"score":0,"citedBy":2,"rep