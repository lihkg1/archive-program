eplyTime":"2017-02-14T13:28:40.000Z","msg":"<img src=\"/assets/faces/big/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"f8d5db6ddaed0b07150857383e08263d6f993caa","tid":88173,"uid":5150,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-14T16:58:40.000Z","msg":"<blockquote><br />\nBrought roses home. Keys didn't fit.<br />\n<br />\n<br />\nThere're two voices in our bedroom. I knock.<br />\n<br />\n<br />\nSmoking my very last cigarette. Again.<br />\n<br />\n<br />\n<span style=\"color: red;\">Wax wings, high hopes. Long fall. <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> </span></blockquote><br />\n<br />\n呢幾個唔明"},{"pid":"ab5551b25c4f2ed3c913395eb288123ca9393a65","tid":88173,"uid":27741,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-14T17:10:28.000Z","msg":"<blockquote><blockquote><br />\nBrought roses home. Keys didn't fit.<br />\n<br />\n<br />\nThere're two voices in our bedroom. I knock.<br />\n<br />\n<br />\nSmoking my very last cigarette. Again.<br />\n<br />\n<br />\n<span style=\"color: red;\">Wax wings, high hopes. Long fall. <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> </span></blockquote><br />\n<br />\n呢幾個唔明</blockquote><br />\n1: 鎖匙唔啱用 象徵分左手/離左婚<br />\n2:  另一半出軌<br />\n3: 講左好多次戒煙都未戒 (深入啲諗 戒煙又食返嘅人好多時除左心癮仲因為情緒）<br />\n4: 關一個希臘神話事<br />\n個故事大概係：有個叫Icarus嘅人，佢以蠟製嘅翼逃出生天後冇理會其父警告，飛得太高對翼俾太陽整熔左<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />  之後跌落海死。"}]}