eplyTime":"2020-08-31T10:18:05.000Z","msg":"我諗緊轉頭食乜好<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"318188ed968a4528988b708b866caaeadb4e1e5c","tid":2181424,"uid":272819,"like":0,"dislike":0,"score":0,"quote":{"pid":"85931ffe0ef0b9882ca03d1545c993c7064a5ac6","tid":2181424,"uid":310853,"like":0,"dislike":0,"score":0,"quote":{"pid":"d1f972354372c8eb73243dfa1cad6145db9c5335","tid":2181424,"uid":272819,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-31T10:06:29.000Z","msg":"真心想食:("},"citedBy":2,"replyTime":"2020-08-31T10:17:48.000Z","msg":"正常 未係超級好食"},"citedBy":0,"replyTime":"2020-08-31T10:26:29.000Z","msg":"希望你今日又食好野"},{"pid":"4488f134713200178092b234422706e490a67d6b","tid":2181424,"uid":67049,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-31T10:27:49.000Z","msg":"此回覆已被刪除"},{"pid":"083b29bb0c2e717b59ff52fabdb4bd58e40412c0","tid":2181424,"uid":13867,"like":0,"dislike":0,"score":0,"quote":{"pid":"e875675228e335eb42233fb18622bebe57e97a0f","tid":2181424,"uid":13361,"like":5,"dislike":1,"score":4,"citedBy":3,"replyTime":"2020-08-31T03:20:33.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />呢間餃子好普通 食物口味唔太岩香港人 有時叫餃子送白粥幾好食 有時送碗好難食嘅唔知咩羹 有時就普通清湯 <br />\n想食餃子一定係長沙灣甜記 /美味餃子店<br />\n<br />\n附近間 饗-車仔麵唔錯 牛舌有驚喜<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><br />\n<br />\n再附近間魚鈁-椒鹽豆腐粒同麻辣魚強 仲有足料海鮮麵都好撚正<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /> <br />\n<br />\n仲有鄰居嘅鄰居 吉寸-最好打電話訂野食 如果唔係要等佢即叫即燒有排等 燒芝士年糕同大啡菇 翠肉瓜好正<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n西九八樓好多黃店食 但九點後應該大部分都關晒門了<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n89 ，水門雞 ，喇沙面 ，蕃廚（蕃茄類高汁），cool2($18兩隻滷水雞髀飯 走飯都抵食，真係兩隻髀，仲有好多款超平價小食）都推薦<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-31T10:29:42.000Z","msg":"魚鈁 巨好食 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"94cfdd69919a4274d7e4232e568f4f41fe217947","tid":2181424,"uid":310853,"like":0,"dislike":0,"score":0,"quote":{"pid":"4488f134713200178092b234422706e490a67d6b","tid":2181424,"uid":67049,"like":0,"dislike":0,"score":0,"quote":{"pid":"befbc4b7eadcdab47998771931e39acdc43143fc","tid":2181424,"uid":310853,"like":0,"dislike":0,"score":0,"quote":{"pid":"834cf7517062493f887210abad55b2d97930a937","tid":2181424,"uid":216810,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-08-30T15:57:57.000Z","msg":"係咪食餃子送雞粥嗰間?<img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-30T16:04:21.000Z","msg":"唔知<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n千之味隔離嗰間"},"citedBy":1,"replyTime":"2020-08-31T10:27:49.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2020-08-31T10:31:54.000Z","msg":"千之味幾好食<br />\n之前我個fd話煮嘢食比我食<br />\n冇理由兩手空空上去<br />\n買咗d三文魚腩上去 佢哋都話幾好食"},{"pid":"7ba8d61ee95a2b33ff836dcf6fa0ea4dd3d60417","tid":2181424,"uid":67049,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-31T10:32:43.000Z","msg":"此回覆已被刪除"},{"pid":"78b7ec18b6c01e1fc3e828ca85312ab89b333e66","tid":2181424,"uid":277497,"like":0,"dislike":0,"score":0,"quote":{"pid":"517da904a91ebee0c9a495c4f8c1e9da60efa2de","tid":2181424,"uid":310853,"like":0,"dislike":0,"score":0,"quote":{"pid":"38cd5973cc30abf1684029bf4086349dce998a1f","tid":2181424,"uid":299794,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-30T15:36:39.000Z","msg":"今日去鄰居都無得食<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n無曬漢堡扒"},"citedBy":2,"replyTime":"2020-08-30T15:44:23.000Z","msg":"近十點左右都唔知有咩可以食<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-31T10:35:26.000Z","msg":"check check魚舫, 之前係做晚飯宵夜檔<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"f79eb93a583f6c6134a04991b9a102be533967d8