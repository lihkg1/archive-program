es/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8e02fcfc4c4fd5572c31c3b87486965fd97a88d9","tid":722333,"uid":41351,"like":0,"dislike":0,"score":0,"quote":{"pid":"cfe450300cb6a511fd909e92f2171b01dfd1d214","tid":722333,"uid":15730,"like":0,"dislike":0,"score":0,"quote":{"pid":"05d61a7d46c646e6fd7bdf13bc4fd3b7a14a6257","tid":722333,"uid":41351,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-06-29T11:50:50.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/06/29/195039_180f172932e2175dba5797d5efa5944b.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F29%2F195039_180f172932e2175dba5797d5efa5944b.png&h=0005f48c&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/06/29/195045_7ecc12820370671355a6512415ca6e8d.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F29%2F195045_7ecc12820370671355a6512415ca6e8d.png&h=34337b5f&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-07-03T06:25:38.000Z","msg":"陳秀珠咁肥既<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-03T06:49:06.000Z","msg":"珠姐年紀真係唔細"},{"pid":"88ac754b411e9f6de742a8239eed9abad77f18c6","tid":722333,"uid":41351,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-03T15:59:35.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/07/03/235646_62fad631ba1b7f5aac9676ef03a4ed73.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F03%2F235646_62fad631ba1b7f5aac9676ef03a4ed73.png&h=b5e98314&s={SIZE}\" /><br />\n套劇都幾多老戲骨<br />\n盧宛茵，陳秀珠，羅樂琳<br />\n加上愛回家鐵腳黎諾懿，楊卓娜，徐榮，姚嘉莉<br />\n仲有Ali，高ling"},{"pid":"cec22a0f78a337b0695509a3fd6747b199282610","tid":722333,"uid":41351,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-04T13:10:06.000Z","msg":"<a href=\"https://youtu.be/VewPcQwKnQw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FVewPcQwKnQw&d=VG8A9p9VJnYnEt6ENIbQGwdLCpCjoNGxXEizPMjNmRM%3D&h=58091add\" data-auto-link target=\"_blank\">https://youtu.be/VewPcQwKnQw</a>"},{"pid":"3ca081db9d0d810ffc6b4d892645140126e74779","tid":722333,"uid":41351,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-04T15:32:35.000Z","msg":"<img src=\"http://1721826975.rsc.cdn77.org/wp-content/uploads/2018/07/03141157/24-25-640x402.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2F1721826975.rsc.cdn77.org%2Fwp-content%2Fuploads%2F2018%2F07%2F03141157%2F24-25-640x402.jpg&h=8eaacdab&s={SIZE}\" /><br />\n<br />\n做人父母甚艱難！皆因要在現代社會養育一個小朋友不但要付出四百萬，更要同時奉獻無限的愛心及關心。事實上，準爸爸媽媽的預備工作其實早在懷孕初期就要開始，而近年更流行產前、產後的陪月服務，所謂的「金牌陪月」亦因此在坊間應運而生，甚至供不應求。 由監製廖晉碩與編審黃秉怡聯手打造，李佳芯、黎諾懿首度合作飾演熒幕新手父母，並連同高海寧、陳秀珠、楊卓娜、盧宛茵、徐榮、姚嘉妮、黃長興、吳家樂、羅樂林等一同演出的「Amazing Summer」貼地都市劇集《BB來了》， 就是以「陪月」這個新興行業為題材，探討新手爸爸媽媽迎來首個寶寶的喜悅、辛酸，甚至血淚史，分享「BB來了」對父母及家人關係帶來的影響及「湊B」的獨到心得！<br />\n<br />\n故事大綱<br />\n意外懷孕令唐恬兒（李佳芯飾）和葉致廷（黎諾懿飾）夫妻二人大失預算，本可寄望雙方母親的幫忙，可惜兩老育嬰方式南轅北轍，衝突頻生，終請來陪月達人王佳妙（楊卓娜飾）救亡。因為BB來了，令恬兒狠心告別時尚愛美的事業，而致廷亦要遠離夜夜笙歌的品味人生，恬兒更為事業轉型，毅然接手經營陪月中介公司，令恬兒對母親這個新身分別有一番體會，但與致廷卻漸行漸遠，更懷疑他與酒吧同事許晴（高海寧飾）有染；誰料致廷因在一次意外中勇救小孩而成了網紅的「絕世好爸」，並為恬兒及致廷的生活帶來了翻天覆地的改變&hellip;&hellip;<br />\n<br />\n<img src=\"http://1721826975.rsc.cdn77.org/wp-content/uploads/2018/07/03141033/1097-New-Drama-2a-1080x720.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2F1721826975.rsc.cdn77.org%2Fwp-content%2Fuploads%2F2018%2F07%2F03141033%2F1097-New-Drama-2a-1080x720.jpg&h=3c858af4&s={SIZE}\" /><br />\n<br />\n完美型新手媽媽<br />\n唐恬兒 &emsp;李佳芯飾<br />\n性格：愛美如命，愛好時尚，崇尚完美主義。 意外懷孕 翻天覆地<br />\n身為高級時裝買手的唐恬兒（李佳芯飾）與任職高級餐廳及酒吧經理的葉致廷（黎諾懿飾）結婚一年。恬兒、致廷原本堅拒生育，享受租樓不買樓，買酒買衫，定期旅行的優質生活，然而恬兒竟意外有孕，打亂了二人的生活之餘，亦帶來了翻天覆地的改變。 意外懷孕對恬兒衝擊最大，因為身材、樣貌、嗜好、事業等各方面，隨時都要犧牲，而母親身分以後亦會掩蓋自己原有的人生。幸恬兒得到丈夫致廷及母親梁月嬋（陳秀珠飾）愛護，她決心跨過難關，然而前面卻有無限的挑戰等待着她去面對&hellip;&hellip;<br />\n<img src=\"http://1721826975.rsc.cdn77.org/wp-content/uploads/2018/07/03141023/1097-New-Drama-2b-640x427.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2F1721826975.rsc.cdn77.org%2Fwp-content%2Fuploads%2F2018%2F07%2F03141023%2F1097-New-Drama-2b-640x427.jpg&h=51709d26&s={SIZE}\" /><br />\n<br />\n實際型新手爸爸<br />\n葉致廷 &emsp;黎諾懿飾<br />\n性格：樂天開朗，能言善道，交遊廣闊，面面俱圓。 甜心少爺 體貼人夫<br />\n成為新手爸爸的葉致廷（黎諾懿飾）一向擁有甜心少爺仔的性格，知情識趣。他諒解懷孕對太太恬兒所造成的衝擊，盡力照顧其身心所需，卻見識到在香港產子、養兒開支驚人的程度。為了省錢及擺脫奶奶葉康麗貞（盧宛茵飾）的操控，恬兒自行報讀陪月課程，致廷愛妻心切，陪妻子上課，成為班上唯一男學員。 恬兒希望為寶寶築巢，致廷情商母親麗貞出首期買樓，卻遭哥哥葉致遠（徐榮飾）反對；麗貞惟有叫二人搬到自己樓下物業，更請纓幫忙照顧愛孫，二人便不用捱貴租，又可省卻工人錢，可以儲錢置業。致廷落力勸說，最終恬兒只好無奈接受。<br />\n<br />\n<img src=\"http://1721826975.rsc.cdn77.org/wp-content/uploads/2018/07/03141014/1097-New-Drama-2e-640x427.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2F1721826975.rsc.cdn77.org%2Fwp-content%2Fuploads%2F2018%2F07%2F03141014%2F1097-New-Drama-2e-640x427.jpg&h=d8d5ecc8&s={SIZE}\" /><br />\n恬兒不惜工本想給寶寶最好的一切，卻看輕陪月只是調理產婦身體，寧將聘請陪月的費用花在寶寶身上，遂自行報讀陪月課程。<br />\n<br />\n<img src=\"http://1721826975.rsc.cdn77.org/wp-content/uploads/2018/07/03141003/1097-New-Drama-2f-640x427.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2F1721826975.rsc.cdn77.org%2Fwp-content%2Fuploads%2F2018%2F07%2F03141003%2F1097-New-Drama-2f-640x427.jpg&h=c10cf870&s={SIZE}\" /><br />\n女兒出世加上寄居麗貞的物業，宣告了婆媳、夫妻、岳母與女婿的戰事開始，衝突連連！三女為育嬰方式而爭吵不休，致廷忙於調停，疲於奔命！<br />\n<br />\n<img src=\"http://1721826975.rsc.cdn77.org/wp-content/uploads/2018/07/03140953/1097-New-Drama-2g-640x427.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2F1721826975.rsc.cdn77.org%2Fwp-content%2Fuploads%2F2018%2F07%2F03140953%2F1097-New-Drama-2g-640x427.jpg&h=4d405f2f&s={SIZE}\" /><br />\n冷艷調酒師<br />\n許晴 &emsp;高海寧飾<br />\n性格：孤芳自賞，獨立特行，自尊心強。 舊友知己 秘密情人<br />\n致廷的家庭矛盾令他的工作地方頓成了喘息的空間，更跟舊相識兼新同事許晴（高海寧飾）成為酒杯知己。話說致廷在結識恬兒前，已認識許晴，而許晴原來又是恬兒多年未有聯絡的中學師妹。三人重遇，對過去的關係一笑置之。 與此同時，許晴表面上是剛剛加盟到致廷老闆李冠中（黃長興飾）的餐廳，但實際上她跟冠中已相戀一年，卻因出身寒微，冠中不敢向家人道明，二人只能偷偷摸摸。許晴真心愛冠中，一直拒絕接受冠中的金錢與厚禮。冠中欲提昇許晴，希望她日後接手其餐廳，好向家人介紹許晴，遂安排她入職。後來致廷偶然發現許晴跟冠中的秘密情人關係，許晴每每受情傷後，只能跟致廷傾訴，而致廷亦會跟她傾訴家庭壓力。"},{"pid":"82c8d17965b8dc1faff1349ff4d6cf66cbcbd02e","tid":722333,"uid":41351,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-05T15:59:10.000Z","msg":"<a href=\"https://youtu.be/sL-TflY7nKg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FsL-TflY7nKg&d=VG8A9p9VJnYnEt6ENIbQGwdLCpCjoNGxXEizPMjNmRM%3D&h=dfbef0a4\" data-auto-link target=\"_blank\">https://youtu.be/sL-TflY7nKg</a><br />\n星期一 8:30"},{"pid":"40747191afd5f998f2f0ae575cdd02e117646ebf","tid":722333,"uid":41351,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-06T11:32:34.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/07/06/193226_f0d17e98907342624d449a71a46fb53f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F06%2F193226_f0d17e98907342624d449a71a46fb53f.png&h=021973a4&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/07/06/193228_7800146916d6620d16689f88ccaf305d.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F06%2F193228_7800146916d6620d16689f88ccaf305d.png&h=a21a0aa7&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/07/06/193229_b88403f9703bf88b0f5b409cd07d910a.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F06%2F193229_b88403f9703bf88b0f5b409cd07d910a.png&h=0aa0d46c&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/07/06/193231_88df7ae28eb56fdf2564a28a2e2a00aa.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F06%2F193231_88df7ae28eb56fdf2564a28a2e2a00aa.png&h=ea90f5c4&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/07/06/193232_bb0c84cf9c2c9ad475943494c858ce1e.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F06%2F193232_bb0c84cf9c2c9ad475943494c858ce1e.png&h=2125dc4d&s={SIZE}\" />"},{"pid":"36a27fc83365746b4eddc1aa79d50622d7227442","tid":722333,"uid":189911,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-08T06:49:37.000Z","msg":"沈大師<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"4ea28209b00e7549b7f904a1644d97d43924abd2","tid":722333,"uid":4052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-09T04:52:46.000Z","msg":"Ali<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"6804dbb4d1023dd04ca304e39f75c3abaaa9abe5","tid":722333,"uid":27970,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-09T08:40:07.000Z","msg":"留名"},{"pid":"01b84aa04fbefcdae14cccd177cb5a3bb1af9b5a","tid":722333,"uid":41351,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-09T08:55:42.000Z","msg":"今晚8:30開波"},{"pid":"0380fdc2ee2ba9c5071c6164933815cac6cee990","tid":722333,"uid":27970,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-07-09T12:35:06.000Z","msg":"乜歌<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"86a188e12f774f4d075ad0acb505cc8d5650c232","tid":722333,"uid":86140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-09T12:35:40.000Z","msg":"又拎舊歌洗人腦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}