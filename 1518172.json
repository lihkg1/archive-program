omponent%2Fk2%2F1477717-20190830.htm&d=zmS1uFJnVw4lvQjuvPvUioZnnstt8OVeiO3WagLZNiI%3D&h=6d4fec65\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1477717-20190830.htm&h=0c818935\" target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1477717-20190830.htm</a><br />\n<br />\n由今朝到0830到而家,署長話見又話有誠意。結果餓到我地而家係胡忠8樓,社署點解唔肯見社工。<br />\n<br />\n<br />\n咁你而家出黎未<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"982f14bdafda8c850eeb241dc81845f30fab929c","tid":1518172,"uid":14264,"like":0,"dislike":0,"score":0,"quote":{"pid":"ccebd6b62bbbf085fb1bd2abb0905d4f06dbdfc8","tid":1518172,"uid":82829,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7cb4ee6a51e27214112e013f45432c29951dd89","tid":1518172,"uid":14264,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-08-30T07:22:01.000Z","msg":"可能真係因為年紀細（2x歲）<br />\n未見過世面"},"citedBy":1,"replyTime":"2019-08-30T07:26:47.000Z","msg":"我年紀仲細（1x歲）"},"citedBy":1,"replyTime":"2019-08-30T07:28:41.000Z","msg":"扮晒嘢 你都考DSE啦 仲以為你細過我好多"},{"pid":"f37bee86922105f675afd9cc88e4a13297fe5875","tid":1518172,"uid":82829,"like":0,"dislike":0,"score":0,"quote":{"pid":"982f14bdafda8c850eeb241dc81845f30fab929c","tid":1518172,"uid":14264,"like":0,"dislike":0,"score":0,"quote":{"pid":"ccebd6b62bbbf085fb1bd2abb0905d4f06dbdfc8","tid":1518172,"uid":82829,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7cb4ee6a51e27214112e013f45432c29951dd89","tid":1518172,"uid":14264,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-08-30T07:22:01.000Z","msg":"可能真係因為年紀細（2x歲）<br />\n未見過世面"},"citedBy":1,"replyTime":"2019-08-30T07:26:47.000Z","msg":"我年紀仲細（1x歲）"},"citedBy":1,"replyTime":"2019-08-30T07:28:41.000Z","msg":"扮晒嘢 你都考DSE啦 仲以為你細過我好多"},"citedBy":1,"replyTime":"2019-08-30T07:33:59.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />單純想笑你個（2x歲）<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoj