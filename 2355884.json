=https%3A%2F%2Fstatic01-proxy.hket.com%2Fres%2Fv3%2Fimage%2Fcontent%2F2730000%2F2732164%2F0822_1024.jpg&h=12554b52&s={SIZE}\" /><br />\n<br />\n<img src=\"https://scontent.fhkg6-1.fna.fbcdn.net/v/t1.0-9/fr/cp0/e15/q65/117145216_615064492538087_8253529764118476224_o.jpg?_nc_cat=109&amp;ccb=2&amp;_nc_sid=8024bb&amp;_nc_ohc=ZaKQGgkZ6TsAX8qbgU2&amp;_nc_ht=scontent.fhkg6-1.fna&amp;tp=14&amp;oh=5f56ff994b278166aeee2ca41d9a5eea&amp;oe=601C56E0\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg6-1.fna.fbcdn.net%2Fv%2Ft1.0-9%2Ffr%2Fcp0%2Fe15%2Fq65%2F117145216_615064492538087_8253529764118476224_o.jpg%3F_nc_cat%3D109%26ccb%3D2%26_nc_sid%3D8024bb%26_nc_ohc%3DZaKQGgkZ6TsAX8qbgU2%26_nc_ht%3Dscontent.fhkg6-1.fna%26tp%3D14%26oh%3D5f56ff994b278166aeee2ca41d9a5eea%26oe%3D601C56E0&h=05fc930a&s={SIZE}\" />"},"citedBy":0,"replyTime":"2021-01-06T12:08:18.000Z","msg":"Hket <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"745c837f239d3e16092b374995717d3dd3b962c9","tid":2355884,"uid":115579,"like":0,"dislike":0,"score":0,"quote":{"pid":"4365e9460d557a00fc1bb1e7634aeb6381df551d","tid":2355884,"uid":10509,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-06T11:49:50.000Z","msg":"又準備拎香港人出氣<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-06T12:14:04.000Z","msg":"不嬲都係咁<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"493483d2b2ff412719f2fa32ce9e1f8a1079472c","tid":2355884,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"745c837f239d3e16092b374995717d3dd3b962c9","tid":2355884,"uid":115579,"like":0,"dislike":0,"score":0,"quote":{"pid":"4365e9460d557a00fc1bb1e7634aeb6381df551d","tid":2355884,"uid":10509,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-06T11:49:50.000Z","msg":"又準備拎香港人出氣<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-06T12:14:04.000Z","msg":"不嬲都係咁<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-06T12:20:33.000Z","msg":"反而讓台灣和民主陣營更堅定反共"},{"pid":"dc69bcdd15b9b72217a383b4a5b1654dd68a3ad6","tid":2355884,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-06T12:27:51.000Z","msg":"<strong><span class=\"x-large\">專家：台美政治軍事對話浮上檯面 利延續關係</span></strong><br />\n最新更新：2021/01/06 20:12<br />\n<br />\n（中央社記者游凱翔、郭建伸、王承中台北6日電）<span class=\"red\">台美明天進行政治軍事視訊對話，軍事專家今天分析，該對話行之有年，美方主動公告，研判是希望制度化且持續下去，相信拜登政府上任後，會延續這樣的對話機制，深化台美交流合作。</span><br />\n<br />\n美國國務院公布，政軍局助卿古柏（Clarke Cooper）美東時間6日晚上6時30分（台北時間7日上午7 時30分）將透過視訊出席美台「政治軍事對話」（Political and Military Dialogue），並在會中發表談話。<br />\n<br />\n民進黨立委王定宇表示，軍事對談行之有年，並非新設立，<span class=\"red\">但這次公告有嶄新意義，一是美國國務院以官方正式通知、主動向媒體揭露，顯現國務院已將台美之間的政軍對談，列為官方認可的正式、可公開活動，代表台美之間關係從過去模糊策略，轉而明白、公開、正常化。</span>這代表台美關係提升、美方不忌諱中國施壓。<br />\n<br />\n王定宇說，美中衝突源於中國擴張，中共的擴張主義不變，美中衝突就不會隨政權輪替改變，而台灣位於印太戰略樞紐，台美間的合作就是必然，關係正常化、檯面化將是趨勢。<br />\n<br />\n民進黨立委羅致政表示，台美政治軍事對話過去就存在，是年度例行性交流，只是過去較低調不公開。他認為，<span class=\"red\">川普政府將對話交流公開，是希望這項交流能夠制度化</span>；川普將卸任，這次對話應不會觸及重大議題，但意義在於能讓對話持續下去，相信未來拜登政府上任後，會延續這樣的對話機制，深化台美交流合作。<br />\n<br />\n民進黨立委蔡適應也說，<span class=\"red\">美國國務院主動公開台美政治軍事對話的意義在於將此對話機制檯面化、常態化，對台灣非常重要。</span>未來這項對話不會因為政黨輪替而改變，或因為不公開而被拖延。<br />\n<br />\n國防部智庫、國防安全研究院學者舒孝煌說，外交部與國防部不透露對話相關細節，因此難以評論，不過，美國近期通過內含挺台抗中聲明的「2021財政年度國防授權法案」（NDAA FY21），強調應強化與亞太地區夥伴的交流與對話並藉此增加互信，推測台美政治軍事對話的內容，不外乎是上述內容。<br />\n<br />\n舒孝煌指出，雖然美國總統川普對NDAA FY21部分條文內容行使否決權，但美國國會仍以壓倒性票數推翻川普的否決，並通過這項法案，顯見美國國會對於亞太地區的安全局勢有高度共識，認為五角大廈在這樣的態勢下不能停擺。<br />\n<br />\n舒孝煌認為，基於台美互信基礎，外交部與國防部不對台美政治軍事對話多做評論，並且保持低調，這是必要的。<br />\n<br />\n國防院學者蘇紫雲指出，台美政治軍事對話行之有年，美國務院將這項對話排在國際正式會議的議程中，並且在國務院官方網站公開，<span class=\"red\">這正是落實台旅法、台北法案、台灣保證法等一系列法案的精神。</span><br />\n<br />\n蘇紫雲分析，這場對話雖然不公開，但依據美國與北約、其他國家的安全對話內容，推估可能的四大方向，包括安全情勢、科技安全、台美軍事安全合作、經濟安全。（編輯：謝佳珍、趙蔚蘭）1100106<br />\n<br />\n<a href=\"https://www.cna.com.tw/news/aipl/202101060357.aspx\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.cna.com.tw%2Fnews%2Faipl%2F202101060357.aspx&d=dNeHxx%2FttK3%2FgpwSwFVImUuhYyo0AmqkWOXXUYRqYBI%3D&h=e7d715ee\" data-auto-link target=\"_blank\">https://www.cna.com.tw/news/aipl/202101060357.aspx</a>"},{"pid":"346b81d421beb09aa8db02ed7ee2c13036aea4ed","tid":2355884,"uid":318362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-06T12:32:44.000Z","msg":"氣炸<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"e882f68c2c2a598ab0b0a509a8b78de9dd1f164a","tid":2355884,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-06T12:40:20.000Z","msg":"美國國務院在華府時間5日晚間公布，美台將於台灣時間7日透過視訊進行政治軍事對話。美方會由國務院政軍局助卿庫珀（Clarke Cooper）代表參與，對話預計聚焦在區域情勢、台美軍事合作與軍售等議題"}]}