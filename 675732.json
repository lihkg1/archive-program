/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"c6ee8d728496ed8c01f9fdf57fd42b98193151a9","tid":675732,"uid":19985,"like":14,"dislike":6,"score":8,"citedBy":0,"replyTime":"2018-05-24T11:01:41.000Z","msg":"因為Asso升得上既科都唔係神科，姐係DSE直升果班勁極有個譜.<br />\n而Asso果班讀多兩年，仲要同人爭位，梗有一部分既水平勁過中學直升U既同學仔.<br />\n咁中學直升果班咪嬲豬"},{"pid":"6fa83823937862bb3c5e1b12fe436f5abd1aa71b","tid":675732,"uid":28451,"like":11,"dislike":0,"score":11,"citedBy":0,"replyTime":"2018-05-24T11:20:10.000Z","msg":"不嬲都係睇最終學歷<br />\nUgrad得撚閒理你有冇讀asso咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n仲有大把人讀埋master"},{"pid":"e65c84c204b9df1e0ec42c8f42bee02c97ecc796","tid":675732,"uid":43856,"like":27,"dislike":0,"score":27,"citedBy":0,"replyTime":"2018-05-24T11:47:36.000Z","msg":"又唔見啲醫生律師行出嚟屌啲asso仔<br />\n如果大家係唔同level嘅根本就唔洗放上心<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n屌得asso仔都大概知你個人咩level"},{"pid":"82dfd92727889a109290756fcb3984f6aa2305fb","tid":675732,"uid":137017,"like":5,"dislike":1,"score":4,"citedBy":1,"replyTime":"2018-05-24T12:07:19.000Z","msg":"Asso制度開頭幾年邊有人鬧，但之後人見人憎好大程度上係因為部分asso仔行事作風低劣乞人憎導致，特別係擦鞋、搞小圈子杯葛人<br />\n<br />\n而且asso制度內裡有好多利益問題<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/05/24/200200_154484a89e0ec3305e8c51998e7afdef.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F24%2F200200_154484a89e0ec3305e8c51998e7afdef.png&h=2679f1a9&s={SIZE}\" /><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/05/24/200429_65bba15a5a6abaaf53bb13f6320c1c86.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F24%2F200429_65bba15a5a6abaaf53bb13f6320c1c86.png&h=071ec2ae&s={SIZE}\" /><br />\n<br />\n去兩年有1萬係咩玩法？<br />\n營長制度又係咩嚟?<br />\n最令人厭惡嘅係呢一班asso仔做埋曬啲衰嘢攞完着數仲周圍串串貢？<br />\n<br />\n<br />\n<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" /> 所以話asso仔俾人睇唔起，唔係冇原因"},{"pid":"50f48d1d08fb284c33d56ea01863b81909cb1f