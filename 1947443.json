\" />"},{"pid":"000b61c5ac202477666ee8fe6dfe9b7b61190a28","tid":1947443,"uid":49004,"like":5,"dislike":15,"score":-10,"citedBy":3,"replyTime":"2020-03-28T10:48:24.000Z","msg":"如果當年元首贏咗<br />\n德國日本美國三大優秀國家統治世界就好<br />\n<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4ba71182556581a1b72030e73f6aec44d625e3df","tid":1947443,"uid":130419,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T10:49:49.000Z","msg":"算啦 疫情過後咪又係奶返共"},{"pid":"ec8178b45436c97ac28bf7452284e248f48717a9","tid":1947443,"uid":194120,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T10:50:10.000Z","msg":"Italy攪成咁多少係自己攞嚟，徐咗親中之外不斷削減醫療資源撥款，而家有事咪負苛唔到囉。"},{"pid":"6b51db1650e92ee9896b2b1171fbd6c67ae6e9d0","tid":1947443,"uid":301479,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T10:51:10.000Z","msg":"push"},{"pid":"2e47805b7890f92db007d9b07ede5a68eb000999","tid":1947443,"uid":165683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T10:51:41.000Z","msg":"Push"},{"pid":"763ef1cb5a04101b4373f477a909afbc65dc606c","tid":1947443,"uid":343643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T11:07:52.000Z","msg":"馬克龍終於瞓醒"},{"pid":"c03f3821baf75be0f387b20c1cd11d1c4e1a38bf","tid":1947443,"uid":288707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T11:24:22.000Z","msg":"戰敗國同盟<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1926b2ee842165ec821b6e37cf3076a32dccc253","tid":1947443,"uid":251732,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-03-28T12:38:57.000Z","msg":"自己有份出口裝備畀黑警，仲有心情發噏風<img src=\"/assets/faces/mouse/smile.gif\" class=\"hkgmoji\" />"},{"pid":"09d8b19d72ab2102e833e949188ed9dd5aa30482","tid":1947443,"uid":55089,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T12:39:26.000Z","msg":"<img src=\"/assets/f