images%2F2336428%2Forg%2Fd6836fac3948440610f3400f4488ffd5.png%2Fu3k1i8CxDEG38KfUtJ6HvN2VeeOZ85vvH_YhVh_2IVY&h=b5dca3e1&s={SIZE}\" /><br />\n<br />\n<img src=\"https://cdn.hk01.com/di/media/images/2336423/org/5128e5a682c9c7f86951c5cc2497af8f.png/i1MEQwqUnMflO3kAPFHCyMG7HHOnrv6jd1D3NXdQ9zU\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F2336423%2Forg%2F5128e5a682c9c7f86951c5cc2497af8f.png%2Fi1MEQwqUnMflO3kAPFHCyMG7HHOnrv6jd1D3NXdQ9zU&h=5614726d&s={SIZE}\" />"},{"pid":"ab3ce37ae8abec954877bbb43ed382d6fd705157","tid":1006324,"uid":209301,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-04T03:53:06.000Z","msg":"<img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" />"},{"pid":"e51f88d533126ea2d1531e8a9d63c8f3c017ac64","tid":1006324,"uid":6864,"like":37,"dislike":1,"score":36,"quote":{"pid":"d421ab6a2c7a00787e924bd72db650c58e5d0e51","tid":1006324,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-03T02:13:42.000Z","msg":"去年成功眾籌重建的「東築波烏托邦」為賀新年，特地訓練小野豬作表演，希望藉以轉運，讓動物園免於倒閉。<br />\n<br />\n<img src=\"https://cdn.hk01.com/di/media/images/2336086/org/c34ebb26ed1f45730fd6e27f3865241a.jpg/ame3gfA-27M-w0Pii_Mz9DCgzfgzWNBDPxnAuT8ZwLk?v=w1600\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F2336086%2Forg%2Fc34ebb26ed1f45730fd6e27f3865241a.jpg%2Fame3gfA-27M-w0Pii_Mz9DCgzfgzWNBDPxnAuT8ZwLk%3Fv%3Dw1600&h=b8f9c29b&s={SIZE}\" /><br />\n<br />\n「東築波烏托邦」被稱為日本最冷清的動物園，因為地理位置太偏僻及動物種類不吸引，導致沒有客人到訪，每年都錄得約500萬日元虧損。由於園內所有動物都是收養回來的，一旦結業，動物們便流離失所，這也是園長一直堅持營業的原因。<br />\n<br />\n訓練小野豬賀新年<br />\n<br />\n眾籌成功後，動物園馬上開始改建工程，能否翻身就取決於今年。適逢今年是野豬年（日本的豬年為野豬年），加上剛好收養了小野豬豆豆，於是園長想訓練牠成為年度吉祥物，並設計野豬表演。<br />\n<br />\n<img src=\"https://cdn.hk01.com/di/media/images/2336284/org/4847c8e710bdc6509a5d68bc567a602d.jpg/qLQDDrSpiykP4j5S9Dawe35btW6GI4q3m294rptveK4?v=w1600\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F2336284%2Forg%2F4847c8e710bdc6509a5d68bc567a602d.jpg%2FqLQDDrSpiykP4j5S9Dawe35btW6GI4q3m294rptveK4%3Fv%3Dw1600&h=d0b80b05&s={SIZE}\" /><br />\n<br />\n訓練豆豆的工作由員工富田小姐負責，可惜訓練並不順利...<br />\n<br />\n<img src=\"https://cdn.hk01.com/di/media/images/2336425/org/595d84724b26ac1f94a764d2eb8af40f.png/QSZrZ92CNOrpiW5wXEXRNGSAgr20KfexCJfFpwiXxac\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F2336425%2Forg%2F595d84724b26ac1f94a764d2eb8af40f.png%2FQSZrZ92CNOrpiW5wXEXRNGSAgr20KfexCJfFpwiXxac&h=4ff6f3a4&s={SIZE}\" /><br />\n<br />\n園內正興建野豬牧場，預計於3月上旬開幕，豆豆到底能否完成訓練，為動物園改轉命運呢？大家請拭目以待吧！<br />\n<br />\n<img src=\"https://cdn.hk01.com/di/media/images/2336430/org/226cac560dffe469044e79d933a4b49e.png/MPUVo-i3WqlpvY30TigSVx0RY6CM_3pIrpQrXa6UK10\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F2336430%2Forg%2F226cac560dffe469044e79d933a4b49e.png%2FMPUVo-i3WqlpvY30TigSVx0RY6CM_3pIrpQrXa6UK10&h=1928a2f0&s={SIZE}\" /><br />\n豬年生肖交接儀式<br />\n<br />\n睇片 <br />\n<a href=\"https://www.hk01.com/%E5%AF%B5%E7%89%A9/284239/%E6%97%A5%E6%9C%AC%E6%9C%80%E5%86%B7%E6%B8%85%E5%8B%95%E7%89%A9%E5%9C%92-%E8%A8%93%E7%B7%B4%E5%B0%8F%E9%87%8E%E8%B1%AC%E8%B3%80%E6%96%B0%E5%B9%B4-%E8%B7%9F%E5%87%BA%E8%B7%9F%E5%85%A5%E8%B6%85%E5%BE%97%E6%84%8F#media_id=2336430\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E5%25AF%25B5%25E7%2589%25A9%2F284239%2F%25E6%2597%25A5%25E6%259C%25AC%25E6%259C%2580%25E5%2586%25B7%25E6%25B8%2585%25E5%258B%2595%25E7%2589%25A9%25E5%259C%2592-%25E8%25A8%2593%25E7%25B7%25B4%25E5%25B0%258F%25E9%2587%258E%25E8%25B1%25AC%25E8%25B3%2580%25E6%2596%25B0%25E5%25B9%25B4-%25E8%25B7%259F%25E5%2587%25BA%25E8%25B7%259F%25E5%2585%25A5%25E8%25B6%2585%25E5%25BE%2597%25E6%2584%258F%23media_id%3D2336430&d=6VpbUQS5Cy4QwgKrD6%2Fp7v%2FZYLwdGiEzwb2OZuYF8yg%3D&h=591337