ts/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"675930c3fb72b10f841fb6a90dc5b1d2fc9bcb6e","tid":874011,"uid":81113,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6b5bbf0947ab04c1740c418d3798c1032f9298dd","tid":874011,"uid":26329,"like":0,"dislike":0,"score":0,"quote":{"pid":"a783109b1160f72c307a50eb5514349bef76cf69","tid":874011,"uid":7699,"like":12,"dislike":0,"score":12,"quote":{"pid":"937287c9da870cbbf0a1bdcf803b3319d3e4f3e2","tid":874011,"uid":10757,"like":9,"dislike":0,"score":9,"citedBy":2,"replyTime":"2018-10-24T01:06:26.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-24T01:08:37.000Z","msg":"唔駛驚 有咩事仲有007同Johnny English"},"citedBy":1,"replyTime":"2018-10-24T01:37:40.000Z","msg":"Johnny English夠做啦<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-24T06:55:11.000Z","msg":"屌<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6e1c539bf8e11c14fcf108a582a26614c7b9cc47","tid":874011,"uid":35430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-24T07:05:53.000Z","msg":"終於浮上面<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n當日屌我話支那人冚把爛間諜係老屈個班廢柴肯面對未<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"dd76193034f826773a62a65f627a75a10aeac5a5","tid":874011,"uid":35430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-24T07:07:32.000Z","msg":"話我睇唔到支那人幾優秀幾出色唔會為黨服務個班打靶死剩種愛支病人幾時肯自盡<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"fd7dcbe3489180e5d0777936bb4939e64992d8c7","tid":874011,"uid":6752,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-24T07:09:54.000Z","msg":"最緊要肯醒"}]}