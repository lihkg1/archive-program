/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c0a62f99523daacc41ed79af26f4c40dd9b513fb","tid":185091,"uid":3302,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-05T15:12:40.000Z","msg":"午睡<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 離撚哂罩"},{"pid":"43342c7fabdf4d5f948d0133bf0cd09eef8944e9","tid":185091,"uid":7846,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-05T15:35:08.000Z","msg":"此回覆已被刪除"},{"pid":"afbb67e38077faff88d32f223401f2d3c9340b8e","tid":185091,"uid":7846,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-05T15:35:51.000Z","msg":"此回覆已被刪除"},{"pid":"4ccb9e0312d5febc983c100632f198b94d470deb","tid":185091,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-07T05:47:09.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}