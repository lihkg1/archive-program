bacbe4fed3fbad9390fb1c612f585019b1f28ab","tid":1983792,"uid":8948,"like":1,"dislike":0,"score":1,"quote":{"pid":"de0c7640924d8b76171425f0e7407a0d8795a05e","tid":1983792,"uid":36920,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-04-22T05:20:34.000Z","msg":"而家個收費太平<br />\n其實貴啲我都肯俾"},"citedBy":1,"replyTime":"2020-04-22T05:32:20.000Z","msg":"其他人連而家呢個價都唔訂閱"},{"pid":"af7c9713acd7346bf881184e5d25fc836ea0f0e8","tid":1983792,"uid":8948,"like":0,"dislike":0,"score":0,"quote":{"pid":"3b78c39c22c421096cf47dd77a712c44938584e9","tid":1983792,"uid":179718,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-04-22T05:24:34.000Z","msg":"根本肯俾更多嘅大有人在<br />\n如果唔想改 plan 入面個收費<br />\n直接課金好過啦"},"citedBy":2,"replyTime":"2020-04-22T05:33:07.000Z","msg":"課金冇穩定收入，好難預算<br />\n成盤數會變得更難經營"},{"pid":"b2c13c8bcd83bdb64a9f5f50a29329985bfd2de9","tid":1983792,"uid":7137,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-22T05:34:00.000Z","msg":"Push"},{"pid":"23764fa522bf7f058f77073a193b539bab6d7e94","tid":1983792,"uid":36592,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-04-22T05:34:06.000Z","msg":"樓主同意請pin<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://lihkg.com/thread/1983824/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1983824/page/1</a><br />\n<br />\n蘋果告急根本搞撚錯左重點！深黃既香港人一早訂左蘋果，隨時仲訂足一年<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n蘋果日報本身冇其他option課金，深黃絲除左like/share，仲有咩幫到肥佬黎？<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><br />\n<br />\n答案就係課埋壹週刊（每月$30 ／每年$288），保守估計而家有課壹週刊既可能連蘋果用戶1/10都冇<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n雖然對壹週刊d 娛樂新聞冇興趣，但係佢既時事專題都值得睇，而且有好多高質專訪<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n如果有10萬人月課壹週刊，蘋果每個月就多300萬現金流<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />，如果一半蘋果用戶訂壹週刊，仲可能抵銷到之前用戶退訂既影響<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n<br />\n已課蘋果又想出多分力幫肥佬黎，立即課金壹週刊<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n網頁：<a href=\"https://s.nextmag.hk/e/lC67NoYyJY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fs.nextmag.hk%2Fe%2FlC67NoYyJY&d=ltyh5TmdzGcNJFTF%2BAmR8r9ZTfDhdyQuSOQsORMTmv0%3D&h=4f1f4a6e\" data-auto-link target=\"_blank\">https://s.nextmag.hk/e/lC67NoYyJY</a><br />\nAndroid：<a href=\"https://play.google.com/store/apps/details?id=hk.com.nextmedia.magazine.nextmediaplus&amp;hl=zh_HK\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fplay.google.com%2Fstore%2Fapps%2Fdetails%3Fid%3Dhk.com.nextmedia.magazine.nextmediaplus%26hl%3Dzh_HK&d=ltyh5TmdzGcNJFTF%2BAmR8r9ZTfDhdyQuSOQsORMTmv0%3D&h=2edcbef2\" data-auto-link target=\"_blank\">https://play.google.com/store/apps/details?id=hk.com.nextmedia.magazine.nextmediaplus&amp;hl=zh_HK</a><br />\nios：<a href=\"https://apps.apple.com/hk/app/%E5%A3%B9%E9%80%B1%E5%88%8A/id722696868\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fapps.apple.com%2Fhk%2Fapp%2F%25E5%25A3%25B9%25E9%2580%25B1%25E5%2588%258A%2Fid722696868&d=ltyh5TmdzGcNJFTF%2BAmR8r9ZTfDhdyQuSOQsORMTmv0%3D&h=75611768\" data-auto-link target=\"_blank\">https://apps.apple.com/hk/app/%E5%A3%B9%E9%80%B1%E5%88%8A/id722696868</a><br />\n<br />\n<img src=\"https://i.lih.kg/540/https://na.cx/i/sZ5xwcC.png\" />"},{"pid":"87f141223eb19a8fd5ec10f89477f656af658760","tid":1983792,"uid":186181,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-04-22T05:34:12.000Z","msg":"開個有下限無上限自由訂價啦 <img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />"},{"pid":"05f0fe5cb152468742de79f35c3bba1f1fc301d8","tid":1983792,"uid":33391,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-04-22T05:34:13.000Z","msg":"講真，蘋果唔係一個好嘅媒體，有時報啲嘢又尻下尻下，但係佢一定係企喺我地呢邊最大嘅媒體<br />\n<br />\n如果因為佢有時啲報導尻而又去唔支持肥佬黎，咁我地就一定輸，所以希望大家諗下應唔應該去大力幫肥佬黎。"},{"pid":"89803fe24b9820065a876e807fffbca963ecb594","tid":1983792,"uid":158977,"like":0,"dislike":0,"score":0,"quote":{"pid":"3a10b56f7cca83821df33f2271439a0a82522abe","tid":1983792,"uid":271303,"like":0,"dislike":14,"score":-14,"citedBy":1,"replyTime":"2020-04-22T05:30:49.000Z","msg":"做唔店就執7左佢la毒果<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-22T05:34:35.000Z","msg":"blocked thx"},{"pid":"1cf7bd65226d7d1837c87e16840942f43a48c241","tid":1983792,"uid":140411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-22T05:38:29.000Z","msg":"一人開一個蘋果post, 我先<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"77b10f4a00e5fd2f3f8f8f7ec4667970e6eb0248","tid":1983792,"uid":68080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-22T05:39:10.000Z","msg":"一早支持緊<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a3a3731b3734448f1776d7e01d38b5ed17823c82","tid":1983792,"uid":205109,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-22T05:39:40.000Z","msg":"Push"},{"pid":"b3b2f71a6d8ceae10171ff26d569f3e825444808","tid":1983792,"uid":302070,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2020-04-22T05:40:58.000Z","msg":"本來好想支持<br />\n但係佢喺理大戰役出賣過手足<br />\n以後都唔會再買"},{"pid":"ce14a1beece32c09310ec281919eca3b0af6e4cf","tid":1983792,"uid":170143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-22T05:41:07.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"72113bc2f7398622b0ccd35fe2ca9f6021f7c349","tid":1983792,"uid":38465,"like":0,"dislike"