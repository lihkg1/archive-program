king%2Frealtime%2Farticle%2F20180521%2F58218181&d=F5tZIgatfxdCzmqhhx%2Fgnp4%2BuNhYgvPKbWZYs3KJomg%3D&h=8ded8d20\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20180521%2F58218181&h=703a9685\" target=\"_blank\">https://hk.news.appledaily.com/breaking/realtime/article/20180521/58218181</a></blockquote><br />\n<br />\n佢需要係安樂死<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"4712399508bbfafc12e5b901f0fe4580079379d1","tid":672313,"uid":104684,"like":130,"dislike":1,"score":129,"citedBy":0,"replyTime":"2018-05-21T01:30:09.000Z","msg":"98歲<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /> <br />\n香港需要安樂死"},{"pid":"d044935af864230c39ab8055149baf6bd03ef16e","tid":672313,"uid":22622,"like":121,"dislike":4,"score":117,"citedBy":0,"replyTime":"2018-05-21T01:36:06.000Z","msg":"周身病痛，行又行唔到，日日無野做係度等死，真係好慘<br />\n<br />\n政府呢方面支援真係唔夠"},{"pid":"7c4507f632e76334e21ede7633e3f4e79acd42bb","tid":672313,"uid":41404,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2018-05-21T01:36:49.000Z","msg":"<img src=\"http://hk.on.cc/hk/bkn/cnt/news/20180521/photo/bkn-20180521063901101-0521_00822_001_01p.jpg?20180521084851\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20180521%2Fphoto%2Fbkn-20180521063901101-0521_00822_001_01p.jpg%3F20180521084851&h=0fb33b9d&s={SIZE}\" /><br />\n墮樓老翁送院。(葉嘉文攝)<br />\n<br />\n深水埗元州邨元滿樓一名98歲老翁，清晨6時許，被發現從高處墮下，倒臥1樓簷篷奄奄一息，其(96歲)妻子發現報警。消防員到場利用升降台將老翁救下，並交由救護車送院搶救後，證實不治，警員在場調查相信事件無可疑。 <br />\n<br />\n防止自殺求助熱線： <br />\n香港撒瑪利亞防止自殺會： 2389 2222 <br />\n生命熱線： 2382 0000 <br />\n明愛向晴軒： 18288 <br />\n社會福利署： 2343 2255 <br />\n撒瑪利亞會熱線(多種語言)： 2896 0000 <br />\n東華三院芷若園： 18281 <br />\n醫管局精神健康專線： 2466 7350 <br />\n<a href=\"http://hk.on.cc/hk/bkn/cnt/news/20180521/mobile/bkn-20180521063901101-0521_00822_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20180521%2Fmobile%2Fbkn-20180521063901101-0521_00822_001.html&d=F5tZIgatfxdCzmqhhx%2Fgnp4%2BuNhYgvPKbWZYs3KJomg%3D&h=870fbf7c\" data-auto-link target=\"_blank\">http://hk.on.cc/hk/bkn/cnt/news/20180521/mobile/bkn-20180521063901101-0521_00822_001.html</a>"},{"pid":"0a5fedc6b84ec6d78f8685609d6188ed5ad1d458","tid":672313,"uid":50740,"like":2,"dislike":21,"score":-19,"citedBy":0,"replyTime":"2018-05-21T01:40:19.000Z","msg":"福氣"},{"pid":"68a4fd014e640baca017da9060720934773580b7","tid":672313,"uid":41404,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2018-05-21T02:28:21.000Z","msg":"98歲翁疑因病厭世元州邨墮樓亡 96歲老妻報案<br />\n<br />\n<img src=\"http://static.stheadline.com/stheadline/inewsmedia/20180521/_2018052107435325815.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.stheadline.com%2Fstheadline%2Finewsmedia%2F20180521%2F_2018052107435325815.jpg&h=bc3941b9&s={SIZE}\" /><br />\n消防接報到場救下事主，交救護車送院搶救。<br />\n一名懷疑因病尋死的98歲老翁，早上在深水埗元州邨元滿樓墮樓，昏迷倒卧1樓簷篷，送院搶救後不治。<br />\n<br />\n事發於清晨6時許，老翁被發現在簷篷奄奄一息，96歲的妻子報警求助。<br />\n<br />\n消防接報到場救下事主，交救護車送明愛醫院搶救，其後證實死亡。警方於現場未有檢獲遺書，相信事主從3樓一單位墮下。<br />\n<br />\n<a href=\"http://hd.stheadline.com/news/realtime/hk/1220811/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhd.stheadline.com%2Fnews%2Frealtime%2Fhk%2F1220811%2F&d=F5tZIgatfxdCzmqhhx%2Fgnp4%2BuNhYgvPKbWZYs3KJomg%3D&h=ab6706f7\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fhd.stheadline.com%2Fnews%2Frealtime%2Fhk%2F1220811%2F&h=db17eb23\" data-auto-link target=\"_blank\">http://hd.stheadline.com/news/realtime/hk/1220811/</a>"},{"pid":"fc2e86d45383b0a157e2803a1b0dae0b8a0e614a","tid":672313,"uid":34223,"like":114,"dislike":1,"score":113,"citedBy":4,"replyTime":"2018-05-21T02:30:19.000Z","msg":"次鳩次都一堆乜撚防止自殺熱線 <br />\n個正苦係有用肯做嘢就唔會咁鳩多人自殺喇<br />\n真係戇鳩鳩"},{"pid":"67002fff5f091fa33fd28af485f7cdb4538978df","tid":672313,"uid":113626,"like":12,"dislike":1,"score":11,"citedBy":0,"replyTime":"2018-05-21T02:31:07.000Z","msg":"家陣香港連自殺都要打電話問過人先 <img src=\"/assets/faces/fs/bye.gif\