gmoji\" />"},{"pid":"634bccd5b61b1c3bdd79f931e9ee9d2c1287de93","tid":1368294,"uid":10788,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-26T12:54:30.000Z","msg":"推 唔好衝動"},{"pid":"c110b7801f5b0687d4fb64ab7ec793c92ac43bbd","tid":1368294,"uid":160991,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-07-26T12:54:32.000Z","msg":"想衝有7.28"},{"pid":"813e193ad57003dad4fc6e237b878aa1b7f3f764","tid":1368294,"uid":124983,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T12:54:44.000Z","msg":"最重要呢句 勿因小失大 自衛"},{"pid":"c43760b0ab12a6acc92e351d1126c667966530a9","tid":1368294,"uid":160991,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T12:55:34.000Z","msg":"諗緊衝唔衝既<br />\n聽下今日森哥<br />\n唔岩聽就聽劉細良"},{"pid":"f86e2e28b0129dce309887328509e3810d688bcc","tid":1368294,"uid":212182,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T12:56:35.000Z","msg":"push"},{"pid":"cc4062d8eebff9f21d49661fd7d03a0452c83a16","tid":1368294,"uid":275901,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T12:56:42.000Z","msg":"啱 勇武不是無腦！！"},{"pid":"e17dc4fb04febcba7f6f585b9041d0a071abdb20","tid":1368294,"uid":259689,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-07-26T12:56:47.000Z","msg":"樓主講左我心個句<br />\n我唔係勇武但我相信勇武應該係有理智有腦<br />\n<br />\n叫啲人唔好咁衝動衝入條村就被人插<br />\n只係聽日唔係適當時候姐<br />\n以退為進唔通唔係一種進擊方式？<br />\n針對無差別暴力事件<br />\n就係要用非暴力去對衡  展現出示威者同暴徒既分別<br />\n更加唔希望再有示威者因為衝入村被人打<br />\n<br />\n既然係不分化冇大臺  不如真係多啲去傾同溝通<br />\n而唔係所有運動都某一方主導曬<br />\n至少聽日唔係一種適合既timing去衝<br />\n<br />\n自衛同保護人真係除外"},{"pid":"8e5a486cabea421afcad120ae34e617b0fd74548","tid":1368294,"uid":117276,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-26T12:57:47.000Z","msg":"我好尊重前線義士<br />\n但勇武都要睇情況<br />\n但聽日真係唔好中計"},{"pid":"1f0dff99c5071243253f240c588a6d8948f6170c","tid":1368294,"uid":182998,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T12:57:49.000Z","msg":"推"},{"pid":"1a3fd2c57262fada3b84be9c51b91511e8a1205d","tid":1368294,"uid":104980,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T12:58:53.000Z","msg":"推"},{"pid":"a8a765b8fc61aff263739e2ba2585b18a66feaa8","tid":1368294,"uid":270250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:00:41.000Z","msg":"推"},{"pid":"f35051ab0c64b0b839c8e09c669fbe74beafd5ed","tid":1368294,"uid":270250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:01:02.000Z","msg":"push"},{"pid":"28ea5ac2c898000481d4bba19f077aca17da3fd6","tid":1368294,"uid":160991,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:04:15.000Z","msg":"不分化"},{"pid":"3b4544ef03e1d69cefeb68e72caf50ebc1a21819","tid":1368294,"uid":281972,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-26T13:05:11.000Z","msg":"保護人係勇武<br />\n亂打人係癲佬<br />\n<br />\nanyway發夢發咗咁多次，非常相信前線係勇武而唔係癲佬"},{"pid":"8a26e105cd198e1f08e87f20fc18c55c36acdb71","tid":1368294,"uid":100028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:06:04.000Z","msg":"同意 <br />\n大家唔好中計"},{"pid":"00479ce785ce9d31508b56f4235c18b591b107f4","tid":1368294,"uid":249187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:07:54.000Z","msg":"推<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"2794bad285bad8264516d695c8eac2d97b6bb629","tid":1368294,"uid":160991,"like":2,"dislike":0,"score":2,"quote":{"pid":"3b4544ef03e1d69cefeb68e72caf50ebc1a21819","tid":1368294,"uid":281972,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-26T13:05:11.000Z","msg":"保護人係勇武<br />\n亂打人係癲佬<br />\n<br />\nanyway發夢發咗咁多次，非常相信前線係勇武而唔係癲佬"},"citedBy":0,"replyTime":"2019-07-26T13:08:31.000Z","msg":"冇錯<br />\n留左前線咁耐<br />\n其實佢地好有分數<br />\n應該話連登巴絲都係好聰明<br />\n每一次都唔會分化到<br />\n每一次都做最好既決定"},{"pid":"645b42fb37f08392e94e16813a9b2b4ce3e2014d","tid":1368294,"uid":18238,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:10:04.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e63484d7502a6a3b2122622faf1cbfc30b0783ce","tid":1368294,"uid":190277,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:11:48.000Z","msg":"同意<br />\n俾人打嘅話一定要保護自己 合理地以武制暴<br />\n但唔好恃住勇武就衝入去生事<br />\n我明大家好嬲<br />\n但咁樣發洩係報唔到仇"},{"pid":"cb80904911b3e383ae3aabdc93963856503ef09a","tid":1368294,"uid":11929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:13:35.000Z","msg":"自衛同主動既分別<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"248f4b76b83e6fdcfd8ec7c0ff94eadfe4ac8cf3","tid":1368294,"uid":276191,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-26T13:13:56.000Z","msg":"只要勇武夠理智<br />\n和理非無限量支持<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a6bc10b9745f8ed0165143b0991da68be700e82d","tid":1368294,"uid":107686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:16:56.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"5f3b11bc852bb79cfb4fd5c4c4a621d6f87d8333","tid":1368294,"uid":87765,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:17:32.000Z","msg":"推"},{"pid":"c51ffc71332fb0e6ff6320e85bae2d83a9abdc72","tid":1368294,"uid":42554,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:18:42.000Z","msg":"經過咁多次<br />\n我信香港人<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n大家都係想蠃"},{"pid":"ed65c173dc61ea4b3c7aa71976f878f07698ed75","tid":1368294,"uid":110043,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:19:11.000Z","msg":"大家有經驗<br />\n識點做"},{"pid":"6e9e687c3c940e8d6201ecb63ccbb6885f98c7de","tid":1368294,"uid":288244,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-26T13:23:13.000Z","msg":"唔好一支竹打沉一船人丫<br />\n可能有D村民都好憎白衫，但係如果聽日搞得太盡我怕會有反效果。<br />\n肯出黎行，已經明確話到俾黑鄉知我地唔怕，再叫下<strong><span style=\"font-size: x-large;\">我地D訴求</span></strong>就夠啦"},{"pid":"35d7ffff69eb5d7c5dd1d188814b855419f8488f","tid":1368294,"uid":160991,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:28:07.000Z","msg":"我地再望下AO講咩<br />\n唔係強逼一定要點樣做<br />\n我相信我地一定搵到最好既辦法"},{"pid":"c98ec53956469d523fa857eb9fff5d09a036e46a","tid":1368294,"uid":52621,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:35:46.000Z","msg":"啱啊"},{"pid":"af39303d81dba0de60351d2500b9a9453e0e4c63","tid":1368294,"uid":14052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:39:47.000Z","msg":"推"},{"pid":"2cd8e5af3a2aa142f5714a79464901419040b810","tid":1368294,"uid":36817,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:40:12.000Z","msg":"以武制暴<br />\n無暴就要做後手<br />\n見到有咩事識自衛還手就可以<br />\n不割蓆<img src=\"/assets/faces/lomoji/42.png\" class=\"hkgmoji\" />"},{"pid":"22788e641083adbfb6106bb164c7faa41c5d3778","tid":1368294,"uid":125349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:41:26.000Z","msg":"勇武 =/= 9衝9打"},{"pid":"9336edf8b229bb36a5f052c3ea12e53bbec6d285","tid":1368294,"uid":32655,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:42:24.000Z","msg":"同意"},{"pid":"342d1caa09324651f9d6b02523142ac2327a288d","tid":1368294,"uid":38784,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:43:25.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"d37e25882365a3c100e09036b2c06b4bf12f6533","tid":1368294,"uid":237355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T13:48:54.000Z","msg":"睇番之前一個月，就知合作先係出路"}]}