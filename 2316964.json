 src=\"https://na.cx/i/sUPGKui.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsUPGKui.png&h=7a4a3907&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-12-08T12:46:40.000Z","msg":"㩒足師<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"65d94846da5055559501d52311afb5c6f748d329","tid":2316964,"uid":199670,"like":0,"dislike":0,"score":0,"quote":{"pid":"683da80bf23fa691c933fe64d8f56e8e8253c2af","tid":2316964,"uid":45910,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-12-08T08:42:30.000Z","msg":"食物及衞生局局長陳肇始表示，政府早前一直與律政司探討封鎖檢測的法律框架，今早框架獲行會通過。食衞局長將可發出《限制檢測宣告》，要求檢測人士，在有檢測結果前留在原本處所內，而<span class=\"red\">政府亦可以按需要，要求轉移處所</span>，或轉移到檢測中心，當有檢測結果後，便可以撤銷封鎖，封鎖時間最長為 7 日。<br />\n<br />\n她又指，部分有特殊需要人士可以申請離開，但仍要遵守相關規定，而社署及民政署會提供物資上的支援。社署將提供如梳洗物品、睡袋等物品。<br />\n<br />\n食物及衞生局常任秘書長陳松青解釋，執行時會把告示展示在處所出入口，「立即生效」，亦會委任包括執法人員在內的公職人員協助執行，限制任何人士離開或進入處所，要求處所內人士接受檢測等。<br />\n<br />\n記者會直播：<a href=\"https://bit.ly/36VMUxs\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F36VMUxs&d=JQtp7%2BScZlazt5%2F0T0af7DvkInyplymEwWc8t9jwBTE%3D&h=e3316bcd\" data-auto-link target=\"_blank\">https://bit.ly/36VMUxs</a>"},"citedBy":0,"replyTime":"2020-12-08T13:02:14.000Z","msg":"防疫撚求仁得仁<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"7dfab44cedac7bccd853e889a3d07d7dd47b0ab0","tid":2316964,"uid":183758,"like":59,"dislike":2,"score":57,"citedBy":3,"replyTime":"2020-12-08T09:44:23.000Z","msg":"<span class=\"xx-large\">共產黨做乜嘢都一定係不懷好意<br />\n<br />\n邊個唔聽話就會確診<br />\n<br />\n集中營前奏</span>"}}