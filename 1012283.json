地魔<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> 完全冇計劃過，雖然後尾俾榮恩說服咗而唔自己一個去<img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" />"},{"pid":"70b5014a4bbe7720782dc4b071967cf1c65a8382","tid":1012283,"uid":24455,"like":22,"dislike":1,"score":21,"citedBy":0,"replyTime":"2019-02-07T16:20:37.000Z","msg":"魔法版大雄"},{"pid":"c08b0d14d16f0448d293af8554bee05199872be6","tid":1012283,"uid":31173,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-02-07T16:23:15.000Z","msg":"哈利波大"},{"pid":"66fa412406e05a9cb154915b1afeed72b8c236c9","tid":1012283,"uid":12169,"like":11,"dislike":1,"score":10,"citedBy":1,"replyTime":"2019-02-07T19:09:57.000Z","msg":"打低馬份拎Elder Wand真係最牽強<img src=\"/assets/faces/lm2lny/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n睇書我係... 咁都得<img src=\"/assets/faces/lm2lny/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"b33a5593639ccddbfaabc2cbb6851c5f30fa2577","tid":1012283,"uid":64694,"like":2,"dislike":1,"score":1,"quote":{"pid":"66fa412406e05a9cb154915b1afeed72b8c236c9","tid":1012283,"uid":12169,"like":11,"dislike":1,"score":10,"citedBy":1,"replyTime":"2019-02-07T19:09:57.000Z","msg":"打低馬份拎Elder Wand真係最牽強<img src=\"/assets/faces/lm2lny/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n睇書我係... 咁都得<img src=\"/assets/faces/lm2lny/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-02-08T08:46:25.000Z","msg":"電影重搞笑，好似就咁執晒佢哋支魔杖<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d9d5468a01f60a4e9bc129842e1f4901ddb0483c","tid":1012283,"uid":190929,"like":1,"dislike":0,"score":1,"quote":{"pid":"45055c51190fdb6637bf02d4f91209a75f49a8a6","tid":1012283,"uid":161731,"like":78,"dislike":1,"score":77,"citedBy":2,"replyTime":"2019-02-07T12:47:27.000Z","msg":"個老豆勁"},"citedBy":0,"replyTime":"2019-02-08T10:20:52.000Z","msg":"<img src=\"/assets/faces/lny/donno.gif\" class=\"hkgmoji\" /> <img src=\"/asse