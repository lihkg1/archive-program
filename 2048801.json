kgmoji\" />"},{"pid":"63d01337b384eb8c9ee8f0af9b40468db5dc36f1","tid":2048801,"uid":27324,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-06-03T06:14:35.000Z","msg":"柯震東28歲<br />\n王大陸29歲<br />\n林依晨37歲"},{"pid":"752263c23183964ac5ff6d86a0f7246e3ca5c2ea","tid":2048801,"uid":10757,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-06-03T06:14:58.000Z","msg":"仲敢死出黎<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"76116309cacb4b837e775a82c707880c57181b28","tid":2048801,"uid":37885,"like":6,"dislike":1,"score":5,"quote":{"pid":"aa1b159198eca24ef9ee2b44e570991c6b4841b3","tid":2048801,"uid":109127,"like":10,"dislike":2,"score":8,"quote":{"pid":"cfbba98324c09649dafb42f0527c7d3715738ccc","tid":2048801,"uid":46435,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-03T04:59:23.000Z","msg":"<a href=\"https://youtu.be/PjRVuIdEF_g\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FPjRVuIdEF_g&d=9MYRmPDtC2YjWedq%2F%2FxxgQWTNdVklcLtcNqJxXVG150%3D&h=c0236dc5\" target=\"_blank\">https://youtu.be/PjRVuIdEF_g</a><br />\n放左差唔多成六年終於上到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />仲轉左古仔天下一做發行<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2020-06-03T05:01:51.000Z","msg":"好期待 話晒九把刀都有岀聲支持香港人 要支持返佢套戲<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-03T06:23:42.000Z","msg":"佢連德國對國安法嘅態度都會出聲<br />\n<br />\n看到德國跟歐盟的反應，已經確信，德國在二戰後種種由政府與民間帶動的對種族滅絕、對集中營、對納粹主義的反省與國家教育，基本上都是一種過度美化。長期以來，全世界都認為德國上上下下都深切反省了國家所犯的錯誤這一個&quot;印象&quot;，肯定給了德國人民另一種優越感，暗自欣喜不已------我們德國人可是反省又反省再反省，我們真是好棒棒。<br />\n現在看起來，德國深切反省數十年後所結出的果實，不、過、如、此。<br />\n不過德國的反應，還是讓我想了半天。<br />\n以下大家都很熟了，正義必勝，因為所謂的正義，必定是由勝利者決定的定義。在歷史上尤其如此，給足時間，戰爭勝利者可以重新詮釋一遍發生過的歷史，去教育新世界的人民什麼是對什麼是錯。這些都是大家耳熟能詳的論點。<br />\n那麼問題來了------如果二戰的最後勝利者是德國納粹，我們身為人類，真的有可能在數十年過後接受了&quot;當初國家設立了集中營屠殺數千萬猶太人，其實是一種滅絕有害人種的必要之惡&quot;嗎？<br />\n我們身為人類，真的有一點點可能覺得奉承一個血肉之軀作為國家唯一真神的獨裁制度，比民主來得優越嗎？<br />\n我們身為人類，真的有可能認為批評國家元首、或揭發腐敗、或批評黨，就是一種必須被處罰否則就會破壞穩定的罪名嗎？<br />\n我們身為人類，真的有一點點可能接受這些扭曲的正義嗎？只因為戰爭的勝利者決定這樣寫歷史？可能嗎？<br />\n我們身為人類，不該有一種善良的直覺深深寫在我們的基因裡嗎？我們真的會接受&quot;對少數人的屠殺是了成就多數人的利益&quot;這種觀點嗎？可能嗎？真的可能嗎？<br />\n看看我的小時候，好像真的有可能。<br />\n小時候我所受的歷史與國文教育，的確讓我盲目崇拜被海扁到灰頭土臉只好集體逃亡的國家機器，崇拜滿手血腥的獨裁者，崇拜&quot;一切都是為了大局&quot;的自我矮化思維，小學四年級時我甚至還參加過&quot;保密防諜人人有責&quot;的畫圖比賽，超想贏。但那是因為我很小，腦波弱，當時一定有非常多清醒的大人根本就覺得那些課本是有毒的思想大便，只是不想說不想反抗，以免被國家機器抓去關吧？<br />\n民主是有很多缺陷，但這些缺陷裡，沒有一個會讓我在網路上寫這些東西被會被刪文，會被砍帳號，會被關，會被殺。<br />\n我很高興二戰的贏家們，為這個世界介紹了有點混亂的民主，儘管當時的贏家也帶來了其他令人超傻眼的東西。"},{"pid":"d196308e83ad87756a14f9a2d40775f49101ab86","tid":2048801,"uid":228995,"like":1,"dislike":1,"score":0,"quote":{"pid":"63d01337b384eb8c9ee8f0af9b40468db5dc36f1","tid":2048801,"uid":27324,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-06-03T06:14:35.000Z","msg":"柯震東28歲<br />\n王大陸29歲<br />\n林依晨37歲"},"citedBy":0,"replyTime":"2020-06-03T06:28:44.000Z","msg":"六年前拍<br />\n<br />\n22<br />\n23<br />\n31"},{"pid":"bfb4d9018d90efc53f610f2473e83335e03ebc7e","tid":2048801,"uid":74203,"like":0,"dislike":0,"score":0,"quote":{"pid":"b77e6b78ed4762eb88251eaa0352f0dd3d5bab7d","tid":2048801,"uid":68689,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-06-03T05:02:01.000Z","msg":"徐子珊<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-03T06:37:52.000Z","msg":"嗰半秒<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"318259ef3e26dea8a8bf09458cb6eaceca5b5553","tid":2048801,"uid":6842,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-06-03T07:19:53.000Z","msg":"點解搞咁耐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n嗰時專登買本小說等佢上<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"a9208bfc295ace92d1399bac02857b176cd0a24e","tid":2048801,"uid":61275,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-03T07:22:26.000Z","msg":"要支持，九把刀前排出左本小說係支持香港同屌柒中共"},{"pid":"f79b0aeffd6d9cb288705c9a8abed8966776c9af","tid":2