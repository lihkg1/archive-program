5cdf2ceba46a921b20b5995","tid":2141741,"uid":146055,"like":1,"dislike":0,"score":1,"quote":{"pid":"c624b5e58c2018bf965f178aff5c193745adb73c","tid":2141741,"uid":126508,"like":19,"dislike":0,"score":19,"citedBy":4,"replyTime":"2020-08-06T03:43:01.000Z","msg":"<img src=\"https://na.cx/i/HEAQkQC.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHEAQkQC.png&h=03abe17e&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-08-06T08:05:17.000Z","msg":"言論自由 0/1 CD:不可回復"}],"pinned":{"pid":"c624b5e58c2018bf965f178aff5c193745adb73c","tid":2141741,"uid":126508,"like":19,"dislike":0,"score":19,"citedBy":4,"replyTime":"2020-08-06T03:43:01.000Z","msg":"<img src=\"https://na.cx/i/HEAQkQC.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHEAQkQC.png&h=03abe17e&s={SIZE}\" />"}}