s=\"hkgmoji\" />"},{"pid":"7da14785ef4786a71b288320e484fcbcf0810180","tid":1881042,"uid":76310,"like":1,"dislike":0,"score":1,"quote":{"pid":"419e6768c125cc057cb9d62cb32957182c4e9b0b","tid":1881042,"uid":176447,"like":14,"dislike":1,"score":13,"citedBy":2,"replyTime":"2020-02-15T09:38:02.000Z","msg":"啲人死晒唔使陪錢<br />\n廠佬又可以接埋間廠唔使爆炸<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-15T10:55:29.000Z","msg":"要比隔離費用<br />\n伙記當出糧咁<br />\n咪on9<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"1530b3cd03f2271491d7a01427a803a09133a080","tid":1881042,"uid":227801,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-15T10:58:28.000Z","msg":"<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"90640621a7ba3df9ab153044688da62f8e5035da","tid":1881042,"uid":307398,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-15T10:58:49.000Z","msg":"加速支爆<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"dad3843bc60c67612d579cfa6a9cc9220b2a2edf","tid":1881042,"uid":24707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-15T10:59:12.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6a6c4d04bad8521336512f6e3d3f6f4f84c37f64","tid":1881042,"uid":295735,"like":0,"dislike":0,"score":0,"quote":{"pid":"fb39144392d160255f80eca06866dcc5f76c0ae0","tid":1881042,"uid":54373,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-15T09:29:28.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n發布時間 : 2020年2月15日12:33<br />\n<br />\n武漢肺炎（COVID-19）持續擴大，中國死亡人數已破千例，眼看經濟逐漸下滑，中國各地企業近日陸續開工，但如今傳出重慶巴南區有一間工廠爆出群聚感染，公司內有２例確診、1例無症狀陽性感染者，共131人有密切接觸，這也是中國開工後首例公司內部出現群聚感染的狀況，工廠隨即封閉。<br />\n<br />\n隨著年後開工日漸近，中國各地企業陸續復工，官方也訂定相關規範，以便在防疫和經濟上取得平衡，像是湖北省就宣布，省內各類企業不於2月20日前復工，但據美國之音估計，大陸企業全面復工是在2月17日，屆時會有1.6億員工重返工作崗位。<br />\n<br />\n重慶巴南區攀鋼重慶鈦業公司開工後，因未嚴格依照疫情管控要求進行管理，在10日竟傳出發生群聚感染的情況，目前該公司已全面封鎖隔離，官方也派出人力前往公司所在地，巴南區麻柳沿江開發區加強企業調查。<br />\n<br />\n中國公司開工即發生群聚感染的情況，引起網友爭相討論，大家紛紛表示，「感染不重要，開工比較重要」、「復工早點死，不復工晚點死」、「復工病死，停工餓死」、「陸資廠的作事就是這樣」、「全部送去火神山，這家公司也可以關了」、「開工會死更多」、「這是大家都預期到的事情」。"},"citedBy":0,"replyTime":"2020-02-15T10:59:44.000Z","msg":"我係咪要笑"},{"pid":"d5ede87c1bc538fd46ddb90859cfa104abda5eb2","tid":1881042,"uid":257622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-15T11:00:28.000Z","msg":"白痴真係無藥醫"},{"pid":"bcdd44467dcb47fc3c4d17c1029bf5a1d7bd5332","tid":1881042,"uid":35087,"like":0,"dislike":0,"score":0,"quote":{"pid":"90640621a7ba3df9ab153044688da62f8e5035da","tid":1881042,"uid":307398,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-15T10:58:49.000Z","msg":"加速支爆<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-15T11:01:42.000Z","msg":"gogogo"},{"pid":"5a11510cd1466d5ff383c41d9182cac63c890ba6","tid":1881042,"uid":64767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-15T11:02:27.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"577acb055e795cee6f7da2262d72bc2f460847a9","tid":1881042,"uid":4840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-15T11:03:46.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"cf779cb130666436a33eeb876c6de870da034ce1","tid":1881042,"uid":96664,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-15T11:05:18.000Z","msg":"中國最大攬炒家－中國共產黨<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"fb8009cb8aefc00097a