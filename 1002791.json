:36.000Z","msg":"仲有南區各大超級富豪住宅區, 例如李+X, 賭王....等家居外圍...<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"df913a8966550a6201d58d10ab3f5c14e99093c5","tid":1002791,"uid":77936,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-01-31T08:16:09.000Z","msg":"你魚蛋多我一粒 我要你少返粒<br />\n就係唔識話我都要多粒魚蛋"},{"pid":"ce5f5f1cdca9d893488a389f0b4d6cf353378016","tid":1002791,"uid":183601,"like":0,"dislike":0,"score":0,"quote":{"pid":"d0d259163180007c11c38934ce29e4fc155ae5c8","tid":1002791,"uid":61018,"like":0,"dislike":0,"score":0,"quote":{"pid":"bdf052c55990e816c96337a76208872c854f8424","tid":1002791,"uid":183601,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-31T08:06:10.000Z","msg":"西環呢屌?"},"citedBy":1,"replyTime":"2019-01-31T08:08:44.000Z","msg":"唔係講笑<br />\n西環近呢幾年成日多咗大媽係度跳大媽舞<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-31T08:19:45.000Z","msg":"可能係西環d蝗親蟈戚嚟<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"f2d0b1201f40b9aeafaf53301118a8c43d354bac","tid":1002791,"uid":54373,"like":1,"dislike":0,"score":1,"quote":{"pid":"df913a8966550a6201d58d10ab3f5c14e99093c5","tid":1002791,"uid":77936,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-01-31T08:16:09.000Z","msg":"你魚蛋多我一粒 我要你少返粒<br />\n就係唔識話我都要多粒魚蛋"},"citedBy":0,"replyTime":"2019-01-31T08:26:17.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"d3888fee860d6d49f0f61416adc2eadb4fad9351","tid":1002791,"uid":27432,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-31T08:43:00.000Z","msg":"推啦屌<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9e3e57dce74963e85fa44eed6e210a30f4cf5b9e","tid":1002791,"uid":27432,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-31T08:44:01.000Z","msg":"寫個行程去微博啦"},{"pid":"32b8e4