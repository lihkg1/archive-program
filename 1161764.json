lyTime":"2019-05-19T12:13:27.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"073069b5513f5e1fdbfaa584b36a4ba37c37a2f4","tid":1161764,"uid":157427,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-19T12:13:37.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"1e6531f240aedda427fbb866e6b5e9e7c866d168","tid":1161764,"uid":157427,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-19T12:13:52.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"ef3b7a735dd782fefb6e13e07adf0eab155671e9","tid":1161764,"uid":119810,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-05-19T19:30:04.000Z","msg":"若果你為人地國家付出 交税 努力賺錢買樓唔炒樓 相信我地唔會成為蝗蟲 而家啲蝗蟲係唔交税 咩都唔做坐係度 然後攞綜緩搶公屋 um 起碼我唔會係咁囉"}]}