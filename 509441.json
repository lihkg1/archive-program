ets/faces/xm/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6530f82b0b234ba58967d32976d60896b444706c","tid":509441,"uid":70760,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-05T16:41:59.000Z","msg":"心靈"},{"pid":"21e1cb329a6930f92020cf69779fda8aaca0698d","tid":509441,"uid":75326,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-05T17:31:44.000Z","msg":"以前宗教主要作用係幫助貧苦大眾 提供教育機會 食物 仲有一定既政治力量<br />\n但依家社會發展咁快 基本上富裕少少既國家已經唔需要教會提供呢d幫助<br />\n咁宗教係咪已經變成左一種儀式上既傳統？<br />\n                                           ^^^^^^^^^^^^^<br />\n傳統上嘅儀式<br />\n<br />\n越富裕嘅國家，宗教就越進入生活<br />\n幫助貧苦提供教育係佢地嘅責任，但並非目的<br />\n你想知道作用，<br />\n就搵下教友討論一下問下佢去為乜<br />\n去黃大仙聽下求籤嘅人口噏噏講乜<br />\n去大嶼山寶蓮寺齋堂旁邊翻下佛經<br />\n去尖沙咀站A出口旁邊望下人做乜<br />\n如果你認為呢啲係一種 routine 儀式<br />\n咁香港人每日翻工、炒股、賭馬又何償唔係?<br />\n一種係為搵食溫飽而生存<br />\n另一種係為心靈上滿足而學習"},{"pid":"c87f7496366834a3e1fc68391ca898f96089992a","tid":509441,"uid":70760,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-08T19:19:03.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a3867c8328ac15617c4bb11841dc5a7ec9c33962","tid":509441,"uid":70760,"like":0,"dislike":0,"score":0,"quote":{"pid":"58942a6c08b33dcaf4996a9bdd0498bd85ab97fd","tid":509441,"uid":41355,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2017-12-25T18:24:37.000Z","msg":"簡而言之<br />\n作用就是:<br />\n1.作為弱勢者的心靈上、生命上避難所<br />\n<br />\n2.作為一種自圓其說的語言藝術<br />\n<br />\n3.作為象徵、裝飾、題材，是藝術性的<br />\n<br />\n4.洗黑錢、恐嚇、操縱民眾<br />\n<br />\n5.傻仔傻女收集箱<br />\n<br />\n6.無野搵野黎搞"},"citedBy":0,"replyTime":"2018-02-08T19:22:05.000Z","msg":"就第一點,想請教<br />\n<br />\n點樣可以成為一個強勢者 (不論背景財富知識多寡)<br />\n<br />\n人無信仰或信念 (兩者唔知相唔相同, 又或兩者未必係現時的宗教)可否成為強勢者 (或咩係強勢者?)<br />\n<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"}]}