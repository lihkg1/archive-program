a7e3d6e6c23943bcbce1e","tid":1415211,"uid":67752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T13:56:14.000Z","msg":"<img src=\"/assets/faces/lomoji/33.png\" class=\"hkgmoji\" />"},{"pid":"454787b89c252d9d27d1db0ce23b51785cc0ff29","tid":1415211,"uid":1241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T13:57:15.000Z","msg":"推"},{"pid":"8d047eb13e69bb9d3466160672a269764e4efdf2","tid":1415211,"uid":150083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T13:57:22.000Z","msg":"推"},{"pid":"81272c8ba23bb66e6d097d79c5ac93c3a869a952","tid":1415211,"uid":76543,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T13:58:13.000Z","msg":"我哋不割蓆 不分化 不篤灰！！！！！<br />\n<a href=\"https://lih.kg/1415493\" data-auto-link target=\"_blank\">https://lih.kg/1415493</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"e880e4d3e32d2f722e646684e06cedbbad58b659","tid":1415211,"uid":67752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T14:00:42.000Z","msg":"深水埗又有義士被捕啦<img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" />"},{"pid":"e96016a956758cb2a1c29a8ec33d1fc01628c762","tid":1415211,"uid":290531,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-08-05T14:00:58.000Z","msg":"<span style=\"font-size: x-large;\"><strong><span style=\"color: orange;\">係唔割啊</span></strong></span><br />\n絕對明白勇武的意義，前線嘅勇氣唔係人人都有，多謝您地！<br />\n但唔可以認定勇武係唯一一條路，有勇同時要有謀<br />\n每次衝突完都掀發更多警察極醜惡嘅一面！仇完警後，每次都有好多要追究的野，每次未追究完，又有新一單，但到最後 <span style=\"font-size: large;\">政府唔理！呢個先係重點 </span>，我地無爭取過一樣野呀<br />\n所以有必要性同急迫性去試下其他方法，智取！試下唔好質問其他人：咁您教我點/仲可以點，而係大家 <strong><span style=\"font-size: large;\"><span style=\"color: gold;\">一齊諗 ！ 一齊做 ！</span></span></strong><br />\n<br />\n絕對係有需要去用一啲方法去嬴埋所謂的「中立派」同「淺藍」的支持！無錯，同佢地講野真係哂__氣，淨係睇示威者「破壞」的表徵！（但如果佢地有腦就唔會係中立派同藍啦！）當佢地就係咁流於表面的人，我地就用下表面改變佢地！<br />\n<br />\n保持思考！！！！"},{"pid":"32c198f73e9d34c0c4445e612ee985420b81bd5e","tid":1415211,"uid":123713,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-05T