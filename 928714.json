8714,"uid":150609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-05T09:44:05.000Z","msg":"大灣區機遇處處  大力奶返啖先<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},{"pid":"7aba86ca90e7f8ed3fefcc15d32df4c60ce46f73","tid":928714,"uid":35790,"like":0,"dislike":0,"score":0,"quote":{"pid":"a705e554cc596495e214ba9536e80ba2fbb2561b","tid":928714,"uid":65320,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-05T05:40:41.000Z","msg":"防RFID卡套<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-05T09:48:07.000Z","msg":"邊度有得賣？"},{"pid":"2363e99619f57cc28e1e38b6607138a668d106bc","tid":928714,"uid":10670,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-05T09:51:29.000Z","msg":"普通錫紙ok?"},{"pid":"5c966e8e52796e78758fb15e5000e40eb2101503","tid":928714,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"53d263f8753fabe4a5c073efe143e40fb5bc964a","tid":928714,"uid":78755,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2018-12-05T05:15:34.000Z","msg":"方指若香港新智能身份證加密鑰匙不慎對外洩露，同樣有風險被不法份子盜用。<br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n咁有啲咩encryption冇風險"},"citedBy":2,"replyTime":"2018-12-06T02:39:37.000Z","msg":"Aes256+sha256+rsa2048<br />\n這是國際免費公開密碼算法<br />\n理論上冇法破解"},{"pid":"af016ba273a5dc5879a3dde7553e28463d3087ff","tid":928714,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"5c966e8e52796e78758fb15e5000e40eb2101503","tid":928714,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"53d263f8753fabe4a5c073efe143e40fb5bc964a","tid":928714,"uid":78755,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2018-12-05T05:15:34.000Z","msg":"方指若香港新智能身份證加密鑰匙不慎對外洩露，同樣有風險被不法份子盜用。<br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n咁有啲咩encryption冇風險"},"citedBy":2,"replyTime":"2018-12-06T02:39:37.000Z","msg":"Aes256+sha256+rsa2048<br />\n這是國際免費公開密碼算法<br />\n理論上冇法破解"},"citedBy":0,"replyTime":"2018-12-06T02:43:21.000Z","msg":"但encryption key可以洩漏。<br />\n所以最重要的係政府內部監管和管理。<br />\n要保證冇人可以隨便get到encryption key。<br />\n一般建議separation of duties and power，least privileges, least knowledge, need to know basis,<br />\n但中國呢方面應該做得比較差。"},{"pid":"7e9000953f42e2232a81ef332a16c853178ab662","tid":928714,"uid":28195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-06T02:44:05.000Z","msg":"居住證屬於國家簽發，俾國家睇既人，肯定身有屎<br />\n<br />\n譚耀宗都認同呢個邏輯"},{"pid":"dc1bb7a07a71ef43b14699511674ec036167e947","tid":928714,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-06T02:45:19.000Z","msg":"廢老：行得正企得正，怕乜比共產黨睇？<br />\n<br />\n<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"7c7f58aac02c97e013a54fb544261ea63e1f929a","tid":928714,"uid":85461,"like":0,"dislike":0,"score":0,"quote":{"pid":"2363e99619f57cc28e1e38b6607138a668d106bc","tid":928714,"uid":10670,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-05T09:51:29.000Z","msg":"普通錫紙ok?"},"citedBy":0,"replyTime":"2018-12-06T02:45:47.000Z","msg":"OK"}]}