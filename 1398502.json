/faces/lomoji/37.png\" class=\"hkgmoji\" />"},{"pid":"6b26e972b56f1a4c08a154b4ed5ecb6c708014e3","tid":1398502,"uid":280457,"like":0,"dislike":0,"score":0,"quote":{"pid":"6c5a8339d6c7b80c24a743efebb1c1cb63bc8b46","tid":1398502,"uid":128472,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-08-02T21:36:24.000Z","msg":"2019 fresh grad未開始搵工。咁老母今日同我講話佢公司有個人就走，就問我要唔要入去做。個職位本身淨係請有經驗既人，所以其實我都好驚入咗去但根本冇能力勝任，會唔心安理得同埋影衰老母。加上同自己阿媽同一間公司，所有嘢好似會變得好奇怪同柒（雖然唔同department）<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />lunch一齊/唔一齊食好奇怪，當私人時間同自己阿媽傾公事又係唔知想點<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n同埋入到去應該會有閒言閒語（已經想像到比人恥笑靠母幹、裙腳仔）<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />但個職位應該幾好pay，如果我用自己能力喺出面搵應該會少成5k人工。<br />\n<br />\n<br />\n請問如果係你哋會點揀？<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-03T01:43:20.000Z","msg":"你咪保持低調咪話人知你老母都係度做囉...<br />\n然後做夠一定時間拎住多<span style=\"font-size: xx-large;\"><span style=\"color: red;\">5k</span></span>既人工搵下一份～"},{"pid":"d528aa8b96515df08302241a1244daf2d1cf3e64","tid":1398502,"uid":163207,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-03T01:44:59.000Z","msg":"群腳仔湯包？<img src=\"/assets/faces/lm2/photo.gif\" class=\"hkgmoji\" />"},{"pid":"40d93412ab04e3746b84807f6b292141b775cb4e","tid":1398502,"uid":68758,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c177d16fa526b6d246557f7fdce37fb1d62aed0","tid":1398502,"uid":128472,"like":0,"dislike":0,"score":0,"quote":{"pid":"84c4765028ac231d06e46c9a58664194ec35293a","tid":1398502,"uid":68758,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-08-03T01:36:46.000Z","msg":"可以試下<br />\n<br />\n利申:走過後門，依加轉工做埋super"},"citedBy":1,"replyTime":"2019-08-03T01:38:51.000Z","msg":"第一份工已經係後門？"},"citedBy":0,"replyTime":"2019-08-03T01:46:14.000Z","msg":"以轉行黎講，算係第一份。<br />\n做左三年閃人，下一份已經有人under自己"},{"pid":"82625ef3