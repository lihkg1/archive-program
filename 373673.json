-25T09:10:57.000Z","msg":"我冇講錯啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0b7e79be1e23529a2d8e809343949d394aed9269","tid":373673,"uid":51546,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-08-25T10:20:00.000Z","msg":"結論：中華文明係垃圾"},{"pid":"bac028727176816d10e274a70c0455dd7002afa0","tid":373673,"uid":51937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-25T10:36:56.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7d4cde0533f86014eb0f18ef2a0b25791e57cfb8","tid":373673,"uid":24140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-25T10:49:10.000Z","msg":"<blockquote>結論：中華文明係垃圾</blockquote><br />\n暴秦暴政2000年 根本無終止過 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"c8000964c9c70829d590a2116548ffe1c2c6e4e1","tid":373673,"uid":55597,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-08-25T11:26:31.000Z","msg":"一講 linux 見到一班無良心既人"},{"pid":"9446674454e11824f0e11abd7ebe73f664e29ffe","tid":373673,"uid":10757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-25T11:28:35.000Z","msg":"為何仁義在書上 社會上卻搵唔到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n紙上談兵<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e5ae2fbc9adb04504bbdf2ffcbf51d45150aad97","tid":373673,"uid":74778,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-08-25T11:32:47.000Z","msg":"日本繼承曬<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"e07d9dc0dabf862a1737b0e2bc5a51772a3e2865","tid":373673,"uid":5559