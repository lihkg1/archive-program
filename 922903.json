e1d30256d081bb2d06896d2b7cbc","tid":922903,"uid":72801,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-30T21:58:53.000Z","msg":"有抑鬱嘅同時對好多事物無曬衝勁先大獲<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"03ac7efc38b4f818841b01d3c7b79d3b9ec0e584","tid":922903,"uid":47876,"like":0,"dislike":0,"score":0,"quote":{"pid":"f8f8bda72e252a1ccf30ba266295842c228ea250","tid":922903,"uid":42900,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-11-30T21:47:17.000Z","msg":"心理黎M"},"citedBy":0,"replyTime":"2018-11-30T22:01:30.000Z","msg":"agger<br />\n有睇過研究話男人都會黎M<br />\n只係身理上唔同 但都會情緒易波動"},{"pid":"e039f127394979baf063c9863a985def1b6c5954","tid":922903,"uid":205371,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-30T22:23:07.000Z","msg":"我都係<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 完全唔知自己想點"},{"pid":"826bc18b821f1fbd1766cd4b804fb5a278455d71","tid":922903,"uid":224249,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2018-11-30T22:41:21.000Z","msg":"可以試下supplement, 調節下<br />\n抑鬱症狀要持續幾個星期至當係<br />\n最好就問下醫生意見啦，總好過拖到問題嚴重至處理。<br />\n我都試過呢種情況，每個星期都有一兩日係咁，成個人無左動力，乜都唔想做，想就咁坐係度，夾硬逼自己做野會好痛苦，但其實自己都唔想咁。成個人好平靜，好空洞，甚至去到一個程度，會覺得死亡先能夠得到永久的平靜和安寧。情況持續左大約兩年至慢慢消失，但真係幾辛苦，有去見過counselor，但都幫唔到。"},{"pid":"9a9158d4f552039de2a66daa9a72b9cc59ea4237","tid":922903,"uid":205403,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-30T22:59:38.000Z","msg":"日日都係咁  係屋企一粒聲都無出過"},{"pid":"0587647c2ce236f7ff2487079c6fb90f79b7ca0d","tid":922903,"uid":5434,"like":1,"dislike":0,"score":1,"quote":{"pid":"194319cc77202bcb00099f0d6f52b421bf72d9c9","tid":922903,"uid":122623,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-11-30T21:50:40.000Z","msg":"有時因為小小事就想喊<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n分唔清係自己懦弱定痴咗線<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-30T23:15:09.000Z","msg":"我都係 無啦啦係條街到喊 控制唔到<img src=\"/assets/faces/fs/want_die.gif\" class=\"hkgmoji\" />"},{"pid":"891d4db82bd0e1115b05895021921ad6a410f929","tid":922903,"uid":5434,"like":0,"dislike":0,"score":0,"quote":{"pid":"f327f2df8e19e1d30256d081bb2d06896d2b7cbc","tid":922903,"uid":72801,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-30T21:58:53.000Z","msg":"有抑鬱嘅同時對好多事物無曬衝勁先大獲<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-30T23:20:01.000Z","msg":"都差唔多去到呢個地步<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /> <br />\n//如果有眼淚只不過生理分泌//"},{"pid":"8ed969193412906019716e1ec20afadbeb1504cc","tid":922903,"uid":122513,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-01T07:23:38.000Z","msg":"看來你心中的痛苦，已令你覺得生無可戀．．．人生之中往往有很多重要的決定，而自殺肯定是人一生中最矛盾、最痛苦，也是最重大的決定。我相信，自殺不是你想選擇的，更不是你唯一的選擇，只不過你所面對的困境和痛苦好像超越了你所能應付的，是嗎？<br />\n<br />\n <br />\n<br />\n無論你將會如何打算你的前路，我也希望你不要將困擾藏在心裡，好像氣球裡積存的壓力一樣。你不如停一停，<a href=\"http://到我們的網站www.help4suicide.com.hk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2F%E5%88%B0%E6%88%91%E5%80%91%E7%9A%84%E7%B6%B2%E7%AB%99www.help4suicide.com.hk&d=%2FrJA25CgA%2BBTVbOoZHtMgDCdMQr7etzq9tFbjrA%2B72k%3D&h=5f41c519\" data-auto-link target=\"_blank\">到我們的網站www.help4suicide.com.hk</a>。那裡有一些與自殺有關的人與事，你可以隨心看看（<a href=\"http://www.help4suicide.com.hk/myth_showlist.php）。\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.help4suicide.com.hk%2Fmyth_showlist.php%EF%BC%89%E3%80%82&d=%2FrJA25CgA%2BBTVbOoZHtMgDCdMQr7etzq9tFbjrA%2B72k%3D&h=d5f12bf5\" data-auto-link target=\"_blank\">http://www.help4suicide.com.hk/myth_showlist.php）。</a> 你更可以進入網站內的『Chat窿』（（星期一至五：上午六時至凌晨一時；星期六、日及公眾假期：下午８時至凌晨１時），即時與我們的義工在網上交談，或致電我們24小時電話熱線2389-2222，與我們的義工傾訴。<br />\n<br />\n <br />\n<br />\n我們願意聆聽你的心聲，伴你一起走過這段艱難的時候！只因『晴天雨天要樂天，難關難過總會過』！<br />\n<br />\n <br />\n<br />\n《自殺．自療．互助舍》"},{"pid":"10580b8f60132eb68b476d496c8ca0d72b5b11a3","tid":922903,"uid":171832,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-01T14:07:31.000Z","msg":"我都係咁 每個星期重有一兩日係咁 好辛苦"},{"pid":"60