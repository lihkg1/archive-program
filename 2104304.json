\"https://na.cx/i/zLbgCxW.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzLbgCxW.png&h=ebdfabd5&s={SIZE}\" />"},{"pid":"c3ef97fdd2437badfa2d03dc07e1bec7f5261db9","tid":2104304,"uid":80356,"like":1,"dislike":0,"score":1,"quote":{"pid":"21761c954fcfa7a88dbd4cf8faf57362895e55e5","tid":2104304,"uid":98386,"like":0,"dislike":6,"score":-6,"quote":{"pid":"ceb3a569a5b3237e6ca78065672175b47fa341a6","tid":2104304,"uid":242805,"like":1,"dislike":3,"score":-2,"quote":{"pid":"a0f2efb4031b586fd15b35150cd1d65f4d7ab28d","tid":2104304,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-12T00:11:30.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/20200712/6W2A4INRCHP74J2NWXZ73FELIQ/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20200712%2F6W2A4INRCHP74J2NWXZ73FELIQ%2F&d=GdzNT1%2FdEV%2FiwqmWSoLNnpugP7yqsTcUQnBN8ZzcBqk%3D&h=323d95ab\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20200712%2F6W2A4INRCHP74J2NWXZ73FELIQ%2F&h=1f4d95e6\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/20200712/6W2A4INRCHP74J2NWXZ73FELIQ/</a><br />\n<br />\n節錄<br />\n<br />\n法律界：警查私隱案奇怪 <br />\n鍾劍華：我話特首辦洩資料 係咪搜佢電腦？<br />\n<br />\n<br />\n【夜搜民研】<br />\n<br />\n【本報訊】港版國安法推行後，<br />\n。。。。。。<br />\n研究所副行政總裁鍾劍華直斥，行動明顯是政治打壓，政府做法「下作」、「低莊」。受警方搜查影響，研究所職員需通宵重新準備票站二維碼，令昨日的初選延遲三小時至中午才舉行。有法律界人士指，<br />\n。。。。。。<br />\n<br />\n前晚6時許，約十名網罪科探員持搜查令到民研的黃竹坑總部，指懷疑包<br />\n。。。。。。<br />\n發現涉案的2013年調查問卷或撿走電腦。<br />\n<br />\n<img src=\"https://hk.appledaily.com/resizer/fXbq_DEzr7uxJuh8Ue7jOlNcMew=/797x448/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/ZJG2P5TUO5IGVA6XPVUESIW5AA.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FfXbq_DEzr7uxJuh8Ue7jOlNcMew%3D%2F797x448%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FZJG2P5TUO5IGVA6XPVUESIW5AA.gif&h=1823aded&s={SIZE}\" /><br />\n鍾劍華（左）及民研主席鍾庭耀昨凌晨會見記者。<br />\n<br />\n<br />\n累重製二維碼延遲投票<br />\n<br />\n相關新聞：警查票站影市民 製白色恐怖<br />\n<br />\n民研副行政總裁鍾劍華指，當日下午2時曾有人到民研的灣仔辦事處示威，而當晚警方到民研總部調查時，職員正為票站出入登記用的二維碼、票站指引等準備，但因警方搜查而延誤，加上有警員搜查過程中疑不小心拍下有關的二維碼，雖然事後已刪除有關相片，但為保障參與投票人士的私隱、避免不明來歷選票，職員事後需通宵重新準備，令昨日初選延遲3小時至中午12時舉行。昨晨鍾巡視票站後認為運作大致順利，對元朗有票站多達300人排隊，「證明市民唔服氣！」<br />\n<br />\n對於警方於選前一夜高調行動，鍾指政府明顯為恫嚇市民，阻止選民投票，「政府啱啱講完初選可能違反國安法，警方就咁做，你話係咪政治打壓？」警方今次行動，源自網上有人聲稱要攻擊研究所電腦，竊取涉及警員個人資料的文件並放上網。鍾劍華批評，警方因匿名投訴而大費周章的做法荒謬，「我話特首辦洩露我嘅資料，警方係咪去搜特首辦嘅電腦？」根據教育局打壓教師言論，以及港台事件，鍾認為連串行動反映政府的針對性行為越趨嚴重，「根本係鼓勵文革式批鬥！」<br />\n<br />\n港大法律學院首席講師張達明指，過去涉及私隱的案件一般由私隱專員公署調查，今次卻由警方主動高調跟進，「感覺好怪」。<br />\n<br />\n法政匯思召集人吳宗鑾指，<br />\n。。。。。。<br />\n吳認為，警方是次大費周章搜查令人費解，令外界質疑其專業判斷。"},"citedBy":1,"replyTime":"2020-07-12T00:37:49.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><br />\n話人地怪又話做法唔合理，但係鳩講吓就算咩行動追究都冇。<br />\n同法律界班垃圾一樣，日日對國安法深感憂慮，而家俾人踩到上心口都係咩都冇做<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2020-07-12T00:56:37.000Z","msg":"尻up下做俾你班人睇 之後唔夠錢咪大大聲眾籌 你班傻仔又一車車錢送上門<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-12T01:20:20.000Z","msg":"唔好講咁多<br />\n你兩毫子送上去振災都冇人要<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"1fa29b7d8dad11633717d22b0dd45fe0e5044554","tid":2104304,"uid":56381,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-12T01:20:36.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"d61f4d38c270d3ba45a89e3edfb7084917092fa7","tid":2104304,"uid":39710,"like":1,"dislike":0,"score":1,"quote":{"pid":"4525c48e9602258dfa0fee0a2f67c31201d8e54a","tid":2104304,"uid":254594,"like":5,"d