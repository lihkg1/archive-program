d":2290540,"uid":14918,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-18T06:00:58.000Z","msg":"Lm"},{"pid":"b4507641d5c0bf95019cae2140898f4a4908949c","tid":2290540,"uid":74935,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-11-18T06:09:42.000Z","msg":"勁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"fc1f26f7da54ea942cedebe285241e00a12d1f76","tid":2290540,"uid":287269,"like":1,"dislike":0,"score":1,"quote":{"pid":"35115f3c3b038c25561b55abdd3780a6241d4e90","tid":2290540,"uid":200758,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2020-11-18T05:43:16.000Z","msg":"<a href=\"https://twitter.com/llinwood/status/1328921766799011841?s=21\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Fllinwood%2Fstatus%2F1328921766799011841%3Fs%3D21&d=KoeRi8LHiva86SpHjnbz1ZmCY7kjLy3g2NNjbjbrEl8%3D&h=a348eac3\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftwitter.com%2Fllinwood%2Fstatus%2F1328921766799011841%3Fs%3D21&h=52f9be5f\" data-auto-link target=\"_blank\">https://twitter.com/llinwood/status/1328921766799011841?s=21</a>"},"citedBy":0,"replyTime":"2020-11-18T06:28:47.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"21f6cc48cacb79dcce7290f2e235bb1c847bb439","tid":2290540,"uid":54550,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2020-11-18T06:40:29.000Z","msg":"繼續<br />\n<strong>Nevada</strong><br />\n汁 - <a href=\"https://www.youtube.com/watch?v=ZeWfhRUJ0og&amp;feature=emb_logo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DZeWfhRUJ0og%26feature%3Demb_logo&d=KoeRi8LHiva86SpHjnbz1ZmCY7kjLy3g2NNjbjbrEl8%3D&h=954b1a00\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=ZeWfhRUJ0og&amp;feature=emb_logo</a><br />\n<br />\n11月17消息 - <br />\n侵團隊其中一代表Jesse Binnall確定內華達州入lawsuit，佢指當去除所有不當選票之後，內華達州係侵贏<br />\n<br />\n<strong>Pennsylvania</strong><br />\n<br />\n侵團隊投訴佢地嘅觀察員被隔開100尺咁遠 而PA supreme court 以5:2裁定 無規定監票員應該向咩距離入面觀票先係合法. 佢地補充，法庭唔應該好似之前上訴庭嘅裁決咁 為監票員距離下定義 (補充說明 PA 上訴庭係裁定左侵佢地可以向六尺內觀票)<br />\n<br />\nthe court said the state&rsquo;s election code does not set a minimum distance poll observers need to be in order to watch ballot counts and meet the laws&rsquo; requirements. The majority added that if the court imposes a distance requirement, as the lower court did, it would be improperly rewriting the statute.<br />\n<br />\nPA州最高法院訴訟輸左，但朱利安尼向11月17號向Fox Business入面講預左有幾單訴訟打到最高法庭，就好似當年向Florida入面嘅州supreme court都係判戈爾贏，因為嗰個州嘅Court係由DEM人把持，布殊要打到supreme court先贏"},{"pid":"fda455158da12738a32f559013e981ec61647539","tid":2290540,"uid":51057,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-11-18T06:45:57.000Z","msg":"GA個州長會唔會被自殺<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3ae728ff2f096dc16ca21d6f20a47284d039e7f0","tid":2290540,"uid":43939,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-11-18T06:46:45.000Z","msg":"GA 係咁比人追擊好好笑<br />\n雖然唔知有冇用不過好on9 件事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"37c7e773209d5b8998355170eff7f0623b71af88","tid":2290540,"uid":54550,"like":3,"dislike":0,"score":3,"quote":{"pid":"fda455158da12738a32f559013e981ec61647539","tid":2290540,"uid":51057,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-11-18T06:45:57.000Z","msg":"GA個州長會唔會被自殺<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-18T06:46:49.000Z","msg":"佢而家自殺實係DEM郁手架喎. DEM 到時咪水洗都唔清 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"11f3847af32b74a2ead05b3492c58c030bf9fefd","tid":2290540,"uid":51057,"like":3,"dislike":0,"score":3,"quote":{"pid":"37c7e773209d5b8998355170eff7f0623b71af88","tid":2290540,"uid":54550,"like":3,"disl