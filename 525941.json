\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs10.postimg.org%2Feq8erqgi1%2FScreenshot_2017-06-11-09-54-22.png&h=99e1c7d2&s={SIZE}\" /><br />\n<br />\n<img src=\"https://s3.postimg.org/mhshwom03/Screenshot_2017-06-11-09-42-18.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs3.postimg.org%2Fmhshwom03%2FScreenshot_2017-06-11-09-42-18.png&h=2dcd081b&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: green;\">繼續去死撐啦，同快D用假膠黎掩飾啦傻鳩</span></strong></span><img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"3dd2ee9472ab6ae2a274380bad9bdfe78bc7e3f1","tid":525941,"uid":38820,"like":0,"dislike":1,"score":-1,"quote":{"pid":"7be04d46509e610419fad6d5425a6944e6aa841b","tid":525941,"uid":74981,"like":0,"dislike":1,"score":-1,"quote":{"pid":"883a5a4d18225f266d1693b12da0ad0dd808ffa5","tid":525941,"uid":32583,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2018-01-11T07:43:51.000Z","msg":"肥絲一早block左"},"citedBy":1,"replyTime":"2018-01-11T07:47:43.000Z","msg":"Well done<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-01-11T07:49:14.000Z","msg":"same<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"643a17624d4dc9cad7283a047ca8d91bf844903b","tid":525941,"uid":74981,"like":0,"dislike":2,"score":-2,"quote":{"pid":"9114202c4c0745fb3de888a66113db1701f31d81","tid":525941,"uid":21423,"like":1,"dislike":1,"score":0,"quote":{"pid":"883a5a4d18225f266d1693b12da0ad0dd808ffa5","tid":525941,"uid":32583,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2018-01-11T07:43:51.000Z","msg":"肥絲一早block左"},"citedBy":1,"replyTime":"2018-01-11T07:47:11.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-01-11T07:49:17.000Z","msg":"你食撚屎啦on9，你個gag無人笑呀傻閪<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b059d083a311385377070ce30d87001c6ef5f3c0","tid":525941,"uid":74981,"like":0,"dislike":2,"score":-2,"quote":{"pid":"3dd2ee9