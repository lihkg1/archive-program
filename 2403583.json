aces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"16d92e01a9f986d16993799fdca2cf98647fcd16","tid":2403583,"uid":42246,"like":0,"dislike":0,"score":0,"quote":{"pid":"2db99285ef99441cd36571b3e17db759c1329195","tid":2403583,"uid":60432,"like":2,"dislike":0,"score":2,"quote":{"pid":"631f63f9ec786449f923582f2df6d711fcebfec9","tid":2403583,"uid":42246,"like":1,"dislike":0,"score":1,"quote":{"pid":"8266b3c17b1f543bb566da9a8babd76a16fa0307","tid":2403583,"uid":60524,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-02-11T07:32:30.000Z","msg":"曼城洗錢有冠軍有盃<br />\n曼聯洗錢加強魔性<br />\n2間球會風格唔同<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-11T07:43:33.000Z","msg":"近5季有兩英超<br />\n負6億都值既<br />\n<br />\n排第二負5億<br />\n有個英超亞軍<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-11T07:54:21.000Z","msg":"一個有人注資<br />\n一個有人抽錢走<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-11T08:01:01.000Z","msg":"有人抽錢走<br />\n咪一樣年年用買一億買人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c042e1060221211176629efc2d75469e20efde47","tid":2403583,"uid":42246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-11T08:05:36.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"aa3866e57b06a8b315185a74eaf9270ad9edf5cf","tid":2403583,"uid":228170,"like":0,"dislike":0,"score":0,"quote":{"pid":"068d90069c4db88528da4d8316cb09acfdb351b9","tid":2403583,"uid":42246,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-02-11T07:23:37.000Z","msg":"有錢，就是任性！曼城、曼聯兩大英超富豪球隊持續在轉會市場「高買低賣」，有數得計，近5季轉會淨開支冠絕歐洲5大聯賽，成為足球界「大嘥鬼」。<br />\n陷入嚴重的財困西甲班霸巴塞隆拿齋計開支用得最多錢，不過他們收入也不少，排第三位，同樣財大氣粗的巴黎聖日耳門和國際米蘭分列第四、五位。<br />\n到底哪支球隊是賺過盤滿砵滿的轉會精明眼？貼士：不是李斯特城。<br />\n<br />\n<span class=\"red\">國際體育研究中心（CIES）統計歐洲5大聯賽近10個轉會窗數據，檢視各隊轉會開支與收入，結果曼城以負6.31億歐元力壓負5.86億歐元的曼聯榮登最大淨開支之王。</span><br />\n<br />\n<br />\n如果只計轉會開支，近期陷入破產邊緣的巴塞隆拿高達11.71億歐元，實在相當驚人，只因他們亦有7億歐元轉會收入，才在排行榜列第三位。有趣的是，巴塞兩大勁敵皇家馬德里和馬德里體育會排名相當後，明顯在轉會市場操作遠較巴塞精明。<br />\n<br />\n沒有一支英超球隊期內轉會淨開支成正數，支出方面車路士較曼聯更多，他們收入遠勝紅魔所以只排英超第五。第三位爆出冷門，是利物浦市另一球隊愛華頓。阿士東維拉2019/20重返英超時大肆擴軍，高佔第四位。上屆冠軍利物浦管理層擅玩Money Ball，開支超過6億歐元的同時，轉會收入亦接近5億，在20隊之中排第14位，較轉會市場獨具慧眼的李斯特城財技更加出神入化。<br />\n<br />\n不過說到要在轉會市場有錢賺，英超球隊完全不及其餘4大聯賽球隊。法甲20支球隊之中，竟多達16隊轉會淨開支為正數，目前聯賽榜首的里爾期內大賺近2億歐元，次席的里昂也有逾1.5億歐元進帳，榮登5大聯賽「轉會精明眼」頭兩位，證明成績不一定要靠花大錢得來。西甲和意甲也分別有9隊和8隊轉會收入高於開支，德甲亦有6隊之多。<br />\n<br />\n長年雄霸當地聯賽的祖雲達斯和拜仁慕尼黑，以至西甲馬德里兩大豪門皇家馬德里及馬體會常予人「轉會大豪客」的印象，然而他們在轉會市場同時有可觀收益，在轉會淨開支方面未如想像中高。<br />\n<br />\n與拜仁長年對抗的多蒙特，甚至有錢落袋，蜜蜂兵團陣中年輕球星者眾，查頓辛祖和夏蘭特更是各大強隊收購目標，未來數年可以坐定粒六慢慢數銀紙。<br />\n<br />\n<br />\n<br />\nhk01唔貼link<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n曼城係水魚<br />\n不過有英超<br />\n<br />\n另一隊就<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-11T08:14:09.000Z","msg":"而家邊隊捧英超最多？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"32b95292c93a0ab9cc2864dda59ff31a858b453d","tid":2403583,"uid":42246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-11T08:14:14.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"28b73ad923c8b842407e8c9a131a221992e6e517","tid":2403583,"uid":42246,"like":0,"dislike":0,"score":0,"quote":{"pid":"aa3866e57b06a8b315185a74eaf9270ad9edf5cf","tid":2403583,"uid":228170,"like":0,"dislike":0