if\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/arrogant.gif\" class=\"hkgmoji\" />"},{"pid":"2fd86d6381d18fa301c4fb89d65c75998a57832b","tid":2430442,"uid":105627,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-03-03T06:08:25.000Z","msg":"打mRNA 咪冇事囉<br />\n都冇virus何來virion"},{"pid":"0231542e9f96fa33efc1d74d15db2ff7d031df89","tid":2430442,"uid":20241,"like":0,"dislike":0,"score":0,"quote":{"pid":"2fd86d6381d18fa301c4fb89d65c75998a57832b","tid":2430442,"uid":105627,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-03-03T06:08:25.000Z","msg":"打mRNA 咪冇事囉<br />\n都冇virus何來virion"},"citedBy":0,"replyTime":"2021-03-03T06:10:25.000Z","msg":"堅定流<br />\nlm學嘢"},{"pid":"ff952e536686e3dda592512dfcf88418f4047c39","tid":2430442,"uid":262674,"like":0,"dislike":0,"score":0,"quote":{"pid":"2fd86d6381d18fa301c4fb89d65c75998a57832b","tid":2430442,"uid":105627,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-03-03T06:08:25.000Z","msg":"打mRNA 咪冇事囉<br />\n都冇virus何來virion"},"citedBy":0,"replyTime":"2021-03-03T06:26:00.000Z","msg":"想知 <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"a95746efbbd72b3afb46099d1789b364055588d9","tid":2430442,"uid":12599,"like":0,"dislike":0,"score":0,"quote":{"pid":"2fd86d6381d18fa301c4fb89d65c75998a57832b","tid":2430442,"uid":105627,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-03-03T06:08:25.000Z","msg":"打mRNA 咪冇事囉<br />\n都冇virus何來virion"},"citedBy":0,"replyTime":"2021-03-03T06:26:23.000Z","msg":"但係mRNA都會有spike protein，理論上都會有相同問題？<br />\n<br />\n打完疫苗個空窗期俾第二隻病毒攻擊都會引發ADE?"}]}