=\"font-size: xx-large;\"><strong>唯唯 我哋約好11號晚同12號再見啦<br />\n不見不散<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /></strong></span></span>"},{"pid":"49d26ce5af3bfe870a17804c81c5e1ed0e7753be","tid":1199784,"uid":38946,"like":1,"dislike":0,"score":1,"quote":{"pid":"f71c0dcf6d9da52d56d42dab58983bc119f694b2","tid":1199784,"uid":152123,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-06-10T14:54:19.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://na.cx/i/ksgCHG5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%2Fi%2FksgCHG5.png&h=a13f3dfb&s={SIZE}\" /><br />\n<br />\n<br />\n<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-10T15:01:06.000Z","msg":"盾牌<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ce1d0786b186e2413ba32a5430f16b5e9468e301","tid":1199784,"uid":38946,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-06-10T15:04:15.000Z","msg":"<img src=\"https://na.cx/i/VwrCHQU.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVwrCHQU.png&h=4234c977&s={SIZE}\" /><br />\n唯唯<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"de9f9db7db9ed264a3f788ef73a39751c71cef50","tid":1199784,"uid":152123,"like":11,"dislike":0,"score":11,"quote":{"pid":"49d26ce5af3bfe870a17804c81c5e1ed0e7753be","tid":1199784,"uid":38946,"like":1,"dislike":0,"score":1,"quote":{"pid":"f71c0dcf6d9da52d56d42dab58983bc119f694b2","tid":1199784,"uid":152123,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-06-10T14:54:19.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://na.cx/i/ksgCHG5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.