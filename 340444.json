mg.eservice-hk.net/upload/2017/07/30/111008_f5e3556e28be3fa3de1967c3bb30957b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F30%2F111008_f5e3556e28be3fa3de1967c3bb30957b.jpg&h=75c13b0e&s={SIZE}\" /><br />\n<br />\n呢張最右條友個髮型潮到<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n右2有啲似William Hung 㖭<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a9c83db72c7a62bb806e9dcba0c3a6eaf14e1364","tid":340444,"uid":22302,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-30T04:45:44.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"457e7b147fe4e60125b46ec1d24d70a5f42a7f1f","tid":340444,"uid":57205,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-30T04:52:19.000Z","msg":"留名<br />\n黑白相好有FEEL<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"3266d124cae775e6fb684713f4f7e7db246a7a4f","tid":340444,"uid":51720,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-07-30T05:25:36.000Z","msg":"遲早變歷史文物，要好好保存 <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <br />\n英殖時代嘅香港年報，恐怕只能去中央圖書館嘅參考圖書館，先至可以閱覽到 <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"329a3a185d0f928c2e494daa0c558c7205799318","tid":340444,"uid":67895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-30T06:22:19.000Z","msg":"巴打一定好靚仔<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n阿公靚仔都咁<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"b6a79390bacd8fd32176e9aff4607b0afdc5f2bc","tid":340444,"uid":88392,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-07-30T11:12:28.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/07/30/190931_66d31ad71724aff735a698ac9ad7dc04.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F30%2F190931_66d31ad71724aff735a698ac9ad7dc04.jpg&h=381f6d88&s={SIZE}\" /><br />\n以前啲人嘅字寫得好有心機<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2017/07/30/190932_5563ffb691c863c86aae59086af56b89.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F30%2F190932_5563ffb691c863c86aae59086af56b89.jpg&h=51281c92&s={SIZE}\" /><br />\n阿公點解你咁型<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2017/07/30/190933_80fd1af7a03e08353ec179aa9385b68e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F30%2F190933_80fd1af7a03e08353ec179aa9385b68e.jpg&h=f0aebe08&s={SIZE}\" /><br />\n<br />\n我公公婆婆由細都係香港大，係二戰時婆婆去咗大陸避難（嗰陣佢得幾歲）<br />\n阿公就好似二戰時人在澳門<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8671670837f2435a32d7da305b913037326ef91e","tid":340444,"uid":88392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-30T11:12:54.000Z","msg":"<blockquote><blockquote><img src=\"https://img.eservice-hk.net/upload/2017/07/30/111008_f5e3556e28be3fa3de1967c3bb30957b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F30%2F111008_f5e3556e28be3fa3de1967c3bb30957b.jpg&h=75c13b0e&s={SIZE}\" /><br />\n<br />\n呢張最右條友個髮型潮到<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n右2有啲似William Hung 㖭<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\nWilliam Hung係我公<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5528c78098f49f674845f4aa52e1d37ee811abbf","tid":340444,"uid":88392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-30T11:13:42.000Z","msg":"<blockquote>遲早變歷史文物，要好好保存 <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <br />\n英殖時代嘅香港年報，恐怕只能去中央圖書館嘅參考圖書館，先至可以閱覽到 <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /></blockquote><br />\n一定會珍藏<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> 留比下代繼續傳<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"87e53c8c3389c7f2a1981316cef29cbcebb92cb4","tid":340444,"uid":88392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-30T11:14:33.000Z","msg":"<blockquote>巴打一定好靚仔<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n阿公靚仔都咁<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /></blockquote><br />\n粉紅色床單<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 你肯定係巴<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /> ？<br />\n<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /> 不要幻想我個樣<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e6a3705e4dec3cb48e40de21ad56bdd2a6a85abd","tid":340444,"uid":15730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-30T12:15:05.000Z","msg":"<blockquote>一定有錢人<br />\n影咁多相<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /></blockquote><br />\n似係 身光頸靚咁"},{"pid":"9fc541b038e8f202afb8b73094d30a97571e39f1","tid":340444,"uid":41423,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-30T12:28:47.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"dbee845f2dba0e798179d4d3c33a318a71f422e2","tid":340444,"uid":5372,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-30T12:30:39.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2017/07/30/111008_f5e3556e28be3fa3de1967c3bb30957b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F30%2F111008_f5e3556e28be3fa3de1967c3bb30957b.jpg&h=75c13b0e&s={SIZE}\" /><br />\n<br />\n呢張最