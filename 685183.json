islike":0,"score":0,"citedBy":0,"replyTime":"2018-05-31T14:38:37.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"fdc20f3c3217f10a3b640212eb1cffd95e1e7fb1","tid":685183,"uid":176366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-31T14:39:13.000Z","msg":"郭官小撚心啲行路"},{"pid":"aba4ac627412817a23713faeda0975ab0d5ab854","tid":685183,"uid":176366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-31T14:48:14.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"aeec99cdb762c1171ac9c34a9510efcc0042f2a8","tid":685183,"uid":176366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-31T14:48:38.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0c4c7736b61f217e666aaee8ce43b0057c72ddb3","tid":685183,"uid":132859,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-31T15:03:07.000Z","msg":"永遠記得烈士貢獻<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"e16256a5daf3e2d1c1ea515e53bb8bf482fa0f3d","tid":685183,"uid":53026,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-05-31T16:17:54.000Z","msg":"唔好意思，訓咗好耐，此人收監未？<br />\n<br />\n<img src=\"https://vignette.wikia.nocookie.net/evchk/images/4/48/Cy_support_boy_throwing.jpg/revision/latest/scale-to-width-down/640?cb=20130812155525\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fevchk%2Fimages%2F4%2F48%2FCy_support_boy_throwing.jpg%2Frevision%2Flatest%2Fscale-to-width-down%2F640%3Fcb%3D20130812155525&h=e2090ba1&s={SIZE}\" />"}]}