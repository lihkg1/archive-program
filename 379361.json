aWQ9aGlnaGxhbmRlcjtzbT0xO3c9NzQ4O2g9NzQ5/http://media.zenfs.com/en/homerun/feed_manager_auto_publish_494/8666c2bfe2951a576f2ef9ca38974366\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs.yimg.com%2Fny%2Fapi%2Fres%2F1.2%2Fb52fq6EfikPIRPxmGQN9Pw--%2FYXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9NzQ4O2g9NzQ5%2Fhttp%3A%2F%2Fmedia.zenfs.com%2Fen%2Fhomerun%2Ffeed_manager_auto_publish_494%2F8666c2bfe2951a576f2ef9ca38974366&h=7c8366aa&s={SIZE}\" /><br />\n<img src=\"https://s.yimg.com/ny/api/res/1.2/Uc9YoV3NBQ9Y.JEbfjMr5Q--/YXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9NzQ5O2g9NzQ4/http://media.zenfs.com/en/homerun/feed_manager_auto_publish_494/850a3e91bdc11adee1dc63d6cac129a7\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs.yimg.com%2Fny%2Fapi%2Fres%2F1.2%2FUc9YoV3NBQ9Y.JEbfjMr5Q--%2FYXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9NzQ5O2g9NzQ4%2Fhttp%3A%2F%2Fmedia.zenfs.com%2Fen%2Fhomerun%2Ffeed_manager_auto_publish_494%2F850a3e91bdc11adee1dc63d6cac129a7&h=fb2739ee&s={SIZE}\" /><br />\n<br />\n今屆《2017香港小姐競選》喺星期日（9月3日）舉行，近年港姐經常都被指佳麗美貌一年不如一年，但相反由泰國搞嘅變性人選美大賽（Miss Tiffany&rsquo;s Universe），一班佳麗嘅質素就越嚟越高。比賽日前已經喺芭堤雅舉行，最後由有「泰版Angelababy」之稱嘅新人演員Yoshi Rinrada，喺30名佳麗中脫穎而出，成為第20屆選美皇后。<br />\n<br />\n今年20歲嘅Yoshi，其實2015年就憑劇集《為愛所困》走紅，不過當時佢就否認佢嘅變性傳聞，只係承認整過嘴唇和隆乳整形手術。查實佢17歲已經完成變性手術，成為名符其實嘅女性。<br />\n<br />\n原來Yoshi自細就好鍾意洋娃娃，少年時代就更加已經係男生女相，加上擁有小蠻腰、手腳又纖幼，Yoshi大個咗就向家人坦承話想做女仔，不過就被家人反對。直到佢開始拍劇漸露頭角後，家人先肯放低成見，接受佢做變性手術，完成手術後靚過唔少真女人。<br />\n<br />\n<br />\n比賽當晚佢爸爸亦有到場支持，場面十分感動。而佢當選後，佢IG followers人數直升到103萬，認真犀利呀！<br />\n<br />\n<br />\nYoshi咁靚女，當然會俾人將佢同「泰版最美變性人」之稱嘅Poyd比較啦！Poyd自從2013年拍咗港產片《掃毒》之後就甚為香港人熟悉，亦令更多香港人發現原來泰國有好多「靚女」。既然泰國美女喺香港都咁受落，唔知Yoshi會唔會學Poyd咁嚟香港發展下呢？<br />\n<br />\n<br />\n<img src=\"https://s.yimg.com/ny/api/res/1.2/26N5uu_UxQ5uhrUb30SzyQ--/YXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9NjI0O2g9NjQ4/http://media.zenfs.com/en/homerun/feed_manager_auto_publish_494/16109a842893fe7a460c6fe71aadb944\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs.yimg.com%2Fny%2Fapi%2Fres%2F1.2%2F26N5uu_UxQ5uhr