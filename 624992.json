cee54473ca816","tid":624992,"uid":54927,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-04-11T07:49:20.000Z","msg":"祖國收番日本啦吊"},{"pid":"6bdd9b08cadd14539da4881b8d37e6408a10c230","tid":624992,"uid":93266,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-04-11T07:51:22.000Z","msg":"根本有堆人就唔係討論<br />\n<br />\n特登係度搵交嘈"},{"pid":"afe5355ad6626f5e94dc67faa156504378f5d2ab","tid":624992,"uid":38523,"like":1,"dislike":0,"score":1,"quote":{"pid":"70e812658de7e15ed194874ce83cee54473ca816","tid":624992,"uid":54927,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-04-11T07:49:20.000Z","msg":"祖國收番日本啦吊"},"citedBy":0,"replyTime":"2018-04-11T07:51:23.000Z","msg":"掉轉就真<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n支那比日本佔領過<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0807ac0e45e711214c89b24294771cceee2e96b4","tid":624992,"uid":134400,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2018-04-11T07:51:47.000Z","msg":"日經原文就係呢篇<br />\n<br />\n<a href=\"https://r.nikkei.com/article/DGXMZO29216170Q8A410C1EA2000\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fr.nikkei.com%2Farticle%2FDGXMZO29216170Q8A410C1EA2000&d=a3%2FA6laLgyZZ0mbNJ%2FLrwtr9upuAghWR75VkZoMWgf8%3D&h=7986af92\" data-auto-link target=\"_blank\">https://r.nikkei.com/article/DGXMZO29216170Q8A410C1EA2000</a><br />\n<br />\n東大の加藤教授は「経済性が大幅に向上したことで、レアアースの資源開発の実現が視野に入ってきた」と強調する。<br />\n<br />\nレアアースを巡っては、日本は大部分を中国からの輸入に依存する。中国は全世界の生産量の約9割を握るため、価格の高騰や供給が不安定になる事態が発生してきた。<br />\n<br />\n一方、東大の加藤教授らは2012年に南鳥島周辺でレアアースを大量に含む可能性が高い泥を発見。<br />\n<br />\n剩係講到發現左有儲藏量，無講過有技術可腑以開採<br />\n<br />\n跟住就跟左呢句&ldquo;14年には三井海洋開発、トヨタ自動車などと「レアアース泥開発推進コンソーシアム」を設立し、回収技術の開発に取り組んできた。&rdquo;<br />\n<br />\n事實上レアアース泥開発推進コンソーシアム同東大今次呢team 人就完全無關既<br />\n<br />\n成篇野都係有心誤導"},{"pid":"5bf1a25783fad357e309812b5a07ac11d967e0ad","tid":624992,"uid":51701,"like":2,"dislike":0,"score":2,"quote":{"pid":"38795352276043fc7b4a8f731e12de7d86959cdf","tid":624992,"uid":9732,"like