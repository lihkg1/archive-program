lass=\"hkgmoji\" />"},{"pid":"fd82cb3a3bc159c83eccaafbea411be3c5634ef2","tid":1228222,"uid":150921,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T03:35:20.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"1dd480a47a779b20af12207da5ec3b76b80e4d2b","tid":1228222,"uid":150921,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T03:38:19.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6d6c017d6a69e6df63c76965591f2163f819766d","tid":1228222,"uid":150921,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T03:48:06.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"ae98468fa331c25e50b502ae46c6e0ee21cf5734","tid":1228222,"uid":150921,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T04:01:29.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a24843afe309ebb8f47b26e9d781044790766d1a","tid":1228222,"uid":150921,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T05:34:54.000Z","msg":"推"},{"pid":"77a032bf1f6fd176ceb69534c0cba8a4e0565bec","tid":1228222,"uid":147855,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-16T05:45:36.000Z","msg":"呢個真<br />\n我老母已經唔係親政府果啲人 但佢係果啲想乜都唔付出淨係希望個天會賜俾佢果種人<br />\n唔會明白點解年輕人咁激進<br />\n尋晚佢知道呢單野都係話點解唔諗下屋企人父母呢啲說話<br />\n而唔係走去怪個政權"}]}