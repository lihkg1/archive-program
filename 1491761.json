0,"dislike":0,"score":0,"quote":{"pid":"3ea7e4df7bf27786a9b7e015b8047e6309a40c61","tid":1491761,"uid":255637,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-22T03:45:30.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 你經歷既呢個暑假之後成長得會好快 加油"},"citedBy":1,"replyTime":"2019-08-23T07:03:48.000Z","msg":"希望係咁 希望自己可以捱過壓力同絕望啦"},{"pid":"96511b043c3aac16bef7ea84682c1a702728bd7e","tid":1491761,"uid":300082,"like":0,"dislike":0,"score":0,"quote":{"pid":"ceec588c3adcd66c6abf6d76ca02ac1ef3f9fa68","tid":1491761,"uid":307890,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-22T14:25:03.000Z","msg":"今年我都18 好似乜都冇做咁<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />生日嗰陣咁啱得咁橋香港「黎料」<br />\n我發誓我成世人都唔會忘記自己嘅18歲<br />\n<br />\n日日睇到啲新聞都好唔開心，又同屋企人嘈，2019真係煩到想嘔<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-23T07:20:19.000Z","msg":"呢個真 淨係呢一年D壓力係提升左幾倍<br />\n屋企人明明係80年代出世 <br />\n見證香港由繁榮走到今日田地 <br />\n依然可以盲目瘋狂撐共 屌尻英國侵蝕大中華<br />\n講廿幾次都唔肯聽 又唔肯睇下香港歷史<br />\n次次理論就話我凶尻佢 又話我比人洗腦 紅衛兵<br />\n之後我都廢撚事講 <br />\n有個勇武fd仲成日笑住問我幾時係屋企勇武<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f261e2620b5ffadca825656e32bd35b3bd19df5a","tid":1491761,"uid":300082,"like":0,"dislike":0,"score":0,"quote":{"pid":"9cb02bfa41d568b51f6a836546d7a857bc64e1ad","tid":1491761,"uid":25073,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-22T15:00:34.000Z","msg":"肯發夢仲要單機發夢<br />\n請受小弟一拜<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-23T07:23:57.000Z","msg":"唔使拜我<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />我做緊一個公民應該要做嘅事<br />\n<strong><span style=\"color: gold;\">因為呢個係我嘅責任</span></strong><br />\n雖然solo好撚大壓力<br />\n但我只有一個信念 就係<br />\n<strong><span style=\"color: red;\"><span style=\"font-size: x-large;\">光復香港 時代革命</span></span></strong>"},{"pid":"eb9ab2392bfbca6ef5803087349c18fbdac9f341","tid":1491761,"uid":311865,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-23T07:26:47.000Z","msg":"加油 <br />\n<br />\n香港既未來就係靠你地班年輕人"},{"pid":"c2d568fedf87e346780fee48cd6be73baa5977cc","tid":1491761,"uid":300082,"like":0,"dislike":0,"score":0,"quote":{"pid":"b9492bd24b644503eda7121af19677a285d36e38","tid":1491761,"uid":305458,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-23T01:36:46.000Z","msg":"<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-23T07:32:55.000Z","msg":"加油<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n你有咁嘅心 己經好好<br />\n係我間垃圾中學 出嚟抗爭一隻手數得哂 計埋非為打卡而出嘅和理非 十個唔夠 女嘅得一個<br />\n試過有叫女出和理非 唔係搵藉口 就係真係戇鳩 視抗爭為打卡手段 出去畫面唔夠靚打卡就唔去 <br />\n做唔到前線 可以做好多嘢 千祈唔好放棄任何一個自己出一分力機會就得"},{"pid":"880d2201a93499a4bf824612c87b9c231f33e426","tid":1491761,"uid":300082,"like":0,"dislike":0,"score":0,"quote":{"pid":"1a4549db62ae521341ff89d46e8ef53feeda7784","tid":1491761,"uid":305458,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-23T01:47:10.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-23T07:35:39.000Z","msg":"大撚把呢D人<br />\n通常都係為打卡 <br />\n完全唔明點解要出嚟抗爭<br />\n如果唔係9月罷課 我驚自己嬲到捉撚哂成間垃圾中學啲畜生打"},{"pid":"4f50df2141cc37383754958a42b6cf320c2e3aa4","tid":1491761,"uid":300082,"like":0,"dislike":0,"score":0,"quote":{"pid":"eb9ab2392bfbca6ef5803087349c18fbdac9f341","tid":1491761,"uid":311865,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-23T07:26:47.000Z","msg":"加油 <br />\n<br />\n香港既未來就係靠你地班年輕人"},"citedBy":0,"replyTime":"2019-08-23T07:35:59.000Z","msg":"多謝你 Ching"},{"pid":"2f6024f2c2cc155e4c24fce3b1d427089362fbbd","tid":1491761,"uid":255637,"like":0,"dislike":0,"score":0,"quote":{"pid":"6ca18c4e3df6ad3edbe984b9ee09d24087cfc135","tid":1491761,"uid":300082,"like":0,"dislike":0,"score":0,"quote":{"pid":"3ea7e4df7bf27786a9b7e015b8047e6309a40c61","tid":1491761,"uid":255637,"like":0,"dislike":0,"score":0,"citedBy