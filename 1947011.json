495adb47db4","tid":1947011,"uid":127929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T04:53:05.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"dce1a0be525be76f45c45d7cda8517a9b507e92d","tid":1947011,"uid":254246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T04:54:32.000Z","msg":"push"},{"pid":"377085da91fc7824a5abc4f7bf5a76c0ae56ea40","tid":1947011,"uid":31952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T05:24:06.000Z","msg":"推"},{"pid":"52212e34b1b7cff331a76a40c9e5c95f1b131e92","tid":1947011,"uid":53612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T05:44:04.000Z","msg":"推"},{"pid":"b63f31cd75bff194f8086b5cf344736712c5252b","tid":1947011,"uid":53612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T05:54:15.000Z","msg":"推"},{"pid":"c279272b445a6e444e37e3a7de02dcc479cf348e","tid":1947011,"uid":156327,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T05:56:14.000Z","msg":"廿蚊張條仆街剩係幫啲大集團 咪撚再助紂為虐"},{"pid":"81bea02701cb03cc94a66b1c56b4508ce6e20a1e","tid":1947011,"uid":168818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T05:57:36.000Z","msg":"<img src=\"/assets/faces/lm2/@.gif\" class=\"hkgmoji\" />"},{"pid":"fde3f0b21d241777f8e732564116ea0ca1267f0b","tid":1947011,"uid":112748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T05:57:47.000Z","msg":"推！"},{"pid":"8a7708b21bce286faf3101b5c8a17ad26c8d9687","tid":1947011,"uid":53766,"like":0,"dislike":0,"score":0,"quote":{"pid":"c2fb7fc8ab77c5937d6705a0ee18b633421f317d","tid":1947011,"uid":127929,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-28T04:01:52.000Z","msg":"<strong><span style=\"font-size: x-large;\">飲食界</span></strong><br />\n<br />\n<span style=\"color: red;\">告急情況：</span><br />\n1. 登記率極低：根據2019既資料，現時食環署發出的食物業牌照超過2萬個，但飲食界已登記選民合共僅4,408個，即<span style=\"color: red;\">登記率只有2成！</span><br />\n2. 藍票比例極高：而以2016年立法會選舉為例，張宇人以2,438票擊敗民主派候選人伍永德的647票 (即係以目前既4千幾飲食界選票中，超過7成係鐵票)<br />\n<br />\n<span style=\"color: red;\">登記資格：</span>只要持有食環署食物業牌照，就可以登記成為飲食界選民(注意：飲食界分為團體票及個人票，店主要留意自己是否為個人持牌，即個人票)<br />\n<br />\n<span style=\"color: red;\">截止日期：</span>2/4/2020 (下星期四)<br />\n<br />\n<span style=\"color: red;\">如何遞交申請：</span><br />\n1. 個人票：<br />\n如果你本身<span style=\"color: red;\">有</span>傳統功能界別 或 你<span style=\"color: red;\">有</span>超級區議會界別既投票資格，<span style=\"color: red;\">你必須填寫 REO-43</span>( <a href=\"https://www.reo.gov.hk/pdf/form/REO-43(C\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.reo.gov.hk%2Fpdf%2Fform%2FREO-43%28C&d=g1YLBr7c5t2fgTVFseaOq0BBI%2BG%2BtQAW9Loz3QxUp%2BM%3D&h=feea8087\" data-auto-link target=\"_blank\">https://www.reo.gov.hk/pdf/form/REO-43(C</a>).pdf )，以更改功能界別選民。如果你<span style=\"color: red;\">不是</span>任何傳統功能界別 或 你<span style=\"color: red;\">不是</span>超級區議會界別既選民，請填寫表格 REO-41( <a href=\"https://www.reo.gov.hk/pdf/form/REO-41(C\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.reo.gov.hk%2Fpdf%2Fform%2FREO-41%28C&d=g1YLBr7c5t2fgTVFseaOq0BBI%2BG%2BtQAW9Loz3QxUp%2BM%3D&h=b1e661e0\" data-auto-link target=\"_blank\">https://www.reo.gov.hk/pdf/form/REO-41(C</a>).pdf )<br />\n<br />\n2. 團體票<br />\n請填寫表格 REO-42 ( <a href=\"https://www.reo.gov.hk/pdf/form/REO-42(C\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.reo.gov.hk%2Fpdf%2Fform%2FREO-42%28C&d=g1YLBr7c5t2fgTVFseaOq0BBI%2BG%2BtQAW9Loz3QxUp%2BM%3D&h=34d47314\" data-auto-link target=\"_blank\">https://www.reo.gov.hk/pdf/form/REO-42(C</a>).pdf )<br />\n<br />\n請把已填妥及由你或你的團體的負責人和獲授權代表簽署（如屬團體申請）的申請表格，<span style=\"color: gold;\">在4月2日(下星期四)前</span>，以<span style=\"color: red;\">郵遞方式</span>寄回<strong>九龍九龍灣展貿徑一號九龍灣國際展貿中心十三樓</strong>或傳真至 2891 1180。<br />\n<br />\n<span style=\"color: red;\">source:</span> <br />\n<a href=\"https://www.reo.gov.hk/pdf/gn/cat_c.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.reo.gov.hk%2Fpdf%2Fgn%2Fcat_c.pdf&d=g1YLBr7c5t2fgTVFseaOq0BBI%2BG%2BtQAW9Loz3QxUp%2BM%3D&h=6987545d\" data-auto-link target=\"_blank\">https://www.reo.gov.hk/pdf/gn/cat_c.pdf</a><br />\n<a href=\"https://hk.news.appledaily.com/local/20200328/XPSAFOUIDH4P7UKLRYUO7LJP5E/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20200328%2FXPSAFOUIDH4P7UKLRYUO7LJP5E%2F&d=g1YLBr7c5t2fgTVFseaOq0BBI%2BG%2BtQAW9Loz3QxUp%2BM%3D&h=4fc85949\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20200328%2FXPSAFOUIDH4P7UKLRYUO7LJP5E%2F&h=2731c843\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/20200328/XPSAFOUIDH4P7UKLRYUO7LJP5E/</a><br />\n記者 李雨夢<br />\n美心擁276間持牌食肆 造就大量鐵票<br />\n「民間飲食界選民登記小隊」翻查食環署的食肆牌照發現，美心集團旗下有276間持牌食肆、大家樂有161間、稻香約46間、富臨約60間、太興約118間。若以上5個「深藍」大集團透過不同公司，為旗下持牌食肆登記作飲食界選民，粗略估計或有超過600鐵票支持張宇人。2016年立法會選舉，張宇人以2,438票擊敗民主派候選人伍永德的647票。"},"citedBy":0,"replyTime":"2020-03-28T05:59:45.000Z","msg":"推"},{"pid":"2aa696d9b71e90f7e47ba57442538bb48cbed270","tid":1947011,"uid":17847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T06:02:12.000Z","msg":"推"},{"pid":"79e1b4cde1ccc6c8956a03359210412034a616dd","tid":1947011,"uid":127929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T07:20:31.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e339a59830b5dd01d75845727229e121c72eee0f","tid":1947011,"uid":189132,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T07:21:50.000Z","msg":"推"},{"pid":"8c32ac3083631e951e7376b8751043e7f94f3ad1","tid":1947011,"uid":20870,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T07:21:52.000Z","msg":"落門面宣傳會唔會好啲 但可能好多藍店入"},{"pid":"e863f41a4bd0355101cf3bab92c4c3a4f94a9022","tid":1947011,"uid":32748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-28T07:21:55.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig