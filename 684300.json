4.000Z","msg":"侵侵求下你派兵轟炸香港<img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f79e64f9a58e69c78c72777776d19799266f0cdc","tid":684300,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-30T23:19:34.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"52667e2451506289046a21085b30d03dbb6f0aef","tid":684300,"uid":13592,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-30T23:33:09.000Z","msg":"係真先算"},{"pid":"d79aacacbf06c2aeac3bd9b8eea17dd4519ebdf6","tid":684300,"uid":11980,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-30T23:51:14.000Z","msg":"1.凍結名單上人員在美國以及相關盟國的所有財產，深度審查他們的美國親戚們的資產。<br />\n<br />\n終於要出呢招 有戲睇<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"4996aa1f6d05fab10fb807560fe0c7908c71c62e","tid":684300,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-30T23:56:04.000Z","msg":"收鳩佢地親屬嘅綠卡"},{"pid":"b7ee141a79fc0c8a79ce963be1a1d034d9af3b98","tid":684300,"uid":99420,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-30T23:58:21.000Z","msg":"此回覆已被刪除"},{"pid":"cf540602d57bc5a1aecd6e3100e071e956e70a8a","tid":684300,"uid":186181,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-31T00:05:13.000Z","msg":"專心愛國 又贏<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"56e9767d8f8b6e823df5ddb70780c4419ef32528","tid":684300,"uid":47496,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-31T00:08:25.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">高管</span></span><img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"}]}