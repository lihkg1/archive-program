lm2/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5b012da7bf7964ab19b4b2ec4afa7e943831bcce","tid":1355721,"uid":8607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T16:17:56.000Z","msg":"推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n抗爭必須多元化。<br />\n審時度勢，見機行事，才稱得上「be water」。"},{"pid":"d2e6e9d13be70cd25867b1bf58cd4b62426a926e","tid":1355721,"uid":106408,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T16:22:44.000Z","msg":"點都好啦<br />\n又唔洗有共識既 <br />\n廢事比人借呢件事分化<br />\n到時邊度唔夠人 有heart既人都會去幫手<br />\n大家一條心先最緊要 我地只有團結呢樣野係輸唔起"},{"pid":"d9c9b562840b74bff1c32484237b0ad6dbee08b4","tid":1355721,"uid":256072,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T16:38:04.000Z","msg":"其實「上環」同「元朗」兩件事都<span style=\"color: red;\">connect</span><br />\n<br />\n喺<span style=\"color: red;\">追究警隊濫權</span>一項<br />\n「元朗」事件中「黑警與鄉黑拍膊頭」「心領了」更直接證明<span style=\"color: red;\">「成立獨立調查委員會」</span>嘅迫切性<br />\n我相信無人會忘記五大訴求甚至忘記我地由6月9日至今行出來嘅目的喺咩<br />\n<span style=\"color: red;\"><strong>就喺想我地香港依個家變好</strong></span><br />\n<br />\n「元朗」事件將原本政治中立或政治冷感嘅人刮醒<br />\n令佢地知道自己已經喺依盤巨大棋盤內<br />\n無得你話退出就可以退出<br />\n同時 有賴各傳媒朋友<br />\n令剛蘇醒嘅人看得更清香港政府依個當權者嘅黑暗及血腥<br />\n<br />\n我明白大家為各義士嘅付出心急及感到不忿<br />\n但請唔好忘記「點解你當日會選擇行出來」<br />\n行出來喺因為對政府感到失望 對當權者感到憤怒<br />\n<br />\n無論如何<br />\n大家目標一致<br />\n<span style=\"color: red;\">不割席 不篤灰 不流血 不被捕</span><br />\n最終達至「民主會戰勝歸來」嘅畫面<br />\n所有人嘅努力就無白費<br />\n<br />\n兄弟爬山<br />\n各自努力"},{"pid":"19fe5944d0ab59b60d1c966d747e7596372b5902","tid":1355721,"uid":28202,"like":0,"dislike":0,"score":0,"quote":{"pid":"f9f2755f918d30e6c7203463bc514e5e4d4f359c","tid":1355721,"uid":997,"like":5,"dislike":0,"score":5,"quote":{"pid":"adb8a7dae721451e680397ce55ccc36c51c9c3fe","tid":1355721,"uid":117418,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-07-23T12:23:48.000Z","msg":"咁大粒花生梗係食啦<br />\n今日星期二之嘛<br />\n次次都話唔夠人唔夠人<br />\n其實上星期日仲KEEP到四十幾萬人出嚟就知大家團火冇咁易急<br />\n劉細良話齋, 四十萬人已經好多人喇<br />\n放鬆啲啦~<br />\n不割蓆不分化"},"citedBy":1,"replyTime":"2019-07-23T12:29:23.000Z","msg":"邊個唔知上環單野有幾大鑊<br />\n<br />\n問題係新聞角度黎講,元朗果單震撼好多<br />\n你睇BBC/CNN/NYT全部都係提元朗<br />\n<br />\n因為係有組織既黑社會打9 d途人<br />\n呢d就係外國既恐怖襲擊<br />\n只不過平時睇新聞係用炸彈同刀多,今次用藤條/棍/鐵通咁解<br />\n殺傷力相對低, 但係動機係一模一樣, 連無辜既人都打埋一份<br />\n<br />\n呢單野仲可以引伸係支聯辦吹雞<br />\n連場抗爭已經迫到對家出黑社會,支那就行得通<br />\n香港根本行唔通<br />\n<br />\n黑警咁多仆街野都未令到商會講野<br />\n元朗果單野連香港總商會都要出聲,因為琴日真係嚇到d人唔出街<br />\n商家最驚呢樣"},"citedBy":0,"replyTime":"2019-07-23T16:52:37.000Z","msg":"明明元朗係好牌,進一步証明黑警真係黑警,<br />\n竟然話係失焦,真係嘆為觀止,<br />\n剩係叫人虛無縹緲咁關注,又唔講有咩行動,<br />\n啲度連登阿,唔係香討,有人會忘記五大訴求咩,有人忘記烈士咩,<br />\n駛唔駛每個鐘都提五大訴求,over曬啦,<br />\n係未想全連登時事台啲post剩係講五大訴求,<br />\n剩係講有人中彈阿,痴撚線　<br />\n之前各區連儂牆,各區示威,做乜9都好,又係好撚多人衝出嚟話失焦<br />\n你當我多心啦,唔知係未有人故技重施搞事"},{"pid":"96e832c659587c76733cad07c23c2c46b4326ab8","tid":1355721,"uid":268978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T17:19:41.000Z","msg":"推"},{"pid":"4795ea2a6b364d77e9fe5cedc8602e46f9c2542a","tid":1355721,"uid":77383,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-23T17:21:46.000Z","msg":"其實無人忘記過<br />\n但屌你老母用啲咁既語氣叫人睇呢樣推嗰樣<br />\n好撚反感好煩<br />\n仲有啲標題撚<br />\n咪嘈呀仆街"},{"pid":"f904656cfa4cb2454696f4de146da510179bb08a","tid":1355721,"uid":107297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T18:28:09.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"8ab852287f8eb1fff7730c603fa85bca576e4d2b","tid":1355721,"uid":285424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T18:34:37.000Z","msg":"推"},{"pid":"c16a64083cb47722a4d9c272a00f4485c1908af6","tid":1355721,"uid":176731,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-23T18:41:42.000Z","msg":"我有個辦法！解決元朗中環混亂問題<br />\n<a href=\"https://lih.kg/1357664\" data-auto-link target=\"_blank\">https://lih.kg/1357664</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"469cbb3887880db5ddabfc9810b331aa7258c374","tid":1355721,"uid":176731,"like":0,"dislike":0,"score":0,"quote":{"pid":"c16a64083cb47722a4d9c272a00f4485c1908af6","tid":1355721,"uid":176731,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-23T18:41:42.000Z","msg":"我有個辦法！解決元朗中環混亂問題<br />\n<a href=\"https://lih.kg/1357664\" data-auto-link target=\"_blank\">https://lih.kg/1357664</a><br />\n- 分享自 LIHKG 討論區"},"citedBy":0,"replyTime":"2019-07-23T18:42:38.000Z","msg":"光復香港 時代革命"},{"pid":"58d74ab855a430572b84b0ea3d9eed700d40b108","tid":1355721,"uid":13076,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T23:05:51.000Z","msg":"長期抗爭<br />\n不宜chur盡市民力氣<br />\n返工嘅真係抵受唔到個個星期日情緒吊頸<br />\n區議會選舉前留力<br />\n拉攏多d身邊家人/藍絲/不問政治<br />\n七百萬人人皆兵<br />\n先係上計<br />\n<br />\n教育唔係一日做到<br />\n我兩年前幫媽咪手機apps大換血<br />\n教佢用電話課金<br />\n而家略有收成<br />\n<br />\n不引戰不流血不停步<br />\n<br />\n我哋係要保護香港直到永遠<br />\n唔係人人都記得5大訴求<br />\n好多低學歷唔會明白義士嘅犧牲<br />\n壓力太大反而會令士氣低落<br />\n<br />\n街戰之後流亡<br />\n非必要的話可免則免<br />\n<br />\nbe water<br />\n民意不可失<br />\n否則我哋會損失好多力量<br />\n好似上環一役咁<br />\n辛辛苦苦受傷被捕<br />\n徒然花費氣力<br />\n點解今次上環中彈冇人理？<br />\n其實大家都知<br />\n<br />\n有理智嘅一群<br />\n進退有度<br />\n方為上策"},{"pid":"9b896b6c5aeda494344d7e47bb296303492a6007","tid":1355721,"uid":107297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:09:59.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"1401e7db75dda00dbdba3a009032ddf23c933796","tid":1355721,"uid":43823,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:13:40.000Z","msg":"推"},{"pid":"f5611fa0c2b135c11164b49e03a3d2ef85e687aa","tid":1355721,"uid":185063,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:39:57.000Z","msg":"推"},{"pid":"9aad71c33352f495cbd5dfeca559ea5c56363855","tid":1355721,"uid":107297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:49:40.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"125458461b5b58d6e6029963fc342e1c200064d8","tid":1355721,"uid":107297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T07:03:12.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6f48c157ab38b3a919d4fc3096cdf010b3eb5a49","tid":1355721,"uid":34293,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T07:04:17.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"c46c4a949265f2ea1652a5b09707900f7b118a35","tid":1355721,"uid":100974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T07:07:25.000Z","msg":"<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" />"},{"pid":"050b0ddccae8603733d326b4534cadfc1bff05b9","tid":1355721,"uid":107297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T07:42:43.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"0de4e51a074e14a092f82bee74115b159c79770a","tid":1355721,"uid":142332,"like":0,"dislike":0,"score":0,"quote":{"pid":"627f9875a92d6f474a8111fa8377a86920427aef","tid":1355721,"uid":161430,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-07-23T11:02:56.000Z","msg":"1. <span style=\"color: red;\">你地講既野我地全部都知</span>，唔需要用一種我唔明，眾人皆醉既視角去提點<br />\n<br />\n2. 場抗爭太多抑壓，有黑社會搞下墳，<span style=\"color: red;\">大家舒暢下</span>冇咩唔好，係唔係一日24小時都要谷住或者喊曬口咁<br />\n<br />\n3. 我<span style=\"color: red;\">冇忘記五大訴求</span>，中聯辦同西環既事我全部留意住，但元朗恐襲的確更加貼近社區民生，全香港既關注度的確好高，睇外媒擺邊樣做國際A1你就知呢件事幾值得煲落去，如果文宣解釋返好，反而先係<span style=\"color: red;\">最可以令人connect，全民反黑警同政府，更加切身明白建制有幾邪惡</span><br />\n<br />\n4. 最重要呢樣:<br />\n<span style=\"color: red;\">關注元朗，同關注西環一樣有好多共通點</span>，<br />\n關注元朗即係追究緊背後既<span style=\"color: red;\">警黑合作</span>，同關注西環果件事<span style=\"color: red;\">一樣係追究緊黑警</span>，關注元朗一樣係<span style=\"color: red;\">追求背後既政府，甚至政府既大佬中聯辦</span>，因為呢件事就係中聯辦搞出黎，實際同反送中一樣係反緊成個政府，<br />\n<br />\n元朗呢件事更加<span style=\"color: red;\">帶出政府已經無力管治</span>，而且<span style=\"color: red;\">帶出警察再比示威者消耗落去都會頂唔順，所以先要警黑合作</span><br />\n<br />\n所以關注元朗背後好多意義都係反緊政府同個制度，同樣其<span style=\"color: red;\">實727一樣係會叫五大訴求既口號</span>，點樣失焦左？<br />\n<br />\n反而有班人成日話唔好失焦，問人究竟明唔明，其實唔明果個會唔會反而係你地?"},"citedBy":0,"replyTime":"2019-07-24T07:46:29.000Z","msg":"其實反送中係反映左香港人一直比人魚肉緊 好多以前唔想理唔去關心既惡法導致今日有送中條例<br />\n<br />\n呢一刻我地因為反送中企出來<br />\n但背後好多時間累積落來既問題我地需要開始正視<br />\n所以兄弟爬山 唔同人拆解唔同個問題 達至最後目的 就係政府係要以民為主"},{"pid":"4db75ac24ef6c98787d3fe46acbbec9cfeb882c1","tid":1355721,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T07:47:39.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"29a61d7f2b8eb82d2de02374542de6ebec480ab0","tid":1355721,"uid":107297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T07:57:08.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"8c339ecca3bad1f2bb121efd2f7cdb599c012b62","tid":1355721,"uid":273531,"like":0,"dislike":0,"score":0,"quote":{"pid":"627f9875a92d6f474a8111fa8377a86920427aef","tid":1355721,"uid":161430,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-07-23T11:02:56.000Z","msg":"1. <span style=\"color: red;\">你地講既野我地全部都知</span>，唔需要用一種我唔明，眾人皆醉既視角去提點<br />\n<br />\n2. 場抗爭太多抑壓，有黑社會搞下墳，<span style=\"color: red;\">大家舒暢下</span>冇咩唔好，係唔係一日24小時都要谷住或者喊曬口咁<br />\n<br />\n3. 我<span style=\"color: red;\">冇忘記五大訴求</span>，中聯辦同西環既事我全部留意住，但元朗恐襲的確更加貼近社區民生，全香港既關注度的確好高，睇外媒擺邊樣做國際A1你就知呢件事幾值得煲落去，如果文宣解釋返好，反而先係<span style=\"color: red;\">最可以令人connect，全民反黑警同政府，更加切身明白建制有幾邪惡</span><br />\n<br />\n4. 最重要呢樣:<br />\n<span style=\"color: red;\">關注元朗，同關注西環一樣有好多共通點</span>，<br />\n關注元朗即係追究緊背後既<span style=\"color: red;\">警黑合作</span>，同關注西環果件事<span style=\"color: red;\">一樣係追究緊黑警</span>，關注元朗一樣係<span style=\"color: red;\">追求背後既政府，甚至政府既大佬中聯辦</span>，因為呢件事就係中聯辦搞出黎，實際同反送中一樣係反緊成個政府，<br />\n<br />\n元朗呢件事更加<span style=\"color: red;\">帶出政府已經無力管治</span>，而且<span style=\"color: red;\">帶出警察再比示威者消耗落去都會頂唔順，所以先要警黑合作</span><br />\n<br />\n所以關注元朗背後好多意義都係反緊政府同個制度，同樣其<span style=\"color: red;\">實727一樣係會叫五大訴求既口號</span>，點樣失焦左？<br />\n<br />\n反而有班人成日話唔好失焦，問人究竟明唔明，其實唔明果個會唔會反而係你地?"},"citedBy":0,"replyTime":"2019-07-24T08:01:14.000Z","msg":"<img src=\"https://na.cx/i/ohxMvgH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FohxMvgH.jpg&h=ddb0e53c&s={SIZE}\" />"},{"pid":"967efc95b602dadfac681e076b5f425e1ab89b8f","tid":1355721,"uid":107297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T08:17:33.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4a85a30e8cd9bf8176fc4a8789d317f8215a0189","tid":1355721,"uid":260325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T08:19:11.000Z","msg":"同意"},{"pid":"5bfb7d63fc0b2ee96bcc6c298efffddb4f511fd6","tid":1355721,"uid":107297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T09:14:58.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}