4cad709949607632b853aaa627cfc","tid":755441,"uid":57148,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-25T19:46:31.000Z","msg":"識睇唔識寫<br />\n<br />\n綜合同作文各寫咗7-8版 都5**"},{"pid":"c3c38ea8846719307e9c6aadddcb0b22e54a7a5f","tid":755441,"uid":146917,"like":0,"dislike":0,"score":0,"quote":{"pid":"19076594bf879be85cd449d7231466718b7108e6","tid":755441,"uid":27097,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-07-25T18:27:27.000Z","msg":"作文同綜合2份卷5**，全部用繁體字。<br />\n唔撚好再講啲咩用殘體字會寫得快啲嘅藉口，係有料嘅，全用繁體字都冇難度。<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-26T04:51:38.000Z","msg":"我都係<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />  根本話快係藉口"},{"pid":"8c9e94619bd8331692c7a528c5c35df3b99b56ae","tid":755441,"uid":39177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-26T05:07:25.000Z","msg":"由細到大都未寫過"},{"pid":"b2bd370ef279d4cdcc277777e888ea15a9e472a1","tid":755441,"uid":134087,"like":2,"dislike":0,"score":2,"quote":{"pid":"5522b7d001cc10044dcc637938e51a70603502d3","tid":755441,"uid":25769,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-25T08:27:22.000Z","msg":"唔撚記得小學定幼稚園<br />\n個miss同我講什同甚係一樣係通<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n寫左段好長既時間都係用什<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-26T05:56:14.000Z","msg":"唔肯定巴打知唔知，知唔理我就得，只係唔想誤導人<br />\n先舉一例<br />\n你從來都唔會見到有人寫「什至」，淨係得「甚至」<br />\n只有「什麼」同「甚麼」係通<br />\n說明咗用「什」可以唔係簡體字<br />\n文言版《説文解字》：什，相什保也。從人、十。    <br />\n古代已經有「什」字，不過唔同已家解法，讀作十<br />\n<br />\n甚 讀音前面似S 未似M  同麼前面一樣都有M 音，所以讀得快同「十麼」似，所以先有「什麼」同理，唔會有「什至」呢樣嘢<br />\n<br />\n所以只有係「什麼」兩個字先通，其他時間唔係，可能係你老師一時無講清楚"},{"pid":"f700b5540bba3dc010aa522e4e7d52f6dfed6b3f","tid":755441,"uid":146917,"like":0,"dislike":0,"score":0,"quote":{"pid":"9893990d5624cad709949607632b853aaa627cfc","tid":755441,"uid":57148,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-25T19:46:31.000Z","msg":"識睇唔識寫<br />\n<br />\n綜合同作文各寫咗7-8版 都5**"},"citedBy":1,"replyTime":"2018-07-26T12:30:11.000Z","msg":"7-8版 <img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />  唔是叫你寫小說"},{"pid":"01cff319379afababf99841045ff8385411da283","tid":755441,"uid":48887,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-26T12:40:26.000Z","msg":"可能睇卡通片多，成日寫左漢字<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},{"pid":"3ac50b21bee0b6e3bcf5cddc514d604a350f2378","tid":755441,"uid":146917,"like":0,"dislike":0,"score":0,"quote":{"pid":"01cff319379afababf99841045ff8385411da283","tid":755441,"uid":48887,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-26T12:40:26.000Z","msg":"可能睇卡通片多，成日寫左漢字<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-26T17:26:27.000Z","msg":"點解咁講"},{"pid":"30f4c27c4ab2e727621dcea45c383cf4323ec23f","tid":755441,"uid":140309,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-26T17:29:47.000Z","msg":"無，係我最自豪嘅其中一件事<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"}]}