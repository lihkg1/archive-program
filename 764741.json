assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"034fcfd15201424eb6b0727bdaf101bdfa429bcd","tid":764741,"uid":51200,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-08-02T10:12:50.000Z","msg":"花衫嗰個<br />\n差佬嚟到都仲唔停手<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n你老尾咁撚樣都有人話四眼仔針對錯人<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n<br />\n分分鐘求其一個身邊嘅乘客郁一郁都俾花衫既打到仆街<br />\n情緒咁撚唔穩定<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"31464f1ca4ee4d3088e422cc5a16c9da7f837132","tid":764741,"uid":189243,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-08-02T10:13:47.000Z","msg":"做呢啲角色吃力不討好"},{"pid":"8bdeedc974fb05585deeaeebf6057ff2d06ab124","tid":764741,"uid":51200,"like":0,"dislike":3,"score":-3,"quote":{"pid":"31464f1ca4ee4d3088e422cc5a16c9da7f837132","tid":764741,"uid":189243,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-08-02T10:13:47.000Z","msg":"做呢啲角色吃力不討好"},"citedBy":0,"replyTime":"2018-08-02T10:16:13.000Z","msg":"岩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n但係就呢件事來講<br />\n四眼仔真係冇問題<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 好多人搵野來講"},{"pid":"83a82e92085c285db284d9b472defd687b8eb4ef","tid":764741,"uid":109560,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-02T10:31:40.000Z","msg":"花衫咁樣比人打完一巴還手<br />\n比人㩒低仲要比人鬧<br />\n最後比差佬塔埋<br />\n<br />\n如果其他人一定會唔還手比埋另一面佢打"},{"pid":"1c9c7a4ceea8035b41f4b959da4c646887598118","tid":764741,"uid":95641,"like":7,"dislike":1,"score":6,"citedBy":0,"replyTime":"2018-08-02T10:36:52.000Z","msg":"四眼仔冇問題？！<br />\n你試下代入花姨阿嬸，比人兜巴車埋嚟你嬲唔嬲，係人都即刻還拖啦<br />\n<br />\n你話呢個時候四眼仔走埋嚟「勸交」，你覺得咁樣係勸交？我淨係睇到佢凶神惡煞係度兇緊個花衫喎<br />\n<br />\n明明係比白衫兜巴星完在先，之後仲比個四眼仔兇，而自己就眼白白睇住打自己嗰個人走，然後仲比成班人圍，千夫所指，我係花衫都失控啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n而花衫嘅失控，好大程度係四眼仔造成，如果四眼仔係真係「勸交」，我相信件事唔會搞到咁大"},{"pid":"18698028bfad55094094ad4c592cd4f211d7bf0a","tid":764741,"uid":35219,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-02T10:37:55.000Z","msg":"一開波花衫好似有打到白衫？定係角度問題"},{"pid":"502e50b25f1de5c3b6dcd642a495b675d282d00d","tid":764741,"uid":118120,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2018-08-02T10:37:58.000Z","msg":"出手打人先果個你唔擋住<br />\n反而係擋住被打果個<br />\n咁樣算係點<br />\n即係俾機會施襲者逃離現場 ?<br />\n大家真係要小心呢d 新既手法<br />\n和事佬其實係夾埋, 扮好人既真正目的係俾施襲者成功逃走"},{"pid":"c3c20e7debcbf98c9bdf70339613a86799202fb1","tid":764741,"uid":51200,"like":1,"dislike":1,"score":0,"quote":{"pid":"502e50b25f1de5c3b6dcd642a495b675d282d00d","tid":764741,"uid":118120,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2018-08-02T10:37:58.000Z","msg":"出手打人先果個你唔擋住<br />\n反而係擋住被打果個<br />\n咁樣算係點<br />\n即係俾機會施襲者逃離現場 ?<br />\n大家真係要小心呢d 新既手法<br />\n和事佬其實係夾埋, 扮好人既真正目的係俾施襲者成功逃走"},"citedBy":0,"replyTime":"2018-08-02T10:47:18.000Z","msg":"如果花衫無還手，你岩<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n但係四眼仔擋住既時候，<br />\n係邊個捱打，同邊個發晒矛咁打？<br />\n<br />\n同埋仲有一樣野<span style=\"font-size: xx-large;\"><br />\n<span style=\"color: red;\">係花衫出手先啊<br />\n</span><br />\n</span><br />\n望多次條片啦，<br />\n花衫反手打落去先去<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"a75c19cabd881afffc210db4ad36585fb7a59a59","tid":764741,"uid":51200,"like":1,"dislike":0,"score":1,"quote":{"pid":"502e50b25f1de5c3b6dcd642a495b675d282d00d","tid":764741,"uid":118120,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2018-08-02T10:37:58.000Z","msg":"出手打人先果個你唔擋住<br />\n反而係擋住被打果個<br />\n咁樣算係點<br />\n即係俾機會施襲者逃離現場 ?<br />\n大家真係要小心呢d 新既手法<br />\n和事佬其實係夾埋, 扮好人既真正目的係俾施襲者成功逃走"},"citedBy":0,"replyTime":"2018-08-02T10:48:02.000Z","msg":"屌你花衫出手先架<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"ed0bac6e418571ac14e52c1aed35f274a2033575","tid":764741,"uid":51200,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-02T10:57:29.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"60cca4099b66612d7be48aea419cb76c307da2f7","tid":764741,"uid":109560,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-02T11:36:22.000Z","msg":"如果四眼仔唔出現<br />\n件事會變成點"},{"pid":"6a8f0db23c2d2688fcd881735be89e05725aa88f","tid":764741,"uid":51200,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-03T01:38:34.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0fb0e9568c6a3cf417d1cd95e23f7a2e8c6a6d64","tid":764741,"uid":29510,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-08-03T01:57:14.000Z","msg":"好撚ON9<br />\n當時四眼仔又唔係睇片, 點會睇到邊個出手先<br />\n只係見到有人打交, 去阻止, <br />\n根本白衫除左出手果下, 佢都係下風<br />\n可能到佢見到果時花衫已經出緊連還拳<br />\n<br />\n係咁咪應該觀察下, 睇埋有冇人拍片先, 睇完邊個出手先<br />\n再去阻止?"}]}