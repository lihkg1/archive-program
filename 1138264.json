10737343a2ebe56c10","tid":1138264,"uid":76885,"like":0,"dislike":0,"score":0,"quote":{"pid":"d46334d3ad0559400cfe301d4b499fb85843b6af","tid":1138264,"uid":180760,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-05T00:40:54.000Z","msg":"諗自己要點生活可能都係一種生活<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" /><br />\n不過諗下諗下就一世，最後咩都無做過"},"citedBy":1,"replyTime":"2019-05-05T00:53:58.000Z","msg":"咁咁咁&hellip;我可能要學接受咁既結果 <img src=\"/assets/faces/fs/agree.gif\" class=\"hkgmoji\" />"},{"pid":"132e88299c8160557082951613c5dbb5769872bb","tid":1138264,"uid":180760,"like":0,"dislike":0,"score":0,"quote":{"pid":"b3727d4e195b9736cb486b10737343a2ebe56c10","tid":1138264,"uid":76885,"like":0,"dislike":0,"score":0,"quote":{"pid":"d46334d3ad0559400cfe301d4b499fb85843b6af","tid":1138264,"uid":180760,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-05T00:40:54.000Z","msg":"諗自己要點生活可能都係一種生活<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" /><br />\n不過諗下諗下就一世，最後咩都無做過"},"citedBy":1,"replyTime":"2019-05-05T00:53:58.000Z","msg":"咁咁咁&hellip;我可能要學接受咁既結果 <img src=\"/assets/faces/fs/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-05T01:14:34.000Z","msg":"當初我都唔知自己想點，離開左香港，然後遇到好多人，唔算話人生大起大落，但留底左喺美國，有一份好穩定嘅工，夠食夠租屋，唔夠買樓，可以做到退休唔會比人炒仲會有退休金嗰啲。然後我最近quit左份工，我唔知自己下一步想點，但我知我唔做小小野去改變自己咁就會一世。 可能去轉緬甸上個meditation course，到時再睇下點。 只要唔好餓死街頭就ok <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n暫時仲未揾到人生的意義，目前諗法係既然都已經生而為人，咁就死之前睇多呢個世界，有條命就唔好嘥 <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"2247fabb97f28f122286a42f0da3b885e3850acb","tid":1138264,"uid":192754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-05T01:29:47.000Z","msg":"冇標準答案<br />\n每個人都有/要揾自己嘅答案"},{"pid":"b26d48c8624ba0b08c87e16080c1434082a55826","tid":1138264,"uid":79471,"like":0,"dislike":0,"score":0,"quote":{"pid":"eca3b20436d7f4a4d0e8224dd78a184fd632b952","tid":1138264,"uid":76885,"like":0,"dislike":0,"score":0,"quote":{"pid":"ee