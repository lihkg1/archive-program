ike":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T04:19:27.000Z","msg":"推"},{"pid":"a7e12e643e6a39070fb4f1324e593e8ae7f44289","tid":1742894,"uid":212819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T04:20:36.000Z","msg":"推"},{"pid":"0090d9e7bbbc02dd0100eca42e0d32524644e832","tid":1742894,"uid":212819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T04:22:57.000Z","msg":"推"},{"pid":"2c372950c33bd95b69cc3a85e804921960f49d6d","tid":1742894,"uid":212819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T04:28:26.000Z","msg":"推"},{"pid":"261b8ef62e196318e8365d691486bac80c3e371d","tid":1742894,"uid":201256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T04:40:21.000Z","msg":"721<br />\n811<br />\n831<br />\n101<br />\n1111"},{"pid":"365f5ff5f88f0fa77de8645e8de1b79b11b27117","tid":1742894,"uid":212819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T04:42:08.000Z","msg":"推"},{"pid":"507f187fed16bd1927143e951dd7d70354550c76","tid":1742894,"uid":212819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T04:50:05.000Z","msg":"推"},{"pid":"47b9d1fdd70f2628e3a82079c168d08580e0db5c","tid":1742894,"uid":54564,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-21T04:52:04.000Z","msg":"再次黎明行動！黎一波比上兩星期更有效既不合作同埋堵路行動！記住要喺藍絲鬧手足既時候 手足解釋點解要咁做 而唔係咩都唔講俾人鬧/打 令行動不失民意<br />\n<br />\n其實藍絲要鬧真係點解釋都冇用<br />\n<br />\n我覺得「行動」嘅手足如果比藍絲搞／發現的話就要「快閃」，唔好同佢糾纏，因為糾纏越耐越危險（被打／引狗／拍片公審等等）<br />\n可以等下一班車／轉過個車門繼續，無必要同d癲老廢老冒風險<br />\n<br />\n而其他「黃」嘅手足／收工撚／花生撚，就可以喺附近幫口解釋發生緊乜事（例如扮傾電話講／同朋友傾計／認真同人解釋：記住目標係中立返工撚，藍絲係點講都冇用）<br />\n<br />\n咁當然如果「行動」手足比藍絲廢老郁手搞，其他所有「黃」嘅手足麻煩真係要即場行動幫手／幫口去保護佢哋離開，咪撚再淨係拍片／嗌叫人唔好打，用你身軀走過去幫手分開班藍絲<br />\n你唔敢行動，起碼都要去保護願意行動為你行動嘅人，如果唔係點做「手足」"},{"pid":"30cd352f2f91765cbef7d81a677f9531be73436a","tid":1742894,"uid":171363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-21T04:52:36.000Z","msg":"p"},{"pid":"163e995c73d91fa026f3ca30d6e79074fcb9dc57","tid":174289