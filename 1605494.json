>\n北 成都路 <br />\n西 康定路 <br />\n南 內江街"},{"pid":"7b18d3f5edf0f6262329184f4365737b6e6e7a27","tid":1605494,"uid":57633,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T12:08:59.000Z","msg":"大家知到有另一班同路人係附近<br />\n都無咁驚啦<br />\n<br />\n敵人知你犄角都唔太敢攻啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"d1e25febe5d9dc150a078cccee2e5ea496bd384b","tid":1605494,"uid":57633,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T12:14:22.000Z","msg":"推爆呢頁都無人回就算了<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" />"},{"pid":"e099f320272003f9d1b669b852d5e57604904701","tid":1605494,"uid":57633,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T12:25:35.000Z","msg":"有咩問題<br />\n請提出<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"926640958675a4aef36480fd38b2f99a4c5c9ce7","tid":1605494,"uid":38855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T12:25:56.000Z","msg":"<img src=\"/assets/faces/big/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"c54269691674f6ce589b7dccb8ee00f41fd53c1f","tid":1605494,"uid":57633,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T12:31:03.000Z","msg":"成班人守係馬路中間等人兩邊夾擊<br />\n真係好笨7<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"1272131752eaee0f26860dbfa1e4d0a529e8ae84","tid":1605494,"uid":77532,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T12:34:23.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"35ae0daf05e128f5b9f846f2e9065f444d153644","tid":1605494,"uid":63017,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-30T12:37:05.000Z","msg":"8000人大包圍咁點做"},{"pid":"f3ba4f7a66dbc21f9a0379a4d2a1e52c9ba96d6b","tid":1605494,"uid":57633,"like":0,"dislike":0,"score":0,"quote":{"pid":"35ae0daf05e128f5b9f846f2e9065f444d153644","tid":1605494,"uid":63017,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-30T12:37:05.000Z","msg":"8000人大包圍咁點