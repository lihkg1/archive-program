dBy":0,"replyTime":"2020-01-07T04:53:13.000Z","msg":"推"},{"pid":"ff9e76b19a3dc85ad944d2555b4900303e8b4b9a","tid":1814533,"uid":205927,"like":0,"dislike":0,"score":0,"quote":{"pid":"24f62f8f0c11974cfd8913ba9b61ee39a368cae7","tid":1814533,"uid":329698,"like":13,"dislike":0,"score":13,"citedBy":3,"replyTime":"2020-01-07T03:09:03.000Z","msg":"而家達成共識 捉鬼撚=鬼"},"citedBy":0,"replyTime":"2020-01-07T04:53:27.000Z","msg":"OK!"},{"pid":"d67673b198630b86365395be01865faab3f27e9e","tid":1814533,"uid":80200,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-07T04:53:55.000Z","msg":"推"},{"pid":"4ff72cffc38d59cc74700037763de612ac2d6295","tid":1814533,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-07T04:54:13.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">[警世文]<br />\n澄明思諸，勿陷分化</span></span><br />\n<br />\n捉鬼係永遠捉唔完，中共黨史上最叻就係滲透同分化，大家要默認永遠總有隻鬼喺左近，點捉都捉唔曬，過度緊張捉鬼反而會陷入分化局面<br />\n<br />\n平心而論，對家要收風根本唔會帶住支槍，帶得支槍入去理大就擺明預咗比你捉，達成佢地分化你地嘅政治目的，既然會有帶住支槍嘅鬼，冇槍喺手嘅鬼都肯定會有㗎啦，黑臉白臉嘅鬼自然都會齊曬，正如連登夠有五毛、TG各公海都一定會有對家臥底，呢個係common sense，有時候根本現場叫捉鬼嘅可能本身都係鬼，而我地亦都唔會咁容易分得清，而比對家輕鬆分化我地，害死手足，所以我再重覆一次，<span style=\"color: red;\">中共黨史上最叻就係滲透同分化，大家要默認永遠總有隻鬼喺左近，點捉都捉唔曬，過度緊張捉鬼反而會陷入分化局面</span>"},{"pid":"d700bc82f43b31f364a1017bb492af6aadb69d17","tid":1814533,"uid":95138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-07T05:08:27.000Z","msg":"推"},{"pid":"9907050279d44f985f8c540281eac4328e009a0a","tid":1814533,"uid":95138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-07T05:16:59.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a883e95c03f4144ef5acbb37cd4dcd14644ffafe","tid":1814533,"uid":54927,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-07T05:17:41.000Z","msg":"有問題就正視啦"},{"pid":"05767164ac4945d2e5752baff78bae1b1f082dfd","tid":1814533,"uid":95138,"like":0,"dislike":0,"score":0,"quote":{"pid":"a883e95c03f41