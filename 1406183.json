.000Z","msg":"2"},{"pid":"b50bc42fef037541c8ac2e7d4095fb227ea44d63","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T12:41:02.000Z","msg":"3"},{"pid":"29379f919fd75921ff707e512dcbe3dff0445953","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T12:41:16.000Z","msg":"4"},{"pid":"7964666f3aea1fba2d924503e13eef06ee07780d","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T12:41:27.000Z","msg":"5"},{"pid":"11b4a838bbb846526fab7a2937bc9d93e2418f52","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T12:41:40.000Z","msg":"6"},{"pid":"1a29988b657b33fa05620d9178350a09261a2909","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T12:41:51.000Z","msg":"7"},{"pid":"7e117f3ca67083c4d64bee4142aabca9ab97c6a3","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T12:42:01.000Z","msg":"8"},{"pid":"613f9a8ced97b9b374b094629ab6b9a65c74cf15","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T12:42:12.000Z","msg":"9"},{"pid":"5945cc02cd484ac77e9b3d4d8450a45191f7f9c7","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T12:42:24.000Z","msg":"10"},{"pid":"5f20237e727c49e8b80554b4cbd660954eaa900d","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T12:43:14.000Z","msg":"一個人推到第二頁<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"6e81a3741d4365279b27932132e19d424d91fadc","tid":1406183,"uid":276026,"like":1,"dislike":0,"score":1,"quote":{"pid":"fa8edc04b0cb8f21e425281138f212f47c5f624b","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-04T12:29:37.000Z","msg":"每日打開唔同既社交媒體，上面全部都係警察同市民既對抗片段，我真係好唔明好唔明，有一大堆既諗法想分享下，可以的話希望你睇一睇。<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n一開始，文宣推警察同市民衝突係好有用同好有需要，因為警方對市民使用既暴力，令事件快速升溫，快速獲得國際社會關注，令對政治冷感既香港人甚至淺藍開始轉向，助長呢一場革命既風向。<br />\n<br />\n但我想問，而家呢？<br />\n關注度係香港已經近乎百分之百，於警方同市民衝突事件既站場上，市民既意見基本上已經歸邊，認同既繼續認同，反對既繼續反對。<br />\n警察。對市民，對政府，你既利用價值，已經愈來愈低，甚至你守護緊乜野，你地工作內容，你自己都應該愈來愈含糊。<br />\n我簡單啲講，而家你只係一個幫政府拉仇恨既工具。<br />\n定你以為阻止示威者示威係你工作？咁我想問，如果唔阻止呢？唔阻止，示威者會點？如果你地唔緊守你地自以為既工作崗位，會發生咩事？會有一班所謂既暴徒同空氣戰鬥？破壞建築？示威者互相搏鬥？<br />\n如果唔會既話，咁好明顯，你攻擊示威者，引致示威者既攻擊目標係你之嘛。<br />\n如果你唔岀現，示威者重可以零裝備岀街tim。<br />\n咁你既存在價值係乜？一個攻擊人同被攻擊既對象？唔講我以為你係職業職業格鬥選手。<br />\n你守護緊啲乜野先？<br />\n成個香港發生緊既事態應該係<br />\n「與政府抗爭，爭取回應5大訴求。」<br />\n而你就以為成個事態係<br />\n「與警隊抗爭，爭取消滅香港警方。」<br />\n<br />\n其實而家既局勢已經令人衝昏左頭腦，明明係政府問題，但林鄭已經音訊全無消失左11日，有無留意，政府已經潛左好耐水。<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><br />\n呢段期間只係警察同市民無意義既鬥爭，好多片入面，警方既精神狀態已經明顯岀現咗人格問題，甚至有時候我會諗，係咪一啲人性實驗嚟，實驗內容大致係 ： 俾全副武裝一班人，無任何法律規管，你可以任意行使暴力，最後你會變成一個點既人。<br />\n<br />\n好多片入面，警察已經係單純既發洩情緒，背後所有局勢同引致今時今日咁既事情原委甚至自己既職責都已經拋開左。<br />\n<br />\n呢段期間政府零回應，潛水食花生，推前線警察去拉仇恨去死，而最衰係啲高職位既警察智商又低到真係指揮人去拉仇恨。<br />\n我真係R晒頭。<br />\n你試想像下，假如警察同市民坐係政總，拋開自己既身分，討論一個問題 : 點解而家搞成咁既？<br />\n最後個答案會係乜野？<br />\n<br />\n去到今時今日理性既市民都重識嗌口號，爭取政府回應五大訴求，知道應該做乜同自己做緊乜。<br />\n但點解警方每次都依然單純覺得件事係警民衝突咁去處理。<br />\n<br />\n可唔可以冷靜少少，件事係民眾同政府抗爭，動用武力大家都痛苦，唔係民眾同警察抗爭，警察其實唔係為主角黎，點解會係度搶focus。<br />\n其實情緒壓力去到頂點係應該警察發起罷工去俾啲顏色政府睇，唔應該係發洩落市民度，點解會變得咁奇怪架？<br />\n政府推你地前線去死，你唔開心你嬲我明啊，咁你咪反佢囉。<br />\n你企係錯嗰邊同幾百萬人嘈交點會贏？好似一個人同一百個人辯論咁，點贏姐，重要你自己都應該唔明自己係度守護緊啲乜，守護個無能政府，為咗個害緊你既政府同幾百萬人對抗？<br />\n<br />\n真係好奇怪，我真係R爆頭。<br />\n到底而家警民衝突發生個point係邊，對局勢根本無意義。<br />\n<br />\n可唔可以，再諗清楚，8月5號，同我地企同一陣線，罷工既時候，你既身分可唔可以唔係當值警察或者休班警員。<br />\n單單，只係同我地做一日香港人。"},"citedBy":0,"replyTime":"2019-08-04T12:44:50.000Z","msg":"係啊老老實實<br />\n你地諗下其實香港人想要乜？"},{"pid":"403052c1c154d70f6b7cf841c1ddf2ba7b83354f","tid":1406183,"uid":130894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T12:46:09.000Z","msg":"如果你入到嚟想睇人有意義既回覆，點知淨係見我自己單機數數字數到第二頁真係對唔住<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"4da5f78682428e48c3