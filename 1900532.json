34.000Z","msg":"最緊要識到個有錢女"},{"pid":"db9f643145173a5734cdbd2816def166f2fa7c01","tid":1900532,"uid":291865,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-28T03:29:43.000Z","msg":"個玩法好複雜， 而家日日插....可唔可以反對<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4df615a1df4a4e245870198fee47ab97e4325528","tid":1900532,"uid":52972,"like":0,"dislike":0,"score":0,"quote":{"pid":"6a587cdab3eda8827ac6e2eb6fa57191bb4caf9d","tid":1900532,"uid":52636,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-02-28T02:57:57.000Z","msg":"點解City'super咁值錢? 可以係短短幾年間升130倍"},"citedBy":0,"replyTime":"2020-02-28T04:23:03.000Z","msg":"好明顯20億先係真正價值。 1400萬半層樓都買唔到啦。 應該係唔知用左乜野漏洞夾硬巧取豪奪。"},{"pid":"975e865907c867c3e1e56d170e0fee4b8b7a9e11","tid":1900532,"uid":84471,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T04:33:35.000Z","msg":"咁入唔入手九龍倉置業好"},{"pid":"6d93425bf6486fdcb4d057b6c0f248108f1dfe7a","tid":1900532,"uid":127244,"like":3,"dislike":1,"score":2,"quote":{"pid":"6a587cdab3eda8827ac6e2eb6fa57191bb4caf9d","tid":1900532,"uid":52636,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-02-28T02:57:57.000Z","msg":"點解City'super咁值錢? 可以係短短幾年間升130倍"},"citedBy":0,"replyTime":"2020-02-28T04:33:41.000Z","msg":"由日本開過嚟香港嗰陣時20年前已經係咁值錢<br />\n佢哋成功打造到美國whole food 果種正常人嚮往嘅超市定位，喺嗰度行得舒適買得放心食得安心，<br />\n生果蔬菜肉類嗰種鮮果種甜係大陸垃圾貨有得比嘅咩？<br />\n係班傻閪先會去街市買餸嘅啫⋯⋯<br />\n撇除200,000劏房户，香港至少六百萬正常階層都唔會食佳寶萬年急凍荷爾蒙肉同埋垃圾百佳惠康千年一樣嘅入貨選擇，會滿足到佢哋？<br />\nCitysuper 係亞洲區食物安全問題嘅最後防線，<br />\n而且客戶服務方面做得好都好重要，買完野就算明明係自己問題佢哋都會退錢俾你，如果係百佳惠康嗰啲垃圾地方。睬你都傻<br />\n點解會唔值錢？"},{"pid":"cc59f689dfe037ee62ded3edd9411060a10408e5","tid":1900532,"uid":13724,"like":0,"dislike":0,"score":0,"quote":{"pid":"3f3e617de1d0fe1b7a335aa68664804f43344caa","tid":1900532,"uid":102580,"like":1,"dislike":0,"score":1,"quote":{"pid":"0b14bfd4a0837fe8f4e85251d64719fa8ac12cab","tid":1900532,"uid":19725,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-02-27T22:29:45.000Z","msg":"屌 原來吳光正係靠包Sir 既錢搵食<img src=\"