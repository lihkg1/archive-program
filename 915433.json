g/smile.gif\" class=\"hkgmoji\" />"},{"pid":"01e8d51994ff19595639beba2f587addbebe9995","tid":915433,"uid":29093,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-11-25T04:02:02.000Z","msg":"贏在道德底線 <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"051b701fded5894a90f2251ef78e20093101baae","tid":915433,"uid":29093,"like":8,"dislike":0,"score":8,"quote":{"pid":"d4a8c8264a5d74410e3a7c5a59712fa96557ac2d","tid":915433,"uid":193011,"like":9,"dislike":107,"score":-98,"citedBy":7,"replyTime":"2018-11-25T03:58:07.000Z","msg":"有時候我真係寧願唔要民主<br />\n睇見呢到一堆人只講理想不談現實，總是為自己一己之私而忘記顧全大局<br />\n未來的選擇權就算交到呢堆人手上，選出黎的都只是一個小孩領袖，任性而不顧一切。<br />\n誰人不想做自己喜歡的事？但呢個世界總係需要有人去承擔，否則每人都隨心所欲就只會世界大亂"},"citedBy":1,"replyTime":"2018-11-25T04:02:50.000Z","msg":"9 唔撚 搭 8  <br />\n<br />\n你畀個 number 我,  1 - 5 號  邊個 ?"},{"pid":"b92e3ffc7563a894d22b481087cdafd4bea8e564","tid":915433,"uid":79563,"like":53,"dislike":2,"score":51,"citedBy":0,"replyTime":"2018-11-25T04:03:30.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">因泛民唔開會令議案由嬴變輸實錄</span></strong></span><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/16/211101_61b1a829df455ea9d2859cbc85206f2a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F16%2F211101_61b1a829df455ea9d2859cbc85206f2a.jpg&h=175d7f22&s={SIZE}\" /><br />\n<br />\n2017年6月17日，沙中線8.47億追加撥款以6票之差獲得通過，10名泛民議員缺席未有投票。<br />\n<a href=\"http://www.vjmedia.com.hk/articles/2017/06/17/162225\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.vjmedia.com.hk%2Farticles%2F2017%2F06%2F17%2F162225&d=HyPHtKP0X271k9gPNCCtZwdLCpCjoNGxXEizPMjNmRM%3D&h=a8748c90\" target=\"_blank\">http://www.vjmedia.com.hk/articles/2017/06/17/162225</a><br />\n<br />\n2018年3月22日，立法會審議 1131億臨時撥款，在全體泛民議員缺席下，議案只花兩分鐘，由不足十名建制派議員在不記名投票下贊成通過。<br />\n<a href=\"http://hk.on.cc/hk/bkn/cnt/news/20180322/bkn-20180322090338992-0322_00822_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20180322%2Fbkn-20180322090338992-0322_00822_001.html&d=HyPHtKP0X271k9gPNCCtZwdLCpCjoNGxXEizPMjNmRM%3D&h=fd10c34b\" target=\"_blank\">http://hk.on.cc/hk/bkn/cnt/news/20180322/bkn-20180322090338992-0322_00822_001.html</a><br />\n<br />\n2018年5月26日，工務小組審議17.85億元朗行人天橋撥款，議案以3票之差獲得通過，5名泛民議員缺席未有投票。<br />\n<a href=\"https://www.legco.gov.hk/yr17-18/chinese/fc/pwsc/results/v201805261.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr17-18%2Fchinese%2Ffc%2Fpwsc%2Fresults%2Fv201805261.pdf&d=HyPHtKP0X271k9gPNCCtZwdLCpCjoNGxXEizPMjNmRM%3D&h=91f96bba\" target=\"_blank\">https://www.legco.gov.hk/yr17-18/chinese/fc/pwsc/results/v201805261.pdf</a><br />\n<br />\n2018年5月25日，林卓廷提出就「升降機維修保養對市民安全進行辯論議案」以6票之差未獲通過，7名泛民議員缺席未有投票。<br />\n<a href=\"https://www.legco.gov.hk/yr17-18/chinese/hc/voting/hc20180525-voting-ec.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr17-18%2Fchinese%2Fhc%2Fvoting%2Fhc20180525-voting-ec.pdf&d=HyPHtKP0X271k9gPNCCtZwdLCpCjoNGxXEizPMjNmRM%3D&h=c95ac3ad\" target=\"_blank\">https://www.legco.gov.hk/yr17-18/chinese/hc/voting/hc20180525-voting-ec.pdf</a><br />\n<br />\n2018年5月31日，建制派「共建粵港澳大灣區」動議順利通過，地方選區輸2票，2名泛民議員缺席未有投票。<br />\n<a href=\"https://www.legco.gov.hk/yr17-18/chinese/counmtg/voting/v20180530.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr17-18%2Fchinese%2Fcounmtg%2Fvoting%2Fv20180530.pdf&d=HyPHtKP0X271k9gPNCCtZwdLCpCjoNGxXEizPMjNmRM%3D&h=5a9e6c89\" target=\"_blank\">https://www.legco.gov.hk/yr17-18/chinese/counmtg/voting/v20180530.pdf</a><br />\n<br />\n2018年6月8日，鄭松泰在內務委員會動議立法會授權成立委員會調查港鐵涉隱瞞沙中線紅磡站月台不合規格，動議以5票落敗，5名泛民議員包括涂謹申、尹兆堅、梁耀忠、李國麟及郭榮鏗缺席投票。<br />\n<a href=\"https://www.legco.gov.hk/yr17-18/chinese/hc/voting/hc20180608-voting-ec.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr17-18%2Fchinese%2Fhc%2Fvoting%2Fhc20180608-voting-ec.pdf&d=HyPHtKP0X271k9gPNCCtZwdLCpCjoNGxXEizPMjNmRM%3D&h=7709f463\" target=\"_blank\">https://www.legco.gov.hk/yr17-18/chinese/hc/voting/hc20180608-voting-ec.pdf</a><br />\n<br />\n2018年6月22日，工務小組審議「重置中環郵政總部」議案，泛民議員反對重置方案，指政府10年前就中環海濱三號用地設計諮詢公眾時，並無提及會拆卸郵政總局大樓，批評政府隱瞞、行為閃縮。最終議案獲得通過，4名泛民議員包括莫乃光、張超雄、黃碧雲及陳淑莊缺席投票。<br />\n<a href=\"https://www.legco.gov.hk/yr17-18/chinese/fc/pwsc/results/v201806221.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr17-18%2Fchinese%2Ffc%2Fpwsc%2Fresults%2Fv201806221.pdf&d=HyPHtKP0X271k9gPNCCtZwdLCpCjoNGxXEizPMjNmRM%3D&h=b1d0f91b\" target=\"_blank\">https://www.legco.gov.hk/yr17-18/chinese/fc/pwsc/results/v201806221.pdf</a><br />\n<br />\n2018年6月25日，工務小組審議審議機場三跑系統的3項相關設施，涉及金額逾48億港元，最終以24票贊成、7票反對獲得通過。3名泛民議員包括胡志偉、尹兆堅及許智峯缺席投票。8名泛民議員包括黃碧雲、林卓廷、鄺俊宇、楊岳橋、譚文豪、陳淑莊、郭家麒及莫乃光更投下贊成票。若缺席及投下贊成票的議員能夠出席會議並全數投反對票，議案終會以18票對16票被否決。<br />\n<a href=\"https://www.legco.gov.hk/yr17-18/chinese/fc/pwsc/results/v201806251.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr17-18%2Fchinese%2Ffc%2Fpwsc%2Fresults%2Fv201806251.pdf&d=HyPHtKP0X271k9gPNCCtZwdLCpCjoNGxXEizPMjNmRM%3D&h=b5a8a519\" target=\"_blank\">https://www.legco.gov.hk/yr17-18/chinese/fc/pwsc/results/v201806251.pdf</a>"},{"pid":"c9a8c1a8c7836126b233301e6b58f7347727c88f","tid":915433,"uid":193011,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-11-25T04:04:28.000Z","msg":"成班私怨L<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"010a9d5b90936717e9b38dba04b469852b12b577","tid":915433,"uid":79563,"like":0,"dislike":0,"score":0,"quote":{"pid":"4d018ece1a45d37469e75dca81a3d8d32c3d0554","tid":915433,"uid":66324,"like":63,"dislike":0,"score":63,"quote":{"pid":"d4a8c8264a5d74410e3a7c5a59712fa96557ac2d","tid":915433,"uid":193011,"like":9,"dislike":107,"score":-98,"citedBy":7,"replyTime":"2018-11-25T03:58:07.000Z","msg":"有時候我真係寧願唔要民主<br />\n睇見呢到一堆人只講理想不談現實，總是為自己一己之私而忘記顧全大局<br />\n未來的選擇權就算交到呢堆人手上，選出黎的都只是一個小孩領袖，任性而不顧一切。<br />\n誰人不想做自己喜歡的事？但呢個世界總係需要有人去承擔，否則每人都隨心所欲就只會世