2Fna.cx%2Fi%2FKCfhVw9.jpg&h=cc4a2b71&s={SIZE}\" /><img src=\"https://na.cx/i/F6BpAxa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FF6BpAxa.jpg&h=4f61ec87&s={SIZE}\" /><img src=\"https://na.cx/i/SRYWrDQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSRYWrDQ.jpg&h=7f1b8468&s={SIZE}\" /><img src=\"https://na.cx/i/G1orOSa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FG1orOSa.jpg&h=6f8244b3&s={SIZE}\" /><img src=\"https://na.cx/i/iOobZYR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiOobZYR.jpg&h=d87249b8&s={SIZE}\" /><br />\n@期望連仔幫手壓制fake news <br />\n@上連登要用多用腦！<br />\n預備大型商場不合作運動：<br />\n齋睇唔買，儲多d錢；人多自然塞<br />\n連儂牆戰線不能倒！修建連儂，有你有我<br />\n<br />\n<ins>考驗毅力與堅持</ins><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><span style=\"color: red;\">做更具價值嘅野</span><br />\n#離開同溫層，接觸各種人，理解佢地嘅想法，將不支持我們的人轉為支持我們！這是成功的方法！<br />\n<br />\n<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" />抗爭/革命搞十年八載唔出奇<br />\n<span style=\"font-size: small;\">衛城革命，生活抗爭；拖垮邪惡、打倒腐敗；</span><br />\n<em>每日任務：</em><br />\n1. 優先<span style=\"color: red;\">幫襯</span>良心商店<br />\n2. <span style=\"color: red;\">抵制</span>「邪惡」「無良」的商戶，例如cctvb廣告、黨鐵商埸、黑社會、打壓員工的店鋪，減少淘寶<br />\n3. <span style=\"color: red;\">免費港鐵</span>（注意安全）；二人同遊，一人免費；買平飛；長者八達通<br />\n4. 夜晚<span style=\"color: red;\">十點咆哮</span>！（改9點會少好多人）<br />\n5. <span style=\"color: red;\">健身+運動</span>，身體健康，鬥長命<br />\n6. <span style=\"color: red;\">每日一post</span>，社交媒體戰（Twitter, IG, Facebook, Reddit) #HongKongProtest #Chinazi<br />\n#FreeHongKong #HongKongProtests <br />\nTwitter 共識頻道 <a href=\"https://t.me/twittermansyunzou\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Ftwittermansyunzou&d=CoEtBkFB9dbfLkjoGL86rZwtdbXJE8TYY9MHUmPwwUI%3D&h=4c62cc62\" target=\"_blank\">https://t.me/twittermansyunzou</a><br />\n7. 不要說推，試著copy and paste呢段嘢<br />\n8. 保持<span style=\"color: red;\">獨立思考</span>，分析能力level up，<strong><span style=\"color: red;\">冷處理fake news/ rumour</span></strong> 、五毛分化post<br />\n<br />\n<em>每星期任務：</em><br />\n1. <span style=\"color: red;\">低消費</span>，高儲蓄；罷買Bye Buy Day：星期日、星期五(唔買非必需品）<br />\n2. <span style=\"color: red;\">做孝子救港</span>，關心下老母老豆老人家，自己老母自己救<br />\n3. 去<span style=\"color: red;\">連儂牆</span>貼3張文宣，輸出革命思想<br />\n<br />\n<em>每月任務：</em><br />\n1. 出糧換美金、買美股，MPF轉美國<br />\n2. 搵多一個人參與<br />\n3. 關心社會、陪審員、派傳單、放映會<br />\n或者做唔足，但我會堅持到尾；Best effort，你呢？<br />\nVersion 2019.09.14</blockquote>"},{"pid":"981a9b189ecfb00d34022df24a57dfeea94c08a9","tid":1575113,"uid":149566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T18:08:53.000Z","msg":"【新．白宮聯署】- 請美國國會協助揭露新屋嶺真相<a href=\"https://petitions.whitehouse.gov/petition/please-expose-truths-and-punish-brutality-youngsters-san-uk-ling-holding-centre-hong-kong?fbclid=IwAR0Z2JT9-L9YVoz-xZYxNPWxjPuahVkLFRHG2t7kmwK6hk3JbpJ46cvf-bs\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fplease-expose-truths-and-punish-brutality-youngsters-san-uk-ling-holding-centre-hong-kong%3Ffbclid%3DIwAR0Z2JT9-L9YVoz-xZYxNPWxjPuahVkLFRHG2t7kmwK6hk3JbpJ46cvf-bs&d=CoEtBkFB9dbfLkjoGL86rZwtdbXJE8TYY9MHUmPwwUI%3D&h=24ee70dd\" data-auto-link target=\"_blank\">https://petitions.whitehouse.gov/petition/please-expose-truths-and-punish-brutality-youngsters-san-uk-ling-holding-centre-hong-kong?fbclid=IwAR0Z2JT9-L9YVoz-xZYxNPWxjPuahVkLFRHG2t7kmwK6hk3JbpJ46cvf-bs</a><br />\n<br />\n推到有真相 [ 非理工大學學生於Z座跳樓案 ]<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1575183\" data-auto-link target=\"_blank\">https://lih.kg/1575183</a>"}]}