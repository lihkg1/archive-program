衰落<br />\n好多中國「低端人口」失業<br />\n所以佢地就會來香港搵食<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <br />\n<br />\n好快 葉繼歡時代 會再來臨<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"b5795b917006af3889a3e2881e324dce51ea2047","tid":604673,"uid":57705,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-25T07:11:22.000Z","msg":"此回覆已被刪除"},{"pid":"35a1ccbf5c7119991cad715ccfa6d7f7e7c6acbd","tid":604673,"uid":16676,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-25T07:16:18.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: x-large;\"><strong>條仆街霸撚住部機咁撚耐</strong></span></span> <img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /> <br />\n讓都唔讓下人, <span style=\"color: red;\">點知拎埋鎚仔返轉頭仲係度</span><br />\n唔扑佢仲係人黎既<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"cc64b310d48ffed8fb0127bc4c3e7e1cc51aef00","tid":604673,"uid":79919,"like":0,"dislike":0,"score":0,"quote":{"pid":"5a56313ca675bc15f76c5e44495f159806fd965e","tid":604673,"uid":137912,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2018-03-25T03:19:27.000Z","msg":"多謝黨輸入中國專才<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-25T07:20:58.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"007328f278d488d612a5be9722da5d518f63b949","tid":604673,"uid":810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-25T07:21:52.000Z","msg":"霸王式霸氣<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"6508c2ed8e6bcb509618a3d550df23ceedc3f3ce","tid":604673,"u