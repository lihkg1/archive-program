2FsVbAXSk%2FqMRyYewxCuMeYC5A6rl8%2B6t9FBevN87M%3D&h=ce1edecc\" target=\"_blank\">https://www.youtube.com/watch?v=_2WLsufmULU&amp;feature=youtu.be&amp;t=385</a>"},"citedBy":0,"replyTime":"2020-07-14T10:53:45.000Z","msg":"男人老狗美顏<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b575ec90be80be112d4c6dfd4c0a5f7b694865d6","tid":2108042,"uid":531,"like":3,"dislike":0,"score":3,"quote":{"pid":"ae3f8b51e8bddd7aa54f41b9e5083cc5687a37c3","tid":2108042,"uid":129393,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-07-14T10:17:56.000Z","msg":"其實組隊投票得唔得<br />\n如果你個地區分區，泛民aim 6席，你就搵齊6個人組隊，一人投一個<br />\n<br />\n用票站或者分區來配票，會唔會怕有啲死硬派唔肯？"},"citedBy":0,"replyTime":"2020-07-14T10:54:09.000Z","msg":"要200幾萬選民確保個個都搵到組會唔會太難，個組仲要跟唔同地區分3，4，5，6人，到時超區點投？樓主個方法最科學最簡單"},{"pid":"12dde045d71e35313319bc28fe91e71dc9ac881e","tid":2108042,"uid":129393,"like":1,"dislike":0,"score":1,"quote":{"pid":"f1c0ea75515f7615380545f26f47bd220f72ed0f","tid":2108042,"uid":112094,"like":3,"dislike":0,"score":3,"quote":{"pid":"ae3f8b51e8bddd7aa54f41b9e5083cc5687a37c3","tid":2108042,"uid":129393,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-07-14T10:17:56.000Z","msg":"其實組隊投票得唔得<br />\n如果你個地區分區，泛民aim 6席，你就搵齊6個人組隊，一人投一個<br />\n<br />\n用票站或者分區來配票，會唔會怕有啲死硬派唔肯？"},"citedBy":2,"replyTime":"2020-07-14T10:21:16.000Z","msg":"佢個網有解釋<br />\n<br />\n<a href=\"https://tacticalvoting.github.io/leg2020/#faq\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftacticalvoting.github.io%2Fleg2020%2F%23faq&d=fc%2FsVbAXSk%2FqMRyYewxCuMeYC5A6rl8%2B6t9FBevN87M%3D&h=d80ef790\" data-auto-link target=\"_blank\">https://tacticalvoting.github.io/leg2020/#faq</a><br />\n<br />\n<blockquote>而「6人成行」的配票方法除了操作複雜，還會造成政黨地區樁腳與策略選民的巨大衝突，一方面樁腳要為自身政黨拉票，確保勝選，另一方面該區的策略選民又要呼籲選民分散投票，結局難免是地區資源豐厚的政黨樁腳極力守住地區得票，而其他地區又同時為該政黨配了票，最後就是該政黨成了表面風光的票王票后，但民主陣營卻把地區資源匱乏的參選名單押在最後一席的豪賭上。</blockquote>"},"citedBy":0,"replyTime":"2020-07-14T11:04:37.000Z","msg":"諗多兩諗，有兩個問題：<br />\n<br />\n(1) 分區配票靠DC票數字。一來有時差(可能某區選民數字有變)，二來本身亦可能有選民意向改左都唔定<br />\n<br />\n(2) 以下呢句<br />\n<br />\n<blockquote>而「6人成行」的配票方法除了操作複雜，還會造成政黨地區樁腳與策略選民的巨大衝突，一方面樁腳要為自身政黨拉票，確保勝選，另一方面該區的策略選民又要呼籲選民分散投票，結局難免是地區資源豐厚的政黨樁腳極力守住地區得票，而其他地區又同時為該政黨配了票，最後就是該政黨成了表面風光的票王票后，但民主陣營卻把地區資源匱乏的參選名單押在最後一席的豪賭上。</blockquote><br />\n<br />\n係基於一個現象，就係死忠投返自己黨。點解呢個現象喺分區配票就會忽然消失？唔合理。<br />\n<br />\n可唔可以靠<strong><span class=\"x-large\">改變拉票策略</span></strong>來解決呢個問題？即係好似初選九西本土派合作咁樣。選舉嗰日，各大黨當然要催票要宣傳，但唔係叫人投畀個別黨，而係平均地投畀呢張初選出線名單（冇朋友就用身份證之類或者隨機）。<br />\n<br />\n如果我地可以用新思維來拉票，就可以解決到上面個問題<br />\n<br />\n我仲係覺得「六人成行」好啲，因為真係平均啲。而家區選數字都係得56%黃，唔係贏好多。你見個網啲例子，真係要配得好準先拎到六席呀！！！"},{"pid":"dce58aae712afb65ba07d8e8d9be75090ffff066","tid":2108042,"uid":76558,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-14T11:20:16.000Z","msg":"呢個post高質過果d乜野擲骰仔同生日<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f7e64e7e8220328e2238ec68045e28ff3d1b2531","tid":2108042,"uid":20362,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-07-14T11:24:23.000Z","msg":"呢個方法屈機在你基本上今日已經可以推演到每一張名單既票數"},{"pid":"fe38a4157879d9b1692e79a96a700ddd8639597c","tid":2108042,"uid":85252,"like":0,"dislike":0,"score":0,"quote":{"pid":"dce58aae712afb65ba07d8e8d9be75090ffff066","tid":2108042,"uid":76558,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-14T11:20:16.000Z","msg":"呢個post高質過果d乜野擲骰仔同生日<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-07-14T11:24:23.000Z","msg":"但未推到上熱門<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"7890ea0c1a46a9e764007b31e7904a6fb914b6a8","tid":2108042,"uid":76558,"like":1,"dislike":0,"score":1,"quote":{"pid":"fe38a4157879d9b1692e79a96a700ddd8639597c","tid":2108042,"uid":85252,"like":0,"dislike":0,"score":0,"quote":{"pid":"dce58aae712afb65ba07d8e8d9be75090ffff066","tid":2108042,"uid":76558,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-14T11:20:16.000Z","msg":"呢個post高質過果d乜野擲骰仔同生日<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-07-14T11:24:23.000Z","msg":"但未推到上熱門<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-14T11:25:52.000Z","msg":"幫下你手"},{"pid":"2014bb5f1eab6ec22d31573cf4a9fcea5c630cb6","tid":2108042,"uid":20362,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-14T11:27:01.000Z","msg":"喝個方法配得好 屈保皇機都得"},{"pid":"8f4e44626ff0439bb05d6eb5064f78fe4ad998d2","tid":2108042,"uid":76558,"like":1,"dislike":0,"score":1,"quote":{"pid":"2014bb5f1eab6ec22d31573cf4a9fcea5c630cb6","tid":2108042,"uid":20362,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-14T11:27:01.000Z","msg":"喝個方法配得好 屈保皇機都得"},"citedBy":1,"replyTime":"2020-07-14T11:28:33.000Z","msg":"好過果d乜野 生日/骰仔/組隊"},{"pid":"0e3d47fe1b68e43492acb4338b8e95308b614943","tid":2108042,"uid":20362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-14T11:29:26.000Z","msg":"推下"},{"pid":"ef8ecbe0a26797641d92924e0ffc72f4f5625175","tid":2108042,"uid":150033,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-14T11:31:30.000Z","msg":"其實自己圍內組隊有冇得諗？<br />\n最理想主義下 四人一組分別投abcd<br />\n愈多組 宣傳愈高 效益愈大"},{"pid":"32f8662dac6cae7ebc7e0067d84f3b9614ac7d47","tid":2108042,"uid":85252,"like":0,"dislike":0,"score":0,"quote":{"pid":"8f4e44626ff0439bb05d6eb5064f78fe4ad998d2","tid":2108042,"uid":76558,"like":1,"dislike":0,"score":1,"quote":{"pid":"2014bb5f1eab6ec22d31573cf4a9fcea5c630cb6","tid":2108042,"uid":20362,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-14T11:27:01.000Z","msg":"喝個方法配得好 屈保皇機都得"},"citedBy":1,"replyTime":"2020-07-14T11:28:33.000Z","msg":"好過果d乜野 生日/骰仔/組隊"},"citedBy":0,"replyTime":"2020-07-14T11:31:35.000Z","msg":"最怕係用生日/骰仔/組隊的話<br />\n候選人會因為街站相見，互插內鬥<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"6b4a4665de58a8282752058439183611956a37d8","tid":2108042,"uid":271130,"like":1,"dislike":0,"score":1,"quote":{"pid":"ae3f8b51e8bddd7aa54f41b9e5083cc5687a37c3","tid":2108042,"uid":129393,"like"