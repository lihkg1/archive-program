eplyTime":"2018-12-31T03:19:59.000Z","msg":"支那式陰道"},{"pid":"93233c71fd9fc0fd7b586020b9bf7189e0c99579","tid":962530,"uid":30710,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-31T03:27:29.000Z","msg":"娶支那雞嘅下場<img src=\"/assets/faces/xm/dead.gif\" class=\"hkgmoji\" />"},{"pid":"1482a53b4808b3349c34b1f6b536a145a65b1a64","tid":962530,"uid":179409,"like":15,"dislike":0,"score":15,"citedBy":0,"replyTime":"2018-12-31T03:34:22.000Z","msg":"呢單嘢應該長期置頂<br />\n等有班香港男人以為支那女人好正<br />\n真係好正<br />\n先劏你一頸血<br />\n再叫屋企人劏多你父母荷包一次<br />\n命又要、錢又要"},{"pid":"10b96825780705fcd2b7de0f6cf51d1045ccc12e","tid":962530,"uid":200328,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-31T03:37:11.000Z","msg":"支那種<img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" /> <br />\n娶得實無好下場"},{"pid":"d1e1615e4f10726a4446f54ac17105ac39624245","tid":962530,"uid":173271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-31T03:41:34.000Z","msg":"重男輕女<img src=\"/assets/faces/xm/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e4de5175bf172b8d3bcfaf8e6d33125992d2d29b","tid":962530,"uid":68993,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-12-31T05:37:55.000Z","msg":"殺左人地個仔仲問人有無甜品"},{"pid":"f5717628c0cc1d44c607220b6776e537391fb30d","tid":962530,"uid":72186,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-12-31T05:40:47.000Z","msg":"個男孫係香港<img src=\"/assets/faces/xm/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ea8abcc2b25e20894ae6f66f47b5bedc1866eeea","tid":962530,"uid":15677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-31T05:49:21.000Z","msg":"係英國定支那審？<br />\n<br />\n親家才簽署庭外和解協議 做咩咁傻仔和解 老閪都爭哂全權撫養<br />\n個男仔mola mola"},{"pid":"757c9a4a1847638dce204938901249809463f41c","tid":962530,"uid":63132,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-31T06:09:36.000Z","msg":"已經用咗一百萬打官司<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"}]}