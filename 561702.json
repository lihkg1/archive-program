,{"pid":"e47201dc8180c5cee5a9a44dcda4827d32d7ce2c","tid":561702,"uid":114355,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2018-02-16T02:44:36.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/02/16/104422_7c6fe8f48378c30001a9a85485fd9fe8.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F16%2F104422_7c6fe8f48378c30001a9a85485fd9fe8.png&h=d6c0dda2&s={SIZE}\" /><br />\n<br />\n<img src=\"/assets/faces/lny/biggrin.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"68e0e09a1dd5acd775c4558ca6f9ba8ab49fe0d4","tid":561702,"uid":24227,"like":0,"dislike":1,"score":-1,"quote":{"pid":"1f94295b9102dba802483682694d2d87a031ca91","tid":561702,"uid":33643,"like":29,"dislike":0,"score":29,"citedBy":1,"replyTime":"2018-02-15T17:09:26.000Z","msg":"【專審水貨客──裁判官吳蕙芳金句錄】<br />\n<br />\n老當益壯，運咁多奶粉，一定都可以承受牢獄之苦。（2月4日）<br />\n<br />\n<span style=\"color: red;\">自己國家製造嘅奶粉都唔敢食，真係可悲，我認為係國恥。（2月6日）<br />\n</span><br />\n<br />\n人生過咗大半世，經歷咁多，體驗咁多，你哋竟然咁易俾人利用？心軟就唔得了，唔好逼我判長者坐監！（2月9日）<br />\n<br />\n<span style=\"color: red;\">我希望長者唔好恃老賣老，（走私奶粉）真係會判監，千祈唔好以身試法！（2月10日）</span><br />\n<br />\n希望犯罪集團積陰德，唔好咁冇陰公送老人家坐監。（2月11日）<br />\n<br />\n<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-16T03:58:13.000Z","msg":"<img src=\"/assets/faces/lny/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"f29d46b540054e2f1a0cfb2d895dc58f2dbca7f8","tid":561702,"uid":14055,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-16T04:06:59.000Z","msg":"FF緊女事主個樣<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"}]}