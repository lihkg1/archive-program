ig/cook.gif\" class=\"hkgmoji\" />"},{"pid":"68e8009f2fd31d64a7dfc6acefd512f9d47ff2c7","tid":2179390,"uid":108756,"like":0,"dislike":0,"score":0,"quote":{"pid":"dc4db1504780a522fcf590657a833a90b64e5d2b","tid":2179390,"uid":128600,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-08-29T05:56:44.000Z","msg":"十幾歲時試過<br />\n可以去到3-4層夢<br />\n真係會上癮<br />\n醒咗個人會好赲<br />\n<br />\n好多年冇再試<br />\n因為再沉迷落去會變到出體"},"citedBy":1,"replyTime":"2020-08-29T05:57:56.000Z","msg":"好耐無聽過呢個詞語<br />\n細個睇書睇到出體 成日想試<br />\n但就係唔識<br />\n利申睇鬼故書大<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"72728146398c2a83e8103c9138d1175db57477ef","tid":2179390,"uid":366500,"like":0,"dislike":0,"score":0,"quote":{"pid":"dc4db1504780a522fcf590657a833a90b64e5d2b","tid":2179390,"uid":128600,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-08-29T05:56:44.000Z","msg":"十幾歲時試過<br />\n可以去到3-4層夢<br />\n真係會上癮<br />\n醒咗個人會好赲<br />\n<br />\n好多年冇再試<br />\n因為再沉迷落去會變到出體"},"citedBy":0,"replyTime":"2020-08-29T06:01:43.000Z","msg":"有時失控會差啲出唔返嚟<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />驚到傻<br />\n勁多層夢，醒極都仲喺個夢度輪迴"},{"pid":"e2b008e12cef04c799d4d11481976ffd00ddb1ed","tid":2179390,"uid":148315,"like":0,"dislike":0,"score":0,"quote":{"pid":"76d0b9dd94567d46215e3f47e0292bdd5f18a7f0","tid":2179390,"uid":185842,"like":2,"dislike":0,"score":2,"quote":{"pid":"ec0d5293c72cb3541a13c20817c1d5b06970d41f","tid":2179390,"uid":148315,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-08-29T05:39:07.000Z","msg":"之前有一排瞓覺前專登訓練自己發清醒夢<br />\n控制夢嘅機會真係多咗<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n但呢排懶咗直接瞓就冇咗呢個能力<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-08-29T05:41:07.000Z","msg":"點樣訓練，我求先一開始係我聽住嘅歌控制住個夢，之後就慢慢發覺好似係夢境"},"citedBy":0,"replyTime":"2020-08-29T06:02:10.000Z","msg":"瞓喺床上面不斷諗「我可以控制個夢嘅」<br />\n不斷浮啲你喺個夢入面可以自由自在咁郁嘅畫面<br />\n諗到瞓著<br />\n<br />\n但真係好晒腦力<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />咁做係一種奢侈，通常攰到一瞓落去就瞓著咗"},{"pid":"7b39293f3604c0f7ce13829c7bc29f9ffbbab400","tid":2179390,"uid":294489,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T06:02:25.000Z","msg":"係個夢度除緊褲跟住電話響都試過<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"ae692e05f51302763652019195374bc2a74229dc","tid":2179390,"uid":117238,"like":1,"dislike":0,"score":1,"quote":{"pid":"76d0b9dd94567d46215e3f47e0292bdd5f18a7f0","tid":2179390,"uid":185842,"like":2,"dislike":0,"score":2,"quote":{"pid":"ec0d5293c72cb3541a13c20817c1d5b06970d41f","tid":2179390,"uid":148315,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-08-29T05:39:07.000Z","msg":"之前有一排瞓覺前專登訓練自己發清醒夢<br />\n控制夢嘅機會真係多咗<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n但呢排懶咗直接瞓就冇咗呢個能力<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-08-29T05:41:07.000Z","msg":"點樣訓練，我求先一開始係我聽住嘅歌控制住個夢，之後就慢慢發覺好似係夢境"},"citedBy":1,"replyTime":"2020-08-29T06:15:43.000Z","msg":"好耐之前練過 有段時間真係KEEP到<br />\n不過後尾無時間就打回原狀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 網上有好詳盡嘅教學 不過大陸野我廢事share 簡單講下<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n其實主要係train你係發夢嘅時候 顯意識要出返黎 簡單黎講係首先你要知道自己係發緊夢<br />\n記得篇教學入面有分兩種大方向 睇個人體質 一種係for平時有試過比鬼壓果種經驗 教你利用果種狀態入夢 因為比鬼壓其實等於你顯意識仲喺度 但身體就訓著咗嘅狀態<br />\n<br />\n我自己未試過所以主要睇另外嘅方法<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n1. 記夢 (每日起身果下 搵方法記低個夢 要起身即做 多數刷個牙已經唔多記得)<br />\n2. 習慣諗下自己係咪發緊夢 or 如果發夢成日會見到某樣野 現實見到都可以問下自己<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 其實係train類似條件反射嘅野 等你發夢一見到就即刻會問自己 咁顯意識容易會出返黎(不過呢個Step我自己覺得好似無咩用)<br />\n3. 入睡時 諗下類似&quot;呢次一定記得個夢&quot; or &quot;如果再夢到XXX 一定要知自己發緊夢etc.&quot;<br />\n<br />\n第一種方法就係Keep住做以上嘅野 <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 目的係令到自己發夢時大機會發現自己原來發緊夢 顯意識出返黎就可以控制到夢啦<br />\n不過控夢時間長短其實都係要另外訓練 唔係可能控得一兩分鐘 就已經比個夢帶走咗又唔記得自己發緊夢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n <br />\n如果唔洗返工 仲有種方法我自己試過仲有效 計返睡眠周期REM 係某個 時間整一整醒自己 or 趁半夜好眼訓去完廁所返訓 <br />\n合埋眼之後有意識咁去留意 仲有種方法我自己試過仲有效 計返睡眠周期REM 係某個 時間整一整醒自己 or 趁半夜好眼訓去完廁所返訓 合埋眼之後有意識咁去留意片黑色(真係唔知點形容<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 有啲抽象 當佢好似個螢幕咁) 我之前成功果陣 就會慢慢見到片黑色會有畫面 之後就清醒控到夢<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<br />\n純粹分享下<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 依家已經無咁得閒玩 呢啲野就算同朋友講佢地都唔多信"},{"pid":"04734fc722b28a6a091927a41c364de6b94d8cd7","tid":2179390,"uid":60303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T06:23:45.000Z","msg":"lm"},{"pid":"21d7a15c02a96ae56d47f56b8f8acc1cca28dd45","tid":2179390,"uid":128600,"like":0,"dislike":0,"score":0,"quote":{"pid":"68e8009f2fd31d64a7dfc6acefd512f9d47ff2c7","tid":2179390,"uid":108756,"like":0,"dislike":0,"score":0,"quote":{"pid":"dc4db1504780a522fcf590657a833a90b64e5d2b","tid":2179390,"uid":128600,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-08-29T05:56:44.000Z","msg":"十幾歲時試過<br />\n可以去到3-4層夢<br />\n真係會上癮<br />\n醒咗個人會好赲<br />\n<br />\n好多年冇再試<br />\n因為再沉迷落去會變到出體"},"citedBy":1,"replyTime":"2020-08-29T05:57:56.000Z","msg":"好耐無聽過呢個詞語<br />\n細個睇書睇到出體 成日想試<br />\n但就係唔識<br />\n利申睇鬼故書大<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-29T06:36:36.000Z","msg":"我係自己發現點做清醒夢的<br />\n之後大個咗上網check<br />\n原來個方法係同我差唔多"},{"pid":"e1f3d558b5b5469117794760533a2400d8eba0fd","tid":2179390,"uid":128600,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-08-29T06:38:50.000Z","msg":"最難突破就係<br />\n當你係夢入面一知道自己發夢時就會即刻醒"},{"pid":"e2a1b4d0c34cde94a88122ca094711eea02177ca","tid":2179390,"uid":108756,"like":0,"dislike":0,"score":0,"quote":{"pid":"21d7a15c02a96ae56d47f56b8f8acc1cca28dd45","tid":2179390,"uid":128600,"like":0,"dislike":0,"score":0,"quote":{"pi