db22bd7622c7c7f","tid":46300,"uid":9171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T05:27:52.000Z","msg":"用生鐵pan<br />\n方法跟上面<br />\n<img src=\"http://www.seriouseats.com/images/2014/11/20141106-cast-iron-myth-1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.seriouseats.com%2Fimages%2F2014%2F11%2F20141106-cast-iron-myth-1.jpg&h=17087d32&s={SIZE}\" />"},{"pid":"5c240b161e3d0140c7fea13f5124fe9f79ba657e","tid":46300,"uid":9171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T05:31:47.000Z","msg":"<blockquote>用生鐵pan<br />\n方法跟上面<br />\n<img src=\"http://www.seriouseats.com/images/2014/11/20141106-cast-iron-myth-1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.seriouseats.com%2Fimages%2F2014%2F11%2F20141106-cast-iron-myth-1.jpg&h=17087d32&s={SIZE}\" /></blockquote><br />\n<br />\n或者用carbon steel<br />\n同用不銹鋼係兩個世界<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"http://i.stack.imgur.com/3uzhf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi.stack.imgur.com%2F3uzhf.jpg&h=eafc939b&s={SIZE}\" />"},{"pid":"8f9bf32dcb4bb4a87f2c754b6cd5dd1ec787710a","tid":46300,"uid":28245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T07:45:10.000Z","msg":"我煎緊第一面 點解係咁出血水"},{"pid":"e29a785a9aee7168fb2c8897618ca564f7f6182f","tid":46300,"uid":39552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T07:56:27.000Z","msg":"lm"},{"pid":"73265a71f20741275626743d6f270a5ef92fd2e1","tid":46300,"uid":11809,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T07:58:36.000Z","msg":"慢煮＋煎"},{"pid":"07c76a1c5f35f99b67fb119b4ee76d3dbc002ef3","tid":46300,"uid":12986,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T07:59:05.000Z","msg":"慢煮棍再加火槍"},{"pid":"bd47605a19467232e791e78753ba8c2655c828f1","tid":46300,"uid":66774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T09:02:28.000Z","msg":"<blockquote>慢煮棍再加火槍</blockquote><br />\n慢煮加火槍有個問題就係塊扒唔夠熱<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"3ef4fffcd930b418dcfd216337d58c59175bf823","tid":46300,"uid":8632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T09:06:08.000Z","msg":"<blockquote><blockquote><blockquote><br />\n邊有人用易潔鑊煎牛扒<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />一開頭成件事已經錯哂</blockquote><br />\n<br />\n易潔鑊有咩問題？</blockquote><br />\n<br />\n人地第一點講左</blockquote><br />\n<br />\n易潔鑊要250度乾煎兩分鐘先會釋出致癌物<br />\n但係易潔鑊貯熱能力低<br />\n根本唔會乾煎隻鑊<br />\nsmoking point 低亦唔代表唔健康或者唔好以用嚟煎嘢食<br />\n唔係話越高溫就越好食<br />\n<br />\n個個大廚都有唔同方法煮食<br />\n有啲話煎牛扒唔好反嚟反去會變柴皮<br />\n有啲調返轉話反覆煎先可以均勻受熱<br />\n<br />\n煮食要理解背後嗰原理<br />\n塊塊牛扒形狀大細厚薄都唔一樣<br />\n品種油花紋理唔一樣<br />\n死記大火幾多秒細火幾多秒<br />\n實際效果一定唔會理想<br />\n<br />\n最後想講慢煮一定係失敗率最低嘅方法"},{"pid":"5ee09d79a395924df2b3a4ef0d6d7390ce114ba9","tid":46300,"uid":9171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T09:11:02.000Z","msg":"<blockquote><blockquote><blockquote><br />\n<br />\n易潔鑊有咩問題？</blockquote><br />\n<br />\n人地第一點講左</blockquote><br />\n<br />\n易潔鑊要250度乾煎兩分鐘先會釋出致癌物<br />\n但係易潔鑊貯熱能力低<br />\n根本唔會乾煎隻鑊<br />\nsmoking point 低亦唔代表唔健康或者唔好以用嚟煎嘢食<br />\n唔係話越高溫就越好食<br />\n<br />\n個個大廚都有唔同方法煮食<br />\n有啲話煎牛扒唔好反嚟反去會變柴皮<br />\n有啲調返轉話反覆煎先可以均勻受熱<br />\n<br />\n煮食要理解背後嗰原理<br />\n塊塊牛扒形狀大細厚薄都唔一樣<br />\n品種油花紋理唔一樣<br />\n死記大火幾多秒細火幾多秒<br />\n實際效果一定唔會理想<br />\n<br />\n最後想講慢煮一定係失敗率最低嘅方法</blockquote><br />\n<br />\n易潔無鑊氣已經爭好遠<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n同埋用cast iron煎已經唔會黐底<br />\n點解仲要用易潔？"},{"pid":"3bba51fc355af6fd4714ddf98242e839033a08ef","tid":46300,"uid":516,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T09:13:15.000Z","msg":"想請教用grill pan 點樣煎"},{"pid":"9115a5f80b4ada2a3a8d5206b8f475636df704c2","tid":46300,"uid":8632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T09:35:16.000Z","msg":"<blockquote><blockquote><blockquote><br />\n<br />\n人地第一點講左</blockquote><br />\n<br />\n易潔鑊要250度乾煎兩分鐘先會釋出致癌物<br />\n但係易潔鑊貯熱能力低<br />\n根本唔會乾煎隻鑊<br />\nsmoking point 低亦唔代表唔健康或者唔好以用嚟煎嘢食<br />\n唔係話越高溫就越好食<br />\n<br />\n個個大廚都有唔同方法煮食<br />\n有啲話煎牛扒唔好反嚟反去會變柴皮<br />\n有啲調返轉話反覆煎先可以均勻受熱<br />\n<br />\n煮食要理解背後嗰原理<br />\n塊塊牛扒形狀大細厚薄都唔一樣<br />\n品種油花紋理唔一樣<br />\n死記大火幾多秒細火幾多秒<br />\n實際效果一定唔會理想<br />\n<br />\n最後想講慢煮一定係失敗率最低嘅方法</blockquote><br />\n<br />\n易潔無鑊氣已經爭好遠<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n同埋用cast iron煎已經唔會黐底<br />\n點解仲要用易潔？</blockquote><br />\n<br />\n因為牛扒有好多種<br />\n薄身西冷咁煎好易老<br />\n題目係屋企煮<br />\n唔係個個屋企有隻鐵鑄鑊<br />\n個個都講慢煮火槍<br />\n咁屋企得隻易潔鑊收得皮啦<br />\n我唔係話易潔鑊好<br />\n只係易潔鑊係香港人廚房最常見嘅工具<br />\n好多人只能退而求其次"},{"pid":"ac64c1b54e5b72010478cfb3bc20a14d4fbaa970","tid":46300,"uid":36359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T09:40:55.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><br />\n<br />\n人地第一點講左</blockquote><br />\n<br />\n易潔鑊要250度乾煎兩分鐘先會釋出致癌物<br />\n但係易潔鑊貯熱能力低<br />\n根本唔會乾煎隻鑊<br />\nsmoking point 低亦唔代表唔健康或者唔好以用嚟煎嘢食<br />\n唔係話越高溫就越好食<br />\n<br />\n個個大廚都有唔同方法煮食<br />\n有啲話煎牛扒唔好反嚟反去會變柴皮<br />\n有啲調返轉話反覆煎先可以均勻受熱<br />\n<br />\n煮食要理解背後嗰原理<br />\n塊塊牛扒形狀大細厚薄都唔一樣<br />\n品種油花紋理唔一樣<br />\n死記大火幾多秒細火幾多秒<br />\n實際效果一定唔會理想<br />\n<br />\n最後想講慢煮一定係失敗率最低嘅方法</blockquote><br />\n<br />\n易潔無鑊氣已經爭好遠<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n同埋用cast iron煎已經唔會黐底<br />\n點解仲要用易潔？</blockquote><br />\n<br />\n因為牛扒有好多種<br />\n薄身西冷咁煎好易老<br />\n題目係屋企煮<br />\n唔係個個屋企有隻鐵鑄鑊<br />\n個個都講慢煮火槍<br />\n咁屋企得隻易潔鑊收得皮啦<br />\n我唔係話易潔鑊好<br />\n只係易潔鑊係香港人廚房最常見嘅工具<br />\n好多人只能退而求其次</blockquote><br />\n寧願用中式生鐵鑊都仲好過易潔鑊<br />\n你要講個別例子就冇辦法，但大路黎講最唔建議既一定係易潔鑊囉"}]}