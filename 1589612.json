.cc/W4L6Qy\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Freurl.cc%2FW4L6Qy&d=%2B%2BEjZc3BRqGg7MXYxMXK69LD3cQOkzCKckuFp%2FmPVdU%3D&h=9e3c316c\" target=\"_blank\">https://reurl.cc/W4L6Qy</a>"},{"pid":"fdcadbb8cb90758f91565a379d240663b20c0711","tid":1589612,"uid":192824,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-23T12:17:44.000Z","msg":"#chinazi #terrorism<br />\n<img src=\"/assets/faces/dog/escape.gif\" class=\"hkgmoji\" />"},{"pid":"95d1b17ba863052140042056a4ce1fbaeca4d6c2","tid":1589612,"uid":14715,"like":2,"dislike":0,"score":2,"quote":{"pid":"e6fbd9ce76a37bb5cbc0f6101cf13ba987084e3d","tid":1589612,"uid":212246,"like":5,"dislike":0,"score":5,"citedBy":3,"replyTime":"2019-09-23T11:06:54.000Z","msg":"如果佢地知道咗新疆muslim集中營會點？<img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-23T12:19:57.000Z","msg":"塔利班：嘩屌咁L 殘忍，不了。"},{"pid":"ed2fff5ea8f5416f8d0eec04646673f3a48107f0","tid":1589612,"uid":12404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T12:21:04.000Z","msg":"邪惡軸心國<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"589f7fd534499b97bcf5f83940d3f30d0f73d1a7","tid":1589612,"uid":313615,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-23T12:24:16.000Z","msg":"現階段，主要大國中得俄羅斯認定塔利班係恐怖組織。<br />\n中、美、英、歐盟、聯合國都冇將塔利班認定為恐怖組織。<br />\n維基百科&ldquo;畀認定嘅恐怖組織表&rdquo;：<br />\n英文維基<br />\n<a href=\"https://en.wikipedia.org/wiki/List_of_designated_terrorist_groups\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fen.wikipedia.org%2Fwiki%2FList_of_designated_terrorist_groups&d=%2B%2BEjZc3BRqGg7MXYxMXK69LD3cQOkzCKckuFp%2FmPVdU%3D&h=ee2b392e\" data-auto-link target=\"_blank\">https://en.wikipedia.org/wiki/List_of_designated_terrorist_groups</a><br />\n其中美國之前一段時間曾認定塔利班系恐怖組織，但最早於2015年已經將其移除名單，轉而稱其為&ldquo;武裝暴亂（armed insurgency）&rdquo;：<br />\n'Armed Insurgency？' White House's Inability To Call The Taliban Terrorists Is Just Plain Embarrassing&ndash;And Endangers Us All - Fox Nation<br />\n白宮發言人：塔利班唔係恐怖組織<br />\n2，美國已經同塔利班進行六輪講數，最近一次喺卡達：<br />\nTaliban and U.S. Start New Round of Talks IN Qatar - The New York Times<br />\n與美國新一輪談判在即，塔利班大佬放話：唔達標誓唔停戰<br />\n自1996年至2001年，塔利班曾喺阿富汗建立全國性政權（但執政能力低下），直到2001年阿富汗戰爭，政權先畀瓦解，後轉為遊擊。<br />\n最新進展：<br />\n美國阿富汗問題特使紮勒米&middot;哈利勒紮德（Zalmay Khalilzad）表示美國政府與阿富汗塔利班嘅新一輪談判將於6月29號開始"}]}