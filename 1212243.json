lass=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/GWeAMqT.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FGWeAMqT.png&h=8269ab53&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/3TnnrqT.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3TnnrqT.png&h=316efd69&s={SIZE}\" />"},{"pid":"afb2cb128e3bdf95a71c2d50c81ff8348783039b","tid":1212243,"uid":71037,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-12T17:50:33.000Z","msg":"呢個都好可疑，邊到來既錢去東京留學？<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/Aom3VjN.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAom3VjN.png&h=9b33c83b&s={SIZE}\" /><img src=\"https://na.cx/i/0REAMrt.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0REAMrt.png&h=c82e84ae&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2019/06/13/015029_5758ca88c69f308b7aec51f66aa303ec.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F06%2F13%2F015029_5758ca88c69f308b7aec51f66aa303ec.png&h=55295f51&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2019/06/13/015030_f76034ac62463879f39083ccad256999.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F06%2F13%2F015030_f76034ac62463879f39083ccad256999.png&h=178ee15e&s={SIZE}\" />"},{"pid":"f64a43ae749d1210f907b70b75cca606c0f34099","tid":1212243,"uid":71037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T17:54:26.000Z","msg":"推"},{"pid":"c290969f3155832f0f7c94839cfe2fef1135b7cc","tid":1212243,"uid":71037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T17:54:38.000Z","msg":"Push!"},{"pid":"edcfd1658c1c72a980e59b5cfd15fbe5a6ae85ed","tid":1212243,"uid":71037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T17:55:05.000Z","msg":"請大家留意有無資金來源可疑人士！保護香港銀行體