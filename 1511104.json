威者的「攬炒論」，稱他們「對社會無貢獻，不介意摧毀香港經濟」，又指希望得到和平示威者的體諒。<br />\n<br />\n<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"16d2bc591ad59e85bcba4e272d8600e45ab30132","tid":1511104,"uid":177510,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T12:44:56.000Z","msg":"<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/point2.gif\" class=\"hkgmoji\" />"},{"pid":"09e3c5d9d0b212edef275a032d3a2b31846dae0a","tid":1511104,"uid":83265,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T15:41:59.000Z","msg":"<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"a5ea901224d336a04c8806826900daefc0701cdd","tid":1511104,"uid":83265,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T02:07:43.000Z","msg":"<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"}]}