om%2Fwp-content%2Fuploads%2F2015%2F11%2F%25E9%2585%258D%25E5%259C%2596.jpg%3Ffit%3D960%252C960&h=f6994520&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-06-12T02:46:41.000Z","msg":"右邊"},{"pid":"64e14464882d534ca411ef0ace98d2d6089dba5d","tid":1206231,"uid":171273,"like":3,"dislike":0,"score":3,"quote":{"pid":"20abf0e890f19cda5c578e06fbec2bae9bc4787a","tid":1206231,"uid":157434,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2019-06-12T02:46:18.000Z","msg":"你有你做佢有佢做有咩好屌？"},"citedBy":2,"replyTime":"2019-06-12T02:47:20.000Z","msg":"佢叫人走呀<br />\n有乜好屌"},{"pid":"9bd1b1c6ffd41cee1fc63282ab69365d18dfd33f","tid":1206231,"uid":221265,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T02:47:43.000Z","msg":"見有巴打咁有心打咁大段嘢  我都幫手轉發<br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">[求識外語者或熟外國文化嘅人幫拖]</span></span></strong><br />\n想用<span style=\"color: green;\">由聽日開始外國人嚟香港有機會俾人捉番大陸</span>做標題，po去唔同國家既論壇同social media<br />\n<br />\n其實今次過咗嘅話，外國遊客或者在港外籍人士有可能受影響，同外國人傾嗰陣，發覺其實好難單從香港人人權受影響去令人留意，所以想睇下有冇機會用𠵱樣嘢嚟發大件事，引多啲外國公民注意，再提供當地嘅請願方式去搞大件事，從而令各地政府去開始承受較大壓力，去開始有更具體嘅操作。<br />\n<br />\n我見對外嘅大家都係支持香港之類嘅post，所以想睇下有冇新方向可以再搞大佢。<br />\n<br />\n主要係想不斷槓桿式搞大件事，因為如果開始多外國公民知，先有機會令外國政府更大行動，但依家大部分外國人其實都唔知，所以有機嘅話，哪怕係令外國人去幫手簽啲人權聯署去增加影響力都好，令各地政府有更大壓力都好，當然講嗰陣，要套用返各個地方嘅例子做類比就最好。<br />\n<br />\n不如用<span style=\"color: green;\">由聽日開始外國人嚟香港有機會俾人捉番大陸</span>做標題，po去唔同國家論壇同social media，咁起碼會好多好多有相關嘢，例如家人喺香港或者會嚟工作、旅遊嘅會留意，再補條要求當地政府關注嘅link去搞大件事。<br />\n<br />\n又舉個例，日本後生一代好中意嚟香港玩，你見唔少日本明星都有，最近日本節目先講完，如果係5ch出到依類post嘅話，我相信喺日本迥響會比𠵱家大好多，其他地方都係，有冇人可以幫手？<br />\n<br />\n<span style=\"color: red;\">Template類似</span><br />\n<br />\n由聽日開始外國人嚟香港旅行，有機會俾人捉番大陸！<br />\n<br />\n香港最為人熟悉嘅李小龍、成龍，一個充滿東方味道及美麗夜景，同中國完全不同既地方。過往香港同大陸係唔同體制，但香港政府聽日有機會通過一條法例，從而令任何人喺香港即使旅客、工作中嘅外國人都有機會俾人捉番大陸。<br />\n<br />\n6月9日，有103萬人和平上街遊行，但香港政府仍然堅持通過，而香港𠵱家有如(XX某地方類似性質嘅歷史事件)一樣，𠵱個條例會剝奪香港人嘅包括生命權、自由權、財產權、尊嚴權及追求幸福的各項人權，而且不受任何人權法律保障。<br />\n<br />\n由於香港政府聽命於內地政府，所以需要各國政府動用國際關係去保護21世紀仲會大倒退嘅人權，特別香港同中國一直行緊兩套政策同完全唔同嘅文化語言。所以懇請各位，曾經對香港文化有認識或者嚟過香港，又或尊重人權認為人人平等嘅各位，可以幫手請願，令你嘅政府更關注事件，利用國際關係同具體措施，對香港同中國政府施壓。<br />\n<br />\n特別6月尾前修例會通過，所以情況緊急，可以的話請幫忙廣傳。<br />\n<br />\n(之後提供當地簡單嘅官方請願方式)<br />\nーー<br />\n<br />\n各位如果知唔同地方嘅請願方式、主要流行嘅論壇都可以留言幫下手<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://lihkg.com/thread/1205217/page/1\" target=\"_blank\">https://lihkg.com/thread/1205217/page/1</a>"},{"pid":"532add27e0c02179a4fab25d75f4c7d361e53560","tid":1206231,"uid":221265,"like":2,"dislike":0,"score":2,"quote":{"pid":"a36ef20d426c20aa973a08d58ea65bfaa67b68a7","tid":1206231,"uid":38217,"like":28,"dislike":4,"score":24,"quote":{"pid":"f8b281f3b7cb96238ade43a50e5d13952ea0b813","tid":1206231,"uid":173814,"like":56,"dislike":18,"score":38,"citedBy":2,"replyTime":"2019-06-12T02:09:37.000Z","msg":"又內鬥屌你老母"},"citedBy":1,"replyTime":"2019-06-12T02:14:45.000Z","msg":"屌人前睇歷史。唔係講句粗口就得"},"citedBy":0,"replyTime":"2019-06-12T02:47:58.000Z","msg":"<span style=\"font-size: xx-large;\">絕對唔應該內鬥<br />\n</span>"},{"pid":"7e4d499de693d5cbac4f7d11cd82dc9c9cbd076d","tid":1206231,"uid":27927,"like":1,"dislike":2,"score":-1,"quote":{"pid":"7d66c57b1efab220d11f417143148426c1bf63c7","tid":1206231,"uid":171273,"like":127,"dislike":1,"score":126,"citedBy":8,"replyTime":"2019-06-12T02:10:20.000Z","msg":"民陣副召集人Figo chan上次一到10點就揸大聲公係咁叫人走<br />\n<br />\n屌佢老母"},"citedBy":2,"replyTime":"2019-06-12T02:48:20.000Z","msg":"民陣無得唔咁做<br />\n唔係下次好難申請"},{"pid":"4dbd6fcedb47cfb2535e2bbcf215b8cc6510585a","tid":1206231,"uid":76591,"like":1,"dislike":1,"score":0,"quote":{"pid":"7e4d499de693d5cbac4f7d11cd82dc9c9cbd076d","tid":1206231,"uid":27927,"like":1,"dislike":2,"score":-1,"quote":{"pid":"7d66c57b1efab220d11f417143148426c1bf63c7","tid":1206231,"uid":171273,"like":127,"dislike":1,"score":126,"citedBy":8,"replyTime":"2019-06-12T02:10:20.000Z","msg":"民陣副召集人Figo chan上次一到10點就揸大聲公係咁叫人走<br />\n<br />\n屌佢老母"},"citedBy":2,"replyTime":"2019-06-12T02:48:20.000Z","msg":"民陣無得唔咁做<br />\n唔係下次好難申請"},"citedBy":0,"replyTime