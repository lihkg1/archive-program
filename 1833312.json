ps://newsstatic.rthk.hk/images/mfile_1504085_1_20200122053125.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fnewsstatic.rthk.hk%2Fimages%2Fmfile_1504085_1_20200122053125.jpg&h=807c8385&s={SIZE}\" /><br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1504085-20200122.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1504085-20200122.htm&d=fvWYig%2FFXUG8IHhaG2JvmDbTr8NPmLdj%2FTsGYWOA6so%3D&h=ac964a98\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1504085-20200122.htm&h=32ce4bad\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1504085-20200122.htm</a>"},"citedBy":4,"replyTime":"2020-01-21T21:48:11.000Z","msg":"講到眾人皆醉我獨醒咁，全世界都錯，得佢同班狗係正義"},"citedBy":0,"replyTime":"2020-01-22T00:27:37.000Z","msg":"覺得自己考第一呀"},{"pid":"a54af5a5272af68a3774a34817e883eb5c6414a6","tid":1833312,"uid":237143,"like":0,"dislike":0,"score":0,"quote":{"pid":"b95e295b11caf0941f56b523a42d8ce2a97f8f49","tid":1833312,"uid":19100,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-01-21T23:52:16.000Z","msg":"過去七個月的社會動盪，無警犬因為示威者的行動而死亡，表示手足極度克制"},"citedBy":1,"replyTime":"2020-01-22T00:27:40.000Z","msg":"無人死就等於極度克制 講到留你一命就皇恩浩蕩咁 cls"},{"pid":"06a4501a9f2e08706481272ceb2f18466e1ea1c0","tid":1833312,"uid":159876,"like":0,"dislike":0,"score":0,"quote":{"pid":"8d4adb27b0846d5aedec56cfb6e5db77feb7b927","tid":1833312,"uid":213860,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-22T00:21:03.000Z","msg":"佢覺得要有人死先有問題？<br />\n睇見佢有幾咁涼薄"},"citedBy":0,"replyTime":"2020-01-22T00:28:27.000Z","msg":"佢根本由頭到尾視人命如糞土，想問佢係官場上面有邊件事可以感受到佢有人情味？<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"2aa4522985daeb7ebd55c812e0c76c9849236a8c","tid":1833312,"uid":159876,"like":0,"dislike":0,"score":0,"quote":{"pid":"8d4adb27b0846d5aedec56cfb6e5db77feb7b927","tid":1833312,"uid":213860,"like":0,"dislike":0,"score":0,"citedBy":2