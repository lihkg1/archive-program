{"tid":1475630,"cid":5,"subCid":0,"title":"［總結+文宣撚］香港人抗爭日曆，同埋招人幫手派傳單","createTime":"2019-08-15T14:15:59.000Z","updateTime":"2019-08-16T15:45:54.000Z","uid":261649,"like":0,"dislike":0,"uniUserReply":3,"replies":[{"pid":"dc54b7c949a0ce564649c700cc2f78a8ccd826d9","tid":1475630,"uid":261649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T14:15:59.000Z","msg":"8.16 <span style=\"color: red;\">全民禁錢日</span>、學界集會<br />\n8.17 教師集會、光復紅土<br />\n8.18 <span style=\"color: red;\">民陣大遊行</span><br />\n<br />\n都係辛苦個一陣，前線仲辛苦<br />\n6個死左、1個爆眼、無數受傷唔敢睇醫生、700個被捕<br />\n<br />\n<span style=\"font-size: x-large;\"><br />\n黑警還眼！<br />\n還被捕人士公道！</span><br />\n<br />\n文宣撚：<br />\n仲未見有人派傳單/舉牌<br />\n大家係咪想輸比黑警？<br />\n我地同伴比人打比人拉呀<br />\n係咪都唔出黎企幾個鐘？<br />\n<br />\n召喚18區巴打絲打派傳單<br />\n大家冇圖可以問我，教埋大家去邊到印<br />\n唔想用錢既，搵紙寫企係街都得<br />\n最好帶埋豬咀/安全帽/遮右眼<br />\n宣傳效果更好<br />\n大家加油！"},{"pid":"305a1da12d338882c995c5898cb626fa28989769","tid":1475630,"uid":241244,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T14:17:35.000Z","msg":"普教中！！！救下香港嘅下一代！！！！<br />\n<a href=\"https://lih.kg/1475548\" data-auto-link target=\"_blank\">https://lih.kg/1475548</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"a720c36135222da3f5dc557bd8807755cdedc7cb","tid":1475630,"uid":261649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T14:32:23.000Z","msg":"8.18出黎啦！"},{"pid":"12582ff493ee8b90307a47c3b78a9e853c625dc4","tid":1475630,"uid":261649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T15:06:41.000Z","msg":"推推推"},{"pid":"13cfc8d24dbd4521cdb690b0c27dd5fa44bd73d1","tid":1475630,"uid":134508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T15:10:44.000Z","msg":"push"},{"pid":"80da31b1abf19f759ef22e0e99dcc8745e9035b8","tid":1475630,"uid":261649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:45:54.000Z","msg":"8.18出黎啦 撚屌"}]}