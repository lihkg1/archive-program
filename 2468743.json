normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"7599deda2a439a30fa4c7fe1ba51dd5addcafbc8","tid":2468743,"uid":69157,"like":0,"dislike":0,"score":0,"quote":{"pid":"556e937185948b5d91b05762ff29d4c17c9a9c87","tid":2468743,"uid":329269,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-01T13:13:26.000Z","msg":"閱讀卷可以點準備好 文言文同範文都ok 但白話文好差"},"citedBy":0,"replyTime":"2021-04-01T19:19:07.000Z","msg":"白話文你係咩題型差？<br />\n你要分析下自己通常答錯咩題目"},{"pid":"1591b99ddf7ff0719a325d359eaea9d365e886dd","tid":2468743,"uid":69157,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-04-02T20:36:08.000Z","msg":"【義補】免費閱讀模擬試連批改<br />\n<br />\n自從喺高登第一次搞中文DSE說話workshop已經過去七個寒暑<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" />，（我都變中佬了<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" />）今年搞唔到免費說話練習，不過仍然無阻我想回饋呢個社群<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />，當年受過好多會考AL神人嘅恩惠，佢哋嘅無私令當年嘅窮小子得以完大學夢（即使今時今日可能比人話左膠<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />）。 <br />\n<br />\n<br />\n所以，今次花費咗全日時間，用心研究，製作咗一份同2020DSE相近嘅模擬試。<br />\n<br />\n<br />\n希望為無錢補習嘅你哋盡一分棉力<img src=\"/assets/faces/pig/read.gif\" class=\"hkgmoji\" />，提供一個改善閱讀成績嘅機會，費用全免，而且包埋批改同改善建議。<br />\n<br />\n<br />\n受惠對象：<br />\n綜援學生<br />\n全津學生<br />\n或能證明有經濟問題嘅學生<br />\n<br />\n<br />\n對於無咁嘅需要，能夠承擔補習費嘅同學，你可以捐錢去<a href=\"https://impacthk.org/zh/donate-hk/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fimpacthk.org%2Fzh%2Fdonate-hk%2F&d=T8vHa4Omq%2F1xxkbvjwgdjs5Q2JFdPMmcxM5Tq6mQO7A%3D&h=99f45a03\" data-auto-link target=\"_blank\">https://impacthk.org/zh/donate-hk/</a><br />\n下限為＄100，不設上限。喺呢個飢寒交迫嘅冬天，為露宿者送上一份溫暖。<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n參加方法：<br />\n直接去我IG click bio條link<br />\n講聲「我想參加免費閱讀模擬試」<br />\n提供返相關證明嘅副本（經濟情況同個人身份）<br />\n捐錢嘅同學比返捐錢同個人身份證明就可以<br />\n相關資料只作認證用途<br />\n最後可以嘅話留言推Post，等有需要嘅人睇到<br />\n我會自掏銀包租場，安排地點進行模擬試<br />\n<br />\n<br />\n<br />\n製作呢份卷、批改同針對每份卷比改善建議係有時間成本，犧牲好多私人休息時間去做，所以即使免費都好，希望各位參加者都認真咁去做，全力以赴。<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n最後再次多謝當年幫過我嘅獨孤巴打<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />，免費幫我補數補咗一個暑假，多謝金娜娜巴打<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />收好平比晒啲筆記我溫英文。多謝捐錢嘅同學們！<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n有咩中文Dse相關問題都可以問我 <img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" />"},{"pid":"a4862f9b9bd523ddd85ec2683fc3e5ed9eb01b61","tid":2468743,"uid":69157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-03T07:39:23.000Z","msg":"推多次 想幫多啲有需要嘅人<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"0b2892524d908ae6be01afaa058da1ede21c3fcb","tid":2468743,"uid":144187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-03T08:01:39.000Z","msg":"push"},{"pid":"3597cabaed9e7cba4752e1191952c4b4d6c1f3cf","tid":2468743,"uid":69157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-04T18:23:51.000Z","msg":"會延遲到5點開始"},{"pid":"39b271cf21bb6b5861128faa0bf55dea033e89c9","tid":2468743,"uid":69157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-05T00:48:58.000Z","msg":"Pushhhh"},{"pid":"93d35ed7ed96a414a05df62af7ce58f76af4d75c","tid":2468743,"uid":69157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-06T16:14:11.000Z","msg":"再推"},{"pid":"54774332c923aa770664d227579709fe117dcd21","tid":2468743,"uid":69157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-07T16:02:45.000Z","msg":"Pushh"}]}