moji\" />"},{"pid":"88662315750c452d34664a024784ba127f4c1e5a","tid":29802,"uid":39207,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-10T16:33:45.000Z","msg":"此回覆已被刪除"},{"pid":"7668c0a5a3a40c207fc1768b0ec1e185b5378939","tid":29802,"uid":39207,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T16:45:49.000Z","msg":"此回覆已被刪除"},{"pid":"a779dec7ce230f315e4b6bdf6adf0831d9d7254e","tid":29802,"uid":17502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T20:57:10.000Z","msg":"去你老母"},{"pid":"6035b868bcb829a66fc804bbfb412dfa2a4ac6cb","tid":29802,"uid":57914,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T20:58:57.000Z","msg":"留名"},{"pid":"1e2f4903814edf2fe86be7941b44de44424eee26","tid":29802,"uid":62318,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T21:09:08.000Z","msg":"<blockquote>巴打畀啲意見<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/369.gif\" class=\"hkgmoji\" /></blockquote><br />\n把打又係你<img src=\"/assets/faces/fs/bye.gif\" class=\"hkgmoji\" /> 如果真係有D惡魔可以搵我，然後用我剩下既生命換錢就好啦<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"831958cd0856c28ccd8f621e418eb445f96e3102","tid":29802,"uid":7241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-12T23:36:12.000Z","msg":"<blockquote>認真有死嘅意願<br />\n<br />\n但想報答父母<br />\n<br />\n點樣可以死前賺五十萬或以上畀家人?<br />\n<br />\n唔好講借財仔 - 有住址證明, 佢哋會搵得到我家人嘔返錢出來<br />\n<br />\n唔好講碌爆卡套現 - 合共得幾皮, 遠遠唔夠啦<br />\n<br />\n供份保單然後死<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> 我又等唔切, 已經好想死了, 唔想再慢慢供<br />\n<br />\n有冇計? 請鬼仔? 筆仙碟仙? <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 折壽又好咩都好 有錢就得 反正求死</blockquote><br />\n<br />\n若以報答父母為最終目標，求死必與目標違背。<br />\n<br />\n上得呢度講嘢，仲要有文有路，應該都年過十五(好似係)。<br />\n<br />\n五十萬買斷十幾年養育的心機和時間，你未免太睇低你父母。<br />\n<br />\n若在港長大，讀左咁多年書、做左咁多年人，社會成本都唔低，不如去做住義工、去深水埗幫明哥派飯洗碗做阿四，再唔係投身社運。<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n話唔定最後有女賞識兼脫毒。春宵一刻值千金，到時想死先再諗點搵五十萬。"}]}