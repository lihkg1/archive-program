e"},{"pid":"0a154a7e3c91c190806aeab89566f21d8dfd7932","tid":1415963,"uid":17232,"like":2,"dislike":0,"score":2,"quote":{"pid":"dfdd87b013cffa5b3d0886db3b4d487ef73776a7","tid":1415963,"uid":231583,"like":18,"dislike":0,"score":18,"citedBy":2,"replyTime":"2019-08-05T14:31:03.000Z","msg":"佢地就係想你倉猝升級失敗，之後洩左道氣"},"citedBy":1,"replyTime":"2019-08-05T14:31:37.000Z","msg":"啱"},{"pid":"0c8aabcbbbd3c0a936699047193edc4215865841","tid":1415963,"uid":231583,"like":5,"dislike":2,"score":3,"quote":{"pid":"bdd45c2e912a833cbe2e8ec9903cbf24853b7343","tid":1415963,"uid":17232,"like":2,"dislike":1,"score":1,"quote":{"pid":"3cca31488252b40d1b05c020eb24925a71da879f","tid":1415963,"uid":10928,"like":17,"dislike":2,"score":15,"citedBy":1,"replyTime":"2019-08-05T14:28:36.000Z","msg":"每個月一日都夠啦<br />\n一下子要個個罷工 一黎要搵食 二黎要有體力應付到"},"citedBy":1,"replyTime":"2019-08-05T14:29:54.000Z","msg":"每月一日我覺得係應付到嘅限度"},"citedBy":1,"replyTime":"2019-08-05T14:31:49.000Z","msg":"我覺得起碼都每兩星期一日<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n慢慢進化到四天工作制<br />\n最後逼政府回應<br />\n一個月一日影響力好似又太低"},{"pid":"bf890f523b2946058e10762ec9cee984041a666e","tid":1415963,"uid":235374,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-08-05T14:31:56.000Z","msg":"<strong><span style=\"color: red;\"><span style=\"font-size: xx-large;\">警察已經成為過街老鼠<br />\n下一步就要對準政權 五大訴求<br />\n要讓一班高官切身感到害怕</span></span></strong>"},{"pid":"327812ecae558aec169738675cd0b8251c970226","tid":1415963,"uid":231583,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T14:32:05.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a851a6ec2d4a4cffc0bbc84fcead59ee9e0e4127","tid":1415963,"uid":17232,"like":2,"dislike":0,"score":2,"quote":{"pid":"0c8aabcbbbd3c0a936699047193edc4215865841","tid":1415963,"uid":231583,"like":5,"dislike":2,"score":3,"quote":{"pid":"bdd45c2e912a833cbe2e8ec9903cbf24853b7343","tid":1415963,"uid":17232,"like":2,"dislike":1,"score":1,"quote":{"pid":"3cca31488252b40d1b0