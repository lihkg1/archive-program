":474732,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-21T13:34:17.000Z","msg":"想 phone in 既話可以 whatsapp 到 5224-7984,  留低電話號碼, <br />\n<br />\n顏生會安排 phone back."},{"pid":"16681505a8a382e1597514d8949ecb8932335c8b","tid":474732,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-23T13:25:03.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"341510301a6a28a256750f96d9b143cd61a6d5a5","tid":474732,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-27T13:06:39.000Z","msg":"開始"},{"pid":"b53a6b0541ac5fab2c1b8316dbf0c8056cf0482f","tid":474732,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-30T14:32:33.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"cc0c5641ebad54f44475caa60255f7dc5196930f","tid":474732,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T14:25:46.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0d35a5b2e3b91b4c8fb965b78b8ce9c89abc206f","tid":474732,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-18T12:59:06.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"6d816f02dda17feba7071f0a9af9bed9f7a770b8","tid":474732,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-21T13:46:53.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"31cef54b1afbe024e569129b8dab392aae121fcd","tid":474732,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-12T13:33:14.000Z","msg":"That's the way I like it"}]}