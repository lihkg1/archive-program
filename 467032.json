3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F13%2F143122_55305e9e793dba0622cd8214a3bcd400.jpg&h=9234d026&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/11/13/143126_35e6fd8f81c0a9ced7baa03c0284bd0a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F13%2F143126_35e6fd8f81c0a9ced7baa03c0284bd0a.jpg&h=9c08e6e8&s={SIZE}\" /><br />\n蛾出沒請注意！早前一隻外表奇怪兼「核突」、貌似飛蛾的昆蟲照片在台灣瘋傳，該物種有橙紅色身軀、灰色翅膀，尾部還有4條毛茸茸、類似「觸鬚」的部位。照片流傳到香港後，不少平時飽受蛇蟲鼠蟻困擾的市民，包括大埔及屯門區的居民，紛紛留言表示非常擔心這奇怪生物會「入侵」住宅。而蛾類專家及香港鱗翅目學會創辦人之一的甘狄克（Roger Kendrick）博士則解釋，其「觸鬚」會釋放香氣吸引異性，對人類沒有害，呼籲市民遇到此類灰燈蛾時無需驚慌。<br />\n<br />\n野生生物顧問公司董事甘狄克，在港研究蛾類超過20年，他指照片中的蛾是黑條灰燈蛾（Creatonotos gangis），在中國南部及台灣可以找到，但香港暫未有發現。根據本港紀錄，曾出現兩種跟黑條灰燈蛾同為灰燈蛾屬（Creatonotos）的相近品種，分別是八點灰燈蛾（Creatonotos transiens）及暫無中文譯名的Creatonotos fasciatus。<br />\n<br />\n甘狄克又表示相中黑條灰燈蛾身後的「觸鬚」，其實是發香器（coremata），在每年的繁殖季節，雄蛾獨有的發香器就會鼓脹起來，並發出香氣吸引異性。翻查資料，原來<span style=\"color: red;\">一眾雄蛾會互相比較自己「雄偉」的發香器，而雌蛾就從中尋找交配對象。</span></blockquote><br />\n鬥大J<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n但佢地點鬥大，科學家又點知佢地鬥緊大<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /></blockquote><br />\n動物傳心師</blockquote><br />\n同樣你去廁所有條友對住你陰陰嘴笑都知咩事啦</blockquote><br />\n我每次去廁所隔離D人都低哂頭<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b1ed81d934cf65495a7e709c97543d6a1e29e33d","tid":467032,"uid":3189,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-13T07:49:20.000Z","msg":"四條J<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f1b31836e86d36f6a8a114910333fe0c2505982e","tid":467032,"uid":27143,"like":10,"dislike":2,"score":8,"citedBy":0,"replyTime":"2017-11-13T07:50:58.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/11/13/155046_4e6e4629b368e2fc0def159445a20bac.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F13%2F155046_4e6e4629b368e2fc0def159445a20bac.jpg&h=cf787512&s={SIZE}\" /><br />\n係你喇！"},{"pid":"65b3d9281df8d502a752c6a9e4a27bbd3fd15e63","tid":467032,"uid":51110,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-11-13T07:51:24.000Z","msg":"津路水炮呢"},{"pid":"1ad9a0e2d4ac9a1c51019c558af778facc284ea7","tid":467032,"uid":86893,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2017-11-13T07:54:31.000Z","msg":"<img src=\"https://images-na.ssl-images-amazon.com/images/M/MV5BNDcyZmFjY2YtN2I1OC00MzU3LWIzZGEtZDA5N2VlNDJjYWI3L2ltYWdlXkEyXkFqcGdeQXVyNTAyODkwOQ@@._V1_UY1200_CR81,0,630,1200_AL_.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimages-na.ssl-images-amazon.com%2Fimages%2FM%2FMV5BNDcyZmFjY2YtN2I1OC00MzU3LWIzZGEtZDA5N2VlNDJjYWI3L2ltYWdlXkEyXkFqcGdeQXVyNTAyODkwOQ%40%40._V1_UY1200_CR81%2C0%2C630%2C1200_AL_.jpg&h=55904e5d&s={SIZE}\" />"},{"pid":"fa960693578f23bc88762978f1a3d03ae85e12d3","tid":467032,"uid":137811,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-11-13T08:00:58.000Z","msg":"<blockquote><img src=\"https://d2p4va2bfxy5el.cloudfront.net/wp-content/uploads/2015/09/flamethrower-bg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fd2p4va2bfxy5el.cloudfront.net%2Fwp-content%2Fuploads%2F2015%2F09%2Fflamethrower-bg.jpg&h=61f080b7&s={SIZE}\" /></blockquote><br />\n呢到唔係用水炮架咩"},{"pid":"f35d8686a6bebeaed6029bd326fa92023147badb","tid":467032,"uid":32733,"like":21,"dislike":0,"score":21,"citedBy":0,"replyTime":"2017-11-13T08:01:05.000Z","msg":"岩岩睇果段新聞訪問左個唔知咩昆蟲學家, 佢溫馨提示雖然隻野本身冇毒, 但係都不可食用, 因為唔知佢會唔會食完D有毒既食物<br />\n<br />\n<br />\n好彩佢提一提叫我唔好食<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"d603a7aa8f1819aa58437d815b8ec0b210f448e5","tid":467032,"uid":65449,"like"