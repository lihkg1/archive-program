24531,"uid":71166,"like":0,"dislike":0,"score":0,"quote":{"pid":"4a0f051242fbcab292d29628efd01b7efdf0bc05","tid":1124531,"uid":60536,"like":3,"dislike":3,"score":0,"citedBy":3,"replyTime":"2019-04-25T05:55:40.000Z","msg":"1+1=10<br />\n1+1+1=11<br />\n咁咪唔一定等於2<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-25T05:58:58.000Z","msg":"點解可以證明1+1=0"},"citedBy":1,"replyTime":"2019-04-25T06:00:13.000Z","msg":"點解可以證明1+1=10"},"citedBy":0,"replyTime":"2019-04-25T06:02:46.000Z","msg":"二進制"},{"pid":"3bc39b1b0a7d1202a6d79169ae198b881a0de9d8","tid":1124531,"uid":1751,"like":2,"dislike":1,"score":1,"quote":{"pid":"4a0f051242fbcab292d29628efd01b7efdf0bc05","tid":1124531,"uid":60536,"like":3,"dislike":3,"score":0,"citedBy":3,"replyTime":"2019-04-25T05:55:40.000Z","msg":"1+1=10<br />\n1+1+1=11<br />\n咁咪唔一定等於2<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-04-25T06:03:32.000Z","msg":"用二進制寫法只係令個表達方式，將佢轉番做十進制仍然1+1=2"},{"pid":"c90e93972db39eec97a2f38fb563e493330d4e99","tid":1124531,"uid":193476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-25T06:05:19.000Z","msg":"係時候重溫雙拼經濟學"},{"pid":"8054aa9b825b8c1fc3e4a95e278c7851d995937e","tid":1124531,"uid":8550,"like":7,"dislike":0,"score":7,"citedBy":2,"replyTime":"2019-04-25T06:11:02.000Z","msg":"睇你攞咩field<br />\n<br />\n如果你個field 得兩粒數，let say <strong>Z</strong>/2<strong>Z</strong><br />\n<br />\n啫係{0,1}<br />\n<br />\nConsider addition <br />\n<br />\n因為佢係field, 所有喺入面嘅elements 都係close under addition <br />\n<br />\n啫係1+1,0+1,0+0,1+0 都會係返{0,1} 入面嘅elements<br />\n<br />\n但個field得兩粒數，1同埋0，係冇2 <br />\n<br />\n而1之後會返去0 咁所以1+1=0<br />\n<br />\n可能有啲位唔太mathematically true 但大概應該解答到樓主想問嘅嘢"},{"pid":"e69a9499d439593f8ea6e9543444b145c10ffdc9","tid":1124531,"uid":61655,"like":0,"dislike":1,"score":-1,"quote":{"pid":"2c868c21f00629e53332bee2fdaba79dbd69b3bb","tid":1124531,"uid":71166,"like":0,"dislike":1,"score":-1,"quote":{"pid":"47f09a02b5515a2f2d3b7abfe8797bc7d39fa11d","tid":1124531,"uid":61655,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-04-25T05:53:25.000Z","msg":"算術既運1+1=2 係無錯<br />\n<br />\n但世界既法則有好多變化<br />\n<br />\n電力: 1Volt + 1Volt 正常你覺得等於幾多?"},"citedBy":2,"replyTime":"2019-04-25T05:57:58.000Z","msg":"咁點樣可以證明1+1=2"},"citedBy":0,"replyTime":"2019-04-25T06:13:30.000Z","msg":"首先十進制呢套系統係人諗出黎既, 而唔係世界法則, 只係一個諗野既方法<br />\n<br />\n而要係現實証明就要用度量衡, 同用現世間既國際單位 (SI unit)  重量, 時間, mole,  光度, 溫度, 電流, 長度<br />\n<br />\ne.g 1gram  + 1gram = 2g , 只要兩個物質測試環境相同咪証明到 1+1=2<br />\n<br />\n同上面電力講左1volt + 1volt 唔一定等於2 volt . 因為你要睇賣佢個電路係串定並聯<br />\n<br />\n所以1+1=2 係要睇你用落邊度"},{"pid":"3c52a82aed3e1853a00d555d9f3553878c97b870","tid":1124531,"uid":41887,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-25T06:30:22.000Z","msg":"Can 1+1 Have More Than Two Points?<br />\n<a href=\"https://golem.ph.utexas.edu/category/2019/04/can_11_have_more_than_two_poin.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgolem.ph.utexas.edu%2Fcategory%2F2019%2F04%2Fcan_11_have_more_than_two_poin.html&d=sSksRl51obRI29wW5WU5SbXqul57XbQM8lVYa5HUNM4%3D&h=44eeb2c2\" target=\"_blank\">https://golem.ph.utexas.edu/category/2019/04/can_11_have_more_than_two_poin.html</a>"},{"pid":"d5cf42256d1b0fae85d2969c9af4eea50a45c99d","tid":1124531,"uid":245399,"like":0,"dislike":0,"score":0,"quote":{"pid":"2c868c21f00629e53332bee2fdaba79dbd69b3bb","tid":1124531,"uid":71166,"like":0,"dislike":1,"score":-1,"quote":{"pid":"47f09a02b5515a2f2d3b7abfe8797bc7d39fa11d","tid":1124531,"uid":61655,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-04-25T05:53:25.000Z","msg":"算術既運1+1=2 係無錯<br />\n<br />\n但世界既法則有好多變化<br />\n<br />\n電力: 1Volt + 1Volt 正常你覺得等於幾多?"},"citedBy":2,"replyTime":"2019-04-25T05:57:58.000Z","msg":"咁點樣可以證明1+1=2"},"citedBy":0,"replyTime":"2019-04-25T17:39:04.000Z","msg":"加法定義"},{"pid":"d86b1d61863f0afdaec348947340edf4b8c68119","tid":1124531,"uid":245399,"like":0,"dislike":0,"score":0,"quote":{"pid":"8054aa9