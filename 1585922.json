{"tid":1585922,"cid":18,"subCid":0,"title":"前線-打狗救人篇","createTime":"2019-09-21T17:54:29.000Z","updateTime":"2019-09-21T19:53:54.000Z","uid":87533,"like":9,"dislike":0,"uniUserReply":6,"replies":[{"pid":"ed39fbb720eed3b833b2b640ce21a6489a7b1add","tid":1585922,"uid":87533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T17:54:29.000Z","msg":"<img src=\"https://na.cx/i/9j84NMs.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F9j84NMs.png&h=1ee8861e&s={SIZE}\" /><br />\n<br />\n<br />\n一般狗係咁樣壓制手足<br />\n呢個時候大家一定要冷靜<br />\n唔好亂咁打<br />\n打中狗有甲啲位係冇任何作用<br />\n<br />\n1.挫腰眼位（腰側）（難度較易）<br />\n2.從後 用棍打尾龍骨/搵野插狗屎眼/用腳踢下體（十分建議）<br />\n3.用手指摙住狗的喉嚨/用棍挫佢後頸（難度較高）<br />\n<br />\n難易度<br />\n1&gt;2&gt;3<br />\n<br />\n傷殘程度<br />\n2&gt;3&gt;1"},{"pid":"bf8870ce03230bf83f85759b4028021f2d2de0ed","tid":1585922,"uid":87533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T17:55:58.000Z","msg":"自推 1"},{"pid":"34245e706f57a705546ea627ff1d87fb76674bd4","tid":1585922,"uid":87533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T17:56:08.000Z","msg":"自推2"},{"pid":"f84f2bce26fc4b503aab424c4e161c0fee9c907c","tid":1585922,"uid":87533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T17:56:22.000Z","msg":"自推3"},{"pid":"29625f80d7c6b45af9bc99e54cdb1e7102cf56c2","tid":1585922,"uid":54946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T17:57:50.000Z","msg":"可以試下嗚門秘技"},{"pid":"c409ee96d78bc7d20132b22800f2ca24175b3c76","tid":1585922,"uid":87533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T17:57:58.000Z","msg":"自推4"},{"pid":"a042d1700f7a293f6166144cd233efd8b7060b2c","tid":1585922,"uid":87533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T17:58:11.000Z","msg":"自推5"},{"pid":"25086bb358b08fc69acc6865c381a9b752d82229","tid":1585922,"uid":87533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T17:58:21.000Z","msg":"自推6"},{"pid":"5b4f4fa