香港咁大冇流浪狐狸？"},{"pid":"ab3e31e1538c7d998d1888f868a4a0f22ffef875","tid":1163142,"uid":4917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-20T14:04:47.000Z","msg":"實同支那集團有關啦，唔查得架"},{"pid":"76497dea4dc651ddd65627b37f2722d42bef63c0","tid":1163142,"uid":65429,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-20T14:07:46.000Z","msg":"早幾年 淘寶都有得買 2000蚊內有隻"},{"pid":"a1429cce1322cbe02ea4715aac2c380ef382355a","tid":1163142,"uid":61882,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-20T14:10:02.000Z","msg":"<img src=\"https://i.imgur.com/ivyAT.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FivyAT.gif&h=a09f43f4&s={SIZE}\" /><br />\nThe quick brown fox jumps over the lazy dog"},{"pid":"1c50ea51a05b168e4a513ce85bfb794a010594e2","tid":1163142,"uid":130626,"like":0,"dislike":0,"score":0,"quote":{"pid":"cfccbc4592b90121ecb79e43f9939ef55dd18b62","tid":1163142,"uid":71635,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2019-05-20T09:38:24.000Z","msg":"政府部門養開蛇<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-20T16:30:09.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"d41f08cde74c979a6331fa373ee0804cffc23adb","tid":1163142,"uid":143033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-20T16:39:54.000Z","msg":"此回覆已被刪除"}]}