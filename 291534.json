得怪人"},{"pid":"89829365064205fc58e835a7b39b23ca14e528c0","tid":291534,"uid":60635,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-20T17:25:40.000Z","msg":"多得D 老屎忽日日學歷歧視<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" />"}]}