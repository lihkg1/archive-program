ps%3A%2F%2Fna.cx%2Fi%2FU3pLHfS.jpg&h=cd00d14a&s={SIZE}\" />"},{"pid":"6f3e601509204c2626c70c07339faaaabcdac29c","tid":1588442,"uid":263150,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T00:06:48.000Z","msg":"搭小巴唔好帶原子筆，D坐位好易穿窿<img src=\"/assets/faces/mf/adore.gif\" class=\"hkgmoji\" />"},{"pid":"27a0d67e8b1c809eda29ccc14966cd966ecef88f","tid":1588442,"uid":28252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T00:15:37.000Z","msg":"慘"},{"pid":"9bee4e35baf40adc7b59554bb1f247e71bb885b4","tid":1588442,"uid":69289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T00:27:50.000Z","msg":"推"},{"pid":"f4bc0f98ced2209d69c9f3ebac7ab7d857e353e0","tid":1588442,"uid":320646,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-23T03:46:00.000Z","msg":"各位手足，有關昨日紅van NY3831司機篤灰導致8名手足不幸被狗咬，<br />\n麻煩每人去1823 app舉報NY3831<br />\n<br />\n以下為專業手足寫的template<br />\n<br />\n=============================<br />\n<br />\n本人對以下紅色小巴作出以下投訴要求1823轉介相關政府部門<br />\n<br />\n車牌：NY 3831<br />\n地點：旺角通菜街近亞皆老街交界<br />\n<br />\n投訴事項：<br />\n香港警務處<br />\n(1) 此紅色小巴每日下午2時至晚上10時，經常無視禁區規例，違法停泊於旺角通菜街近亞皆老街交界，要求警方派交通督導員到上址作執法行動，同時將上址列為交通黑點，定期安排執法行動<br />\n<br />\n運輸署<br />\n(2) 要求即時於上址加設24小時違泊監控鏡頭，及同時安排公僕到現場視察直至問題解決<br />\n(3) 懷疑上述車輛車呔紋不足1mm厚度<br />\n(4) 懷疑司機安全帶被非法改裝<br />\n(5) 懷疑行車速度紀錄儀被非法改裝<br />\n(6) 懷疑車頭泵把被非法改裝<br />\n(7) 懷疑司機位前有屏幕顯示裝置，令司機分心<br />\n(8) 懷疑車頭膠製阿加力顯示牌阻礙司機視線<br />\n(9) 司機未有展示公共小巴司機證<br />\n<br />\n控煙酒辦公室 <br />\n(10) 上述小巴司機經常在車箱內違法吸煙<br />\n<br />\n環保署<br />\n(11) 上述車輛懷疑未有妥善維修車輛，導致有過量廢氣排放<br />\n<br />\n<a href=\"https://t.me/comp1823gp/2050\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fcomp1823gp%2F2050&d=ly7kxqs2i5dkBMcnx8ulyxZhTFX1FVJLw6RhI%2FCRHR8%3D&h=681e722f\" data-auto-link target=\"_blank\">https://t.me/comp1823gp/2050</a>"},{"pid":"4f870ae7e84da42c79b1aae9214eb2f15c456cd9","tid":1588442,"uid":28252,"like":0,"dislike":0,"score":0,"quote":{"pid":"f4bc0f98ced2209d69c9f3ebac7ab7d857e353e0","tid":1588442,"uid":320