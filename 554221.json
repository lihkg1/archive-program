ihkg.com/thread/509441/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/509441/page/1</a>"},"citedBy":1,"replyTime":"2018-02-08T19:56:29.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-02-08T19:58:55.000Z","msg":"對"},{"pid":"e8a949d2f14f704577b9f9594f27630b9a31df80","tid":554221,"uid":44073,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-08T20:03:32.000Z","msg":"此回覆已被刪除"},{"pid":"c3f9d50f4ae1f087fad7bd8e92a2aa23fd8cf9ec","tid":554221,"uid":41355,"like":0,"dislike":0,"score":0,"quote":{"pid":"2a8d42147a0f99d3900c651e94e933d6620cee9b","tid":554221,"uid":70760,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-08T19:54:56.000Z","msg":"回應主題 現時要革命 我諗都要各區軍閥帶頭起內戰?"},"citedBy":0,"replyTime":"2018-02-09T06:50:18.000Z","msg":"革命從來都要拉攏武裝勢力。<br />\n民間可以做既係文宣同解決班廢老屎忽之類，<br />\n<br />\n<br />\n雖然ff<br />\n<br />\n但情況係一定要激起軍閥有動機幫手，問題係萬一交比軍閥掌權，情況一樣好快腐化。<br />\n<br />\n其次往後情況網絡好大可能靠唔住，如果係我會先奪取網絡服務商，斷對方文宣攻擊，到時紙媒同有學歷既寫手就有翻存在價值<br />\n<br />\n成件事要一定要催化出針對現在權貴既怨恨，利用奴隸從來都要靠佢地既怨恨作為動力，貧富懸殊越大對我地越有利，利用呢種對比同資訊就可以有人力物力反。<br />\n<br />\n革命唔係一朝一夕，要做好多催化工作，令全部人意識到現今情況極差，但幸福從來不在大多數。<br />\n<br />\n當中下階級停止怨恨就係失敗之時。"},{"pid":"ca34fd03f0bc789656db852df986d00eed543859","tid":554221,"uid":41355,"like":0,"dislike":0,"score":0,"quote":{"pid":"61b32a388dec51933da9ed1e82e415b187415b2e","tid":554221,"uid":70760,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-02-08T19:53:40.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /> 森巴打有空來這答答問題 <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<a href=\"https://lihkg.com/thread/509441/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/509441/page/1</a>"},"citedBy":0,"replyTime":"2018-02-09T06:52:02.000Z","msg":"先唔好諗咩係強，諗下咩係弱?點解會弱?弱者諗野係點?"},{"pid":"5ecb117078f0925648974c7824ff5257bf9f47a0","tid":554221,"uid":41355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime