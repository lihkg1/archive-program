1662222,"uid":30624,"like":3,"dislike":0,"score":3,"quote":{"pid":"f178942c2fe828fa0d918d3c5d0d27c903f4a4cd","tid":1662222,"uid":18012,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-10-18T15:57:52.000Z","msg":"香港仲有d 咁舊式餐廳？<br />\n定係佈景？"},"citedBy":1,"replyTime":"2019-10-18T16:07:14.000Z","msg":"旺角弼街"},"citedBy":1,"replyTime":"2019-10-18T16:59:04.000Z","msg":"餐廳叫咩名？好似幾正咁"},{"pid":"125071b27545a81d7855e056650ebb983b377aaf","tid":1662222,"uid":259493,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-10-18T17:02:20.000Z","msg":"要攬炒、炒到盡！2 <img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><br />\n<br />\n[ 戰略物資管制 +美國要求獨立調查委員會]<br />\n<br />\n<a href=\"https://en.wikipedia.org/wiki/Strategic_and_Critical_Materials_Stock_Piling_Act_of_1939\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fen.wikipedia.org%2Fwiki%2FStrategic_and_Critical_Materials_Stock_Piling_Act_of_1939&d=hAhx4mZ6jCiP%2Fv5W8BSz9luXAffr%2FfAYLX%2F1af%2FGhNY%3D&h=0c9a5939\" data-auto-link target=\"_blank\">https://en.wikipedia.org/wiki/Strategic_and_Critical_Materials_Stock_Piling_Act_of_1939</a><br />\n二次世界大戰之中，美國透過此法案阻撓戰略物資進入日本/德國<br />\n人權法案審議中，為了增加美國支持  我們必須做好英文Fact checked 事件表/YouTube影片，做好時序 每星期發生的暴行 ，寄給國會議員！<br />\n'人權民主法案'只是開始，一定要每年不斷加辣加法案，直至真普選和永遠廢除中聯辦， 高度自治才可以保護外國人在香港的資產/金融財產；<br />\n違反中英聯合聲明就要中國付出代價，美國要對中國和香港進行戰略物資管制 ，必須有兩普選+ 獨立調查委員會+ 取消駐港的中聯辦和港澳版， 才考慮取消全面禁運<br />\n身在美國/加拿大的手足 必須親身拜訪 國會議員！（女性或學生演講為佳）<br />\n<br />\n<br />\n[ 所有已發展國要求成立獨立調查委員會+ 全球制裁央企和偽民企 +歐盟調查央企/偽民企的反競爭情況一如對付google壟斷一樣]<br />\n身處歐洲/日本/ 加拿大/英國/瑞士 的手足！（女性或學生演講為佳），請要求當地議員提出當地的人權及民主法案，支援香港呼應美國，親身拜訪當地國會議員， 連霸權美國都咁支持香港, 其他國家 ,道德上 需要響應; <br />\n違反中英聯合聲明就要中國付出代價， 要求歐/日調查央企/偽民企的一切罪行， 反壟斷法/傾銷/反競爭/國家補貼 /商業間諜， google和微軟都可以被歐盟庭處罰 中國冇可能不守約束<br />\n歐洲/英國/日本的戰略物資管制~  中美貿易戰開始後，中國更加依賴日本/歐洲/英國的技術， 加上中國的商業間諜罪行無處不在， 談判桌上 大把籌碼 ，絕對可以即時制裁 ， 並要求大陸停止干預香港  。<br />\n<br />\n各國要解決香港危機， 必先成立獨立調查委員會， 把中共的醜惡公諸於世 ， 世人譁然 就 所有制裁和稅行都變得合理， 也名正言順地保障各國在內地在香港的利益。<br />\n<br />\n謹記&ldquo;不要問：為何他們無動於衷 ，不幫助我們，請先問為何他們一定要幫助我們？&rdquo; 我們既要謙虛也要感恩。<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n香港人幫外國人食子彈，就是保護全球經濟增長、他們在香港的利益和 自由陣營的最前線 ，眼前的'新西柏林'意義重大，西方國家更沒理由， 無條件輸送金錢給中國請流氓打柒香港人， 今時今日，孕婦和十幾歲的學生都在前線捍衛著自由，人類道德價值觀最高的歐洲，是否應該幫助香港人?<br />\n<br />\n再冇其他選擇 香港人不講獨立不分化<br />\n一齊頂硬上！"},{"pid":"7290299c1f069c5074769a9afc373101eb273d93","tid":1662222,"uid":99591,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T17:07:04.000Z","msg":"不推文回覆"},{"pid":"41c74eb8489b559d1b4103c4862d77328ff340f4","tid":1662222,"uid":99172,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2019-10-18T17:08:15.000Z","msg":"以為係肥彭Chris Patten <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"6c0dbb67c50374f910c5f23cc3ce793d2915917d","tid":1662222,"uid":31254,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-10-18T17:11:02.000Z","msg":"who"},{"pid":"6eb238408393d194252d2461531a6781fe6ee708","tid":1662222,"uid":136457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T17:13:59.000Z","msg":"#ad"},{"pid":"bb7f4c812e63f37db4c64e512e836358cf3782e5","tid":1662222,"uid":305553,"like":0,"dislike":0,"score":0,"quote":{"pid":"9a490622d46b7685798cedc2c732c3e1bb4ce375","tid":1662222,"uid":322304,"like":2,"dislike":37,"score":-35,"citedBy":1,"replyTime":"2019-10-18T16:21:40.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-10-18T17:39:02.000Z","msg":"我啱啱睇heading都以為係Chris Patten<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ab7eefa265e06736a61b09ef720479f750a07906","tid":1662222,"uid":18647,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T17:40:25.000Z","msg":"拉"},{"pid":"9306544d6f8e615296fc26964e0d4089e1a736e5","tid":1662222,"uid":30624,"like":1,"dislike":2,"score":-1,"quote":{"pid":"242b7bf7ba1f06a9d6c8b3aa8e12239ca0c30ac3","tid":1662222,"uid":265951,"like":0,"dislike":0,"score":0,"quote":{"pid":"acba9af74a5ddbcec81aff30b0c71d0bc3411f5d","tid":1662222,"uid":30624,"like":3,"dislike":0,"score":3,