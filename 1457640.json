ji/01.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" />"},{"pid":"8bf2d5d5f2cddb8d81c9a9a2b63bc12b891813dc","tid":1457640,"uid":259812,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T12:34:14.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c496de6825b44141d9a34d0a2965515386b61f39","tid":1457640,"uid":295487,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-12T12:34:27.000Z","msg":"有航班停已經是贏<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"b480617960dec4c4697686790bc765166d80a108","tid":1457640,"uid":38691,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T12:34:30.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"bfb433852dabcad34520ec13b33e6e0bfee6e1d3","tid":1457640,"uid":99240,"like":0,"dislike":0,"score":0,"quote":{"pid":"c496de6825b44141d9a34d0a2965515386b61f39","tid":1457640,"uid":295487,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-12T12:34:27.000Z","msg":"有航班停已經是贏<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-12T12:35:19.000Z","msg":"！贏左大半！<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"d2963c004ca5340228f6fd466d1eefedfb51d890","tid":1457640,"uid":99240,"like":0,"dislike":0,"score":0,"cit