-1.fna.fbcdn.net%2Fv%2Ft1.0-9%2F118390826_783836029047494_3962843658626122553_o.png%3F_nc_cat%3D106%26_nc_sid%3D730e14%26_nc_ohc%3DNvXT7m2TfiEAX-u_dS_%26_nc_ht%3Dscontent.ftpe7-1.fna%26oh%3D58dd3f26ae5c51572ccfb3bcbcc46b49%26oe%3D5F75968A&h=7ada71d5&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-09-01T17:52:43.000Z","msg":"擺明問中好多藍屍<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"e6eccd1049d39f0efc551033e733cab7f54f2385","tid":2184680,"uid":278298,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2219d3e40722deb302a06abc7bd8b595c6e8fdd","tid":2184680,"uid":204539,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-01T17:37:53.000Z","msg":"香港人係善忘嘅溫水蛙<img src=\"/assets/faces/lm2/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-09-01T17:54:39.000Z","msg":"我唔會對港豬唔再有期望<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"cce1b800f2cb63c6f1a7ec9635ede8a85d54c222","tid":2184680,"uid":245849,"like":2,"dislike":0,"score":2,"quote":{"pid":"96550f299b383653d80fafb953e9c58d9eed18de","tid":2184680,"uid":323443,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-09-01T17:31:56.000Z","msg":"好感: 澳門人民45%<br />\n<br />\n真？"},"citedBy":0,"replyTime":"2020-09-01T18:01:11.000Z","msg":"因為文化相近&hellip;&hellip;<br />\n你排除咗澳門藍果一大堆去睇就冇太大問題。<br />\n<br />\n其實反而係澳門人有在意鍾唔鍾意香港人<br />\n其實你唔提，我都忘記咗澳門，諗起都唔會有太多壞印象"},{"pid":"86a1906898efca93dcab85966ccd5a67146b8bbb","tid":2184680,"uid":204539,"like":0,"dislike":0,"score":0,"quote":{"pid":"e6eccd1049d39f0efc551033e733cab7f54f2385","tid":2184680,"uid":278298,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2219d3e40722deb302a06abc7bd8b595c6e8fdd","tid":2184680,"uid":204539,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-01T17:37:53.000Z","msg":"香港人係善忘嘅溫水蛙<img src=\"/assets/faces/lm2/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-09-01T17:54:39.000Z","msg":"我唔會對港豬唔再有期望<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-01T18:20:47.000Z","msg":"不過計返-39的話應該有30%答好感70%答反感<br />\n本來黃藍比例都係咁上下啦"},{"pid":"1a1e54c6b7bf2349074b4389433310c2c1a798a4","tid":2184680,"uid":36861,"like":0,"dislike":0,"score":0,"quote":{"pid":"2f2ea0e6f49e9f37d39ddb3cfc20f5f46d69d3fb","tid":2184680,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-01T17:24:29.000Z","msg":"<strong><span class=\"x-large\">香港民調：港人最愛台灣人、台灣政府 最反感中國人、香港政府</span></strong><br />\n   <br />\n<a href=\"https://img.ltn.com.tw/Upload/news/600/2020/09/01/3278625_1_1.jpg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fimg.ltn.com.tw%2FUpload%2Fnews%2F600%2F2020%2F09%2F01%2F3278625_1_1.jpg&d=H6IDb39AroI58YjM1eqeYQy7VxIBYRqzliHj24KwcnI%3D&h=49a15524\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fimg.ltn.com.tw%2FUpload%2Fnews%2F600%2F2020%2F09%2F01%2F3278625_1_1.jpg&h=cc9b94bf\" data-auto-link target=\"_blank\">https://img.ltn.com.tw/Upload/news/600/2020/09/01/3278625_1_1.jpg</a><br />\n香港大學民意研究計劃訪問港人對各國政府以及人民的好感度，結果顯示，港人對台灣人民的好感度贏過香港、中國、澳門。（資料照，記者張嘉明攝）<br />\n<br />\n2020-09-01 21:38:48<br />\n〔編譯陳成良／綜合報導〕香港民意研究計劃（香港民研）1日公佈在8月進行的香港民眾對各地政府及人民觀感的調查，顯示港人最愛台灣人、台灣政府；最反感的是中國人及香港政府，其中對港府得好感淨值為-39%。<br />\n<br />\n港人對中國及香港政府的觀感由2008年的高位開始下降，到今年年初跌至最低點，對香港政府的好感淨值為-61%，對中國政府的好感淨值-36%。在本次調查中，兩項數字分別上升至-39%及-26%。對澳門政府的好感淨值則從-4%大幅上升至25%。對台灣政府的好感淨值略有下降至31%，但仍高於兩岸四地其它政府。<br />\n<br />\n對兩岸四地人民的觀感方面，好感淨值由高到低依次是：<span class=\"red\">台灣人民64%，香港人民49%，澳門人民45%，中國人民則在0至1%之間</span>。香港市民對各地人民的好感度，普遍高於當地政府。<br />\n<br />\n這項民調於8月由真實訪問員以隨機抽樣電話訪問方式，分兩階段成功訪問了1,001和1,020名香港居民，在95%信新水平下，調查的百分比誤差不超過+/-4%，淨值誤差不超過+/-7%。<br />\n<a href=\"https://news.ltn.com.tw/news/world/breakingnews/3278625\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F3278625&d=H6IDb39AroI58YjM1eqeYQy7VxIBYRqzliHj24KwcnI%3D&h=becd5885\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F3278625&h=65c47105\" data-auto-link target=\"_blank\">https://news.ltn.com.tw/news/world/breakingnews/3278625</a>"},"citedBy":0,"replyTime":"2020-09-01T18:32:20.000Z","msg":"張嘉明中文小平如小學生般"},{"pid":"b08c024a40047de11024af63384b0e9c16d9c6a2","tid":2184680,"uid":44358,"like":0,"dislike":0,"score":0,"quote":{"pid":"65a97cb9345507a8a900e01b4d2a50db0a89b0c2","tid":2184680,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-09-01T17:42:18.000Z","msg":"<img src=\"https://scontent.ftpe7-1.fna.fbcdn.net/v/t1.0-9/118390826_783836029047494_3962843658626122553_o.png?_nc_cat=106&amp;_nc_sid=730e14&amp;_nc_ohc=NvXT7m2TfiEAX-u_dS_&amp;_nc_ht=scontent.ftpe7-1.fna&amp;oh=58dd3f26ae5c51572ccfb3bcbcc46b49&amp;oe=5F75968A\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.ftpe7-1.fna.fbcdn.net%2Fv%2Ft1.0-9%2F118390826_783836029047494_3962843658626122553_o.png%3F_nc_cat%3D106%26_nc_sid%3D730e14%26_nc_ohc%3DNvXT7m2TfiEAX-u_dS_%26_nc_ht%3Dscontent.ftpe7-1.fna%26oh%3D58dd3f26ae5c51572ccfb3bcbcc46b49%26oe%3D5F75968A&h=7ada71d5&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-09-01T18:52:30.000Z","msg":"真正幫香港排名<br />\n<br />\n美國＝台灣＝＞英國＝＞澳洲＝＝＞其他＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＞港共＝中蟈。"},{"pid":"988667c3f154bd9cdbf6e2e05c41bb6382cdd9f9","tid":2184680,"uid":293677,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-09-01T18:55:14.000Z","msg":"<span class=\"red\">中國人民則在0至1%之間</span><br />\n<br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"ff1132515f2f14a6cfe4f58e36cee9a9d62da08a","tid":2184680,"uid":261796,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-09-01T18:59:02.000Z","msg":"On9 將台灣同中共比。btw 如果你俾埋其他地方佢地揀，佢地應該會揀日本人。"},{"pid":"074361d42c6cc6b83286efe6716c5a43e2465920","tid":2184680,"uid":261796,"like":0,"dislike":0,"score":0,"quote":{"pid":"b08c024a40047de11024af63384b0e9c16d9c6a2","tid":2184680,"uid":44358,"like":0,"