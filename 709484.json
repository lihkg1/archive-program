dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 個老母一齊入去坐啦仆街"},{"pid":"39d327da876045852c485671f12797ba6ce4a501","tid":709484,"uid":52939,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-20T04:59:55.000Z","msg":"用我<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f1c9347c511e96f6907dda3d80944d0fec548328","tid":709484,"uid":18948,"like":1,"dislike":0,"score":1,"quote":{"pid":"39d327da876045852c485671f12797ba6ce4a501","tid":709484,"uid":52939,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-20T04:59:55.000Z","msg":"用我<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-20T05:01:38.000Z","msg":"物化自己"},{"pid":"130111c7bfc497907ce5f634478161757fafd000","tid":709484,"uid":133522,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-20T05:05:57.000Z","msg":"個阿媽算唔算幫兇呀？<img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" />"},{"pid":"a3b8d3761fceaa23631089cbcd6181fa2e2a2d0d","tid":709484,"uid":161374,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-20T05:09:22.000Z","msg":"未入就知係台灣"},{"pid":"9b2928e3f4e1d880935856f954923ab52e2e7929","tid":709484,"uid":67823,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-06-20T05:11:10.000Z","msg":"性侵就新北<br />\n姦殺就印度<br />\n<img src=\"/assets/faces/fifa/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"f4ab7229d986ea188fe60bf8789f03ad1270acd8","tid":709484,"uid":3023,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-20T05:21:00.000Z","msg":"新北<img src=\"/assets/faces/fifa/goal.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fifa/goal.gif\" class=\"hkgmoji\" />"},{"pid":"8c152f39938375fa2656a36716bf51b2a3217726","tid":709484,"uid":108236,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-20T05:36:49.000Z","msg":"寶島<img src=\"/assets/faces/fifa/goal.gif\" class=\"hkgmoji\