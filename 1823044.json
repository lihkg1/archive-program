c=\"https://na.cx/i/AHNEZfh.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAHNEZfh.jpg&h=928a647b&s={SIZE}\" /><img src=\"https://na.cx/i/rXcamtD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrXcamtD.jpg&h=e7210122&s={SIZE}\" /><img src=\"https://na.cx/i/3Qx5UOF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3Qx5UOF.jpg&h=9c8a61a7&s={SIZE}\" />"},{"pid":"e931c2d119fd159f411f14c3045f484dea662a4d","tid":1823044,"uid":302248,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-13T16:22:58.000Z","msg":"咁你快撚啲認一國一制啦，又唔撚敢用<br />\n<br />\n<span style=\"font-size: xx-large;\">垃圾支共</span>"},{"pid":"e9d00e08d1df35b06fe60240be1d82811198098f","tid":1823044,"uid":266755,"like":0,"dislike":0,"score":0,"quote":{"pid":"e931c2d119fd159f411f14c3045f484dea662a4d","tid":1823044,"uid":302248,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-13T16:22:58.000Z","msg":"咁你快撚啲認一國一制啦，又唔撚敢用<br />\n<br />\n<span style=\"font-size: xx-large;\">垃圾支共</span>"},"citedBy":0,"replyTime":"2020-01-13T16:25:55.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f3086565257d8de78165523db3ef877f76c4e0a6","tid":1823044,"uid":48067,"like":0,"dislike":0,"score":0,"quote":{"pid":"c32a205e923d9959146f09d0a9d0548a7e1f8db1","tid":1823044,"uid":65371,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-13T11:00:11.000Z","msg":"<a href=\"https://www.facebook.com/393304404377707/posts/1050510995323708/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F393304404377707%2Fposts%2F1050510995323708%2F&d=x7%2Fg1uS4a%2BT3911x%2BwLoHAKWJX65Gw4YGtkQ1cmlXhw%3D&h=9ab5d62d\" data-auto-link target=\"_blank\">https://www.facebook.com/393304404377707/posts/1050510995323708/</a><br />\n<br />\n今日，在外交部例行記者會上，有記者問，據報道，「人權觀察」組織執行董事羅斯昨日稱，他被禁止入境香港。你能否證實？如屬實，這是否是中國中央政府向香港特區政府下達的命令？原因是什麼？<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/UVrBZHm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUVrBZHm.jpg&h=99be4435&s={SIZE}\" /><br />\n<br />\n發言人耿爽表示，中國中央政府和香港特區政府一向依法處理出入境事務，<span style=\"font-size: xx-large;\"><span style=\"color: red;\">允許或不允許誰入境，是中國的主權。</span></span><br />\n<br />\n耿爽指出，大量的事實和證據表明，有關的非政府組織通過各種方式支持反中亂港分子，極力教唆他們從事極端暴力犯罪行動，煽動「港獨」分裂活動，對當前香港的亂局負有重大責任。這些組織理應受到制裁，也必須付出應有的代價。<br />\n<br />\n<a href=\"https://world.huanqiu.com/article/9CaKrnKoRlo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fworld.huanqiu.com%2Farticle%2F9CaKrnKoRlo&d=x7%2Fg1uS4a%2BT3911x%2BwLoHAKWJX65Gw4YGtkQ1cmlXhw%3D&h=12de8ef7\" data-auto-link target=\"_blank\">https://world.huanqiu.com/article/9CaKrnKoRlo</a><br />\n<br />\n----------<br />\n<br />\n歡迎關注公署官方微信公眾號(帳號:fmcoprc)，希望為你提供豐富有益的資訊和便捷周到的服務。"},"citedBy":0,"replyTime":"2020-01-13T16:26:14.000Z","msg":"出入境自由rip"},{"pid":"a9d629de52bda3387ffab9e2caf0e2a9f3a4e2b3","tid":1823044,"uid":272422,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-13T16:27:36.000Z","msg":"推"},{"pid":"104059389fd469be35594fc354e1e042c91c0584","tid":1823044,"uid":123688,"like":0,"dislike":0,"score":0,"quote":{"pid":"1a8a0395f43a798c75e5d282de240cb9c29404aa","tid":1823044,"uid":47202,"like":13,"dislike":0,"score":13,"citedBy":5,"replyTime":"2020-01-13T11:26:00.000Z","msg":"連聯合國接近最老牌既人權組織都唔俾佢入境，而家人地一定上聯合國大會唱衰你，真係戇鳩<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-13T16:31:19.000Z","msg":"聯合國=橡皮圖章<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"79735b74345ac3f744fd19586549ca783194f146","tid":1823044,"uid":156652,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-13T16:32:45.000Z","msg":"<img src=\"https://na.cx/i/QFWyjkx.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQFWyjkx.gif&h=31ca8f1d&s={SIZE}\" />"},{"pid":"1bc5ff8c49051fbb5bcf31f08c27fb55513d1624","tid":1823044,"uid":333072,"like":0,"dislike":0,"score":0,"cit