e":"2018-09-02T06:30:59.000Z","msg":"咪閪燈大貓 大貓清盤我都唔知用邊間銀行"},{"pid":"f6bdfdcb1fb175465b900ed964596f89cdc8bf03","tid":802623,"uid":53206,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-02T07:08:34.000Z","msg":"<img src=\"/assets/faces/big/lomore_shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/lomore_shocking.gif\" class=\"hkgmoji\" />"},{"pid":"858fd335a8ddfe4dde3253e6b5b4ef257a651213","tid":802623,"uid":56698,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-02T07:10:57.000Z","msg":"如果藍籌係咁穩陣就一世都喺嗰450隻啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}