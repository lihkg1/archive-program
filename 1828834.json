g/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQxshhCE.jpg&h=f2dca26c&s={SIZE}\" />"},{"pid":"9b6f509e2e3c2c873c2ee37f1cd13370a8bb9e3b","tid":1828834,"uid":5725,"like":2,"dislike":0,"score":2,"quote":{"pid":"b2023c5d863f2305473e701f31f5a1cdae475bdc","tid":1828834,"uid":36551,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2020-01-18T13:51:54.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-18T14:44:52.000Z","msg":"雖然事主話冇問題, 但我都覺得有D高風險.<br />\nDEL左先, 大家想要錄影會面既證明TG問返事主拎"},{"pid":"b9587a4fff1aacd81349246430cec3933ec984a1","tid":1828834,"uid":82746,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T14:45:08.000Z","msg":"個熱門似咩樣呀！同我推1.19遊行post -  <a href=\"https://lih.kg/1822966\" data-auto-link target=\"_blank\">https://lih.kg/1822966</a>"},{"pid":"54f4fc8503b01010e119be83600c7ce2eeb9c7cd","tid":1828834,"uid":71071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T14:50:46.000Z","msg":"應該出唔到國喎手足<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"539f1df2f8b503d7dbab41d1180db2182be31972","tid":1828834,"uid":35364,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T14:51:44.000Z","msg":"放上公海......<br />\n無聊野就日日鬧交，<br />\n正經野就亂咁處理。<br />\n連登近幾個月咩事啊？"},{"pid":"00c7df5a5ae0c6e9b7a8502b1293f545199a7716","tid":1828834,"uid":296369,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2020-01-18T15:00:08.000Z","msg":"叫佢搵桐叔幫手.....<br />\n有好多嘢唔係表面咁簡單，真係需要幫手就要搵信得過嘅人幫手....知道之前有手足真係需要協助，有人話幫佢重話籌錢，點不知自己袋埋啲錢......手足喊住講.....<br />\n區議員會跟進及refer 去比較可靠渠道，對受助者及施予者都有一定保障......."},{"pid":"3b34b97ed32ca90003db7e6a25d318928da00c23","tid":1828834,"uid":316420,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T15:20:54.000Z","msg":"<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" />講到咁白 想出國 好難幫喎"},{"pid":"c166384843d12a848719c18256cea9e7c65019f9","tid":1828834,"uid":5725,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2020-01-18T16:29:44.000Z","msg":"如果大家驚的話, 我叫左事主DEL哂入邊內容<br />\n事主打算留係屋企食蘋果算, 大家捐俾佢食下蘋果啦<br />\n<a href=\"https://gogetfunding.com/%E8%A2%AB%E6%8E%A7%E6%9A%B4%E5%8B%95%E6%89%8B%E8%B6%B3%E6%83%B3%E9%80%97%E5%88%A9%E6%98%AF%E5%87%BA%E5%9C%8B/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgogetfunding.com%2F%25E8%25A2%25AB%25E6%258E%25A7%25E6%259A%25B4%25E5%258B%2595%25E6%2589%258B%25E8%25B6%25B3%25E6%2583%25B3%25E9%2580%2597%25E5%2588%25A9%25E6%2598%25AF%25E5%2587%25BA%25E5%259C%258B%2F&d=qHKTGL1WilUkyN31MLoEKPno2Xhlbsa%2F7jwkLKy9%2F%2FE%3D&h=4e81f396\" data-auto-link target=\"_blank\">https://gogetfunding.com/%E8%A2%AB%E6%8E%A7%E6%9A%B4%E5%8B%95%E6%89%8B%E8%B6%B3%E6%83%B3%E9%80%97%E5%88%A9%E6%98%AF%E5%87%BA%E5%9C%8B/</a><br />\n<br />\n有野想強調一下, 我絕對唔係幫事主籌, 條眾籌LINK係佢之前自己POST左係FB, 但冇人理所以我幫佢貼上黎, 所有野都唔會經過我, 大家可以自己TG事主問下, 佢作為冇連登ACCT既人其實唔知點樣為大家釋疑。<br />\n<a href=\"https://upload.cc/i1/2020/01/19/a4CcIX.jpg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fupload.cc%2Fi1%2F2020%2F01%2F19%2Fa4CcIX.jpg&d=qHKTGL1WilUkyN31MLoEKPno2Xhlbsa%2F7jwkLKy9%2F%2FE%3D&h=93bc96ce\" data-auto-link target=\"_blank\">https://upload.cc/i1/2020/01/19/a4CcIX.jpg</a><br />\n<a href=\"https://upload.cc/i1/2020/01/19/Vqh1IA.jpg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fupload.cc%2Fi1%2F2020%2F01%2F19%2FVqh1IA.jpg&d=qHKTGL1WilUkyN31MLoEKPno2Xhlbsa%2F7jwkLKy9%2F%2FE%3D&h=57faddcf\" data-auto-link target=\"_blank\">https://upload.cc/i1/2020/01/19/Vqh1IA.jpg</a><br />\n<br />\n<strong><span style=\"color: red;\">另外以下係我自己想講既野, 唔代表事主:</span></strong><br />\n想大家諗真D邊D先係緊急要幫助既CASE<br />\n當初下面呢個POST我都係咁質疑需唔需要呢刻眾籌<br />\n<a href=\"https://lihkg.com/thread/1810718/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1810718/page/1</a><br />\n一位高收入人士半年抗爭話用300K, 有樓話留份心意俾老婆仔女大家可以慷慨捐19萬, 但明明呢D先係可以光明正大搵區議員做既事。<br />\n<br />\n我冇錢幫到事主, 只係我覺得佢揹住條十年既罪, 唔通我同佢講人間有愛相信香港法治乖乖地留係屋企?<br />\n呢個明明係較為緊急同應該暗地做既CASE 大家又叫搵區議員明做, 大佬邊有可能。<br />\n<br />\n事主話得唔得都好, 佢都唔會入獄會處置自己, 我唔知佢咩意思, 我都唔想係我估既意思。我亦冇可以覆佢: 你放心啦, 唔好做傻事,上庭我地會幫你打氣, 大時大節會探你, 十年好快過。<br />\n<br />\n我最多做個橋樑幫佢放係連登, 有人一張無罪名既保釋紙唔緊急地籌左19萬, 有人緊急CASE揹住大罪冒住俾人起底風險盡可能交哂證明出黎, 仲有612都幫助過佢但大家都唔肯信, 我希望大家係未睇到個POST多過唔相信佢, 就算唔相信佢希望都可以TG問下佢俾個機會佢證明自己。<br />\n之後我唔發表自己意見啦, 廢事幫倒忙。希望大家只係早D休息為左聽日"},{"pid":"94aba0eb427ac84cfc208ecf7e8b6ad1e911c79d","tid":1828834,"uid":157037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T16:37:13.000Z","msg":"推...幫得幾多就盡幫<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"09f7d5baee9823c47ca5ceed4d7e7ccd1c0124c4","tid":1828834,"uid":325840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T16:38:15.000Z","msg":"推"},{"pid":"1ecb4c6beff17bb515117d40ab42109f629d8841","tid":1828834,"uid":163149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T18:11:18.000Z","msg":"19/1 戰前推推， 手足逗利是仲少過樓下看更<img src=\"/assets/faces/lomoji/17.png\" class=\"hkgmoji\" />"},{"pid":"a4fe5b24cdc19155a9fc4a3150be94d067037441","tid":1828834,"uid":100368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T18:18:05.000Z","msg":"推 手足不是condom"},{"pid":"547e7ef4405f66a46563b7e87afb7f98bfbd02c9","tid":1828834,"uid":89388,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T18:28:28.000Z","msg":"台灣英文女神鍾意派利是<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><br />\n<br />\n美國佬侵侵就好似唔興派"},{"pid":"2d8e366270a89ee54cf38e6a28c9481b7a5738aa","tid":1828834,"uid":269372,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T18:32:21.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d54b86591b5aea9d209bdfd2bcb3b1b4411c1141","ti