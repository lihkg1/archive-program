與中國雙邊部隊5日和9日在拉達克（Ladakh）地區班公錯湖（Pangong Tso）及錫金中印實際控制線（LAC）一帶<span style=\"color: red;\">發生互毆、丟擲石塊等</span>大規模鬥毆。<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-25T08:41:50.000Z","msg":"石器時代<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"90d6745a73c79544387533c491f3364333172800","tid":2034370,"uid":249794,"like":0,"dislike":0,"score":0,"quote":{"pid":"623d714a83b8336ff3898866243f02278f1d38f1","tid":2034370,"uid":21545,"like":2,"dislike":0,"score":2,"citedBy":4,"replyTime":"2020-05-25T08:01:04.000Z","msg":"<img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-25T08:42:59.000Z","msg":"南亞來了我帶路<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"4ad15f3ae9babc46f14515922155a95efd85bd61","tid":2034370,"uid":173271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-25T08:47:51.000Z","msg":"悶.jpg<img src=\"/assets/faces/dog/zzz.gif\" class=\"hkgmoji\" />"},{"pid":"e25b92f07ec16cbf2bb3b2bea5a664930f723fa8","tid":2034370,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-25T09:04:17.000Z","msg":"朋友 爭氣啦"}]}