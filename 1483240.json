18T11:11:05.000Z","msg":"唔駛喺sogo度9企2個鐘架"},{"pid":"34ffd50e820c855323d9dc3943957394740ff771","tid":1483240,"uid":62755,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:11:09.000Z","msg":"推<br />\n岩岩兜天后入到<img src=\"https://na.cx/i/HY7TyxO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHY7TyxO.jpg&h=b00d0e75&s={SIZE}\" />"},{"pid":"895ff26cdc46698a83f8dc3491aee27aa2f8e1a0","tid":1483240,"uid":85132,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:11:45.000Z","msg":"天后入啊"},{"pid":"e4385d4285795d18a793f6a36957b00934b54fcb","tid":1483240,"uid":265195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:11:54.000Z","msg":"銅鑼灣地鐵站嘅人都唔好上sogo個邊塞"},{"pid":"b697a85623215007598c5bd76e05185ab5d05ac0","tid":1483240,"uid":170297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:12:24.000Z","msg":"從天后入，好易入。<br />\n除了不入中聯辦，入維園都好重要。"},{"pid":"36551423954ccd17d4fdc75a5e72f7f0b297aca2","tid":1483240,"uid":165683,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-18T11:12:31.000Z","msg":"呼籲 大家幫手做人潮管制<br />\n唔好再撞人潮了 <br />\n1. 銅鑼灣站人: 落月台搭去天后出<br />\n2. 維園人: 走向維園銅鑼灣方向出口 比空間人入<br />\n3. 來緊的人: 炮台山天后站 入維園<br />\n4. 銅鑼灣人: 想入維園去行上告士打道天橋/落世貿停車場沿海旁入維園/插隊"},{"pid":"55e161eb696afb84ddf7827fd7340dfa93cf1c77","tid":1483240,"uid":170297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:12:40.000Z","msg":"從天后入，好易入。<br />\n除了不入中聯辦，入維園都好重要。"},{"pid":"70fe0cb89402861a24cc3a787ba50c3485dee004","tid":1483240,"uid":21562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:12:50.000Z","msg":"唔小心走左去中環 ，係遮打花園坐陣飲飲水，可考慮返回維園繼續集會，維園要keep住爆，達至集會目的。塞先係我地和理非想見到既野，遊行不是。<br />\n警方策略：引導前線到中聯辦，等待時機進行鎮壓，與其係咁，無限維園集會直至集會時間結束先係和理非既王牌。"},{"pid":"813cb2c8d861c115b03101a7c710c828bdac1b46","tid":1483240,"uid":170297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:13:01.000Z","msg":"呼籲 大家幫手做人潮管制<br />\n唔好再撞人潮了 <br />\n1. 銅鑼灣站人: 落月台搭去天后出<br />\n2. 維園人: 走向維園銅鑼灣方向出口 比空間人入<br />\n3. 來緊的人: 炮台山天后站 入維園<br />\n4. 銅鑼灣人: 想入維園去行上告士打道天橋/落世貿停車場沿海旁入維園/插隊"},{"pid":"6fb484e3b8e14f7ca30bba0484db6fb47dbf56bf","tid":1483240,"uid":200957,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-18T11:13:09.000Z","msg":"SoGO門口附近果幾條路其實塞左好多個鐘!<br />\n銅鑼灣地鐵站既人目前係入唔到去  又出唔到黎<br />\n如果未入維園既求大家唔好擔遮<br />\n左穿右插就可以殺出條路去維園<br />\n<br />\n我由四點係銅鑼灣sogo到維園果條路塞左三個鐘 <br />\n依家關遮殺出一條血路先可以到到維園<br />\n但結果維園原來好少人<br />\n個個塞哂係地鐵站附近<br />\n<br />\n<br />\n千其唔好行去皇室堡 sogo個方向 <br />\n呢條街係對流緊<br />\n因為有好多人未去維園架<br />\n<br />\n維園目前其實好少人!!!<br />\n<br />\n大家唔好怕淋雨  因為塞左咁耐  都因為個個都開遮"},{"pid":"2938e5a71d6dad2ef7b01718432992f979bb31bd","tid":1483240,"uid":210612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:13:36.000Z","msg":"啱 次次都塞皇室堡塞到驚"},{"pid":"1c90fada986272a2e53f3e6daa1a28d5e55e6034","tid":1483240,"uid":265195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:13:58.000Z","msg":"推 流動番就可以解決到塞嘅問題"},{"pid":"cb9a47552cf6af47ad10090a714cc616f2ea8c4c","tid":1483240,"uid":53128,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-18T11:14:01.000Z","msg":"Hysan果度落唔落到地鐵站？"},{"pid":"e48e663c60a7c153d3963719e67b6406b9dbd326","tid":1483240,"uid":50013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:14:17.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"3441892b1c9e2f72f4a3d8c39bc8827938d8f0a3","tid":1483240,"uid":92606,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:14:29.000Z","msg":"轉載<br />\n冇大台結果塞實曬都冇辦法， 大家盡量呼籲身邊既手足<br />\n⬇️⬇️⬇️<br />\n銅鑼灣灣仔既人要入維園， 請盡量行去海傍方向，沿海傍既路極之暢通， 過左銅鑼消防局先轉入維園<br />\n⬇️⬇️⬇️<br />\n維園入面既手足，離開維園時， 請盡量靠左， 俾多啲條路面入維園既手足入黎， 見維園入面人少， 大家唔使走得咁快"},{"pid":"6808f2556a6d860b314af73d2558d97fb0fee69c","tid":1483240,"uid":28432,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:14:58.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"95e0eeff11811508afccb4b44b1707dc103ccb22","tid":1483240,"uid":235084,"like":0,"dislike":0,"score":0,"quote":{"pid":"e8d4d99a39394a85c8fe1467531aae9a164422c0","tid":1483240,"uid":100811,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-18T11:05:37.000Z","msg":"<span style=\"font-size: x-large;\"><span style=\"color: red;\">係銅鑼灣sogo塞撚咗兩個鐘</span></span><br />\n<img src=\"https://na.cx/i/hYSsCWn.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhYSsCWn.png&h=93428edb&s={SIZE}\" /><br />\n後尾經銅鑼灣站搭去天后 <br />\n十分十分鬆動 <br />\n<img src=\"https://na.cx/i/eXxPRgR.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeXxPRgR.png&h=bbccdd13&s={SIZE}\" /><br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: medium;\"><span style=\"font-size: xx-large;\">維園好吉銅鑼灣塞撚到仆街大家唔好係SOGO 鳩塞 <br />\n因為ikea 係出口來嫁 維園出的人係一路出緊來 <br />\n完全無路畀sogo 的人入維園<br />\n維園好吉 經天后入呀 唔好塞係到呀！</span></span></span>"},"citedBy":0,"replyTime":"2019-08-18T11:15:10.000Z","msg":"push"},{"pid":"d9c1d85f62d4110af6d38b153d68435709c19f03","tid":1483240,"uid":265195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:15:57.000Z","msg":"上電車站上面天橋兜過去都入到架"},{"pid":"dad947146ee1d815dea3b468c54e3dabc11786d6","tid":1483240,"uid":170297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:16:56.000Z","msg":"呼籲 大家幫手做人潮管制<br />\n唔好再撞人潮了 <br />\n1. 銅鑼灣站人: 落月台搭去天后出<br />\n2. 維園人: 走向維園銅鑼灣方向出口 比空間人入<br />\n3. 來緊的人: 炮台山天后站 入維園<br />\n4. 銅鑼灣人: 想入維園去行上告士打道天橋/落世貿停車場沿海旁入維園/插隊"},{"pid":"294f98cf0142da9705c567ef4815fefd444699f3","tid":1483240,"uid":170297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T11:17:06.000Z","msg":"呼籲 大家幫手做人潮管制<br />\n唔好再撞人潮了 <br />\n1. 銅鑼灣站人: 落月台搭去天后出<br />\n2. 維園人: 走向維園銅鑼灣方向出口 比空間人入<br />\n3. 來緊的人: 炮台山天后站 入維園<br />\n4. 銅鑼灣人: 想入維園去行上告士打道天橋/落世貿停車場沿海旁入維園/插隊"},{"pid":"38a123f31d99da87976ca824c6e778bbfd9541d8","tid":1483240,"uid":284319,"like":0,"d