"},{"pid":"8ebe6dc8ccf32fbfec859892b47b78e43156bbb5","tid":795044,"uid":41818,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-08-26T17:09:35.000Z","msg":"鬥平鬥賤搶標"},{"pid":"545bc3510d22325e6d08354ab3c26024a24b0e50","tid":795044,"uid":29702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-26T17:35:36.000Z","msg":"此回覆已被刪除"},{"pid":"73d5e1b000a9c1bf57f2b7973e9cc514562216a0","tid":795044,"uid":39632,"like":0,"dislike":0,"score":0,"quote":{"pid":"1ac4a0b4430a9c8abaac4ce4ee4162e4a710b0fb","tid":795044,"uid":19454,"like":0,"dislike":0,"score":0,"quote":{"pid":"120ef96dce72ecf110a9d329e4787786abee29e0","tid":795044,"uid":67338,"like":2,"dislike":0,"score":2,"quote":{"pid":"287b96c83f61abfd1d6028ba7fa7fe1295e883bb","tid":795044,"uid":42764,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-08-26T16:38:38.000Z","msg":"人工太低<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-26T16:46:05.000Z","msg":"仲要隨時有心理準備要坐監"},"citedBy":1,"replyTime":"2018-08-26T17:01:21.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-26T17:38:40.000Z","msg":"睇舊登講好似老屎忽都冇15k<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}