簽<br />\n夠10萬個就有機會喺英國國會討論<br />\n<br />\n喺香港住嘅take返Hong Kong<br />\nPostal code 就打000000 或 N/A<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=%2BEgMKdsH73Wj%2FuX4aBpXdgHlXPv3B7QU%2BsV1%2BUkEKpk%3D&h=6d64c493\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"2d12ff2e0b9776696bab5db8a9ab570dc3f40f91","tid":1474264,"uid":22131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T06:29:26.000Z","msg":"廣傳<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"5fd31321120c651b1045f1de4882acb5f70b80d2","tid":1474264,"uid":251292,"like":1,"dislike":0,"score":1,"quote":{"pid":"1af23b53d45ff271509d6ea5adef4f2546cee04e","tid":1474264,"uid":230942,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-08-15T06:21:14.000Z","msg":"殘體 同音 錯字都冇<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-08-15T06:32:14.000Z","msg":"要加少少殘體同音字"},{"pid":"6aa9c06bbe78d60a9b7ab8aed125595f8b0f890f","tid":1474264,"uid":22131,"like":0,"dislike":0,"score":0,"quote":{"pid":"5fd31321120c651b1045f1de4882acb5f70b80d2","tid":1474264,"uid":251292,"like":1,"dislike":0,"score":1,"quote":{"pid":"1af23b53d45ff271509d6ea5adef4f2546cee04e","tid":1474264,"uid":230942,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-08-15T06:21:14.000Z","msg":"殘體 同音 錯字都冇<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-08-15T06:32:14.000Z","msg":"要加少少殘體同音字"},"citedBy":0,"replyTime":"2019-08-15T06:42:56.000Z","msg":"<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"de7fefb52ec195587670b973ff1e6fae17218440","tid":1474264,"uid":108337,"like":0,"dislike":0,"score":0,"c