/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"09a1d8706bdbfb97edc092840a98ed3b846a3ede","tid":547263,"uid":74981,"like":0,"dislike":0,"score":0,"quote":{"pid":"22f0a76026d8d443c59c598cfc944916d569362f","tid":547263,"uid":74981,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-02-01T10:49:28.000Z","msg":"炒洋蔥炒得耐洋蔥會呈啡色，煮出黎既汁都係會偏啡，今次正經答你野，唔屌你條仔<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-01T10:50:31.000Z","msg":"Block左我係你既損失<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"61341530eec4556b1f66cbaffdd8cce1dac9c872","tid":547263,"uid":22318,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-01T11:07:11.000Z","msg":"<blockquote><blockquote>一係你牛油麵粉底做個白汁算啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote>唉屌我本來諗住可以少d功夫啊嘛<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/02/01/182730_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F01%2F182730_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=ddc2597b&s={SIZE}\" /></blockquote><br />\n你炒完雞肉唔好落水 裝起先<br />\n洗鑊 淨煮汁 如果出黎都唔係圖咁白就放棄啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n開牛油麵粉底 落牛奶仲簡單好味<br />\n開稀啲煮意粉又得<br />\n&quot;杰&quot;身啲焗飯/意粉又得<br />\n再唔係煮多個肉醬做千層寬麵 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 反正百搭"},{"pid":"25c003d4781df69b17cdb8169dc03d5753d94650","tid":547263,"uid":8246,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-01T11:12:34.000Z","msg":"用白洋蔥會好啲<br />\n而且洋蔥炒得太腍<br />\n雞肉同洋蔥分開炒半熟先<br />\n另外紅蘿蔔太多，只係要幾舊整靚個色<br />\n而且唔洗炒蘿蔔先<br />\n落完白汁先落蘿蔔<br />\n<br />\n另外你炒完個鑊已經有鑊焦都會影響隻色<br />\n下次炒完洗鑊試下"},{"pid":"f6098a5fece66e18505f3a4a7856bbbbf33e4d50","tid":547263,"uid":92,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-01T11:14:05.000Z","msg":"食落咩味？"},{"pid":"059aff16cc1e833e48d0606724f929d36992a68f","tid":547263,"uid":81852,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-02-01T11:27:41.000Z","msg":"此回覆已被刪除"},{"pid":"4f8ba9673c0f69c9c92e2c554f229911cd733b12","tid":547263,"uid":25321,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-01T11:32:56.000Z","msg":"仆街睇咗做女夜鬼"},{"pid":"fcdd5d339c2c2b390ffc611555683726a3aec346","tid":547263,"uid":43041,"like":1,"dislike":0,"score":1,"quote":{"pid":"8a722d72f173f75b10a2812f48f009925e4f61b3","tid":547263,"uid":126603,"like":5,"dislike":0,"score":5,"quote":{"pid":"317c469ba6b9ff72285aa560ad0ac4ba66fae3ab","tid":547263,"uid":43041,"like":0,"dislike":0,"score":0,"quote":{"pid":"844fb6c7ac46422f2054fefc5ec51fd921bc92d0","tid":547263,"uid":126603,"like":0,"dislike":3,"score":-3,"citedBy":2,"replyTime":"2018-02-01T09:35:28.000Z","msg":"胡蘿蔔同肉啊"},"citedBy":1,"replyTime":"2018-02-01T10:22:58.000Z","msg":"但個盒既指示都叫我咁做<br />\n點解煮唔到同樣效果<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-01T10:28:20.000Z","msg":"你用邊款紅蘿蔔<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> ？<br />\n<br />\n但其實跟盒嘅指示煮出嚟嘅嘢同盒嘅食物賣相好多是都唔一樣<br />\n<br />\n太多因素啦<br />\n例如廚具選擇、你落鑊爆下啲嘢食嘅時間長短同款式，even食材都有影響"},"citedBy":0,"replyTime":"2018-02-01T12:40:43.000Z","msg":"高手<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n我只係用6蚊一袋大條個d紅蘿蔔咋，我都唔清楚咩品種<br />\n可能我蘿蔔炒耐左都唔定，個邊燶左少少<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5b22f444af3c958a5904e20891557ff89ecf2fa8","tid":547263,"uid":43041,"like":1,"dislike":0,"score":1,"quote":{"pid":"0c09651ba72581754c0e4574608e05f4ddd7f21a","tid":547263,"uid":44814,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-02-01T10:35:46.000Z","msg":"你下次分開搞 煮熟左啲料擺一邊<br />\n用個鍋開左個醬 顏色對路嘅話<br />\n差唔多就擺埋啲料落去煮一煮返熱同攪勻"},"citedBy":0,"replyTime":"2018-02-01T12:42:14.000Z","msg":"收到<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 下次料同汁會分開處理"}]}