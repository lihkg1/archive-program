imag.cx%2FhBXlI.jpg&h=32290e7c&s={SIZE}\" /><br />\n<img src=\"https://i.imag.cx/vHoXA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FvHoXA.jpg&h=1fb87b30&s={SIZE}\" /><br />\n下面呢個係隨便台Official LINE群,有咩突發消息,開台通知,我都會係呢度公布<br />\n<img src=\"http://qr-official.line.me/L/aqio2VXZLo.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fqr-official.line.me%2FL%2Faqio2VXZLo.png&h=03fd5638&s={SIZE}\" />"},{"pid":"6af08d9f9e8df626f0e9e6ce2379314bd2bd93e0","tid":396070,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-11T11:37:53.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d8ef845859b1f182f054976633d17af210a00545","tid":396070,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-11T11:42:02.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"7fb1346e5d3f8690ea96e236f17a175d58a9117d","tid":396070,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-11T11:58:57.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f104604231077f0c89f5d53b4cd890b01c11b1e7","tid":396070,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-11T11:59:10.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\"