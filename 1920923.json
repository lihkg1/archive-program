2Fi%2FS8HqvJX.png&h=11d8b4ca&s={SIZE}\" /><img src=\"https://na.cx/i/1Jm3hoY.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1Jm3hoY.jpg&h=e8434470&s={SIZE}\" /><img src=\"https://na.cx/i/hKtJhoZ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhKtJhoZ.jpg&h=26d915d0&s={SIZE}\" /><img src=\"https://na.cx/i/F6ZXmQE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FF6ZXmQE.jpg&h=7f25a21d&s={SIZE}\" /><img src=\"https://na.cx/i/viJk330.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FviJk330.jpg&h=76614421&s={SIZE}\" /><br />\n<br />\n我知好多本土派唔滿意，但希望大敵當前忍讓一下，係重要關頭能屈能伸，雖然政治理念唔同，但係大家既敵人依然係一致<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n梁天琦獄中公開信：真正公義還未來臨　莫被仇恨支配<br />\n<br />\n<img src=\"https://na.cx/i/yXZcVb5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyXZcVb5.png&h=2b5b54bf&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-03-12T07:40:33.000Z","msg":"《立會初選》合作係本土贏嘅契機<br />\n<a href=\"https://lih.kg/1921728\" data-auto-link target=\"_blank\">https://lih.kg/1921728</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"db89b46217e55e8cb33561922d6cd47b12ccd949","tid":1920923,"uid":101392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T13:09:43.000Z","msg":"割完楊岳橋<br />\n跟住譚文豪<br />\n跟住引導人割黃絲<br />\n而家立場都想割埋<br />\n<br />\n立場新聞寫法為紅官護航<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1922193\" data-auto-link target=\"_blank\">https://lih.kg/1922193</a>"},{"pid":"c3bf24f1c400acebfbaf2167fd31bbc98f14cc72","tid":1920923,"uid":38164,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-12T13:30:55.000Z","msg":"<span style=\"font-size: x-large;\"><span style=\"color: red;\">兄弟爬山<br />\n各自努力<br />\n不分化<br />\n不割蓆<br />\n不捉鬼<br />\n不內鬥<br />\n和勇一心<br />\n光復香港<br />\n時代革命<br />\n五大訴求<br />\n缺一不可<br />\n願榮光歸香港</span></span><br />\n<br />\n五毛、黑警<br />\n極端留言破壞正常討論<br />\n大家唔好再互相拖兄弟後腿<br />\n應該所有方法都要去做！盡量去做！<br />\n經歷咗咁耐大家都唔明白？<br />\n我哋就係要喺所有戰線上<span style=\"font-size: x-large;\"><span style=\"color: gold;\">一定要建制輸</span></span><br />\n<span style=\"color: gold;\"><span style=\"font-size: x-large;\">係呢啲咁關鍵嘅時候竟然有人重提投白票分化<br />\n仲晒時間屌偽黃、內鬥</span></span><br />\n大把文宣野可以做，去聲援、去旁聽、可以做國際戰線可以做、連儂牆可以做、申請工會可以做<br />\n<span style=\"color: gold;\"><span style=\"font-size: x-large;\">求下大家做實事好唔好</span></span><br />\n靜待時機一定可以捲土重來"},{"pid":"caf6128c592bdf3320f5c6dadbc8530337250aa0","tid":1920923,"uid":145292,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T13:32:53.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"7bd3f98e8e814c370cd6171da455b4de445b3cbb","tid":1920923,"uid":128546,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-12T13:33:47.000Z","msg":"唔割！"},{"pid":"4ed73db82f6d7f6fbe4bcb56080cabccd15d8438","tid":1920923,"uid":38164,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-12T13:35:55.000Z","msg":"割完楊岳橋<br />\n跟住譚文豪<br />\n周圍屌人偽黃<br />\n連個細路仔都唔放過<br />\n大家要醒下啦<br />\n<br />\n正經野永遠冇人去推<br />\n屌人嘅PO就熱門<br />\n分化撚癲大家唔好一齊癲<br />\n唔好再俾人慫恿到做埋啲戇鳩野<br />\n對抗水軍嘅最好方法<br />\n就係大家要保持一定嘅發言次數<br />\n唔好再懶啦"},{"pid":"5dd8b63126c9d700a0bc3210121d844f79d0bcce","tid":1920923,"uid":261330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T13:37:11.000Z","msg":"黃絲咪一樣分化有啲人唔夠黃<br />\n批評下又話熱狗<br />\n其實民主係一定會有唔同意見<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0ec17310a112d1f5f0ad5a9f7fbcf9324f05a3ad","tid":1920923,"uid":285371,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T13:37:19.000Z","msg":"推"},{"pid":"cb095d23df6f21d66bb41cd653b17bbb8d2ee445","tid":1920923,"uid":234362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-12T13: