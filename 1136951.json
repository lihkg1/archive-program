d":216433,"like":1,"dislike":0,"score":1,"quote":{"pid":"d67f526957215eefa6d036446a63124ad683a986","tid":1136951,"uid":2259,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2019-05-03T14:02:06.000Z","msg":"試下係咪真係怕糯米"},"citedBy":0,"replyTime":"2019-05-03T21:43:45.000Z","msg":"佢地唔驚糯米架 只係將糯米煮爛 再將d糯米封住d窿窿罅罅 等佢地走唔到出黎<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"1f251484f8ef12d168e4b1ec9210e0d446e2b48a","tid":1136951,"uid":244105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-03T22:33:02.000Z","msg":"樓主俾木蝨咬撚死左?"},{"pid":"1006f1c3887ef13a48a0f89d1f307db420376a29","tid":1136951,"uid":86540,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-03T23:49:10.000Z","msg":"之前屋企試過有床蝨，搵返個竇，用蒸氣燙斗去蒸佢係殺得死既。<br />\n床蝨大戰第三回合-聽朝等結果<br />\n<a href=\"https://lih.kg/889675\" data-auto-link target=\"_blank\">https://lih.kg/889675</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"8f34ebf0c57164e000413eaf602ddd04fa32d087","tid":1136951,"uid":13156,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-04T01:08:10.000Z","msg":"買DE粉<br />\n<br />\n我屋企試過 我乜方法都用過<br />\n最後靠DE粉搞返好"},{"pid":"54cc36bf008c93acffb936c8c1b85aa7566736af","tid":1136951,"uid":108228,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2019-05-04T01:31:01.000Z","msg":"其實唔洗掉哂傢私 因為佢點都會番去床到咬你<br />\n<br />\n1. 抽濕機<br />\n2. 蒸汽機蒸床<br />\n3. 買防床蝨床套包實張床肉 包番年幾 咁就唔洗掉 同埋白色易睇佢地係邊<br />\n4. 都係咩de粉 噴噴之類<br />\n5. 一定要搵哂佢地d巢出黎殺哂<br />\n<br />\n之前比蝨咬左成個幾月 初頭以為比蚊咬 後尾多起上黎先知 <br />\n不過平時會開抽濕機 所以唔知點解d蝨總共得8隻 1日殺哂 當晚無野咬 過1星期有1粒蛋孵左 殺埋<br />\n<br />\n聽講 初頭咬1粒=1隻 你唔驚眼訓 咪換白色床套 夜晚坐係張床 佢地一定會咬人 坐係度捕佢地囉"},{"pid":"ef4e4ea8d0331737fbd95385185c8dceb3a205a9","tid":1136951,"uid":108228,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-04T01:34:06.000Z","msg":"漏左<br />\n<br />\n我有拎哂d衫床套出去洗衣店洗+乾 因為熱力係殺得死佢地 一般自助乾衣溫度同時間都夠殺<br />\n<br />\n<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />我一樣傢私同床同無掉過<br />\n香港好滑濕好麻煩 呢隻野一濕就繁殖得好快 多開抽濕"},{"pid":"5b3cef0ad0450329cbffaab88870ce663d54843a","tid":1136951,"uid":138713,"like":0,"dislike":0,"score":0,"quote":{"pid":"1d92199bfc82bc5a1aa7dda24dfdf369e8fd25be","tid":1136951,"uid":82376,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-05-03T14:14:40.000Z","msg":"儲定錢去換床啦<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-04T01:34:30.000Z","msg":"換樓啦直頭"}]}