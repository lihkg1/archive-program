l/cry.gif\" class=\"hkgmoji\" />"},{"pid":"3648d70a1c2771bbf776a56e6a9d420bf529b59b","tid":823552,"uid":189507,"like":0,"dislike":0,"score":0,"quote":{"pid":"3ed801ebb5ffbef85fb46fe2b97148049aba3340","tid":823552,"uid":35790,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2018-09-16T23:45:56.000Z","msg":"天水圍無輕鐵"},"citedBy":0,"replyTime":"2018-09-17T00:27:15.000Z","msg":"砍樹中&hellip;&hellip;"},{"pid":"3fd9981b71f36e96b8f50c036edadc887b3ccaa7","tid":823552,"uid":5490,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-17T00:36:11.000Z","msg":"7點幾天水圍上車重少人過平時<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"153371b07e4d3a115f3447603a8daa5be2fde790","tid":823552,"uid":176442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-17T01:43:41.000Z","msg":"輕鐵路綫505綫、507綫、614P綫及615P綫維持正常服務：<br />\n614綫及615綫改道，將不停藍地站至元朗站；<br />\n610綫改道，將不停塘坊村站至元朗站；<br />\n751綫改道，將不停坑尾村站至天逸站。<br />\n <br />\n其他路綫暫時未能提供服務。<br />\n <br />\n港鐵已安排免費接駁巴士，行走來往705綫沿途各站接載受影響車站的乘客。<br />\n乘客亦請考慮改搭其他交通工具。<br />\n港鐵職員正在處理事件。請耐心等候，多謝合作。"},{"pid":"33d3b8f5119bd87a9a71fe3e17bdf46a0e46a3d2","tid":823552,"uid":104432,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-17T01:49:15.000Z","msg":"969有車，但出左天水圍一陣已經塞塞地<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},{"pid":"d8f5834d310242abd081d8448fc409955ed72899","tid":823552,"uid":27432,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-17T02:55:51.000Z","msg":"接駁巴去西鐵好順暢<br />\n西鐵都順暢無乜人<br />\n而家東鐵慢慢地<br />\n<br />\n利申10點出門"}]}