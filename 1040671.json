=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"},{"pid":"0205e6e481a15d0053952e46fcd743d01ca3d9d0","tid":1040671,"uid":149844,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-01T08:15:19.000Z","msg":"好心早晚刷牙<br />\n一年一次洗牙啦<br />\n少菌感染無咁易牙齦發炎同牙痛"},{"pid":"346784367b1eb2beaf45adec764e243525bee8a2","tid":1040671,"uid":179979,"like":3,"dislike":0,"score":3,"quote":{"pid":"c84b1fe4a86c88aee92ef1114aa0cbe12e1f96be","tid":1040671,"uid":152598,"like":2,"dislike":3,"score":-1,"citedBy":1,"replyTime":"2019-03-01T07:48:01.000Z","msg":"我隻狗啲牙乾淨過你<br />\n我晚晚有同佢刷牙<br />\n你有無叫你主人幫你刷牙？<br />\n你買潔齒骨食咪得囉<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-01T08:36:09.000Z","msg":"係網上講野係唔同d既"},{"pid":"43aa819d993c16117349ff45cb50f5c0799ff289","tid":1040671,"uid":10637,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-01T08:41:40.000Z","msg":"唔洗大病<br />\n手足口已經慘過牙痛啦"},{"pid":"5ff5ae43bbb53b50715f45a82d156c6797260613","tid":1040671,"uid":128210,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-01T09:09:56.000Z","msg":"同意，細個無人理。完全無刷牙。<br />\n牙痛咗好耐（幾年），當時讀緊書儲唔到錢整，同無牙科常識。我屋企人係低能，叫我拎保_ _ 塞住，小小錢都唔幫我出。<br />\n<br />\n牙痛真係超辛苦。<br />\n我對付牙痛的方法：<br />\n1. 食止痛藥，樓主話無效，的確，止痛藥藥效對付牙痛係因人而異，試多幾隻唔同的藥試下。去藥房問而唔好去萬寧/屈 問。<br />\n<br />\n2. 用冰水麻痺隻牙，愈凍愈好，不過好快會無效。<br />\n<br />\n盡快去睇，唔拖得。不過隻牙痛緊，已經要度牙根。"},{"pid":"b3a30e67154ea20ef80d29942740b796450eaed7","tid":1040671,"uid":116330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-01T09:13:17.000Z","msg":"即刻搵牙醫剝左佢佢啦<br />\n仲食咩止痛藥"},{"pid":"0c4de813369db376a75be5bfb6cd98fc54f730dc","tid":1040671,"uid":152598,"like":0,"dislike":1,"score":-1,"quote":{"pid":"346784367b1eb2beaf45adec764e243525bee8a2","tid":1040671,"uid":179979,"like":3,"dislike":0,"score":3,"quote":{"pid":"c84b1fe4a86c88aee92ef1114aa0cbe12e1f96be","tid":1040671,"uid":152598,"like":2,"dislike":3,"score":-1,"citedBy":1,"replyTime":"2019-03-01T07:48:01.000Z","msg":"我隻狗啲牙乾淨過你<br />\n我晚晚有同佢刷牙<br />\n你有無叫你主人幫你刷牙？<br />\n你買潔齒骨食咪得囉<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-01T08:36:09.000Z","msg":"係網上講野係唔同d既"},"citedBy":0,"replyTime":"2019-03-01T09:43:35.000Z","msg":"下 講真話 <br />\n你做咩蛀牙先 <br />\n如果你智慧齒蛀咗我同情你<br />\n好地地又會蛀牙嘅"},{"pid":"69a9883f1011583a213610458bec6b728f5322fc","tid":1040671,"uid":13503,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-01T09:59:26.000Z","msg":"樓主應該好口臭<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"d34db74a4563571619a35effd60f95588dd555f7","tid":1040671,"uid":152598,"like":0,"dislike":0,"score":0,"quote":{"pid":"69a9883f1011583a213610458bec6b728f5322fc","tid":1040671,"uid":13503,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-01T09:59:26.000Z","msg":"樓主應該好口臭<img src=\"/assets/faces/dog/scare.gi