s/normal/sosad.gif\" class=\"hkgmoji\" />)"},{"pid":"0906bebf1386b7f7aae9e0dafae59076d609e1ab","tid":1286051,"uid":261343,"like":0,"dislike":0,"score":0,"quote":{"pid":"5bff8103a06318781377a0720947c62f4dc48284","tid":1286051,"uid":25166,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-05T02:01:59.000Z","msg":"要釐清 句子本身一定有啲部分唔清楚<br />\n但聆聽呢個詞語 意思唔會係左耳入右耳出<br />\n<br />\n如果佢真係咁on9<br />\n咁佢就扭曲咗聆聽呢個字"},"citedBy":0,"replyTime":"2019-07-06T15:10:52.000Z","msg":"其實我真係覺得佢係扭曲左「聆聽」既意思<br />\n佢成日強調自己有聆聽市民既意見<br />\n但從佢講既說話同做既行為我真係睇唔出佢係有聆聽<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ef33211b9a2b8a02b168205c99c55b21497be8a2","tid":1286051,"uid":126973,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-06T15:35:09.000Z","msg":"李鵬：我好誠實<br />\n <br />\n某甲：李鵬成日講大話，所以佢講嘅「誠實」 係指講大話<br />\n某乙：李鵬講嘅「誠實」嘅意思同常人一樣，只不過佢事實上唔係誠實 <br />\n唔通佢嘅 intended meaning係指自己講大話咩, on9"},{"pid":"00f50103f35904faef9b78d05252287edb1e4fef","tid":1286051,"uid":126973,"like":0,"dislike":0,"score":0,"quote":{"pid":"c3554966504e253758f8293db8cb218f8caddad7","tid":1286051,"uid":173852,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6f492564d1f857861a4bd773a5c5cc4a0883a121","tid":1286051,"uid":126973,"like":7,"dislike":0,"score":7,"quote":{"pid":"1cdebd2e89ad19328e900940a14ea11ec2742f99","tid":1286051,"uid":126973,"like":2,"dislike":3,"score":-1,"citedBy":1,"replyTime":"2019-07-05T00:23:21.000Z","msg":"好無聊  搬下李天命d野出來  又當自己識思考"},"citedBy":2,"replyTime":"2019-07-05T00:26:14.000Z","msg":"真係識思考嘅人 唔會將林鄭呢句野 煞有介事咁「分析」<br />\n因為根本冇乜好分析 <br />\n佢意思好明顯 唔存在有乜歧義嘅可能性<br />\n正常人亦唔會認同佢呢句野"},"citedBy":1,"replyTime":"2019-07-06T08:35:44.000Z","msg":"好同意 有D野盲既都知 根本唔洗咩XXX思考 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n有心關心時事 不如讀多D社經政治野算啦<br />\n<br />\n(細細聲講句 格離精神分析post都有少少類似既問題<br />\n各種學科/常識既方法論都有「形而上預設」既，但好多野真係要辨證再辨證，批判又批判咩？唔洗黑格爾拉岡講我都知啦 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />)"},"citedBy":0,"replyTime":"2019-07-06T15:36:24.0