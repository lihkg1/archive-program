8ad3e2783db25b69bf2653f416adf","tid":2147763,"uid":1426,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-09T13:16:37.000Z","msg":"G"},{"pid":"0463c33646e22148edbd2243952afdd68deb3673","tid":2147763,"uid":293677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-09T13:20:39.000Z","msg":"<img src=\"/assets/faces/lm2/dead.gif\" class=\"hkgmoji\" />"},{"pid":"cc0a323ae10de6b5dd4b41496895fd313e08cd40","tid":2147763,"uid":179938,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-09T13:23:02.000Z","msg":"林手足幾時弒妻<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"275da4a413d6ea2f574fb85820fc30b9e35f508a","tid":2147763,"uid":236368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-09T13:23:40.000Z","msg":"唔含都已經頂唔到啦屌"},{"pid":"248adc05846f91d0fe4b29cce180a2264578e2c1","tid":2147763,"uid":213877,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-08-09T13:30:11.000Z","msg":"此回覆已被刪除"},{"pid":"ac792080829b64ee30207917fb0d939f259ec9ff","tid":2147763,"uid":224602,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-09T13:32:56.000Z","msg":"樓主伯母係咪西痕?"},{"pid":"1dd893d857aebd88de08bdd50049408893391f5b","tid":2147763,"uid":28913,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-09T13:38:27.000Z","msg":"屌你老母<br />\n嚇到瀨尿"},{"pid":"5eec068a8580197d91dd8a3a7dd396602ac8c175","tid":2147763,"uid":240975,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-09T14:24:03.000Z","msg":"娥非常緩慢的脫下衣服，而且你可以看到習近平硬了。習近平用手指在林鄭月娥的胸膛留下痕跡，然後拿出了他已經硬了的陰莖<br />\n「慢慢的握住他，」習近平輕吟...<br />\n<br />\n月娥開始上下輕吻近平的陰莖<br />\n「我要...我而家想要！」，習近平呼吸急促，月娥開始含他的陰莖，習近平的手帶著月娥的頭上下有節奏的動著，林鄭月娥感到不舒服但沒有停下，習近平漸漸感到愈來愈興奮，沒辦法控制他自己了。<br />\n<br />\n林鄭月娥手也沒停下來，開始自慰，習近平滿意地笑了，他喜歡看到月娥自得其樂的樣子。<br />\n<br />\n林鄭月娥開始感到要高潮，習近平也快要高潮了，雄厚的叫聲起伏，他沒辦法再忍了<br />\n<br />\n「我快要...我快要...」，月娥把習近平的陰莖從嘴巴𥚃抽出來，然後開始舔，近平的背微弓起來，呻吟林鄭月娥的名字。<br />\n<br />\n林鄭月娥可以感覺到習近平堅挺的陰莖在臉上射了，看著他的戀人高潮了，並品嘗他鹹鹹的，高潮帶來的精液，噴在他的手上，還有地板上。<br />\n<br />\n近平躺回去，閉眼氣喘吁吁，林鄭躺在近平黏膩的身體上，開始輕輕的拍打他雙唇。<br />\n<br />\n他們互相依靠，熱情如火的黏在一起，燈火搖曳著欲求不滿的兩個影子，再次依循著獸欲，無眠地過著這一夜晚。"},{"pid":"04b51dd0f010f9d595a46f2c4020864879fef3f1","tid":2147763,"uid":19552,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-08-09T14:26:50.000Z","msg":"g"},{"pid":"4f661ad354735a285d5ed2f9533c0a59379f4c72","tid":2147763,"uid":1734,"like":0,"dislike":1,"score":-1,"quote":{"pid":"04b51dd0f010f9d595a46f2c4020864879fef3f1","tid":2147763,"uid":19552,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-08-09T14:26:50.000Z","msg":"g"},"citedBy":0,"replyTime":"2020-08-09T14:27:13.000Z","msg":"G"}]}