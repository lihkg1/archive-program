ota出post<br />\n<a href=\"https://lih.kg/1737677\" data-auto-link target=\"_blank\">https://lih.kg/1737677</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"04da6a2d209c959eb1c8b2d74aaa6b40b5c2c0f4","tid":1738323,"uid":319824,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-19T09:10:00.000Z","msg":"冇問題<br />\n最簡單 全民豬嘴眼罩先<br />\n射左tg唔好再即跑走"},{"pid":"d0720c9c9ef5a6ad3200dab351945317d7b2c956","tid":1738323,"uid":182624,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T09:11:30.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"251f01b1121a091d797d43a2c576e06da8969057","tid":1738323,"uid":294,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T09:13:37.000Z","msg":"我就係要呢d"},{"pid":"35e2e1520854ba2da462d7707737e99886e62d52","tid":1738323,"uid":93324,"like":0,"dislike":0,"score":0,"quote":{"pid":"04da6a2d209c959eb1c8b2d74aaa6b40b5c2c0f4","tid":1738323,"uid":319824,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-19T09:10:00.000Z","msg":"冇問題<br />\n最簡單 全民豬嘴眼罩先<br />\n射左tg唔好再即跑走"},"citedBy":1,"replyTime":"2019-11-19T09:15:39.000Z","msg":"思路正確<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"3b7b82218e0e6555923eeb8b5dab6d2585e64e1a","tid":1738323,"uid":93324,"like":0,"dislike":0,"score":0,"quote":{"pid":"68ba27a6e2a2d3cc30ca9446c51db6e20c44763f","tid":1738323,"uid":273991,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-19T08:52:51.000Z","msg":"和理非！進化！　<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-19T09:17:54.000Z","msg":"啱呀<br />\n千祈唔好再互相指責、分化<br />\n咁就中左popo嘅滲透戰術"},{"pid":"364753033e24c81bd1f67c64e0e8c94b889301e1","tid":1738323,"uid":93324,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T09:32:21.000Z"