.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"192e51e0c1377cc950965302372c04c1e574a011","tid":1312630,"uid":36470,"like":0,"dislike":0,"score":0,"quote":{"pid":"11fab3d169a33b590f9f0db18aa66bf65b9650d2","tid":1312630,"uid":170426,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-13T14:38:48.000Z","msg":"快啲簽<br />\n叫多啲人簽！！！<br />\n<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-13T14:40:36.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />yes"},{"pid":"d02903953a4b9b7a04f715f2180f3e9c42ab1641","tid":1312630,"uid":80965,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T14:42:07.000Z","msg":"市民倒地後舉手投降仍然被警察朝面噴胡椒噴霧<br />\n<a href=\"https://www.facebook.com/303668637132303/posts/522889241876907?s=100002216289676&amp;v=e&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F303668637132303%2Fposts%2F522889241876907%3Fs%3D100002216289676%26v%3De%26sfns%3Dmo&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=67ecf6a3\" target=\"_blank\">https://www.facebook.com/303668637132303/posts/522889241876907?s=100002216289676&amp;v=e&amp;sfns=mo</a><br />\n<br />\n用警棍不斷對沒有反抗嘅瘦弱的少女作出擊打<br />\n<a href=\"https://www.facebook.com/169166456593130/posts/1257595487750216?s=100002216289676&amp;v=e&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F169166456593130%2Fposts%2F1257595487750216%3Fs%3D100002216289676%26v%3De%26sfns%3Dmo&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=b732060b\" target=\"_blank\">https://www.facebook.com/169166456593130/posts/1257595487750216?s=100002216289676&amp;v=e&amp;sfns=mo</a><br />\n<br />\n記者被警察打傷並拿相機<br />\n<a href=\"https://www.facebook.com/2787894407949833/posts/2803164013089539?s=100002216289676&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F2787894407949833%2Fposts%2F2803164013089539%3Fs%3D100002216289676%26sfns%3Dmo&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=89298233\" target=\"_blank\">https://www.facebook.com/2787894407949833/posts/2803164013089539?s=100002216289676&amp;sfns=mo</a><br />\n<br />\n遊行人士被打到重傷 滿地鮮血<br />\n<a href=\"https://www.facebook.com/623064611149143/posts/2141091966013059?s=100002216289676&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F623064611149143%2Fposts%2F2141091966013059%3Fs%3D100002216289676%26sfns%3Dmo&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=de6f8ecf\" target=\"_blank\">https://www.facebook.com/623064611149143/posts/2141091966013059?s=100002216289676&amp;sfns=mo</a><br />\n<br />\n被警方迫至後退嘅遊行人士被後方警方用警棍打到頭部流血<br />\n<a href=\"https://www.facebook.com/2787894407949833/posts/2802948696444404?s=100002216289676&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F2787894407949833%2Fposts%2F2802948696444404%3Fs%3D100002216289676%26sfns%3Dmo&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=ed43b459\" target=\"_blank\">https://www.facebook.com/2787894407949833/posts/2802948696444404?s=100002216289676&amp;sfns=mo</a><br />\n<br />\n3個警員壓住一個遊行人士 傷者身體抽搐 嘴角流血<br />\n<a href=\"https://www.facebook.com/2787894407949833/posts/2803071113098829?s=100002216289676&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F2787894407949833%2Fposts%2F2803071113098829%3Fs%3D100002216289676%26sfns%3Dmo&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=067885bb\" target=\"_blank\">https://www.facebook.com/2787894407949833/posts/2803071113098829?s=100002216289676&amp;sfns=mo</a><br />\n<br />\n一班警員突然衝落行人天橋在沒有警告下出椒和警棍狂毆示威者<br />\n<a href=\"https://www.facebook.com/330920327037381/posts/2136037743192288?s=100002216289676&amp;v=e&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F330920327037381%2Fposts%2F2136037743192288%3Fs%3D100002216289676%26v%3De%26sfns%3Dmo&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=91d93f8b\" target=\"_blank\">https://www.facebook.com/330920327037381/posts/2136037743192288?s=100002216289676&amp;v=e&amp;sfns=mo</a><br />\n<br />\n警方用武力拘捕示威者，並多次以「差人做嘢」為理由，拒絕記者拍攝。<br />\n<a href=\"https://www.facebook.com/207097505984138/posts/3074478372579356?s=100002216289676&amp;v=e&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F207097505984138%2Fposts%2F3074478372579356%3Fs%3D100002216289676%26v%3De%26sfns%3Dmo&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=e875f491\" target=\"_blank\">https://www.facebook.com/207097505984138/posts/3074478372579356?s=100002216289676&amp;v=e&amp;sfns=mo</a><br />\n<br />\n追捕16歲示威者令佢差啲跌落天橋 半身懸吊空中<br />\n<a href=\"https://www.facebook.com/303668637132303/posts/522914551874376?s=100002216289676&amp;v=e&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F303668637132303%2Fposts%2F522914551874376%3Fs%3D100002216289676%26v%3De%26sfns%3Dmo&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=4fb98908\" target=\"_blank\">https://www.facebook.com/303668637132303/posts/522914551874376?s=100002216289676&amp;v=e&amp;sfns=mo</a><br />\n<br />\n議員勸警察冷靜 一野比人用警棍扑頭<br />\n<a href=\"https://www.facebook.com/200954406608272/posts/2311878618849163?s=100002216289676&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F200954406608272%2Fposts%2F2311878618849163%3Fs%3D100002216289676%26sfns%3Dmo&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=1fb01fd3\" target=\"_blank\">https://www.facebook.com/200954406608272/posts/2311878618849163?s=100002216289676&amp;sfns=mo</a><br />\n<br />\n女警突然對途人施放胡椒噴霧 但當時嘅情況係連對峙都稱唔上<br />\n<br />\n\t<br />\n\t<a href=\"https://www.facebook.com/pighead.sun/videos/10157040385186391/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fpighead.sun%2Fvideos%2F10157040385186391%2F&d=QRr32DkYW87Xu5pQ%2FNKRK1T2VSzVBU3ss%2BeERvjOeOk%3D&h=88a94a45\" target=\"_blank\">https://www.facebook.com/pighead.sun/videos/10157040385186391/</a>"},{"pid":"27626fbb281e5c9c1438b27e32f747bb8da7665d","tid":1312630,"uid":36470,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T14:43:02.000Z","msg":"快幫手簽"},{"pid":"187f92590a493e51236a845399857f8500216f08","tid":1312630,"uid":36470,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T14:43:30.000Z","msg":"15 分鐘 2000 個啦"},{"pid":"563920deda2adc242610bfd394f44cb1c509a60f","tid":1312630,"uid":88675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T14:43:47.000Z","msg":"推"},{"pid":"4eb1ade905510e3d64e5abe31f0f3963b8d4ed7f","tid":1312630,"uid":36470,"like":0,"dislike":0,"score":0,"quote":{"pid":"0f6b05a8312bda558f97222135577a6902a23358","tid":1312630,"uid":108337,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-13T14:32:12.000Z","msg":"快簽<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-13T14:43:55.000Z","msg":"14424 left <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3d549275ef1a5152883aa29b057f9fd2b9db6899","tid":1312630,"uid":271857,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-13T14:47:03.000Z","msg":"打名email &gt; confirm email，搞惦。"},{"pid":"e3a21dcd67833e3f8ef8caf2bbaee79f07cdc685","tid":1312630,"uid":240968,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T14:47:13.000Z","msg":"推推推"},{"pid":"4f9367a0a737ec9321ca281f1c251b96fde33a8b","tid":1312630,"uid":36470,"like":0,"dislike":0,"score":0,"quote":{"pid":"3d549275ef1a5152883aa29b057f9fd2b9db6899","tid":1312630,"uid":271