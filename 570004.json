atch?v=ftZ0kha2RrQ</a><br />\n太正<br />\n中國狗叫&quot;WANG&quot; <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n黃明志從來冇另人失望<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"6766f79c8aa790be91e3dbc92c41fa2318d75872","tid":570004,"uid":119778,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-24T09:53:10.000Z","msg":"台灣d綜藝節目爆料過佢好撚臭串"},{"pid":"d1a93f1ec117ce21167d24152f69cb44b64e34b2","tid":570004,"uid":139676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-24T09:58:12.000Z","msg":"做自己"},{"pid":"20ce945d3b9cea52e43864f12bd998af264822cb","tid":570004,"uid":3405,"like":0,"dislike":0,"score":0,"quote":{"pid":"6766f79c8aa790be91e3dbc92c41fa2318d75872","tid":570004,"uid":119778,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-24T09:53:10.000Z","msg":"台灣d綜藝節目爆料過佢好撚臭串"},"citedBy":0,"replyTime":"2018-02-24T09:58:29.000Z","msg":"LINK?"},{"pid":"e14d4f33bb5f92ea9edcd8278c5b20c86524d0fc","tid":570004,"uid":90457,"like":0,"dislike":0,"score":0,"quote":{"pid":"033a879ab92002e0cf78095d472d138ad8d1db79","tid":570004,"uid":121069,"like":0,"dislike":1,"score":-1,"quote":{"pid":"cfbf35107955d88061815f7bc5e5cceea91d22f7","tid":570004,"uid":55982,"like":0,"dislike":0,"score":0,"quote":{"pid":"bb56a64605c33fca2d3ffde6c339304b81243cee","tid":570004,"uid":157063,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-24T07:05:28.000Z","msg":"移民啦<br />\n留係馬來西亞托咩"},"citedBy":2,"replyTime":"2018-02-24T07:09:47.000Z","msg":"出去外國攞獎佢都要拎住馬國國旗<br />\n佢應該唔會想走<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-02-24T09:04:31.000Z","msg":"馬國大愛左膠代表<br />\n愛馬來西亞但不愛大馬政府<br />\n仲作過愛國歌<br />\n膠到以為換左政府就唔會針對佢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-24T10:07:42.000Z","msg":"左膠=愛國<br />\n<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"630e1be03b8e37ce77766754b5adde7a9baa8160","