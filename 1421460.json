assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />原來係咁"},{"pid":"bed3e921f542ad80e575c28bf547435850c012f2","tid":1421460,"uid":123738,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-06T08:17:18.000Z","msg":"關撚你事咩支那狗<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"97a50f1f4328ad9faa00e85d5c3ebbf8ccddda34","tid":1421460,"uid":293698,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2019-08-06T08:17:59.000Z","msg":"此回覆已被刪除"},{"pid":"8b3b943e6233e06b3141ce4275d3b5c3081e5a31","tid":1421460,"uid":269202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:18:54.000Z","msg":"趕走元朗黑社會<br />\n<br />\n趕走屯門尖咁淫蕩舞<br />\n<br />\n請繼續"},{"pid":"7e217c958d132c839993af2194734c3e06aef673","tid":1421460,"uid":33307,"like":0,"dislike":0,"score":0,"quote":{"pid":"bed3e921f542ad80e575c28bf547435850c012f2","tid":1421460,"uid":123738,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-06T08:17:18.000Z","msg":"關撚你事咩支那狗<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-06T08:22:29.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"8eef252ec8c183e15df09a08a14b8d8b967dbfa4","tid":1421460,"uid":61018,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:22:34.000Z","msg":"自誇大國人嘅政府連中文都唔識?"},{"pid":"e93c70bd7e0df00fcf3437dfceab7c0c96da9c83","tid":1421460,"uid":266924,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-06T08:23:29.000Z","msg":"自1997年起，香港受胡虜入侵<br />\n香港本土文化盡失，市容盡毀<br />\n光復香港，亦即清新本土運動，拒絕胡虜文化<br />\n胡虜人自認中國人，行為儀態背祖忘宗，一反常態<br />\n香港中西匯聚，秉承華朝文化，沿用英國制度<br />\n有利於世界，人文之情濃厚<br />\n反之胡虜支那人因透支未來，一時富貴便目中無人<br />\n貪小便宜之狗性侵害香港繁榮穩定，並試圖利用港元與美元之關係苟延殘喘，可惡之極<br />\n香港普羅大眾皆深明胡虜害人，立志光復香港，重現昔日太平之境象"},{"pid":"80a172c0e2669785ab7ac3b7c8eeb12719d998aa","tid":1421460,"uid":242998,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-06T08:23:43.000Z","msg":"完全自治"},{"pid":"76cfe9daa794863b9e690ab6fd3b076dc3347165","tid":1421460,"uid":44646,"like":0,"dislike":0,"score":0,"quote":{"pid":"8449c98061c2c1b54b14d0f97f77b5a10bb593fc","tid":1421460,"uid":33307,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-06T08:08:49.000Z","msg":"求連登仔解答<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-06T08:24:54.000Z","msg":"政治正確版：<br />\n<br />\n光復2014.8.31之前既雙普選安排"},{"pid":"a3c2fee50132eb44efcd4375894b6a03ffe008a2","tid":1421460,"uid":260317,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:25:11.000Z","msg":"但「光復香港」我們都知道要「光復」到甚麼時代，不就是人權有保障、市民有法律權利、警察是保護市民而不是向自由表達意見的市民施暴的香港嗎？打出港英旗也好，打出美國旗也罷，重點都不是呼喚英國美國來統治香港，而是表示香港要回到英美體制中對自由、對人權的保護。<br />\n<br />\n@李怡"},{"pid":"187700bba7bfc649b71aa6199a2f9189df0e7e4c","tid":1421460,"uid":82929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T08:28:11.000Z","msg":"光復廣東話<br />\n光復繁體字<br />\n光復icac <br />\n光復舊立法局<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f7abbce179ca02c9a88d181dbcdfe55f2367318f","tid":1421460,"uid":4917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T10:36:15.000Z","msg":"我都問返佢，你地要解放甚麼？解放去哪？"},{"pid":"aae1a5a9c5c1e647ab51302040004e874cf62e9d","tid":1421460,"uid":297595,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T10:53:57.000Z","msg":"光復 呢個字可以好多意思<br />\n個人認為同 make Hong Kong great again差唔多<br />\n因為依家香港已經唔撚似樣 污煙障氣<br />\n<br />\n要香港變返好，政府必須肯聽民意，睇民情，顧民生<br />\n既然依家呢個垃圾政府乜都唔做<br />\n連派4000蚊都要攪成年，光復香港只可以靠自己"},{"pid":"d1e72458ba4a97a16796fe73d04443fa1e5539af","tid":1421460,"uid":33307,"like":0,"dislike":0,"score":0,"quote":{"pid":"80a172c0e2669785ab7ac3b7c8eeb12719d998aa","tid":1421460,"uid":242998,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-06T08:23:43.000Z","msg":"完全自治"},"citedBy":0,"replyTime":"2019-08-06T13:33:00.000Z","msg":"搵人答佢地"}]}