3_472833bcdab950793d2e5d25c3429706.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F05%2F132243_472833bcdab950793d2e5d25c3429706.jpg&h=b6fd1ae2&s={SIZE}\" /><br />\n<br />\n2018年8月5日 <br />\n<br />\n昨天的大阪live非常感謝！<br />\n<br />\n來了的各位<br />\n沒有因為炎熱身體不良吧？(＞人＜;)<br />\n<br />\n今天來的各位也是身體第一<br />\n來的時候請註意(＞人＜;)<br />\n<br />\n順便一提與田元氣滿滿請放心！<br />\n<br />\n今天也要加油！<br />\n<br />\n剛剛彩排了！<br />\n氣溫竟然有41度！！(　ﾟдﾟ)"},{"pid":"a811723a517f8ba8fa5c5c3d15694ed5966da43c","tid":764463,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-05T09:49:39.000Z","msg":"<img src=\"http://wx3.sinaimg.cn/large/005E838yly1ftyupg41h2j30de0hs76q.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwx3.sinaimg.cn%2Flarge%2F005E838yly1ftyupg41h2j30de0hs76q.jpg&h=66faf937&s={SIZE}\" /><br />\n<br />\n2018年8月5日 <br />\n<br />\n加油！<br />\n<br />\n沖鴨！ ​​​"},{"pid":"dcc75efaaf0ff7bdd71ccabcf76f3f652199fbb6","tid":764463,"uid":44730,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-05T13:52:24.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/05/214954_6bf4b05148b6ac33b2457e2323d67008.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F05%2F214954_6bf4b05148b6ac33b2457e2323d67008.jpg&h=957a9b4d&s={SIZE}\" /><br />\n<br />\n2018.08.05<br />\n大阪公演第2天結束啦ー！！！<br />\n<br />\n特別的開心♪<br />\n<br />\n曲中、misa前輩和若月桑都沖我笑了<br />\n從昨天開始就開心的不得了！<br />\n<br />\n很幸福特別的happy[愛心][愛心]！<br />\n<br />\n与田最近都有在扮鬼樣"},{"pid":"91ca3916635d67708b4a47a3523fcd577e40fbcb","tid":764463,"uid":7551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-05T16:39:45.000Z","msg":"見到小百柒開始靚女返 <br />\n老懷安慰<br />\n🚬🚬"},{"pid":"89c6dd1bcca0a6f60548345e769a7da8d06073f9","tid":764463,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-05T17:06:58.000Z","msg":"<blockquote>見到小百柒開始靚女返 <br />\n老懷安慰<br />\n🚬🚬</blockquote><br />\n過份啦你，名都改埋<img src=\"https://img.eservice-hk.net/upload/2018/01/24/025919_097483ffec7dc8a1f0fb6d9467d2fa11.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F24%2F025919_097483ffec7dc8a1f0fb6d9467d2fa11.png&h=addbc80d&s={SIZE}\" />"},{"pid":"a0deb9c59795888cda7f023932b8eb64efc39589","tid":764463,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-06T12:37:24.000Z","msg":"<img src=\"http://wx4.sinaimg.cn/large/005E838yly1ftzz6bhr6gj30jg0cy3zz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwx4.sinaimg.cn%2Flarge%2F005E838yly1ftzz6bhr6gj30jg0cy3zz.jpg&h=02b9d5ff&s={SIZE}\" /><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/12/22/023112_e9fcefa24e589dca0ee88a946b33a1ee.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F22%2F023112_e9fcefa24e589dca0ee88a946b33a1ee.png&h=f99a10a4&s={SIZE}\" />"},{"pid":"b64f6c0cd1313f3c6c8cfe27e63d51f2c93fd7d5","tid":764463,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-06T12:41:54.000Z","msg":"<img src=\"http://wx2.sinaimg.cn/large/6cb6ff5bly1ftzzxy91hij20dc0hs77t.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwx2.sinaimg.cn%2Flarge%2F6cb6ff5bly1ftzzxy91hij20dc0hs77t.jpg&h=af510e30&s={SIZE}\" /><br />\n<br />\n2018年8月6日 <br />\n<br />\n胳膊酸痛啊<br />\n<br />\n瀏海被那個出冷風的機器（不知道名字叫什麽）吹亂了 現在超不開心！<br />\n雖然這麽說著還是對著鏡頭笑了的桃子和<br />\n不管何時對任何事都很努力的葉月。<br />\n嗯&mdash;果然這個衣服超級可愛！<br />\n<br />\n昨天回程的路上一直在我旁邊的像天使一樣的与田。<br />\n久違的傾了很久<br />\n真的是讓我覺得与田上輩子是不是真的是天使。<br />\n就是那麽的可愛。做什麽都可愛。<br />\n不可思議的人ー"},{"pid":"14bd1f8dcc162a447ff740a28e8e9b256b1fb422","tid":764463,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-06T12:44:35.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/06/204359_781b89795664e5b0058058a2fb970187.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F06%2F204359_781b89795664e5b0058058a2fb970187.jpg&h=ef60776c&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2017/12/22/023112_e9fcefa24e589dca0ee88a946b33a1ee.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F22%2F023112_e9fcefa24e589dca0ee88a946b33a1ee.png&h=f99a10a4&s={SIZE}\" />"},{"pid":"3e7fbdad75920860cfdac1bef568c431bf38e5bb","tid":764463,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-06T12:51:09.000Z","msg":"<img src=\"http://wx3.sinaimg.cn/large/6f428e50gy1fu01bueyp9j211v1kwgyn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwx3.sinaimg.cn%2Flarge%2F6f428e50gy1fu01bueyp9j211v1kwgyn.jpg&h=9bc8ba3d&s={SIZE}\" /><br />\n<br />\n2018年8月6日 <br />\n<br />\n今天唱了主題曲<br />\n<br />\n參加了電影七大罪的發佈會～<br />\n<br />\n現在乃團正和出演伊麗莎白的梅醬還有美月一起(*&acute;-`)<br />\n<br />\n晚上與有野桑、濱口桑<br />\n久野美咲桑還有梶裕貴桑一起拍了照片！<br />\n<br />\n因為今天是劇中角色霍克的生日所以擺了這個姿勢(^-^)/<br />\n<br />\n豬生快！<br />\n<br />\n我果然、好喜歡空扉<br />\n還想看一次七大罪吶<br />\n<br />\n8月18日會公佈！<br />\n<br />\n另外梅醬在劇裏出演伊麗莎白，舞台劇現在正在演出期間！<br />\n<br />\n這次很可惜沒能去參加&hellip;<br />\n<br />\n好想好想去啊（ ; ; ）<br />\n<br />\n去看過的各位、請在握手會和blog的評論裡留下大家的感想吧(ノ_＜)<br />\n<br />\n我會轉達給梅醬的！！"},{"pid":"3682dd20914f56c935b23b2b8a0aaa626b8232ee","tid":764463,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-06T15:28:09.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/06/232726_605933467636ad950de58067a2eae452.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F06%2F232726_605933467636ad950de58067a2eae452.jpg&h=460097fc&s={SIZE}\" /><br />\n<br />\n嗯公主嗯<img src=\"https://img.eservice-hk.net/upload/2017/12/22/023112_e9fcefa24e589dca0ee88a946b33a1ee.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F22%2F023112_e9fcefa