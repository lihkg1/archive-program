019-07-12T21:53:42.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e60568d8a853f1a0470b0b0d6313be1c4c1faaf1","tid":1310721,"uid":243366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T21:55:11.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f5a94e629c1fc8952d275fc301579adb1c0543b3","tid":1310721,"uid":243366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T22:07:20.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}