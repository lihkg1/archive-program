rc=\"/assets/faces/lny/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/clown.gif\" class=\"hkgmoji\" />"},{"pid":"809d19a1ffdfb40a86061abc2a0c65ea19602e61","tid":1854734,"uid":199957,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-31T16:53:33.000Z","msg":"你老母"},{"pid":"438fc95d68b64d555127d2ba135c990dff10266b","tid":1854734,"uid":152589,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-31T16:56:57.000Z","msg":"歷史將再一次重複"},{"pid":"cb9209098f1ba3b694cedaddd74f97b3a6c0ac2d","tid":1854734,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-01T01:10:41.000Z","msg":"<img src=\"/assets/faces/lny/smile2.gif\" class=\"hkgmoji\" />"},{"pid":"871fbb4f65bb27da157d4611a54d3256e14da2b2","tid":1854734,"uid":6435,"like":0,"dislike":0,"score":0,"quote":{"pid":"abd0fb807e5ae137623a2ad9055ac3500b74878b","tid":1854734,"uid":2054,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-01-31T16:10:37.000Z","msg":"中國滲透國際組織害人終害己<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-01T01:50:27.000Z","msg":"歐美縱容中國滲透先啱"},{"pid":"2c7fb36c03a05fc16b4ee534647abf6264f7cac1","tid":1854734,"uid":292710,"like":0,"dislike":0,"score":0,"quote":{"pid":"871fbb4f65bb27da157d4611a54d3256e14da2b2","tid":1854734,"uid":6435,"like":0,"dislike":0,"score":0,"quote":{"pid":"abd0fb807e5ae137623a2ad9055ac3500b74878b","tid":1854734,"uid":2054,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-01-31T16:10:37.000Z","msg":"中國滲透國際組織害人終害己<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-01T01:50:27.000Z","msg":"歐美縱容中國滲透先啱"},"citedBy":0,"replyTime":"2020-02-01T01:53:19.000Z","msg":"<a href=\"https://petitions.whitehouse.gov/petition/hong-kong-universal-suffrage-plan\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fhong-kong-universal-suffrage-plan&d=6xH2G4nGFyEJ53rX7DpuMf3PLjr3aI%2Bxco%2FW%2FCjCBac%3D&h=5c940d6d\" data-auto-link target=\"_blank\">https://petitions.whitehouse.gov/petition/hong-kong-universal-suffrage-plan</a><br />\n3個鐘快簽"},{"pid":"0f325ca8d9c01254fdeb9e5b0f4ffccd837d6332","tid":1854734,"uid":2054,"like":0,"dislike":0,"score":0,"quote":{"pid":"438fc95d68b64d555127d2ba135c990dff10266b","tid":1854734,"uid":152589,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-31T16:56:57.000Z","msg":"歷史將再一次重複"},"citedBy":0,"replyTime":"2020-02-01T11:38:12.000Z","msg":"十四年前種個因<br />\n今日係武漢個果"},{"pid":"d06974ba63a3557248f37a46906bf3ed9b38dda3","tid":1854734,"uid":134774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-01T11:43:47.000Z","msg":"uwants 香討d留言 wtf<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"901afcb1aed0d22b87e446a4c0a2626aaf10569b","tid":1854734,"uid":63543,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-01T11:46:23.000Z","msg":"binc<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"efa73409437f6bdc385f323ea4a31972c0fb4985","tid":1854734,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-01T11:56:04.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"}]}