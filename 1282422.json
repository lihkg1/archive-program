gel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-03T16:23:00.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"872c13a0b8d84fa29dc8c4fdfa5ad443c423f70d","tid":1282422,"uid":105924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T16:25:40.000Z","msg":"我無野講 我唔解鎖 我搵律師 唔好凶我 我投訴你 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"d031862b6f175d6504a3388647c69df75d045e37","tid":1282422,"uid":11290,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-03T16:28:04.000Z","msg":"睇到眼濕濕<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n香港人唔係大家所諗嘅咁冷漠<br />\n只要有啲咩事 我地又會再聚埋一齊架喇<br />\n點都好 用自己方式一齊頂住 加油呀<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"0f55872e3bfa8460269d612206b1964e1cc066ab","tid":1282422,"uid":180960,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T16:29:20.000Z","msg":"我無嘢講"},{"pid":"4e6e22454cae5e0c59137265aba7104f8358e50b","tid":1282422,"uid":120675,"like":0,"dislike":0,"score":0,"quote":{"pid":"5de10b549ca6287219d101cb5437538528c024c9","tid":1282422,"uid":180960,"like":1,"dislike":0,"score":1,"quote":{"pid":"6725731f4c1ab9c4b82503f43fdc1237d3ffd792","tid":1282422,"uid":120675,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-07-03T16:20:06.000Z","msg":"我無嘢講<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-03T16:23:00.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-03T16:29:40.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}