.eservice-hk.net%2Fupload%2F2018%2F08%2F18%2F121647_fac422d2c54d5e0c8c90da505153a2d4.png&h=2878acf4&s={SIZE}\" /><br />\n<br />\n真倉 淨係做GBPUSD <br />\nUS$423 起家 一個月唔夠既result<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/18/121648_f8cf59904dacace0bdae47397a5652bf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F18%2F121648_f8cf59904dacace0bdae47397a5652bf.png&h=6913907e&s={SIZE}\" />"},{"pid":"cf379791f60dee6bd4592263129d1164469fb215","tid":783572,"uid":138286,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-18T04:27:53.000Z","msg":"lm<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"01b6527aae6b140e7fa8b39fc4557515e8f28c0d","tid":783572,"uid":138286,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-18T04:45:57.000Z","msg":"自己都有玩開EA, 但係唔識自己寫，想問Ching,一開始點學寫？<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n同埋而家玩開人地果D現成EA, 都覺得夠, 但係因為唔知佢用咩原理落盤,所以都冇咩安全感, Ching 點睇？<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},{"pid":"3e85190736edeb175576fdc886ceda6b3113b386","tid":783572,"uid":36289,"like":0,"dislike":0,"score":0,"quote":{"pid":"4088dce79216322186a490f02cc8955a72fe1db2","tid":783572,"uid":97882,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e185af50948fbfcf6b86cc954f88d2f3c05e0d58","tid":783572,"uid":36289,"like":0,"dislike":0,"score":0,"quote":{"pid":"382acf0b7072e0d4f6ffa53c491a02301c731db9","tid":783572,"uid":97882,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-17T20:30:10.000Z","msg":"leverage幾大？"},"citedBy":1,"replyTime":"2018-08-17T21:52:17.000Z","msg":"第2張圖有<br />\n1:500<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-18T01:05:08.000Z","msg":"巴打用邊間Broker<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-18T08:10:24.000Z","msg":"第2張圖有.....icmarket"},{"pid":"d258b5a86fdd56ce397ed631df3ff0b3e179338e","tid":783572,"uid":36289,"like":0,"dislike":0,"score":0,"quote":{"pid":"67c6439706717918a8d2d9646b531644bf3fd806","tid":783572,"uid":132524,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-18T02:35:54.000Z","msg":"但係點定輸幾多先再加倉？<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-18T08:11:19.000Z","msg":"冇定,睇indicator短時間到底就加"},{"pid":"a4f0e7c9994af912e2a29347b677e27e9aa67b88","tid":783572,"uid":132524,"like":0,"dislike":0,"score":0,"quote":{"pid":"d258b5a86fdd56ce397ed631df3ff0b3e179338e","tid":783572,"uid":36289,"like":0,"dislike":0,"score":0,"quote":{"pid":"67c6439706717918a8d2d9646b531644bf3fd806","tid":783572,"uid":132524,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-18T02:35:54.000Z","msg":"但係點定輸幾多先再加倉？<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-18T08:11:19.000Z","msg":"冇定,睇indicator短時間到底就加"},"citedBy":0,"replyTime":"2018-08-18T08:13:07.000Z","msg":"定係其實馬丁係比個strategy加倉 <br />\n如果strategy本身高win rate 基本上加倉 變相幫你滾大個錢？<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"ac25eb14986f158ba47b9ad0817dce65fe581a19","tid":783572,"uid":36289,"like":0,"dislike":0,"score":0,"quote":{"pid":"01b6527aae6b140e7fa8b39fc4557515e8f28c0d","tid":783572,"uid":138286,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-18T04:45:57.000Z","msg":"自己都有玩開EA, 但係唔識自己寫，想問Ching,一開始點學寫？<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n同埋而家玩開人地果D現成EA, 都覺得夠, 但係因為唔知佢用咩原理落盤,所以都冇咩安全感, Ching 點睇？<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-18T08:17:07.000Z","msg":"我本身it狗,一開始就識答你唔到...<br />\n但可以網上free果d ea code黎睇,上網搵下d code做緊咩,當年做it奇都係咁<br />\n<br />\n而上網買果d我都買唔少,主要用黎參考人地炒法,大約有3 4成可以估得返個炒法出黎<br />\n馬丁果d最易睇,一定睇到....但我都唔會用真錢<br />\n一來%少,二來真係唔夠膽<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"0099e55251a197983a6cab5d7ad131a0fae634ac","tid":783572,"uid":163916,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-18T09:51:13.000Z","msg":"玩直欖?<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"b75e3aabab2e971412abbe96922081a080c224b4","tid":783572,"uid":36289,"like":0,"dislike":0,"score":0,"quote":{"pid":"0099e55251a197983a6cab5d7ad131a0fae634ac","tid":783572,"uid":163916,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-18T09:51:13.000Z","msg":"玩直欖?<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-18T11:01:49.000Z","msg":"可以咁講<br />\n巴打賭徒黎？<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"}]}