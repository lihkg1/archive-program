"quote":{"pid":"fc8e61fc41ab57f929fe7f93b2d77066e2c6823f","tid":1374724,"uid":134437,"like":2,"dislike":3,"score":-1,"quote":{"pid":"64c21d1373f61d2b4e717ee7eab1ddd692539aed","tid":1374724,"uid":226155,"like":6,"dislike":1,"score":5,"quote":{"pid":"18f4bb97607ac2ef539cd717e6a486638a981887","tid":1374724,"uid":134437,"like":1,"dislike":5,"score":-4,"citedBy":1,"replyTime":"2019-07-28T05:56:23.000Z","msg":"they have the record of everything you said"},"citedBy":1,"replyTime":"2019-07-28T06:27:14.000Z","msg":"Google就係<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-28T06:32:34.000Z","msg":"咪一鳩樣.jpeg"},"citedBy":1,"replyTime":"2019-07-28T06:35:17.000Z","msg":"完全唔一樣，之前google爆果單有比較過，apple 係會cut到認唔到邊個user先review,google 唔會,有講地址有講名之類全部都直接上去review"},{"pid":"a742830aa8f4bf41f6c9b48b39e8fe7071bc163f","tid":1374724,"uid":3296,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-07-28T06:39:53.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />有咩方法熄左siri佢"},{"pid":"e5071313e802c5f0a58eb5e2e9a9985fe78380d7","tid":1374724,"uid":103759,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2019-07-28T07:27:47.000Z","msg":"Apple係會錄音 但唔會賣你啲資俾廣告商 google會 google係一間做廣告嘅公司<br />\nSiri 可以俾用家閂 但google 唔會可以 <br />\n<br />\n咁嘅情況 你自己揀"},{"pid":"40952e718b3f0ebb04ac960cf88cae8d09a00506","tid":1374724,"uid":103759,"like":1,"dislike":0,"score":1,"quote":{"pid":"a742830aa8f4bf41f6c9b48b39e8fe7071bc163f","tid":1374724,"uid":3296,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-07-28T06:39:53.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />有咩方法熄左siri佢"},"citedBy":0,"replyTime":"2019-07-28T07:27:58.000Z","msg":"去setting 閂"},{"pid":"55ce071deda7656b6acf8c89bdceaca290118b9e","tid":1374724,"uid":291751,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-28T07:48:24.000Z","msg":"此回覆已被刪除"},{"pid":"356cedb190182f8c55e3bd6969de7623c87c2f3e","tid":1374724,"uid":134437,"like":0,"dislike":3,"score":-3,"quote":{"pid":"55ce071deda7656b6acf8c89bdceaca290118b9e","tid":1374724,"uid":291751,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-28T07:48:24.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-07-28T08:38:02.000Z","msg":"<a href=\"https://youtu.be/FZ23kosLFec\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FFZ23kosLFec&d=ajJRCbjZ3CJF8zdY8%2Fu%2F11QYB6qXEwX4CB7r1YlVkGU%3D&h=56e336b2\" target=\"_blank\">https://youtu.be/FZ23kosLFec</a>"},{"pid":"707cb2abdb4cffe1942af1d8f6c7b39fdaa7d56a","tid":1374724,"uid":134437,"like":0,"dislike":3,"score":-3,"quote":{"pid":"356cedb190182f8c55e3bd6969de7623c87c2f3e","tid":1374724,"uid":134437,"like":0,"dislike":3,"score":-3,"quote":{"pid":"55ce071deda7656b6acf8c89bdceaca290118b9e","tid":1374724,"uid":291751,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-28T07:48:24.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-07-28T08:38:02.000Z","msg":"<a href=\"https://youtu.be/FZ23kosLFec\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FFZ23kosLFec&d=ajJRCbjZ3CJF8zdY8%2Fu%2F11QYB6qXEwX4CB7r1YlVkGU%3D&h=56e336b2\" target=\"_blank\">https://youtu.be/FZ23kosLFec</a>"},"citedBy":0,"replyTime":"2019-07-28T08:38:30.000Z","msg":"<a href=\"https://youtu.be/WberQSoM6Rs\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FWberQSoM6Rs&d=ajJRCbjZ3CJF8zdY8%2Fu%2F11QYB6qXEwX4CB7r1YlVkGU%3D&h=70154268\" target=\"_blank\">https://youtu.be/WberQSoM6Rs</a>"}]}