hkgmoji\" />"},{"pid":"e41b873543303a7e525ef08c60b3c1f7d74a5a43","tid":2398912,"uid":232157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-07T17:44:57.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"e281d578305e69aabd957fa412762b86c7351efc","tid":2398912,"uid":25240,"like":0,"dislike":0,"score":0,"quote":{"pid":"6983b9e3a6f64ca7d791871a329add9e229a92dd","tid":2398912,"uid":67896,"like":0,"dislike":0,"score":0,"quote":{"pid":"98e76f563227ca19c877c8e148965cde9d8ec2ea","tid":2398912,"uid":247064,"like":16,"dislike":1,"score":15,"citedBy":2,"replyTime":"2021-02-07T17:15:53.000Z","msg":"<blockquote>梁頌恆：「呢代人就似係鋪緊一條路，你當係條路從中環過海去尖沙咀。但每個人嘅力量都有限，只能夠搬到一兩嚿石頭只能夠鋪幾格，而且條路係單程路，鋪完你就要跳落海。但係後人可以沿著條路行落去，而且會越離越近終點。</blockquote><br />\n<br />\n每一個香港人都係要踩住前人嘅屍骨繼續行落去，過往香港人就係有太多道德潔癖，覺得踩住人哋屍體係唔光彩，係消費其他人，但要認清現實，只要想反抗，就要有不惜一切嘅意志，連道德枷鎖都擺脫唔到，又點樣同極權鬥？"},"citedBy":2,"replyTime":"2021-02-07T17:18:06.000Z","msg":"True<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> 終於喺連登見到啲有sense嘅comment<br />\n而唔係一日到黑喺度鬥黃"},"citedBy":0,"replyTime":"2021-02-07T17:45:04.000Z","msg":"其實鬥得最勁個垃圾全部唔係香港 / 根本唔會落場"},{"pid":"3823d964fe5fd52a61eff0073c92ff01a122f13e","tid":2398912,"uid":6435,"like":2,"dislike":0,"score":2,"quote":{"pid":"d35d15c8757f34ea4338495ca0d26e84a2188221","tid":2398912,"uid":247064,"like":4,"dislike":1,"score":3,"quote":{"pid":"b0fea78a89bc3c4a498bca33939f5a334d75681c","tid":2398912,"uid":5843,"like":16,"dislike":1,"score":15,"quote":{"pid":"b8cab0c8a2fb18f0b291a5b9ad58ac2af532f658","tid":2398912,"uid":30476,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2021-02-07T17:12:41.000Z","msg":"班仆街開實彈<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-07T17:14:46.000Z","msg":"<img src=\"https://www.moonlol.com/wp-hong-kong-style/p3.jpg\" data-thumbnail-src=\"https://i.lih.