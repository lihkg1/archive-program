assets/faces/dog/math.gif\" class=\"hkgmoji\" />"},{"pid":"c71764ffad75e11c18d89df069fdba21078c9255","tid":2233004,"uid":38861,"like":1,"dislike":0,"score":1,"quote":{"pid":"c45102a065eee4ee3b4da0ac0098fdce3762036d","tid":2233004,"uid":18605,"like":0,"dislike":0,"score":0,"quote":{"pid":"0a404ec37eb515a7fa84507b47fe0af4c8496630","tid":2233004,"uid":38861,"like":1,"dislike":0,"score":1,"quote":{"pid":"8bf10e0a31caf50ee3d5b3983dd654eb80eed188","tid":2233004,"uid":18605,"like":2,"dislike":1,"score":1,"citedBy":2,"replyTime":"2020-10-06T22:21:51.000Z","msg":"用代糖來煮餸得唔得<img src=\"/assets/faces/mouse/solution.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-07T06:22:49.000Z","msg":"<img src=\"/assets/faces/pig/champagne.gif\" class=\"hkgmoji\" />你知道我不嬲都係代糖反對者<img src=\"/assets/faces/pig/champagne.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-07T07:21:08.000Z","msg":"想知用代糖代糖會唔會因為加熱而有其他轉變而令味道改變<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-07T07:26:02.000Z","msg":"代糖同樣會因為加熱而感覺比較甜，因為佢可以用T1R機制，但唔會因為加鹽而變得比較甜，因為佢同葡萄糖的結構唔同，用唔到SGLT機制。<img src=\"/assets/faces/mouse/solution.gif\" class=\"hkgmoji\" />"},{"pid":"fa0bb0a638568cabe9e17d9663a67839d7cc85b9","tid":2233004,"uid":81139,"like":0,"dislike":0,"score":0,"quote":{"pid":"8d0e1c8cc29fba6c4a723c6210ba4118223f3566","tid":2233004,"uid":38861,"like":0,"dislike":0,"score":0,"quote":{"pid":"2aee1259e17766bf9c76628d6a87031df65587f3","tid":2233004,"uid":32345,"like":2,"dislike":0,"score":2,"quote":{"pid":"f92027d5657211ce8b74a8271210a04483a0f28e","tid":2233004,"uid":93385,"like":7,"dislike":0,"score":7,"citedBy":2,"replyTime":"2020-10-06T22:22:32.000Z","msg":"咁有時整鹹嘅嘢食話再落少少糖令佢唔好係死鹹呢？<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-07T06:48:02.000Z","msg":"所以食咸肉傻要加糖"},"citedBy":1,"replyTime":"2020-10-07T07:05:07.000Z","msg":"但都有豉油派的存在<img src=\"/assets/faces/mouse/solution.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-10-07T07:32:23.000Z","msg":"加甜豉油點睇？<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />"}]}