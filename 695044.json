:"70d5ca1ae2939fb483178798dc2e74cc0022f904","tid":695044,"uid":404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T02:38:44.000Z","msg":"一嗌就會分手"},{"pid":"fe1a5898a6f5c431a4f950ed1566514e182969ad","tid":695044,"uid":114275,"like":14,"dislike":0,"score":14,"citedBy":0,"replyTime":"2018-06-09T02:40:09.000Z","msg":"兩個人都唔計較咪唔洗嗌交<br />\n<br />\n做人咁多計較脾氣做乜<br />\n<br />\n唔同意見咪一時跟下你一時跟下我<br />\n<br />\n有咩事要咁堅持值得你去嗌交？"},{"pid":"ca96ed82605f7259193ae0afd9a9bd35cf91919d","tid":695044,"uid":149552,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2018-06-09T02:41:33.000Z","msg":"2年幾3年冇嗌過 結果分手果陣炒獲大既<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"6c67a7e97d44c92a49889e3c18cb25a7d9635254","tid":695044,"uid":166491,"like":0,"dislike":0,"score":0,"quote":{"pid":"00afe3a92ae4d5aeecd0903f534cd53a213e6941","tid":695044,"uid":78222,"like":74,"dislike":3,"score":71,"citedBy":1,"replyTime":"2018-06-09T02:35:27.000Z","msg":"一定唔會冇嗌過交 實會有唔夾嘅地方<br />\n唔鬧交大機會係忍住左係心入面 就算對方無理取鬧都因為（包容）而放係心入面唔講出黎<br />\n<br />\n咁樣愈積埋積埋啲小事 個jackpot就愈和味 你一中就仆硬街 有陣時鬧交講嘅野 就係心入面嘅感受 如果唔夠溝通 永遠識唔到佢心入面真正嘅自己或對方<br />\n<br />\n利申 同女朋友一齊五年 我地同其他人都覺得仲係熱戀期咁 但其實短則一星期鬧交 耐嘅都係一兩個月都會鬧一次交 但每次鬧完交都會檢討雙方咩位錯 雙方感受 我真係feel到咩叫鬧交可以增進感情 前題當然係你鬧完交氹得店<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-09T02:53:27.000Z","msg":"我指嗌交係真係會炒穫大既 可能會冷戰個種 當然我同佢都會有時不滿對方一d小事 但係大家都知道炒大穫對件事無幫助 反正一知道對方嬲9左你 即刻氹番通常都無事 佢地無非都係想你氹番佢姐 前題你男/女朋友唔係小氣類型<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3866f7481ee64871261952b1f4f2e4b7495e8a9c","tid":695044,"uid":50411,"like":12,"dislike":3,"score":9,"citedBy":0,"replyTime":"2018-06-09T02:55:45.000Z","msg":"唔嗌等分手啦！<br />\n另外表現越恩愛，越易分"},{"pid":"c27dce8f438594dfc7fe2bd76770fc81a10d2969","tid":695044,"uid":186003,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2018-06-09T03:03:43.000Z","msg":"一路都唔會嘈，一年嗌一次交都叫密。<br />\n其實只係以為自己忍到點知積積埋埋一嗌就分，頭都唔回。<br />\n依家學識有不滿要講，但係行開幾日消左啖氣好聲好氣傾，希望會好d <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9f909bc91ff518177c849c38cfad8ffcf5a1bcda","tid":695044,"uid":147856,"like":0,"dislike":0,"score":0,"quote":{"pid":"deeddfd73358e09df4353691d044b44f7a999fec","tid":695044,"uid":166491,"like":6,"dislike":0,"score":6,"quote":{"pid":"33960f0cb35471e457b7eabd52ca3d08b59a95f9","tid":695044,"uid":147856,"like":13,"dislike":0,"score":13,"quote":{"pid":"be65459f0c1f05cc11ea47da61e403d496525945","tid":695044,"uid":166491,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-09T02:14:38.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-06-09T02:17:50.000Z","msg":"係佢對我有不滿又唔講，我又戇鳩鳩咁，頂我唔順一次過講晒出黎就分手<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-09T02:28:20.000Z","msg":"有時候覺得唔對路 直接攤出黎講可能仲好<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 等到爆煲點既時候已經太遲了"},"citedBy":0,"replyTime":"2018-06-09T03:30:53.000Z","msg":"情願有交嗌<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"0ba87aac6a95580b6c5076941ab4d377c2bfa4f6","tid":695044,"uid":34753,"like":17,"dislike":0,"score":17,"citedBy":0,"replyTime":"2018-06-09T03:31:49.000Z","msg":"無鬧交<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /> 不過係單方面比人鬧<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"547a6fb7c285a81f3abf0555931b2aefe5ebcc8d","tid":695044,"uid":81183,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-06-09T03:34:19.000Z","msg":"一齊左差唔多十年，<br />\n通常單方面被發脾氣<br />\n跟住另一邊一係知衰氹番人，<br />\n一係自己覺得都嬲，<br />\n但唔會反鬧，都係唔出聲，<br />\n隔一排又冇野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n認真嘈交就未試過"},{"pid":"84d225ec5f0b44f5cebd234aeaa7e1fcc091fe52","tid":695044,"uid":179783,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-06-09T03:42:12.000Z","msg":"嗌完交先知對方需要咩 去互相遷就返對方<br />\n有時嗌交都唔係一件壞事<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"89be8c7ee38fd45137dc7e3fa3411f6c6d029946","tid":695044,"uid":19529,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-06-09T03:43:38.000Z","msg":"嗌叫緊有 不過好少會嘈過夜<br />\n一齊8年日日都咁sweet<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"0aea735a35f933847d76e1ecd06de5d17de9ec05","tid":695044,"uid":70763,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-06-09T04:08:23.000Z","msg":"唔覺得冇嗌過交係好事"},{"pid":"2e896e4dcf2558fb36c4c2bbd7c1f2fb963f2fcc","tid":695044,"uid":46207,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-09T04:21:32.000Z","msg":"同ex一直冇嗌過交 唯一一次嗌完 就分手了"},{"pid":"885d1a457cbe9b1b70a10b401929d706551317a7","tid":695044,"uid":125079,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T04:22:44.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"f2b832b0d8265717dda57c7958a8fd1b101113f0","tid":695044,"uid":25760,"like":2,"dislike":0,"score":2,"quote":{"pid":"84d225ec5f0b44f5cebd234aeaa7e1fcc091fe52","tid":695044,"uid":179783,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-06-09T03:42:12.000Z","msg":"嗌完交先知對方需要咩 去互相遷就返對方<br />\n有時嗌交都唔係一件壞事<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-09T04:26:51.000Z","msg":"同意！<br />\n我同女朋友拍拖一個月嗌一次<br />\n感覺上嗌完之後都知對方想要d乜，大家都會反省下<br />\n雖然每次嗌交都好痛苦，但希望嗌完可以長久d啦"},{"pid":"085eecee0803238f5ea33f2406785c52bc37a953","tid":695044,"uid":177457,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-06-09T04:28:16.000Z","msg":"如果真係好愛大家 嗌下交反而感情更好<br />\n大家都仲care先有交鬧 淡左就冇交鬧啦<br />\n不過嗌完交唔改又係另一回事<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"509d19a52059159d97f91e8fabea10a0950cfa32","tid":695044,"uid":84481,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T04:37:29.000Z","msg":"咁即係嗌好定唔嗌好<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" />"},{"pid":"4de776a7ae9e20984f3b36496fe5d2460841c125","tid":695044,"uid":95082,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T04:41:36.000Z","msg":"一齊咗一年多啲<br />\n一個禮拜必嘈一次<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},{"pid":"0311fa4caead159d322e8ebee32b797bdace5c09","tid":695044,"uid":73362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T04:45:19.000Z","msg":"一齊五年冇鬧過交<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n但平時會互串互相話對方柒咁<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" />"},{"pid":"1ffa05c7daf42234e1585f117c91a36803c90768","tid":695044,"uid":81569,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-09T04:47:20.000Z","msg":"有個friend從來唔會同女朋友嗌架<br />\n條女比狗公媾緊<br />\n佢都唔會嬲<br />\n咁係好定唔好<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8611359f03dc97cc3134290dfb48d260bd2fc119","tid":695044,"uid":47237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T05:12:53.000Z","msg":"27年來都無<br />\n<br />\n利申：左手"},{"pid":"cb5fc1f3323798ae1544275b316e3b7b6a03d0e5","tid":695044,"uid":123308,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9575bec02c1e15690fa74b283310465252f32c7","tid":695044,"uid":7615,"like":143,"dislike":1,"score":142,"citedBy":3,"replyTime":"2018-06-09T02:11:47.000Z","msg":"表面冇嗌交 其實只係大家收埋收埋唔講<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-09T05:22:20.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n就好似充滿 gas 嘅房間，小小嘅火花就會爆 <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"ea3c3bf23427cc27b4e400aa82e43cde91d33e56","tid":695044,"uid":135316,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T05:27:57.000Z","msg":"兩年半冇鬧過交 已散<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},{"pid":"73ffa5d5d4c8b8edd6e0c2519bae57237a7579ea","tid":695044,"uid":121060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T05:48:10.000Z","msg":"2年冇嗌過交，但話散就散<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"b60aa7c1373b447aa9b82c02ce6d91c7e8b5fcb4","tid":695044,"uid":116905,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-06-09T06:08:46.000Z","msg":"唉屌<br />\n忍左佢好耐架喇<br />\n條八婆<br />\n幼稚到死又野蠻又唔講道理<br />\n成日有咩事就屈我賴我咩都我錯<br />\n駁返佢就一句得啦得啦我錯哂你啱哂啦<br />\n講多兩句就喊喊喊成個女人咁<br />\n貪你啱啱破處夠緊咋<br />\n含又唔識<br />\n坐蓮又唔識<br />\n呻吟都唔叫吓<br />\n搞親野都要比佢射咗先<br />\n跟住好多時就要我自己打飛機<br />\n遲早飛咗你個死八婆"},{"pid":"261eeb63af4eb50deb4ba08cfbde4d8499890e63","tid":695044,"uid":22808,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9575bec02c1e15690fa74b283310465252f32c7","tid":695044,"uid":7615,"like":143,"dislike":1,"score":142,"citedBy":3,"replyTime":"2018-06-09T02:11:47.000Z","msg":"表面冇嗌交 其實只係大家收埋收埋唔講<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-09T06:28:53.000Z","msg":"呢樣真，最後一爆覆水難收"},{"pid":"eb1374c84fad27144e8f6e8279264fbd25db45fa","tid":695044,"uid":189087,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9575bec02c1e15690fa74b283310465252f32c7","tid":695044,"uid":7615,"like":143,"dislike":1,"score":142,"citedBy":3,"replyTime":"2018-06-09T02:11:47.000Z","msg":"表面冇嗌交 其實只係大家收埋收埋唔講<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-09T06:30:25.000Z","msg":"心聲"},{"pid":"d938dcb4a4917847eaea820f8407dd99d4d47150","tid":695044,"uid":3647,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T06:35:46.000Z","msg":"一齊第二年果時經常開戰<br />\n愈黎愈少"},{"pid":"2e97b9d882cafa9332c4667aff316542f74ef8b8","tid":695044,"uid":114275,"like":1,"dislike":0,"score":1,"quote":{"pid":"cb5fc1f3323798ae1544275b316e3b7b6a03d0e5","tid":695044,"uid":123308,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9575bec02c1e15690fa74b283310465252f32c7","tid":695044,"uid":7615,"like":