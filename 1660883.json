,罷工"},{"pid":"dc81b053ead0464597ee45db53d0d46704c277d0","tid":1660883,"uid":254330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T02:05:18.000Z","msg":"香港人,反抗<br />\n香港人,罷工"},{"pid":"b890abb5e15e29508307c008ff86174dd800cd94","tid":1660883,"uid":254330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T02:06:10.000Z","msg":"香港人,反抗<br />\n香港人,罷工"},{"pid":"58e697dd84a10565e0c8b02391d47f6fa49ef882","tid":1660883,"uid":254330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T02:12:48.000Z","msg":"香港人,反抗<br />\n香港人,罷工"},{"pid":"d4e69d3b964d34daa99c7911c02487c279bfd473","tid":1660883,"uid":254330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T02:46:42.000Z","msg":"香港人,反抗<br />\n香港人,罷工"},{"pid":"1371a22738dea46f4d0543fef2050d38d46bd2ce","tid":1660883,"uid":60563,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-18T03:11:02.000Z","msg":"因為大家都知罷唔起所以咪唔講"},{"pid":"548d4deb21c900f1a426c40008a239b9394494b3","tid":1660883,"uid":60563,"like":0,"dislike":0,"score":0,"quote":{"pid":"1a727c1014717740ee43f0cf9d7b39cf848177cc","tid":1660883,"uid":73804,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-17T19:25:29.000Z","msg":"廢話<br />\n香港人要罷工都要靠勇武塞黨鐵 搞rb"},"citedBy":0,"replyTime":"2019-10-18T03:12:42.000Z","msg":"連自己份工都要勇武幫你罷<br />\n呢個就係失敗主因<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"095b8033fb434894b65b2b6587bae599d454c100","tid":1660883,"uid":254330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T03:29:58.000Z","msg":"香港人,反抗<br />\n香港人,罷工"},{"pid":"fb6c8bd43d7bd41bab5fbbb96f31271c4873188d","tid":1660883,"uid":254330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T03:35:41.000Z","msg":"香港人,反抗<br />\n香港人,罷工"},{"pid":"203ca4e291be27c442508b18766915477aa13b69","tid":1660883,"uid":254330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T03:53: