攬空姐、空少及飛機師參加。經過首輪面試及重重篩選後，15位入圍參賽者今日（17日）在電視城會晤傳媒，當中包括10位空少及飛機師、5位空姐，被視為大熱的前組合Square成員李傑志（Brian）、麥明詩的飛機師緋聞男友盛勁為（Keith）順利入圍！據知決賽將會於12月26日晚直播舉行，冠軍會贏得10萬獎金及試鏡機會。<br />\n<br />\n男多過女<br />\n比HEHE睇?<br />\n<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3a254bad6a60388f2c48a0a2ba6fab9408cbefca","tid":2329702,"uid":51469,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2020-12-17T11:52:53.000Z","msg":"<img src=\"https://www.mpweekly.com/entertainment/wp-content/uploads/2020/12/021-20201217110406.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.mpweekly.com%2Fentertainment%2Fwp-content%2Fuploads%2F2020%2F12%2F021-20201217110406.jpeg&h=e063e18c&s={SIZE}\" />"},{"pid":"6b4551881b9ac131321c2a493c4bf151630545e3","tid":2329702,"uid":149494,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2020-12-17T11:56:21.000Z","msg":"呢班係黃定藍？"},{"pid":"c00319accbeb12ae7e73106539484acd166abcce","tid":2329702,"uid":267283,"like":4,"dislike":1,"score":3,"quote":{"pid":"6b4551881b9ac131321c2a493c4bf151630545e3","tid":2329702,"uid":149494,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2020-12-17T11:56:21.000Z","msg":"呢班係黃定藍？"},"citedBy":2,"replyTime":"2020-12-17T12:14:33.000Z","msg":"入得TVB嘅，你話呢"},{"pid":"8e87c10b375b1a3a3b23805e81de053c8abc0918","tid":2329702,"uid":149494,"like":0,"dislike":2,"score":-2,"quote":{"pid":"c00319accbeb12ae7e73106539484acd166abcce","tid":2329702,"uid":267283,"like":4,"dislike":1,"score":3,"quote":{"pid":"6b4551881b9ac131321c2a493c4bf151630545e3","tid":2329702,"uid":149494,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2020-12-17T11:56:21.000Z","msg":"呢班係黃定藍？"},"citedBy":2,"replyTime":"2020-12-17T12:14:33.000Z","msg":"入得TVB嘅，你話呢"},"citedBy":0,"replyTime":"2020-12-17T12:15:07.000Z","msg":"之前呢？"},{"pid":"6cf92bc3d34af45499d0f94677be861b91430a7f","tid":2329702,"uid":88168,"like":1,"dislike":1,"score":0,"citedBy":4,"replyTime":"2