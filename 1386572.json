ps://lih.kg/1386584</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"7d79551a8b02c22d5ef48c7a67c6973cd887c82e","tid":1386572,"uid":272057,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T11:38:42.000Z","msg":"推"},{"pid":"92cbe815789b9d26ec1dce5f92d1b079a0698b99","tid":1386572,"uid":30402,"like":0,"dislike":0,"score":0,"quote":{"pid":"b959306d11c27a90b72b69b8d4a2a56b5b47c6da","tid":1386572,"uid":279401,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-30T11:36:04.000Z","msg":"大家行動前都睇睇條片<br />\n<a href=\"https://lih.kg/1386584\" data-auto-link target=\"_blank\">https://lih.kg/1386584</a><br />\n- 分享自 LIHKG 討論區"},"citedBy":0,"replyTime":"2019-07-30T11:39:22.000Z","msg":"推"},{"pid":"78d44de26843459f46a216bec7c6818b5498854f","tid":1386572,"uid":30402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T11:40:12.000Z","msg":"推"},{"pid":"68a93ce0403bd06567b25718ecc98e79fa7c1a25","tid":1386572,"uid":30402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T11:40:24.000Z","msg":"推"},{"pid":"304097aa7304f7fe58765270a533d3ad15fb0d11","tid":1386572,"uid":122786,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-30T11:40:28.000Z","msg":"呢個政權會令你疑惑同埋疲累，保持思考但我哋唔可以放棄，一放棄我哋就會失去一切，要有希望同埋信念。"},{"pid":"ccd14eba7796eb8998a82698f9fae0d28f29315b","tid":1386572,"uid":30402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T11:40:37.000Z","msg":"推"}]}