c4ec69594a245473fd2ccd4823f13","tid":1165063,"uid":235986,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2019-05-22T18:09:54.000Z","msg":"煮家男人=典型華人心態<br />\n冇用公子=基層<br />\n<br />\n煮家男人的角度：你地唔讀書等畢業果時乖乖地搵工，我地邊搵到機會剥削你地班基層。<br />\n<br />\n冇用公子：我地冇父幹冇家底乜都冇果類，除左讀書幫人打一世工之外仲會唔會有其他出路呢。<br />\n<br />\n<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"99ce0507236a67ec74db4f879abdf0541f87f2b1","tid":1165063,"uid":193476,"like":0,"dislike":0,"score":0,"quote":{"pid":"8eec7408de9c4ec69594a245473fd2ccd4823f13","tid":1165063,"uid":235986,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2019-05-22T18:09:54.000Z","msg":"煮家男人=典型華人心態<br />\n冇用公子=基層<br />\n<br />\n煮家男人的角度：你地唔讀書等畢業果時乖乖地搵工，我地邊搵到機會剥削你地班基層。<br />\n<br />\n冇用公子：我地冇父幹冇家底乜都冇果類，除左讀書幫人打一世工之外仲會唔會有其他出路呢。<br />\n<br />\n<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-05-22T18:35:37.000Z","msg":"其實Bob叔係唔會明白低下階層個種思想<br />\n<br />\n低下層既細路，屋企人無錢又無學識，自細無人教已經蠢，學業上根本無能力去追，最後只有合理法唔讀書都搵到錢呢個point。<br />\n<br />\n每個階層既人都有自已生存方式同見解，其實無對錯，只係大家出生唔同，就會有唔同選擇。"},{"pid":"133be3d67341c213242c613808f8482bb39361a4","tid":1165063,"uid":167464,"like":9,"dislike":1,"score":8,"citedBy":1,"replyTime":"2019-05-23T00:21:54.000Z","msg":"今鋪支持慕容，讀書根本就係浪費時間<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />早啲出嚟搵食仲好啦<br />\n<br />\n飲食，物流，保險，倫敦金大把發展機會<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<br />\n利申: 讀到中三無讀嘅公屋死窮撚，而家做緊飲食界才俊，經理好睇得起我同我炸啲薯條<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"830f856cb0378a06021239b88573dc3443ceb2f2","tid":1165063,"uid":249475,"