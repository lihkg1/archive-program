tion/restore-hong-kongs-autonomy-make-hong-kong-great-again\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Frestore-hong-kongs-autonomy-make-hong-kong-great-again&d=0fhT0ZiErqSmjIt08Df9omVlCuV5KOpEhASsqV1EMe4%3D&h=7804435c\" target=\"_blank\">https://petitions.whitehouse.gov/petition/restore-hong-kongs-autonomy-make-hong-kong-great-again</a>"},{"pid":"a88945fdda56022ed032a9aa852c26d3181c689b","tid":1493070,"uid":653,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T06:54:23.000Z","msg":"團結中國人民力量<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"07f22db4d9c8ab665b64eb7b74b266b1e743cca5","tid":1493070,"uid":29080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T06:55:07.000Z","msg":"所以先圍到中聯辦成個城堡咁<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"a53c6b1c5e8525a7113b92466f49ddd9d44db7b9","tid":1493070,"uid":264121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T06:55:32.000Z","msg":"推"},{"pid":"35b3b8532a294116e21c9d0b685ba412a8225089","tid":1493070,"uid":217217,"like":0,"dislike":0,"score":0,"quote":{"pid":"28723a96a1328fd0b724623ffcb78b36cb8bdda6","tid":1493070,"uid":272653,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T06:48:19.000Z","msg":"侮辱國旗同區旗<br />\n應該唔包括黨旗<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-21T07:25:04.000Z","msg":"身披國旗，腳踩黨旗，手持維尼<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"}]}