e":"2020-03-25T02:32:56.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a09b877cb6dfbbc5dc5984993f627c89b94108cd","tid":1942063,"uid":164485,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T02:36:36.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"bad9a5102a9dece34bbdf4a8ed5c4a2b4cfd9786","tid":1942063,"uid":6562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T02:38:22.000Z","msg":"得意有趣又有意義 和你推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c75aee3080bd590142ab371a3324f8c64fa5305e","tid":1942063,"uid":285371,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T02:40:19.000Z","msg":"push"},{"pid":"3a420328dedfa1570e87087258e2fddc3250a25c","tid":1942063,"uid":155344,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T02:52:52.000Z","msg":"多謝手足 <br />\n有啲唔講真係唔知<br />\n希望啲人睇完文宣 唔好淨係覺得靚就夠"},{"pid":"0f3e55d5320c9f60c4007c070e152cbe893512c2","tid":1942063,"uid":181093,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-25T04:04:24.000Z","msg":"點解佢哋唔一齊嚟嗰張喊到仆街"},{"pid":"4a9347bd01dd7813512f7bb318942014f99094dc","tid":1942063,"uid":93202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T04:11:23.000Z","msg":"PISH"},{"pid":"69795ee1f41ad6b510aa639848565448737ff0ae","tid":1942063,"uid":26014,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T04:13:47.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4a2f9cbf05148c73714cdcc379d186da9668d160","tid":1942063,"uid":162927,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-25T04:21:01.000Z","msg":"呢個要知！"}]}