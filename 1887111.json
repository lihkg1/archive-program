aces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"62bceebce5c2d9b0621f512d4a8824f2ece688ce","tid":1887111,"uid":52152,"like":0,"dislike":0,"score":0,"quote":{"pid":"ba66bf2ea3aa0ae7d810197fc1b517682a9071bd","tid":1887111,"uid":197213,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-02-19T10:26:58.000Z","msg":"可能係有狗住粉嶺, 自己人做場大龍鳳 SPIN 走個集中營, 之後單CASE又HEA跟唔捉人<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-19T10:32:08.000Z","msg":"PTU 總部好似幾近？"},{"pid":"07b42188d1f4e151d7e93a108690b7b4e6b4624b","tid":1887111,"uid":238828,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-02-19T10:32:45.000Z","msg":"一落地居然淨係拆rb同&rsquo;勸喻&rsquo;市民走<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /><br />\n粉嶺大大個ptu基地係到 你自己諗下點解會俾你玩咁耐<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"c85fe672965141fef65aa1b04f88c6d3b70315a9","tid":1887111,"uid":4493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-19T10:32:58.000Z","msg":"火炭嗰頭根本冇乜人住<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"8b6255b72c140bb0ee3758d5bce95d1ba0b48640","tid":1887111,"uid":10189,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-02-19T10:35:31.000Z","msg":"個PTU基地唔近<br />\n仲遠過粉嶺火車站<br />\n但你車出車入難保社區有狀況<br />\n再加上一開波無諗過係藍絲行頭<br />\nD藍絲平時無性點9知佢做咩出黎"},{"pid":"7c5461092b519ae0414c6aa533168e81eb08fc78","tid":1887111,"uid":27664,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-19T10:42:23.000Z","msg":"其他地方要中過招先識驚 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"7ee129d046536bcf52cebe378b26d984a76e5467","tid":1887111,"uid":269629,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-19T10:43:10.000Z","msg":"點同<br />\n佢當時唔預你黃藍一家　最後燒晒幢樓嘛<b