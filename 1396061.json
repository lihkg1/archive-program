59d9cb906ac0e955ee3","tid":1396061,"uid":227968,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-08-02T03:34:19.000Z","msg":"#我係香港人 <br />\n#我會參與罷工罷市罷課<br />\n<br />\n8月2日 公務員罷工集會<br />\n8月5日 一齊罷工 7區集會"},{"pid":"ac631f783cce9f5aafc69049a9a6610c815fba95","tid":1396061,"uid":277554,"like":18,"dislike":1,"score":17,"quote":{"pid":"2866aee626495a6024ff94938a36c6319116dbd0","tid":1396061,"uid":187861,"like":44,"dislike":0,"score":44,"citedBy":1,"replyTime":"2019-08-02T03:30:24.000Z","msg":"連賓賓、印印都say no to 支共<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\nWe fucking connect <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-02T03:35:15.000Z","msg":"不過講真香港對佢地大部分黎講都只係一個做野既地方，佢地唔會話咩企出黎。<br />\n但令賓賓印印知咩事，都係保障番佢地。<br />\n同埋等香港班<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">離地中產撚咪撚再咁離地啦屌你老母，有咩事大家一鑊熟呀！</span></span>"},{"pid":"c3c9fe04f0aac4c13732e3cdfac04d39228571e8","tid":1396061,"uid":277554,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2019-08-02T04:31:02.000Z","msg":"<img src=\"https://na.cx/i/e472uZV.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fe472uZV.png&h=937f8818&s={SIZE}\" /><br />\n<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"4a253fc2ace29a0e96c7aa18a9093cda184028b3","tid":1396061,"uid":257422,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2019-08-02T04:31:16.000Z","msg":"我地可以迫大集團表態，<br />\n只要佢地肯表態，<br />\n市民自然會少左個包袱去罷工<br />\n<br />\n <span style=\"font-size: xx-large;\">一人一信 推到 大貓 今日內交代 8月5罷工 立場！！！！！</span><br />\n<a href=\"https://lih.kg/1396162\" data-auto-link target=\"_blank\">https://lih.kg/1396162</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<img src=\"https://na.cx/i/1AMiNLW.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1AMiNLW.jpg&h=611f7a48&s={SIZE}\" />"},{"pid":"0a27dfb4c1369505214641524d65fc5ab855b99b","tid":1396061,"uid":277554,"like":13,"dislike":1,"score":12,"citedBy":0,"replyTime":"2019-08-02T04:45:12.000Z","msg":"幫手推po<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n識一條中產撚香港發生乜事完全唔知，但又不停講暴動，仲問我點解唔睇大公報同TVB。<br />\n香港真係有一大堆<span style=\"color: teal;\">活係平行時空既中產</span>。<br />\n一日佢地覺得影響唔到自己，一日佢地都唔會思考。只要連離地中產都we connect埋，香港更有望！！"},{"pid":"1b245ac7575164d9f3409c934b4fe23f0581f372","tid":1396061,"uid":45041,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-02T04:48:18.000Z","msg":"推啊 香港人加油<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"3da1feee9e581183a3f841d8375b771a2d9e4cfb","tid":1396061,"uid":277554,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2019-08-02T04:48:45.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">以後無工人姐姐同你執屋洗衫湊B<br />\n等講大陸鐘點啦</span></span><br />\n<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"1afb875511680517fa58becd6e17a9db512e6c2e","tid":1396061,"uid":277554,"like":1,"dislike":0,"score":1,"quote":{"pid":"3da1feee9e581183a3f841d8375b771a2d9e4cfb","tid":1396061,"uid":277554,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2019-08-02T04:48:45.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">以後無工人姐姐同你執屋洗衫湊B<br />\n等講大陸鐘點啦</span></span><br />\n<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-02T04:49:16.000Z","msg":"<span style=\"font-size: small;\"><span style=\"color: gold;\">請*</span></span>"},{"pid":"2386a3cde5037e930c