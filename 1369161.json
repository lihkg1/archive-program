0aa916a42d09e94e64b","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T03:36:58.000Z","msg":"推"},{"pid":"14dc744ca6bdd74fa793f77596f3417c669e037f","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T03:39:05.000Z","msg":"推"},{"pid":"5d5b65c5f67ff41eeec02df5bcfed3f5019482a9","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T03:40:20.000Z","msg":"推"},{"pid":"95c1d1acc940acce81813ca0c5a005a7a0cc80d9","tid":1369161,"uid":278911,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T03:42:08.000Z","msg":"推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"bd0c265858ff7a2a6f14f8293631efb632cf1578","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T03:46:07.000Z","msg":"推"},{"pid":"12e8961932a811d7812aecd44d75de0c543e69b5","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T03:46:54.000Z","msg":"推"},{"pid":"d7312ba3dffa79776618e5cb0bd69dc655d6edcf","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T03:53:23.000Z","msg":"推"},{"pid":"d40583764e5630d0f3e6ba53689e5c2cf7160bd2","tid":1369161,"uid":8584,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T03:54:57.000Z","msg":"推<br />\n呢2日真係好撚明顯！"},{"pid":"d1a05747a3ec17440bdda8a22602cf5f3e2ebdc9","tid":1369161,"uid":259170,"like":0,"dislike":0,"score":0,"quote":{"pid":"9922bf4537bb677ec2d0710fab8a2997253c895d","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-26T15:38:59.000Z","msg":"出面有極多post有以下言論：<br />\n1）聽日會有二五仔搞事，扮勇武/入村<br />\n2）要阻止勇武派/阻止入村<br />\n3）聽日係和理非主場/勇武派主場<br />\n<br />\n眾所周知，聽日情況必定混亂，<br />\n我重申一次入元朗目的：<br />\n1）宗教活動<br />\n2）購物消費<br />\n3）重訴五大訴求<br />\n4）<span style=\"font-size: large;\"><span style=\"color: red;\">掃除白色恐怖</span></span><br />\n<br />\n由於無不反對通知書，大家絕對唔好諗住去元朗遊行，但元朗係公眾地方，必須要有足夠證據證明你去元朗嘅目的（1）（2）.<br />\n<br />\n如果無啦啦入圍村，比較難證明（1）（2）<br />\n不過如果有人犯法，請運用你地公民逮捕權。<br />\n<br />\n<img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /><br />\n在目睹有人犯罪時，可否出手相助？本港法律第221章《刑事訴訟程序條例》第101條訂明，一般市民有權進行拘捕， 當中第101條第2款訂明「任何人可無需手令而逮捕任何他合理地懷疑犯了可逮捕的罪行的人」，而「可逮捕的罪行」是指由法律規限固定刑罰的罪行，或根據法例對犯罪人士可處超過12個月監禁的罪行，常見罪行如謀殺、強姦、毆打，導致他人身體嚴重受傷、盜竊、縱火等。<br />\n<br />\n而《刑事訴訟程序條例》第101A條規定，「任何人於防止罪案時或於進行或協助合法逮捕罪犯或疑犯或非法地不在羈留中的人時，可使用就當時環境而言屬於合理的武力」。<br />\n<img src=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" /><br />\n<br />\n我地普通市民反對一切暴力！但我地會使用武力去制服一切暴徒，反對白色恐怖漫延！還我清新元朗"},"citedBy":0,"replyTime":"2019-07-27T04:14:07.000Z","msg":"推！"},{"pid":"d22a29246a609caeb4aa56b4aa1b5ff5ae732f14","tid":1369161,"uid":53840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T04:16:50.000Z","msg":"推"},{"pid":"61d5fc74cbb3cbde74cfe275681935d4d710047c","tid":1369161,"uid":69159,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-27T04:18:43.000Z","msg":"推"},{"pid":"074eb928451ba42254d5ac201464b8322a74bf1a","tid":1369161,"uid":266011,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T04:25:35.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"53f8c472e57447de41ae1ad9b036fb3ea4e9d12b","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T04:25:44.000Z","msg":"推"},{"pid":"d54c89c8aeddd21a253ab79b9aaaa2df76a7c553","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T04:30:59.000Z","msg":"推"},{"pid":"1ac440eb26b7e6e34084b3861e1c4b9781024e2c","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T04:34:44.000Z","msg":"推"},{"pid":"0adcf762d4444ec2de44c0c648e32ada30019cbd","tid":1369161,"uid":22566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T04:35:10.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"e252c48a02a38336aec2c2a923c64a405203181b","tid":1369161,"uid":146813,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T04:35:39.000Z","msg":"推"},{"pid":"9dc128723ec9ae7ed0eedd5e24a46c417f68e05b","tid":1369161,"uid":49812,"like":0,"dislike":0,"score":0,"quote":{"pid":"5e42c5ffc38cc83561a6b046bb1d89f70de22973","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-26T15:51:06.000Z","msg":"推"},"citedBy":0,"replyTime":"2019-07-27T04:36:47.000Z","msg":"倒不如&hellip;<br />\n<a href=\"https://petitions.whitehouse.gov/petition/sanction-hong-kong-government-its-state-terrorism-activity-conducted-yuen-long-train-station-hong-kong-721\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fsanction-hong-kong-government-its-state-terrorism-activity-conducted-yuen-long-train-station-hong-kong-721&d=vhywW4AIbf33TEOu71%2FwUwPtErjweJPees2C482IDEo%3D&h=54846fd0\" target=\"_blank\">https://petitions.whitehouse.gov/petition/sanction-hong-kong-government-its-state-terrorism-activity-conducted-yuen-long-train-station-hong-kong-721</a>"},{"pid":"5c08c86af40b36284a187022f8a1cded94b00e80","tid":1369161,"uid":53840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T04:36:56.000Z","msg":"推<br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">集中五大訴求<br />\n1.全面撤回逃犯條例<br />\n2.撤銷暴動定性<br />\n3.釋放被捕義士並承諾永不追究<br />\n4.全面實行雙普選<br />\n5.成立獨立調查委員會追究黑警責任(包括警黑勾結元朗恐襲)</span></span><br />\n<br />\n<strong><span style=\"font-size: medium;\"><span style=\"color: gold;\"><div style=\"text-align: center;\"><br />\n兄弟爬山 各自努力 齊上齊落<br />\n不分化 不篤灰 不割蓆 不譴責 不撤不散<br />\n提防 三毛 五毛</div></span></span></strong>"},{"pid":"40e53471ce3faa989a07445675cefe21e2ae3916","tid":1369161,"uid":69159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T04:39:36.000Z","msg":"推"},{"pid":"d393bdb3459a0bd