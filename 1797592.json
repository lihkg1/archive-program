5E5%25B0%2596%25E6%25B2%2599%25E5%2592%2580%25E8%25A2%25AB%25E6%258D%2595-%25E8%25AD%25A6%25E6%258C%2587%25E8%2597%258F-19-%25E5%258E%2598%25E7%25B1%25B3%25E5%2588%25A9%25E5%2588%2580%2F&d=TvOq0m68uPCtaVYdNLQuFO6cow1LS9WQT%2BeJ8I%2F17x8%3D&h=73cdb313\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E5%25BB%259A%25E6%2588%25BF%25E4%25BD%25AC-%25E6%2598%25A8%25E5%25B0%2596%25E6%25B2%2599%25E5%2592%2580%25E8%25A2%25AB%25E6%258D%2595-%25E8%25AD%25A6%25E6%258C%2587%25E8%2597%258F-19-%25E5%258E%2598%25E7%25B1%25B3%25E5%2588%25A9%25E5%2588%2580%2F&h=45c2f5be\" data-auto-link target=\"_blank\">https://www.thestandnews.com/politics/%E5%BB%9A%E6%88%BF%E4%BD%AC-%E6%98%A8%E5%B0%96%E6%B2%99%E5%92%80%E8%A2%AB%E6%8D%95-%E8%AD%A6%E6%8C%87%E8%97%8F-19-%E5%8E%98%E7%B1%B3%E5%88%A9%E5%88%80/</a>"},"citedBy":2,"replyTime":"2019-12-25T15:13:51.000Z","msg":"有無睇錯，19厘米，3/4寸，我個指甲挫都長佢幾倍"},"citedBy":0,"replyTime":"2019-12-25T16:13:23.000Z","msg":"19厘米咪以前返學嘅短間尺再短少少囉（8寸間尺）"},{"pid":"825f63c40d29e54b759408f1e20e47036fa5805c","tid":1797592,"uid":192598,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2019-12-25T16:13:23.000Z","msg":"19厘米=19mm=1.9cm......oh god...JESUS CHRIST......."},{"pid":"0883fe1c06ba793356faeecfaaa304a016eb367f","tid":1797592,"uid":65952,"like":0,"dislike":0,"score":0,"quote":{"pid":"1ca97e0ef5cdd3c51919a594eed8655e8254d8bc","tid":1797592,"uid":51271,"like":50,"dislike":0,"score":50,"citedBy":3,"replyTime":"2019-12-25T15:03:49.000Z","msg":"<a href=\"https://www.youtube.com/watch?v=KBeAvnc26hw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DKBeAvnc26hw&d=TvOq0m68uPCtaVYdNLQuFO6cow1LS9WQT%2BeJ8I%2F17x8%3D&h=590b8a19\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=KBeAvnc26hw</a><br />\n<br />\n<br />\n5年前唔拉"},"citedBy":0,"replyTime":"2019-12-25T16:17:27.000Z","msg":"人地藍絲撐警嘛<img src=\"/assets/faces/pigxm/heard.gif\" class=\"hkgmoji\" />"},{"pid":"5ce47d81d7723dfd1538ca