ee4272e80a25c641a306","tid":649143,"uid":146717,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2018-05-01T16:50:42.000Z","msg":"明明平時打字都會打&quot;顯示卡&quot;<br />\n但有時口快快會講咗&quot;顯卡&quot;<br />\n<br />\n睇黎共狗字詞真係不知不覺融入咗生活，真係要戒喇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4b74a5a955c93ea5f8ccc3b1c15b61c6a2d9d198","tid":649143,"uid":48234,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c3d0694ec0ec5c2d3a7ee4272e80a25c641a306","tid":649143,"uid":146717,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2018-05-01T16:50:42.000Z","msg":"明明平時打字都會打&quot;顯示卡&quot;<br />\n但有時口快快會講咗&quot;顯卡&quot;<br />\n<br />\n睇黎共狗字詞真係不知不覺融入咗生活，真係要戒喇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-01T22:48:38.000Z","msg":"我口講同打字都盡量用正統英文,即係graphics card<br />\n以前會叫display card,唔記得邊位巴定絲打提過係港式英文"},{"pid":"446859a14ba438ccbd28bf49516ad7041776853a","tid":649143,"uid":53466,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-05-01T22:50:09.000Z","msg":"此回覆已被刪除"},{"pid":"7a58ce86ea183d6e78d0fb54d01b2c7b5e641491","tid":649143,"uid":48234,"like":4,"dislike":3,"score":1,"quote":{"pid":"446859a14ba438ccbd28bf49516ad7041776853a","tid":649143,"uid":53466,"like":1,"dislike":0,"score":1,"quote":{"pid":"59efa33f07d09662919df28e364cc056b8ac9ad2","tid":649143,"uid":109923,"like":12,"dislike":1,"score":11,"citedBy":1,"replyTime":"2018-05-01T16:35:33.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/04/24/220903_5844d11bc6a305bf23cdc2248193f595.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F24%2F220903_5844d11bc6a305bf23cdc2248193f595.png&h=0c7353d1&s={SIZE}\" /><br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/24/220903_857ba09aadb0e6395ec11e084d8e1e0b.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F24%2F220903_857ba09aadb0e6395ec11e084d8e1e0b.png&h=4d040ca5&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-05-01T22:50:09.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-05-02T02:30:53.000Z","msg":"事實證明連登俾人蝗化<br />\n仲有兩個詞更加係蝗化到根深蒂固<br />\n手提電話,香港人簡稱手提/電話,係支那文化入侵香港先搞到講做「手機」,屌你老母就連連登講手提電話嘅台都叫「手機台」<br />\n耳筒,唔知幾時全撚部都講做耳機<br />\n明明耳機係講耳聾機,入耳式耳筒係耳塞,頭戴式係耳牛,耳筒先係統稱<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"8dedac0a67666aa78e209cdf0c681db9d9a2760b","tid":649143,"uid":15205,"like":5,"dislike":3,"score":2,"citedBy":1,"replyTime":"2018-05-02T13:18:24.000Z","msg":"我喺黃金做咗咁多年以前 d 人黎買<br />\n都係叫顯示卡/display 卡 ,<br />\n當年黃金既砌機 list 冇人會寫顯卡 ,<br />\n係近四五年先有班小朋友叫顯卡 , <br />\n次次班小朋友問我有冇咩顯卡 ,<br />\n我都問返佢咩叫顯卡 , <br />\n最後咪又係死死地氣答我顯示卡 or display 卡 ,<br />\n我屌晒你班叫顯卡既新移民<br />\n同比支那仔同化既小朋友呀<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}