ife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"acf5cce02b0f74ef75518bf95536416877c39168","tid":1492942,"uid":129537,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T05:06:32.000Z","msg":"未出糧啊嘛"},{"pid":"7339739c07d7783627ab7ed88546095cf6868010","tid":1492942,"uid":53361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T05:06:44.000Z","msg":"612 721 811<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"d573cb279ef62143f61eb13cc8e71bec9b81e876","tid":1492942,"uid":143526,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T05:06:44.000Z","msg":"每日都撳"},{"pid":"0b16ceadbacdf698dd1d480b545bdf6b65479433","tid":1492942,"uid":33907,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T05:07:01.000Z","msg":"花木蘭都靜曬啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"aa285e2cf82535cb63575da6112d3ea4e905eee4","tid":1492942,"uid":82588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T05:07:01.000Z","msg":"推"},{"pid":"d0a6be7ce20c78c9f7861ec6b2be43a0d999bb05","tid":1492942,"uid":53361,"like":0,"dislike":0,"score":0,"quote":{"pid":"d573cb279ef62143f61eb13cc8e71bec9b81e876","tid":1492942,"uid":143526,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T05:06:44.000Z","msg":"每日都撳"},"citedBy":0,"replyTime":"2019-08-21T05:07:09.000Z","msg":"態度正確<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"59c7cc768a119999efdf7e6d8a3fa61ed965011f","tid":1492942,"uid":39698,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T05:07:16.000Z","msg":"未出糧呀清<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"}]}