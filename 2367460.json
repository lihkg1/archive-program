/pig/dying.gif\" class=\"hkgmoji\" />"},{"pid":"cbebabfc5ba8fec8b8b36af1c2ecc006382aa9ec","tid":2367460,"uid":52048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-15T12:52:54.000Z","msg":"比你係麻雀大俠又點  試下同行運超人打鋪牌<br />\n鋪鋪天糊打條撚"},{"pid":"6be4decee9a4adc92db02e642c9f3051db9a6541","tid":2367460,"uid":46213,"like":0,"dislike":0,"score":0,"quote":{"pid":"440919162c45350c341a7ef1d1ed804444ed546c","tid":2367460,"uid":16516,"like":2,"dislike":0,"score":2,"quote":{"pid":"52587455ef2b987b4d15c1c21befa6cb17e8039b","tid":2367460,"uid":201169,"like":0,"dislike":0,"score":0,"quote":{"pid":"5da1f3932734977bcb8a62555a414586a40894a4","tid":2367460,"uid":242921,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-15T11:36:11.000Z","msg":"你的說法更有境界。 <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-15T12:26:24.000Z","msg":"首先要睇你同唔同意自摸係講運唔講技術先。<br />\n<br />\n我既意思係你唔出銃，其他人出銃，你既收益係零<br />\n你唔出銃，人哋自摸，你收益負1<br />\n但你自摸係正3"},"citedBy":1,"replyTime":"2021-01-15T12:31:39.000Z","msg":"其實有時唔係咁計<br />\n好似你打poker咁<br />\n你都要build up個image<br />\n你image係狂扣牌既<br />\n咁你稍為唔扣d人已經知你超靚<br />\n有時d野唔係咁straight forward <br />\n我估你打法多數係計下機率唔出沖為先<br />\n長遠咁打落去，你靚牌就會長期3家扣你<br />\n而你輸既牌就多數會係大牌自摸"},"citedBy":1,"replyTime":"2021-01-15T12:54:44.000Z","msg":"真 每個人一定有偏好既章法同攻防取向<br />\n比人捉到 有運都無咁易食"},{"pid":"2325e91e654c519dcabfe45c13104d0e0a31cb52","tid":2367460,"uid":201169,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc2664fd66e5b16beac3f26435024f3235aed807","tid":2367460,"uid":140363,"like":0,"dislike":0,"score":0,"quote":{"pid":"c2ecf74f9d68d661797f46d84fa9856b9c1c0758","tid":2367460,"uid":201169,"like":0,"dislike":0,"score":0,"quote":{"pid":"d00520cd44fa34fcd9152e6a023429197c666a6c","tid":2367460,"uid":16516,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-15T12:46:37.000Z","msg":"咁另外幾家做d乜<br />\n有冇同人撞<br />\n形勢係點<br />\n都好影響最後邊個食<br />\n人地打法唔同你<br />\n結果咪唔同囉"},"citedBy":2,"replyTime":"2021-01-15T12:49:05.000Z","msg":"我地玩台牌，唔一定要做牌。<br />\n<br />\n或者咁啦，你認唔認同自摸係講運先？你有技術都唔會控制到你摸咩架嘛。"},"citedBy":1,"replyTime":"2021-01-15T12:51:12.000Z","msg":"咁講啦 摸係運<br />\n打出係技術<br />\n<br />\n既然兩者都存在 點分邊樣多啲<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-15T12:55:23.000Z","msg":"同意你講摸係運<br />\n出係技術<br />\n<br />\n我主要想討論既係運氣可唔可以用時間去抵消，間接洐生左要個問題係贏錢要靠咩？<br />\n<br />\n咁大家都個自摸收3家，打牌要贏得多就要自摸多，咁要自摸多究竟係靠運呀定講緊你識唔識叫邊隻牌。"},{"pid":"e9b37505b4511d92151ec48e195a6d461d708db2","tid":2367460,"uid":201169,"like":0,"dislike":0,"score":0,"quote":{"pid":"6be4decee9a4adc92db02e642c9f3051db9a6541","tid":2367460,"uid":46213,"like":0,"dislike":0,"score":0,"quote":{"pid":"440919162c45350c341a7ef1d1ed804444ed546c","tid":2367460,"uid":16516,"like":2,"dislike":0,"score":2,"quote":{"pid":"52587455ef2b987b4d15c1c21befa6cb17e8039b","tid":2367460,"uid":201169,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-15T12:26:24.000Z","msg":"首先要睇你同唔同意自摸係講運唔講技術先。<br />\n<br />\n我既意思係你唔出銃，其他人出銃，你既收益係零<br />\n你唔出銃，人哋自摸，你收益負1<br />\n但你自摸係正3"},"citedBy":1,"replyTime":"2021-01-15T12:31:39.000Z","msg":"其實有時唔係咁計<br />\n好似你打poker咁<br />\n你都要build up個image<br />\n你image係狂扣牌既<br />\n咁你稍為唔扣d人已經知你超靚<br />\n有時d野唔係咁straight forward <br />\n我估你打法多數係計下機率唔出沖為先<br />\n長遠咁打落去，你靚牌就會長期3家扣你<br />\n而你輸既牌就多數會係大牌自摸"},"citedBy":1,"replyTime":"2021-01-15T12:54:44.000Z","msg":"真 每個人一定有偏好既章法同攻防取向<br />\n比人捉到 有運都無咁易食"},"citedBy":1,"replyTime":"2021-01-15T12:57:09.000Z","msg":"我講自摸....<br />\n你控制唔到人地自摸，你唔落牌，人地可以門清自摸。"},{"pid":"ed107678139d312af2a16c64b37bc987944272f4","tid":2367460,"uid":137814,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-15T12:57:33.000Z","msg":"技術好打技術差 長打會贏 前提係你真係要好心水清<br />\n<br />\n以港台為例 除左一般拆牌入章讀牌清章 仲有好多野要睇 同埋你去片守牌都有+/-ev 有時睇漏左打柒左自己都未必知 諗得愈多(方向岩) 當然愈易贏 <br />\n<br />\n打3番同槓牌技術好個urge都係好細 要既場數要更多先會稀釋到運氣影響<br />\n<br />\n記著你技術再好 平均食糊率最多都係3-4成 一場半場贏輸旺黑一定有 最緊要係打啱<br />\n<br />\n利申 打左幾年港台 贏大概50000番 (朋友都幾水魚下)"},{"pid":"561def545d4f0725f9216edd1c0a2bdb2b94e00d","tid":2367460,"uid":249143,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d08d252a47bb9bcf89bc226b1dd5704faa8457c","tid":2367460,"uid":201169,"like":1,"dislike":0,"score":1,"citedBy":5,"replyTime":"2021-01-15T12:18:16.000Z","msg":"利申：<br />\n我自己做左近4000鋪數據，我出銃率比朋友A低好多，而佢自摸率比我高少少，我同朋友A都係贏錢，不過佢就多D 50%左右。<br />\n<br />\n其實我地拗既重點係運氣依樣野係咪可以用時間去抵消，希望大家可以focus 係依一點上面！"},"citedBy":0,"replyTime":"2021-01-15T12:58:55.000Z","msg":"運氣同時間冇關係<br />\n所以不"},{"pid":"1f0a2f94c31899784998a2f31a973d2af877ce22","tid":2367460,"uid":140363,"like":0,"dislike":0,"score":0,"quote":{"pid":"2325e91e654c519dcabfe45c13104d0e0a31cb52","tid":2367460,"uid":201169,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc2664fd66e5b16beac3f26435024f3235aed807","tid":2367460,"uid":140363,"like":0,"dislike":0,"score":0,"quote":{"pid":"c2ecf74f9d68d661797f46d84fa9856b9c1c0758","tid":2367460,"uid":201169,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-15T12:49:05.000Z","msg":"我地玩台牌，唔一定要做牌。<br />\n<br />\n或者咁啦，你認唔認同自摸係講運先？你有技術都唔會控制到你摸咩架嘛。"},"citedBy":1,"replyTime":"2021-01-15T12:51:12.000Z","msg":"咁講啦 摸係運<br />\n打出係技術<br />\n<br />\n既然兩者都存在 點分邊樣多啲<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-15T12:55:23.000Z","msg":"同意你講摸係運<br />\n出係技術<br />\n<br />\n我主要想討論既係運氣可唔可以用時間去抵消，間接洐生左要個問題係贏錢要靠咩？<br />\n<br />\n咁大家都個自摸收3家，打牌要贏得多就要自摸多，咁要自摸多究竟係靠運呀定講緊你識唔識叫邊隻牌。"},"citedBy":0,"replyTime":"2021-01-15T13:00:41.000Z","msg":"咁一個人四圈鋪鋪出充三番  食一鋪自摸十番 <br />\n<br />\n你界定佢係運氣定技術先<br />\n<br />\n計運氣好廣範  例如人地手揸乜 你摸乜 揀邊隻打先<br />\n<br />\n但技術只局限你手上牌嘅變化 <br />\n<br />\n好難一概而論"},{"pid":"547fc920d3080cfd3a1806e0cfe2f5943ad8999e","tid":2367460,"uid":46213,"like":0,"dislike":0,"score":0,"quote":{"pid":"e9b37505b4511d92151ec48e195a6d461d708db2","tid":2367460,"uid":201169,"like":0,"dislike":0,"score":0,"quote":{"pid":"6be4decee9a4adc92db02e642c9f3051db9a6541","tid":2367460,"uid":46213,"like":0,"dislike":0,"score":0,"quote":{"pid":"440919162c45350c341a7ef1d1ed804444ed546c","tid":2367460,"uid":16516,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-01-15T12:31:39.000Z","msg":"其實有時唔係咁計<br />\n好似你打poker咁<br />\n你都要build up個image<br />\n你image係狂扣牌既<br />\n咁你稍為唔扣d人已經知你超靚<br />\n有時d野唔係咁straight forward <br />\n我估你打法多數係計下機率唔出沖為先<br />\n長遠咁打落去，你靚牌就會長期3家扣你<br />\n而你輸既牌就多數會係大牌自摸"},"citedBy":1,"replyTime":"2021-01-15T12:54:44.000Z","msg":"真 每個人一定有偏好既章法同攻防取向<br />\n比人捉到 有運都無咁易食"},"citedBy":1,"replyTime":"2021-01-15T12:57:09.000Z","msg":"我講自摸....<br />\n你控制唔到人地自摸，你唔落牌，人地可以門清自摸。"},"citedBy":1,"replyTime":"2021-01-15T13:01:57.000Z","msg":"鋪鋪自摸咩 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n都要佢做牌先有得自摸 咁佢咪有機會出銃囉<br />\n自摸嗰下當然係靠運 但係你話打左4000場 咁所謂運氣factor已經好細啦"},{"pid":"cb9c388915adf12b7d8f1bae05fd0751fd1f179d","tid":2367460,"uid":156573,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-15T13:04:42.000Z","msg":"我係朋友A 叫過嚟睇post既<br />\n我數學好屎 諗野廢 麻將勉強知道規矩咁<br />\n但你個po我睇左幾次<br />\n有啲廢話想發表<br />\n<br />\n首先個標題係「打麻將贏錢係靠運氣定靠技術」<br />\n如果只睇呢句，其實你個句「贏錢靠運氣，防守靠技術」無得輸，因為本身贏錢都係要運氣技術相輔相成⋯<br />\n<br />\n我諗到後面就開始諗咩叫運氣，運氣我覺得本身個定義就係「defying the odds」，你做一件事如果100% 會成功，而你成功左，你唔會叫自己做好運，反而如果成功率得1% 而你成功，咁先係好運。所以如同某個reply所講，運氣係根據結果嚟定義。咁其實無咩討論空間，唯有假設就係，每個人本身都有唔同既運氣。<br />\n呢個假設本身都屈，就好似朋友A講四個dice 個例子咁，其實本身已經假設左無運氣成份係度，因為光睇機率，每人大概就係25%。但同時佢都講左，variance（運氣）依然會存在，25.1 對 24.9勝率，能造就呢個0.1% difference既都係靠運氣。<br />\n而朋友A所講，透過精進技術，係提升緊自己食糊既機率，但只要唔係100%，運氣呢樣嘢可以負面正面，你摸唔到就係摸唔到。<br />\n所以時間係咪可以降低運氣既影響？我個人認為唔可以，但我都係覺得本身運氣呢樣野同機率有衝突，好運呢樣嘢既本質就係打贏機率⋯⋯ 憑結果而論，時間長左，大家勝率差唔多，就係「運氣都差唔多」，有人贏多左，就係「佢比較好運」，問題就係無法事前quantify運氣，所以用返我「每個人都有唔同運氣」既<br />\ndefinition，就係贏錢靠運氣，係理論角度，技術配合無限既時間可以消滅運氣，某程度上就係「運氣唔存在」，咁我又覺得朋友A啱。但我唔知咁講係咪啱「只要時間唔係無限，就算再微小都會有variance」？如果呢句成立，咁最後都係靠運氣⋯⋯<br />\n<br />\n但無奈打麻雀係現實層面就係一個有限既時間玩有限既game，根據標題個問題，最後我都係投你一票啦，sorry for 1999<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"569f03d4ce0940b63ad971b357339ada3fdd17a0","tid":2367460,"uid":20809,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-15T13:04:56.000Z","msg":"見過大把唔知自己可以叫三飛，亂打叫卡窿，又真係俾佢自摸，我係後面睇撚到咬牙切齒"},{"pid":"c4fccc99307c3e87ba58d77d955b58d5b918ecc8","tid":2367460,"uid":201169,"like":0,"dislike":0,"score":0,"quote":{"pid":"547fc920d3080cfd3a1806e0cfe2f5943ad8999e","tid":2367460,"uid":46213,"like":0,"dislike":0,"score":0,"quote":{"pid":"e9b37505b4511d92151ec48e195a6d461d708db2","tid":2367460,"uid":201169,"like":0,"dislike":0,"score":0,"quote":{"pid":"6be4decee9a4adc92db02e642c9f3051db9a6541","tid":2367460,"uid":46213,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-15T12:54:44.000Z","msg":"真 每個人一定有偏好既章法同攻防取向<br />\n比人捉到 有運都無咁易食"},"citedBy":1,"replyTime":"2021-01-15T12:57:09.000Z","msg":"我講自摸....<br />\n你控制唔到人地自摸，你唔落牌，人地可以門清自摸。"},"citedBy":1,"replyTime":"2021-01-15T13:01:57.000Z","msg":"鋪鋪自摸咩 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n都要佢做牌先有得自摸 咁佢咪有機會出銃囉<br />\n自摸嗰下當然係靠運 但係你話打左4000場 咁所謂運氣factor已經好細啦"},"citedBy":0,"replyTime":"2021-01-15T13:04:58.000Z","msg":"其實你同意摸係講運就夠架啦，我淨係關心依一點"},{"pid":"a14c9c6d8db2c28f39878b326befffacda4c0683","tid":2367460,"uid":140363,"like":0,"dislike":0,"score":0,"quote":{"pid":"cb9c388915adf12b7d8f1bae05fd0751fd1f179d","tid":2367460,"uid":156573,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-15T13:04:42.000Z","msg":"我係朋友A 叫過嚟睇post既<br />\n我數學好屎 諗野廢 麻將勉強知道規矩咁<br />\n但你個po我睇左幾次<br />\n有啲廢話想發表<br />\n<br />\n首先個標題係「打麻將贏錢係靠運氣定靠技術」<br />\n如果只睇呢句，其實你個句「贏錢靠運氣，防守靠技術」無得輸，因為本身贏錢都係要運氣技術相輔相成⋯<br />\n<br />\n我諗到後面就開始諗咩叫運氣，運氣我覺得本身個定義就係「defying the odds」，你做一件事如果100% 會成功，而你成功左，你唔會叫自己做好運，反而如果成功率得1% 而你成功，咁先係好運。所以如同某個reply所講，運氣係根據結果嚟定義。咁其實無咩討論空間，唯有假設就係，每個人本身都有唔同既運氣。<br />\n呢個假設本身都屈，就好似朋友A講四個dice 個例子咁，其實本身已經假設左無運氣成份係度，因為光睇機率，每人大概就係25%。但同時佢都講左，variance（運氣）依然會存在，25.1 對 24.9勝率，能造就呢個0.1% difference既都係靠運氣。<br />\n而朋友A所講，透過精進技術，係提升緊自己食糊既機率，但只要唔係100%，運氣呢樣嘢可以負面正面，你摸唔到就係摸唔到。<br />\n所以時間係咪可以降低運氣既影響？我個人認為唔可以，但我都係覺得本身運氣呢樣野同機率有衝突，好運呢樣嘢既本質就係打贏機率⋯⋯ 憑結果而論，時間長左，大家勝率差唔多，就係「運氣都差唔多」，有人贏多左，就係「佢比較好運」，問題就係無法事前quantify運氣，所以用返我「每個人都有唔同運氣」既<br />\ndefinition，就係贏錢靠運氣，係理論角度，技術配合無限既時間可以消滅運氣，某