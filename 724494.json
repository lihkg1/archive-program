":"37c17c68856dd4a746947d1873f4bfc2f737d364","tid":724494,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-06T05:22:50.000Z","msg":"<a href=\"https://china.hket.com/article/2109414/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fchina.hket.com%2Farticle%2F2109414%2F&d=II%2FpOSK6LHuoVjesMKBJi8n%2FdpYTMnF8ODxps2tmzCA%3D&h=c0f953cf\" data-auto-link target=\"_blank\">https://china.hket.com/article/2109414/</a><br />\n<br />\n<span style=\"font-size: xx-large;\">美加徵關稅成真 中國<span style=\"color: red;\">未提反擊時間表</span></span><br />\n<br />\n中美貿易戰打響第一槍。外電報道，本港時間今日（6日）中午12時01分，美國對首批818項、340億美元的中國商品，加徵25%關稅，正式生效。<br />\n<br />\n中國商務部上午12時05分在網站發布發言人講話指，中方承諾不打第一槍，但為了捍衛國家核心利益和人民群眾利益，不得不被迫作出必要反擊。但沒有給出具體的報復時間表。<br />\n<br />\n發言人表示，中方將及時向世貿組織通報相關情況，並與世界各國一道，共同維護自由貿易和多邊體制。<br />\n<br />\n贏国唔應該係咁架<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},{"pid":"160f62d365285e1b3e678e3e3abda11d1e428dd5","tid":724494,"uid":30169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-06T05:58:16.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"}]}