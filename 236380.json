F%2Fna.cx%2Fi%2F6v8z97r.jpg&h=22d0c00a&s={SIZE}\" /><br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2016/12/04/012213_fa1c9e0e262832aa437067b9264bfaa7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2016%2F12%2F04%2F012213_fa1c9e0e262832aa437067b9264bfaa7.jpg&h=41ac5ba3&s={SIZE}\" /><br />\n<br />\n[size=4]<strong><span style=\"color: purple;\">둘！셋！방 탄！안녕하세요，방탄소년단입니다！<br />\n<br />\n2！3！防 彈！大家好，我地係防彈少年團！<br />\n<br />\ndul！ses！bang tan！annyeonghaseyo，bangtansonyeondanibnida！</span></strong></span><br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2016/12/04/011518_6b23e241a581a5ff7546484f254432b3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2016%2F12%2F04%2F011518_6b23e241a581a5ff7546484f254432b3.jpg&h=efb6031e&s={SIZE}\" /><br />\n2015/05/07 M! Countdown 'I NEED U' 1位<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2016/12/04/011331_143be3ce0dd297e571be55e2e23da52d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2016%2F12%2F04%2F011331_143be3ce0dd297e571be55e2e23da52d.jpg&h=c402b34a&s={SIZE}\" /><br />\n2015/12/11 Music Bank 'RUN' 1位<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2016/12/04/011533_3d27ba1b17fe894ee2491895b522d12a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2016%2F12%2F04%2F011533_3d27ba1b17fe894ee2491895b522d12a.jpg&h=24be4953&s={SIZE}\" /><br />\n2016/05/13 Music Bank 'FIRE' 1位<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2016/12/04/011406_375e0e04ceedc92fbfaba26791bed4c3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2016%2F12%2F04%2F011406_375e0e04ceedc92fbfaba26791bed4c3.jpg&h=60ed5ec7&s={SIZE}\" /><br />\n2016/10/28 Music Bank 'Blood Sweat &amp; Tears' 1位<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/2xf5uqW.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F2xf5uqW.jpg&h=c9f8d60b&s={SIZE}\" /><br />\n2017/02/23 M! Countdown 'Spring Day' 1位<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2016/12/04/011602_f2522b78f546a0592dcaf813b1ade7da.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2016%2F12%2F04%2F011602_f2522b78f546a0592dcaf813b1ade7da.jpg&h=1993f8f2&s={SIZE}\" /><br />\n2016/11/19 第8屆 Melon Music Awards 年度專輯大賞《花樣年華 Young Forever》<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2016/12/04/010652_62019a4104cd76106d6061f48113b671.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2016%2F12%2F04%2F010652_62019a4104cd76106d6061f48113b671.jpg&h=f13feaad&s={SIZE}\" /><br />\n2016/12/2 第18屆 Mnet Asian Music Awards 最佳年度藝人<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/8Tumf77.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8Tumf77.jpg&h=3a0a1d2e&s={SIZE}\" /><br />\n2017/01/19 第26屆首爾歌謠大賞 本賞、舞蹈表演獎、最佳音樂錄影帶獎、最佳專輯獎<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/5r1FsAn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F5r1FsAn.jpg&h=00e4655f&s={SIZE}\" /><br />\n2017/02/22 第6屆Gaon Chart Music Awards V LIVE Global Popularity獎、第四季 專輯部門年度歌手獎</div><br />\n<br />\n<br />\n<span style=\"font-size: medium;\">防彈少年團（방탄소년단），簡稱BTS，韓國男子音樂組合，由Jin、SUGA、J-hope、Rap Monster、Jimin、V、Jung Kook七名成員組成，隸屬Big Hit娛樂經紀公司旗下。為Big Hit娛樂第一個獨立製作培養的團體，同時也是知名作曲人與製作人方時赫首次獨立栽培的團體。<br />\n<br />\n防彈有擋住子彈的意思，而防彈少年團的涵義是具有承受像子彈一樣的批評與時代偏見的音樂團體。<br />\n2013年7月9日，公布粉絲官方名稱為「A.R.M.Y（아미）」，同時也是「Adorable Representative M.C for Youth」的縮寫（值得人們景仰的青年代表）。由防彈少年團成員們從大約1000個粉絲意見中，一個一個閱讀後挑選出來。ARMY在英語的意思是軍隊，防彈衣和軍隊總是在一起，所以也有粉絲們一直和防彈少年團一起的意思。</span>"},{"pid":"eb9f65ad37652b64e8984f7db26c146dcaa4580b","tid":236380,"uid":28008,"like":0,"dislike":0,"s