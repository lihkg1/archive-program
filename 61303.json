s://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FtSa0Er5.jpg&h=e24bc2ec&s={SIZE}\" />"},{"pid":"7ed12290eb1472b10d942798cba84045324b42d6","tid":61303,"uid":29278,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T07:08:19.000Z","msg":"邊位巴打咁高壇數<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"5f3440444e94fbe56618c3ab81f196725ec986bc","tid":61303,"uid":2404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T07:16:00.000Z","msg":"狐狸精啊屌<img src=\"/assets/faces/lomoji/33.png\" class=\"hkgmoji\" />"},{"pid":"1b1650e0447c975fe0b642edfa520d5968a856a1","tid":61303,"uid":62030,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T07:16:47.000Z","msg":"睇標題Load 左幾秒，小三仔寫信令300人人人自危？？？"},{"pid":"c184470242cc37eda6562acb5ddb47b2f46bb8ed","tid":61303,"uid":43173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T07:17:04.000Z","msg":"呢單野好耐喎"},{"pid":"df83107bc18257178b3d347ba36e0e0b92538a41","tid":61303,"uid":32723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T07:17:57.000Z","msg":"<blockquote>阿sir包二奶唔駛你教<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n要我<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 另歪面罰企呀拿"},{"pid":"d299782a05079ea4345759aa39bd85c9dd29eacf","tid":61303,"uid":5937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T07:20:26.000Z","msg":"小你老母三咩仲以為講小學三年級<br />\n二奶就二奶 第三者就第三者啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"381b657394077f3da33fec3c8072d03d8f6919d1","tid":61303,"uid":39177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T07:20:28.000Z","msg":"map炮<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1a30e95bd86e68907813a544f79672a3bd72065e","tid":61303,"uid":30710,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T07:25:23.000Z"