ss=\"hkgmoji\" />"},{"pid":"4120165596f7b2724ed82f39db915fda78b033ae","tid":702460,"uid":92611,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-15T04:38:14.000Z","msg":"披區旗好似香港有份踢咁<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"da7cb751c485d696d263b217e9a2d9826145fcf9","tid":702460,"uid":82720,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-15T04:44:50.000Z","msg":"<blockquote>未有打入決賽周的中國隊球迷也甚為搶鏡，他們清一色穿上紅衣，當他們發現4位香港球迷後，就大聲地叫：「香港人嗎？來來來，跟<span style=\"color: red;\">我們中國隊</span>拍個照。」<br />\n<br />\n我屌你老母支那</blockquote><br />\n<br />\n隊你老母咩 世界盃關你地撚事 支國啦啦隊<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"1479defbab25a22b7e472c1102b49f4c4119956f","tid":702460,"uid":33631,"like":4,"dislike":2,"score":2,"quote":{"pid":"6734be0dcf4e1f4e99c5aeffca3a4f667bb5e5a4","tid":702460,"uid":23087,"like":1,"dislike":3,"score":-2,"quote":{"pid":"c0bb354852df62dab51ae3bfb6211bd007465d29","tid":702460,"uid":4917,"like":2,"dislike":0,"score":2,"quote":{"pid":"b9fede8276ffe3893a02db6577c2e9d1f7a94b60","tid":702460,"uid":187076,"like":9,"dislike":1,"score":8,"citedBy":1,"replyTime":"2018-06-15T02:37:06.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/06/15/103704_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F15%2F103704_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=220dab66&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-06-15T02:39:09.000Z","msg":"偷影eason嗰個應該都係vip?"},"citedBy":1,"replyTime":"2018-06-15T03:03:29.000Z","msg":"舉埋中指咁串"},"citedBy":0,"replyTime":"2018-06-15T04:44:51.000Z","msg":"人地走到去俄羅斯睇波都要騷擾人<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f66049d15b1d162e4217421db12ed01095ff927e","tid":702460,"uid":85629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTi