6e0ba962c32ec846e6085457b563710cf9","tid":1775980,"uid":113630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-10T04:31:45.000Z","msg":"甴近平"},{"pid":"bfab028d8aca21763457c8e2f87e6df1f61e8afd","tid":1775980,"uid":113630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-10T04:33:38.000Z","msg":"甴近平"},{"pid":"43b7ffdcdc634a822c7b5ffd91ca610fa8f42fca","tid":1775980,"uid":113630,"like":0,"dislike":0,"score":0,"quote":{"pid":"1884cf56d957b410488b76ab2f67c06d8c947f1b","tid":1775980,"uid":113630,"like":8,"dislike":0,"score":8,"citedBy":3,"replyTime":"2019-12-09T08:08:35.000Z","msg":"剪卡示例<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/rX56ocn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrX56ocn.jpg&h=c100b772&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-12-10T04:34:53.000Z","msg":"<span style=\"font-size: large;\"><span style=\"color: red;\">推到上報：<br />\n瞄準TVB客戶 網民狙擊安信兄弟</span></span><br />\n無綫因新聞內容被指「維穩」，近年經常受到網民批評，有人甚至開設fb專頁，集中狙擊在TVB落廣告的客戶，號召網民洗版、杯葛，最新對象為曾經暫停於無綫落廣告，但最近再度「落稿」的安信兄弟。<br />\n<br />\n籲取消WeWa信用卡<br />\n<br />\n其中一個名為「五毛電視-抵制tvb廣告商」的fb專頁，經常廣邀鍵盤戰士到TVB的廣告客戶專頁「洗版」，要求對方停落TVB廣告，目前已有超過4.3萬人讚好；新近成功狙擊例子為彩豐行，該公司昨天在fb專頁宣佈明年將選擇TVB以外的平台作宣傳渠道。該狙擊專頁昨「乘勝追擊」，要求網民發起「剪卡行動」，抗議安信兄弟再度於無綫落廣告，呼籲網民致電其客戶服務中心、取消該行與中旅社合作推出的WeWa信用卡，並建議將「剪卡」相片上載，務求向對方施壓，打擊貸款及按揭公司這個TVB第二大廣告客源。<br />\n<a href=\"https://hk.appledaily.com/finance/20191210/KL2AO4LRNZD2VVTBGV5EH5IVRQ/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Ffinance%2F20191210%2FKL2AO4LRNZD2VVTBGV5EH5IVRQ%2F&d=2Jo0d4zpMW7MEYOmRW2LdUcTp%2BQsjpNju1TtMRGBB4E%3D&h=87c422d2\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Ffinance%2F20191210%2FKL2AO4LRNZD2VVTBGV5EH5IVRQ%2F&h=18f7005a\" data-auto-link target=\"_blank\">https://hk.appledaily.com/finance/20191210/KL2AO4LRNZD2VVTBGV5EH5IVRQ/</a>"},{"pid":"f8b8a207057bf875e1c8223500796f04805c29af","tid":1775980,"uid":113630,"like