ts/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0b35be57d6ecc9cc7cac2de90152e5e343c56f0f","tid":21320,"uid":42434,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-14T07:22:50.000Z","msg":"上松山燈塔啦<br />\n都唔錯 靜靜地"},{"pid":"54a8b7976da225403b3c9aa7d1a612ddfd224f59","tid":21320,"uid":52910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T18:18:23.000Z","msg":"<blockquote>有間 食蝦子撈麵 炸鯪魚球幾正 但唔記得名 有冇人知邊間<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n係咪聯記？"},{"pid":"806dc68374c37f333ddfa33b77e692165bd1b848","tid":21320,"uid":283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T18:23:44.000Z","msg":"<blockquote><blockquote>有間 食蝦子撈麵 炸鯪魚球幾正 但唔記得名 有冇人知邊間<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n六記</blockquote><br />\n<br />\n六記對面華軒都正野<br />\n冇咩遊客知"},{"pid":"19f0cab8fc0c0f858563cc7c69b159af660c1148","tid":21320,"uid":283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T18:30:01.000Z","msg":"去大三巴附近想食豬扒包<br />\n一定食世記咖啡<br />\n大三巴啲店寫著咩正宗葡撻，豬扒包<br />\n全部都係伏<br />\n葡撻只推薦安德魯， 不過係路環<br />\n瑪嘉烈，狗都不屌"},{"pid":"aebaf8580b2a9e2919746e1b449bb877a1a07f0e","tid":21320,"uid":61988,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T18:59:30.000Z","msg":"留名"},{"pid":"769d237b2d23a25b617a048369836b80666095cd","tid":21320,"uid":14779,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T19:09:32.000Z","msg":"牛記蟹黃撈麵<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"1adbc25ab26db343e7307452f62ceb4ec6e78b35","tid":21320,"uid":22192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T19:36:00.000Z","msg":"<blockquote><blockquote>黑沙灣間西餐廳<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> 不過遠左少少<br />\n有時間可以試下<br />\n<br />\np.s.覺得小飛象果啲退步哂 食翅都唔環保</blockquote><br />\n<br />\n黑沙灣特登入去冇野做</blockquote><br />\n<br />\n去海灣，要打的<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6daa30fc75893e69edb346a3e094c2dbc563fe6f","tid":21320,"uid":22192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-20T19:37:31.000Z","msg":"<blockquote>想食葡國菜可以去媽閣船屋<br />\n如果去過幾次澳門我建議去下其他地方唔好留大三巴，可以帶女朋友上主教山睇夜景<br />\n：澳門人</blockquote><br />\n<br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n去下大炮台，景唔錯，崗頂。。"},{"pid":"6b063162b9df3202a9d598916111e2068e0f2561","tid":21320,"uid":3748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T03:09:51.000Z","msg":"<blockquote><span style=\"font-size: xx-large;\"><span style=\"color: red;\">我都唔明點解咁多香港人鐘意去澳門<br />\n你話要去賭錢叫雞既話，我就冇野好講<br />\n其他既話我諗唔到咩係香港冇澳門有<br />\n睇下香港啲商場，再去睇下澳門果啲<br />\n跟本冇得比<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n落後地方，地方又細，仲要四周圍都係支那人<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> 情況絕對嚴重過香港</span></span></blockquote><br />\n<br />\n總有蠢人去澳門俾狗劏"},{"pid":"56a425e1d98b93761f0044e7d039eaaec4aad4ec","tid":21320,"uid":6267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T03:17:32.000Z","msg":"留番係房交功課啦你"},{"pid":"573c08bd99bf4d0db1d01fef7fa33472911b78ae","tid":21320,"uid":6267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T03:18:19.000Z","msg":"<blockquote>豬扒包去邊間食？<br />\n上網睇有間叫大利，但驚通常吹好大果d都係普通料黎，<br />\n又貴過人</blockquote><br />\n<br />\n其實唔洗突登搵，間間都差唔多"},{"pid":"e39e15634917514dcc76bbccdd4d02071860c14c","tid":21320,"uid":60279,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T03:37:50.000Z","msg":"咖哩文旁邊有間世記<br />\nD野幾好食<br />\n特別係個奶茶 重茶味, 我好鍾意<br />\n<br />\n不過囉唔到番HK"},{"pid":"5b73bae7ca2ac0d3b00649eb9355bccb6a5e7348","tid":21320,"uid":4166,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T03:49:01.000Z","msg":"十月初五街牛雜，不過夜晚先開"}]}