moji\" />"},{"pid":"501e0c095f9ebcc635a2387fb785a4d018de4bee","tid":1588251,"uid":200389,"like":0,"dislike":0,"score":0,"quote":{"pid":"d802664cb4934f030d7a4e62c710fd35e997f66e","tid":1588251,"uid":287384,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-22T18:20:46.000Z","msg":"鐳射筆真係尻叫合唱嘉年華先拎出嚟玩啦<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n實用度低<br />\n又會畀狗咬<br />\n而且買一枝勁既lazer要成3-400蚊<br />\n性價比低到喊<br />\n買枝強光電筒都唔使咁貴<br />\n夜晚拎嚟照明又得<br />\n必要時可以一下照落對家對眼度<br />\n分分鐘有奇效<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-23T18:30:41.000Z","msg":"<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"059c8107e7f30fe9b9826e8716d22760f6929c68","tid":1588251,"uid":5298,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T04:49:09.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"a157f2de565b55fad4f0cf843467be51ee5c126c","tid":1588251,"uid":123615,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T04:51:10.000Z","msg":"電筒用黎射cam一流"},{"pid":"d504343cb170913ed0a0537050f24043708f127d","tid":1588251,"uid":261530,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T15:16:11.000Z","msg":"此回覆已被刪除"}]}