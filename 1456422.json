enger.page</a>"},{"pid":"219d1b762cf5f04db008bba92831f4f22fe1a9b5","tid":1456422,"uid":4357,"like":0,"dislike":0,"score":0,"quote":{"pid":"eaf4bdffbfa1b849ec96769a0de1e8a82d4324df","tid":1456422,"uid":27718,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-12T10:10:31.000Z","msg":"唔女再鳩信人吹風好冇呀"},"citedBy":0,"replyTime":"2019-08-12T10:19:20.000Z","msg":"轉飛有幾難<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"49d4a0997b8a5998aa95de87d2f2c92dc6c0b413","tid":1456422,"uid":283494,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2019-08-12T10:31:10.000Z","msg":"其實大家睇睇機管局網站, 仍有好多貨機今晚升降。取消的主要是客機。"},{"pid":"29101b92c17887e18b3f9bcaf2d608748430ade0","tid":1456422,"uid":4357,"like":2,"dislike":0,"score":2,"quote":{"pid":"49d4a0997b8a5998aa95de87d2f2c92dc6c0b413","tid":1456422,"uid":283494,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2019-08-12T10:31:10.000Z","msg":"其實大家睇睇機管局網站, 仍有好多貨機今晚升降。取消的主要是客機。"},"citedBy":0,"replyTime":"2019-08-12T11:05:09.000Z","msg":"客運大樓點阻貨機呀 P牌仔"}]}