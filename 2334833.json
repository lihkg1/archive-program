m/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" /> 一貫作風"},{"pid":"9d60d88ed0149b26604b79df1594d45def774f30","tid":2334833,"uid":238214,"like":0,"dislike":0,"score":0,"quote":{"pid":"ed692aa457600dbb7940f1ad7ff632eaed0b5a3b","tid":2334833,"uid":66087,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-12-21T12:17:29.000Z","msg":"即係點，支那一夜之間禁左支付寶？<br />\n<br />\n咁香港d支付寶點算？<img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-21T12:23:26.000Z","msg":"唔只係支付寶旗下d金融產品下架<br />\n因為佢出到3-5% 吸用戶在支付寶入邊d錢去投資"},{"pid":"1fc68d7f394a20245074feb90ef578a953b6e098","tid":2334833,"uid":370061,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-21T12:24:44.000Z","msg":"穩定度：-1"},{"pid":"b78f6c0854107f0e4f01261d61ec60931de1be0d","tid":2334833,"uid":284671,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-21T12:25:06.000Z","msg":"共產<img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" />"},{"pid":"743675101b963b66939a996e70c3d76219edae87","tid":2334833,"uid":43173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-21T14:07:17.000Z","msg":"螞蟻都變韮菜<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f931c0234eadb65c28c31a21ae3bbfca60b6a694","tid":2334833,"uid":352873,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-21T14:08:53.000Z","msg":"你班用中資虛擬銀行既撚屌睇路啦<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"98f041c5acefba60f3c4dca53080770990254810","tid":2334833,"uid":278097,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-21T14:17:49.000Z","msg":"幾時用國安法搵晒班水貨佬<br />\n成日用w7收錢"},{"pid":"0c4c558047a25b115a75711f451a873e1c0c02d2","tid":233