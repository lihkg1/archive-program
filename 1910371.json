pid":"be0687d60ff62ee7f247d1b308614f817aa4f4e1","tid":1910371,"uid":169146,"like":22,"dislike":1,"score":21,"citedBy":0,"replyTime":"2020-03-04T16:48:28.000Z","msg":"用你溝佢嗰陣嗰份心去對佢<br />\n唔係話咩都要就晒個女仔<br />\n係心嗰份好著緊佢嘅心"},{"pid":"85b175f0cc09606e97126aa55c75b44bfd75579b","tid":1910371,"uid":244149,"like":14,"dislike":1,"score":13,"citedBy":0,"replyTime":"2020-03-04T17:03:28.000Z","msg":"<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"7cca1074b6b588b2f258f9a055beff11cb673cf5","tid":1910371,"uid":301017,"like":9,"dislike":11,"score":-2,"citedBy":0,"replyTime":"2020-03-04T17:21:56.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"2f52f88b78dac6022be7436ae1447e9326c08291","tid":1910371,"uid":225688,"like":13,"dislike":1,"score":12,"citedBy":0,"replyTime":"2020-03-04T17:22:34.000Z","msg":"唔好冷落女朋友"},{"pid":"9ef78139fe7c170f104951cddbdde033b9f30b7c","tid":1910371,"uid":142522,"like":24,"dislike":2,"score":22,"quote":{"pid":"0fa40efd8f3d2d028b1c436fb9f297c879194eb1","tid":1910371,"uid":240545,"like":44,"dislike":2,"score":42,"quote":{"pid":"d22fe1fede3489c9fb5dede859aea859cd184d25","tid":1910371,"uid":192075,"like":0,"dislike":1,"score":-1,"quote":{"pid":"8e38be745d9d91f57e068c754956986fd175c4a0","tid":1910371,"uid":240545,"like":29,"dislike":2,"score":27,"citedBy":1,"replyTime":"2020-03-04T15:29:38.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-04T15:31:35.000Z","msg":"例如？"},"citedBy":1,"replyTime":"2020-03-04T15:48:34.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-04T17:31:42.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"36ed4b6e24d1f7fda35c653f9330ab7d7779c9ce","tid":1910371,"uid":317104,"like":48,"dislike":1,"score":47,"citedBy":1,"replyTime":"2020-03-04T17:58:55.000Z","msg":"真絲答你 當然答案只供參考 不代表所有女仔<br />\n其實我覺得被珍惜係一種感覺嚟<br />\n有時唔洗真係做好多嘢<br />\n例如出街個陣望少啲電話 互相聽下對方嘅說話<br />\n傾計個陣望住佢 主動拖下/搭下膊頭 最好拖到實一實<br />\nWhatapps唔好已讀不回 有時簡單一句good morning/good night/食咗飯未啊/今日凍咗喎 <br />\n已經可以令對方feel到你有掛住/關心佢<br />\n得閒帶佢去啲平時𠱸唔會去嘅地方行下玩下<br />\n陪另一半影下港女相<img src=\"/assets/faces/lomoji/12.png\" class=\"hkgmoji\" />留低多啲回憶<br />\n生日/情人節整啲小驚喜比對方<br />\n我自己就比較容易滿足 男友12點準時第一個同我講生日快樂我已經好開心<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /><br />\n當然啦 最主要都係你要show到你真心愛佢 <br />\n唔好忽略/唔理佢就得啦<br />\n通常女仔開始覺得冇咁熱戀都係因為你冇好似以前咁關心佢 令佢覺得冷淡咗<br />\n一句講哂 比起物質 有你陪住先係最開心最幸福"},{"pid":"a66093634b1867b90c4617761068b4692bd73a50","tid":1910371,"uid":240545,"like":6,"dislike":0,"score":6,"quote":{"pid":"9ef78139fe7c170f104951cddbdde033b9f30b7c","tid":1910371,"uid":142522,"like":24,"dislike":2,"score":22,"quote":{"pid":"0fa40efd8f3d2d028b1c436fb9f297c879194eb1","tid":1910371,"uid":240545,"like":44,"dislike":2,"score":42,"quote":{"pid":"d22fe1fede3489c9fb5dede859aea859cd184d25","tid":1910371,"uid":192075,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-03-04T15:31:35.000Z","msg":"例如？"},"citedBy":1,"replyTime":"2020-03-04T15:48:34.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-04T17:31:42.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-05T05:45:45.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"756518f3dace7d69ef4fe83b3a2669726bd375c1","tid":1910371,"uid":192075,"like":0,"dislike":1,"score":-1,"quote":{"pid":"a66093634b1867b90c4617761068b4692bd73a50","tid":1910371,"uid":240545,"like":6,"dislike":0,"score":6,"quote":{"pid":"9ef78139fe7c170f104951cddbdde033b9f30b7c","tid":1910371,"uid":142522,"like":24,"dislike":2,"score":22,"quote":{"pid":"0fa40efd8f3d2d028b1c436fb9f297c879194eb1","tid":1910371,"uid":240545,"like":44,"dislike":2,"score":42,"citedBy":1,"replyTime":"2020-03-04T15:48:34.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\