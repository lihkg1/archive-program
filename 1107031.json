i\" />"},{"pid":"289195b5a4e3b23876da9b7879d6f6e51665db55","tid":1107031,"uid":184233,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-04-15T11:22:11.000Z","msg":"男人老狗買樓仲要老母比首期 <img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"},{"pid":"832d105dfe49f0ffb07a5151d110620467285006","tid":1107031,"uid":114728,"like":0,"dislike":0,"score":0,"quote":{"pid":"5688733d26179e711dc31da17b7cae1168b02ac4","tid":1107031,"uid":28331,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2019-04-15T11:12:21.000Z","msg":"首期唔係你俾就叫你老婆收嗲啦<br />\n裙腳仔<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-04-15T11:24:14.000Z","msg":"AGGER<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />  無錢俾無資格出聲<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},{"pid":"2b10beda667db2931f52c9dda4575bacdd8fa42f","tid":1107031,"uid":156121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-15T11:25:02.000Z","msg":"係你老母既問題"},{"pid":"7bb414893f6b995889aa4bcc705063a3b1095944","tid":1107031,"uid":129739,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-15T11:25:03.000Z","msg":"痴撚線"},{"pid":"b226873759648f4df05ecc93a6a0b66f45a4b4f7","tid":1107031,"uid":3807,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-04-15T12:29:48.000Z","msg":"呢個post完全體現左連登仔點樣「講就天下無敵」"},{"pid":"4a1f56d808d8ad91177345f3ca3dfb09ea4cd3a3","tid":1107031,"uid":122936,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-04-15T12:31:41.000Z","msg":"你老婆就收皮啦<br />\n奶奶出首期帶親戚上黎睇下都唔想<br />\n有本事就佢自己出錢 可以門都唔比奶奶入"},{"pid":"37143f939f98b530a8f4173c69534ef431574da0","tid":1107031,"uid":13860,"like":0,"dislike":0,"score":0,"quote":{"pid":"506eae10e8736bccf3afa3f03f59e2523fe8c625","tid":1107031,"uid":173216,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-04-15T03:10:46.000Z","msg":"<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />本來同老婆已經睇中左個單位，但落訂前老母帶埋兩個親戚話幫下眼，我老婆好抗拒但我老母堅持要都冇辦法，最尾上到去兩個親戚基本上都無讚過任何野，只係話嗰到唔掂邊到唔得，最尾搞到老母都覺得風水唔好，叫我揀過另一個單位...<br />\n<br />\n吊，呢個單位我同老婆揀左兩個月先睇中，個價同地點係好岩我地，邊有咁易再揀過<img src=\"/assets/faces/fs/superman.gif\" class=\"hkgmoji\" /> 但首期老母俾，冇辦法，但我決定下次死都唔俾d 19親戚上黎睇了..."},"citedBy":0,"replyTime":"2019-04-15T12:38:37.000Z","msg":"老母：陳師奶，唔該哂你呀，一陣飲茶食多d<br />\n陳師奶：客咩氣呀<br />\n黃師奶：咪就係，上次我地都係用呢招幫陳師奶個仔揀樓<br />\n陳師奶：咁d後生要民主丫嘛"},{"pid":"2725d775b2be1aaa0fd6fe09d818ab0c0ab04d27","tid":1107031,"uid":214534,"like":5,"dislike":4,"score":1,"quote":{"pid":"289195b5a4e3b23876da9b7879d6f6e51665db55","tid":1107031,"uid":184233,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-04-15T11:22:11.000Z","msg":"男人老狗買樓仲要老母比首期 <img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-04-15T12:49:24.000Z","msg":"<span style=\"font-size: large;\"><span style=\"color: red;\">其實我身邊既中學同學 大學同學<br />\n幾乎個個近幾年結到婚既全部都係買到樓既<br />\n仲要好多全部都係靠老豆老母<br />\n佢地直頭唔怕講出口，都係靠屋企人幫手咁<br />\n個老婆都係中上樣，有一兩個女神級(個男都唔差)<br />\n啲男人有幾個既IG仲要平時成日旅行豪洗<br />\n<br />\n老老實實<br />\n2019年有父幹母幹先係皇道<br />\n俾完首期基本上只係得供樓洗費，你人生已經輕鬆好多<br />\n<br />\n你估好似啲公屋窮撚同埋佢地既父母呢世人乜都冇野俾到仔女<br />\n仲要個個月追佢家用咩<br />\n呢啲真係拖仔女後腿 養兒防老喇<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><br />\n</span></span>"},{"pid":"b641fe827fc04f1fd3c0fe509c0566b1c0a8dcbb","tid":1107031,"uid":101291,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-15T13:01:09.000Z","msg":"其實佢唔想比，搵d親戚黎唱雙黃。"},{"pid":"62d9abb29ef823ffcad6e709eded0f4ecc059c17","tid":1107031,"uid":193131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-15T13:02:39.000Z","msg":"靠母幹，佢要你交埋條匙比佢自出自入，你都冇得say no呀"},{"pid":"a684b8c6c5fee88a7429e71e09582b7487f40fe1","tid":1107031,"uid":55851,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-04-15T13:33:25.000Z","msg":"自己儲首期囉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />你而家要靠老母，預咗比佢揸實春袋架喇<img src=\"/assets/faces/