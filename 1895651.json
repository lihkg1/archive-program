d":43413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T16:37:33.000Z","msg":"我想講&mdash;&mdash;文宣手足從來無放棄過！有新職業介紹，入黎掙扎！！<br />\n<a href=\"https://lih.kg/1895551\" data-auto-link target=\"_blank\">https://lih.kg/1895551</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"0c9ecba0d7283776171648c13802cf909e40f435","tid":1895651,"uid":43413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T16:38:16.000Z","msg":"【香港民族】天琦話睇完呢本書之後充滿力量<br />\n<a href=\"https://lih.kg/1895346\" data-auto-link target=\"_blank\">https://lih.kg/1895346</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"78f19026a64e7cb93f56912b976e805fdc9bd6ab","tid":1895651,"uid":9480,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T16:38:52.000Z","msg":"推！麻煩大家真係睇哂佢"},{"pid":"1aa2225035d36d83310c094ea21825c33261ffc4","tid":1895651,"uid":43413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T16:41:23.000Z","msg":"push"},{"pid":"271330f7afbf3b57340282355e156eb692d66165","tid":1895651,"uid":43413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T16:56:34.000Z","msg":"push"},{"pid":"a4845373d9109a27ab2cbb643de561beeee60ccc","tid":1895651,"uid":34184,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-24T17:16:50.000Z","msg":"<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},{"pid":"ee9f046e461fe925a6a213081260897012d3ce7a","tid":1895651,"uid":43413,"like":0,"dislike":0,"score":0,"quote":{"pid":"a4845373d9109a27ab2cbb643de561beeee60ccc","tid":1895651,"uid":34184,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-24T17:16:50.000Z","msg":"<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-24T17:24:33.000Z","msg":"保你老帽？"},{"pid":"fb73308d43efb63e3eeda463a26e13959115612a","tid":1895651,"uid":43413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T17:44:58.000Z","msg":"push"},{"pid":"f1d50784718bfdd3eeed4aaca2a70672d2440cc0","tid":1895651,"uid":205566,"lik