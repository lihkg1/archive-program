09.000Z","msg":"實則虛之, 虛則實之"},"citedBy":1,"replyTime":"2019-09-17T03:57:33.000Z","msg":"點呀大師 講白啲得唔得呀小弟冇你咁高智慧"},{"pid":"0724c4288a3c10161c18a8d2b42ccae707dcba2d","tid":1575830,"uid":155167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T03:58:06.000Z","msg":"推"},{"pid":"d6f62e2576357e3dcc67db790f834c223f4b1b6c","tid":1575830,"uid":212070,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-17T04:01:19.000Z","msg":"我覺得入機場就應該有心理準備要攬炒,如果唔係可以唔入住"},{"pid":"9aabd5babd6745cca0ec8f2efcc3723f4b657da9","tid":1575830,"uid":104454,"like":1,"dislike":0,"score":1,"quote":{"pid":"4ad75c03f5580e4e975c55782158ba4559e16d70","tid":1575830,"uid":196450,"like":0,"dislike":0,"score":0,"quote":{"pid":"b2a12bba399960ec9a84e4addb1aabae6dc00b4d","tid":1575830,"uid":160294,"like":4,"dislike":1,"score":3,"citedBy":2,"replyTime":"2019-09-17T03:47:06.000Z","msg":"Agger <br />\n一開始係成功 <br />\n但黎到呢個地步效用唔高 <br />\n唔好留戀"},"citedBy":2,"replyTime":"2019-09-17T03:57:00.000Z","msg":"效用一直都高，因為只要癱左機場，政府就玩完<br />\n<br />\n知唔知點解一次難過一次入去？<br />\n因為政府如果俾我地入左去<strong>佢 無 辦 法 分 辨 遊 客 同 示 威 者 所 以 無 辦 法 清 場 呀</strong>！<br />\n所以只能夠做預防手段唔俾人入去！<br />\n<br />\n又，知唔知有無諗過點解政府可以一次又一次升級預防手段？<br />\n因為每次都入一入去就有『散水撚』叫走呀！！<br />\n第一次非常容易入去，走左，下次政府升級預防手段<br />\n第二次，又入左去，走左，政府又再升級預防手段<br />\n第三次，辛苦終於入到去，乜都唔做，再走，政府又再升級預防手段<br />\n<br />\n到底想Loop幾多次呀？散水撚<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n實際上只要搵一次全部人入到機場之後直接癱瘓佢到政府跪低就贏左，就係因為散水撚一次又一次拖後腳幫政府安然渡過危機先搞到越黎越難搞春袋！<br />\n<br />\n知唔知香港人而家要咩呀？要贏呀！敵人明知個度係弱點梗係重兵防守啦，但你要贏梗係要攻打弱點啦，咁簡單既道理都唔明？"},"citedBy":2,"replyTime":"2019-09-17T04:05:36.000Z","msg":"咁實際上點解決真係冇人敢再去既問題先<img src=\"/assets/faces/mf/clown.gif\" class=\"hkgmoji\" />大家都知係春袋 但上星期真係冇人敢再去<br />\n<br />\n你口中既散水撚只係因為去到現場真係見到唔work先走<br />\n<br />\n你答我幾個問題：<br />\n1.佢t1 t2封哂，全部人係哂室外，佢可以用催淚彈驅散，點解決？<br />\n<br />\n2.支援慢，塞死哂，根本唔夠時間去聚到好多人就俾人驅散咗先<br />\n<br />\n3.結果又散番哂去東涌，啲人又係出面塞緊，佢係依個時間圍捕好易，我相信佢下次升級就會拉幾百個，點解決？"},{"pid":"e3aa6ddaca2df3891a5f3fd7ead57fa1b6e16396","tid":1575830,"uid