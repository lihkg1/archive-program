br />\n先前有報導說，蘋果也在開發圖像處理器、數據機和電源管理等晶片。（吳國仲╱綜合外<br />\n電報導）<br />\n<br />\n<a href=\"https://tw.finance.appledaily.com/realtime/20190330/1542505/?itm_source=twad_web&amp;itm_medium=internal&amp;itm_campaign=twad_marquee&amp;itm_content=marquee\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.finance.appledaily.com%2Frealtime%2F20190330%2F1542505%2F%3Fitm_source%3Dtwad_web%26itm_medium%3Dinternal%26itm_campaign%3Dtwad_marquee%26itm_content%3Dmarquee&d=Ru8OiKpQtXbNv5YRwinC6jcyzTZykTUlxRhnZlW9F%2Bg%3D&h=097ce578\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftw.finance.appledaily.com%2Frealtime%2F20190330%2F1542505%2F%3Fitm_source%3Dtwad_web%26itm_medium%3Dinternal%26itm_campaign%3Dtwad_marquee%26itm_content%3Dmarquee&h=98cac6ab\" target=\"_blank\">https://tw.finance.appledaily.com/realtime/20190330/1542505/?itm_source=twad_web&amp;itm_medium=internal&amp;itm_campaign=twad_marquee&amp;itm_content=marquee</a>"},"citedBy":0,"replyTime":"2019-03-30T10:36:09.000Z","msg":"有個仲勁人入去做"},{"pid":"9bc3d8998ec953797958ebe9d33c1d580121afbe","tid":1084302,"uid":134522,"like":2,"dislike":8,"score":-6,"citedBy":0,"replyTime":"2019-03-30T10:55:32.000Z","msg":"Apple依家最勁就係得返cpu..."},{"pid":"bc499d9374d8a7c54639bba8335343fa7273b185","tid":1084302,"uid":219081,"like":2,"dislike":5,"score":-3,"citedBy":0,"replyTime":"2019-03-30T11:02:34.000Z","msg":"冇架啦，俾apple完啦好嘛"},{"pid":"7883e31017c53770857392799f07cb67b811dee7","tid":1084302,"uid":68094,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-03-30T11:04:00.000Z","msg":"此回覆已被刪除"},{"pid":"08252840ec557922c5d151a08691c96eff62a219","tid":1084302,"uid":214926,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-30T11:09:03.000Z","msg":"有人走有人入嘅啫<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"e6b81cf3a1957a5cf34254681f992bc2a1e7ab4c","tid":1084302,"uid":147097,"like":0,"dislike":1,"score":-1,"quote":{"pid":"08252840ec557922c5d151a08691c96eff62a219","tid":1084302,"uid":214926,"like"