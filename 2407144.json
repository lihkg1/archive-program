ji\" />"},{"pid":"181d3885a0bbe62dfe3e38f15886078aae0fabfd","tid":2407144,"uid":112551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-18T17:26:09.000Z","msg":"中出即飛"},{"pid":"4bfe57f607df8e33f087ab568f9f19cc690cf2b3","tid":2407144,"uid":210338,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2021-02-18T18:44:48.000Z","msg":"一直都以為段感情好順利<br />\n直到我開始攰，先發現我其實對對方有好多不滿，好多擔憂，但我又會下意識幫對方諗藉口。表面上我好似好善解人意，好就得人咁，但事實我連自己都呃左<br />\n一大堆火藥，加個導火線，我就講分手。<br />\n對方仲好驚訝，好似嘈交嘈唔夠一兩次就火速比人飛咁。"},{"pid":"820b72e6d99eb2e531d3827ab413ca69ea1f6ffc","tid":2407144,"uid":358559,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-02-18T18:50:36.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"c4374e2585f2ed26c13729336b7e4493d1946af4","tid":2407144,"uid":311609,"like":0,"dislike":0,"score":0,"quote":{"pid":"5ca70657c946abcd74b40aa7a51609a93032ece7","tid":2407144,"uid":158493,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-02-18T17:02:53.000Z","msg":"太熟對方 變左親人而唔係情侶 4年半"},"citedBy":1,"replyTime":"2021-02-18T19:29:12.000Z","msg":"我都係咁 話慣左 唔似情侶<br />\n原來平淡唔係一件好事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"25c8b0439ecfd956b5ce746cbd0494fc0ad26045","tid":2407144,"uid":196512,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-18T20:21:55.000Z","msg":"因為佢覺得我唔體諒佢<br />\n但其實我已經每件事都以佢為先<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n又話係累積落嚟既<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"1f215c8c05c250294eaccfbbe73fe4760607efe8","tid":2407144,"uid":271223,"like":0,"dislike":0,"score":0,"quote":{"pid":"918647155025dbe753a96bbea1521950e04ecdc2","tid":2407144,"uid":290760,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c31630c273c42b3bbadc01d14ab996d7d226f7b","tid":2407144,"uid":37328,"like":0,"dislike":0,"score":0,"quote":{"pid":"5b23b64f2342b99ed713a6c6cf9eea8db1325ab3","tid":2407144,"uid":290760,"like":0,"dislike":0,"score":0,"citedBy":