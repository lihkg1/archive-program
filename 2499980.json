5.gif&h=abcaac4b&s={SIZE}\" />"},{"pid":"77790cd42acd65071c076de56d9dc7ec51538dab","tid":2499980,"uid":201299,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T12:05:33.000Z","msg":"old news is so"},{"pid":"ec3899cb2e21c4dd988c105c535b4937e9f02700","tid":2499980,"uid":265338,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-04-22T12:05:57.000Z","msg":"幾成熟...下次醒少少啦"},{"pid":"f2b4d9dbe31970dfa925e86cd16df87e7a39b53b","tid":2499980,"uid":108756,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T12:06:23.000Z","msg":"睇到標題已經諗緊屌唔撚係又黎呀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"db562e8fa1c27b24060ba862bca082cfef3ea1c7","tid":2499980,"uid":142368,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-04-22T12:09:25.000Z","msg":"零分重作"},{"pid":"682e37b5cd1fa59a935cd5bd86fe0551e3630c2d","tid":2499980,"uid":236991,"like":0,"dislike":2,"score":-2,"quote":{"pid":"84b1ab55b372ee66ed5aa2fa125c9ecb2a7577ac","tid":2499980,"uid":326472,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-22T09:34:50.000Z","msg":"本來今日條女生日 比佢話事揀去邊到食飯 今次仲要係我請<br />\n<br />\n條仆街就揀左間好撚貴既西餐廳 我都唔撚識讀間餐廳既名 我見一塊死人扒都成幾百蚊<br />\n<br />\n但見條女生日 好 今日我忍9你 <br />\n<br />\n入到去 我就同女朋友坐左係個卡位到 個WAITER(鬼佬)走埋黎問:what can I help you?<br />\n<br />\n雖然我英文真係中一二程度 不過喱句都唔算難到我 <br />\n<br />\n我女朋友用英文話 想要拎個MENU睇睇 <br />\n<br />\n由於入面全部英文我都唔多識 所以我就話跟女朋友點餐 佢要咩我要咩就算<br />\n<br />\n個鬼佬又走番埋黎問左句野 我剩係聽到:what xxxxxxxxxxxxxxxx like?<br />\n<br />\n我女友就點左2個DINNER SPECIAL 之後個鬼佬又問:what xxxxxxxxxxxxxxxxxxxxx?<br />\n<br />\n我仍然係聽唔明 女友就同佢講:WELL DONE!<br />\n<br />\n我聽到喱到我大約就GET到 我估個鬼佬問佢覺得喱間餐廳既質素/員工服務/態度點 因為我見女友都讚佢<br />\n<br />\n個鬼佬轉另轉頭問我:whatxxxxxxxxxxxxxxxxxxxxxxxxx?<br />\n<br />\n我好自豪 充滿自信 大大聲答: GOOD JOB!!<br />\n<br />\n個鬼佬就呆哂 唔明我無啦啦做乜講GOOD JOB咁 <br />\n<br />\n女友見到 即刻幫我答:WELL DONE <br />\n<br />\n個鬼佬點點頭 就行左去 我其實到而家都唔明白 到底讚外國人係咪一定要用WELL DONE?<br />\n<br />\n點解講GOOD JOB佢反而又呆哂又聽唔到咁既  有冇巴打可以幫幫手教我"},"citedBy":0,"replyTime":"2021-04-22T12:10:47.000Z","msg":"Well done = 你塊扒要全熟"},{"pid":"2dfe64694ee8f2395701d0b0579393f09057af7b","tid":2499980,"uid":229712,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-04-22T12:11:32.000Z","msg":"成班新會然<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"bf9036f05035745dceaebccfe21b9d58ba4c40e9","tid":2499980,"uid":1658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-22T12:11:54.000Z","msg":"沒自信的毒男"}]}