 />"},{"pid":"bf6ed79a21caf75f362d7bcb0b0e334e879c19ec","tid":742914,"uid":74435,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-16T19:09:44.000Z","msg":"<a href=\"https://www.xuehua.us/2018/07/12/《扶摇》宗越怎么知道扶摇是真佛莲-宗越还有什么/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.xuehua.us%2F2018%2F07%2F12%2F%E3%80%8A%E6%89%B6%E6%91%87%E3%80%8B%E5%AE%97%E8%B6%8A%E6%80%8E%E4%B9%88%E7%9F%A5%E9%81%93%E6%89%B6%E6%91%87%E6%98%AF%E7%9C%9F%E4%BD%9B%E8%8E%B2-%E5%AE%97%E8%B6%8A%E8%BF%98%E6%9C%89%E4%BB%80%E4%B9%88%2F&d=NfhGcV7ouBHz7GOcl1%2FIvP755KD0hvcRsprRlRVhNBc%3D&h=4af4dd0f\" target=\"_blank\">https://www.xuehua.us/2018/07/12/《扶摇》宗越怎么知道扶摇是真佛莲-宗越还有什么/</a><br />\n可能跟小說<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />  所以佢一早就知<br />\n<span style=\"color: pink;\"><span style=\"font-size: x-small;\">宗越係殺扶搖老母嘅殺手，帶扶搖上玄元山都係佢，扶搖真身係佛蓮，依家個佛蓮係扶搖家姐，即係無極當初婚約係扶搖</span></span>"},{"pid":"01861d35b8330675ec43973e044764b64885589a","tid":742914,"uid":81486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-01T19:24:42.000Z","msg":"岩岩睇到58集,真係無人睇大陸劇<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <br />\n套劇D場景道具<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 演員劇本各方面都唔錯<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n楊冪有幾場戲,真係高汁<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> 大家真係可以追"},{"pid":"68a3f72a24916a0c6a2e2d71bbc302fee3f0b724","tid":742914,"uid":107605,"like":0,"dislike":0,"score":0,"quote":{"pid":"bf6ed79a21caf75f362d7bcb0b0e334e879c19ec","tid":742914,"uid":74435,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-16T19:09:44.000Z","msg":"<a href=\"https://www.xuehua.us/2018/07/12/《扶摇》宗越怎么知道扶摇是真佛莲-宗越还有什么/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.xuehua.us%2F2018%2F07%2F12%2F%E3%80%8A%E6%89%B6%E6%91%87%E3%80%8B%E5%AE%97%E8%B6%8A%E6%80%8E%E4%B9%88%E7%9F%A5%E9%81%93%E6%89%B6%E6%91%87%E6%98%AF%E7%9C%9F%E4%BD%9B%E8%8E%B2-%E5%AE%97%E8%B6%8A%E8%BF%98%E6%9C%89%E4%BB%80%E4%B9%88%2F&d=NfhGcV7ouBHz7GOcl1%2FIvP755KD0hvcRsprRlRVhNBc%3D&h=4af4dd0f\" target=\"_blank\">https://www.xuehua.us/2018/07/12/《扶摇》宗越怎么知道扶摇是真佛莲-宗越还有什么/</a><br />\n可能跟小說<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />  所以佢一早就知<br />\n<span style=\"color: pink;\"><span style=\"font-size: x-small;\">宗越係殺扶搖老母嘅殺手，帶扶搖上玄元山都係佢，扶搖真身係佛蓮，依家個佛蓮係扶搖家姐，即係無極當初婚約係扶搖</span></span>"},"citedBy":0,"replyTime":"2018-08-01T19:47:56.000Z","msg":"啱啱睇完最新嗰集<br />\n唔想爆雷 是非題啦<br />\n劇集版內容：<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<blockquote><span style=\"font-size: x-small;\">宗越係殺扶搖老母嘅殺手 -&gt; F<br />\n帶扶搖上玄元山都係佢-&gt; ? 無講<br />\n扶搖真身係佛蓮-&gt; T 不過劇集版其實好似直到最新一集都唔用佛蓮稱呼扶搖，似係二王女既別名多啲<br />\n依家個佛蓮係扶搖家姐 -&gt; 表姐妹, 同一個時辰出世, 唔同老母。劇情描述唔詳細，我推斷唔係同一個老豆，因為係既話現女王應該會強調呢個point。<br />\n即係無極當初婚約係扶搖-&gt; 婚約從來唔係扶搖。訂婚約既時候已經大個左，太子部份原因係為兩國聯姻，順便保埋二王女條命。太子鍾意細個遇到既女仔，但個女仔係唔係二王女，佢都唔係好sure，收到信物所以當住係先，其實一直都無完全確信，同埋對大個既佛蓮無feel。婚約一半為兒時情，一半為國利</span><br />\n</blockquote>"},{"pid":"bd949dbf5055e132bf68de9548dc2ca39cf5251b","tid":742914,"uid":97104,"like":0,"dislike":0,"score":0,"quote":{"pid":"f8c3cf2e69f1a4adb5a1aa3009b9b489020af234","tid":742914,"uid":173487,"like":1,"dislike":0,"score":1,"quote":{"pid":"d030144b1e36fc88ec33cfb84bf0e3a2759af2a8","tid":742914,"uid":191199,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-16T04:22:40.000Z","msg":"有講咩？ 唔係話佢扮佛連住係佢屋企"},"citedBy":1,"replyTime":"2018-07-16T13:47:56.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/07/16/214741_92b4cb201989ab944b73613bdb5fefd3.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F16%2F214741_92b4cb201989ab944b73613bdb5fefd3.png&h=a7a92025&s={SIZE}\" /><br />\n<br />\n就係唔明<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-02T01:43:33.000Z","msg":"佢係講無極未知扶搖扮佛蓮哥陣"},{"pi