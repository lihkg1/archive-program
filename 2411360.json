5614cf0a4ac48360ab10e8311dbf8","tid":2411360,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-17T11:49:17.000Z","msg":"<img src=\"/assets/faces/lny/devil.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},{"pid":"674c60522e37713caa805f274d8a89777546e7e9","tid":2411360,"uid":304431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-17T11:51:16.000Z","msg":"五毛：經濟圈冇用"},{"pid":"1e016b642144d92f3e9ac641cfb7fd8b8e99a64e","tid":2411360,"uid":69746,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ad1007fdb351cb7bc2f0d63313be5de432d17e8","tid":2411360,"uid":34804,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2021-02-17T09:42:55.000Z","msg":"習大大果然係天選之人<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n明明對自己無好處都搞到人要反中<img src=\"/assets/faces/mouse/ohyes.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-17T11:51:58.000Z","msg":"習：唔周圍樹敵點顯得我國強大<img src=\"/assets/faces/cow/power.gif\" class=\"hkgmoji\" />"},{"pid":"6d18b55e4ddf65ffca8655198cc21908bfb01d6c","tid":2411360,"uid":76591,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a7a4136f5973458b51dddefc2d7def1579e361c","tid":2411360,"uid":261937,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-17T10:16:45.000Z","msg":"緬甸玉石加到天價俾支那人接啦<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-17T11:53:46.000Z","msg":"緬北D武裝份子好似親中國<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"3221a1688dbc9bdb946cb633c3303ec52f78006d","tid":2411360,"uid":288913,"like":1,"dislike":0,"score":1,"quote":{"pid":"e207376acce4ee95f6cef5775a78d1d7368d9de2","tid":2411360,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-17T09:24:46.000Z","msg":"緬甸2月1日爆發軍事政變，實質領導人翁山蘇姬（Aung San Suu Kyi）及政府高層被指控「選舉舞弊」並遭到逮捕，16日軍方再以違反《自然災害管理法》提出第二項告訴。<br />\n<br />\n儘管軍方強力鎮壓，緬甸民眾持續在街頭抗議，他們的怒火甚至燒向中國。<br />\n<br />\n英國《金融時報》報導，示威者聚集在中國駐仰光大使館外，抗議北京在背後推動軍事政變，而緬甸目前領導人三軍總司令敏昂來（Min Aung Hlaing）是中國國家主席習近平的魁儡。<br />\n<br />\n網路上也有人發起「抵制中國產品」運動，甚至號召破壞連接中國雲南和緬甸若開邦皎漂（Kyaukpyu）深水港的中緬油氣管道，它是中國一帶一路在緬甸重要能源基建，政變爆發前中國才宣布將增資擴建該港。<br />\n<br />\n中國在背後搞鬼？學者駁：翁山蘇姬與北京關係良好<br />\n<br />\n華府智庫史汀生研究中心（Stimson Center）中國研究主任孫韻（Yun Sun）表示，緬甸民眾覺得是中國拋棄了翁山蘇姬，近日境內開始出現針對中國人的仇恨言論，還有人揚言攻擊中國公民或中國建案。<br />\n<br />\n緬甸軍方日前切斷網路，民眾懷疑他們意圖在中國幫助下打造緬甸版「網路長城」，社群網路上盛傳多架來自中國昆明的貨機在仰光降落，運載斷網所需設備及技術人員，甚至是解放軍。<br />\n<br />\n緬甸軍方發言人16日否認受到中國幫助，指斷網這種事緬甸自己也做得到；中國駐緬甸大使陳海、緬甸中華總商會也斥之為無稽之談，他們解釋這些都是正常貨運航班，載運緬甸出口水產。<br />\n<br />\n陳海應和中國外交部聲明，強調北京對政變事先並不知情，他們絕對不樂見當前形勢。<br />\n<br />\n中國是否是緬甸軍事政變幕後推手，引起許多揣測，然而香港大學政治與公共行政系助理教授韓恩澤指出，翁山蘇姬當政時中緬關係穩定，「看不出中國有什麼理由希望軍方回歸，而且（若支持軍方政變）還可能面臨制裁等後果」。<br />\n<br />\n緬甸變天，中國仍未定調「政變」<br />\n<br />\n至今中國仍不願以「政變」指稱緬甸政治變天，孫韻對《美國之音》表示，中國與緬甸軍方以及翁山蘇姬的全國民主聯盟皆關係良好，北京可能足以勝任居中協調的角色，但也因兩邊都不想得罪而態度曖昧。<br />\n<br />\n緬甸軍事政變後，北京時不時釋出截然相反的矛盾訊息，也因此加深緬甸民眾的疑慮。<br />\n<br />\n政變爆發之初《新華社》以重大內閣改組形容翁山蘇姬被捕，而在聯合國安理會上中國、俄國一起否決了譴責緬甸政變的決議案，之後卻又參與安理會聲明，呼籲立即釋放翁山蘇姬等人。<br />\n<br />\n中俄原本也支持聯合國人權理事會要求釋放翁山蘇姬的決議案，但接著又退出，態度相當反覆。<br />\n<br />\n中國駐聯合國大使陳旭一方面指這是「緬甸內政」不便介入，一方面又說北京正與其他利益關係方合作，希望能讓緊繃態勢回歸正常。<br />\n<br />\n北京立場曖昧，美國國務院發言人普萊斯（Ned Price）16日表示美方「清楚表達我們希望中國在這件事能扮演有建設性的角色」，並指國務院會繼續敦促中國譴責緬甸軍方。<br />\n<br />\n<a href=\"https://tw.news.yahoo.com/緬甸政變激起民眾反中情緒-號召抵制中貨-破壞-帶-路輸油管-065718940.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.news.yahoo.com%2F%E7%B7%AC%E7%94%B8%E6%94%BF%E8%AE%8A%E6%BF%80%E8%B5%B7%E6%B0%91%E7%9C%BE%E5%8F%8D%E4%B8%AD%E6%83%85%E7%B7%92-%E8%99%9F%E5%8F%AC%E6%8A%B5%E5%88%B6%E4%B8%AD%E8%B2%A8-%E7%A0%B4%E5%A3%9E-%E5%B8%B6-%E8%B7%AF%E8%BC%B8%E6%B2%B9%E7%AE%A1-065718940.html&d=bV20Ktv%2Bt3m81RcJrVEN29Dxg6radaiL0c7rOhjaEfM%3D&h=76a5246e\" target=\"_blank\">https://tw.news.yahoo.com/緬甸政變激起民眾反中情緒-號召抵制中貨-破壞-帶-路輸油管-065718940.html</a>"},"citedBy":0,"replyTime":"2021-02-17T11:54:42.000Z","msg":"應該學印尼