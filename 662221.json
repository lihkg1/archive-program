3b58903846e4e3","tid":662221,"uid":56684,"like":3,"dislike":28,"score":-25,"quote":{"pid":"a119f3f073608d4c27be253cd1ea45f0960447f6","tid":662221,"uid":133883,"like":31,"dislike":2,"score":29,"citedBy":2,"replyTime":"2018-05-12T08:55:50.000Z","msg":"屌我都試過俾同性同學表過白"},"citedBy":2,"replyTime":"2018-05-12T09:04:01.000Z","msg":"我呢個係真係好撚好撚friend<br />\n我諗我起碼有一半係嬲佢咁做破壞緊我地關係"},"citedBy":1,"replyTime":"2018-05-14T06:03:55.000Z","msg":"名唔可以講多啲想了解下"},{"pid":"43c5e5d306923cd09033982fdf8225f54e6aeb35","tid":662221,"uid":56684,"like":0,"dislike":4,"score":-4,"quote":{"pid":"9076df4f7edbeefa4921e5fcaac3b97baa8599ad","tid":662221,"uid":54927,"like":0,"dislike":0,"score":0,"quote":{"pid":"38c76c8710467910598623c0353b58903846e4e3","tid":662221,"uid":56684,"like":3,"dislike":28,"score":-25,"quote":{"pid":"a119f3f073608d4c27be253cd1ea45f0960447f6","tid":662221,"uid":133883,"like":31,"dislike":2,"score":29,"citedBy":2,"replyTime":"2018-05-12T08:55:50.000Z","msg":"屌我都試過俾同性同學表過白"},"citedBy":2,"replyTime":"2018-05-12T09:04:01.000Z","msg":"我呢個係真係好撚好撚friend<br />\n我諗我起碼有一半係嬲佢咁做破壞緊我地關係"},"citedBy":1,"replyTime":"2018-05-14T06:03:55.000Z","msg":"名唔可以講多啲想了解下"},"citedBy":2,"replyTime":"2018-05-14T06:57:39.000Z","msg":"可能睇到最後你會覺得嘥左你時間<br />\n我首先講句唔好意思同多謝你畀位我講先<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n大概係咁既<br />\n咁呢位朋友本身就喺街到撩我先既<br />\n識左一排就開始拍拖<br />\n但拍左冇耐拖佢就飛鳩咗我<br />\n話覺得同我之間既感情唔係愛情 想同我做返朋友<br />\n我果時一黎因為本身朋友少<br />\n二黎我諗住繼續留喺佢身邊可能以後都會有機會<br />\n所以就繼續同佢做朋友<br />\n<br />\n咁做左幾年朋友其實頭果三四年我都未放低晒<br />\n咁有時我地都會做d曖昧野 但係可能我地大家既性格都係比較隨性<br />\n所以都唔係真係為咗令對方誤會而做 <br />\n係有時真係太撚close先做到咁<br />\n但其實呢幾年佢都有鐘意過唔同既女仔 都話同我冇發展既機會架喇<br />\n佢次次講親我都好撚嬲 心諗：屌 你又知我想同你發展<br />\n我唔知佢係真係睇得出我果時仲對佢有啲留戀定點<br />\n總之佢周不時會咁樣刮醒我<br />\n<br />\n之後我都拍咗幾次拖 其實對佢都真係慢慢冇乜感覺<br />\n可能因為識既人同經歷既野多咗 或者同佢一齊既時間長咗 或者畀佢刮刮吓刮醒咗<br />\n捱過左果段仲會成日諗住佢既時間之後就變到真係珍惜佢呢個人 多過珍惜佢對我既愛<br />\n<br />\n不過到自己察覺到自己放低左之後就變到有d睇唔起自己<br />\n因為我諗起以前對佢咁好 唔係因為我作為一個朋友鐘意佢<br />\n而係我仲係想喺佢身上得到回報<br />\n咁當然最後因為我係個冇膽既人所以我都冇講到出口 冇要求到任何野<br />\n而最後我地變左做好好既朋友 我諗真係意外<br />\n<br />\n其實半年前我都仲鐘意緊佢<br />\n果時成日聽張懸首艷火<br />\n仲會幻想可能我等等吓佢就會另返轉頭<br />\n而我會一路企定定喺原地等佢<br />\n到時我地就可以變返以前咁 但係其實以前都冇乜好事發生過<br />\n而到佢好似想另返轉頭既時候我都已經唔需要<br />\n可能我需要嬲既係當時咁懦弱 而依加都咁懦弱唔想面對既自己<br />\n嬲佢令我又一次更加強烈咁了解到自己可以控制既事係好少好少"},{"pid":"5dd082b20c95485f770a6c76554b9f0f097359fd","tid":662221,"uid":47492,"like":0,"dislike":0,"score":0,"quote":{"pid":"682f61618973e797f7674ba69e591e8ae817ff2c","tid":662221,"uid":56684,"like":0,"dislike":1,"score":-1,"quote":{"pid":"1f3351edb5c79e86a064f70dfdc69295e0223cbb","tid":662221,"uid":9136,"like":0,"dislike":0,"score":0,"quote":{"pid":"2a596b4088436a61ee67254b90331b478bbb4288","tid":662221,"uid":56684,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-05-14T00:53:10.000Z","msg":"大概係咁 以前畀佢抽水都覺得冇乜野 friend丫嘛 屌"},"citedBy":1,"replyTime":"2018-05-14T02:40:47.000Z","msg":"點抽你水<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-05-14T05:50:26.000Z","msg":"之前同佢去旅行 因為得一張雙人床咁就一齊瞓<br />\n頭幾晚佢都攬住我瞓 咁我就係咁縮既<br />\n果排佢話佢唔開心想攬住人瞓<br />\n但我當時覺得唔對路就叫佢唔好<br />\n<br />\n我認我抵撚死 我抵撚死啊屌"},"citedBy":1,"replyTime":"2018-05-14T07:29:17.000Z","msg":"臭雞"},{"pid":"3e878bfad508cb23cb9e489f36b6f043dafeb461","tid":662221,"uid":54927,"like":0,"dislike":0,"score":0,"quote":{"pid":"43c5e5d306923cd09033982fdf8225f54e6aeb35","tid":662221,"uid":56684,"like":0,"dislike":4,"score":-4,"quote":{"pid":"9076df4f7edbeefa4921e5fcaac3b97baa8599ad","tid":662221,"uid":54927,"like":0,"dislike":0,"score":0,"quote":{"pid":"38c76c8710467910598623c0353b58903846e4e3","tid":662221,"uid":56684,"like":3,"dislike":28,"score":-25,"citedBy":2,"replyTime":"2018-05-12T09:04:01.000Z","msg":"我呢個係真係好撚好撚friend<br />\n我諗我起碼有一半係嬲佢咁做破壞緊我地關係"},"citedBy":1,"replyTime":"2018-05-14T06:03:55.000Z","msg":"名唔可以講多啲想了解下"},"citedBy":2,"replyTime":"2018-05-14T06:57:39.000Z","msg":"可能睇到最後你會覺得嘥左你時間<br />\n我首先講句唔好意思同多謝你畀位我講先<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n大概係咁既<br />\n咁呢位朋友本身就