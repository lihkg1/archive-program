5AA%2592-%25E4%25B8%25AD%25E5%259C%258B%25E7%25B6%25B2%25E6%25B0%2591%25E4%25BB%25A5-ai-%25E7%2594%259F%25E6%2588%2590%25E4%25BA%25BA%25E8%2587%2589%25E9%2580%25A0%25E5%2581%2587%25E6%2588%25B6%25E5%258F%25A3%25E7%25B6%25B2%25E7%25B5%25A1-%25E7%25A4%25BE%25E4%25BA%25A4%25E5%25AA%2592%25E9%25AB%2594%25E7%2599%25BC%25E5%25B8%2583%25E8%258B%25B1%25E6%2596%2587%25E7%259F%25AD%25E7%2589%2587%25E8%25BF%25BD%25E6%2593%258A%25E7%2589%25B9%25E6%259C%2597%25E6%2599%25AE%2F&d=kJyKEnCePQht%2Ftv3UrQe8bTr7UizNwCuyTydxCoZ6r4%3D&h=b83705b0\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Finternational%2F%25E7%25BE%258E%25E5%25AA%2592-%25E4%25B8%25AD%25E5%259C%258B%25E7%25B6%25B2%25E6%25B0%2591%25E4%25BB%25A5-ai-%25E7%2594%259F%25E6%2588%2590%25E4%25BA%25BA%25E8%2587%2589%25E9%2580%25A0%25E5%2581%2587%25E6%2588%25B6%25E5%258F%25A3%25E7%25B6%25B2%25E7%25B5%25A1-%25E7%25A4%25BE%25E4%25BA%25A4%25E5%25AA%2592%25E9%25AB%2594%25E7%2599%25BC%25E5%25B8%2583%25E8%258B%25B1%25E6%2596%2587%25E7%259F%25AD%25E7%2589%2587%25E8%25BF%25BD%25E6%2593%258A%25E7%2589%25B9%25E6%259C%2597%25E6%2599%25AE%2F&h=4fd51e27\" target=\"_blank\">https://thestandnews.com/international/%E7%BE%8E%E5%AA%92-%E4%B8%AD%E5%9C%8B%E7%B6%B2%E6%B0%91%E4%BB%A5-ai-%E7%94%9F%E6%88%90%E4%BA%BA%E8%87%89%E9%80%A0%E5%81%87%E6%88%B6%E5%8F%A3%E7%B6%B2%E7%B5%A1-%E7%A4%BE%E4%BA%A4%E5%AA%92%E9%AB%94%E7%99%BC%E5%B8%83%E8%8B%B1%E6%96%87%E7%9F%AD%E7%89%87%E8%BF%BD%E6%93%8A%E7%89%B9%E6%9C%97%E6%99%AE/</a>"},"citedBy":0,"replyTime":"2020-08-15T18:30:15.000Z","msg":"推"},{"pid":"6ffae72b4dbd21253602a0e75d1b3a54d0226cd4","tid":2157932,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T18:44:09.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"6dd8dc7bffe10b86255ee0e54eb7fa6cf857d27e","tid":2157932,"uid":76310,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-08-15T11: