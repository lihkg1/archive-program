/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"534f128a0d28cc074fbeb52478c9384c37825375","tid":555422,"uid":139272,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-02-09T17:43:07.000Z","msg":"人同人相處其實都要用自己最舒服既方式，<br />\n但感覺樓主可能性格問題，對其他人始終都有唔少戒心<br />\n不過對人真誠始終都係最重要，主動關心對方傾下計等佢知你內心諗咩<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"edeee9835d90818a2d17ada27b9afdcf0667fa85","tid":555422,"uid":20696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-09T18:35:07.000Z","msg":"不停咁錯過<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n但大個咗就學識逼自己唔好去諗<br />\n錯過得就證明唔屬於自己<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ccef20e34427633623af8c9fd6c88d5bf0f76630","tid":555422,"uid":171119,"like":0,"dislike":0,"score":0,"quote":{"pid":"f1bde3ee29fc380db4b1c05a07bccb348736c77b","tid":555422,"uid":27210,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-02-09T14:19:02.000Z","msg":"我<span style=\"color: pink;\"><span style=\"font-size: x-small;\">當年</span></span>都係咁<br />\n而家識朋友零難度<br />\n老土個句 試多啲就得"},"citedBy":0,"replyTime":"2018-02-09T22:47:15.000Z","msg":"分享下？"},{"pid":"a620cbfa9ea6820de3a93147b9b17cc909b0e00a","tid":555422,"uid":171119,"like":0,"dislike":0,"score":0,"quote":{"pid":"67cdd4303316f2a4cf01d3bec0a25513dff4ac76","tid":555422,"uid":6219,"like":0,"dislike":0,"score":0,"quote":{"pid":"861221cd8f6ad357d6c9f7bad842d71dde71cd9b","tid":555422,"uid":171119,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-09T12:34:26.000Z","msg":"一樣<br />\n<br />\n後來試過有一段時間好so得，但唔知係咪太熱情太活躍搞到人地唔自在定以為我有目的，最後我都係放棄咁主動<br />\n<br />\n我只係想有d friend一齊笑一齊癲<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-09T13:39:39.000Z","msg":"熟左真係可以乜都傾一餐 但係好難去到呢一步"},"citedBy":0,"replyTime":"2018-02-09T22:48:37.000Z","msg":"所以我唔再諗喇<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"}]}