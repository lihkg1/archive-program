g src=\"/assets/faces/mf/frown.gif\" class=\"hkgmoji\" />"},{"pid":"e98798cdca9430e90eb0f77e7d4a326a4fe0c151","tid":841981,"uid":143241,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2018-09-30T03:05:30.000Z","msg":"呢班人入面絕對有人去過深圳飲閪茶,總之邊個去大陸玩,邊個就係鬼."},{"pid":"a7953f1bfcf0a7d89daa2ab574ec63d976f68f52","tid":841981,"uid":34793,"like":8,"dislike":1,"score":7,"citedBy":2,"replyTime":"2018-09-30T03:07:30.000Z","msg":"2018啦 仲攞呢個movement 打飛機<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n笑撚死"},{"pid":"2755022b1527bf2c0d2ccc14debf7d80ff949cc8","tid":841981,"uid":55488,"like":2,"dislike":3,"score":-1,"citedBy":0,"replyTime":"2018-09-30T03:09:01.000Z","msg":"此回覆已被刪除"},{"pid":"6424ee999f8e7f78886d65f70af0a4ccb3304637","tid":841981,"uid":49974,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7953f1bfcf0a7d89daa2ab574ec63d976f68f52","tid":841981,"uid":34793,"like":8,"dislike":1,"score":7,"citedBy":2,"replyTime":"2018-09-30T03:07:30.000Z","msg":"2018啦 仲攞呢個movement 打飛機<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n笑撚死"},"citedBy":1,"replyTime":"2018-09-30T03:10:11.000Z","msg":"啱，腥港人不思進取<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"44d94b09c6bc9f52367a6d0b5a03db9295af62d5","tid":841981,"uid":42764,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-09-30T03:13:09.000Z","msg":"唔上堂去唱k<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"817b0637d5b416bdbb580488d391acd2b3cd329f","tid":841981,"uid":149494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-30T03:15:01.000Z","msg":"呢個LIST入面既學校所有學生社會信用評級一定好低<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a795a09f569a0ca8b77477dc262e332dc2a3d8a3","tid":841981,"uid":34793,"like":4,"dislike":0,"score":4,"quote":{"pid":"6424ee999f8e7f78886d65f70af0a4ccb3304637","tid":841981,"uid":49974,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7953f1bfcf0a7d89daa2ab574ec63d976f68f52","tid":841981,"uid":34793,"like":8,"dislike":1,"score":7,"citedBy":2,"replyTime":"2018-09-30T03:07:30.000Z","msg":"2018啦 仲攞呢個movement 打飛機<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n笑撚死"},"citedBy":1,"replyTime":"2018-09-30T03:10:11.000Z","msg":"啱，腥港人不思進取<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-30T03:17:26.000Z","msg":"成撚日係度唉呢唉路 話想當年自己都食過乜乜乜 鳩叫過 又話識到囡囡 共過患難<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n事實：企係度鳩叫 比黑警禁住黎屌 食2野椒洗個面再打卡 最後比人清場就話i will be back<br />\n港共心諗：做乜鳩<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"fc021d774966eb1251afdcd723f7833464501ea9","tid":841981,"uid":185224,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7953f1bfcf0a7d89daa2ab574ec63d976f68f52","tid":841981,"uid":34793,"like":8,"dislike":1,"score":7,"citedBy":2,"replyTime":"2018-09-30T03:07:30.000Z","msg":"2018啦 仲攞呢個movement 打飛機<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n笑撚死"},"citedBy":0,"replyTime":"2018-09-30T03:27:01.000Z","msg":"根本on9,成班Facebook 打卡，轉黃絲logo,跟住比人撚狗（遊行果堆），到旺角啦，你老母又話暴力，慢慢坐係度等啦。"}]}