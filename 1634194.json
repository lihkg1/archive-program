F%2Fna.cx%2Fi%2FQQQtmfb.jpg&h=4b2d97fd&s={SIZE}\" /> <br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">八點先啱唔好去錯</span></span>"},{"pid":"afb430ad7417fa2b0d85f7cdf91636aff0b54e7f","tid":1634194,"uid":265192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T07:37:25.000Z","msg":"<img src=\"https://na.cx/i/JG49P0v.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJG49P0v.jpg&h=bfdca82e&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: orange;\">目標一、哂馬</span></strong></span><br />\n由於警狗唔再批不反，即使批左亦會製造衝突。<br />\n為左令和理非可以舒舒服服地出返黎，展示人數同民意，<br />\n所以就利用黃店門外既人龍，製造畫面同話題吸引媒體注意。<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: orange;\">目標二、支持黃色經濟</span></span></strong><br />\n依幾個月生意難免受影響，加上可能被藍絲杯葛，<br />\n良心黃店係好需要大家支持。<br />\n最實際既支持當然就係拎銀包出黎，入錢入錢入錢！<br />\n另外參考連登既食評，由於良心經營既關係，黃店食物質素一般都偏高，<br />\n絕對係win win雙贏！<br />\n<br />\n------------國際文宣------------<br />\n請將買返黎既貨物/食物/單據同排隊盛況<br />\n一齊用<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">#Buy4HK</span></span></strong><br />\n放上IG, Twitter, reddit"},{"pid":"7a32de8ac71192218a8c74d294336ae4fa725448","tid":1634194,"uid":218298,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T07:38:19.000Z","msg":"「緊急」要草船借箭啊！！！<br />\n<a href=\"https://lih.kg/1629930\" data-auto-link target=\"_blank\">https://lih.kg/1629930</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"73c0f884ca8d8036a04f427111740221888d8491","tid":1634194,"uid":265192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T07:39:16.000Z","msg":"<img src=\"https://na.cx/i/JG49P0v.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJG49P0v.jpg&h=bfdca82e&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: orange;\">目標一、哂馬</span></strong></span><br />\n由於警狗唔再批不反，即使批左亦會製造衝突。<br />\n為左令和理非可以舒舒服服地出返黎，展示人數同民意，<br />\n所以就利用黃店門外既人龍，