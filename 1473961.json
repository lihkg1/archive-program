sets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"8a6f0ba9cdb5a8f49e4ab6aef9c60230d905b550","tid":1473961,"uid":57674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T05:28:21.000Z","msg":"勇武義士 好多謝你地捱到今日<br />\n你地休息下先 絕對唔係割唔係叫你地解散<br />\n我地和理非會盡全力救返俾人拉左既人"},{"pid":"e7dd47a159ee600c4aaac81a918c3cc796cdb731","tid":1473961,"uid":304384,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T05:29:51.000Z","msg":"push"},{"pid":"5318c7d9c3fe84f5a0f573da529a6266d914efab","tid":1473961,"uid":70227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T05:30:38.000Z","msg":"推"},{"pid":"13e2475519e1272d2ed48b3db618d46eb88eb1f1","tid":1473961,"uid":272985,"like":0,"dislike":0,"score":0,"quote":{"pid":"c64697c87dce542b993079ce1b8b2663cbfc96ed","tid":1473961,"uid":90601,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-15T04:07:42.000Z","msg":"侵段tweet千祈唔好當無到<br />\n係首次將香港放入中美角力既貿易戰程序入面<br />\n大家知道，今次中美貿易戰角力係主線<br />\n而侵同未來中國既命運，都係會受今次事件影響<br />\n<br />\n侵擺香港上台，貌似只係嘴炮，但更大可能係佢知道貿易戰好難deal得成<br />\n而需要連任籌碼既佢，將香港放入去談判桌上，係幫緊自己刷政績<br />\n最後傾唔成＝因為中國對香港唔讓步，所以貿易戰deal唔成<br />\n最後傾得成＝侵成功解決香港示威問題，又多份籌碼<br />\n<br />\n所以係中美角力既大環境之下，再亂勇武係無大意思<br />\n俾你打爆18區狗屋，打狗打鬼<br />\n都唔及得老美一份制裁法案，或者侵對刁大施加壓力咁有用<br />\n<br />\n所以當下最緊要既，係國際級別既和理非，幫自己同老美拎盡光環<br />\n係老美既描述入面，香港人係受害者，係被鎮壓，係和平理性，係爭取民主自由既勇者<br />\n依個講法，會直接影響埋歐盟，各大國乃止台灣、日本<br />\n如果我地出手施放暴力再先，老美對刁大就出師無名<br />\n再莫講話，和理非就係防鬼既最大武器<br />\n如果無人衝，鬼就衝唔到<br />\n<br />\n相反，係老美既描述入面<br />\n中國係邪惡，係鎮壓一方<br />\n侵叫刁大「用人道方式解決」，姐係暗示緊中共已再打算用「不人道方式」對付香港<br />\n要打響第一槍，就要中共打先<br />\n唔洗再做咩博攬炒，因為中共已有打算攬炒<br />\n千祈唔好由我地打先 <br />\n<br />\n我100％建議，係9月美國國會通過《香港人權及民主法案》之前<br />\n唔再有任何勇武行動<br />\n法案之後，就視乎侵同刁大既進程<br />\n再決定係咪1001勇武<br />\n仲有一個半月時間，各位前線當俾自己抖抖"},"citedBy":0,"replyTime":"2019-08-15T05:31:50.000Z","msg":"推"},{"pid":"81d13b2370f5d8952d231d0699d0ae97cd9524ee","tid":1473961,"uid":20076,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T05:33:34.000Z","msg":"818"},{"pid":"2329bba746728ab7699273b5db5b034e3d7bbe37","tid":1473961,"uid":274573,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T05:35:40.000Z","msg":"推"},{"pid":"29606d57293da5ea84eda1640f39ac29fa673064","tid":1473961,"uid":53411,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-15T05:39:46.000Z","msg":"同時又係70周年國慶<br />\n會用更殘暴/快速既手段 壓制<br />\n想70周年前平息<br />\n所以呢段時間勇武真係不而 <br />\n記住小心 不被捕 <br />\n<img src=\"https://na.cx/i/9NVENHS.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F9NVENHS.jpg&h=5d9cba5f&s={SIZE}\" />"},{"pid":"2035a3d62b61139d3f2a6cbb48dd8e0efe7a0443","tid":1473961,"uid":215876,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T05:40:52.000Z","msg":"要國會脅持佢<br />\n唔係淨係trump話事"},{"pid":"7c97c2c7fca6fd28b70f9103cdf401ed45c18e1d","tid":1473961,"uid":299203,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-15T05:40:57.000Z","msg":"呢次同雨革唔同既係 今次已經升上國家層面<br />\n局面一定走向攬炒<br />\n只係睇侵侵會唔會伸手拉住我地<br />\n起碼要等到9月國會開先可以部署下一步行動<br />\n<br />\n呢段時間 剩係遊行同埋繼續煲大721 811已經好足夠"},{"pid":"c42c832036ca1a96eea2f87b3bea19fa4d62d5fb","tid":1473961,"uid":36089,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T05:45:10.000Z","msg":"唔好意思，借一借位~<br />\n<br />\n求求大家，盡快去換美元現鈔！<br />\n<a href=\"https://lih.kg/1429581\" data-auto-link target=\"_blank\">https://lih.kg/1429581</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"25651b36a0550a01b321a734b41cc7121eceb4b4","tid":1473961,"uid":53411,"like":0,"dislike":0,"score":0,"quote":{"pid":"7c97c2c7fca6fd28b70f9103cdf401ed45c18e1d","tid":1473961,"uid":299203,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-15T05:40:57.000Z","msg":"呢次同雨革唔同既係 今次已經升上國家層面<br />\n局面一定走向攬炒<br />\n只係睇侵侵會唔會伸手拉住我地<br />\n起碼要等到9月國會開先可以部署下一步行動<br />\n<br />\n呢段時間 剩係遊行同埋繼續煲大721 811已經好足夠"}