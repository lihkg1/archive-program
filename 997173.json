faces/normal/slick.gif\" class=\"hkgmoji\" />"},{"pid":"dfb0b4694de52382c861e62d82bb281e1748f035","tid":997173,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-27T06:37:51.000Z","msg":"委內瑞拉個 frd 支那，做乜唔派兵去？"},{"pid":"7eec46c0e364d3b5b598815d1c85f763d349fbf4","tid":997173,"uid":20241,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-01-27T06:38:04.000Z","msg":"到了晚上，500名民兵、3輛俄製T-72坦克步步逼近，約在晚上10點30分，俄羅斯傭兵和敘利亞軍隊發動了襲擊，美軍曾鳴槍示警，但沒有任何效果。眼見大軍逼近，炮火聲出現，美軍緊急出動MQ-9「死神」偵察機、F-22「猛禽」戰鬥機、F-15E「打擊鷹式」戰鬥轟炸機、B-52「同溫層堡壘」轟炸機、AC-130空中砲艇、AH-64阿帕契直升機！"}]}