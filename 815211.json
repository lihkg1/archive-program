=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"1d1a55cb51d3d44abed2fe2ecc70c62436025bd3","tid":815211,"uid":144626,"like":0,"dislike":0,"score":0,"quote":{"pid":"647907767933467c987ae8c51eed3afcba57fed5","tid":815211,"uid":79375,"like":0,"dislike":0,"score":0,"quote":{"pid":"cf1d1f4f82e7b811e1cf36e6ca702de01ffeea25","tid":815211,"uid":45760,"like":2,"dislike":0,"score":2,"quote":{"pid":"8eb5d0a67b1376bef3a0807ad4520fae97c2ed2d","tid":815211,"uid":144626,"like":25,"dislike":7,"score":18,"citedBy":1,"replyTime":"2018-09-12T01:28:29.000Z","msg":"我真係覺得熱鬧兩個字係負面詞<br />\n<br />\n出街已經冇空間，當時家姐結婚，老豆直接話姐夫入黎一齊住，熱鬧<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n搞到我而家脾氣好差，而家間屋人多，好易傳播細菌，而家全家都病晒<br />\n<br />\n所以我準備辭工返支那都唔想住埋一齊<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-09-12T01:33:28.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 你老豆<br />\n<br />\n你姐夫又好意思搬埋入來做住， 冇d 骨氣<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-12T01:36:57.000Z","msg":"姐夫唔爭氣，冇錢買樓唔肯租樓，冇計"},"citedBy":1,"replyTime":"2018-09-12T01:44:45.000Z","msg":"加上而家仲生左兩件<br />\n外家幫佢養，而家返學仲住埋一齊<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n另一個原因住埋一齊就係慳錢<br />\n話管理費同差餉貴<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n