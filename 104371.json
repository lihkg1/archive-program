faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6b19754b5d5c3e9b2deb82d73a6530e91234afd4","tid":104371,"uid":11895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T05:52:10.000Z","msg":"邊個律師講野咁撚蠢?"},{"pid":"68823df88fcf075d481371edeb8fc57683ce620f","tid":104371,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T05:52:59.000Z","msg":"<span style=\"font-size: xx-large;\">被告中三學歷，月入3.5萬元，</span><br />\n<br />\n<img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"9ba96d3967805608ca8349681b17497adcd4a26e","tid":104371,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T05:54:09.000Z","msg":"有習性=豁免？"},{"pid":"35b8d642d40578d93ca46489d55b910541897592","tid":104371,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T05:56:43.000Z","msg":"習性=/=姓習 喎！"},{"pid":"b39a2f4bc13a793d7a8f4e4a8e34eebef907ccbc","tid":104371,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T05:58:45.000Z","msg":"廢青做到死下死下都唔及廢中HEA住做"},{"pid":"81b8221d2c93790d12986e57d78b7995ee25d1d8","tid":104371,"uid":47966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T06:00:26.000Z","msg":"辯方律師咁大整古<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" /> 習性"},{"pid":"730b927890b11b9448767afa809f53fb86e40c03","tid":104371,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T06:00:34.000Z","msg":"<blockquote><span style=\"font-size: xx-large;\">被告中三學歷，月入3.5萬元，</span><br />\n<br />\n<img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /></blockquote><br />\n中三都3皮五，垃圾廢老來<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"51ccd3e8f3efae2126055ccf352f983e8506c11a","tid":104371,"uid":38976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T06:02:45.000Z","msg":"屌<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n即係咁<br />\n如果你地返工都係要簽簿既<br />\n但你遲兩個字返工或者早幾分鐘收工走人<br />\n你會唔會簽遲到早走個時間先<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n根本呢樣野就好普遍<br />\n呢條友應該得罪人/上頭唔like佢<br />\n所以被人篤灰啦<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"4648631b138812261784061c7ffc49db13f0820f","tid":104371,"uid":4519,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T06:03:02.000Z","msg":"<blockquote><blockquote><span style=\"font-size: xx-large;\">被告中三學歷，月入3.5萬元，</span><br />\n<br />\n<img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" /></blockquote><br />\n中三都3皮五，垃圾廢老來<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n海事處d工全部機好撚高人工，因為香港根本就無乜人出海<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"023985475cf1eb8064d27851233b00760aa2fc7c","tid":104371,"uid":38976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T06:03:45.000Z","msg":"<blockquote>屌<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n即係咁<br />\n如果你地返工都係要簽簿既<br />\n但你遲兩個字返工或者早幾分鐘收工走人<br />\n你會唔會簽遲到早走個時間先<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n根本呢樣野就好普遍<br />\n呢條友應該得罪人/上頭唔like佢<br />\n所以被人篤灰啦<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /></blockquote><br />\n不過辯方律師咁樣講野真係好肉酸<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"b8cad4215bebaccddfa082685e13e7a5e82567c9","tid":104371,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T08:30:45.000Z","msg":"lm"}]}