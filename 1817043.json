懼症，雙眼無神，前列線炎<br />\n<br />\n戒丁必睇資料：<br />\n<br />\n戒為良藥<br />\n<a href=\"https://www.qiusuoo.com/2\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.qiusuoo.com%2F2&d=y5xLblNGdgzQkswvdzbF0xAEDuEYyIgqOvZcTDxqS2A%3D&h=c110d71f\" data-auto-link target=\"_blank\">https://www.qiusuoo.com/2</a>"},{"pid":"b5e0995cb6e5a38423edc5d181185ce6f73e5dbb","tid":1817043,"uid":256142,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-09T05:42:16.000Z","msg":"生日快樂<img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2c96116b60eb2a7fc9be68c35d9a97eb16f7c39d","tid":1817043,"uid":189879,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-09T06:09:18.000Z","msg":"hb2me"},{"pid":"cfd60cac1000ad295e071b6b1218b0cb2a71a29f","tid":1817043,"uid":189879,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-09T06:09:54.000Z","msg":"路過講聲 生日快樂<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"68c9f9c793ea381c951c88610516ecdbb10ac9ba","tid":1817043,"uid":27482,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-09T06:22:18.000Z","msg":"早知約你今日一齊去海洋公園啦"},{"pid":"2d5e8d5cb2e5f04b540b472b16d0489a52c843f9","tid":1817043,"uid":143763,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-09T06:46:18.000Z","msg":"生日快樂呀！<img src=\"/assets/faces/lihkg/hb.gif\" class=\"hkgmoji\" />"},{"pid":"8934c1fa35fee6cf72ddb2870aa34575774f381f","tid":1817043,"uid":230054,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-09T06:51:53.000Z","msg":"生日快樂"},{"pid":"6965efa66c797a6bfd0f4a0369f9e713d7bd4ad9","tid":1817043,"uid":137472,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-09T06:53:48.000Z","msg":"馬田生日快樂<img src=\"/assets/faces/lihkg/pig_hb.gif\" class=\"hkgmoji\" />"},{"pid":"c0a5ca81b74210d9e0cec35a69f8222a7030c221","tid":1817043,"uid":70922,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-09T07:01:31.000Z","msg":"生樂"},{"pid":"e1a3b77c8b025456e0cfec78730d127385f1b9ff