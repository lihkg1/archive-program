0,"score":0,"citedBy":0,"replyTime":"2017-10-10T09:10:12.000Z","msg":"一定要入埋佢 出邊無位停?<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"408008daf135a470a9a2141eb2e9db39aaf4d673","tid":430921,"uid":136994,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-10T10:48:49.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"fad8522061216c8bd1836b1a674570d77562a4cc","tid":430921,"uid":136994,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-10T13:32:19.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}