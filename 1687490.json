/>\n反而日本/美國野會有機會認"},{"pid":"1b60f7e33416fd021ea867799162207e91d424e0","tid":1687490,"uid":100680,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-03T00:55:06.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"}]}