ig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"3490b5b196471fab98dd2ff0319d7b57c2a33d1e","tid":1938661,"uid":110509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-22T17:52:49.000Z","msg":"加油"},{"pid":"2f2c2af26f7c60819771b0346df5cf292a015148","tid":1938661,"uid":269307,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-03-22T18:28:47.000Z","msg":"將twitter戰線融入生活  <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />  例如<br />\n<br />\n<strong><span style=\"color: orange;\"><span style=\"font-size: x-large;\">每日搭巴士返工去telegram twitter bot 攞任務  like + rt + comment 15分鐘<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" /><br />\n<br />\nlunch hour 食完飯 like ＋ rt 手足留言 10分鐘<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><br />\n放工返歸打少15分鐘機  去tweet 15分鐘<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /></span></span></strong><br />\n<br />\n咁就唔會覺得有心無力  返到屋企之後可以休息 / 整文宣<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /> ，或者<strong><span style=\"color: violet;\">做任務前download定啲文宣圖，comment嗰時就可以好方便附埋圖令comment更吸睛<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /></span></strong><br />\n<br />\n星期六日唔出街每食完一餐規定tweet 15分鐘<img src=\"/assets/faces/lm2/eating.gif\" class=\"hkgmoji\" />，<br />\n<strong><span style=\"color: limegreen;\">要令twitter任務變成同每日刷牙洗面一樣，咁就可以一直持續<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /></span></strong>"},{"pid":"2c23976a5adb48b4f346cb06492e713b80e737ee","tid":1938661,"uid":27725,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-24T13:06:39.000Z","msg":"推"},{"pid":"090782f2f808180565f11046d6d29e42440e73c9","tid":1938661,"uid":27725,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-26T01:04:36.000Z","msg":"push"},{"pid":"94492ce5f9a29097017e42868660d9a8d98b3782","tid":1938661,"uid":67553,"like":0,"dislike":0,"score":0,"cite