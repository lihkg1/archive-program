=\"hkgmoji\" />推"},{"pid":"48260026a24739d6eb3b52bc66da97d1ea617e18","tid":1223200,"uid":197121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-20T01:50:58.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />推"},{"pid":"c0a3dc7872ae9be96a188d7c1fcc4783ac9e523a","tid":1223200,"uid":263181,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-20T02:01:09.000Z","msg":"有用po 推"},{"pid":"418cd09ebf02652edd597b870dfa31c7663b658e","tid":1223200,"uid":178272,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-20T04:19:50.000Z","msg":"推"},{"pid":"2171b4dd087f4e353244d433dbdde4b66e96f9c5","tid":1223200,"uid":4448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-20T07:33:46.000Z","msg":"push"},{"pid":"ddfbe4335b1588c7f96801b4d9df0cd405f9ff33","tid":1223200,"uid":168368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T04:49:40.000Z","msg":"仲有辣椒水槍"},{"pid":"69858dec3ded49d7d2f3c9836462b8da47b1131b","tid":1223200,"uid":201726,"like":0,"dislike":0,"score":0,"quote":{"pid":"c66d5cee63fab110151084711acc430e7b6f3a9e","tid":1223200,"uid":172166,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-14T15:45:52.000Z","msg":"代專業視光師朋友開post<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n今日發夢果時夢到自己好似有啲印象接觸咗催淚彈同胡椒噴霧，教下大家可以點做<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">催淚彈</span></span>會係接觸咗幾秒之後會有反應，會last大約15-30分鐘<br />\n會引起流眼水，睇嘢模糊，紅，吞嘢有困難，咳，抖唔到氣，皮育紅，作嘔等等<br />\n<br />\n處理方法：盡量除衫，用水同鹼液去洗受影響嘅部分（包括洗埋影響到嘅眼罩，眼鏡）<br />\n如果影響到眼請用清水沖10-15分鐘！有戴CON都馬上除咗佢（唔好再戴番啦，掉咗佢）<br />\n受影響之後盡量要去空曠嘅位抖氣，有需要要食哮喘藥(本身有哮喘要就住黎)<br />\n<br />\n接觸到<span style=\"font-size: x-large;\"><span style=\"color: red;\">胡椒噴霧</span></span>之後會影響皮膚出紅斑，呼吸困難，影響睇嘢，有比較低機會會引起低血壓等等<br />\n<br />\n處理方法：用鹽水沖，用凍敷有機會會舒服啲，其實係要用藥（類固醇)，但要處方，同埋後遺症有機會會有復發性角膜糜爛，所以記得要睇醫生<br />\n<br />\n都係果句，如果接觸完好耐都未無曬徵狀，記得要睇醫生<br />\n<br />\n希望各位巴絲forward 出去 等多啲人知 有起咩事上黎都可以幫到身邊嘅朋友<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n香港人加油！！<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-29T10:48:37.000Z","msg":"Push"},{"pid":"04f06e432fc0f0d055355b310a39d349545d94d9","tid":1223200,"uid":122988,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T01:37:58.000Z","msg":"推"},{"pid":"5d27f9e35a2b68f2945bab6de5411a45379cf157","tid":1223200,"uid":24853,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T01:38:15.000Z","msg":"推"}]}