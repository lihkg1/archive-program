faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"b5dcf6f9d389885343b5bcce295cb8949ff17b02","tid":2139531,"uid":152700,"like":0,"dislike":0,"score":0,"quote":{"pid":"78a6b056e08b553b4c90b00da73349cee84f93b3","tid":2139531,"uid":77471,"like":0,"dislike":0,"score":0,"quote":{"pid":"721325ea28159a8d45079eb8555a0ccb5e2e26ba","tid":2139531,"uid":152700,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-04T14:40:26.000Z","msg":"我都係，上星期仲要抖唔到氣以為自己就死"},"citedBy":1,"replyTime":"2020-08-04T16:05:20.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-04T17:16:07.000Z","msg":"我就係同左啲巴絲傾完好好多"},{"pid":"78c86d2f5cd5d6740ea707671f30a86c22452f67","tid":2139531,"uid":53769,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-08-04T17:19:21.000Z","msg":"都散左一個月 幾年感情<br />\n中間曾經諗或者呢個就係最後一個<br />\n散左之後覺得 既然個個人着眼點都唔係大家<br />\n咁有乜意思<br />\nSad左幾日就冇事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fd63d4417cfee071a461abf331fbd2e00cc0ff28","tid":2139531,"uid":122513,"like":0,"dislike":0,"score":0,"quote":{"pid":"c5bc8768e45dc1c88ac5ba903dea144e775f83b3","tid":2139531,"uid":77471,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-04T10:51:18.000Z","msg":"岩岩散左，好down 唔開心，我知好多人散唔係得我一個唔開心，有冇人可以做下我樹洞傾下計，我沒咩朋友同我傾到依樣野，散一散心<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-05T15:02:16.000Z","msg":"&quot;你好，這是《自殺．自療．互助舍》。看來你已累積了不少負面情緒，是嗎？人就好像氣球一樣，若積存的鬱結和壓力太多，便會有爆發的一天。何不暫時停一停，到我們的網站    <a href=\"http://www.help4suicide.com.hk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.help4suicide.com.hk&d=dUSYmziiyXe0H9uVu%2B4Yd7Xqul57XbQM8lVYa5HUNM4%3D&h=9f8620f4\" data-auto-link target=\"_blank\">www.help4suicide.com.hk</a>     。 那裡有一些勵志故事和有趣短片，你可以隨心看看。你也可以進入網站內的『Chat窿』（星期一至五：上午六時至凌晨一時；星期六、日及公眾假期：下午８時至凌晨１時），讓我們的義工為你加油打氣！<br />\n<br />\n我們願意聆聽你的心聲，伴你一起走過這段艱難的時候！只因『晴天雨天要樂天，難關難過總會過』！<br />\n<br />\n《自殺．自療．互助舍》&quot;"},{"pid":"9fbceb273e9fdb4a17aa74f0dd9a9720f50ee0c3","tid":2139531,"uid":53815,"like":0,"dislike":0,"score":0,"quote":{"pid":"0281bacadcbad685baa5852b60c95a99e006712e","tid":2139531,"uid":328340,"like":2,"dislike":0,"score":2,"quote":{"pid":"83719f46f6b442b7aa7c41b641c6b9e2ba6905e4","tid":2139531,"uid":77471,"like":0,"dislike":0,"score":0,"quote":{"pid":"d5de196161c53bc787581f4bff6eb3962e94a598","tid":2139531,"uid":328340,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2020-08-04T13:37:50.000Z","msg":"唔關事架小朋友，佢係愛你既，你同佢講句關心既說話佢已經好知足，佢係對你變左既，你做任何野都激唔起佢心裡面個份心動，仲細咪當攞下經驗囉，責任唔係全部係你身上，佢見到你唔夠關心你，正常都會話你兩句，佢連提都唔提，表示佢已經好早就想放棄呢段感情<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n無事既，分多幾次，個人就會長大"},"citedBy":1,"replyTime":"2020-08-04T16:03:17.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-04T16:09:03.000Z","msg":"人生梗有一兩段感情係傷得深啲既，當你經歷過之後會睇開好多，我自己曾經都試過同一個拍拖4年嘅分手，都係好傷好傷，但過左之後就發現自己睇通好多，係男女感情呢方面，所以每段感情都會令人成長，只係多與少，時間會沖淡好多野，個心好快就會好返，到時你會記得佢，但已經無晒感覺<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-05T15:17:59.000Z","msg":"介唔介意講多少少？你睇通咗啲咩？"},{"pid":"a3cd4038d11f97383d8d5886a06d6774af499519","tid":2139531,"uid":341876,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-05T15:22:01.000Z","msg":"我今日都正式完咗啦<img src=\"/assets/faces/fs/bye.gif\" class=\"hkgmoji\" />"},{"pid":"f76b8081a7cd5d641a6ba08f169263b04ba138b1","tid":2139531,"uid":328340,"like":12,"dislike":0,"score":12,"quote":{"pid":"9fbceb273e9fdb4a17aa74f0dd9a9720f50ee0c3","tid":2139531,"uid":53815,"like":0,"dislike":0,"score":0,"quote":{"pid":"0281bacadcbad685baa5852b60c95a99e006712e","tid":2139531,"uid":328340,"like":2,"dislike":0,"score":2,"quote":{"pid":"83719f46f6b442b7aa7c41b641c6b9e2ba6905e4","tid":2139531,"uid":77471,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-04T16:03:17.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-04T16:09:03.000Z","msg":"人生梗有一兩段感情係傷得深啲既，當你經歷過之後會睇開好多，我自己曾經都試過同一個拍拖4年嘅分手，都係好傷好傷，但過左之後就發現自己睇通好多，係男女感情呢方面，所以每段感情都會令人成長，只係多與少，時間會沖淡好多野，個心好快就會好返，到時你會記得佢，但已經無晒感覺<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-05T15:17:59.000Z","msg":"介唔介意講多少少？你睇通咗啲咩？"},"citedBy":1,"replyTime":"2020-08-05T16:02:46.000Z","msg":"個次分手，個段傷心既日子，有日日落夜場飲酒識唔周既女仔，又玩過一夜又剩，去麻醉自己，亦試過好賤咁同身邊一個識左好耐既一個朋友拍拖，當人係水泡，明明自己根本就唔係鐘意佢，唔夠一個月就同人覺得自己未適合咁快再拍拖呢啲理由去分手，傷害左個女仔，後尾過左段時間，個人冷靜左就發現，原來我咁傷心，係因為唔習慣，同個女仔拍拖4年，原本一直屬於你既野，突然間因爲一句分手就乜都無晒，佢唔再係你，你地再唔會有任何交集，你發現自己本來每日會做既野，倒如朝早起身會搵搵佢，返工食飯時間又會同佢講兩句，收工就可能講十零分鐘電話，突然間全部都唔洗再做，咁當你每到某啲時間點你就會特別諗起佢，但時間一過，你就會慢慢淡忘呢啲習慣，對佢既感覺就會轉淡，慢慢你就會變左習慣無佢係係身邊，我覺得人係25歲前會將拍拖睇到好似好激清，成日都話要浪漫，驚喜，成日都話要有感覺，但當你人大左，你會覺得其實平平淡淡咁拖，覺得對方適合自己，同對方係一齊既時候感覺係舒服就可以<img src=\"/assets/faces/dog/zzz.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n你要洗自己腦，同自己講，每個人都有選擇既權利，你同佢拍拖，你係都係試緊佢姐，睇下佢適唔適合你，佢都一樣你簡試緊你適唔適合，大家都啱咪無事無幹囉，佢簡唔啱你咪放手囉，唔好投入太多，到你地真係有共識，原來好鳩適合行到尾既，你再推副身家落去都未遲啦，鋪鋪你都話曬冷，神仙都幫你唔到呀手足！<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n純粹個人觀點，唔撚係肯定啱架，啱睇你就睇啦！<br />\n<br />\n<br />\n係好長氣，對唔住，浪費左你時間<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"60823ef6a27808be54306015f88d7bc7733b66ae","tid":2139531,"uid":77916,"like":0,"dislike":0,"score":0,"quote":{"pid":"6b9bd98f03ea25d9901803ca2dad37ed6e4148bf","tid":2139531,"uid":77471,"like":0,"dislike":0,"score":0,"quote":{"pid":"5516911e827f68ba21de18501c2c35932077bdd7","tid":2139531,"uid":274732,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2020-08-04T11:20:12.000Z","msg":"分手最慘就係每缝假日一個人唔知做咩好<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2020-08-04T11:25:02.000Z","ms