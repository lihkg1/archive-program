個咁傻嘅決定，<br />\n諗真啲呀"},{"pid":"af0fd4a07490aad6e7b627d83b4a2bd8874785ae","tid":2158494,"uid":325243,"like":0,"dislike":0,"score":0,"quote":{"pid":"81f077aa1794ee26e0938462fbfb1a644caaa1ea","tid":2158494,"uid":227433,"like":0,"dislike":0,"score":0,"quote":{"pid":"9699e2c4882c04e60bcb918855661da988a81a09","tid":2158494,"uid":325243,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-15T18:55:33.000Z","msg":"巴打有無玩Steam既game"},"citedBy":1,"replyTime":"2020-08-15T18:56:28.000Z","msg":"冇打機好耐啦<br />\n失去哂興趣"},"citedBy":0,"replyTime":"2020-08-15T19:08:48.000Z","msg":"槍game？"},{"pid":"c1b2c473b16978209d6e30d13cdce2afc9e21987","tid":2158494,"uid":121587,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T19:09:19.000Z","msg":"真香港人係呢啲時刻真係好難過 <br />\n少一個就係少左你一個<br />\n二百萬人後面本身就唔應該有+數字<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},{"pid":"8ae7bd653d043233e977bbb5bf03c8f5d5421d45","tid":2158494,"uid":251263,"like":0,"dislike":0,"score":0,"quote":{"pid":"53544e09f0462618fd5345c64305d6c6ba94fdba","tid":2158494,"uid":227433,"like":0,"dislike":0,"score":0,"quote":{"pid":"47eb9eceddf78064b3d7ee428286e0b873f8f49c","tid":2158494,"uid":326258,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-15T18:56:44.000Z","msg":"唔好呀。巴打你不如同我哋分享吓你嘅顧慮?"},"citedBy":1,"replyTime":"2020-08-15T18:57:23.000Z","msg":"我分唔到自己係發緊夢定係清醒"},"citedBy":1,"replyTime":"2020-08-15T19:09:49.000Z","msg":"咁咪唔好刻意去分囉，又唔係拍緊inception<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"52d49015d2389d3004426881fd97d399559957d2","tid":2158494,"uid":325243,"like":0,"dislike":0,"score":0,"quote":{"pid":"f28baa3d80007599b47fae495b2b16d2c27d31b4","tid":2158494,"uid":227433,"like":0,"dislike":0,"score":0,"quote":{"pid":"5bb58f6ab116804ad9dce3fa1a452c2d535b4005","tid":2158494,"uid":65063,"like":0,"dislike":0,"score":0,"quote":{"pid":"178f33011aeb8aa2b8627485893f4d92a4ec833b","tid":2158494,"uid":227433,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"202