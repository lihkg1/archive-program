ets/faces/lm2/noodles.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/noodles.gif\" class=\"hkgmoji\" />"},{"pid":"ebf7063b714453d7c623ece05c333dbcf1f222fc","tid":2158494,"uid":166845,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-08-15T19:22:25.000Z","msg":"唔好呀, 仲有好多野未做, 咁就死左唔抵<br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=ory6wm3_uNQ\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3Dory6wm3_uNQ&d=Z4osEZd2TI9THLKNWu9ELyK1%2BumEGLY4xtueqN3WuFY%3D&h=064d15aa\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=ory6wm3_uNQ</a>"},{"pid":"4f6346f3a8538d861a141d9c6ff0b561e0485dfd","tid":2158494,"uid":67555,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-15T19:25:10.000Z","msg":"巴打 我明白呀 我都曾經有過咁樣嘅感受 好想一了百了<br />\n或者係我地對呢個世界有太多太多嘅期望 所以先咁痛苦<br />\n但係我都係決定活下去 或者活下來會見到不一樣嘅嘢呢？<br />\n希望你聽下呢首歌 能夠得到力量<br />\n<a href=\"https://youtu.be/QL3T2Nzcqcs\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FQL3T2Nzcqcs&d=Z4osEZd2TI9THLKNWu9ELyK1%2BumEGLY4xtueqN3WuFY%3D&h=3b352741\" data-auto-link target=\"_blank\">https://youtu.be/QL3T2Nzcqcs</a>"},{"pid":"b8e9a4c096f1318921b496ea412d70e6dd8deeba","tid":2158494,"uid":200520,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-08-15T19:26:16.000Z","msg":"巴打<br />\n以過來人身份同你講 上到天台望落去既高度<br />\n其實你一定會猶豫<br />\n當你單腳踏出去果刻 你人生就會好似走馬燈咁<br />\n即使你認為當下既你自己係有幾咁行屍走肉<br />\n幾咁痛苦 幾咁無助 你一定會突然間猶一猶豫<br />\n試下諗 你出世到而家有冇啲咩你想守護既野？<br />\n人？價值？如果有 其實已經係我地活落去既理由<br />\n好多人都同你一樣 或者喺呢一刻仲未諗到自己想要啲咩 但其實搵life goal都係一個life goal黎架<br />\n我知道呢幾日既深夜 的確令我地都好無力<br />\n但希望你可以同我地一齊頂住 如果你想傾計既<br />\ntg我地吖 呢到一班連登巴絲陪你架 冇事喎<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" />"},{"pid":"41a5c9635c0ea656e569a630684cd0525fe9566c","tid":2158494,"uid":810,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-08-15T19:26:50.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f075f5e7d2bb2889c858a807522d9153854739f5","tid":2158494,"uid":74696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T19:28:15.000Z","msg":"巴打 唔好啊"},{"pid":"5a07ebc175532f3d42446bfd3ca2e4debdf094ad","tid":2158494,"uid":344824,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T19:28:33.000Z","msg":"You never walk alone 利物浦今年都嬴英超<br />\n你都可以撐過呀巴打<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />"},{"pid":"2086f76193e034a0233c3bfc2c41e7688e986cc3","tid":2158494,"uid":31414,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-15T19:36:15.000Z","msg":"要走都要搵狗走 做d有意義既事"},{"pid":"c410d85cae9577302929241f99ad51d9b26c550c","tid":2158494,"uid":199700,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T19:43:43.000Z","msg":"個世界咁大<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />遲啲等肺炎完左出去見識下啦<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />一定有地方比香港更舒服更適合你<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />我都係同自己講環遊世界之後就可以去安樂死<img src=\"/assets/faces/fs/pokemon_1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/pokemon_1.gif\" class=\"hkgmoji\" />不過一定要係環遊完世界之後<img src=\"/assets/faces/fs/good.gif\" class=\"hkgmoji\" />"},{"pid":"f79eaa2d5f0768bfb4ee8f731a19aadaaf13855a","tid":2158494,"uid":113922,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T19:46:06.000Z","msg":"pish"},{"pid":"73112eb0cfbe5500d02523a69239a8b3314206be","tid":2158494,"uid":178574,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-15T19:49:32.000Z","msg":"雖然生存都好難<br />\n但生存會易過搵天台跳<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},{"pid":"8d0d50d63cbb91aeba60dd182c85327cde4c42b5","tid":2158494,"uid":227433,"like":0,"dislike":0,"score":0,"quote":{"pid":"9366df94992ce01405da152040344a6df91f15ff","tid":2158494,"uid":200464,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-15T19:08:45.000Z","msg":"你話唔想死都搞到屋企人，<br />\n不如你諗吓 你跳落嚟，有機會壓死無辜嘅人，<br />\n嚇親小朋友令佢地有陰影，<br />\n勞煩人地幫你收屍，<br />\n你以為唔喺屋企死就唔會影響屋企人？<br />\n如果佢地愛你，肯撚定會內疚自責傷心一世。<br />\n<br />\n你遇到嘅難關挫折一定好大，<br />\n如果唔係你唔會尋死，<br />\n但係你係咪已經冇動力繼續撐落去？<br />\n已經冇曬所有野？<br />\n屋企人？朋友？愛你嘅人？<br />\n你撐到而家已經好勁，不如再撐耐啲？<br />\n<br />\n信我，生命嘅誕生好神聖好難得，<br />\n希望你唔好雙腳離地嘅時候喺你生命最後幾秒先後悔自己做咗個咁傻嘅決定，<br />\n諗真啲呀"},"citedBy":1,"replyTime":"2020-08-15T20:05:48.000Z","msg":"真係頂唔到 我好努力"},{"pid":"ff2c6cf3caa89adf6a46c2a94d5dcd6182614f10","tid":2158494,"uid":227433,"like":0,"dislike":0,"score":0,"quote":{"pid":"8ae7bd653d043233e977bbb5bf03c8f5d5421d45","tid":2158494,"uid":251263,"like":0,"dislike":0,"score":0,"quote":{"pid":"53544e09f0462618fd5345c64305d6c6ba94fdba","tid":2158494,"uid":227433,"like":0,"dislike":0,"score":0,"quote":{"pid":"47eb9eceddf78064b3d7ee428286e0b873f8f49c","tid":2158494,"uid":326258,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-15T18:56:44.000Z","msg":"唔好呀。巴打你不如同我哋分享吓你嘅顧慮?"},"citedBy":1,"replyTime":"2020-08-15T18:57:23.000Z","msg":"我分唔到自己係發緊夢定係清醒"},"citedBy":1,"replyTime":"2020-08-15T19:09:49.000Z","msg":"咁咪唔好刻意去分囉，又唔係拍緊inception<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-15T20:06:14.000Z","msg":"我就係覺得好似inception 咁"},{"pid":"3f8cf35fc7a75c7d9ddee66db8588f9d84b4ec17","tid":2158494,"uid":227433,"like":0,"dislike":0,"score":0,"quote":{"pid":"746d81c5589f1898ce21a5daabb5080536c2da68","tid":2158494,"uid":108734,"like":0,"dislike":0,"score":0,"quote":{"pid":"f78344dc4dcd0349b38a51bd3d7bff9979ebc152","tid":2158494,"uid":227433,"like":0,"dislike":0,"score":0,"quote":{"pid":"df2b3bd4fd3260296019b6fed0519