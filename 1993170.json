%8D%E5%AE%B6%E5%B1%85%E6%AE%BA%E8%8F%8C%E6%94%BB%E7%95%A5\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftopick.hket.com%2Farticle%2F2566294%2F99.9-%25E6%25AE%25BA%25E8%258F%258C%25E8%258A%25B1%25E7%258E%258B%25E5%25AE%25B6%25E5%25B1%2585%25E5%25A5%25BD%25E7%2589%25A9%25E6%258E%25A8%25E4%25BB%258B%2520%25E5%2585%25A8%25E6%2596%25B9%25E4%25BD%258D%25E5%25AE%25B6%25E5%25B1%2585%25E6%25AE%25BA%25E8%258F%258C%25E6%2594%25BB%25E7%2595%25A5&d=C0QxMr2ftqWfBh1dRblImMg1Od0Dt6CGL4wHSLmh2%2Bg%3D&h=c48f6dc2\" data-auto-link target=\"_blank\">https://topick.hket.com/article/2566294/99.9-%E6%AE%BA%E8%8F%8C%E8%8A%B1%E7%8E%8B%E5%AE%B6%E5%B1%85%E5%A5%BD%E7%89%A9%E6%8E%A8%E4%BB%8B%20%E5%85%A8%E6%96%B9%E4%BD%8D%E5%AE%B6%E5%B1%85%E6%AE%BA%E8%8F%8C%E6%94%BB%E7%95%A5</a><br />\n<br />\n廚房篇：無菌煮食<br />\n<br />\n最近少出街食飯，卻多在家煮飯。我們都知道，廚房出現油煙在所難免，所謂病從口入，食材要清洗乾淨外，煮食用具及餐具的衞生同樣重要。雖然漂白水可以殺菌，但很多時，我們都不敢用普通漂白水清洗廚房。而日本研發的「萬潔靈廚房漂潔泡沫」配方專為廚房及食具而設，可以為砧板、海綿、廚具碗碟、鋅盆等消毒，令人倍安心。它能去漬除味之餘，更強力殺菌99.9%，令廚具潔白又衞生。至於同樣含有漂白水成份的「萬潔靈廚房漂潔液」，只要用1:20的分量稀釋，不但可以消毒廚具，更可代替一般漂白水消毒家居。"},{"pid":"85220b57e90c0948e69c990e4930764686bfeac2","tid":1993170,"uid":260581,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-28T21:59:55.000Z","msg":"早幾日睇星星師傅拍片 佢話用梳打粉洗<br />\n我自己平時都係用洗潔精 驚唔乾淨<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"da8142ffe3e8efe31e0d4a479164b903c582b66c","tid":1993170,"uid":1249,"like":0,"dislike":0,"score":0,"quote":{"pid":"85220b57e90c0948e69c990e4930764686bfeac2","tid":1993170,"uid":260581,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-28T21:59:55.000Z","msg":"早幾日睇星星師傅拍片 佢話用梳打粉洗<br />\n我自己平時都係用洗潔精 驚唔乾淨<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-0