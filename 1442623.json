86a1bd6d22d4&amp;oe=5DE1C8E9\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg1-1.fna.fbcdn.net%2Fv%2Ft1.0-9%2F67627416_10157730850644203_5182147478807379968_n.jpg%3F_nc_cat%3D110%26_nc_oc%3DAQlsg6D2yjn3c0jPKOTjtswXuczGq1Z64uuRgjexfMBH1NU--Ax8mUFP2oZxQSv2BXc%26_nc_ht%3Dscontent.fhkg1-1.fna%26oh%3Db199431d6c9eed9c644286a1bd6d22d4%26oe%3D5DE1C8E9&h=0043157a&s={SIZE}\" />"},{"pid":"f3c73e6df131e56d2f2f23d33ce1c4ea1eda51d2","tid":1442623,"uid":127543,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-11T04:30:58.000Z","msg":"由北角變死城，然後推返個責任比政府算啦"},{"pid":"c19ba10fa162231e37184d40ecc9fb6ac8143549","tid":1442623,"uid":90004,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-11T04:31:25.000Z","msg":"而家都唔係社團打鬥，做返啲同政府黑驚有關嘅事啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n唔係去曬馬，另外如何黑驚又放任黑社會亂打人，矛頭就基本直指黑驚"},{"pid":"8d223cbf7cd573df71665b339fe33502369061de","tid":1442623,"uid":66805,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-11T04:31:48.000Z","msg":"有荃灣，旺角，深水埗，太子，黃大仙，紅隧揀<br />\n點解要去北角<br />\n去北角係送頭，送比黑社會同黑警<br />\n你打機都唔會送頭啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"2405ed37b800449994650f276c3ce2d5e4fc0286","tid":1442623,"uid":273252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:20:03.000Z","msg":"政府北角呢步棋 我地點行都反攻唔到<br />\n所以要好好防守 下一步將佢軍"},{"pid":"d2dede425fbc1725c70fe2c6913fbd388e232b50","tid":1442623,"uid":41245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:20:52.000Z","msg":"<span style=\"font-size: large;\">針對警方無差別襲擊，標籤為<span style=\"color: red;\">國家恐怖主義武裝組織</span></span><br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">文宣核彈 - 為恐怖主義正名</span></span><br />\n<img src=\"https://na.cx/i/cEh1L51.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcEh1L51.jpg&h=6b5d83e8&s={SIZE}\" /><br />\n恐怖主義標籤係諸國用嚟打壓異己嘅手法，「國家當局可用以將政敵或其他對手非法化，從而使國家武裝部隊可理直氣壯地打擊敵人」，包括支那對新疆嘅打壓，都係以打擊恐怖主義為名，效果顯著。若果我地為警隊嘅恐怖主義正名，絕對係致命打擊警隊嘅合法性同認受性嘅方法。<br />\n<span style=\"color: orange;\">佢標籤我地做港獨，我地標籤返佢做「國家恐怖主義份子」 正名標籤警方為非法嘅武裝組織</span><br />\n<a href=\"https://lih.kg/1426058\" target=\"_blank\">https://lih.kg/1426058</a><br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">無差別襲擊製造恐怖氣氛絕對已經係恐怖主義！我地係嘅係要為警隊嘅行為正名！</span></span><br />\n<span style=\"color: orange;\">警隊失控無差別襲擊，係屬於國家恐怖主義嘅行為，已經超越「過度暴力」、「濫捕」同「濫用暴力」，依啲字眼淡化佢嘅「拐帶」、「恐怖襲擊」等非法行為，警隊嘅行為喺好多國家已經係可以定義為失去合法性啲武裝組織。<br />\n而且加上721恐襲同打後嘅黑警合作，有理由相信依個恐怖主義組織係跨越明同暗。現時警察喺民間嘅認受性極低，成為過街老鼠，執法行動已變質，失去合法地執行職務嘅能力，街坊見到警察嘅武裝會產生恐懼感。恐怖主義管治已引起社會及國際極度不安。</span><br />\n<img src=\"https://scontent.fool1-1.fna.fbcdn.net/v/t1.0-9/fr/cp0/e15/q65/67630995_110432746967840_2331413204384612352_o.jpg?_nc_cat=107&amp;efg=eyJpIjoidCJ9&amp;_nc_oc=AQl4L1bx4RYkXXmGjLvLvV0mieI9WjtsALdVP9McHQyfw-djgsY6ZSsf-1vl88RayEY&amp;_nc_ht=scontent.fool1-1.fna&amp;oh=58b06b4db0bdb4fb6b665e75af38d026&amp;oe=5DD55B02\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fool1-1.fna.fbcdn.net%2Fv%2Ft1.0-9%2Ffr%2Fcp0%2Fe15%2Fq65%2F67630995_110432746967840_2331413204384612352_o.jpg%3F_nc_cat%3D107%26efg%3DeyJpIjoidCJ9%26_nc_oc%3DAQl4L1bx4RYkXXmGjLvLvV0mieI9WjtsALdVP9McHQyfw-djgsY6ZSsf-1vl88RayEY%26_nc_ht%3Dscontent.fool1-1.fna%26oh%3D58b06b4db0bdb4fb6b665e75af38d026%26oe%3D5DD55B02&h=2d15fa1a&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">無差別化武襲擊！！</span></span><br />\n<span style=\"color: orange;\">[過期催淚彈][有圖] 毒到連眼都起水泡！！！！！麻煩全世界前線中線後線街坊啊婆啊伯！！戴靚少少既Gear唔該！！！！！</span><br />\n<a href=\"https://lih.kg/1436725\" data-auto-link target=\"_blank\">https://lih.kg/1436725</a><br />\n<br />\n<span style=\"font-size: x-large;\">認同請聯署請分享</span><br />\n<a href=\"https://petitions.whitehouse.gov/petition/officially-recognize-hong-kong-police-force-hkpf-led-commissioner-stephen-lo-wai-chung-terrorist-organization\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fofficially-recognize-hong-kong-police-force-hkpf-led-commissioner-stephen-lo-wai-chung-terrorist-organization&d=haqyWHVU0l66G8glzozbUxV%2B9HGzyIzIqBo2vIhly3s%3D&h=679f30cc\" data-auto-link target=\"_blank\">https://petitions.whitehouse.gov/petition/officially-recognize-hong-kong-police-force-hkpf-led-commissioner-stephen-lo-wai-chung-terrorist-organization</a><br />\n已有<span style=\"color: orange;\">46,938</span>/100,000個簽名（11 Aug 2019 at 13:20）<br />\n［白宮聯署］香港警察為恐怖組織<br />\n<a href=\"https://lih.kg/1427701\" target=\"_blank\">https://lih.kg/1427701</a><br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">警黑合作 恐怖治國<br />\n警察本色 恐怖組織</span></span><br />\n<span style=\"font-size: large;\"><span style=\"color: orange;\">槍炮化武 無差別襲擊<br />\n警黑勾結 武裝巴結<br />\nHKPF IS STATE TERRORIST!<br />\nNO STATE TERRORISM!<br />\nNO INDISCRIMINATE ATTACK!</span></span><br />\n<br />\n821守衛香港 反警黑恐怖治國 反恐大遊行/集會（未定）<br />\n821 - 元朗恐襲紀念日<br />\n<a href=\"https://lih.kg/1442294\" data-auto-link target=\"_blank\">https://lih.kg/1442294</a>"},{"pid":"6f63a1fed677b353f7c3e3ece12036f839446d4c","tid":1442623,"uid":214767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:23:55.000Z","msg":"推 出面幾個post引人去北角送頭<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e42759e4754fff5a8ce6fde488bdb3e71c9fffd6","tid":1442623,"uid":41245,"like":0,"dislike":0,"score":0,"quote":{"pid":"c19ba10fa162231e37184d40ecc9fb6ac8143549","tid":1442623,"uid":90004,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-11T04:31:25.000Z","msg":"而家都唔係社團打鬥，做返啲同政府黑驚有關嘅事啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n唔係去曬馬，另外如何黑驚又放任黑社會亂打人，矛頭就基本直指黑驚"},"citedBy":0,"replyTime":"2019-08-11T05:24:23.000Z","msg":"啲三毛仲係唔明我地心態<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n以為我地係無腦俾人煽動，所以佢地就想煽動下就以為可以引到啲勇武去亂打送人頭<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"fd1b88d4a180c1a1840f772d2e67049b94caa295","tid":1442623,"uid":144492,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:24:35.000Z","msg":"話唔去又俾人屌散水<br />\n又話咩你自己屋企俾人入你會唔會搬屋<br />\n我剩係知北角不嬲深紅唔係我屋企<br />\n正如你唔會主動入元朗啲圍村自殺<br />\n不過而家剩係屌左膠屌大台屌所有人<br />\n無哂6月至7月初嗰種團結"},{"pid":"3306bdab8849352b5eb11b3df61478e5b954fc16","tid":1442623,"uid":45123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:25:00.000Z","msg":"講左好多日<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 希望真係睇到"},{"pid":"3395e50ae939c800e3018f77f0f32060fc8b58e0","tid":1442623,"uid":245371,"like":0,"dislike":0,"score":0,"quote":{"pid":"7c6d45d6e0bccc74a235e385f6c5d4ed32319fc3","tid":1442623,"uid":41477,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-11T04:14:09.000Z","msg":"唔好理邊個打贏，佈左個局仲要踩落去，自己唔該反省一下。"},"citedBy":0,"replyTime":"2019-08-11T05:25:24.000Z","msg":"小心誤變成連登蠕蟲及幫兇<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/dAEcdS\" data-auto-link target=\"_blank\">https://lih.kg/dAEcdS</a><br />\n幫推  光復連登<br />\n<br />\n咪再出呢d係人都知既post啦"}]}