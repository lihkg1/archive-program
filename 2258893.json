src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"089b3ca75caa054ca17f7457f66b124d916bef67","tid":2258893,"uid":78769,"like":0,"dislike":0,"score":0,"quote":{"pid":"65d5255f33c73883eb82c343d1b11c059534450d","tid":2258893,"uid":167464,"like":6,"dislike":2,"score":4,"citedBy":1,"replyTime":"2020-10-26T12:47:21.000Z","msg":"根本而家走後門入就勁易<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />過多幾年全民大學生<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-27T06:44:41.000Z","msg":"以前話周街大學生，之後就周街碩士生"}]}