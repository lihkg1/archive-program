src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVeJJ3id.jpg&h=50bde3c1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/SsV05wz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSsV05wz.jpg&h=d54e941c&s={SIZE}\" /><img src=\"https://na.cx/i/EUH604U.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEUH604U.jpg&h=74590733&s={SIZE}\" />"},{"pid":"f3562cfba4ceee556f182d71806f11d8db4803fe","tid":1542993,"uid":257422,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-05T04:38:28.000Z","msg":"撤回唔係為咗俾香港人降溫；<br />\n撤回係要分化外國政客、媒體，<br />\n令佢地失去插手香港局面既意慾。<br />\n<br />\n<br />\n<span style=\"color: pink;\"><span style=\"font-size: xx-large;\">香港人<br />\n約定你<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/izm7G7f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fizm7G7f.jpg&h=6080f594&s={SIZE}\" /><br />\n<br />\n<img src=\"https://na.cx/i/aTJem7g.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaTJem7g.jpg&h=c2ef69f2&s={SIZE}\" /><br />\n<br />\n<br />\n<img src=\"https://na.cx/i/uxxSc8m.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuxxSc8m.jpg&h=fc48e2e5&s={SIZE}\" /><br />\n<br />\n<br />\n九月八日 星期日</span></span><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\"><br />\n12:00pm <br />\n遮打集合<br />\n(歡迎遲到，好過無到) <br />\n<br />\n2:00pm<br />\n<ins>美國駐港澳總領事館</ins> <br />\n為《香港人權及民主法案》請願</span></span><br />\n<br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">唱國歌(美國) ：</span></span><br />\n<a href=\"https://youtu.be/PWMy7Rpk5Bo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FPWMy7Rpk5Bo&d=Fy0o8YzXie14Yexn7W6ruTcZFjLth35g1vO%2BxS%2F2N%2Fg%3D&h=3e10a60b\" data-auto-link target=\"_blank\">https://youtu.be/PWMy7Rpk5Bo</a><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: blue;\">揮國旗(<span style=\"color: gold;\">美國</span>x<span style=\"color: red;\">香港</span>) ：</span></span><br />\n<br />\n<br />\n<img src=\"https://na.cx/i/6CAXjTX.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6CAXjTX.jpg&h=00eeedf1&s={SIZE}\" /><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\">香港人，九月八日見</span>"},{"pid":"061756dbe8839ac5720d79fe769beaae45ddcba6","tid":1542993,"uid":54921,"like":0,"dislike":0,"score":0,"quote":{"pid":"73419a3e1f4f9c311e36de90f4b23a7757e3bfaa","tid":1542993,"uid":249170,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-09-05T04:37:33.000Z","msg":"首先本人係絕對支持蘋果<br />\n之前都有撐3蚊<br />\n<br />\n今日本想訂閱新plan<br />\n但發現佢自動訂閱左,仲自動扣數<br />\n而且綁定左既信用卡仲冇得移除.........<br />\n<br />\n咁樣好危險，唔係信唔過蘋果動<br />\n但至少都設立一個移除信用卡資料<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-05T04:38:42.000Z","msg":"可選擇 取消亭閱"},{"pid":"3c1dcb5a631ae54f8e1ae8db1c09bf4761ad236b","tid":1542993,"uid":59242,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-05T04:42:44.000Z","msg":"我有email 過蘋果，佢咁答<br />\n<br />\n蘋果動新聞（香港）不會儲存你的信用卡資料，只保留有信用卡最後4位號碼作紀錄。而信用卡資料只能修改並不能刪除。\t<br />\n<br />\n信用卡交易完全由授權第三方Braintree Payments收費平台進行收費，及Zuora訂閱計劃服務公司根據符合支付卡產業資料安全標準 (PCI Compliance) 來收集及處理付款人之信用卡數據，壹傳媒及其員工並不會接觸到相關資料。"},{"pid":"4819068b75ecf6cdb39003acbaf3825536f25ea3","tid":1542993,"uid":94824,"like":2,"dislike":5,"score":-3,"citedBy":1,"replyTime":"2019-09-05T04:45:03.000Z","msg":"Braintree 支那公司？<br />\n<br />\n我屌你毒果賣港"},{"pid":"00327d58fd0190ffc785ab0a321fe8187830a131","tid":1542993,"uid":249170,"like":0,"dislike":0,"score":0,"quote":{"pid":"061756dbe8839ac5720d79fe769beaae45ddcba6","tid":1542993,"uid":54921,"like":0,"dislike":0,"score":0,"quote":{"pid":"73419a3e1f4f9c311e36de90f4b23a7757e3bfaa","tid":1542993,"uid":249170,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-09-05T04:37:33.000Z","msg":"首先本人係絕對支持蘋果<br />\n之前都有撐3蚊<br />\n<br />\n今日本想訂閱新plan<br />\n但發現佢自動訂閱左,仲自動扣數<br />\n而且綁定左既信用卡仲冇得移除.........<br />\n<br />\n咁樣好危險，唔係信唔過蘋果動<br />\n但至少都設立一個移除信用卡資料<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-05T04:38:42.000Z","msg":"可選擇 取消亭閱"},"citedBy":0,"replyTime":"2019-09-05T04:50:31.000Z","msg":"已經比左6舊水一年訂閱<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n但憎尻班衰佬幫我自動訂閱左<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n如果我出年呢個時候唔記得㩒取消訂閱自動續約，仲要蘋果動出年加價，又就岩果期窮，<br />\n我就奶野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1e5f2141fb54199b3a20dc012a6ba5cf483ee67d","tid":1542993,"uid":136375,"like":1,"dislike":0,"score":1,"quote":{"pid":"4819068b75ecf6cdb39003acbaf3825536f25ea3","tid":1542993,"uid":94824,"like":2,"dislike":5,"score":-3,"citedBy":1,"replyTime":"2019-09-05T04:45:03.000Z","msg":"Braintree 支那公司？<br />\n<br />\n我屌你毒果賣港"},"citedBy":0,"replyTime":"2019-09-05T04:54:07.000Z","msg":"應該唔係<br />\n<br />\n<a href=\"https://en.m.wikipedia.org/wiki/Braintree_(company\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fen.m.wikipedia.org%2Fwiki%2FBraintree_%28company&d=Fy0o8YzXie14Yexn7W6ruTcZFjLth35g1vO%2BxS%2F2N%2Fg%3D&h=0adcc106\" data-auto-link target=\"_blank\">https://en.m.wikipedia.org/wiki/Braintree_(company</a>)"},{"pid":"9f685d527befab032554e8b0c12ada46f7771869","tid":1542993,"uid":249170,"like":3,"dislike":0,"score":3,"quote":{"pid":"3c1dcb5a631ae54f8e1ae8db1c09bf4761ad236b","tid":1542993,"uid":59242,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-05T04:42:44.000Z","msg":"我有email 過蘋果，佢咁答<br />\n<br />\n蘋果動新