/lny/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bb333f425be8fa05b496d9205b3eb01ad76ea4ae","tid":1849861,"uid":344033,"like":0,"dislike":0,"score":0,"quote":{"pid":"ba7457e981d5f7c85d1e61da60e30ab2ada40e38","tid":1849861,"uid":344851,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-29T09:19:29.000Z","msg":"屋企剩低8-10個口罩，全屋6個人，又買唔到口罩，我預咗死啦，再見手足。"},"citedBy":1,"replyTime":"2020-01-29T09:34:20.000Z","msg":"用罐啦"},{"pid":"e90951844034b9722908251aae72ac7617804e6c","tid":1849861,"uid":344033,"like":0,"dislike":0,"score":0,"quote":{"pid":"bb333f425be8fa05b496d9205b3eb01ad76ea4ae","tid":1849861,"uid":344033,"like":0,"dislike":0,"score":0,"quote":{"pid":"ba7457e981d5f7c85d1e61da60e30ab2ada40e38","tid":1849861,"uid":344851,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-29T09:19:29.000Z","msg":"屋企剩低8-10個口罩，全屋6個人，又買唔到口罩，我預咗死啦，再見手足。"},"citedBy":1,"replyTime":"2020-01-29T09:34:20.000Z","msg":"用罐啦"},"citedBy":0,"replyTime":"2020-01-29T09:34:44.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">請廣傳</span></span><br />\n<br />\n手足裝備抗沙士：防毒面具/濾罐 (型號/分析/用法/清潔全齊）<br />\n<br />\n<a href=\"https://lih.kg/1848447\" data-auto-link target=\"_blank\">https://lih.kg/1848447</a>"},{"pid":"c7655ddcb0c65715c155e7f63efe9b4b98d5d6f1","tid":1849861,"uid":271617,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T09:36:13.000Z","msg":"好多人以為自己帶口罩就冇事。事實係愈多人帶口罩愈安全<br />\n<br />\n要做到完全防禦係超高難度<br />\n1. 首先要入屋企門口前將出過街嘅衫除低（防止身上病毒帶入家中）<br />\n2. 將衫放入密封袋入面<br />\n3. 盡快沖涼、洗頭、刷牙<br />\n4. 消毒身上配件 (耳機、手錶、眼鏡、手機）<br />\n5. 任何街上帶番屋企物品、食物都有可能有病毒。每次接觸後應該洗手<br />\n6. 增加拖地次數，減少中招機會<br />\n<br />\n以上只係輕易版。最有效方法係大家都帶口罩，從源頭減廢。"}]}