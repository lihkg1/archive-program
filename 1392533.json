mal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-01T03:25:19.000Z","msg":"你尋日tg問我果樣<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"51266c93daafd35ab2bce87177ee002a6cd1b2d7","tid":1392533,"uid":78695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T03:25:39.000Z","msg":"<img src=\"https://i.imgur.com/p6SPF3E.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2Fp6SPF3E.gif&h=6818fdd6&s={SIZE}\" />"},{"pid":"c94725b6c4baae81becc1c68b7ab937f32761b33","tid":1392533,"uid":109320,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T03:25:50.000Z","msg":"我哋係一班IT中嘅小器鬼們, 目前正組隊著手開發香港黑歷史網頁 - 小器簿，網頁主要係針對巿民擔心警察無依法律制裁白衣人等等問題，怕高調拉人，低調放人，或輕判小罪，而我哋就係要記住佢keep住跟進<img src=\"/assets/faces/lm2/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://lihkg.com/thread/1391590/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1391590/page/1</a><br />\n<br />\n目前缺文宣，前台UI (Reactjs, css)開發及資料搜集<br />\n歡迎有興趣朋友 <a href=\"https://t.me/joinchat/MmqsdxQcR6lrp_4Jw9uMqw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fjoinchat%2FMmqsdxQcR6lrp_4Jw9uMqw&d=puaUx2dgpXXsrsLU9noyGByAur%2Bbp9MVyOkMM5%2FMxDY%3D&h=3cd7708b\" data-auto-link target=\"_blank\">https://t.me/joinchat/MmqsdxQcR6lrp_4Jw9uMqw</a> 加入<br />\n現需要大量小器鬼幫手搵料<img src=\"/assets/faces/lm2/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/photo.gif\" class=\"hkgmoji\" /><br />\ngoogle form報料區(最好成set新聞連後續發展報) or 直接入group都得<br />\n<a href=\"https://forms.gle/ahpKJxmdCPRuBMnH7\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2FahpKJxmdCPRuBMnH7&d=puaUx2dgpXXsrsLU9noyGByAur%2Bbp9MVyOkMM5%2FMxDY%3D&h=7ec24115\" data-auto-link target=\"_blank\">https://forms.gle/ahpKJxmdCPRuBMnH7</a><br />\n<br />\n*為暫時收集資料資源途徑之一, 稍後將提供其他方法更有效收集分類, 如有其他spreadsheets資料齊歡迎隨時以本報料區/本文回覆/加入小器鬼TG提供<br />\n而8月5號小器嘅大家，識做啦<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"8ada9ecb618330274d0f26705d12e5329e5afdb3","tid":1392533,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-01T03:27:15.000Z","msg":"放工既呀蛇係最脆弱既<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n如果有咩事發生就好不幸啦"},{"pid":"08573445b1fbebf2bfdb576da2ab896c71f5806b","tid":1392533,"uid":249794,"like":0,"dislike":0,"score":0,"quote":{"pid":"8ada9ecb618330274d0f26705d12e5329e5afdb3","tid":1392533,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-01T03:27:15.000Z","msg":"放工既呀蛇係最脆弱既<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n如果有咩事發生就好不幸啦"},"citedBy":0,"replyTime":"2019-08-01T03:44:32.000Z","msg":"麻布袋?<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n同佢一齊玩cosplay<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"62028557282b8c2e4b36e742d4c6b1380e273d3a","tid":1392533,"uid":53695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T04:35:22.000Z","msg":"Hit and Run，攻心，麻包袋<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"68e775b126223ab27ea5d886ea9e02fd8724b7ba","tid":1392533,"uid":265443,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T05:07:03.000Z","msg":"推"}]}