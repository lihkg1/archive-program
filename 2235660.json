e":0,"quote":{"pid":"4339089adf952f3d30c2457a9056ccc733599ce3","tid":2235660,"uid":123895,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2020-10-09T01:05:57.000Z","msg":"咁具體即係咩思想"},"citedBy":0,"replyTime":"2020-10-09T03:50:57.000Z","msg":"中國版主體思想<br />\n將金日成換做習近平就差唔多"},{"pid":"1bc24a658d078b34eb25c2e0e01dac8ba280b24a","tid":2235660,"uid":52942,"like":0,"dislike":0,"score":0,"quote":{"pid":"4339089adf952f3d30c2457a9056ccc733599ce3","tid":2235660,"uid":123895,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2020-10-09T01:05:57.000Z","msg":"咁具體即係咩思想"},"citedBy":0,"replyTime":"2020-10-09T06:03:06.000Z","msg":"寬衣通商<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"7dbc11e4aae6582ea66d6056a83d2d3ec9efb439","tid":2235660,"uid":108022,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-09T06:06:11.000Z","msg":"雜技式玩賓周思想<img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"2a7705b8d14bf7150be3561826fd49d5063fb6de","tid":2235660,"uid":153239,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-09T06:07:24.000Z","msg":"乜撚野掘墓人<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"818155a4af96d44b9da6fd3d7cbc087f20d2ae64","tid":2235660,"uid":180851,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-09T06:09:59.000Z","msg":"幾撚可悲先要向個小學生學做人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"32cbb2b77190228be5c1473997119e97851ae2a4","tid":2235660,"uid":35430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-09T06:12:35.000Z","msg":"楊焗腸今次點睇？"}]}