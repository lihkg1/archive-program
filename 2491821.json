me=uudyMsj.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuudyMsj.jpg&h=d1d35215&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmaPFd1EHXMUy3kXAk9Kj7gdHpGhLFDLSdcnzhQSCYaXgJ?filename=RiL5Czd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRiL5Czd.jpg&h=32482dd8&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qme8hB3V3YmaNdbQf46Dfo3k5LKf3GqHrzsnxVnMDNVSCX?filename=AKZRx7L.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAKZRx7L.jpg&h=f42ee50a&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmQ87FmFbkv6EdqMWX6mbQvBqCouT1DoFCdRCJ15NajUjZ?filename=cvbAfmh.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcvbAfmh.jpg&h=1e672001&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmSywtdj6tGoowP59b7ouqiNbB5gZSCQxb12RuUXUWnp1y?filename=bkCchzW.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbkCchzW.jpg&h=a7a2f888&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmVCrk32Gg39waA82qYc3ejXpBPemQ75mZzPwb47SMvope?filename=BBrgKfb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBBrgKfb.jpg&h=42cb9c0b&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmWW85YEEUBhDdGGyWeEyivvtzLABUEHdyJfJGcd7Azd5v?filename=0mAxhAm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0mAxhAm.jpg&h=18a7e4cf&s={SIZE}\" /><br />\n<br />\n有隻唔想入返去<img src=\"/assets/faces/mouse/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/love.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmf9Yf8yX8M2DZjZq3f1ShvzYva9bwhAN34DDcCQpu3gX8?filename=OL68Ang.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOL68Ang.jpg&h=33ee7938&s={SIZE}\" /><br />\n<br />\n唯有抱佢入去<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qma7d3FzHTSVn2DgE9AbNaLvfRoboKhin32eQMvvqR38Jx?filename=nixvOHH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnixvOHH.jpg&h=5fccf517&s={SIZE}\" /><br />\n<br />\n個畫面好似：<br />\n<br />\nStaff：快啲入去喇！屌你！<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmXqZMAC9dfGWzuzGe2rvt1peEaeKL7nAfc4B89N9d6329?filename=93nWKgh.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F93nWKgh.jpg&h=273d5248&s={SIZE}\" /><br />\n<br />\n最後入返去<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmWEGxHFuEEBBLqtBhZqMpxGU7yQshKmvuGkxz15yConG3?filename=hRyZG3j.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhRyZG3j.jpg&h=8aefc585&s={SIZE}\" /><br />\n<br />\n繼續參觀<img src=\"/assets/faces/cat/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/bye.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qma7Ppgs7e7AP7b1jcJCbfzG78SRkHpUYaXX7DTQGCwLAc?filename=KgrAfoz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKgrAfoz.jpg&h=95bbca9c&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmRVcg97Vn9qMQHoVgpqk6CfiQSwwofdsty5hVrucynicP?filename=0NzaOJ2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0NzaOJ2.jpg&h=05c1ccae&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmUKqgdDdsPqgCRdQpHGghfivygeuACwzuhA6uyAzELxzQ?filename=z5v1Vo3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fz5v1Vo3.jpg&h=69b1df16&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmYzBWxuWNXSqye2N4MntQNhxXGmHmbiadk5QucxnXX4VR?filename=WWZidaL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWWZidaL.jpg&h=73721833&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmUAY8NTkYZDix28622xcUHa8mB3w7aDsDbrBHh1mY8ppg?filename=sxQxhCs.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsxQxhCs.jpg&h=c788c54f&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmThMbNBLhddRKWWEdR7Hkmy6kedTxiSwE4VmGjgKnNqet?filename=mGLJpht.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmGLJpht.jpg&h=96015e0d&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmWRLmVTqKG7EBbNX8CLwJQzPJYCXsziwr4DjLwbChedSC?filename=jvcchCv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjvcchCv.jpg&h=c8afefa3&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmbcK3JTMwuDyzua2MU2XgHUCfn3vKXs2amr9ZLmtaU1Qc?filename=1CkhtKb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1CkhtKb.jpg&h=e15c4cfa&s={SIZE}\" /><br />\n<br />\n最後入咗架船行咗陣，比啲公仔嚇到仆街<img src=\"/assets/faces/cat/swipe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/swipe.gif\" class=\"hkgmoji\" />，所以無影相<img src=\"/assets/faces/cat/annoyed.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/annoyed.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmagkr1ZFp78gjzsXo3XgbcNMPCxyZnJmXjLFHoSPcQSfY?filename=G1E94hE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FG1E94hE.jpg&h=b71ca54d&s={SIZE}\" /><br />\n<br />\n之後去咗搵巴士去高山<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmSdL7YvsoRDq47GpipNZ3PBLuPWK38EBFWJx4AGinCagS?filename=BptGaYg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBptGaYg.jpg&h=ad587c26&s={SIZE}\" /><br />\n<br />\n坐足三個鐘<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmRSfBZGAdEAs3VRQ66GRhTr8XZsaMzb6vkXrvKBGAevBQ?filename=g4CDdbN.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fg4CDdbN.jpg&h=cc8cc412&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmcn1CwpNnLm3knGHSyYxQBopfmgP6SejWhTeCSasd3PMg?filename=0E6DXDu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0E6DXDu.jpg&h=0e42201e&s={SIZE}\" /><br />\n<br />\n待續......<br />\n<br />\n聽朝繼續，送個月亮比大家<img src=\"/assets/faces/cat/lucky.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/lucky.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmfKDjvrTgVdM983Cy4JELZ6Vn2wEpieYMKjKahBxN2j5p?filename=VQu6m5j.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVQu6m5j.jpg&h=23c91b92&s={SIZE}\" />"},{"pid":"213042e23801cede29088f9c799663b883db2d46","tid":2491821,"uid":19310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-16T20:10:02.000Z","msg":"留名"},{"pid":"ce0ade85323f0218153b430ce4e79b66fe62e4d8","tid":2491821,"uid":32,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-17T02:45:20.000Z","msg":"坐咗三個鐘，終於到高山<img src=\"/assets/faces/cat/nap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/nap.gif\" class=\"hkgmoji\" /><br />\n<br />\n酒店係呢間<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmP9fUEx4thKcvN5ncnffXqg7pHvoHr3SpgdR8kQaK6Qrg?filename=wty3s30.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fwty3s30.png&h=5aa8b4d8&s={SIZE}\" /><br />\n<br />\n<br />\n酒店房都幾細<img src=\"/assets/faces/mouse/fuck.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmWD1jzfyANbiH89gjdgkJ6aGrcdJSnKkwbAryi9MgefeA?filename=qNv5GmG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqNv5GmG.jpg&h=05ed0964&s={SIZE}\" /><br />\n<br />\n<br />\n間酒店7/8點前仲有happy hour，飲杯嘢濕下個口就落咗樓<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmT2V9zWgWgMZ3i9eaS632qbL4VMNjCNWkXW9jK63AxWxQ?filename=vMftD9P.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FvMftD9P.jpg&h=74c377f2&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n本身打算去味藏天國食飯，點知定休日食唔到<img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" /><br />\n<br />\n見到鋪頭關哂，於是係車站外面食碗拉麵就算<img src=\"/assets/faces/cat/headache.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/headache.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmTu54dpr2R5ckkzMeY4md1HufnJEhetv5JUq6mm5o4daE?filename=NzB1eGV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNzB1eGV.jpg&h=74ffea03&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmdj3REuXgSRngoBaucDe4cdpyen2dULctvavi8LZi5C9Y?filename=70aYgVy.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F70aYgVy.jpg&h=adb4d90b&s={SIZE}\" /><br />\n<br />\n一陣出埋Day 3<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"dbc45b87b167f3fec6e0494792a58643e5962743","tid":2491821,"uid":32,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-04-17T03:01:08.000Z","msg":"Day 3<br />\n<br />\n本身諗住5點半起身去搭頭班車去上高地，點知4點已經比太陽殘醒咗<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><br />\n<br />\n之後梳洗完，再抖多陣就出發<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n因為2年都嚟，地點唔太記得，直接post相<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmc3jM8pgwbuecZZw4onrNNyZtppdA2MaeNPjQnbyXbrRP?filename=mXQdQjm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmXQdQjm.jpg&h=aeb60f49&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmNxoxnC4mD6pqsD8mi5w74PAFS7VwU8kvYjw1HAwzp3Sk?filename=U2gAjcU.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FU2gAjcU.jpg&h=64d2de9e&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmXbipNVpDgRUnV8XnHgMdmG4N8iVJb876XTViCWkBZsUA?filename=08U2JEL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F08U2JEL.jpg&h=1463176c&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmUyQgdoBBaALsMdCrTw1bqfE7sGG6AUv3SXTgYNuWi4RH?filename=t89RBZM.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Ft89RBZM.jpg&h=9dfe15fd&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmPWM4xkGGgD3xThd668gLsHVzHWVNdo7Sn77pk1MzKF1C?filename=mjMgN6D.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmjMgN6D.jpg&h=fd99802b&s={SIZE}\" /><br />\n<br />\n前面呢位係泰仔嚟，中間捉住我幫手影相<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n<br />\n當然我叫佢幫返我影喇<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmV9i7h4nhiQkv5crgVLQP8J9DgLKqgFJWrSFuVk8Dc42J?filename=iMRTQj0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiMRTQj0.jpg&h=8fe5ea60&s={SIZE}\" /><br />\n<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmUWU33dbTNAtuakEBXd2fQ7yojAtCL8sVoomRRFHPFPN4?filename=hmRAjdV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhmRAjdV.jpg&h=3060230b&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmUHrLB8n8NNwaeikQT2GxZdVRkZDwbXVSA2tdM2C4qTLj?filename=akaELTX.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FakaELTX.jpg&h=94453597&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmUSvbfAbiUSE6ew4aoPY2xBvHLuwAU3YaBfUQTVYsCY18?fi