rmal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"535bcf7b661604525d8032d77c7d4b46ac60c026","tid":1250443,"uid":247891,"like":2,"dislike":0,"score":2,"quote":{"pid":"b20da4578646d7afd3a642c18a69bba2917bbc0c","tid":1250443,"uid":259484,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-06-22T15:16:28.000Z","msg":"忍到忍無可忍既地步"},"citedBy":0,"replyTime":"2019-06-22T16:26:45.000Z","msg":"就係咁，我就講左分手。<br />\n<br />\n利申：6年情一鋪冇哂。"},{"pid":"47df4b7a596bf3ea6ec6bc536f6c41328b0ae7cf","tid":1250443,"uid":257683,"like":3,"dislike":0,"score":3,"quote":{"pid":"6f09e1851a63d5b5e0a3f6bdf11411dcfe81e3e3","tid":1250443,"uid":151120,"like":0,"dislike":0,"score":0,"quote":{"pid":"04ff99bb5f8b8143db27c55fb74fe847e98ca157","tid":1250443,"uid":257683,"like":4,"dislike":1,"score":3,"citedBy":2,"replyTime":"2019-06-22T05:49:25.000Z","msg":"態度突然180度變左，好冷淡 近排分左手<br />\n<br />\n一齊左4年<img src=\"/assets/faces/fs/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-22T16:19:51.000Z","msg":"因為咩原因先"},"citedBy":0,"replyTime":"2019-06-22T16:32:59.000Z","msg":"其實一切都嚟得好突然 <br />\n<br />\n分手時佢講過 佢覺得佢愛我 唔夠我愛佢咁多 覺得我應該搵個更好<br />\n<br />\n 初時真係好傷心 同埋我都做左好多野希望佢會回心轉意 但當然都係冇用 因為女人絕起上黎真係可以好絕<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n但後來我諗通左 佢分手嘅理由根本就係bullshit<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}