中共</blockquote><br />\n<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"cdc5ea297b1309ac5ca9c71e7deed36711ba7426","tid":1578652,"uid":86724,"like":0,"dislike":0,"score":0,"quote":{"pid":"abc931e13e98e6ca14a4f88570dc6522cd10e4a9","tid":1578652,"uid":72730,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-18T09:29:51.000Z","msg":"<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">集中火力講香港係全球民主最前線</span></span></strong>"},"citedBy":0,"replyTime":"2019-09-18T09:35:09.000Z","msg":"同意<br />\n可以講多d大家都認同嘅普世價值<br />\nDemocracy freedom human rights呢d都係會引起共鳴嘅字眼"},{"pid":"70fb5b056872e8510e6f2e5ce97eeb2c15b2866b","tid":1578652,"uid":96091,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-18T09:37:24.000Z","msg":"講左好耐啲人都唔識善用不推文回覆"},{"pid":"b32fba243ee39471b222f42e6b2a682b5f386bce","tid":1578652,"uid":86724,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-18T09:39:49.000Z","msg":"推"},{"pid":"387d3550ff66b6c60d0e0c6012be0dd9e4ca8f34","tid":1578652,"uid":50437,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-18T09:40:26.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"ed38c2e3e8a475098ce9301c1c330f666c6a4b8e","tid":1578652,"uid":277595,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-18T09:42:16.000Z","msg":"推"},{"pid":"2090bae389f8f3a1fe8efa1497263255ba9544e1","tid":1578652,"uid":86724,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-18T09:47:38.000Z","msg":"推"},{"pid":"1c81d18dfc0add614c081feafd1db5e3f0227afb","tid":1578652,"uid":86724,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-18T09:47:48.000Z","msg":"推"},{"pid":"4d00242e8e2cbc9c189ca74f892d4afb1c2fca02","tid":1578652,"uid":126626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-18T09:49:18.000Z","msg":"再比