ormal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d114f3ec66455b6bbfe4366a5547534fc33042da","tid":1983043,"uid":126731,"like":0,"dislike":0,"score":0,"quote":{"pid":"f6c600896cdb056513071d5307034b4ee2cb547c","tid":1983043,"uid":2179,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-21T18:54:08.000Z","msg":"有冇巴絲自學完<br />\n但冇考過日本語試？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-21T19:13:11.000Z","msg":"學語言邊有完架.<br />\n<br />\n原本無打算考, 但最後見FD考左, 500蚊又唔係貴, 忍唔住, 試完N2, N1都1 TAKE PASS.  N1仲要裸考."},{"pid":"6771c372bc74e433df3a46070ef04910cdef919e","tid":1983043,"uid":6132,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-04-21T19:24:00.000Z","msg":"自學過咗n4<br />\n首先背咗50音先，平假同片假都係由漢字嘅潦草/一部分演變而成，例如安-&gt;あ(a)、以-&gt;い(i)，用少少想像力可以幫到你記個字形，不過唔係全部都得<br />\nGrammar可以上網用音速日語、時雨之町學<br />\n輔助工具方面，OJAD係一個極好用嘅網，可以查唔同詞語嘅音調，同埋有齊大家的日本語1-50課嘅詞語連音調，亦可以查到動詞形容詞嘅形態變化<br />\nListening方面nhk有個睇新聞學日文嘅app可以練下，youtube都有好多n5-n1嘅題目可以聽下"},{"pid":"92fcaef64a8b14961a833190138d5f4b626f6377","tid":1983043,"uid":322732,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6771c372bc74e433df3a46070ef04910cdef919e","tid":1983043,"uid":6132,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-04-21T19:24:00.000Z","msg":"自學過咗n4<br />\n首先背咗50音先，平假同片假都係由漢字嘅潦草/一部分演變而成，例如安-&gt;あ(a)、以-&gt;い(i)，用少少想像力可以幫到你記個字形，不過唔係全部都得<br />\nGrammar可以上網用音速日語、時雨之町學<br />\n輔助工具方面，OJAD係一個極好用嘅網，可以查唔同詞語嘅音調，同埋有齊大家的日本語1-50課嘅詞語連音調，亦可以查到動詞形容詞嘅形態變化<br />\nListening方面nhk有個睇新聞學日文嘅app可以練下，youtube都有好多n5-n1嘅題目可以聽下"},"citedBy":0,"replyTime":"2020-04-22T00:47:28.000Z","msg":"我係睇動畫學聽力<br />\n睇漫畫學閱讀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n每個人都唔同<br />\nAV都可以學日文<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},{"pid":"d5de510a9d1d0317f5c9729e919bde2ada997750","tid":1983043,"uid":354503,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-22T01:47:13.000Z","msg":"自學左幾個月<br />\n日日lunch time做大家的日本語入面練習<br />\n一日一課，50課好快做完(當然我由16課