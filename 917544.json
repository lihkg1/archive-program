g src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"05b2d1e62986653c2f145de595ad723230dd600c","tid":917544,"uid":51920,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2018-11-26T13:41:33.000Z","msg":"要不是"},{"pid":"f6cd3efeac5c465cf72a71d9de2353e54294ab40","tid":917544,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-26T13:53:07.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6df499f61b90c76632969ef80e16be7221a5268d","tid":917544,"uid":35790,"like":1,"dislike":5,"score":-4,"citedBy":1,"replyTime":"2018-11-26T13:58:08.000Z","msg":"台灣對大陸旅客每日有限額入境"},{"pid":"90775e33318becabf405f1c53f36dab6ac47b9a5","tid":917544,"uid":13303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-26T13:59:25.000Z","msg":"反了反了, 係中國台灣環島"},{"pid":"40483848b0ce4c7464fbd3bab5767f9731405290","tid":917544,"uid":134071,"like":28,"dislike":0,"score":28,"quote":{"pid":"6df499f61b90c76632969ef80e16be7221a5268d","tid":917544,"uid":35790,"like":1,"dislike":5,"score":-4,"citedBy":1,"replyTime":"2018-11-26T13:58:08.000Z","msg":"台灣對大陸旅客每日有限額入境"},"citedBy":2,"replyTime":"2018-11-26T14:18:06.000Z","msg":"韓國瑜會識做<br />\n<br />\n國民黨執政後, 呢條例廢硬<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fd11569ce7a991c0c4953efd49ef0e70e34f2dcc","tid":917544,"uid":134071,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-11-26T14:26:04.000Z","msg":"<a href=\"http://newtalk.tw/news/view/2018-11-26/172291\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnewtalk.tw%2Fnews%2Fview%2F2018-11-26%2F172291&d=HAQPLkt2ds%2BdTv5hvldFIZ7TfgnX9jywtYe9GXZmhCU%3D&h=a8043526\" data-auto-link target=\"_blank\">http://newtalk.tw/news/view/2018-11-26/172291</a><br />\n<br />\n北京挺韓真給力 網友 : 大陸旅行社紛加旗津行程<br />\n新頭殼newtalk | 林奕彣 編譯報導<br />\n發布 2018.11.26 | 17:50<br />\n<br />\n高雄市長選戰落幕，最終韓國瑜以15萬票的差距擊敗對手陳其邁。沒想到，韓國瑜當選高雄市長才兩天，有眼尖的網友發現大陸旅行社推出旗津旅遊行程，讓人不禁感嘆，韓流真厲害!<br />\n<br />\n高雄市長選戰於(24)日落幕，然而，韓國瑜的聲勢並沒有因為選舉落幕而消退，有大陸網友發現，韓國瑜才當選兩天，北京旅行業者「海洋國際旅行社」及其他大陸業者，隨即推出「台灣環島8天-2站式購物之清境農場 旗津半島」的旅遊行程，海洋國際旅行社甚至把台灣旅遊放在網站首頁，預計將為台灣帶起一波觀光潮。<br />\n<br />\n旅行社的行程不僅帶領遊客遊歷高雄特色景點旗津半島，連清境農場、台北101大樓登頂、故宮博物院、日月潭搭船遊湖、阿里山風景區、墾丁公園士林官邸、國父紀念館、西子灣、北迴歸線紀念碑、九份山城、太魯閣等景點也都包含在內。<br />\n<br />\n此外，旅行社行程不僅將住宿升級成五花酒店，也推出台灣特色小吃，如: 台灣牛肉麵、台灣滷肉飯、台式小火鍋等供遊客享用。預定從明年2月7日開始的環島行程，團體費用每人六千元人民幣有找。<br />\n<br />\n網友稱讚說，韓國瑜在競選期間曾喊出 : 「貨賣得出去、人進得來、高雄發大財。」如今有大陸旅遊業者相挺，高雄又將陸續出現陸客的蹤影。"},{"pid":"a64637af708d1bec6a0ab552c287c082ea8bd50a","tid":917544,"uid":25858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-26T14:38:46.000Z","msg":"<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"87acf5152f805c09ca7e8a52a2304c0b538fc476","tid":917544,"uid":141151,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-26T14:42:10.000Z","msg":"環島<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6ea4e267e8417cf0bfdc83fb9cb63079f9dba344","tid":917544,"uid":79563,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-11-26T14:44:09.000Z","msg":"中華高雄發大財啦<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"87ed6732d527c9156709966035c7eaf270588376","tid":917544,"uid":65984,"like":12,"dislike":0,"score":12,"citedBy":0,"replyTime":"2018-11-26T14:56:14.000Z","msg":"東涌有救啦, 唔該哂你呀台灣<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"d10ebee17473fc877a1d8f6b9ac5d3713df6b78e","tid":917544,"uid":10504,"like":23,"dislike":0,"score":23,"citedBy":0,"replyTime":"2018-11-26T14:59:41.000Z","msg":"比佢地見識下蝗既破壞力<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/11/26/225909_e37a665030e9e422ade3f81bb1841b32.gif\" data-thumbnail-src=\"https://i.lih.