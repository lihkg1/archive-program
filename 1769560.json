sg":"indeed!"},{"pid":"0d324afdbdd2edf2a1a6371b12383bf96127cde1","tid":1769560,"uid":195904,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-12-05T03:49:09.000Z","msg":"人血饅頭"},{"pid":"5a94843c4f143c397739354a2b5d295cca6aee93","tid":1769560,"uid":240448,"like":0,"dislike":0,"score":0,"quote":{"pid":"0d324afdbdd2edf2a1a6371b12383bf96127cde1","tid":1769560,"uid":195904,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-12-05T03:49:09.000Z","msg":"人血饅頭"},"citedBy":0,"replyTime":"2019-12-05T03:50:33.000Z","msg":"點樣人血饅頭"},{"pid":"1a2b65a520ca24942748503ae06575e5295f720b","tid":1769560,"uid":240448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T03:50:50.000Z","msg":"支持法國手足 4/10"},{"pid":"148a1d93176e0559c26a1a6f2f102f572e2055d7","tid":1769560,"uid":240448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T03:54:02.000Z","msg":"支持法國手足 5/10"},{"pid":"c91f5c0f550d74c48db483905bd300bf215a7ab7","tid":1769560,"uid":45007,"like":0,"dislike":0,"score":0,"quote":{"pid":"5a25bbbd3e8b47dbdb7cdf81f7e3ed8538b88c8a","tid":1769560,"uid":77788,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-12-05T03:38:28.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-12-05T03:57:18.000Z","msg":"比人請得上呢個節<br />\n點藍？仲有成個節目佢講自己個仔係抗爭者<br />\n佢自己都好擔心 仲想點"},{"pid":"a2c912216b604c58f1863a65023a24ec17b2e290","tid":1769560,"uid":240448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T04:01:28.000Z","msg":"支持法國手足 6/10"},{"pid":"c0314e89d73d61f378fae98cd00fd8c361a3c793","tid":1769560,"uid":240448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T04:07:24.000Z","msg":"支持法國手足 7/10"}]}