{"tid":2017143,"cid":7,"subCid":0,"title":"【力撐好姊妹阿嬌】蔡卓妍取消賴弘國社交網關注","createTime":"2020-05-15T02:32:31.000Z","updateTime":"2020-05-15T03:00:25.000Z","uid":49336,"like":1,"dislike":1,"uniUserReply":7,"replies":[{"pid":"61b1aecd2302e213f9760a3676eae07a58e5c6dc","tid":2017143,"uid":49336,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-15T02:32:31.000Z","msg":"<img src=\"https://na.cx/i/r892ecZ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fr892ecZ.jpg&h=6c859e61&s={SIZE}\" /><br />\n<br />\n鍾欣潼（阿嬌）和賴弘國日前被爆於今年3月初，已簽下分居協議，連日來2人的「分訊」依然成為熱話，有指賴弘國已取消關注阿嬌所有社交平台帳號，而他的社交網亦未見阿嬌照片，同時他已刪走就離婚一事撰寫的千字文；與阿嬌情同姊妹的阿Sa（蔡卓妍），有指她力撐阿嬌，已取消了對賴弘國的社交平台關注。<br />\n<br />\n<br />\n<code>source：m.mingpao.com</code>"},{"pid":"2016d7ffce8fbe0b16d5f836a6d782b513d8af1b","tid":2017143,"uid":69472,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-15T02:33:21.000Z","msg":"幫手打tvb戰線 借一借位<img src=\"/assets/faces/mouse/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n［cctvb我屌你老母］去無良廣告商fb洗版<br />\n<a href=\"https://lih.kg/2017022\" data-auto-link target=\"_blank\">https://lih.kg/2017022</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"8be145e524147cebfe444928fc7fbe5c4677e5ae","tid":2017143,"uid":2419,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2020-05-15T02:33:42.000Z","msg":"咪撚煩啦 冇人想知"},{"pid":"a815f891f365c238b60d4aa54ba0d06d696a6cef","tid":2017143,"uid":321977,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-05-15T02:34:17.000Z","msg":"好撐架，鮑魚麵呀嘛<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"888b2efe33e8ac5c0c128642de4cbba2e4e7bb37","tid":2017143,"uid":71330,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-05-15T02:34:19.000Z","msg":"兩個都係成仔條女<br />\n咁易得罪咩<br />\n娶個老細肉便器返屋企係咩玩法"},{"pid":"c9e50c3ab184568630aa5f2edcf0c4c968f70a33","tid":2017143,"uid":321977,"like":1,"dislike":0,"sco