assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"faef23f504d52ab02067ecab6b3ef203aa8b0e56","tid":1724593,"uid":30678,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:32:49.000Z","msg":"幾碌膠通&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;3000粒TG"},{"pid":"ad041ee1e92a57ef90915e92d73c172179b52ae6","tid":1724593,"uid":160102,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:33:42.000Z","msg":"白鳩痴"},{"pid":"028296cfd366bc564ae8937a53fd49e57a078da7","tid":1724593,"uid":287891,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:35:02.000Z","msg":"燒膠釋出更多，咁燒你一定係最多<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4118f0d6675d79bac4bdbaf1867e2ee57158052f","tid":1724593,"uid":268873,"like":0,"dislike":0,"score":0,"quote":{"pid":"a50f8ec56383a5fd801169ec311b00f3d3adbf81","tid":1724593,"uid":56772,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-15T13:31:53.000Z","msg":"汪威遜承認催淚彈釋出二噁英 但指燒塑膠釋出更多<br />\n香港電台-港聞 &middot; 991人追蹤<br />\n4 小時前<br />\n警方行動部高級警司汪威遜在記者會表示，翻查不同文獻及公開資料，釋放二噁英的源頭包括發電、汽車、廢料、而最主要是燃燒塑膠。他表示，過去數個月燃燒塑膠最多的肯定是示威者，他們搜集垃圾、水馬等燃燒，釋出的二噁英會傷害市民健康，警方無可選擇地要阻止他們的「邪惡行徑」。<br />\n被問到是否認為示威者燃燒塑膠比警方施放催淚彈釋放更多二噁英，汪威遜表示絕對認同，又說警方並非每日施放催淚彈，但示威者每日都到處燃燒塑膠。<br />\n他承認催淚彈同樣會釋出二噁英，但認為若用催淚彈能阻止示威者燒燃塑膠，為何不使用，強調警方只使用最低武力，希望再次呼籲示威者不要肆無忌憚燃燒雜物，否則短時間會有人命傷亡，另一方面是破壞地球環保上做「黑手」。<br />\n至於警方的裝備是否足以保護警員免受二噁英影響，汪威遜承認，裝備不可能完全保護警員，指唯一完全保護警員的方法，只有停止暴亂，警方就不用執勤。他補充，警方關心警員，因此在教授警員如何使用催淚彈時，會讓他們感受身處有催淚煙環境的感覺，又指警員每次休息、下班都可以領取一套新制服，換走帶有催淚煙的制服。<br />\n<a href=\"https://hk.mobi.yahoo.com/news/%E6%B1%AA%E5%A8%81%E9%81%9C%E6%89%BF%E8%AA%8D%E5%82%AC%E6%B7%9A%E5%BD%88%E9%87%8B%E5%87%BA%E4%BA%8C%E5%99%81%E8%8B%B1-%E4%BD%86%E6%8C%87%E7%87%92%E5%A1%91%E8%86%A0%E9%87%8B%E5%87%BA%E6%9B%B4%E5%A4%9A-094646031.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.mobi.yahoo.com%2Fnews%2F%25E6%25B1%25AA%25E5%25A8%2581%25E9%2581%259C%25E6%2589%25BF%25E8%25AA%258D%25E5%2582%25AC%25E6%25B7%259A%25E5%25BD%2588%25E9%2587%258B%25E5%2587%25BA%25E4%25BA%258C%25E5%2599%2581%25E8%258B%25B1-%25E4%25BD%2586%25E6%258C%2587%25E7%2587%2592%25E5%25A1%2591%25E8%2586%25A0%25E9%2587%258B%25E5%2587%25BA%25E6%259B%25B4%25E5%25A4%259A-094646031.html&d=NKgE6Majit0rEYuBm%2F0CviVDAD9kR8TUwRzNJuuVR5U%3D&h=137dce67\" target=\"_blank\">https://hk.mobi.yahoo.com/news/%E6%B1%AA%E5%A8%81%E9%81%9C%E6%89%BF%E8%AA%8D%E5%82%AC%E6%B7%9A%E5%BD%88%E9%87%8B%E5%87%BA%E4%BA%8C%E5%99%81%E8%8B%B1-%E4%BD%86%E6%8C%87%E7%87%92%E5%A1%91%E8%86%A0%E9%87%8B%E5%87%BA%E6%9B%B4%E5%A4%9A-094646031.html</a><br />\n<br />\n藍絲們，你地只係陪葬品<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n有冇可能煲大呢單喺班自私撚到傳，傳到有一日黎個全港反警大遊行！<br />\n<br />\n解散警隊 刻不容緩！"},"citedBy":0,"replyTime":"2019-11-15T14:37:58.000Z","msg":"會讓他們感受身處有催淚煙環境的感覺"},{"pid":"a9459dfbb6e3475580d5b96c0a467cc762795e94","tid":1724593,"uid":72074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:38:57.000Z","msg":"前線手足d仔女都多幾隻腳指<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f7babb2d6a71f6b79863fb9221c7d6f38b3ae11f","tid":1724593,"uid":187489,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-15T14:39:30.000Z","msg":"汪威遜承認，裝備不可能完全保護警員，指唯一完全保護警員的方法，只有停止暴亂，警方就不用執勤。他補充，警方關心警員，因此在教授警員如何使用催淚彈時，會讓他們感受身處有催淚煙環境的感覺，又指警員每次休息、下班都可以領取一套新制服，換走帶有催淚煙的制服。<br />\n<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n姐係連制服都係公家洗衣機洗 都唔知本身着開嘅有冇癬<br />\n<br />\n有冇