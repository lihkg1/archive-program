/dog/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"494d7ecd119c5cd8c4ac1f633908ebcee803339e","tid":1525640,"uid":246741,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T02:35:48.000Z","msg":"推"},{"pid":"38684ff9355155c6691be2921b2183826997ec09","tid":1525640,"uid":206923,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T02:39:58.000Z","msg":"推多野，訓覺，天就光。"},{"pid":"6afc1490ac502bb568b2da9694abfd403e659b52","tid":1525640,"uid":137459,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T02:40:54.000Z","msg":"推"},{"pid":"3dce5acc5acea86a11172c4067f9a70eab1b69b6","tid":1525640,"uid":259963,"like":2,"dislike":1,"score":1,"quote":{"pid":"29cc7cd3eaa4295270db115f4fdb6287b5c420e8","tid":1525640,"uid":151248,"like":4,"dislike":1,"score":3,"citedBy":1,"replyTime":"2019-09-01T02:33:17.000Z","msg":"連廢老都唔驚帶鎚仔出街<br />\n仲有咩好講呢"},"citedBy":2,"replyTime":"2019-09-01T02:43:31.000Z","msg":"唔好廢老前廢老後<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /><br />\n好多銀髪族支持我地架<br />\n<br />\n係班無腦藍絲先有特權<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},{"pid":"471896d42449683cb05f77d2dde172164c6c5d96","tid":1525640,"uid":73596,"like":27,"dislike":4,"score":23,"citedBy":4,"replyTime":"2019-09-01T02:49:30.000Z","msg":"其實我都認同，點解俾人打唔還手，做咩俾黑警速龍追，個個都雞飛狗走？<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 見到有手足俾人㩒低唔上前幫拖，由得佢地俾人拉？<br />\n<br />\n說好既齊上齊落呢？ 我地唔係好多人架咩？ 個個掛住自己走<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n利申：冷氣軍師，我知我廢，對唔住前線<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"54520e8806bd19eb365d3fe664940516f5e467f2","tid":1525640,"uid":229411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T02:53:29.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"94a719ff486e400cb3bb1abc9b4ac5bb1820be44","tid":1525640,"uid":65439,"like":5,"dislike":0,"score":5,"