ke":6,"score":-3,"citedBy":2,"replyTime":"2018-02-02T14:00:15.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-02-03T03:19:08.000Z","msg":"1m 或 100萬"},{"pid":"86e044cf72ae4079737637d386bda129823813ca","tid":547850,"uid":29093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-03T03:19:20.000Z","msg":"Show Blocked User - RedBaron"},{"pid":"478a3c3247dae808e156a2c981ae505a5fb158dd","tid":547850,"uid":49955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-03T03:24:57.000Z","msg":"<blockquote>Show Blocked User - RedBaron</blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}