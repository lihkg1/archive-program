=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"10dd677184a05d905f8a775d63fe963c6ff2fa9a","tid":1494173,"uid":269428,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-23T06:47:58.000Z","msg":"Push<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n千祈唔好留守。<br />\n千祈唔好送頭。"}]}