.cx/i/M8STBFS.jpg\" /><br />\n<img src=\"https://i.lih.kg/540/https://na.cx/i/a8T7y6C.jpg\" />"},{"pid":"175a8a4fbe022257182e181379f07da8ac724d4f","tid":1910111,"uid":331421,"like":0,"dislike":0,"score":0,"quote":{"pid":"7f5ad2c2d9f14854c69b839e2ccd83adafbc6674","tid":1910111,"uid":196222,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-04T12:27:32.000Z","msg":"推兩席呢個玩法已經好過時<br />\n<br />\n<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-04T13:11:13.000Z","msg":"諗起12年公民袋名單余若薇排第2<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"39e7e0b384302fc9d4c817879d350a895cfb734f","tid":1910111,"uid":39812,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-03-04T12:17:11.000Z","msg":"2016年選舉 九龍東有效票數328993<br />\n理論上要有65800（329000除5）張票先叫穩奪一席<br />\n然而名單多下 票數無可能咁平均 所以大概5萬票就可以穩攞到一席<br />\n<br />\n選舉結果 泛建制派攞到約149000票<br />\n非建制派攞到約179000票<br />\n<br />\n建制派喺呢區淨係出咗5支名單 其中高達斌同另一條撚屌係出來搞事嘅 即係冇投入資源宣傳呢兩個<br />\n當日建制最後階段就係全力幫謝偉俊告急<br />\n<br />\n另一邊廂 非建制出咗足足7支名單 其中6支係有全力谷宣傳<br />\n結果？民建聯 51516 工聯會 50309 謝偉俊 47527<br />\n民主黨 50309 公民袋 45408<br />\n光頭達+陳澤滔+快必 = 77940<br />\n符合大概5萬人就可以穩勝一席個數字<br />\n<br />\n個啟示係乜？<br />\n1. 用地區樁腳鞏固鐵票 令到你可預計咁知道大概幾多人會投某名單 （例：J01 全投A名單 J02 全投B名單）<br />\n2. 計好每個地區有機會攞到幾多席 你5個席位嘅區 比例代表制下 而你只有55%選民支持你下有冇可能攞到4席？ <br />\n咁應該出幾多支名單？<br />\n<br />\n不過可預見地港共會開足機器務求我哋自己人打自己人<br />\n泛民亦都會唔會咁生性又係一個問題"}}