ike":0,"dislike":0,"score":0,"quote":{"pid":"06fe7febacd5cfcf02325ff98ff1ba1312254484","tid":896280,"uid":19990,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-11-10T08:30:05.000Z","msg":"北極熊體型同棕熊都差別大啦，<br />\n騙大陸內陸窮鄉僻壤的人民都可能得既"},"citedBy":0,"replyTime":"2018-11-10T08:37:18.000Z","msg":"指鹿為馬翻版<br />\n<br />\n邊個講呢隻係鹿 就<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"5ff3e9e75e13f9317cf1ab07d71cbd35ecdde076","tid":896280,"uid":53254,"like":28,"dislike":0,"score":28,"quote":{"pid":"c7710201c83da531a78265c5e44a7d65e2fa4158","tid":896280,"uid":73443,"like":47,"dislike":0,"score":47,"citedBy":1,"replyTime":"2018-11-10T08:33:59.000Z","msg":"居然個雪櫃係真<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-10T08:40:50.000Z","msg":"整假雪咪仲經濟, 竟然真係開冷氣"},{"pid":"f4310d9fedcc126f14f22afdf022eff8bfc90a3c","tid":896280,"uid":19990,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-10T08:41:45.000Z","msg":"北極熊係陸地最大肉食動物，棕熊變左做小學生<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"3f02b083a42f371c4d85c61557ae2d0691f13815","tid":896280,"uid":14103,"like":203,"dislike":1,"score":202,"citedBy":0,"replyTime":"2018-11-10T08:41:48.000Z","msg":"我同我老友華dee 一齊去澳洲工作假期 咁我地就係動物園入面做 我就扮馬騮 日日係個籠入面fing <br />\n有一日 我fing fing 下唔小心fing 撚左落隔離個老虎區度<br />\n我諗住死撚緊 點知隻老虎行到埋黎竟然同我講：唔駛驚！我係華dee呀！"},{"pid":"64c47df266bd59daae0179b8497eff50b29e0f12","tid":896280,"uid":9502,"like":163,"dislike":0,"score":163,"citedBy":0,"replyTime":"2018-11-10T08:45:28.000Z","msg":"爲了測試美國、香港、中國大陸三地警察的實力，&ldquo;聯合國&rdquo;將三隻兔子放在三個森林中，看三地警察誰先找出兔子。 <br />\n<br />\n任務：找出兔子<br />\n<br />\n第一個森林前是美國警察，他們先花整整半天時間開會制定作戰計劃，嚴格分工，然後派特種部隊快速進入森林進行地毯式搜索，結果開會耽擱了時間，兔子跑了，任務失敗！<br />\n<br />\n然後輪到香港警察，他們派了一百多號人和幾十輛警車在森林外一字排開，由帶頭人用喇叭喊話：&ldquo;兔子、兔子，你已經被包圍了，快出來投降&hellip;&hellip;&rdquo;半天過去了，沒動靜。飛虎隊進入森林，搜索一遍，沒結果，任務失敗！<br />\n<br />\n最後是中國警察，只有四個，先打了一天麻將，黃昏時一人拿一警棍進入森林，沒五分鐘，聽到森林裏傳來一陣動物的慘叫，中國警察一人抽著一根烟有說有笑的出來，後面拖著一隻鼻青臉腫的熊，熊奄奄一息的說到：&ldquo;不要再打了，我就是兔子&hellip;&hellip;&rdquo;"},{"pid":"789caa440fab79f342e695c00ba0793d7f3826a5","tid":896280,"uid":80103,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-11-10T08:46:18.000Z","msg":"工讀生咩黎<br />\n<br />\n隻熊半工讀？"},{"pid":"8d17590b51d71a89832d785ab41bab5f822c4bcf","tid":896280,"uid":1303,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-10T08:50:37.000Z","msg":"睇片隻野個樣有啲似一個人..."},{"pid":"aa665dbc5014c78306df84f656d9067f128311a3","tid":896280,"uid":194894,"like":5,"dislike":0,"score":5,"quote":{"pid":"209b89abde858b7e58b1350bc7a07ef1591205b8","tid":896280,"uid":126648,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-11-10T02:28:32.000Z","msg":"幾時油埋白色佢<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-10T08:52:07.000Z","msg":"油白咗架。只不過啲白油都係假既"},{"pid":"449c70cdb4aeb3e53f941ee1d739cca0788929ac","tid":896280,"uid":1533,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-10T08:53:50.000Z","msg":"返part time"},{"pid":"58fa1abd20d7db7962cbf3c23d0b7f58d3187297","tid":896280,"uid":40744,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-11-10T08:54:58.000Z","msg":"咁原本隻熊個位用咩扮..."},{"pid":"512bbf00f6f517a4e5bb1742bfa70c7b27e377e4","tid":896280,"uid":91771,"like":1,"dislike":0,"score":1,"quote":{"pid":"137c0c049e8bfd3a3b9b1945a6fcee2427792f7e","tid":896280,"uid":202464,"like":12,"dislike":2,"score":10,"citedBy":1,"replyTime":"2018-11-10T02:35:37.000Z","msg":"咩叫工讀生？"},"citedBy":0,"replyTime":"2018-11-10T08:56:39.000Z","msg":"台灣嘅part time"},{"pid":"609f15a6ab014ae1104cad6fd92b765709acdbff","tid":896280,"uid":91771,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2018-11-10T08:58:34.000Z","msg":"搵隻熊貓油白d黑位好過啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"b93c8446dccee4a40da913a1b71a35e407e8b912","tid":896280,"uid":66365,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-11-10T09:00:11.000Z","msg":"屌你似人扮多啲喎<img src=\"/assets/faces/d