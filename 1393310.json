934e5c","tid":1393310,"uid":171684,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T03:23:07.000Z","msg":"推"},{"pid":"9943a5b61d21e2c882f198a64dfa0186845a0a66","tid":1393310,"uid":170244,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T03:24:44.000Z","msg":"推"},{"pid":"a25fee643d57db47afa78dcbbd3596d68f2e2fcb","tid":1393310,"uid":241000,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-02T03:25:30.000Z","msg":"為咗香港，8月5號我會罷工，你呢？"},{"pid":"efeddc5d780cb8a4d32ca719d76b20646d12a8ab","tid":1393310,"uid":131928,"like":0,"dislike":0,"score":0,"quote":{"pid":"a25fee643d57db47afa78dcbbd3596d68f2e2fcb","tid":1393310,"uid":241000,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-02T03:25:30.000Z","msg":"為咗香港，8月5號我會罷工，你呢？"},"citedBy":0,"replyTime":"2019-08-02T03:37:00.000Z","msg":"放心罷！我地一齊罷！"},{"pid":"905f077b15968cfbca65975b7051b921a30a5a7c","tid":1393310,"uid":281692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T03:49:58.000Z","msg":"推"},{"pid":"8d7958b23b77e9604074108dcf0b9be540461644","tid":1393310,"uid":270078,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-02T03:50:52.000Z","msg":"一定要傳出去比大家知 8月2要和平散平 先會有更多人8月5號願意一齊罷工"},{"pid":"1042f2ceb80ed43bb7e61724380c9fc2ee86aa59","tid":1393310,"uid":131928,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T04:08:14.000Z","msg":"作為公務員，應該以服務社會同市民為前提; <br />\n作為盡責嘅員工，亦有責任向上司/高層諫言; <br />\n作為香港人，應該保衛香港嘅核心價值-民主自由社會; <br />\n作為父母，亦應該為下一代爭取一個安全安穩嘅成長環境同生活空間;<br />\n作為一個人，就應該要明辨是非，有愛心， 不能助紂為虐。<br />\n<br />\n無論邊一個身份，我地都再無理由唔行出嚟表達意見，向政府表達訴求。"},{"pid":"aa2cd8baa59e72431473284d9a3addf66aaf8808","tid":1393310,"uid":171058,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T04:41:39.000Z","msg":"呢個要推"},{"pid":"cec0e75e413e12594a5f1cfbf96c5fffae324191","tid":1393310,"uid":131928,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T05:54:59.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"h