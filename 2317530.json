":{"pid":"c232691a8fbefca7fd93edb032a3313f6ba48a10","tid":2317530,"uid":51701,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-12-08T16:09:24.000Z","msg":"有冇粉俠傳<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-08T16:12:19.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"eaaa440817baee58a5730a282071fa6cb70d2451","tid":2317530,"uid":59693,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-08T16:13:36.000Z","msg":"鼓勵一下"},{"pid":"9ec81dd21ba95256c6de679b2e7ac0a906f49d9a","tid":2317530,"uid":206594,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-08T16:26:11.000Z","msg":"畫工好過初出道嘅諫山好多創<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"cfa8ec15e128339c8c8f34d85a7f72ca35d23a54","tid":2317530,"uid":28910,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-12-08T16:02:00.000Z","msg":"<a href=\"https://medibang.com/book/h52008150108573690000449956/view/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmedibang.com%2Fbook%2Fh52008150108573690000449956%2Fview%2F&d=If5g8ybbdlMRYcYioqq3W5bpPLVkgxcsq72qYZiHPFQ%3D&h=3d435518\" data-auto-link target=\"_blank\">https://medibang.com/book/h52008150108573690000449956/view/</a><br />\n有得睇<br />\n不過唔係好load到<br />\n<img src=\"https://na.cx/i/KqaZxvh.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKqaZxvh.jpg&h=7092bc3f&s={SIZE}\" />"}}