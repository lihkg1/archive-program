l=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20171011%2F57318023&d=R5uB2q%2F6rUkR92WZqqw0ycmB%2BETtKD6oVAJ%2Bxq8xWyI%3D&h=b261b36d\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20171011%2F57318023&h=7317ed98\" data-auto-link target=\"_blank\">hk.news.appledaily.com/local/realtime/article/20171011/57318023</a><br />\n<br />\n人地都話比人性侵，你地做咩唔信人<br />\n係咪想迫死個女仔<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <br />\n而家要同蛆国融合，要自己證明返自己清白嫁"},{"pid":"a02d92630ed3a20feda479b4d56c8398028ae1cd","tid":485711,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-01T08:19:21.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"5bf1bfcdb10bc6cc49e3967582e2df979781e05a","tid":485711,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-01T09:04:48.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"}]}