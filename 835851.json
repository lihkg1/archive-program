":835851,"uid":123738,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-09-25T09:04:36.000Z","msg":"好想支那狗永遠都係咁<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" /> <br />\n<br />\n最賤狗種當之無愧。唔好改善呀<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"80333fc48fb0c9d85f2d236974ecabbbc4e21e85","tid":835851,"uid":144626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-25T09:05:38.000Z","msg":"橫掂法律失效，呢類大媽打佢一身都唔係問題<img src=\"/assets/faces/mf/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n橫掂呢d人後生嗰陣作威作福做紅衞兵，感受下畀人批鬥嘅滋味就啱<img src=\"/assets/faces/mf/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/agree.gif\" class=\"hkgmoji\" />"},{"pid":"83a025c306a693d5ce4d0d8b1e4bd9ca51c1339e","tid":835851,"uid":48277,"like":0,"dislike":0,"score":0,"quote":{"pid":"3abebabd1eda15342a07da2633097f841d6093d7","tid":835851,"uid":63154,"like":12,"dislike":1,"score":11,"citedBy":1,"replyTime":"2018-09-25T08:57:29.000Z","msg":"咁就唔好怪人南京大屠殺啦，人地憑本事殺你，點解要道歉，怪就怪你唔夠人打"},"citedBy":1,"replyTime":"2018-09-25T09:06:21.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"6b079bc76e43ad410f0fb784cd12801b12853089","tid":835851,"uid":162073,"like":0,"dislike":0,"score":0,"quote":{"pid":"c8c13fdcd843dd4718ea78fad28ae7e20a295ce7","tid":835851,"uid":13724,"like":0,"dislike":0,"score":0,"quote":{"pid":"040a03185dea218528d5137a1105fc0ea1624915","tid":835851,"uid":117276,"like":19,"dislike":0,"score":19,"citedBy":1,"replyTime":"2018-09-25T08:33:40.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2016/08/24/131944_d67bb78c2296832945ab6da6fbb0edfc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?