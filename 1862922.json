ata-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeZ7wSaV.jpg&h=53cfcedd&s={SIZE}\" />"},{"pid":"4e176429c867ee16df7bbcf081c28ed00933b9f1","tid":1862922,"uid":152476,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-05T03:06:05.000Z","msg":"唔只文滙大公<br />\n根本12月尾1月頭好多藍絲group都係咁講<br />\n<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},{"pid":"b5a0a027f442b4535c13a7d77cb1b190103cc11c","tid":1862922,"uid":39628,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-05T03:07:43.000Z","msg":"依家蘋果可唔可以告佢?"},{"pid":"5083b3e05b90e20fc1772317ce269097717929d0","tid":1862922,"uid":64810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T03:09:12.000Z","msg":"毒文匯<img src=\"/assets/faces/lny/dead.gif\" class=\"hkgmoji\" />"},{"pid":"7f4bbab9d0d00f7273b823641ee2a1a909f8f1bb","tid":1862922,"uid":297045,"like":0,"dislike":0,"score":0,"quote":{"pid":"b5a0a027f442b4535c13a7d77cb1b190103cc11c","tid":1862922,"uid":39628,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-05T03:07:43.000Z","msg":"依家蘋果可唔可以告佢?"},"citedBy":0,"replyTime":"2020-02-05T03:09:44.000Z","msg":"告誹謗?"},{"pid":"0a8413234946fb9921d0d5d6ac2eb116e70f29c7","tid":1862922,"uid":241723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T03:11:19.000Z","msg":"<img src=\"/assets/faces/lny/bomb.gif\" class=\"hkgmoji\" />無恥到打冷陣"},{"pid":"a3c4f43bf0708cbff5a9d19f69ed4f905190be11","tid":1862922,"uid":140596,"like":0,"dislike":0,"score":0,"quote":{"pid":"2f450f34c20326e55c047a4937e59f8ae72bb117","tid":1862922,"uid":19552,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-02-05T02:27:00.000Z","msg":"「全面封關」負面效益有多大？<br />\n<br />\n  任何事情都有兩面性，不能只看到有利的一面，而忽視不利的一面。如果現時「全面封關」，將有以下不利後果：<br />\n<br />\n  其一，會切斷香港居民的生活來源。眾所周知，香港的水果、蔬菜、肉類、蛋奶均來自於內地供應，連喝的水都是從內地引來的。如果「全面封關」，試問：短時間內從哪裏補上這些缺口？從鄰近的其他國家和地區能補上嗎？如此，將使香港陷入比疫情更大的危機。<br />\n<br />\n  其二，會失去中央政府和內地省份的強力支持。中央政府剛剛向香港緊急調撥350萬個口罩，這僅是支持香港的一個舉措。與當年抗擊沙士一樣，阻擊新型冠狀肺炎疫情，香港需要中央政府和內地省份的更多支持，這場防疫阻擊戰才剛剛開始，假如「全面封關」，香港成為「孤島」，將更加難以應付複雜的局面。<br />\n<br />\n  其三，會帶來社會恐慌。前些天，香港已出現了市民狂掃超市的現象，大米、蔬菜、方便速食品等成為市民囤積的主要物品。這說明，市民對疫情有恐慌心理。對此，正確的做法是「開源」，讓市民看到「源頭自有活水來」，假如「全面封關」，切斷供應鏈，會加劇恐慌心理，帶來比疫情更大的不幸。<br />\n<br />\n  其四，會窒息香港經濟。香港是國際金融中心，在香港上市企業有60%以上來自內地；香港是國際貿易和航運中心。如果「全面封關」，這些經濟活動將全部停止，對香港經濟打擊將是致命性的。<br />\n<br />\n<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-05T03:12:34.000Z","msg":"350萬個口罩 ??????"},{"pid":"3af6a1e28b53e2bfe577d0f49704ae96326ecc78","tid":1862922,"uid":140596,"like":0,"dislike":0,"score":0,"quote":{"pid":"a3c4f43bf0708cbff5a9d19f69ed4f905190be11","tid":1862922,"uid":140596,"like":0,"dislike":0,"score":0,"quote":{"pid":"2f450f34c20326e55c047a4937e59f8ae72bb117","tid":1862922,"uid":19552,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-02-05T02:27:00.000Z","msg":"「全面封關」負面效益有多大？<br />\n<br />\n  任何事情都有兩面性，不能只看到有利的一面，而忽視不利的一面。如果現時「全面封關」，將有以下不利後果：<br />\n<br />\n  其一，會切斷香港居民的生活來源。眾所周知，香港的水果、蔬菜、肉類、蛋奶均來自於內地供應，連喝的水都是從內地引來的。如果「全面封關」，試問：短時間內從哪裏補上這些缺口？從鄰近的其他國家和地區能補上嗎？如此，將使香港陷入比疫情更大的危機。<br />\n<br />\n  其二，會失去中央政府和內地省份的強力支持。中央政府剛剛向香港緊急調撥350萬個口罩，這僅是支持香港的一個舉措。與當年抗擊沙士一樣，阻擊新型冠狀肺炎疫情，香港需要中央政府和內地省份的更多支持，這場防疫阻擊戰才剛剛開始，假如「全面封關」，香港成為「孤島」，將更加難以應付複雜的局面。<br />\n<br />\n  其三，會帶來社會恐慌。前些天，香港已出現了市民狂掃超市的現象，大米、蔬菜、方便速食品等成為市民囤積的主要物品。這說明，市民對疫情有恐慌心理。對此，正確的做法是「開源」，讓市民看到「源頭自有活水來」，假如「全面封關」，切斷供應鏈，會加劇恐慌心理，帶來比疫情更大的不幸。<br />\n<br />\n  其四，會窒息香港經濟。香港是國際金融中心，在香港上市企業有60%以上來自內地；香港是國際貿易和航運中心。如果「全面封關」，這些經濟活動將全部停止，對香港經濟打擊將是致命性的。<br />\n<br />\n<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" /><img src=\