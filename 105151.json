ets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"047fbb3e7afcb81bea74e45fb9222a846d995160","tid":105151,"uid":4260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T16:46:08.000Z","msg":"<blockquote>梁朝偉個反應<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n好重口味呀大佬<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"b2b78a9f690a7a68ccad30ca1ec06ab2f6233785","tid":105151,"uid":550,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T16:46:57.000Z","msg":"<img src=\"https://na.cx/i/B49ku58.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FB49ku58.jpg&h=ea329e5d&s={SIZE}\" /><br />\n我唔好呢味野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1d4c6c5d43f0a22f674b2b7dd42e54f60a5abba7","tid":105151,"uid":45645,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-02T17:12:01.000Z","msg":"<blockquote>劉嘉玲<img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" /></blockquote><br />\nBig balls"},{"pid":"a4320353f9d6658359cd9c7efb618d7a1905d754","tid":105151,"uid":5591,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-03T08:13:18.000Z","msg":"即係咁，喺廿幾年前嘅大台劇集好多都好前衛、好大膽，按照當年的保守程度，同性戀、迫真殺人畫面一樣可以播。不過，時至今日就有好多嘢唔可以出街，究竟係現在的觀眾保守，抑或是大台保守呢? 真是一個謎。 <br />\n<br />\n喺深夜重播的《新紮師兄1988》入面，吳啟明飾演的卓耀祖引梁朝偉入房，之後卓耀祖就以一身女性打扮現身。老老實實，吳啟明扮女人又的確幾嬌俏。未幾，吳啟明露出本性，想霸王硬上弓，嚇得梁朝偉不停反抗。最後因為曾華倩過來找梁朝偉，令梁朝偉幸保不失。 <br />\n<br />\n不過，呢一幕就有刪減過，有網民指當時仲有一個鏡頭是吳啟明伸手去梁朝偉下面，然後使出一招「猴子偷桃」。雖然鏡頭並沒有真的拍住吳啟明「猴子偷桃」，但係意識形態，再加上梁朝偉一個痛苦表情，已經令整個畫面出現在觀眾腦海。 <br />\n<br />\n可惜，深夜重播的第一集，就將吳啟明伸手去梁朝偉下面刪去，只保留梁朝偉痛苦表情。或者大台高層又怕被人投訴，唔想孭鑊咪見有可疑就刪走。<br />\n<br />\n<a href=\"http://s.nextmedia.com/magazine/r.php?a=2_475223_0&amp;i=20170203\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fs.nextmedia.com%2Fmagazine%2Fr.php%3Fa%3D2_475223_0%26i%3D20170203&d=%2BySIvleuZbSdMWEfOjMUQv7vEz4FU%2Bq4m%2F6ZFrWLoTs%3D&h=42b48508\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fs.nextmedia.com%2Fmagazine%2Fr.php%3Fa%3D2_475223_0%26i%3D20170203&h=952964ad\" data-auto-link target=\"_blank\">http://s.nextmedia.com/magazine/r.php?a=2_475223_0&amp;i=20170203</a><br />\n【新紮師兄第三輯】廿九年後大台好保守 刪吳啟明梁朝偉偷桃畫面 | 2017-02-03 | 壹週Plus | 蘋果日報"},{"pid":"2d8413f1f67b633b91e6f30fa2f71b8f9ca10ae4","tid":105151,"uid":6964,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-03T09:00:35.000Z","msg":"仆街原來少左偷桃"},{"pid":"e7f17e54f7c62a8176dcb9c8f756f87cf52470f6","tid":105151,"uid":10176,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-03T09:01:45.000Z","msg":"依家做緊?"},{"pid":"6ad1854f1cb8d7a522f87f207a576da363627e70","tid":105151,"uid":6964,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-03T09:12:55.000Z","msg":"<blockquote>依家做緊?</blockquote><br />\n琴晚第一集"},{"pid":"d103fc478ed296c014258da23acaf83d1e7c1f48","tid":105151,"uid":4260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-03T16:11:53.000Z","msg":"岩岩先返到屋企<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> 有無精彩情節出現左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"b37821106f23fa52cfcaabbe5a5ab0203318b842","tid":105151,"uid":4260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-03T16:13:01.000Z","msg":"<blockquote>仆街原來少左偷桃</blockquote><br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"2a42e92d9e7889413d546e775e2b7aec4e14f5f1","tid":105151,"uid":36178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-03T16:35:10.000Z","msg":"高佬泉真係好撚煩<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"9cc498e264197e01569e99d0d497dce9d80a167b","tid":105151,"uid":42550,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-04T16:29:18.000Z","msg":"首歌好熟<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/