7-04T03:49:30.000Z","msg":"Even 取消埋監警會 或者將佢地變成無實質作用既顧問角色<br />\n投訴警察課既警員 歸公署暫管<br />\n所有個案都要再經公署專員檢閱/抽樣調查，人手問題就解決。"},{"pid":"c89245cda8e086283eec26a7608784545d605c3a","tid":1283914,"uid":216253,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T03:50:46.000Z","msg":"推<br />\n<br />\n<blockquote>我冇野講</blockquote>"},{"pid":"90570164f318243a126dbd09ddbaa0ac4e3106bf","tid":1283914,"uid":268619,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T03:52:35.000Z","msg":"推"},{"pid":"563a3002a04c2392a5de06c6044c92c4cb8b629e","tid":1283914,"uid":259121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T03:53:02.000Z","msg":"推<br />\n<code>我冇嘢講</code>"},{"pid":"2e6214c07199522a34f77d06f7c1933b00942388","tid":1283914,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T03:53:45.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"52e6b3c9745c416851973b00bc3c7d33f08fc4b1","tid":1283914,"uid":268619,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T03:57:33.000Z","msg":"推"},{"pid":"f05576953d06b6c98ede7fc48b42608eb4299bc2","tid":1283914,"uid":250474,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T03:59:17.000Z","msg":"<pre><code data-type=\"\">我無野講</code></pre>"},{"pid":"a3bc8bf9de617ff99b06ed53057d3fe01ff2b474","tid":1283914,"uid":268619,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T04:00:41.000Z","msg":"PUSH"},{"pid":"2b24ac559a54b809484ada4d23e214f374a7c59c","tid":1283914,"uid":26332,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-07-04T04:01:48.000Z","msg":"同議員提議下<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"c0ae6ab1eb143120b46d3489b6103816d537a6ee","tid":1283914,"uid":268619,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-04T04:05:59.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"9c66e736f2d6db5a612c1db2d4972c6e14b7dd8