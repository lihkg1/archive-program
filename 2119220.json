{"tid":2119220,"cid":27,"subCid":0,"title":"TG 狗狗寵物交流Group","createTime":"2020-07-22T03:43:17.000Z","updateTime":"2020-11-09T07:47:59.000Z","uid":100010,"like":5,"dislike":3,"uniUserReply":10,"replies":[{"pid":"f21b81d14bb354f733b17e8d346f59d9d0edb0a5","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-22T03:43:17.000Z","msg":"TG 狗狗寵物交流Group <br />\n<br />\n<br />\n歡迎各位愛狗人仕 加入， 交流養狗喜與樂。 希望多人既話可以搞狗狗聚會😃， 當然係疫情過後。<br />\n如果你都想識多d 朋友或者替狗狗識多d 狗友， 非常歡迎加入<br />\n<br />\n入谷條件： <br />\n1. 需要有養狗 <br />\n2. 香港人<br />\n3. 黃絲<br />\n<br />\n<br />\n<a href=\"https://t.me/joinchat/FhloiklqfcXtjeXgmV2qjg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fjoinchat%2FFhloiklqfcXtjeXgmV2qjg&d=ubUSuZPfwFYlyx9%2FldNtB0oInKkgZqzseva8eQDkMF8%3D&h=f0f5a272\" data-auto-link target=\"_blank\">https://t.me/joinchat/FhloiklqfcXtjeXgmV2qjg</a>"},{"pid":"91bad7ea5f846d9993a17c10d82a1d1e5bcb0c58","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-23T23:46:53.000Z","msg":"Push"},{"pid":"90b469101c908d2f38ec939151a851432e95a258","tid":2119220,"uid":313363,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-24T08:18:41.000Z","msg":"Push <img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},{"pid":"917beb69b5af93072bfcf2839c8184daa54acdfd","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"quote":{"pid":"90b469101c908d2f38ec939151a851432e95a258","tid":2119220,"uid":313363,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-24T08:18:41.000Z","msg":"Push <img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-25T04:33:51.000Z","msg":"<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"f220b5b08853a8ccde3a74d5f721c94dcedce910","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-27T02:18:00.000Z","msg":"<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pi