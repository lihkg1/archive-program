s/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"02f0c62ed344c9ce90814b76f151058d36a66784","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-02T13:00:00.000Z","msg":"<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"f1a27200c8af52c658ead333f210b22736192159","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-08T09:29:55.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"},{"pid":"e83d24bf929c6f4f9efa264bfc56a10f9d484f55","tid":2119220,"uid":360186,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-09T02:27:28.000Z","msg":"唔好意思，借位一用<br />\n連登會員吉野邊又名香辣牛肉麵（#74933）老屈我偷貓舍得出黎對質未，你老母攰啦<br />\n<br />\n<br />\n事原琴日我係人地個Post度教人可以試下去嶺大貓社領養貓貓，點知比人屈我係嶺大偷貓，重要追我Post屈我偷，重話嶺大邊度有From填領養貓貓，又話我仆街，又帶頭屌鳩我。但成件事佢都未攪清楚包括嶺大貓社堅係有得領養，而我領養貓隻係5年前嘅事等，一口就咬定我偷，然後我就結結實實咁攞證據出黎證明我無偷，但屌就識追Post，衰左就唔出黎認，重想公審我，都唔知咩人黎係咪佢老母無教佢做人。所以我<span class=\"large\"><span class=\"red\"><span class=\"x-large\">懇請大家一齊公審翻佢追擊反佢</span></span></span>唔好比啲咁嘅仆街可以講野唔駛負責任鍾意就講，一齊代佢老母教仔，香港人應該係理性，指控人前睇有無證據同理據，我地有讀書嫁麻，教師點都有教嫁。<br />\n<br />\n我目標係追擊到佢公開拍片道歉，上傳係各大貓群組同連登，為期三日，請大家還我一個公道。<br />\n<br />\n如果想睇事件詳情請追以下post:<br />\n<a href=\"https://lih.kg/aCsFHoV\" data-auto-link target=\"_blank\">https://lih.kg/aCsFHoV</a><br />\n重有搵反標題為:我隻貓係麻甩佬<br />\n<br />\nP.S. （我AC係同人共用，我係男人黎）"},{"pid":"4436e7e06491e1133b4d1cccda17f62bc2b58b87","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-10T06:21:29.000Z","msg":"<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"cfa792ebc607f33a930666994767648a0ff4a916","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-11T13:41:15.000Z","msg":"<img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"},{"pid":"4705c95aa1acac4f2d7cccdb78fcb7ed496c7a5c","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-12T07:06:11.000Z","msg":"<img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"},{"pid":"89d0ea2f7ff9158a246bc12bed3d85c7cba946b9","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-12T12:45:16.000Z","msg":"<img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"},{"pid":"08eea371eda3b122fe1dee895a38be5495f343b9","tid":2119220,"uid":100010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-14T04:14:50.000Z","msg":"<img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"},{"pid":"78c815ad67b57c2d73d841e92f7275afd5fbd242","tid":2119220,"uid":92520,"like":0,"dislike":0,"score":0,"quote":{"pid":"830d68c7b86792d2024c937aa4aa454d362f52cb","tid":2119220,"uid":100010,"like":1,"dislike":0,"score":1,"quote":{"pid":"015e7f8389196209a8b8e84f277744ae56251eaa","tid":2119220,"uid":297256,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-20T