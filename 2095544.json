omponent%2Fk2%2F1535932-20200705.htm%3FspTabChangeable%3D0&h=89b735b4\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1535932-20200705.htm?spTabChangeable=0</a>"},"citedBy":0,"replyTime":"2020-07-05T19:18:22.000Z","msg":"習近平是垃圾"},{"pid":"aafd389f1679cf4bd18739a07eef84505042c2c5","tid":2095544,"uid":106739,"like":0,"dislike":6,"score":-6,"citedBy":0,"replyTime":"2020-07-05T19:21:55.000Z","msg":"此回覆已被刪除"},{"pid":"ac223d0ea331f53b0268a16a4ee0ec518925ba04","tid":2095544,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"2df05d64e89cbb8c750645ad76c48bc48d856972","tid":2095544,"uid":39464,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-05T14:04:05.000Z","msg":"洞庭湖水位持續上升，《新華社》報道，防汛形勢嚴峻。<br />\n<br />\n洞庭湖區共有29個堤垸、858公里堤防的水位超出警戒，環洞庭湖地區正在組織人員巡堤查險，準備搶險物資。<br />\n<br />\n內地中央氣象台表示，預計未來四天，持續性強降雨將影響西南地區東部至長江中下游一帶。<br />\n<br />\n貴州、重慶、湖北、江西、安徽、浙江等多個省市，預計累計降雨量將有100至300毫米，湖北東部、安徽西南部局部超過400毫米，預料湖南西北部等地區有大暴雨。<br />\n<br />\n<br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1535932-20200705.htm?spTabChangeable=0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1535932-20200705.htm%3FspTabChangeable%3D0&d=yjoviXv3QiMsqLwchXvj34E4T4y%2BYV5jPOnVoTo%2FPYs%3D&h=339f88e4\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1535932-20200705.htm%3FspTabChangeable%3D0&h=89b735b4\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1535932-20200705.htm?spTabChangeable=0</a>"},"citedBy":0,"replyTime":"2020-07-05T19:23:22.000Z","msg":"習近平是垃圾"},{"pid":"4edd57a0efae37f1ad165dcfd146af0e9041a546","tid":2095544,"uid":35430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-05T21:17:46.000Z","msg":"防洪？放水就放水啦<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b6dfb3e4242fb89dc71dc169a9536441d786967d","tid":2095544,"uid":53695,"like":0,"dislike":0,"score":0,"quote":{"pid":"a634ea4b5494