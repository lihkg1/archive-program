ike":0,"score":7,"quote":{"pid":"95bf40d5d7630697d88d2c59b11ae6ceba07b278","tid":1988873,"uid":96210,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-04-25T15:36:42.000Z","msg":"<a href=\"https://www.instagram.com/p/B_aJ-JLltFu/?igshid=1ay2ffc4dbkc7\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fp%2FB_aJ-JLltFu%2F%3Figshid%3D1ay2ffc4dbkc7&d=5PHCsmqc8bXRSfVPwy6hKkn12mAFq1syGW6OSBl8LUM%3D&h=d3edb58d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.instagram.com%2Fp%2FB_aJ-JLltFu%2F%3Figshid%3D1ay2ffc4dbkc7&h=d2b91662\" target=\"_blank\">https://www.instagram.com/p/B_aJ-JLltFu/?igshid=1ay2ffc4dbkc7</a>"},"citedBy":1,"replyTime":"2020-04-25T15:48:14.000Z","msg":"佢認左 <br />\n靠上床 上位"},"citedBy":0,"replyTime":"2020-04-25T17:04:25.000Z","msg":"被插的時候想過對不起周揚青嗎？<br />\n<br />\n啲人留言<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ccfc1eba178a4bf439d03c510bb0d1cebd5427f3","tid":1988873,"uid":126698,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-25T17:04:50.000Z","msg":"菜花若開 蝴蝶自來"},{"pid":"a8c70666022fda85563583efd1e8aa7ad7fa21fd","tid":1988873,"uid":184756,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-25T17:21:06.000Z","msg":"拉"},{"pid":"69f4b118c442f83dedebcf48156b48b63f8d8fdf","tid":1988873,"uid":13230,"like":18,"dislike":0,"score":18,"citedBy":0,"replyTime":"2020-04-25T17:21:42.000Z","msg":"<img src=\"https://na.cx/i/abqaLQb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FabqaLQb.jpg&h=7717242c&s={SIZE}\" />"},{"pid":"8fd8d8f14fd7c0b57636d67db9b57a37876ccd8f","tid":1988873,"uid":197351,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-04-25T17:29:20.000Z","msg":"望完都唔明????<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />有幾個人起度un,then?<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"4b6dfcd6ecc583702054980466d3ce57f8c133b7","tid":1988873,"uid":204348,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-25T17:30:38.000Z","msg":"On9"},{"pid":"26f3f404c6c2047810ab03d91444ea42b31d790e","tid":1988873,"uid":256127,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-25T17:36:09.000Z","msg":"<a href=\"https://petition.parliament.uk/petitions/300091\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F300091&d=5PHCsmqc8bXRSfVPwy6hKkn12mAFq1syGW6OSBl8LUM%3D&h=faf52c45\" target=\"_blank\">https://petition.parliament.uk/petitions/300091</a><br />\n<br />\nBNO 平權聯署，多你一個多好多快簽！<br />\n<br />\n努力過才不會後悔！英國係廢國都好，最緊要平權後更無顧幫班97後！<br />\n<br />\nPetition 寫uk citizen 但係唔洗理，照簽就得！(你而家咪爭取緊囉吊你）<br />\n<br />\nPostcode 可填E17AA<br />\n<br />\n6月下議院會正式投票平權法案！佢地需要子彈！<br />\n<br />\n一個人力量有限請大家幫忙廣傳！<br />\n<br />\n以下為msn 新聞<br />\n<br />\n香港局勢變幻莫測，不少人都會選擇續領英國BNO。但擁有BNO並不享有居英權和工作權，只是當持有人身處具BNO簽證待遇的國家地區，能夠向當地英國領事館求助。<br />\n<br />\n　　不過英國自由民主黨議員Alistair Carmichael提出的BNO平權法案，日前成功在英國下議院獲首讀通過，意味BNO持有人的待遇將來或可能有望得到提高。<br />\n<br />\n　　Alistair Carmichael的法案提出，給予BNO的香港持有人重新享有居英權、工作權，以及重啟BNO申請。換言之，法案一旦通過落實，回歸前出生但未曾申請BNO的港人，屆時都可以重新申請BNO。<br />\n<br />\n　　平權法案目前已順利首讀通過，將於6月12日進行二讀審議。<br />\n<br />\n　　即使BNO已經過期，只要持有人曾經在1997年7月1日前成功申請過BNO，現時都可以重新續領。如果父母的小朋友當初年紀太小，未有為他們申請，原來只要家長曾在BNO內「included child」一欄中，填上當時未滿16歲子女的姓名，他們亦可以擁有申請BNO的資格。"},{"pid":"adc879e6b223c57dafdd52f2edb68400803a5e85","tid":1988873,"uid":157368,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-04-25T17:41:01.000Z","msg":"港獨之父，咩又係你呀！<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">請問你係邊間PR公司？<img src=\"/assets/faces/normal/hehe