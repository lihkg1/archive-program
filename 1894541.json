x%2Fi%2FtV1TEfw.jpg&h=b98618a4&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/Boq1N8R.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBoq1N8R.png&h=f5e578d4&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/hqiZzOS.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhqiZzOS.png&h=e4c67643&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/PkiF3Hd.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPkiF3Hd.png&h=df3ba1f6&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/rHN31tT.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrHN31tT.png&h=576446f8&s={SIZE}\" /><br />\n<span style=\"font-size: xx-large;\">原來7月17 已經預示到721發生<br />\n<br />\n屌佢老母班賤種狗<br />\n煲大！</span>"},{"pid":"8057ea77bc0acba8d5a1436a34a940a9a53f550b","tid":1894541,"uid":10757,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-02-24T04:08:01.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />班狗根本一早計劃好721"},{"pid":"ab237662bd20aaf257a18bf4d0a84cceae45dcb8","tid":1894541,"uid":146285,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T04:09:29.000Z","msg":"推<br />\n<a href=\"https://www.facebook.com/1484748651847035/posts/2584687148519841/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F1484748651847035%2Fposts%2F2584687148519841%2F%3Fd%3Dn&d=SulGM1C%2FSMvfI9hDp2hpAsemYpZY8oJkMX6FO%2BQoeBQ%3D&h=cf520144\" data-auto-link target=\"_blank\">https://www.facebook.com/1484748651847035/posts/2584687148519841/?d=n</a><br />\n新post 大家繼續入去推爆佢！"},{"pid":"c118f987f776f195dfb88239a3aeceb51529d032","tid":1894541,"uid":120604,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-02-24T04:14:48.000Z","msg":"敬啟者：<br />\n          查詢打壓教師言論自由事宜<br />\n  有鑒 早前貴校於社交媒體發佈文章，指署理副校長何柏欣老師因facebook言論受到停職處分。然而，何老師使用私人帳戶發表個人言論，屬《基本法》保障的言論自由。<br />\n加上本人查看其內容並無不妥，作為一校之副長，呼籲市民在艱難時刻齊心抗疫。當然，不同人對事情有不同見解，有心人若要雞蛋裏挑骨頭屬無可奈何。<br />\n但若 貴校偏聽一面之詞，而將一個教師停職處分，不但打擊嚴重教育工作者的權益和士氣，更會引起同界疑慮，質疑教育界未審先判，有無故造文字獄以及白色恐怖之嫌。<br />\n<br />\n我亦十分疑慮 貴校能否秉持開放自由的教學態度，日後學生若在校園接受言論和思想篩查，將極大損害他們的思維發展。<br />\n 近來警方多次失當發言，包括在別人忌日高呼開香檳等， 貴校未有教育學生引以為戒，反而篩查教師在個人社交帳號上的言論。<br />\n秉承 貴校校訓，須知禮義廉恥，望校方停止對教師的打壓，因貴校舉動已受到公眾廣泛關注，我定必密切關注後續發展。<br />\n特此來函，望 貴校能取消對何老師的停職處分、尊重教師的言論自由以及清晰公佈不會對其秋後算賬。<br />\n<br />\n鈞安<br />\n普通市民<br />\n（你的名字）<br />\n日期<br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\">[url]http://enquiry@chss.edu.hk[/url]一人一email炸過去！！</span><br />\n多謝巴打，我改咗少少<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"7a32292d8ee04e0e4e0e67cfa959d95afa34cf5f","tid":1894541,"uid":120604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T04:16:06.000Z","msg":"推 推呀"},{"pid":"442c424ce5e184bf5bcdeff49502be3619d914c1","tid":1894541,"uid":120604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T04:23:04.000Z","msg":"推上去"},{"pid":"bba2aae57d042e2a5135e76e042855458f2e0236","tid":1894541,"uid":153186,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T04:23:35.000Z","msg":"推"},{"pid":"fb97cd0123fcf55d147e5941373749dad1097a03","tid":1894541,"uid":54392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T04:25:45.000Z","msg":"已SEND<br />\n<br />\n大家一齊!!!<br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"702e7f5ab7b4e647562f80c73941feaa5faf0016","tid":1894541,"uid":286897,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T04:28:38.000Z","msg":"一個考試精同你講-報復支那孔聖堂中學的方法-千祈唔好用！<br />\n<a href=\"https://lih.kg/1894559\" data-auto-link target=\"_blank\">https://lih.kg/1894559</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"71c52c65da80232acaaf0465bdfc3b3513c9b969","tid":1894541,"uid":224657,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T04:30:20.000Z","msg":"up"},{"pid":"d9e0a70bf4b37b215ef3c30dcdff2469bc4fc6a0","tid":1894541,"uid":120604,"like"