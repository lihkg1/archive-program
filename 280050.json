展合作。派克的計畫是：以其人之道，還治其人之身....<br />\n<br />\n3 15AM左右播了 隨時電腦大爆炸<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"a1d363a299567da02a97cd716375e49cc6b9a8c1","tid":280050,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-11T19:16:40.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"71e4d5b5e3d8c769fa49c0098ee9a3dd237a7b36","tid":280050,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-11T20:15:05.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"}]}