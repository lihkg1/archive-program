ike":4,"dislike":1,"score":3,"quote":{"pid":"1e8efb10042a96d9b6485716c63e0d9fad6710d0","tid":2312061,"uid":128087,"like":4,"dislike":1,"score":3,"citedBy":1,"replyTime":"2020-12-04T14:46:56.000Z","msg":"做鴨做到死，值咩 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-04T14:52:29.000Z","msg":"依個38歲係比屋企人感染<br />\n患在腦癱長期要係復康中心"},"citedBy":1,"replyTime":"2020-12-04T15:39:31.000Z","msg":"佢屋企人做鴨定係玩鴨？"},{"pid":"69c5b9766030ee394649dee9143511fd7f467f4c","tid":2312061,"uid":64922,"like":2,"dislike":1,"score":1,"quote":{"pid":"09904fe5177d4b2faf65b668b714fffd58f4c90d","tid":2312061,"uid":128087,"like":0,"dislike":1,"score":-1,"quote":{"pid":"bbdeb9e994fd80ccb5499b508b53ccd19cdfb793","tid":2312061,"uid":64922,"like":4,"dislike":1,"score":3,"quote":{"pid":"1e8efb10042a96d9b6485716c63e0d9fad6710d0","tid":2312061,"uid":128087,"like":4,"dislike":1,"score":3,"citedBy":1,"replyTime":"2020-12-04T14:46:56.000Z","msg":"做鴨做到死，值咩 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-04T14:52:29.000Z","msg":"依個38歲係比屋企人感染<br />\n患在腦癱長期要係復康中心"},"citedBy":1,"replyTime":"2020-12-04T15:39:31.000Z","msg":"佢屋企人做鴨定係玩鴨？"},"citedBy":1,"replyTime":"2020-12-04T15:59:29.000Z","msg":"<blockquote>不幸離世的病人有神經系統方面的長期病患，因有家人確診，故被列為密切接觸者。病人上月27日因呼吸困難及咳嗽，直接由檢疫中心轉送入瑪麗醫院隔離病房，翌日開始病情惡化，檢測到武肺及甲型流感病毒。因他感染不同病毒及細菌，醫院處方抑制細菌的抗生素、治療武肺的干擾素、瑞德西韋及抗流感藥物，然而病人對藥物的反應欠佳，病情持續惡化，昨晚不幸離世。根據衞生署公佈的資料，他沒有病徵，亦沒有他的行蹤。<br />\n<br />\n38歲死者亦是歌舞群組第二宗死亡個案，首宗群組死者為上周四養和醫院離世的癌症女病人（第6079號個案）。她的一名家人亦確診，該家人曾接觸歌舞群組患者。</blockquote><br />\n<br />\n家下死兩個都唔係真去跳舞玩果班，兩個都係被家人傳染2or3代病人"},{"pid":"fcd325798b7981470c06ea6c4438220b5370b184","tid":2312061,"uid":128087,"like":0,"dislike":0,"score":0,"quote":{"pid":"69c5b9766030ee394649dee9143511fd7f467f4c","tid":2312061,"uid":64922,"like":2,"dislike":1,"score":1,"quote":{"pid":"09904fe5177d4b2faf65b668b714fffd58f4c90d","tid":2312061,"uid":128087,"like":0,"dislike":1,"score":-1,"quote":{"pid":"bbdeb9e994fd80ccb5499b508b53ccd19cdfb793","tid":2312061,"uid":64922,"like":4,"dislike":1,"score":3,"citedBy":1,"replyTime":"2020-12-04T14:52:29.000Z","msg":"依個38歲係比屋企人感染<br />\n患在腦癱長期要係復康中心"},"citedBy":1,"replyTime":"2020-12-04T15:39:31.000Z","msg":"佢屋企人做鴨定係玩鴨？"},"citedBy":1,"replyTime":"2020-12-04T15:59:29.000Z","msg":"<blockquote>不幸離世的病人有神經系統方面的長期病患，因有家人確診，故被列為密切接觸者。病人上月27日因呼吸困難及咳嗽，直接由檢疫中心轉送入瑪麗醫院隔離病房，翌日開始病情惡化，檢測到武肺及甲型流感病毒。因他感染不同病毒及細菌，醫院處方抑制細菌的抗生素、治療武肺的干擾素、瑞德西韋及抗流感藥物，然而病人對藥物的反應欠佳，病情持續惡化，昨晚不幸離世。根據衞生署公佈的資料，他沒有病徵，亦沒有他的行蹤。<br />\n<br />\n38歲死者亦是歌舞群組第二宗死亡個案，首宗群組死者為上周四養和醫院離世的癌症女病人（第6079號個案）。她的一名家人亦確診，該家人曾接觸歌舞群組患者。</blockquote><br />\n<br />\n家下死兩個都唔係真去跳舞玩果班，兩個都係被家人傳染2or3代病人"},"citedBy":0,"replyTime":"2020-12-06T15:55:39.000Z","msg":"Oh, bad luck"}]}