 class=\"hkgmoji\" />"},{"pid":"7279af8f9ad52b53d566de91377ee233313fda9e","tid":1389270,"uid":80931,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T08:21:50.000Z","msg":"幫你推下"},{"pid":"3c3e25c294dbd903bd08f1b20b8f5f228aa1cdc3","tid":1389270,"uid":215977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T08:32:55.000Z","msg":"<img src=\"/assets/faces/fs/want_die.gif\" class=\"hkgmoji\" />開完正經post 冇人push"},{"pid":"ef5bc3272d09ea1dadb479eabf8ffddeeb7bae9f","tid":1389270,"uid":85132,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T08:39:20.000Z","msg":"推"},{"pid":"99b31f6bb2ae41b664a3eccf256fb858f8dad7c4","tid":1389270,"uid":215977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T09:21:46.000Z","msg":"原來正經post 真係冇人入<img src=\"/assets/faces/fs/want_die.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/want_die.gif\" class=\"hkgmoji\" />"},{"pid":"f0efbcb4c982a086aff93a0d0aa702bba056c7ae","tid":1389270,"uid":215977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T10:28:25.000Z","msg":"推到勇武入黎睇<br />\n<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"a54cc09255586a60a25c8e81812e9aa88034eb1f","tid":1389270,"uid":215977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T10:28:47.000Z","msg":"5/8 全民罷工"},{"pid":"3fe40ad1c0ef215b6e2062c4bcec3b51bf8b2c58","tid":1389270,"uid":215977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T10:29:44.000Z","msg":"3/8 又會有炒辣蟹放題<img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" />"},{"pid":"1d44495a2a0873043d2c4e09a1a75c6fdda8c07c","tid":1389270,"uid":83118,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T10:32:17.000Z","msg":"我要罷工"},{"pid":"0803ed5a4b3203ab96ba298c767c4e2ceda572e8","tid":1389270,"uid":83118,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T10:32:34.000Z","msg":"我要罷工"},{"pid":"42c75