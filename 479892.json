tw/Upload/ent/page/800/2017/09/16/phpQ0rmvr.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.ltn.com.tw%2FUpload%2Fent%2Fpage%2F800%2F2017%2F09%2F16%2FphpQ0rmvr.jpg&h=defcd5c9&s={SIZE}\" />"},{"pid":"0d894e43e239f8906cbffc82b322a336abbc7dee","tid":479892,"uid":35221,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-11-25T15:05:41.000Z","msg":"<blockquote><img src=\"http://img.ltn.com.tw/Upload/ent/page/800/2017/09/16/phpQ0rmvr.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.ltn.com.tw%2FUpload%2Fent%2Fpage%2F800%2F2017%2F09%2F16%2FphpQ0rmvr.jpg&h=defcd5c9&s={SIZE}\" /></blockquote><br />\n香港快d上<img src=\"/assets/faces/big/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4b2d118ce616618c39c9eb4d28cc629ee42873b8","tid":479892,"uid":35221,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-11-25T15:11:48.000Z","msg":"金馬54／最佳女主角獎：惠英紅《血觀音》演技爆棚<br />\nYahoo奇摩娛樂新聞\t<br />\n2017年11月25日 下午10:58<br />\n<br />\n<img src=\"https://s.yimg.com/ny/api/res/1.2/DjFS505C2DvgAOqaqgapkg--/YXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9ODAw/http://media.zenfs.com/en/homerun/feed_manager_auto_publish_494/aa178108d7ac2831cfbcb7d1589618e1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs.yimg.com%2Fny%2Fapi%2Fres%2F1.2%2FDjFS505C2DvgAOqaqgapkg--%2FYXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9ODAw%2Fhttp%3A%2F%2Fmedia.zenfs.com%2Fen%2Fhomerun%2Ffeed_manager_auto_publish_494%2Faa178108d7ac2831cfbcb7d1589618e1&h=ea53fcae&s={SIZE}\" /><br />\n<br />\n▲惠英紅過去多次入圍金馬獎女配角獎，但入圍金馬獎女主角卻是頭一次。<br />\n<br />\n香港金像獎及澳門國際電影節影后惠英紅，曾憑藉《幸運是我》、《心魔》2部佳作得到業界與觀眾的廣泛讚譽，作為實力派演員，她總能把片中人物的情緒狀態拿捏得精準到位，表演深入人心，使得每個角色都充滿驚喜，此次演出《血觀音》，她更是表現爆棚，在片中展現長袖善舞的超級演技令人折服。<br />\n<br />\n<br />\n武打片出身的惠英紅，很早就知道自己該轉型否則會被淘汰，可惜每次都被想靠武打片賺錢的老闆阻止，不過這一點也無法遮掩惠英紅展現演技，她自信的說：「我一向都知道我會演，我從3歲到13歲都在香港灣仔一帶叫賣養家，從小就要看每一個人臉色找飯吃，我怎麼可能不會演。」<br />\n<br />\n不過惠英紅過去多次入圍金馬獎女配角獎，但入圍金馬獎女主角卻是頭一次，不難看見她在《血觀音》裡每一場戲都全力演出，即使最後一幕是躺在病床上，她也花了一天時間找出適合的音頻，用聲音演戲。片中有一幕惠英紅走進KTV唱歌，為了這場戲她自掏腰包，花了2、3萬元港幣學唱歌，用功程度相當驚人。<br />\n<br />\n《血觀音》描述惠英紅、吳可熙、文淇扮演的一家女性，通過高超手腕及柔軟身段，在複雜的政商關係中生存取利，卻因為一樁滅門懸案，捲入彼此的愛恨情仇中。<br />\n<br />\n<a href=\"https://tw.news.yahoo.com/金馬54／最佳女主角獎：惠英紅《血觀音》演技爆棚-145836228.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.news.yahoo.com%2F%E9%87%91%E9%A6%AC54%EF%BC%8F%E6%9C%80%E4%BD%B3%E5%A5%B3%E4%B8%BB%E8%A7%92%E7%8D%8E%EF%BC%9A%E6%83%A0%E8%8B%B1%E7%B4%85%E3%80%8A%E8%A1%80%E8%A7%80%E9%9F%B3%E3%80%8B%E6%BC%94%E6%8A%80%E7%88%86%E6%A3%9A-145836228.html&d=nbEkwJZyxDf0eudeM5RHHdr9upuAghWR75VkZoMWgf8%3D&h=5eefa28e\" target=\"_blank\">https://tw.news.yahoo.com/金馬54／最佳女主角獎：惠英紅《血觀音》演技爆棚-145836228.html</a>"},{"pid":"0abea9342cb358e059ac822836442eeb5b3768ab","tid":479892,"uid":35221,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-25T15:13:02.000Z","msg":"血觀音贏埋最佳劇情片！！<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"3a2e0258030ca760c3396ef50a32b1b01e176a8d","tid":479892,"uid":35221,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-25T16:43:48.000Z","msg":"十二月大家入場支持<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c8deec9a6296160895af349f807cce294662677a","tid":479892,"uid":129039,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-25T16:46:39.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b2f742d2ababc5cf786035e4da7e95492bceb4cb","tid":479892,"uid":35221,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-26T05:57:13.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"}