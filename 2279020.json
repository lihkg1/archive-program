class=\"hkgmoji\" /><br />\n<br />\n英國走得更前<img src=\"/assets/faces/lomoji/38.png\" class=\"hkgmoji\" />"},{"pid":"0f0d1156cde9d7998d246fd1371226c8a0a4fd61","tid":2279020,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-09T13:37:50.000Z","msg":"push"},{"pid":"9d9b756d900a5a8ed3db5fd49e5e81402272428e","tid":2279020,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-09T13:38:09.000Z","msg":"push"},{"pid":"a1e04ece5deb061a1b01ef84a19e6f336cbecbe3","tid":2279020,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-09T13:38:27.000Z","msg":"push"},{"pid":"946b8c5ab0f9ef10f1d7c8f299d04e0361f43446","tid":2279020,"uid":32204,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-11-09T13:39:15.000Z","msg":"<a href=\"https://youtu.be/CINVwWHlzTY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FCINVwWHlzTY&d=YlPq7SqekvAy96d0W8R9y%2BNdVtVfIexd6qH9K0u6Sk4%3D&h=1f16bd6b\" data-auto-link target=\"_blank\">https://youtu.be/CINVwWHlzTY</a><br />\n呢條片喺技術上解釋咗點解就算原意係好都好，任何政府都唔應該要求後門"},{"pid":"2c766c28fdc88b2df867c6ea5138514c4505684b","tid":2279020,"uid":138409,"like":0,"dislike":0,"score":0,"quote":{"pid":"946b8c5ab0f9ef10f1d7c8f299d04e0361f43446","tid":2279020,"uid":32204,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-11-09T13:39:15.000Z","msg":"<a href=\"https://youtu.be/CINVwWHlzTY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FCINVwWHlzTY&d=YlPq7SqekvAy96d0W8R9y%2BNdVtVfIexd6qH9K0u6Sk4%3D&h=1f16bd6b\" data-auto-link target=\"_blank\">https://youtu.be/CINVwWHlzTY</a><br />\n呢條片喺技術上解釋咗點解就算原意係好都好，任何政府都唔應該要求後門"},"citedBy":0,"replyTime":"2020-11-09T13:41:06.000Z","msg":"tom scott<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a0034492c74511905fe84201e37daa5aa4ed4d99","tid":2279020,"uid":118120,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-11-09T13:42:45.000Z","msg":"big brother is watching you<br />\n你連投票都會俾對家人