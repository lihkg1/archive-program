id":"7bb327eb02a3eee1b24eb8607a13447105aef334","tid":2193384,"uid":38861,"like":2,"dislike":1,"score":1,"quote":{"pid":"149398f630dee07fc96044145f84caf536ed004c","tid":2193384,"uid":155238,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-08T21:17:14.000Z","msg":"薯仔而家仲攞唔攞到grant呀？"},"citedBy":0,"replyTime":"2020-09-08T21:19:33.000Z","msg":"<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />依排就係有幾個deadline衝緊，依一兩日暫停深入淺出，週末會補番<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />"}]}