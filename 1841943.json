43,"uid":102214,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T13:19:29.000Z","msg":"尊重醫護決定"},{"pid":"b5e03862b53d02a23cb6403fa69bfd7aeec8caf5","tid":1841943,"uid":241331,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T13:21:48.000Z","msg":"推"},{"pid":"fe043ad0bd9ef1dd5f73f819d7a88aa86fe83818","tid":1841943,"uid":262063,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T13:21:50.000Z","msg":"睇完今日記者會，更加確定香港人只可以自求多福<br />\n<br />\n希望醫護人員罷工<br />\n現在罷工，香港人受影響無咁大<br />\n到他日香港人都感染要照顧時<br />\n就更難罷"},{"pid":"c66bc224f2c275990802103d0a4d804440bab80b","tid":1841943,"uid":16565,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T13:24:03.000Z","msg":"推"}]}