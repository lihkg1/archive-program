7:35.000Z","msg":"舊區其實都唔錯 但係個人會中意行山 <br />\n想吸收下新鮮空氣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5b2f47199df31d14a9ed33496c11e870d3224d09","tid":25381,"uid":54702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-06T18:46:17.000Z","msg":"留名"},{"pid":"ff9b91661ab12281528f3d70e481c5a84b5b97a6","tid":25381,"uid":32879,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-06T18:47:41.000Z","msg":"其實香港求其搵座山行都已經好多靚景睇<br />\n<img src=\"https://img.eservice-hk.net/upload/2016/12/07/024726_e43450b957b8b77c98c0efe240b045b9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2016%2F12%2F07%2F024726_e43450b957b8b77c98c0efe240b045b9.jpg&h=baad1e84&s={SIZE}\" /><br />\niphone 9影<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"9b7a96ef78168b8a7f12ae7a974a729729d636ae","tid":25381,"uid":14001,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-06T19:23:33.000Z","msg":"Lm"},{"pid":"63a79148b203fba1a67ebab09278ec38745f8b52","tid":25381,"uid":16946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-06T19:33:20.000Z","msg":"有咩地方好介紹"},{"pid":"11eaca51d8652d55ae3d3b741f2eefe0e182d3dc","tid":25381,"uid":40542,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-06T19:39:32.000Z","msg":"無<br />\n想試吓好耐"},{"pid":"127cb5243d4a4ea75bcac3b28d6f089f9ccded53","tid":25381,"uid":53440,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-06T19:52:24.000Z","msg":"比多舊磚<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"http://www.discoverhongkong.com/tc/index.jsp\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.discoverhongkong.com%2Ftc%2Findex.jsp&d=LpDakJBiuObdGkynJVcQHZkBtgkcD0hE3Em2wkgk6m8%3D&h=19b22169\" target=\"_blank\">http://www.discoverhongkong.com/tc/index.jsp</a><br />\n<br />\n個網係香港旅遊發展局既 <br />\n如果係行山黎講 入面都有講左香港常行個d山<br />\n<a href=\"http://www.discoverhongkong.com/tc/