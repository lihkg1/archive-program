多港豬"},{"pid":"e052a164e9e41f86b3d652a2c53d36d88ade1558","tid":2117904,"uid":54927,"like":1,"dislike":0,"score":1,"quote":{"pid":"460473f0a6277010c607c14cddd6f42fb29e83ab","tid":2117904,"uid":231886,"like":11,"dislike":2,"score":9,"quote":{"pid":"1e373e998078981b58de97589e083a138c9d27fe","tid":2117904,"uid":179606,"like":2,"dislike":38,"score":-36,"quote":{"pid":"b56958bfc9eafeda08e9af55e6514c59ea5e0d13","tid":2117904,"uid":231886,"like":7,"dislike":8,"score":-1,"citedBy":4,"replyTime":"2020-07-21T07:25:47.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />慣例問句：藍定黃？"},"citedBy":3,"replyTime":"2020-07-21T12:12:18.000Z","msg":"唔好乜七都藍黃la on9"},"citedBy":1,"replyTime":"2020-07-21T12:28:20.000Z","msg":"你先on9，<span class=\"xx-large\"><span class=\"blue\">即係古舊藍店就可以同情佢？</span></span>"},"citedBy":0,"replyTime":"2020-07-22T23:17:53.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />政治入血<br />\n<br />\n 冇撚得救"},{"pid":"822e41be543f663655b01c92b2bdbb32f1524495","tid":2117904,"uid":162103,"like":0,"dislike":0,"score":0,"quote":{"pid":"b56958bfc9eafeda08e9af55e6514c59ea5e0d13","tid":2117904,"uid":231886,"like":7,"dislike":8,"score":-1,"citedBy":4,"replyTime":"2020-07-21T07:25:47.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />慣例問句：藍定黃？"},"citedBy":0,"replyTime":"2020-07-22T23:19:04.000Z","msg":"應該中立 搵唔到資料顯示"},{"pid":"85348fe01b7f093fc1d68b7088d78bdb6ca513cf","tid":2117904,"uid":162103,"like":2,"dislike":0,"score":2,"quote":{"pid":"1e373e998078981b58de97589e083a138c9d27fe","tid":2117904,"uid":179606,"like":2,"dislike":38,"score":-36,"quote":{"pid":"b56958bfc9eafeda08e9af55e6514c59ea5e0d13","tid":2117904,"uid":231886,"like":7,"dislike":8,"score":-1,"citedBy":4,"replyTime":"2020-07-21T07:25:47.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />慣例問句：藍定黃？"