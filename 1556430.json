e":"2019-09-10T01:38:06.000Z","msg":"推"},{"pid":"2fa713cd962be15b3fa625fc0d29eac70b46b7ec","tid":1556430,"uid":258731,"like":0,"dislike":0,"score":0,"quote":{"pid":"6120a9d37659018f6361d59ed8623a86a54a1d40","tid":1556430,"uid":20723,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-09T17:15:24.000Z","msg":"<img src=\"https://na.cx/i/0pEqbc4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0pEqbc4.png&h=1f16fd8e&s={SIZE}\" /><br />\n<br />\n<a href=\"https://petitions.whitehouse.gov/petition/request-communist-china-government-redeem-imperial-dynasty-s-bond\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Frequest-communist-china-government-redeem-imperial-dynasty-s-bond&d=e21%2BqJk643s04YHbVA6HNnXW3JPDzH8o%2FFP8rJ6jlcg%3D&h=ae1df547\" target=\"_blank\">https://petitions.whitehouse.gov/petition/request-communist-china-government-redeem-imperial-dynasty-s-bond</a><br />\n<br />\n任何國際之間既債務都有繼承義務<br />\n慈禧簽果條辛丑條約 一戰果時民國繼續還<br />\n仲要還到1938年因爲打二戰窮到pk<br />\n去求條約國唔追辛丑賠款先可以停<br />\n既然中共自稱滿清正統承繼人<br />\n呢張債券自然本利點都要還<br />\n唔還既佢講乜差野要用南京條約去收番香港<br />\n而且美國政府係未同中共追還錢<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/wjpU2AG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwjpU2AG.jpg&h=45a46f02&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">Yes! US</span></strong></span>"},"citedBy":1,"replyTime":"2019-09-10T01:38:39.000Z","msg":"<img src=\"https://na.cx/i/a14NDGA.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fa14NDGA.png&h=b89ad2c6&s={SIZE}\" /> <img src=\"https://na.cx/i/KL7GH8h.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKL7GH8h.png&h=85dd15fd&s={SIZE}\" /> <img src=\"https://na.cx/i/HEYe28i.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHEYe28i.png&h=4c7ba601&s={SIZE}\" /> <br />\n<img src=\"