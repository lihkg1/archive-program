ike":0,"score":0,"quote":{"pid":"d7bc9566c67e42085ac282bed58318f5f285ee42","tid":1061410,"uid":225798,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-17T08:49:08.000Z","msg":"星期六無local tour!?????<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><br />\n我見好多Almaty tour係weekend....."},"citedBy":2,"replyTime":"2019-03-17T17:40:24.000Z","msg":"好多都係private tour 貴幾倍<br />\n我淨係搵到呢間係有做group tour<br />\n<a href=\"https://www.skyway.kz/en/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.skyway.kz%2Fen%2F&d=%2FIrJ3RR%2Fwz8SFLZOEAJhpkYD92OErucUe%2F0sHRi%2FZkY%3D&h=5e3a4b4d\" data-auto-link target=\"_blank\">https://www.skyway.kz/en/</a><br />\n佢地都有搞Big Almaty Lake tour 但唔係每日有"},"citedBy":1,"replyTime":"2019-03-18T11:28:35.000Z","msg":"巴打仲係咪係almaty要搵guide我有contact想要留tg<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n舊年4月去almaty都落雪<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />不過凍凍地都舒服過喺香港<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-18T23:22:10.000Z","msg":"已經走左<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />四月落雪<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />我呢幾日有十幾度<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},{"pid":"21be75cb73cf26e65994ca12f93d6e23a014fdb9","tid":1061410,"uid":99381,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-18T23:33:17.000Z","msg":"Almaty Day3<br />\n原本Book左去Charyn Canyon<br />\nGroup Tour 7200 tenge<br />\n佢約左我8點半等 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n去到係個女仔接我 帶我行到2架旅遊巴到<br />\n佢同司機講左一大輪 結果係話漏左我而2架車都Full晒<img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><br />\n睇得出佢真係好唔好意思 跟住問我有無興趣Join佢地City tour 免費既<br />\n我無咩興趣⋯最後我話我去medeo <img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" /><br />\n(雪山黎既 風景好靚 d人去到未必真係滑雪就淨係睇下景)<br />\n佢帶我搭地鐵 去到教我搭巴士<br />\n同佢都幾好傾 佢約左我下奏我去完滑雪返黎帶我去行下Abay Street<br />\n咁我就出發去滑雪啦<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><br />\n巴士去到山腳 可以轉巴士/搭纜車上去<br />\n上到去<br />\n<img src=\"https://na.cx/i/6f6ZTCX.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6f6ZTCX.png&h=65075180&s={SIZE}\" /><img src=\"https://na.cx/i/hBd5Pbm.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhBd5Pbm.png&h=b8702310&s={SIZE}\" /><br />\n呢到都好多餐廳 隔離播住音樂<br />\n坐係到望住個景食野都幾Chill<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><br />\n本身我無諗住滑雪既 不過見人玩好正咁最後都係滑！！<img src=\"/assets/faces/lm2/eating.gif\" class=\"hkgmoji\" /><br />\n纜車飛+上2個鐘堂+租野 7百零蚊<br />\n係咁仆街 不過玩得好開心 爽！<br />\n<img src=\"https://na.cx/i/bKvG6Yq.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbKvG6Yq.png&h=f036656e&s={SIZE}\" /><br />\n滑完雪就返去搵個女仔<br />\n佢約左我係個地鐵站 咁我搭過去<br />\n我遲左小小 搭緊個陣好想同佢講會遲 但電話完全收唔到<br />\n呢個時候我竟然係地鐵到見到佢 好巧合<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n佢話Abay Street係多後生仔去既地方<br />\n有d似旺角 有人賣畫同唔少街頭表演<br />\n<img src=\"https://na.cx/i/zpQ4kjS.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzpQ4kjS.png&h=ae0187f9&s={SIZE}\" /><img src=\"https://na.cx/i/a3dQ0jW.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fa3dQ0jW.png&h=ef7b7536&s={SIZE}\" /><br />\n沿路同佢傾左好多計 好岩傾，都講得幾deep下<br />\n晚餐食左Pizza<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/oYGCFiX.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FoYGCFiX.png&h=9283337a&s={SIZE}\" /><br />\n食完都9點幾 call車同佢一齊搭返我hostel 佢再行返屋企<br />\n臨走其實我好唔捨得佢<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n同佢好投契 識左無耐但都有講有笑 咩話題都講<br />\n如果佢係香港我諗應該同佢係好好朋友<br />\n/<br />\n哈薩克到呢到<br />\n岩岩到阿塞拜疆<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/fq5sh7o.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Ffq5sh7o.png&h=51bff336&s={SIZE}\" />"},{"pid":"b24e1ef9e3b2bfb898a5f4d51f2bd1e045cb0236","tid":1061410,"uid":237901,"like":0,"dislike":0,"score":0,"quote":{"pid":"1c30b8f33d17aae1d166591cd580a7c73fa87aa5","tid":1061410,"uid":99381,"like":0,"dislike":0,"score":0,"quote":{"pid":"98f0a57630c31716b1bed3b46973871ec7d193c9","tid":1061410,"uid":237901,"like":0,"dislike":0,"score":0,"quote":{"pid":"3cd65fab36d30b19cebf729dd02c63e9d0e9d47b","tid":1061410,"uid":99381,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-03-17T17:40:24.000Z","msg":"好多都係private tour 貴幾倍<br />\n我淨係搵到呢間係有做group tour<br />\n<a href=\"https://www.skyway.kz/en/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.skyway.kz%2Fen%2F&d=%2FIrJ3RR%2Fwz8SFLZOEAJhpkYD92OErucUe%2F0sHRi%2FZkY%3D&h=5e3a4b4d\" data-auto-link target=\"_blank\">https://www.skyway.kz/en/</a><br />\n佢地都有搞Big Almaty Lake tour 但唔係每日有"},"citedBy":1,"replyTime":"2019-03-18T11:28:35.000Z","msg":"巴打仲係咪係almaty要搵guide我有contact想要留tg<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n舊年4月去almaty都落雪<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />不過凍凍地都舒服過喺香港<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-18T23:22:10.000Z","msg":"已經走左<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />四月落雪<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />我呢幾日有十幾度<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-19T01:50:51.000Z","msg":"<img src=\"https://na.cx/i/yZv0DRY.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyZv0DRY.jpg&h=40d3e045&s={SIZE}\" /><br />\nIP 都唔洗check