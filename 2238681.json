d":"e9790d46ab7d41d5967821aed8ed9e152eb4e27b","tid":2238681,"uid":253608,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-11T10:54:55.000Z","msg":"有排先有得打啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-10-11T10:58:01.000Z","msg":"要過嚴謹臨床研究，牛津疫苗當然無咁快可以打。<br />\n<br />\n不過中國的國產Sinopharm疫苗，就唔理好醜、唔理第三期研究結果，早就喺7月22日不斷公開俾人打。<img src=\"/assets/faces/dog/treat.gif\" class=\"hkgmoji\" />"},{"pid":"cf8a644f88af185f08ef7a8b56f6e3767dbe0c2c","tid":2238681,"uid":29929,"like":0,"dislike":0,"score":0,"quote":{"pid":"93d84c9a05ee0bfc2207c98ef9abd55e8d36617a","tid":2238681,"uid":38861,"like":2,"dislike":1,"score":1,"quote":{"pid":"e9790d46ab7d41d5967821aed8ed9e152eb4e27b","tid":2238681,"uid":253608,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-11T10:54:55.000Z","msg":"有排先有得打啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-10-11T10:58:01.000Z","msg":"要過嚴謹臨床研究，牛津疫苗當然無咁快可以打。<br />\n<br />\n不過中國的國產Sinopharm疫苗，就唔理好醜、唔理第三期研究結果，早就喺7月22日不斷公開俾人打。<img src=\"/assets/faces/dog/treat.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-11T10:59:02.000Z","msg":"唔覆<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"231f5d716009330176381018f5f2de8d93dc99da","tid":2238681,"uid":62020,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-10-11T10:59:28.000Z","msg":"明明雙盲測試<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d1ce1c91628d4fb13995c402832551a2bca5e4fd","tid":2238681,"uid":38861,"like":0,"dislike":1,"score":-1,"quote":{"pid":"231f5d716009330176381018f5f2de8d93dc99da","tid":2238681,"uid":62020,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-10-11T10:59:28.000Z","msg":"明明雙盲測試<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"