":"a8663afe93625c6139e2ea9c42105d9a0aa06ff2","tid":1278413,"uid":54303,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-07-02T13:03:16.000Z","msg":"民陣從良左 班中學雞唔知佢地黑歷史<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-02T13:06:05.000Z","msg":"可能都算係好事...改邪歸正"},{"pid":"1c4d1334269f52e4409a1705444ed773ca4af46d","tid":1278413,"uid":158976,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-07-02T13:13:09.000Z","msg":"冇衝突。<br />\n<br />\n民意好重要<br />\n所以義士衝完，其他人要做嘅唔係割蓆，又係文宣<br />\n要打輿論戰"},{"pid":"8c1a23710e20bd615c62d3c64bef94ba5e613883","tid":1278413,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T14:37:14.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"94ba8c19dba9267f56481b83322cbc79e90c9a0e","tid":1278413,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T03:45:18.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"f6077bb1b050633f828faf8ae169995e60894163","tid":1278413,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T04:25:55.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"2b43c89ba6610d3d62ba5e917819879b15224173","tid":1278413,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T04:47:00.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4711776e5ae70f59399e8ec8d591a0b1a6fea56e","tid":1278413,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T04:53:15.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"}]}