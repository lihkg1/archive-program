=\"hkgmoji\" />"},{"pid":"ec0286f0f48aa7fc2d4a3e39c179468e79f7f76f","tid":1507263,"uid":195169,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-08-26T05:43:29.000Z","msg":"個人意見, 唔贊成...<br />\n好多鬼佬支持香港, 原因唔係獨立...變咗獨立就唔同哂講法...<br />\nSORRY小小愚見, 有錯輕屌<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"66a38f8f9b2665db6488ff536851f9c1de9a1f00","tid":1507263,"uid":52417,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-26T05:43:49.000Z","msg":"我支持，但未係時候，等支共收皮先"},{"pid":"c62f3ce80dfcc536350a6cc65244ddfba5a7289c","tid":1507263,"uid":48083,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-26T05:44:20.000Z","msg":"反對<br />\n<br />\n講咗揾國際幫手就唔可以講獨<br />\n講聯合聲明一國兩制"}]}