i\" />"},{"pid":"579df4d17fd3454b6049ae109a573096de9aaf4e","tid":97434,"uid":319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T07:02:18.000Z","msg":"<blockquote><blockquote><blockquote><br />\nCowsep係咪睇錯勇文青做勇黑刺<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /></blockquote><br />\nIVE仔<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\nIve 仔成日係成人台叫春<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"ba59112cd23506847aa2e154bf42d474abacb9b4","tid":97434,"uid":4493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T07:21:50.000Z","msg":"<blockquote><blockquote><blockquote><br />\nIVE仔<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\nIve 仔成日係成人台叫春<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<br />\n<br />\n《誰人會愛我這種ive仔》<br />\n<br />\n傳說世間每個人 夠十四分即可得到護蔭<br />\n縱使大多彷如弱能 仍得到中六生的身份<br />\n可惜像我這一種人 EAA永遠不肯給予憐憫<br />\n每天如像乞兒 祈求誰可真心的贈我一分<br />\n<br />\n誰成日話我騎呢又柒下 分低到了話我不知羞家<br />\n問我物理合格了嗎人被半路撇下<br />\n受那風吹雨打<br />\n<br />\n誰人會愛我這種IVE仔流落到谷底<br />\n恐怕我已是個社會的夢遺<br />\n無人前來認領三分低b仔會考再報就等下一世<br />\n<br />\n誰要我這種IVE仔<br />\n誰贈我職位<br />\n當有美女路過亦不敢發圍<br />\n誰在從前話我貧窮但美麗但想抱抱就等待轉世<br />\n<br />\n(唉) 我張cert好貴"},{"pid":"b8911932bddee7f6b6740ac060809bf4998cda97","tid":97434,"uid":62579,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T08:32:24.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><br />\n傻鳩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\nCowsep係咪睇錯勇文青做勇黑刺<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /></blockquote><br />\nIVE仔<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\nIve 仔成日係成人台叫春<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /></blockquote><br />\n收撚皮啦屌你老母"}]}