/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-23T13:54:34.000Z","msg":"應該係，幫你拎$5000，仲想點"},{"pid":"bc79f11021349eab709468b447b65eb6a619bc1f","tid":2297560,"uid":178876,"like":0,"dislike":0,"score":0,"quote":{"pid":"bac604943a0566d48e7d2228e5a7cffd175c71b3","tid":2297560,"uid":288304,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-23T11:07:19.000Z","msg":"配合政府新政策👍🏻"},"citedBy":0,"replyTime":"2020-11-23T15:12:34.000Z","msg":"醉曖恭司<br />\n死都唔請假爬都要爬返去"},{"pid":"4b7848c3ef4be666e54ff8805cdbe55305f6107a","tid":2297560,"uid":20867,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-11-23T21:31:56.000Z","msg":"返公司當面同HR講淸講楚lor"},{"pid":"2b438b1c98d375f68cf9d08ac4c0465eebeb88bc","tid":2297560,"uid":82929,"like":0,"dislike":7,"score":-7,"quote":{"pid":"c879ca200273e6e7020018782b561cd17f06851b","tid":2297560,"uid":158499,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-11-23T11:09:15.000Z","msg":"最差係跟返勞工法例，唔係佢話係咁就咁"},"citedBy":2,"replyTime":"2020-11-23T23:32:32.000Z","msg":"SL係可以冇人工<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n4/5人工係工傷"},{"pid":"78ef7f11b6b299d9bf142196ee19f5138eee784b","tid":2297560,"uid":17747,"like":1,"dislike":0,"score":1,"quote":{"pid":"2b438b1c98d375f68cf9d08ac4c0465eebeb88bc","tid":2297560,"uid":82929,"like":0,"dislike":7,"score":-7,"quote":{"pid":"c879ca200273e6e7020018782b561cd17f06851b","tid":2297560,"uid":158499,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-11-23T11:09:15.000Z","msg":"最差係跟返勞工法例，唔係佢話係咁就咁"},"citedBy":2,"replyTime":"2020-11-23T23:32:32.000Z","msg":"SL係可以冇人工<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n4/5人工係工傷"},"citedBy":1,"replyTime":"2020-11-23T23:38:19.000Z","msg":"問 1.僱 員 在 甚 麼 情 況 下 可 享 有 疾 病 津 貼 ？答 1.<br />\n僱 員 按&nbsp;連 續 性 合 約&nbsp;受 僱 ， 如 符 合 以 下 資 格 ， 便 可 領 取 疾 病 津 貼 ：<br />\n<br />\n( 1 )<br />\n<br />\n病假不少於連續4天（除懷孕僱員因產前檢查、產後治療或流產而缺勤，在這些情況下，如符合下述的規定，每一天病假均可享有疾病津貼）；<br />\n<br />\n( 2 )<br />\n<br />\n僱員能夠出示適當的醫生證明書*；及<br />\n<br />\n( 3 )<br />\n<br />\n僱員已累積足夠的有薪病假&nbsp;（關於累積有薪病假日的資料，請按此處參閱答2。）&nbsp;。<br />\n<br />\n有薪病假可分爲第1 類及第2 類。第1 類病假最多可累積36天，36天以外的病假應撥入第2 類，第2 類病假最多可累積84天。<br />\n僱 員 如 放 取&nbsp;第 1 類&nbsp;有薪病假，須有由註冊醫生、註冊中醫或註冊牙醫簽發的醫生證明書*。<br />\n<br />\n當僱員放取的病假日數超過第1類病假的尚餘日數而需要放取第2類有薪病假，如僱主提出要求，僱員須出示在醫院門診部或留院時為他診治的註冊醫生、註冊中醫或註冊牙醫簽發的醫生證明書*。如僱主提出要求，亦須提交該證明書的簽發者所作過的診斷及治療的簡略紀錄。<br />\n<br />\n* 醫生證明書須指明僱員不適宜工作的日數，及導致該僱員不適宜工作的疾病或損傷性質。"},{"pid":"b3115ed388d7f9cd5cd0c98a33dd2b816b205005","tid":2297560,"uid":25794,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-11-23T23:54:29.000Z","msg":"基本上得班綜援支那閪先拎到<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"19d644c24e9983bfec535d4f45b44c43ed2463b6","tid":2297560,"uid":158499,"like":0,"dislike":0,"score":0,"quote":{"pid":"78ef7f11b6b299d9bf142196ee19f5138eee784b","tid":2297560,"uid":17747,"like":1,"dislike":0,"score":1,"quote":{"pid":"2b438b1c98d375f68cf9d08ac4c0465eebeb88bc","tid":2297560,"uid":82929,"like":0,"dislike":7,"score":-7,"quote":{"pid":"c879ca200273e6e7020018782b561cd17f06851b","tid":2297560,"uid":158499,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-11-23T11:09:15.000Z","msg":"最差係跟返勞工法例，唔係佢話係咁就咁"},"citedBy":2,"replyTime":"2020-11-23T23:32:32.000Z","msg":"SL係可以冇人工<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n4/5人工係工傷"},"citedBy":1,"replyTime":"2020-11-23T23:38:19.000Z","msg":"問 1.僱 員 在 甚 麼 情 況 下 可 享 有 疾 病 津 貼 ？答 1.<br />\n僱 員 按&nbsp;連 續 性 合 約&nbsp;受 僱 ， 如 符 合 以 下 資 格 ， 便 可 領 取 疾 病 津 貼 ：<br />\n<br />\n( 1 )<br />\n<br />\n病假不少於連續4天（除懷孕僱員因產前檢查、產後治療或流產而缺勤，在這些情況下，如符合下述的規定，每一天病假均可享有疾病津貼）；<br />\n<br />\n( 2 )<br />\n<br />\n僱員能夠出示適當的醫生證明書*；及<br />\n<br />\n( 3 )<br />\n<br />\n僱員已累積足夠的有薪病假&nbsp;（關於累積有薪病假日的資料，請按此處參閱答2。）&nbsp;。<br />\n<br />\n有薪病假可分爲第1 類及第2 類。第1 類病假最多可累積36天，36天以外的病假應撥入第2 類，第2 類病假最多可累積84天。<br />\n僱 員 如 放 取&nbsp;第 1 類&nbsp;有薪病假，須有由註冊醫生、註冊中醫或註冊牙醫簽發的醫生證明書*。<br />\n<br />\n當僱員放取的病假日數超過第1類病假的尚餘日數而需要放取第2類有薪病假，如僱主提出要求，僱員須出示在醫院門診部或留院時為他診治的註冊醫生、註冊中醫或註冊牙醫簽發的醫生證明書*。如僱主提出要求，亦須提交該證明書的簽發者所作過的診斷及治療的簡略紀錄。<br />\n<br />\n* 醫生證明書須指明僱員不適宜工作的日數，及導致該僱員不適宜工作的疾病或損傷性質。"},"citedBy":0,"replyTime":"2020-11-23T23:59:01.000Z","msg":"當然，僱傭合約有例明而優於勞工法例嘅條款，就跟合約嘅，勞工法例係保障返僱員嘅基本權益"},{"pid":"b77f0488b6391e9b8731e8ceca0b3c5ee0186b25","tid":2297560,"uid":130456,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-24T00:06:06.000Z","msg":"公司對得你咁好 緊係要番去番工 發揚光大啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"267e8378427173609fee5f6114354da9ab3c8462","tid":2297560,"uid":2290,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-24T00:16:22.000Z","msg":"但得5000蚊<br />\n我當你一禮拜返5日，即係要拎10日no pay<br />\n一日先500蚊，唔著數喎"},{"pid":"4ba8269e07f2b302962d99dca2804254c5793e6f","tid":2297560,"uid":192338,"like":0,"dislike":0,"score":0,"quote":{"pid":"26097971697d5527aaadf3239dee250c4b334b8b","tid":2297560,"uid":291491,"like":13,"dislike":0,"score":13,"citedBy":1,"replyTime":"2020-11-23T11:16:41.000Z","msg":"咁同HR講 我死都要死番公司<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-24T00:27:13.000Z","msg":"香港人要返工係唔會病"},{"pid":"dfd8c38c8caf0876b986ceaca0343e247ea1b8f0","tid":2297560,"uid":272652,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-24T00:33:15.000Z","msg":"因為唔納入職安同保險範圍<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />反而冇嘢做中左有五千"},{"pid":"20449e86530ac054e6eefa39b417fe62d4e97baa","tid":2297560,"uid":175673,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-24T00:33:49.000Z","msg":"大家中左武肺都一定要繼續返工"},{"pid":"b2f02013e31660880f250478ad7f22afc6ba6efd","tid":2297560,"uid":72564,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b438b1c98d375f68cf9d08ac4c0465eebeb88bc","ti