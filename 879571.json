{"tid":879571,"cid":31,"subCid":0,"title":"[еҸҲдҝӮжҲ‘]жңүеҶҮUIUX жғіеҗҲдҪң","createTime":"2018-10-28T05:29:15.000Z","updateTime":"2018-12-30T15:58:19.000Z","uid":104580,"like":3,"dislike":4,"uniUserReply":2,"replies":[{"pid":"5cea6e5edb81cee4638537db17553de94bc9f154","tid":879571,"uid":104580,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-28T05:29:15.000Z","msg":"й»Һз·Ҡжү“з®—еҜ«дёҖеҖӢ еҝғдәӢapp [йЎһдјјйҖЈзҷ»   ж„ҹжғ…еҸ° mix еҝғдәӢеҸ°]пјҢдҝҫдәәеҘҪдјјstoryе’ҒеҜ«дҪҺиҮӘе·ұеҝғдәӢпјҢйҷҢз”ҹдәәеҸҜд»Ҙ1пјҡ1 й–Ӣи§ЈдҪўпјҸдҝӮblog еҲ°з•ҷиЁҖ зӯүзӯү&hellip;<br />\n<br />\nжү“з®—жҗөеӨҡеҖӢuiux дёҖйҪҠжҗһ<br />\n<br />\nдҪ иІ иІ¬ иЁӯиЁҲlayout(еҮәPNGпјҢеҮәзҙ жқҗ)    жҲ‘иІ иІ¬еҜ«app еҜ«з¶Ій Ғ<br />\n<br />\nBusiness modeпјҡ з„Ў&hellip;з„ЎйҢўиіәзҡ„&hellip;дҪҶжұӮдҝҫе№ҙиј•дәәеӨҡдёҖеҖӢз©әй–“ дёҚиЁҳеҗҚең°жҠ’зҷјиҮӘе·ұж„ҹеҸ—<br />\nз•¶еӨҡжЁЈйҮҺеҜ«иҗҪиҮӘе·ұprofile<br />\n<br />\nе®ЈеӮіпјҡ еҸҜд»ҘйҖҸйҒҺжҲ‘зӣ®еүҚжңүдёҖеҖӢдәӨеҸӢappдҪңзӮәе№іеҸ°е®ЈеӮі<br />\n<br />\n<br />\n<br />\n<br />\nзӣ®еүҚжҲҗеҠҹдҪңе“Ғжҡ«жҷӮжңүдёҖеҖӢпјҡ HowsYourDate дәӨеҸӢapp<br />\nIOS пјҡ <a href=\"https://itunes.apple.com/us/app/howsyourdate/id1381389467\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fitunes.apple.com%2Fus%2Fapp%2Fhowsyourdate%2Fid1381389467&d=IT0WKWL4evWOYlI9S0Ou9HIou9iuErJt32EjuWI86Zw%3D&h=a58212db\" data-auto-link target=\"_blank\">https://itunes.apple.com/us/app/howsyourdate/id1381389467</a><br />\nANDROID пјҡ <a href=\"https://play.google.com/store/apps/details?id=com.howsyourdate\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fplay.google.com%2Fstore%2Fapps%2Fdetails%3Fid%3Dcom.howsyourdate&d=IT0WKWL4evWOYlI9S0Ou9HIou9iuErJt32EjuWI86Zw%3D&h=39c1343e\" data-auto-link target=\"_blank\">https://play.google.com/store/apps/details?id=com.howsyourdate</a>"},{"pid":"bad16ae803a4113c9eac2675a32a8fde7f888def","tid":879571,"uid":104580,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-28T05:29:47.000Z","msg":"tg : howsyourdate_official"},{"pid":"0050b708aee9d6c2c64