f1914a6","tid":575853,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"b44032283decb75739610a469ed660c9a45dc590","tid":575853,"uid":16676,"like":37,"dislike":1,"score":36,"citedBy":3,"replyTime":"2018-02-28T12:42:48.000Z","msg":"算醒目, 知道塞車唔搭巴士 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n坐東涌線過海再轉西鐵<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-28T12:51:09.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"377038ba112310ceed2ea41539d19af43f97a2d7","tid":575853,"uid":72009,"like":7,"dislike":1,"score":6,"citedBy":0,"replyTime":"2018-02-28T12:52:09.000Z","msg":"又用八達通<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3f7e2cf594d8b6afbaa0e84ad6999a6d5b98be47","tid":575853,"uid":5499,"like":1,"dislike":1,"score":0,"quote":{"pid":"5c50f0ab294349727661fa1bff099e6daa28c880","tid":575853,"uid":102096,"like":22,"dislike":1,"score":21,"quote":{"pid":"b44032283decb75739610a469ed660c9a45dc590","tid":575853,"uid":16676,"like":37,"dislike":1,"score":36,"citedBy":3,"replyTime":"2018-02-28T12:42:48.000Z","msg":"算醒目, 知道塞車唔搭巴士 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n坐東涌線過海再轉西鐵<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-28T12:43:52.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-02-28T13:12:52.000Z","msg":"再好玩d一定係狂轉小巴，的士"},{"pid":"a029445fd6d856c8a9e52b81472150ecbab67fcb","tid":575853,"uid":35746,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-28T13:13:56.000Z","msg":"支槍似真？<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"43808c09a658b0cc2b668d100af5bbbd8cdc08c7","tid":575853,"uid":48093,"like":36,"dislike":1,"score":35,"citedBy":3,"replyTime":"2018-02-28T13:15:55.000Z","msg":"【銀行械劫】疑犯案底纍纍 曾劫銀行與警駁火 再闖小巴脅持人質<br />\n<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20180228/large/1519822786_6ce3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20180228%2Flarge%2F1519822786_6ce3.jpg&h=82c68003&s={SIZE}\" /><br />\n<br />\n中環東亞總行發生械劫案，疑犯晚上於天水圍落網。消息稱，被捕男子姓杜(57歲)，案底纍纍，可謂危險人物，1987年他曾打劫軒尼詩道道亨銀行銀行與與警駁火，再闖上小巴一度脅持人質，幸最終無造成人命傷亡。2016年1月10日他在深水埗北河街一間金行，假扮豪客要求店員取出一條價值2.3萬元金鏈，其間趁機搶走，警方追查4日後，在天水圍一個單位將他拘捕。<br />\n<br />\n據悉，今日下午獨行賊持槍闖入東亞銀行總行，劫走7萬元現金，由於歹徒犯案時沒有戴頭套口罩，其樣貌被銀行及附近的閉路電視拍攝到，警方根據其樣貌特徵，迅即鎖定杜某目標人物追查，結果在案發5小時後，迅即在天水圍目標單位將他拘捕。"},{"pid":"9984022986fd26d1f3257c97e27cd61b118ca007","tid":575853,"uid":97814,"like":62,"dislike":4,"score":58,"citedBy":0,"replyTime":"2018-02-28T13:24:20.000Z","msg":"此回覆已被刪除"},{"pid":"e53ab4bae694d38f850c8036ae13f4c2e3193fc2","tid":575853,"uid":98381,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-02-28T13:31:24.000Z","msg":"點解成日打劫都係東亞<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n我指係裝修前已經係咁"},{"pid":"e00423d7dcceae234fbdb4b4b07549a7a7b0c443","tid":575853,"uid":35468,"like":1,"dislike":3,"score":-2,"citedBy":0,"replyTime":"2018-02-28T13:54:51.000Z","msg":"咁支野真定假?"},{"pid":"4cdda8d4ee9ad5e61e614ba46ce08a778a0eb47d","tid":575853,"uid":36551,"like":36,"dislike":0,"score":36,"citedBy":0,"replyTime":"2018-02-28T13:56:37.000Z","msg":"搞咁大壇野搶七萬<br />\n俾你著到草都唔夠過世啦<img src=\"/assets/faces/lny/clown4.gif\" class=\"hkgmoji\" />"},{"pid":"b98261dfb3f1d4912ab236b218535c2510c3587c","tid":575853,"uid":2076,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2018-02-28T13:58:25.000Z","msg":"七萬<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n做鬼都唔靈"},{"pid":"bbacc0e60fdadc2dd2eb48f0c1805edfe8313434","tid":575853,"uid":119330,"like":48,"dislike":1,"score":47,"citedBy":1,"replyTime":"2018-02-28T14:02:28.000Z","msg":"口罩都唔戴<br />\n係咪好唔掂<br />\n搏拉<b