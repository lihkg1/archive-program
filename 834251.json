citedBy":0,"replyTime":"2018-09-24T16:57:34.000Z","msg":"垃圾耶撚"},{"pid":"50dcf0309f23669f88cf8b46c6ff370f3b87234c","tid":834251,"uid":20816,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-25T07:18:26.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"58b29dc82fa3ad4b9d8642e15a1802dae9e12a42","tid":834251,"uid":20816,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-26T10:46:42.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"289a0f1a2c67f6474528fea28d8f4048ddac6447","tid":834251,"uid":54927,"like":0,"dislike":0,"score":0,"quote":{"pid":"ee14bf0ad87000c0463ed13b8e046a4d4ea4fdac","tid":834251,"uid":20816,"like":0,"dislike":0,"score":0,"quote":{"pid":"42028b668452fc50eedfefa9c77c784a75e325b9","tid":834251,"uid":51469,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2018-09-24T09:05:14.000Z","msg":"耶穌降生為人<br />\n咁點解佢又可以變做.....?"},"citedBy":2,"replyTime":"2018-09-24T12:13:41.000Z","msg":"耶穌係神降生為人<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-26T11:02:23.000Z","msg":"關公係人變神"},{"pid":"737110a6247afb6b262c4aa279f1e65fa9b8900a","tid":834251,"uid":90457,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-26T11:11:19.000Z","msg":"樓主堪稱全港反耶極致<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"906a1114c80fda7195e2dc1d7375f9d609369ec7","tid":834251,"uid":158270,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-09-26T11:51:16.000Z","msg":"耶穌自稱聖子、救世主、彌賽亞；其生母瑪利亞則自稱處女。加利利人耶穌一生都在傳播教義，稱自己將會打救世人，一時之間積累龐大勢力。<br />\n以色列人期望他趕走羅馬人復國，但他沒有起兵反抗，反而束手就擒，後來亡於耶路撒冷。後人寫了《聖經》，說他能復活，能造福人民，但他受極刑而死，他不能保佑自己；瑪利亞也保不住貞節牌坊，他亦不能顯聖復國，怎能稱為&ldquo;救世主&rdquo;呢？<br />\n今日的人拜耶穌為神，起教堂。其實耶穌是個人，一個人怎能變為神呢？不明真相的人迷信耶穌，求他打救，其實他早已在陰間受痛苦了，他連自己都不能救，又怎能救拜他的人呢？他不是神，他只是無知者手到擒來，一個對未知的解釋罷了。"},{"pid":"2a1eb7405614fb96117b9897ef555e034cd25a16","tid":834251,"uid":20816,"like":0,"dislike":0,"score":0,"quote":{"pid":"289a0f1a2c67f6474528fea28d8f4048ddac6447","tid":834251,"uid":54927,"like":0,"dislike":0,"score":0,"quote":{"pid":"ee14bf0ad87000c0463ed13b8e046a4d4ea4fdac","tid":834251,"uid":20816,"like":0,"dislike":0,"score":0,"quote":{"pid":"42028b668452fc50eedfefa9c77c784a75e325b9","tid":834251,"uid":51469,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2018-09-24T09:05:14.000Z","msg":"耶穌降生為人<br />\n咁點解佢又可以變做.....?"},"citedBy":2,"replyTime":"2018-09-24T12:13:41.000Z","msg":"耶穌係神降生為人<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-26T11:02:23.000Z","msg":"關公係人變神"},"citedBy":1,"replyTime":"2018-09-26T12:11:05.000Z","msg":"Yes<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"df34cb8995041fcd1647577ada5f04f1ca6c50be","tid":834251,"uid":20816,"like":0,"dislike":0,"score":0,"quote":{"pid":"737110a6247afb6b262c4aa279f1e65fa9b8900a","tid":834251,"uid":90457,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-26T11:11:19.000Z","msg":"樓主堪稱全港反耶極致<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-26T12:11:17.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"}]}