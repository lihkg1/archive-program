86%AB%E9%99%A2-%E8%A9%A6%E7%9D%80%E8%AA%AA-%E7%A4%BE%E5%8D%80%E6%B2%BB%E7%99%82%E8%A8%AD%E6%96%BD/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E4%25B8%258D%25E8%25A6%2581%25E8%25AA%25AA-%25E6%2596%25B9%25E8%2589%2599%25E9%2586%25AB%25E9%2599%25A2-%25E8%25A9%25A6%25E7%259D%2580%25E8%25AA%25AA-%25E7%25A4%25BE%25E5%258D%2580%25E6%25B2%25BB%25E7%2599%2582%25E8%25A8%25AD%25E6%2596%25BD%2F&d=Surr%2FXenqJySG8qcND35%2F4429F%2FWQzM9xP7K%2BddLk1E%3D&h=9e92fcdd\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E4%25B8%258D%25E8%25A6%2581%25E8%25AA%25AA-%25E6%2596%25B9%25E8%2589%2599%25E9%2586%25AB%25E9%2599%25A2-%25E8%25A9%25A6%25E7%259D%2580%25E8%25AA%25AA-%25E7%25A4%25BE%25E5%258D%2580%25E6%25B2%25BB%25E7%2599%2582%25E8%25A8%25AD%25E6%2596%25BD%2F&h=6446173c\" data-auto-link target=\"_blank\">https://www.thestandnews.com/politics/%E4%B8%8D%E8%A6%81%E8%AA%AA-%E6%96%B9%E8%89%99%E9%86%AB%E9%99%A2-%E8%A9%A6%E7%9D%80%E8%AA%AA-%E7%A4%BE%E5%8D%80%E6%B2%BB%E7%99%82%E8%A8%AD%E6%96%BD/</a>"},"citedBy":0,"replyTime":"2020-08-03T03:56:21.000Z","msg":"呢個要傳媒幫手糾正啦，明明係一個治療中心，或者臨時隔離治療中心，慌咩鬼瘡咁核突。傳媒記者會既時候問野唔好用 慌瘡醫院 呢四個字，完全係詞不達意亂咁叫。"},{"pid":"41ddb9627d94360012f6596b9455b85ee8684630","tid":2137502,"uid":254183,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-03T04:44:28.000Z","msg":"不要說「方艙醫院」，試着說「集中營」"},{"pid":"54155472e0715c5f218b2c7ee546700ef154f83d","tid":2137502,"uid":108757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-03T04:45:27.000Z","msg":"臨時醫院比較好<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"a2bd27ef83c781141f27a5e90020340472775d48","tid":2137502,"uid":60393,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-03T04:46:46.000Z","msg":"社區治療設施個名咁好聽<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 集中營就集中營啦"}]}