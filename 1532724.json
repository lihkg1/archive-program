.cx%2Fi%2FAavDCKN.gif&h=8b049f13&s={SIZE}\" /><img src=\"https://na.cx/i/Zq8BppO.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZq8BppO.gif&h=c464f74f&s={SIZE}\" />"},{"pid":"4659d33bc608bbe914640db1e24a2ea39269a291","tid":1532724,"uid":193233,"like":0,"dislike":0,"score":0,"quote":{"pid":"8d89a05f362d9fd53787811076b757e1e929b133","tid":1532724,"uid":16034,"like":7,"dislike":1,"score":6,"citedBy":2,"replyTime":"2019-09-03T04:29:11.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />講幾句難聽說話<br />\n見到大家播固然係歡迎，但唔好再將香港同烏克蘭掛勾，我地唔配。<br />\n見到有人打曬飛機講香港係summer on fire真係忍唔住笑，斬隻狗放個火都要傳卧底論，見到幾隻速龍黎就散水唔敢還拖，見到手足比人禁低就自己跑快啲無諗要救，成日就話咩唔好送頭唔好流血，仲學人叫光復香港時代革命？<br />\n屌你有無諗過，作為平民又點可能同班狗同等裝備，除左人數同流血覺悟，無野可以拎黎對抗班狗，唔好話咩對準政權，狗就係政權手中既盾，你唔撚打爆個盾就想打個政權，咁撚天真架咩？<br />\n歐美固然可以幫拖，但憑咩野人地要放棄利益黎幫你？永遠將成敗交托係人地手上，呢樣野真係好香港人style，總有班人係IG FB係咁怒屌黎呃like，但真係要上場就多多理由，交比其他人付出啦，成功就共享成果。"},"citedBy":0,"replyTime":"2019-09-03T06:26:58.000Z","msg":"駁唔到!<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"698016017c40443b32d11fe701ed3a74c55a4374","tid":1532724,"uid":34869,"like":0,"dislike":0,"score":0,"quote":{"pid":"a0ee9f56ae9fbaf0f95d4cc8931f037900318fae","tid":1532724,"uid":159159,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-03T06:24:57.000Z","msg":"未睇地厚天高<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-03T06:28:00.000Z","msg":"<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />搞撚錯呀<br />\n罰你番去睇十次"},{"pid":"186e01b960348ddf0924e2246cc8e3b216765133","tid":1532724,"uid":53254,"like":0,"dislike":0,"score":0,"quote":{"pid":"8d89a05f362d9fd53787811076b757e1e929b133","tid":1532724,"uid":16034,"like":7,"dislike":1,"score":6,"citedBy":2,"replyTime":"2019-09-03T04:29:11.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />講幾句難聽說話<br />\n見到大家播固然係歡迎，但唔好再將香港同烏克蘭掛勾，我地唔配。<br />\n見到有人打曬飛機講香港係sum