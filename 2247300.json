/pig/wail2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" />"},{"pid":"5a08d244b7961c626307bb8c8e5370e40f9ee7c6","tid":2247300,"uid":200249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-17T18:36:12.000Z","msg":"雪國呢<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"60ebe0a63eae114eb1e5e20d520db744a1dd75d2","tid":2247300,"uid":370010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-17T19:05:29.000Z","msg":"此回覆已被刪除"},{"pid":"b7ff056988cf9c05a6cf011fb9255c8763fc95dc","tid":2247300,"uid":370010,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-17T19:06:44.000Z","msg":"此回覆已被刪除"},{"pid":"4ce8d82186b495e81763c131628217f23e2c3602","tid":2247300,"uid":31323,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-10-17T22:07:09.000Z","msg":"今生不回家出嗰時我喺外國<br />\n真係聽到哭𠹌左"},{"pid":"a4881481afc3abc6615f8a9effc7e72631cbf61c","tid":2247300,"uid":49367,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-18T04:19:05.000Z","msg":"佢首凡夫的樂章真係要聽下<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0cd9ccfab1ecd7fd2f28f96ede758c6f65c5a618","tid":2247300,"uid":277836,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-10-18T04:30:49.000Z","msg":"啱啱出今生不回家嗰陣都無感覺<br />\n呢幾個月10次聽9次喊<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\nby被困絕情地方的人 準備等到往生"},{"pid":"fd69047609110675fd25fbeaaaa6ed821ebce584","tid":2247300,"uid":183576,"like":0,"dislike":0,"score":0,"quote":{"pid":"b7ff056988cf9c05a6cf011fb9255c8763fc95dc","tid":2247300,"uid":370010,"like":0,"dislike":0,"score":0,"quote":{"pid":"22b90c0c17ec3600c46a524d1bf998931c8a9d9c","tid":2247300,"uid":80503,"like":0,"dislike":0,"score":0,"quote":{"pid":"c5ee1b9a8a5553b440b86df2244d894f907a2423","tid":2247300,"uid":60047,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2020-10-17T17:52:22.000Z","msg":"最前應該係小國英雄