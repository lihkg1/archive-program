s/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"5bc9bcc69ad4bf4916071cd66cb03db04611848d","tid":1763844,"uid":14549,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-12-01T02:51:59.000Z","msg":"掛住就搵人啦"},{"pid":"872c26ebc86241da13ebc91a75e3a3c2e5caf148","tid":1763844,"uid":177223,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-01T03:48:53.000Z","msg":"起碼一年半載"},{"pid":"04c742e57133725e2272124faaef69f99bf50615","tid":1763844,"uid":187724,"like":0,"dislike":0,"score":0,"quote":{"pid":"f57bfd4c513ad7e7a5477f9b6c596f2675fc7df0","tid":1763844,"uid":241422,"like":0,"dislike":0,"score":0,"citedBy":9,"replyTime":"2019-11-30T15:57:48.000Z","msg":"分左手個幾月<br />\n仲未忘記到佢<br />\n究竟可以點做？"},"citedBy":0,"replyTime":"2019-12-01T05:41:30.000Z","msg":"畀自己個心沈澱吓，唔使迫自己，分分咗手先個幾月仲未忘記到係絕對正常㗎，唔開心就容許自己唔開心，俾多啲活動整忙自己，慢慢會好<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><br />\n<br />\n你地一齊左幾耐？"},{"pid":"4b41de1f75fba28ee946820991805d7630935be4","tid":1763844,"uid":230454,"like":0,"dislike":0,"score":0,"quote":{"pid":"f57bfd4c513ad7e7a5477f9b6c596f2675fc7df0","tid":1763844,"uid":241422,"like":0,"dislike":0,"score":0,"citedBy":9,"replyTime":"2019-11-30T15:57:48.000Z","msg":"分左手個幾月<br />\n仲未忘記到佢<br />\n究竟可以點做？"},"citedBy":1,"replyTime":"2019-12-01T06:04:25.000Z","msg":"認真，人人唔同<br />\n對你好就心掛掛<br />\n對你差就嬲一世<br />\n<br />\n利申：前女友(初戀)大約廿年前分手(戴綠帽)，到宜家未拍過拖<br />\n我就忘記唔到啦，嬲撚到今時今日"},{"pid":"a1f1362017209999797ca28112f78502ad190678","tid":1763844,"uid":31208,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-01T06:12:39.000Z","msg":"十年"},{"pid":"8c3f98e55d7cf9d4ede29b099408dd10517d6c2d","tid":1763844,"uid":314803,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-01T08:59:25.000Z","msg":"sp"},{"pid":"b7371d443513a947b8faa6c5d55c39178fbdc670","tid":1763844,"uid":240336,"like":0,"dislike":0,"score":0,"quote":{"pid":"f57bfd4c513ad7e7a5477f9b6c596f2675fc7df0","tid":1763844,"uid":241422,"like":0,"dislike":0,"score":0,"citedBy":9,"replyTime":"2019-11-30T15:57:48.000Z","msg":"分左手個幾月<br />\n仲未忘記到佢<br />\n究竟可以點做？"},"citedBy":0,"replyTime":"2019-12-01T12:05:07.000Z","msg":"有 d人好快揾第二個，係因為一早對第一個死心，一開始就有 d野憎佢/恨佢<br />\n而你唔憎佢/恨佢，你對佢嘅感情仲係正數，又點會放得低？"},{"pid":"fdc92da86606b40bf0157001deb700baddc5f629","tid":1763844,"uid":103838,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-02T05:38:34.000Z","msg":"4年 分手一個月<br />\n邊有咁易move on<br />\n日日聽歌日日sad<br />\n我都覺得自己on9<br />\n仲要無逢接軌<br />\n咁點解仲要搵我呢..<br />\n<br />\n<br />\n雖然 我真係想復合<br />\n<em>我一定痴左線</em>"},{"pid":"96386cc737269346158e520f9ae9b90a2ff35093","tid":1763844,"uid":130438,"like":1,"dislike":0,"score":1,"quote":{"pid":"4b41de1f75fba28ee946820991805d7630935be4","tid":1763844,"uid":230454,"like":0,"dislike":0,"score":0,"quote":{"pid":"f57bfd4c513ad7e7a5477f9b6c596f2675fc7df0","tid":1763844,"uid":241422,"like":0,"dislike":0,"score":0,"citedBy":9,"replyTime":"2019-11-30T15:57:48.000Z","msg":"分左手個幾月<br />\n仲未忘記到佢<br />\n究竟可以點做？"},"citedBy":1,"replyTime":"2019-12-01T06:04:25.000Z","msg":"認真，人人唔同<br />\n對你好就心掛掛<br />\n對你差就嬲一世<br />\n<br />\n利申：前女友(初戀)大約廿年前分手(戴綠帽)，到宜家未拍過拖<br />\n我就忘記唔到啦，嬲撚到今時今日"},"citedBy":0,"replyTime":"2019-12-02T05:40:05.000Z","msg":"放手啦巴打"},{"pid":"d22943a8c49f496240f19d498bccf0b911b88980","tid":1763844,"uid":246540,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-02T05:44:04.000Z","msg":"制造更多前男友"},{"pid":"e10bcf19f206cd16558ad81c7840ddc62726ae49","tid":1763844,"uid":322613,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-12-02T05:52:20.000Z","msg":"1.刪左對話佢<br />\n2.刪哂所有contact<br />\n3.刪哂所有合照<br />\n4.掉哂/收埋送過比你既嘢<br />\n5.開始揾多啲嘢做，培養興趣等等<br />\n6.揾多啲朋友出街<br />\n你就開始會慢慢放低<br />\n*如果係嬲對方個種忘記唔到<br />\n 放下仇恨 唔發生都發生左<br />\n 下次帶眼識人 唔好錯同樣嘅事就得<br />\n 你一日唔放低仇恨 你一日都忘記唔到佢<br />\n 下個更好"},{"pid":"63598718a79b194ede742a9a4ec0bca5dce9d95b","tid":1763844,"uid":122513,"like":0,"dislike":0,"score":0,"quote":{"pid":"f57bfd4c513ad7e7a5477f9b6c596f2675fc7df0","tid":1763844,"uid":241422,"like":0,"dislike":0,"score":0,"citedBy":9,"replyTime":"2019-11-30T15:57:48.000Z","msg":"分左手個幾月<br />\n仲未忘記到佢<br />\n究竟可以點做？"},"citedBy":0,"replyTime":"2019-12-02T06:02:33.000Z","msg":"你好，這是《自殺．自療．互助舍》。看來你已累積了不少負面情緒，是嗎？人就好像氣球一樣，若積存的鬱結和壓力太多，便會有爆發的一天。何不暫時停一停，到我們的網站    <a href=\"http://www.help4suicide.com.hk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.help4suicide.com.hk&d=ZahK9au6JYDyKCuDEpipfx0Z1crOiE0eyIPSb4MeDzY%3D&h=7f3e44a5\" data-auto-link target=\"_blank\">www.help4suicide.com.hk</a>。 那裡有一些勵志故事和有趣短片，你可以隨心看看。你也可以進入網站內的『Chat窿』（星期一至五：上午六時至凌晨一時；星期六、日及公眾假期：下午８時至凌晨１時），讓我們的義工為你加油打氣！<br />\n <br />\n我們願意聆聽你的心聲，伴你一起走過這段艱難的時候！只因『晴天雨天要樂天，難關難過總會過』！<br />\n<br />\n《自殺．自療．互助舍》"},{"pid":"f4746ae6e8c1d2dabc2bbbc0c589e9dbf3ae35ed","tid":1763844,"uid":4422,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2019-12-02T06:09:38.000Z","msg":"三年前散左單身至今，尋晚鼓起勇氣同佢吹左陣水，佢話佢好愛佢男朋友<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />應唔應該等落去"},{"pid":"a548e6c8635c734e065ce3429356f99fb9f36840","tid":1763844,"uid":44562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-02T06:13:58.000Z","msg":"搵啲新嗜好, 例如養下寵物, 照顧佢都有排你忙"},{"pid":"1676199ffe7e15e29f21bdcb964e58105f892d4c","tid":1763844,"uid":19676,"like":0,"dislike":0,"score":0,"quote":{"pid":"f57bfd4c513ad7e7a5477f9b6c596f2675fc7df0","tid":1763844,"uid":241422,"like":0,"dislike":0,"score":0,"citedBy":9,"replyTime":"2019-11-30T15:57:48.000Z","msg":"分左手個幾月<br />\n仲未忘記到佢<br />\n究竟可以點做？"},"citedBy":0,"replyTime":"2019-12-02T06:15:04.000Z","msg":"比我恨恨屌一次就得"},{"pid":"8ade4fe13481a3e98ce0797c885490d1820bd2ea","tid":1763844,"uid":320559,"like":0,"dislike":0,"score":0,"quote":{"pid":"fac2f805f54d17f443478de5ef74566fec5dbfb5","tid":1763844,"uid":330426,"like":0,"dislike":0,"score":0,"quote":{"pid":"f57bfd4c513ad7e7a5477f9b6c596f2675fc7df0","tid":1763844,"uid":241422,"like":0,"dislike":0,"score":0,"citedBy":9,"replyTime":"2019-11-30T15:57:48.000Z","msg":"分左手個幾月<br />\n仲未忘記到佢<br />\n