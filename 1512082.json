faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"880a52756f6e7baf2cbeae5a59da3b70c6d2d0f5","tid":1512082,"uid":223208,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T06:53:35.000Z","msg":"推"},{"pid":"2d09932f03137590b3b1f15cab395a0f6dc9494b","tid":1512082,"uid":234402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T13:49:13.000Z","msg":"推 順便想知今日個副校 同實際情況係點"},{"pid":"691b03287d6edf4cfabfc2c0a3e45e9443da8168","tid":1512082,"uid":208452,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T13:51:00.000Z","msg":"[澄清]國難五金課金問題&mdash;照舊課！<br />\n<a href=\"https://lihkg.com/thread/1521564/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1521564/page/1</a><br />\n<br />\n國難五金專訪 [國難老闆同一眾員工已保釋,開鋪事直請留意國難五金FB]<br />\n<a href=\"https://lihkg.com/thread/1521301/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1521301/page/1</a><br />\n<br />\n【眾籌】 已集合超過1000名巴絲感想 香港編年史<br />\n<a href=\"https://lihkg.com/thread/1379634/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1379634/page/1</a><br />\n<br />\n<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d078181b16809fb24fbb63e5b7bd28afe6191b00","tid":1512082,"uid":38915,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T22:48:15.000Z","msg":"推"},{"pid":"c8a58e8c752d9546c78c2f27f31584dea298f85c","tid":1512082,"uid":38915,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T22:49:03.000Z","msg":"點解我依加先見到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n你推兩推就潛水 <br />\n<br />\n係咪有另一個po"}]}