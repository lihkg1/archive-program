40daf83d6e8b75e0e6a2c2b3419439.jpg&h=2a567b7a&s={SIZE}\" /><br />\n香港電競有你真係慘喇買分仔<img src=\"/assets/faces/fs/smile_big.gif\" class=\"hkgmoji\" />"},{"pid":"9548a70700a9ffd7646d41f52f0f43923f75f38e","tid":637013,"uid":127033,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-21T12:17:10.000Z","msg":"白金都要買<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" />"},{"pid":"65c86077b8c814dbf682ad8babc395d9303b487d","tid":637013,"uid":147066,"like":0,"dislike":0,"score":0,"quote":{"pid":"9548a70700a9ffd7646d41f52f0f43923f75f38e","tid":637013,"uid":127033,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-21T12:17:10.000Z","msg":"白金都要買<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-21T12:22:28.000Z","msg":"買個垃圾白金唔知做乜<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"597553bb34df75a9f8ce11c20bd3e9a8791ecdfc","tid":637013,"uid":112502,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-21T12:27:00.000Z","msg":"樓主中幾<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"bed011c2dba8cbb1585181bfda957726f8afd362","tid":637013,"uid":147066,"like":0,"dislike":0,"score":0,"quote":{"pid":"597553bb34df75a9f8ce11c20bd3e9a8791ecdfc","tid":637013,"uid":112502,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-21T12:27:00.000Z","msg":"樓主中幾<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-21T12:27:37.000Z","msg":"出面識佢嘅<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"825e947ddf73fd273cec5b29c15c9fe2fc08f103","tid":637013,