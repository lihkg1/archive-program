b07c998298f3baafe895f905a90181745c7395d","tid":2016650,"uid":13663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T16:49:43.000Z","msg":"大家要去"},{"pid":"9408a2487fd82eef96b8b18016e25c017590030f","tid":2016650,"uid":225130,"like":0,"dislike":0,"score":0,"quote":{"pid":"6a95041b8ae0bf52905645af3591659e8a0af202","tid":2016650,"uid":225130,"like":0,"dislike":0,"score":0,"quote":{"pid":"792917eb2c6b9771ee4d7355a41a9b297fc7a691","tid":2016650,"uid":32008,"like":0,"dislike":0,"score":0,"quote":{"pid":"b70f86482ab59ad07e418165c746203695dc8ae4","tid":2016650,"uid":45553,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-05-14T14:20:20.000Z","msg":"google佢好似冇乜掂過手足case<br />\n除左拒絕女村長宵禁"},"citedBy":1,"replyTime":"2020-05-14T14:21:44.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2020-05-14T16:49:19.000Z","msg":"好似係胡官個女？"},"citedBy":0,"replyTime":"2020-05-14T16:50:58.000Z","msg":"只係同名<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n稱「旺角佔領區女村長」的畢慧芬因涉嫌於前年大年初二旺角衝突中掘磚掟磚，被控兩項暴動罪，案件今日於區域法院提堂。法官胡雅文拒絕畢提出撤銷宵禁要求，並把案件押後至9月11日再訊，以待畢有足夠時間申請法律援助，期間畢以原有條件保釋候訊。<br />\n<br />\n <br />\n<br />\n22歲被告畢慧芬被控兩項暴動罪，首項控罪指畢被控於2016年2月9日凌晨3時，在近西洋菜街及豉油街交界與其他人士參與暴動；第二項控罪則指畢於同日清晨5時，在近彌敦道與豉油街交界與其他人士參與暴動，違反香港法例第245章公安條例。<br />\n<br />\n畢表示願意維持現時每星期到警署報道3次的條件，以換取延遲由晚上11時開始的宵禁令。因畢從事飲食業，常有夜間工作的需要，宵禁令「限制其自由」，令她未能工作以幫補生計，尤其是其胞兄剛結婚及姪仔剛出生，加上「父母亦有問題」，故極需要工作以舒家庭財困。 法官則指出畢現時並無工作，若然能夠提供任何形式的證明，以示其需要於宵禁令實施時段工作，可隨時向法庭申請更改保釋條件。法官強調，不會因為畢有機會獲得工作而撤銷宵禁令，在考慮過雙方陳詞後，並不打算修改保釋條件。<br />\n<br />\n畢於庭外亦指自己作為旺角西洋菜南街表演者，基本法保障市民表演權利，畢亦表示如8月4日殺街事件發生後將入稟提出司法覆核，畢指「如果林鄭月娥真係要殺街，我第一個會企出黎」。"},{"pid":"56a70a0e84a0cdfdf0c87e5db062b82e44a96e91","tid":2016650,"uid":223741,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T16:51:18.000Z","msg":"希望冇事"},{"pid":"f74a414f7e8aa517561e6d2ca54f346ce25d6979","tid":2016650,"uid":189157,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2020-05-14T16:52:42.000Z","msg":"判夠佢十年就岩<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"44a1d573b65612a10f496f2666169fbb5c713829","tid":2016650,"uid":60259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T17:05:08.000Z","msg":"推推推"},{"pid":"40159762835082bf9a72c9ee969d5c2ac476fdef","tid":2016650,"uid":124711,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T17:06:52.000Z","msg":"推啊 手足唔係condom"},{"pid":"d389afc529daa3c0daa66bd28ecec3a609375978","tid":2016650,"uid":41423,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T17:07:37.000Z","msg":"光時五缺"},{"pid":"7f0085464683c377038cefa154479b54ecf3d5c6","tid":2016650,"uid":53922,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T17:08:59.000Z","msg":"push"},{"pid":"c94e18eca08a0c068e0e374f8001ec323a3facb1","tid":2016650,"uid":179598,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T17:11:09.000Z","msg":"tui"},{"pid":"deb80a2885d15afbb25082805c6a24d4425f29c3","tid":2016650,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T19:11:55.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"083dc6fa777c4381f371bbce7f31ea2839ac1cd9","tid":2016650,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T19:12:09.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"cd2bcf877ee3dabe37b24686328ad4838f6a70f2","tid":2016650,"uid":47222,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T19:14:46.000Z","msg":"推"},{"pid":"bec1993ec6d0955e851bf2f8e99e65cbf5234309","tid":2016650,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-14T19:17:55.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"baab3038be29eeb7c141ec8f4a61f49dac4f9350","tid":2016650,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyT