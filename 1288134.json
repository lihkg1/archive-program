ji\" />"},{"pid":"f7ede2f097beb22226d4c54bb9719786373c313c","tid":1288134,"uid":117698,"like":0,"dislike":0,"score":0,"quote":{"pid":"cd4a899b8493f8ad1c405f1d00e288c6e4f42888","tid":1288134,"uid":249525,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-05T13:39:17.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-05T13:45:22.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"459b0028b5ca391acadb0ed793c9e552c6f2ea27","tid":1288134,"uid":235665,"like":0,"dislike":0,"score":0,"quote":{"pid":"cd4a899b8493f8ad1c405f1d00e288c6e4f42888","tid":1288134,"uid":249525,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-05T13:39:17.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-05T13:47:35.000Z","msg":"對鏡頭噴油"},{"pid":"7448236eac4cbd2c78ca5d76e9c37e4f1a039f7a","tid":1288134,"uid":235665,"like":0,"dislike":0,"score":0,"quote":{"pid":"459b0028b5ca391acadb0ed793c9e552c6f2ea27","tid":1288134,"uid":235665,"like":0,"dislike":0,"score":0,"quote":{"pid":"cd4a899b8493f8ad1c405f1d00e288c6e4f42888","tid":1288134,"uid":249525,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-05T13:39:17.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-05T13:47:35.000Z","msg":"對鏡頭噴油"},"citedBy":1,"replyTime":"2019-07-05T13:49:21.000Z","msg":"原來無鏡頭，咁噴落雷達度"},{"pid":"2f700b629824df7cf3d4354d268cf173f4e1bc23","tid":1288134,"uid":81273,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-07-05T13:50:14.000Z","msg":"要炒rfid 套了"},{"pid":"44b3dc7fd5d9f5935b9ec7b3a2ff5f98905b7fe7","tid":1288134,"uid":117698,"like":0,"dislike":0,"score":0,"quote":{"pid":"c39e088ac50bdd68e0e56c0e80c050ab20429f17","tid":1288134,"uid":104171,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-07-05T13:31:07.000Z","msg":"冇鏡頭喎話"},"citedBy":0,"replyTime":"2019-07-05T