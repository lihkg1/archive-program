id":812450,"uid":207641,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-09-09T16:33:40.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 佢兵你<br />\n切啦 慢慢黎"},"citedBy":0,"replyTime":"2018-09-09T16:47:14.000Z","msg":"totally agger"},{"pid":"28a1185dd422a204297c080561e19b8932355351","tid":812450,"uid":29879,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-09T16:49:18.000Z","msg":"5年咁耐先表白，一早fd zone左你<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d27c863a689a5059d7e4070ed42fe804dfb8f9ac","tid":812450,"uid":37244,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a739fea2a2765d7474b086da0a9f57d1839a741","tid":812450,"uid":207641,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-09-09T16:33:40.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 佢兵你<br />\n切啦 慢慢黎"},"citedBy":2,"replyTime":"2018-09-09T16:55:58.000Z","msg":"你可能話我自己執迷不悟，但佢無做過收我兵既舉動"},{"pid":"2e27745bf2fdb8697f83647fb2465169e16532db","tid":812450,"uid":37244,"like":0,"dislike":0,"score":0,"quote":{"pid":"28a1185dd422a204297c080561e19b8932355351","tid":812450,"uid":29879,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-09T16:49:18.000Z","msg":"5年咁耐先表白，一早fd zone左你<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-09T16:56:58.000Z","msg":"中間已經表白了 無咁耐"},{"pid":"b4d95c20ab850a5a76e5bfb211a69b7db6b2aad7","tid":812450,"uid":137274,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-09T17:13:59.000Z","msg":"五年前我識你咩<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"8cec8b270911bf0b12381b4c8c0dcf9d2ce57df6","tid":812450,"uid":71085,"like":0,"dislike":0,"score":0,"quote":{"pid":"85bbe543d9fe4c6e4016f015d9bc19a0c7726a79","tid":812450,"uid":37244,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1f109020cc912b44b76d908372a01fa4c755308","tid":812450,"uid":71085,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-09-09T16:08:00.000Z","msg":"睇完替你覺得好辛苦<br />\n依家斷仲嚟得切"},"citedBy":1,"replyTime":"2018-09-09T16:27:52.000Z","msg":"唔係咁容易"},"citedBy":0,"replyTime":"2018-09-09T17:24:02.000Z","msg":"過來人 用比你更長嘅時間切<br />\n唔好諗無可能離開佢乜乜乜就已經係最大嘅可能<br />\n<br />\n<span style=\"font-size: xx-large;\">因為你要知道，佢係無可能比你感動到而同你一齊，是時候醒了</span>"},{"pid":"7b7d6dc0d3987e861ac9d26b9ff7552a74d18a17","tid":812450,"uid":162539,"like":0,"dislike":0,"score":0,"quote":{"pid":"d27c863a689a5059d7e4070ed42fe804dfb8f9ac","tid":812450,"uid":37244,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a739fea2a2765d7474b086da0a9f57d1839a741","tid":812450,"uid":207641,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-09-09T16:33:40.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 佢兵你<br />\n切啦 慢慢黎"},"citedBy":2,"replyTime":"2018-09-09T16:55:58.000Z","msg":"你可能話我自己執迷不悟，但佢無做過收我兵既舉動"},"citedBy":0,"replyTime":"2018-09-09T17:27:34.000Z","msg":"你自己中個頭埋去，佢一顰一笑已經夠啦，佢唔使要求你做咩㗎喎，因為啲嘢根本係你自願做。"},{"pid":"2ca447ac359cf359b917accac54abb71fdcf96c8","tid":812450,"uid":186163,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-09T17:36:46.000Z","msg":"水泡<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"3f89de92997a322285e6cddcd43f0d4ba8242b3d","tid":812450,"uid":186163,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ca447ac359cf359b917accac54abb71fdcf96c8","tid":812450,"uid":186163,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-09T17:36:46.000Z","msg":"水泡<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-09T17:37:15.000Z","msg":"都唔係<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4c86530e080fe6b2373729ee5051312b416b03fe","tid":812450,"uid":53534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-09T17:57:27.000Z","msg":"希望時間會係你最好既解藥<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n唔愛上人就唔會心碎<img src=\"/assets/faces/fs/agree.gif\" class=\"hkgmoji\" />"},{"pid":"da2e012efb204eedf6903ed7872762b01104bfd1","tid":812450,"uid":207641,"like":0,"dislike":0,"score":0,"quote":{"pid":"d27c863a689a5059d7e4070ed42fe804dfb8f9ac","tid":812450,"uid":37244,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a739fea2a2765d7474b086da0a9f57d1839a741","tid":812450,"uid":207641,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-09-09T16:33:40.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 佢兵你<br />\n切啦 慢慢黎"},"citedBy":2,"replyTime":"2018-09-09T16:55:58.000Z","msg":"你可能話我自己執迷不悟，但佢無做過收我兵既舉動"},"citedBy":0,"replyTime":"2018-09-10T00:58:33.000Z","msg":"因為兵的舉動是自願性的 根本打動唔到佢<img src=\"/assets/faces/fs/angry.gif\" class=\"hkgmoji\" /> 都係個句 慢慢切啦比時間"}]}