daily.com/finance/realtime/article/20180812/58553988</a>"},{"pid":"c114c0a2b87844b87b667a51e74aeefd73594c78","tid":774691,"uid":98763,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-12T07:28:46.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"3066b03df9c0f22b2452459cedad539a7698cc2d","tid":774691,"uid":76745,"like":0,"dislike":0,"score":0,"quote":{"pid":"bd970836d5ba891c7b20284c24dad7c7ddf3b49f","tid":774691,"uid":57,"like":0,"dislike":0,"score":0,"quote":{"pid":"1dc25a77daa608b045a7a7f7ee3f8d715f7bd6d7","tid":774691,"uid":62935,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-11T19:27:01.000Z","msg":"130 伙都賣得八成...<br />\n下一期點算..."},"citedBy":1,"replyTime":"2018-08-12T04:27:49.000Z","msg":"咁嘅價錢正常人點會買呢個位<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-12T08:23:39.000Z","msg":"第一批係抵既 7球有大兩房 仲要現樓 但仆街shk第二輪咁狼死加成12％ 想買都卻步喇"},{"pid":"88936fff1d120a603a6d0452a3ef3cd21500fbfb","tid":774691,"uid":191019,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-12T09:39:43.000Z","msg":"第二輪加左咁多<br />\n特別係開放式同一房<br />\n最大個批客冇哂<br />\n利申：AA<br />\n其他因素：上次去抽個啲客逼死哂"}]}