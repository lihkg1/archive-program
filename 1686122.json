faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"926a53cde8e4adbedc040f669d95ee6bd2914cac","tid":1686122,"uid":309015,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-11-01T02:57:37.000Z","msg":"百佳買過去<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"b3693df9b727b72ab7b2b0b0b96b5d8a704954cb","tid":1686122,"uid":65738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-01T02:57:48.000Z","msg":"甴近平在必不成功"},{"pid":"906b5f9ca41bddacae3337a513c3362d4380a5e3","tid":1686122,"uid":267964,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-11-01T02:59:53.000Z","msg":"蘭桂坊協會總監張素媚表示，萬聖節原本是蘭桂坊一年一度最旺的日子，不過受昨日的公眾活動影響，初步預計生意額較往年下跌5成。<br />\n<br />\n張素媚接受本台節目電話訪問時說，昨晚約7時有佩戴面具的市民在主要街道集結，高叫口號，氣氛和平。警方基於蘭桂坊道路斜及窄，擔心即使實施人潮管制，在突發事故下，仍有安全風險，因此晚上7時半開始已禁止遊人出入，其後警方開始施放催淚彈，催淚彈煙吹到蘭桂坊中心區，有部份商戶為保障顧客及員工安全，唯有選擇關門。<br />\n<br />\n張素媚表示，理解警方安排，不過昨晚情況令營商情況雪上加霜。她表示，6月以來，整體營業額已有個位跌幅，晚市銳減兩至三成。昨晚對商戶打擊嚴重，不少客人因公眾活動取消訂單，令酒吧食肆場面冷清，客人寥寥可數，個別生意較好商戶亦只能一半客人，即使有餐廳推出100元任飲優惠作招徠亦無用。她呼籲政府盡快推出措施，尤其針對海外旅客，刺激消費。 <br />\n<br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1489452-20191101.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1489452-20191101.htm&d=rhNKtzo6pyhm84ltIFKzvJ1DrXAeA17tgS6Eh9jzous%3D&h=2a7e0308\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1489452-20191101.htm&h=cd80380e\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1489452-20191101.htm</a>"},{"pid":"ab6d3ae3b9ae207cd6111c90b16213e4a1325f85","tid":1686122,"uid":32934,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-01T03:25:45.000Z","msg":"推"},{"pid":"a0112d26eab63c43ae3ad1905e69a38194b877a3","tid":1686122,"uid":54968,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-01T03:32:15.000Z","msg":"根本唔應該去7仔 cctv會上繳<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n同埋啲管理層全部都係深藍"},{"pid":"1130d59996d02ab