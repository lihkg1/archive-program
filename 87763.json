id":"370f59f5fa1e71c1c699db7e435d8105386846fc","tid":87763,"uid":27766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T14:16:30.000Z","msg":"<blockquote><blockquote><blockquote><br />\n呢個識食係點<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /></blockquote><br />\nWasabi點係壽司飯同刺身中間<br />\n豉油點係刺身面食</blockquote><br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />原來係咁食</blockquote><br />\n有日本人都係咁撈 <br />\n完全mind fucked"},{"pid":"04a5ede3c6b138972b385a590f13f855abf949f6","tid":87763,"uid":75528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T14:20:51.000Z","msg":"唔食mcdonald早餐薯餅"},{"pid":"e77c5420d6d7b2c891dd745b49057d3ba819b4e0","tid":87763,"uid":39785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T16:44:22.000Z","msg":"走蔥"},{"pid":"9fe8eea14db9f738e3505c0357c77be1d1015f23","tid":87763,"uid":58676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T16:47:06.000Z","msg":"走全青<br />\n一定係"},{"pid":"6a1cc07b972d3c907d832e6ee46cdc602be15716","tid":87763,"uid":8171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T16:51:20.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote>Wasabi 攪豉油</blockquote><br />\nAggger</blockquote><br />\n呢個識食係點<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /></blockquote><br />\nWasabi點係壽司飯同刺身中間<br />\n豉油點係刺身面食</blockquote><br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />原來係咁食</blockquote><br />\nWasabi 攪豉油成PAT屎咁<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"2e6723194bac205baff44115134853d0e81ec71b","tid":87763,"uid":60848,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T18:26:15.000Z","msg":"食壽司 飯個面點豉油 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n上次見到有外國人將舊壽司上下兩面都狂&quot;yam&quot;豉油 睇到都鹹到癲<br />\n<br />\n同埋好似正宗食法係 刺身個邊掂脷 即係壽司掉轉擺入口<br />\n<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> 呢個只係聽翻來 唔知係咪真"},{"pid":"9e2560b6b0ec394089d12d7b5a28e605be801c52","tid":87763,"uid":11977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T18:37:43.000Z","msg":"<blockquote><blockquote><blockquote><br />\nbtw<br />\nCarbonara落埋蛋白</blockquote><br />\n正宗carbonara係要落蛋/蛋黃同埋mozzarella而唔係cream</blockquote><br />\n食得唔正宗唔代表唔識食 加cream先正 但加左蛋白就唔好食</blockquote><br />\n<br />\n落cream 就第二樣野啦<br />\n冇人話你唔識食 但你唔好叫白汁意粉做carbonara"},{"pid":"ee969f359325f39520a30bc00d4d0601202f221b","tid":87763,"uid":71114,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T18:53:24.000Z","msg":"<blockquote><blockquote><blockquote><br />\n正宗carbonara係要落蛋/蛋黃同埋mozzarella而唔係cream</blockquote><br />\n食得唔正宗唔代表唔識食 加cream先正 但加左蛋白就唔好食</blockquote><br />\n<br />\n落cream 就第二樣野啦<br />\n冇人話你唔識食 但你唔好叫白汁意粉做carbonara</blockquote><br />\n<br />\n你個名<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n無心罵戰，純粹一啲愚見，總係有人堅持正宗/傳統兩個字，覺得咁先好<br />\n但其實時代會變，好似日本人食拉麵特別大聲即係好食<br />\n但其實近代日本人特別係後生仔，都好反感<br />\n<br />\n所以我個人覺得傳統唔一定好，只係現代對舊時嘅一種幻想，憧憬<br />\n當然如果有根據嘅傳統係好，例如食壽司要掉轉係想味蕾感受到舊魚嘅味先<br />\n但講到做法我就唔太認同了<br />\n<br />\n巴大唔好對號入座，純分享愚見<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"73013664a659dea9e6daaefb452811ff9a580472","tid":87763,"uid":2772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T19:43:47.000Z","msg":"<blockquote>個個都講食法等我講下做法<br />\n<br />\n煮意粉全熟仲要過冷河<br />\nCarbonara落cream<br />\n焗pizza見D芝士融少少就攞出黎搞到個批底又淋又濕<br />\n蒸水蛋落水/雞湯比例唔岩仲要無用保鮮紙/錫紙包住搞到邊火山窿<br />\n炒牛河無整散D河粉先炒</blockquote><br />\n我鍾意食火山窿水蛋<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"4fcc89e47c2b28d6f2651430c2e2b723137da517","tid":87763,"uid":39717,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T19:56:02.000Z","msg":"我就係飲開紅酒，去酒樓食飯果d 包埋紅酒嘅菜單好難飲所以先溝雪碧<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"80edfd65847b9be46ded130060afa2c71245da75","tid":87763,"uid":61232,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T20:28:12.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><br />\nbtw<br />\nCarbonara落埋蛋白</blockquote><br />\n正宗carbonara係要落蛋/蛋黃同埋mozzarella而唔係cream</blockquote><br />\n食得唔正宗唔代表唔識食 加cream先正 但加左蛋白就唔好食</blockquote><br />\n<br />\n落cream 就第二樣野啦<br />\n冇人話你唔識食 但你唔好叫白汁意粉做carbonara</blockquote><br />\n事實上落左cream都仲係carbonara <br />\n唔通你食芝士火鍋無落白酒就唔叫做芝士火鍋？<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"36e8103c6893d50d79f169896095722942b58b33","tid":87763,"uid":49955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T20:55:18.000Z","msg":"食麵唔識一乾三濕"},{"pid":"85df7624b6c4b21e6b7ad69015bfe29fdc497fda","tid":87763,"uid":59519,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T21:19:53.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>個個都講食法等我講下做法<br />\n<br />\n煮意粉全熟仲要過冷河<br />\nCarbonara落cream<br />\n焗pizza見D芝士融少少就攞出黎搞到個批底又淋又濕<br />\n蒸水蛋落水/雞湯比例唔岩仲要無用保鮮紙/錫紙包住搞到邊火山窿<br />\n炒牛河無整散D河粉先炒</blockquote><br />\nCarbonara點會唔落cream<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /></blockquote><br />\nbtw<br />\nCarbonara落埋蛋白</blockquote><br />\n正宗carbonara係要落蛋/蛋黃同埋mozzarella而唔係cream</blockquote><br />\n<br />\nmozzarella? <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1d1df50121fe8f96d75f9f328531417c03bc1b17","tid":87763,"uid":63075,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T21:29:36.000Z","msg":"<span style=\"font-size: xx-large;\">蒸新鮮海魚係唔洗薑架</span>"},{"pid":"b6668551e4fd258524e765309a95dd3c3c0bd412","tid":87763,"uid":27210,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T21:42:09.000Z","msg":"<blockquote><blockquote><blockquote><br />\nAggger</blockquote><br />\n呢個識食係點<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /></blockquote><br />\nWasabi點係壽司飯同刺身中間<br />\n豉油點係刺身面食</blockquote><br />\n<br />\n是撚但啦"},{"pid":"d245edb7281ea73f9a8e3819a1e9c4616620e8c2","tid":87763,"uid":3910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T21:45:04.000Z","msg":"煎扒落黑椒"},{"pid":"054f8923c3ae01902dcd4e2f6fb88141514d8459","tid":87763,"uid":27646,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T21:46:24.000Z","msg":"紅7 有咩問題<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"115d9b617b1908c9a3af6189d6500efaf8288a46","tid":87763,"uid":36414,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T21:57:17.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><br />\nbtw<br />\nCarbonara落埋蛋白</blockquote><br />\n正宗carbonara係要落蛋/蛋黃同埋mozzarella而唔係cream</blockquote><br />\n食得唔正宗唔代表唔識食 加cream先正 但加左蛋白就唔好食</blockquote><br />\n<br />\n落cream 就第二樣野啦<br />\n冇人話你唔識食 但你唔好叫白汁意粉做carbonara</blockquote><br />\n事實上落左cream都仲係carbonara <br />\n唔通你食芝士火鍋無落白酒就唔叫做芝士火鍋？<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /></blockquote><br />\n&quot;唔識食&quot;解唔正宗, 或者 唔識令到D野好食 兩者都合理<br />\n我相信樓主係Carbonara加Cream 係講唔正宗<br />\n至於Carbonara加Cream 仲係咪Carbonara就更加係哲學問題<br />\n有巴打講既豬柳旦走旦仲係咪豬柳旦? 一個人斷左手仲係咪人?<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n都係睇開D啦<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"29f01c272e2e464a95993804133308b3454a26c9","tid":87763,"uid":59519,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T22:02:13.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><blockquote><br />\nbtw<br />\nCarbonara落埋蛋白</blockquote><br />\n正宗carbonara係要落蛋/蛋黃同埋mozzarella而唔係cream</blockquote><br />\n食得唔正宗唔代表唔識食 加cream先正 但加左蛋白就唔好食</blockquote><br />\n<br />\n落cream 就第二樣野啦<br />\n冇人話你唔識食 但你唔好叫白汁意粉做carbonara</blockquote><br />\n事實上落左cream都仲係carbonara <br />\n唔通你食芝士火鍋無落白酒就唔叫做芝士火鍋？<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /></blockquote><br />\n&quot;唔識食&quot;解唔正宗, 或者 唔識令到D野好食 兩者都合理<br />\n我相信樓主係Carbonara加Cream 係講唔正宗<br />\n至於Carbonara加Cream 仲係咪Carbonara就更加係哲學問題<br />\n有巴打講既豬柳旦走旦仲係咪豬柳旦? 一個人斷左手仲係咪人?<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n都係睇開D啦<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n其實我都唔贊成+cream因為味道幾大分別(做過廚，never any cream) 。<br />\n<br />\n但我唔覺得係錯既，講真煮野食就係你鐘意就得，recipe係重要 唔代表係一切，好食先係最撚重要 <img src=\"/assets/faces/lomoji/11.png\" class=\"hkgmoji\" />"},{"pid":"74c716d9478ec938a03982f462ebb106bfb76539","tid":87763,"uid":50483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T22:02:56.000Z","msg":"係某間pizza kitchen做<br />\n卡邦拿個汁係有cream<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n芝士粉同香草落兩次"},{"pid":"f1dbef8f3b6b2210dc9a5e2bf5f67ff4982a93b5","tid":87763,"uid":57346,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T22:04:09.000Z","msg":"<blockquote><span style=\"font-size: xx-large;\">蒸新鮮海魚係唔洗薑架</span></blockquote><br />\n但係我好鐘意食薑絲葱絲喎，切到極幼既薑葱絲再加埋蒸魚豉油撈飯，完勝豬油撈飯！"},{"pid":"1d3df0fbcad347874b73a3c142bb8f660be532f9","tid":87763,"uid":1085,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T22:08:18.000Z","msg":"此回覆已被刪除"},{"pid":"aff9175eea5130413a181a6dcbbef7a67915b690","tid":87763,"uid":65234,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T22:13:44.000Z","msg":"<blockquote><blockquote>豬柳蛋走強</blockquote><br />\n<br />\n細個成日食 因為好憎舊蛋覺得好膠<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n其實有無得走蛋黃 要淨蛋白架"},{"pid":"86a3979ba2029dfe0b47fed3cfc0e64ea80577c1","tid":87763,"uid":63075,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T22:14:50.000Z","msg":"<blockquote><blockquote><span style=\"font-size: xx-large;\">蒸新鮮海魚係唔洗薑架</span></blockquote><br />\n但係我好鐘意食薑絲葱絲喎，切到極幼既薑葱絲再加埋蒸魚豉油撈飯，完勝豬油撈飯！</blockquote><br />\n你鍾意食味另外切一碟食囉<br />\n放埋一齊蒸<br />\n影響左條魚既鮮味 明唔明呀？"},{"pid":"408efe19c81057229d28a085f0b598573d8f832c","tid":87763,"uid":59519,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-20T22:19:03.000Z","msg":"<blockquote>係某間pizza kitchen做<br />\n卡邦拿個汁係有cream<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n芝士粉同香草落兩次</blockquote><br />\n<br />\n3樣材料都唔會用/唔需要<img src=\"/assets/faces/lomoji/16.png\" class=\"hkgmoji\" />"}]}