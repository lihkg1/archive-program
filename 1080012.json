6:15.000Z","msg":"<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-27T11:01:46.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-27T12:42:08.000Z","msg":"佢似想搵你做後備<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n好簡單問佢一個問題: <br />\n可唔可以即刻放棄條仔？<br />\n如果要時間，又要幾耐？<br />\n<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />"},{"pid":"a859901d6b35138cc09461d668b8b85568afa45a","tid":1080012,"uid":125168,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-27T12:46:07.000Z","msg":"<span style=\"color: red;\">一開始都都係哥哥妹妹關係</span><br />\n咁你而家點食得落<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n原來呢個年代仲有人玩上契<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n等佢正式分手先食啦，如果唔係你就做咗仆街"},{"pid":"a0f162b29073dc2a4540ddb03b23d03689bb2d4c","tid":1080012,"uid":243432,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-27T12:48:33.000Z","msg":"講清楚<br />\n分手先<br />\n唔得就收線"},{"pid":"8de65d85ff3ed0500bcf65f08972cfb2529314e3","tid":1080012,"uid":164461,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-27T12:49:18.000Z","msg":"此回覆已被刪除"},{"pid":"d2b2f0ed687607951c49e77a87b8bf90daa7197e","tid":1080012,"uid":228205,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-27T12:51:09.000Z","msg":"由佢表白個刻開始就應該要佢分手啦，如果想一齊"},{"pid":"e82e7f2c43dfea91aae6dbc72cb5b6025ae4e2b5","tid":1080012,"uid":27380,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-27T12:55:25.000Z","msg":"咁點解佢唔分手"},{"pid":"1104f0d4b83318952ffcd86b7c963f20fe603740","tid":1080012,"uid":216800,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-27T13:12:16.000Z","msg":"你地講得岩<br />\n搵個機會問下佢先"},{"pid":"0762fcae0c43f3e6e356a98799e420d05acc8ab7","tid":1080012,"uid":78683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T19:28:17.000Z","msg":"原來是她"}]}