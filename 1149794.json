/clown.gif\" class=\"hkgmoji\" />"},{"pid":"81322220eae19fcfaad2f1e86c97a4ba23aae90d","tid":1149794,"uid":23758,"like":1,"dislike":0,"score":1,"quote":{"pid":"0ab8673e55d5cd145268212beaf07c1168aa07be","tid":1149794,"uid":2419,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-11T18:43:15.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-11T22:28:41.000Z","msg":"明知唔應該講出黎<br />\n不過成世人最鍾意玩解迷同尋寶<br />\n所有野都要放出黎然後擺條線索指過去<br />\n真正有心既人就會搵到"},{"pid":"f2769e0cefc253eed52a9a599d4c0ad083faf0fb","tid":1149794,"uid":23758,"like":0,"dislike":0,"score":0,"quote":{"pid":"977424d30df61aed3753f31c22ab310c059987a2","tid":1149794,"uid":50376,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-05-11T18:32:41.000Z","msg":"唔會架，算吧啦<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-11T22:30:18.000Z","msg":"其實我有超能力<br />\n其中一樣係第六感<br />\n唔知點解就係會覺得呢一日會到來<br />\n所以做左準備"},{"pid":"fa9dfa3825987178e60effbb59cfeafa80be6f63","tid":1149794,"uid":23758,"like":1,"dislike":0,"score":1,"quote":{"pid":"55e80a4bf257585d362751a0d88c0d73cbe7a5df","tid":1149794,"uid":210165,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-11T18:40:59.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-05-11T22:33:29.000Z","msg":"有就梗係最好，冇都只係一個考驗<br />\n我淨係想挑戰一下個結果<br />\n睇下自己可以表現成點<br />\n一早就接受左現況，都行遠左好多<br />\n只會唔好變得更差就可以"},{"pid":"3b485827f6afff97f32cec4203a6b971254c0452","tid":1149794,"uid":23758,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-11T22:37:23.000Z","msg":"我就係想身邊既人都開心幸福<br />\n就算自己演既係悲劇<br />\n只要其他人都可以笑就足夠<br />\n呢一個考驗我通過左一次<br />\n第二關都可以做到<br />\n就算係落花流水，都想見到我既人係笑住走"},{"pid":"d97e6407258e272ff123947d4cc6471b2f1f3163","tid":1149794,"uid":23758,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-11T22:42:42.000Z","msg":"唔知點解會再比人睇到呢個樣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n不過就好似太陽都有黑子，深海都有瑩光<br />\n我既本質就係虛無<br />\n恆星死左就會變成黑洞<br />\n將唔好既野吸走留比自己<br />\n話唔定被填滿既一日又會得到新生"},{"pid":"70a6ea2c57f21737e493f652eff4c6e52abd0256","tid":1149794,"uid":23758,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-11T22:46:07.000Z","msg":"所以重點唔係睇唔睇到呢d野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n而係流星劃過既一刻比人見到<br />\n冇人會想理流星係出現之前係一舊點樣既石，漂浮左幾耐<br />\n佢既價值係得燃燒殞落比人見到果一刻"},{"pid":"e36d84f2ccb31bc6840b7266c67501d751918ced","tid":1149794,"uid":23758,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-11T22:56:39.000Z","msg":"明明身體係自己既，但係又控制唔到真係好無力<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n最慘係連精神上都變到好虛無<br />\n明知有要做既事，就係控制唔到自己行動<br />\n就算過曬期都郁唔到半步<br />\n到底可以點"},{"pid":"8ab2082f29d9e99e6f18909444e070ceb9b1523c","tid":1149794,"uid":23758,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-11T23:02:43.000Z","msg":"扮成太陽既黑洞<br />\n到底呃左幾多人<br />\n去到面對唔到自己既地步<br />\n為左想做既事犧牲自己<br />\n開始覺得自己係錯<br />\n不過又點，冇人接受到身邊既人一直係到偽裝<br />\n到見到真正既樣貌先會避開<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4e17e637d4a86717af1b5fbb678003184cef6039","tid":1149794,"uid":23758,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-11T23:06:25.000Z","msg":"不過我可以保證你見到既一定會係最好既我<br />\n永遠都會係咁<br />\n上面講既野根本唔存在<br />\n睇唔到就唔存在<br />\n就好似對兩個唔認識既人黎講根本就冇存在呢一個人一樣"},{"pid":"5aff03f5da48b9f35bc314eea6800f834b8d1fa4","tid":1149794,"uid":23758,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-11T23:08:46.000Z","msg":"我就係我<br />\n講過既野一定做到<br />\n呢個可能係放棄左現實既好處<br />\n當班奴隸仍然日日只在意物質既時候<br />\n我重可以保住應有既道德"},{"pid":"972bc3cd79ea5cf88ccce0e50e06e6a936eb6d61","tid":1149794,"uid":23758,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-11T23:14:36.000Z","msg":"將全部野變成伏筆埋係唔同地方<br />\n無論係我講既野，我畫既畫，我身邊既野甚至我既樣<br />\n所有野都係一條線索<br />\n一個得我自己識玩既遊戲"},{"pid":"dffe33d43c5e2ca94ffb372a4a653081872e97be","tid":1