na.cx%2Fi%2FUyXOLmg.jpg&h=47348ee0&s={SIZE}\" />"},{"pid":"d9cf167039bdc28b3ec18fc8ffbd209cde326d1c","tid":1623114,"uid":89584,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-10-04T18:38:47.000Z","msg":"認同要搞埋其他<br />\n唔同意停搞狗鐵<br />\n<br />\n開始左戰爭 就只可以不死不休<br />\n搞狗鐵搞搞吓唔搞 點樣震懾到其他人?<br />\n<br />\n黃商要盡力懲罰 千金買馬骨<br />\n藍商要罷買罷食 睇佢愛國定愛錢<br />\n紅商要死戰到底 唔接受投降同和談<br />\n<br />\n狗鐵係共狗降卒 佢都未示弱 我地就停戰<br />\n姐係話比人知 向中共投降都冇乜野姐<br />\n要阻止佢地投共 就要話比佢地聽:<br />\n1.唔投共一樣搵到食<br />\n2.投共分分鐘屎都冇得食<br />\n<br />\n所以我同意搞埋其他 唔同意同狗鐵停戰<br />\nbtw 錢方面冇計 攬炒要付出代價 所以我地要做嘅係令敵人付出更高代價<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"e215aeb005b9933ca3540e3033582e0fa0840a82","tid":1623114,"uid":300559,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T18:40:46.000Z","msg":"尤其係政協有份做老闆或者做股東嗰啲，因為佢哋奶硬共<br />\n有冇人有多d料。"},{"pid":"7f70189848bed18174432b5b636a7fae1f51c2bc","tid":1623114,"uid":25974,"like":1,"dislike":0,"score":1,"quote":{"pid":"d9cf167039bdc28b3ec18fc8ffbd209cde326d1c","tid":1623114,"uid":89584,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-10-04T18:38:47.000Z","msg":"認同要搞埋其他<br />\n唔同意停搞狗鐵<br />\n<br />\n開始左戰爭 就只可以不死不休<br />\n搞狗鐵搞搞吓唔搞 點樣震懾到其他人?<br />\n<br />\n黃商要盡力懲罰 千金買馬骨<br />\n藍商要罷買罷食 睇佢愛國定愛錢<br />\n紅商要死戰到底 唔接受投降同和談<br />\n<br />\n狗鐵係共狗降卒 佢都未示弱 我地就停戰<br />\n姐係話比人知 向中共投降都冇乜野姐<br />\n要阻止佢地投共 就要話比佢地聽:<br />\n1.唔投共一樣搵到食<br />\n2.投共分分鐘屎都冇得食<br />\n<br />\n所以我同意搞埋其他 唔同意同狗鐵停戰<br />\nbtw 錢方面冇計 攬炒要付出代價 所以我地要做嘅係令敵人付出更高代價<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-04T18:41:30.000Z","msg":"同意呢位巴打 <br />\n黨鐵淨係用黎運狗呢點已經唔可以原諒<br />\n用香港人納稅/幫襯嘅錢去為狗隻提供便利"},{"pid":"45064c164c0894c26733eb62a55282f1fa232fc6","tid":1623114,"uid":13936,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-04T18:42:36.000Z","msg":"垃圾樓主  不推文回覆"},{"pid":"dc9196583094b8487489f3b78f7734271166f606","tid":1623114,"uid":80972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T18:44:03.000Z","msg":"羅范椒芬<br />\n<br />\n<img src=\"https://na.cx/i/nr0wJaY.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fnr0wJaY.jpg&h=83893ca9&s={SIZE}\" />"},{"pid":"fcd0dbde7beaa9cd4923d20c27f8851076720db5","tid":1623114,"uid":80972,"like":0,"dislike":0,"score":0,"quote":{"pid":"d9cf167039bdc28b3ec18fc8ffbd209cde326d1c","tid":1623114,"uid":89584,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-10-04T18:38:47.000Z","msg":"認同要搞埋其他<br />\n唔同意停搞狗鐵<br />\n<br />\n開始左戰爭 就只可以不死不休<br />\n搞狗鐵搞搞吓唔搞 點樣震懾到其他人?<br />\n<br />\n黃商要盡力懲罰 千金買馬骨<br />\n藍商要罷買罷食 睇佢愛國定愛錢<br />\n紅商要死戰到底 唔接受投降同和談<br />\n<br />\n狗鐵係共狗降卒 佢都未示弱 我地就停戰<br />\n姐係話比人知 向中共投降都冇乜野姐<br />\n要阻止佢地投共 就要話比佢地聽:<br />\n1.唔投共一樣搵到食<br />\n2.投共分分鐘屎都冇得食<br />\n<br />\n所以我同意搞埋其他 唔同意同狗鐵停戰<br />\nbtw 錢方面冇計 攬炒要付出代價 所以我地要做嘅係令敵人付出更高代價<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-04T18:47:16.000Z","msg":"兄弟爬山囉<br />\n狗鐵個part都係前菜，我提少少意見，都明白有人會唔接受<br />\n<br />\n但中共喺香港呢個利益集團，真係大家要集中火力打擊"},{"pid":"ddc9cf86680c8c2e04087b350f81becccd69fec3","tid":1623114,"uid":29514,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-04T18:47:50.000Z","msg":"受到教訓？今朝仲開緊記者會屌香港人wo"},{"pid":"f3b77083e66384358a5d24575cb2ab17084cf97c","tid":1623114,"uid":289723,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-04T18:49:18.000Z","msg":"認錯道歉,唔再出賣市民自然唔會再搞<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" /><br />\n呢刻我都唔覺黨鐵有受到教訓知錯<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"5e2c53e811085d4844b10de4f736899fa6343d10","tid":1623114,"uid":281484,"like":0,"dislike":0,"score":0,"quote":{"pid":"a91f2dc0da5955f98013a487432297a73fa3e8c7","tid":1623114,"uid":80972,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-04T18:26:18.000Z","msg":"狗鐵出賣港人，經過呢個幾月，已經受到教訓<br />\n畢竟狗鐵嘅錢係香港人俾，最後維修嘅錢都係香港人出，佢地d高層都唔會驚，d錢唔係佢地<br />\n<br />\n我地開始要對準嘅係中共政權，港共，奶共議員，<br />\n<br />\nPriority 1: 紅色企業<br />\n- 對抗共產機構滲透<br />\n- 減少紅色企業