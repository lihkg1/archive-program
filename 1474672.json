/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7ec347d9832f72f75e946df17a97e8c579f726dc","tid":1474672,"uid":85713,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-15T10:14:42.000Z","msg":"已send<br />\n香港人好攰<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"6a20ac24fce28dbc983552894236cce44d613fad","tid":1474672,"uid":67553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T10:16:54.000Z","msg":"要改少少呀！唔係當係同一份"},{"pid":"515f993de40061e5988f016c5f9e390a8c240b78","tid":1474672,"uid":275616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T10:18:39.000Z","msg":"推<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"dd65e4cc77561b8a517de272a1fe83006cb0f1c9","tid":1474672,"uid":14601,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T10:27:35.000Z","msg":"推"},{"pid":"92ea23a1eba2ecc11d4217b56c3c41b3ee8b2ff9","tid":1474672,"uid":292644,"like":0,"dislike":0,"score":0,"quote":{"pid":"7376162f07f3652496fea72d46d4e733f4b23157","tid":1474672,"uid":185022,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-08-15T09:12:40.000Z","msg":"致專責小組成員：<br />\n<br />\n本人為香港市民，有聞 貴組於6月28日文件中提出刪去文憑試聆聽及說話考卷，本人堅表強烈反對，原因如下：<br />\n<br />\n一，掌握母語不等於能以母語表達，說話要言之有物、出口成文，除了要豐富的詞彙，亦要有清晰的表達方式，說話卷的核心價值在於檢視學生在日常用語之外，能否有效建構論點展開討論，而廢除後則無地方訓練學生這頂基本能力。<br />\n<br />\n二，掌握母語不等於能理解別人話語內容，聆聽別人的說話可以訓練學生將對話精煉的能力，亦即是捕捉重點的能力，假如廢除，恐怕學生會失去一個練習的平台，無法與人有效溝通。<br />\n<br />\n三，以語言系公開試ielts雅思為例，考核學生英語水平以讀聽寫說四考卷，尤其是以說話難度最高，一向是該考試衡量英語高水平者的好標準，如今 貴組研廢除聆、說二卷，猶如自斷一臂。<br />\n<br />\n<br />\n綜合以上及眾多學者之言，冀 貴組於此項教育改革方向予於重新考慮。<br />\n<br />\n<br />\n祝<br />\n工作順利<br />\n<br />\n<br />\n香港市民<br />\n<br />\n<img src=\"https://na.cx/i/fpFUCM5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfpFUCM5.png&h=a7026241&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n大家一齊send去佢嘅email<br />\n我唔想粵語咁快死<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-15T10:29:13.000Z","msg":"<span style=\"font-size: xx-large;\">冇粵語就冇得講&quot;賓州艦&quot;</span>"},{"pid":"fb80f523b8b1641bfe59a521dfce8f785bbae754","tid":1474672,"uid":185022,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T10:30:35.000Z","msg":"推"},{"pid":"5042819aee840e2961e8f1234f03193e2a3661b6","tid":1474672,"uid":67816,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T10:32:14.000Z","msg":"Pish"},{"pid":"d586402a5cda4e54346b51335842d10e6679131c","tid":1474672,"uid":89006,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T10:34:17.000Z","msg":"推"},{"pid":"6222982328b9d0bc7da922d50fd75931f19ce27e","tid":1474672,"uid":263068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T10:34:38.000Z","msg":"一定要救！"},{"pid":"aeaa4ea12ac105257a99f4390afeec248d44f9ec","tid":1474672,"uid":57975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T10:49:47.000Z","msg":"推"},{"pid":"d37f2cbcba8c59958ec12334a163ce52b09088b4","tid":1474672,"uid":123205,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T10:57:12.000Z","msg":"推"},{"pid":"34ae00e9cfff0e70c37470c4bd628313f4c821b3","tid":1474672,"uid":32996,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T11:03:15.000Z","msg":"721"},{"pid":"d2c6357472e09431289cae0d6d03ed298ed4cb4d","tid":1474672,"uid":285318,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T11:09:00.000Z","msg":"<img src=\"/assets/faces/dog/fight2.gif\" class=\"hkgmoji\" />搶救粵語<img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" />"},{"pid":"0de83aca959d5b888cc6f8db80beccd627ffa069","tid":1474672,"uid":156653,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T11:14:43.000Z","msg":"推"},{"p