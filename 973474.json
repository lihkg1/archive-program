uid":131262,"like":0,"dislike":0,"score":0,"quote":{"pid":"73ba672a41a3169bec354a905b042a482a8ac155","tid":973474,"uid":144529,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-01-10T02:57:14.000Z","msg":"係咪好似比針吉咁？"},"citedBy":1,"replyTime":"2019-01-10T04:27:45.000Z","msg":"無錯呀<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-10T04:54:35.000Z","msg":"我係出汗多左，飲水多左同埋個人瘦左先無事"}]}