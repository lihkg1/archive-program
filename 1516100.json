手機落地然後踢到母雷公咁遠<br />\n<br />\n<a href=\"https://lihkg.com/thread/1516112/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1516112/page/1</a><br />\n<a href=\"https://lihkg.com/thread/1516100/page/1?post=2\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1516100/page/1?post=2</a>"},{"pid":"561b2a9b729c395682e0d526768958c180f2aea4","tid":1516100,"uid":293698,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T14:14:08.000Z","msg":"此回覆已被刪除"}]}