normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: gold;\">9月8日<br />\n星期日<br />\n到美國領事館(遊行路線待定) <br />\n唱住美國國歌 (下面有MV歌詞) <br />\n全力支持通過<br />\n《香港民主及人權法案》！！</span><br />\n</span><br />\n<br />\n[全登集氣]推到民陣搞，9月8號星期日大遊行，援請通過香港人權法！<br />\n<a href=\"https://lih.kg/1531140\" data-auto-link target=\"_blank\">https://lih.kg/1531140</a><br />\n<br />\n美國人權及民主法案大遊行<br />\n<a href=\"https://lihkg.com/thread/1530650\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1530650</a><br />\n<br />\n<img src=\"https://na.cx/i/ARgCLoO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FARgCLoO.jpg&h=045fa316&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: gold;\">記住練定美國國歌到時唱！！！！<br />\n </span></span><br />\n~~Oh, say can you see, <br />\nBy the dawn's early light, <br />\nWhat so proudly we hailed, <br />\nAt the twilight's last gleaming?~<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/ZykHbrV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZykHbrV.jpg&h=30a62641&s={SIZE}\" /><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">全民發夢合唱</span> <span style=\"color: red;\">美國</span><span style=\"color: blue;\">國歌</span></span> <br />\n<br />\n<span style=\"font-size: x-large;\"> <span style=\"color: gold;\">We should learn how to sing</span><br />\n <em><span style=\"color: red;\">&quot;The Star-</span><span style=\"color: blue;\">Spangled Banner&quot;</span></em><br />\n</span><br />\n<a href=\"https://lih.kg/1528828\" data-auto-link target=\"_blank\">https://lih.kg/1528828</a><br />\n<br />\n<br />\n<br />\n<span style=\"font-size: x-large;\">大家仲記唔記得手足揮美國國旗唱美國國歌唱到Trump Trump都retweet!!!!</span><br />\n<br />\n<img src=\"https://na.cx/i/vNfTjAM.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FvNfTjAM.gif&h=db1663f7&s={SIZE}\" /><br />\n<br />\n<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://twitter.com/dcexaminer/status/1161305213841682439?s=09\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Fdcexaminer%2Fstatus%2F1161305213841682439%3Fs%3D09&d=TzvjPMdTsSggZCZjY4uR2yVDAD9kR8TUwRzNJuuVR5U%3D&h=81cd941c\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftwitter.com%2Fdcexaminer%2Fstatus%2F1161305213841682439%3Fs%3D09&h=72f77df1\" target=\"_blank\">https://twitter.com/dcexaminer/status/1161305213841682439?s=09</a><br />\n<br />\n<br />\n<br />\n<span style=\"color: gold;\">除咗九月八日，如果<span style=\"font-size: xx-large;\">十月一日</span>我地再幫支共賀一賀佢，搞到全美國都知支共國慶我地用美國國歌慶祝，你話會激到維尼幾咁高興？<br />\n<br />\n而最重要，我地之前揮動美國國旗、唱美國國歌，美國傳媒一直都理解成我地係以追求人權民主自由既普世價值而表態！！！亦係動之以情地令佢地推動 香港民主及人權法案 既方法！！！<br />\n</span> <br />\n<br />\n<br />\n<span style=\"font-size: x-large;\"><br />\n九月八日發夢同我一齊唱！<br />\n</span><br />\n<br />\n<span style=\"color: limegreen;\"><strong><span style=\"font-size: x-large;\">MV with Lyrics: </span></strong></span><br />\n<br />\n<a href=\"https://youtu.be/vPKp29Luryc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FvPKp29Luryc&d=TzvjPMdTsSggZCZjY4uR2yVDAD9kR8TUwRzNJuuVR5U%3D&h=9956f821\" target=\"_blank\">htt