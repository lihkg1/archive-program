=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"424ba6f85150f57e43d8d75885d0831516abfcfb","tid":351554,"uid":71166,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-08T08:15:31.000Z","msg":"呢個鍾意"},{"pid":"84cef12ffda0943d87ffbbcc2d38db58032fab0c","tid":351554,"uid":30742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-08T08:49:21.000Z","msg":"<blockquote>呢個鍾意</blockquote><br />\n春雞好！<br />\n<br />\n<br />\n脂肪肥膏少d～岩女仔食<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"12b6f7487081cbc43671cdb2bc0f12808c107e79","tid":351554,"uid":106307,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-08T08:55:43.000Z","msg":"<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"0bcd8a406ab419f87e81d0ca94fa24a0ec2ea0cd","tid":351554,"uid":133256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-08T09:01:41.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"5a73309ee21ecca4d2bb99fafe2b93ee3d64eff2","tid":351554,"uid":4525,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-08T09:07:08.000Z","msg":"高難度"},{"pid":"12d364b0f10bfba10e01e8ef68972f1c630965d3","tid":351554,"uid":30742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-08T09:29:40.000Z","msg":"<blockquote>高難度</blockquote><br />\n其實唔難～～<br />\n最難係起個背骨～有鉸剪慢慢黎就得"},{"pid":"7841448852ff7d32d61c1391ddd678cf1109487e","tid":351554,"uid":72226,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-08T17:30:38.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"688f033b4897bed14423106b28bdce29ef9d536e","tid":351554,"uid":30742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-09T02:33:42.000Z","msg":"<blockquote><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"