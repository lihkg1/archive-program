dislike":0,"score":0,"quote":{"pid":"8084a54259c10d33e296914d0fb1aa1aba3b657f","tid":2124493,"uid":229185,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-25T12:12:23.000Z","msg":"fake news"},"citedBy":1,"replyTime":"2020-07-25T12:23:19.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://twitter.com/Reuters/status/1286992090711429121?s=20\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2FReuters%2Fstatus%2F1286992090711429121%3Fs%3D20&d=jSYRdVihxMCX8m9Ry8wFHZ2AEL7eB1GKmMTTK1c2%2F04%3D&h=ccc85290\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftwitter.com%2FReuters%2Fstatus%2F1286992090711429121%3Fs%3D20&h=9e7fff67\" data-auto-link target=\"_blank\">https://twitter.com/Reuters/status/1286992090711429121?s=20</a>"},"citedBy":1,"replyTime":"2020-07-25T13:07:57.000Z","msg":"咁de facto ban 事實上亦唔係ban<br />\n<br />\n只係用行政手段玩鳩佢，令電訊商唔會用華為<br />\n<br />\n做法同紐西蘭一樣"},"citedBy":0,"replyTime":"2020-07-25T13:20:26.000Z","msg":"咁其實都知huawei bad news又唔直ban<br />\n驚what?<br />\n仲要睇支共面色?"}]}