5-23T19:15:07.000Z","msg":"支持"},{"pid":"13628c4037e68cf71d72082ab01194c9282a1d97","tid":2031970,"uid":97828,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-05-23T19:24:41.000Z","msg":"唔夠醬"},{"pid":"144e3f4612289e098bcb1c839318ee293ac1f8a0","tid":2031970,"uid":260581,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-23T19:44:35.000Z","msg":"靚碟<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"45403d9683b809e835fd49569051a4f5a198b9ad","tid":2031970,"uid":272819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T23:27:55.000Z","msg":"好食呀 點整<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"dbf42afdb58041a2cd3c4a1c81fb4599e750d1b3","tid":2031970,"uid":318887,"like":0,"dislike":0,"score":0,"quote":{"pid":"13628c4037e68cf71d72082ab01194c9282a1d97","tid":2031970,"uid":97828,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-05-23T19:24:41.000Z","msg":"唔夠醬"},"citedBy":0,"replyTime":"2020-05-24T04:58:52.000Z","msg":"係lu，有啲麵皮乾左啲"},{"pid":"e486d6c4de21d486355eee9a96c7c05e07fa9d23","tid":2031970,"uid":318887,"like":0,"dislike":0,"score":0,"quote":{"pid":"144e3f4612289e098bcb1c839318ee293ac1f8a0","tid":2031970,"uid":260581,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-23T19:44:35.000Z","msg":"靚碟<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-24T05:00:17.000Z","msg":"5蚊隻好抵"},{"pid":"3c87d044ace365455aaa47a962031aff797e9ca2","tid":2031970,"uid":318887,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-05-24T13:19:06.000Z","msg":"正宗意大利肉醬做法<br />\n<a href=\"https://youtu.be/JlbSJcriYSs\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FJlbSJcriYSs&d=s%2ByQnOBpfLb1r8GSWDTSOYoeW3mBCvqo%2FKk1k%2BmNMw8%3D&h=5ed4ccbf\" target=\"_blank\">https://youtu.be/JlbSJcriYSs</a><br />\n正宗意大利千層麵做法<br />\n<a href=\"https://youtu.be/3GjDSQsiRMU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F3GjDSQsiRMU&d=s%2ByQnOBpfLb1r8GSWDTSOYoeW3mBCvqo%2FKk1k%2BmNMw8%3D&h=29b3ee4b\" target=\"_blank\">https://youtu.be/3GjDSQsiRMU</a><br />\n<br />\n好喇，以下就係唔正宗千層麵做法<br />\n<br />\n首先，我跟住正宗嘅肉醬做法，但加左意大利粉醬即係759有得賣嗰啲做左肉醬<br />\n<br />\n一罐成功抽左真空，一罐唔成功<br />\n<br />\n因為我食開嘅千層麵都係蕃茄味嘅，唔係肉味菠菜味<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<img src=\"https://na.cx/i/ZxjyRPn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZxjyRPn.jpg&h=0dad47a2&s={SIZE}\" /><br />\n<br />\n煮好左啲醬，就用油掃下個烤盤底，否則最下麵塊麵皮會痴底食唔到，千層麵皮百佳有售<br />\n然後一層麵皮，一層醬<br />\n<br />\n（尋日個肉醬千層麵其實已經好好食，干濕度係啱啱好嘅，就係落醬落得比較窮撚，但我唔捨得兩日就用曬啲醬，所以今日直接加左啲蕃茄碎等個醬好似多啲<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />，正常應該係同肉醬一齊煮好嘅，但我尋日搞左好多嘢今日費事開壇作法，呢個唔好學<img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />）<br />\n<br />\n再加一層芝士，我用左aged chadder 超濃味所以無加好多，另外仲有meadow 嗰個yorkshire 乜鬼芝士，超香奶味我估係羊奶整嘅，通常兩種以上芝士個千層麵先會好食<br />\n<img src=\"https://na.cx/i/UoF2LdK.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUoF2LdK.jpg&h=813317b3&s={SIZE}\" /><br />\n<br />\n<img src=\"https://na.cx/i/PN5x7kz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPN5x7kz.jpg&h=943c1b9c&s={SIZE}\" /><br />\n<br />\n咁其實由於我唔想咁油就切左啲蕃茄片放响底就無掃油<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />正常嘅千層麵係無蕃茄响底嘅，自己食就是但<br />\n<br />\n最後都係整左四層，咁就可以成盤食曬唔使太飽<br />\n<img src=\"https://na.cx/i/zqvBPyL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzqvBPyL.jpg&h=d4f1d859&s={SIZE}\" /><br />\n<br />\n最後嗰層應該要超多芝士，遮曬個面，否則無醬無芝士覆蓋嘅麵皮就會烤燶，但我無咁多錢落芝士就又切啲蕃茄塞曬啲位算<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/dwMQT0t.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FdwMQT0t.jpg&h=a6600346&s={SIZE}\" /><br />\n<br />\n呢篇嘢未打完就焗好左，麵皮盒上面有寫佢個麵要焗幾耐同溫度<br />\n<br />\n<img src=\"https://na.cx/i/4u9V5im.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4u9V5im.jpg&h=6c6060fb&s={SIZE}\" /><br />\n真係今日影嘅，雖然個面個樣同尋日一樣<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n220C 20分鐘食得，如果個肉醬係整好响雪櫃，芝士有存貨真係5分鐘擺好，打機20分鐘，然後食得<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n個蕃茄生勾勾放上麵個結果就係出好多水個麵皮太濕<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />通常啲人都鐘意乾身啲嘅<br />\n<img src=\"https://na.cx/i/XVB5H6b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXVB5H6b.jpg&h=2f6e1e24&s={SIZE}\" /><br />\n<br />\n唔想淥熟個嘴就放入另一隻碟度食<br />\n<br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n總括而言，千層麵好易整，我註明左嘅膠嘢唔好學就得<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"fec4ab8a9586dee2d74467e145f17ec7505e3384","tid":2031970,"uid":318887,"like":0,"dislike":0,"score":0,"quote":{"pid":"3579d455026812fb68da0ad78a6f7c61ca44a8ec","tid":2031970,"uid":217260,"like":0,"dislike":0,"score":0,"quote":{"pid":"bdb420097d0ac209f2b23db36afa4c50b0d47397","tid":2031970,"uid":318887,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-23T18:47:54.000Z","msg":"<img src=\"https://na.cx/i/vboGUKP.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FvboGUKP.jpg&h=dad5ff3b&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/QqDDcww.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQqDDcww.jpg&h=d5ab5436&s={SIZE}\" /><img src=\"https://na.cx/i/HK7sQid.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHK7sQid.jpg&h=88dceca6&s={SIZE}\" />"},"citedBy":2,"replyTime":"2020-05-23T18:55:08.000Z","msg":"有冇得教下好正<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-24T13:27:12.000Z","msg":"<img src=\"https://na.cx/i/E0DDiKR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FE0DDiKR.jpg&h=a41f6052&s={SIZE}\" /><br />\n<br />\n寫左咁多你快啲黎睇"},{"pid":"2b88101c1831d0d9b192c6c1109952185df748f9","tid":2031970,"uid":318887,"like":0,"dislike":0,"score":0,"quote":{"pid":"13628c4037e68cf71d72082ab01194c9282a1d97","tid":2031970,"uid":97828,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-05-23T19:24:41.000Z","msg":"唔夠醬"},"citedBy":0,"replyTime":"2020-05-24T13:28:50.000Z","msg":"窮撚係咁"},{"pid":"1c2ea5ce89620cd367db1f1fe86e5cd2ff1cc857","tid":2031970,"uid":217260,"like":0,"dislike":0,"score":0,"quote":{"pid":"fec4ab8a9586dee2d74467e145f17ec7505e3384","tid":2031970,"uid":318887,"like":0,"dislike":0,"score":0,"quote":{"pid":"3579d455026812fb68da0ad78a6f7c61ca44a8ec","tid":2031970,"uid":217260,"like":0,"dislike":0,"score":0,"quote":{"pid":"bdb420097d0ac209f2b23db36afa4c50b0d47397","tid":2031970,"uid":318887,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-23T18:47:54.000Z","msg":"<img src=\"https://na.cx/i/vboGUKP.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FvboGUKP.jpg&h=dad5ff3b&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/QqDDcww.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%