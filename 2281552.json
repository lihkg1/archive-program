9:04:17.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2020-11-11T09:31:26.000Z","msg":"順便blk埋第一個覆你嗰件"},{"pid":"f78b7e46fbbf1cf8c66abd933a939088bcbf27c8","tid":2281552,"uid":248131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-11T09:31:54.000Z","msg":"唔係秒速冇可疑？"},{"pid":"4a56c30e9bef552e502e069288f02e5a72984497","tid":2281552,"uid":378177,"like":11,"dislike":81,"score":-70,"citedBy":2,"replyTime":"2020-11-11T12:47:34.000Z","msg":"啱啦 少一件垃圾"},{"pid":"cbf8376c309413fe31c00b58b374426394f8f47c","tid":2281552,"uid":312846,"like":41,"dislike":5,"score":36,"citedBy":7,"replyTime":"2020-11-11T13:30:53.000Z","msg":"據了解，姚是涉事宿舍的宿生，昨晚(10日)偕同3男2女友人飲酒聊天，在杯觥交錯間，6人皆喝得醉醺醺。期間，一名女生人有三急，意欲到廁所小解，卻不慎撼傷頭部，其餘5人得悉事件大驚，報警召來救護車將她送院。各人之後討論事件，有人疑將事件責任矛頭指向姚，姚亦深感自責，變得情緒低落，大家不歡而散，各自離開休息。<br />\n消息指，姚不歡而散後，有人疑受酒精影響，鬱結加上愧疚，一時衝動下做出傻事。宿舍閉路電視攝下姚在清晨約5時，獨自乘電梯登上5樓，繼而推門走上天台，雖然開門時一度觸動警鐘，卻無人察覺有異。而天台裝設的太陽能板則發現姚留下的鞋印，懷疑他曾踏上太陽能板，再攀出石壆跳下尋短，飛墮後山側邊地面，因該處人迹罕至，少有人留意，故此在墮樓後近7個小時才被人發現。"},{"pid":"c7ac01d59b5aa6290407c3800a0811996740300e","tid":2281552,"uid":199261,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-11-11T13:33:55.000Z","msg":"此回覆已被刪除"},{"pid":"52fdb18f7236233b243399d2b85e7305dbafea7a","tid":2281552,"uid":106348,"like":31,"dislike":1,"score":30,"quote":{"pid":"d89fb8c921eb416280666f92f9a1291d92aeea75","tid":2281552,"uid":284432,"like":234,"dislike":22,"score":212,"quote":{"pid":"b3adb92e3f01153261bfc595aaff881390106fde","tid":2281552,"uid":192409,"like":58,"dislike":452,"score":-394,"citedBy":6,"replyTime":"2020-11-11T09:00:00.000Z","msg":"手足<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":9,"replyTime":"2020-11-11T09:04:17.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-11-11T13:34:45.000Z","msg":"一早block 咗"},{"pid":"337ae9918061b722448beb8c8316b96c90af9df5","tid":2281552,"uid":332604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-11T13:52:03.000Z","msg":"RIP"},{"pid":"067cec5e82a0b94fa23ddc1920e26195a7d464e1","tid":2281552,"uid":