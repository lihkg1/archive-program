ces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"8a146918406149224d0c4def30093d2c52cd33c3","tid":2234170,"uid":15815,"like":0,"dislike":0,"score":0,"quote":{"pid":"9f461edac80eb8f29d27235619f68aa727854846","tid":2234170,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-07T17:03:36.000Z","msg":"China secret有咩secret"},"citedBy":0,"replyTime":"2020-10-08T12:03:23.000Z","msg":"有冇人肯竊漏國家機密<br />\n入面搞邊科?<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"ff5ac3cec3c6cb1d1f7de17a38b07f8bf8267bdc","tid":2234170,"uid":242537,"like":0,"dislike":0,"score":0,"quote":{"pid":"33638a60542a42d297567c4b0dc6a0fb8ab198a4","tid":2234170,"uid":151143,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-10-07T16:15:33.000Z","msg":"雞蟲又贏 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-11T06:23:52.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/play.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"923aebe24b566a4b6d4c32708a7b07194d0d8797","tid":2234170,"uid":66817,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1be9d39adbe36f75dfcf76a3c1dd32186d319d1","tid":2234170,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-07T16:01:58.000Z","msg":"<img src=\"https://s.yimg.com/ny/api/res/1.2/0D6LSxG8T9GKOoEcWg2JNA--~A/YXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9ODAw/https://media.zenfs.com/zh-tw/singtao.com.hk/b643e8704bcde6ed2d4f2ff180953174\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs.yimg.com%2Fny%2Fapi%2Fres%2F1.2%2F0D6LSxG8T9GKOoEcWg2JNA--~A%2FYXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9ODAw%2Fhttps%3A%2F%2Fmedia.zenfs.com%2Fzh-tw%2Fsingtao.com.hk%2Fb643e8704bcde6ed2d4f2ff180953174&h=d1f891e9&s={SIZE}\" /><br />\n<br />\n衞生署衞生防護中心傳染病處主任張竹君公布，本港今日新增11宗確診個案，累計個案5144宗。在確診個案中，2宗為輸入個案，9宗為本地個案。另有10宗以下的初步確診個案。在9宗本地個案中，6宗與早前的個案有關，3宗為源頭不明個案。<br />\n<br />\n在與早前的個案有關的個案中，3人涉及尖沙嘴豪麗大廈。個案編號5134的患者為泰國籍人士，由檢疫中心送院，曾與5123患者同住同住豪麗大廈，本月2日曾轉到帝苑酒店，相信與早前確診的餐廳職員無關。個案編號5141的患者為泰國籍人士，於9月23日曾到尖沙嘴赫德道利就商業大廈的China Secret酒吧，被送往檢疫中心，曾與5134患者在豪麗大廈同住，本月2日亦曾轉到酒店。個案編號5142的泰籍患者曾與5123患者同住豪麗大廈，由檢疫中心入院。張竹君指，目前相信豪麗大廈人士亦與China Secret酒吧有關。<br />\n<br />\n另有3宗本地個案涉及朋友群組，包括個案編號5135、5136及5137患者。當中，5136患者發病較早，感染源頭不明，與另外兩名患者為朋友，均為旺角藥房的售貨員，分別在西洋菜街龍城中西藥房、豉油街大華藥房及旺角亞皆老街龍城中西藥房工作，最後上班日均為本月4日。3人分別在本月3日及4日不適，本月5日前往養和醫院求醫。3人平日在工作時會到其他藥房分店借貨及聊天，與其他藥房分店的員工有接觸，因此藥房員工會被列為密切接觸者，會送往檢疫。另外，5135患者在潛伏期內，於9月25日曾到油塘按摩，而5136患者則於本月3日發病，9月30日曾到九龍城按摩。中心已請求警方協助調查，未有資料證實3人曾到China Secret酒吧。<br />\n<br />\n另有兩宗個案涉及家庭群組，包括個案編號5143及5144的患者。當中，5143患者為浸大學生，本月1日不適。上月29至30日曾回校上學，會向同一班房的同學派發樣本樽，亦會要求校方進行清潔，學生在上課時有戴口罩。其1名家人、即5144的患者為將軍澳迦密主恩中學的學生，9月30日最後上學，較遲發病。中心會向該校派發樣本樽，並要求校方進行大清洗。兩名患者在潛伏期內曾與數名朋友打籃球，會向該批朋友派發樣本樽，但不會列為密切接觸者。兩名患者亦曾參與家庭聚會，涉及7至8人，另曾與親戚朋友BBQ，涉及6人。<br />\n<br />\n另有一宗個案為私營殘疾院舍「國寶之家」院友，個案編號5140的患者為57歲男子。該院舍有至少2名院友初步確診。<br />\n<br />\n在2宗輸入個案中，均由印度返港，包括個案編號5138及5139的患者。2人同於本月5日乘搭AI310航班到港。<br />\n<br />\n<a href=\"https://hk.news.yahoo.com/增11宗確診包括3藥房職員-china-secret累計9人中招-092100391.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.yahoo.com%2F%E5%A2%9E11%E5%AE%97%E7%A2%BA%E8%A8%BA%E5%8C%85%E6%8B%AC3%E8%97%A5%E6%88%BF%E8%81%B7%E5%93%A1-china-secret%E7%B4%AF%E8%A8%889%E4%BA%BA%E4%B8%AD%E6%8B%9B-092100391.html&d=xM4HlgsByf6UCiwKp%2FWW5Mg1Od0Dt6CGL4wHSLmh2%2Bg%3D&h=7c70994f\" target=\"_blank\">https://hk.news.yahoo.com/增11宗確診包括3藥房職員-china-secret累計9人中招-092100391.html</a>"},"citedBy":1,"replyTime":"2020-10-11T06:39:32.000Z","msg":"屌明明有殘障但叫自己做國寶...<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n真心貪個名好聽定揶揄緊自