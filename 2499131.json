.cx%2Fi%2FaoD0qSZ.png&h=9dcf667a&s={SIZE}\" /><img src=\"https://na.cx/i/OURQN6k.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOURQN6k.png&h=12028f72&s={SIZE}\" /><img src=\"https://na.cx/i/w7VaN6n.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fw7VaN6n.png&h=87aec4e2&s={SIZE}\" /><br />\n<br />\n第一擊應該不停用巡航導彈 同轟炸機轟炸軍事目標<br />\n雷達站 軍營 軍用機場 彈藥庫 <br />\n高鐵站 港口 油庫 <br />\n警局都會被轟炸<br />\n<br />\n到時可能停水停電<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n要儲水儲糧<br />\n<br />\n可以既話 係被轟炸完既警局入面 拿槍自衛"},"citedBy":3,"replyTime":"2021-04-22T04:07:49.000Z","msg":"得你正路d<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n先唔講乜，假設冇核戰<br />\n香港係一個人口多依賴食物入口既城市，到時一定缺水缺糧。睇肺炎個陣連紙巾都搶就知咩事。<br />\n自己一定要預先蓄定糧水，再同人出去爭政府派既糧。<br />\n到時最要防備既係人，要小心唔好畀人搶糧<br />\n<br />\n<br />\n雖然香港唔係工業區<br />\n但係有一個世界級既碼頭。<br />\n萬一到時美軍登陸，中共一定預先炸個港口<br />\n而美軍亦都有機會先發制人炸左個港口，削弱中共海運能力<br />\n到時葵芳荔景居民真係要自求多福<br />\n<br />\n同埋一河之隔既深圳就係個科技中心<br />\n到時要炸深圳，如果用傳統彈藥地毯式轟炸<br />\n北區絕對會係誤中範圍"},{"pid":"707615af2f3c417e00bee7e5391c95dd4b10e944","tid":2499131,"uid":33263,"like":0,"dislike":0,"score":0,"quote":{"pid":"c0c739c25204a21a23f00311c228e42f80c08867","tid":2499131,"uid":60648,"like":3,"dislike":0,"score":3,"quote":{"pid":"124fc588e2a4e755811d382f16721ff02168f8ad","tid":2499131,"uid":33263,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-04-22T02:53:02.000Z","msg":"<img src=\"https://na.cx/i/aoD0qSZ.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaoD0qSZ.png&h=9dcf667a&s={SIZE}\" /><img src=\"https://na.cx/i/OURQN6k.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOURQN6k.png&h=12028f72&s={SIZE}\" /><img src=\"https://na.cx/i/w7VaN6n.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fw7VaN6n.png&h=87aec4e2&s={SIZE}\" /><br />\n<br />\n第一擊應該不停用巡