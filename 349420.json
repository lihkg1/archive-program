MI%3D&h=3c64b981\" data-auto-link target=\"_blank\">https://r.hkbn.net/S/SSHKBN10017</a><br />\n<br />\n月費回贈會在開始使用服務後存入閣下香港寬頻賬戶內，用作扣減月費之用。<br />\n<br />\n如果登記後出現問題，香港寬頻會專人聯絡閣下。"},{"pid":"ee160682e3b7d9e146af87d564ab858ff8cf1813","tid":349420,"uid":137501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-17T12:12:15.000Z","msg":"此回覆已被刪除"},{"pid":"ed218054e502ca0cdbf213e70186c30eaada318a","tid":349420,"uid":137509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-17T12:42:16.000Z","msg":"此回覆已被刪除"},{"pid":"3fc009c6610d747c23825e6b2cd3b5193d3be6a8","tid":349420,"uid":136344,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-17T12:47:38.000Z","msg":"此回覆已被刪除"},{"pid":"f6dae355c7524c6d882a82b762cfaa7f8d9b303b","tid":349420,"uid":137509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-17T14:45:15.000Z","msg":"此回覆已被刪除"},{"pid":"6eba1c546d646cfafdc211402179020e626b2ef3","tid":349420,"uid":136108,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-18T05:13:08.000Z","msg":"此回覆已被刪除"},{"pid":"cab9499168dbe2d3b6f88e85dc35b283d41fe17c","tid":349420,"uid":137771,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-18T05:28:12.000Z","msg":"此回覆已被刪除"},{"pid":"b36872f7394d47e125481bf56307b60ee19c08c9","tid":349420,"uid":136346,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-18T05:43:50.000Z","msg":"此回覆已被刪除"},{"pid":"8a37eceaa92a0b6a1a7df0adad521667e8c18fba","tid":349420,"uid":138490,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-19T15:18:17.000Z","msg":"此回覆已被刪除"},{"pid":"8d7f9485f8fb6c8f9d720c599e405e5a90e37141","tid":349420,"uid":130888,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-19T17:40:47.000Z","msg":"此回覆已被刪除"},{"pid":"034338a6a7319d07dfbe20c72037f357252db130","tid":349420,"uid":138472,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-19T19:20:11.000Z","msg":"此回覆已被刪除"},{"pid":"a1d1edaba2b774dbbaaff48d2d1c2764aaa0883d","tid":349420,"uid":13