umbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6620998.gif&h=58c07c54&s={SIZE}\" />"},{"pid":"12c35a735497612e0e840795f503f463eb2bb557","tid":223060,"uid":25858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-30T05:28:41.000Z","msg":"有美軍we trust<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"43fc67eaa964a5c881430211e867d1e4a9173816","tid":223060,"uid":89478,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-30T05:29:32.000Z","msg":"<blockquote>有美軍we trust<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /></blockquote><br />\n叫我?"},{"pid":"56084471d0cb1753ffe250892f48ef7f86d59c67","tid":223060,"uid":7190,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-04-30T05:29:42.000Z","msg":"美軍來了我帶路"},{"pid":"0f87ad45000dd87da9af96bc53ef9af0e86354b5","tid":223060,"uid":30487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-30T05:30:16.000Z","msg":"又可以打J<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"0034ccf72a2bd095fa839428fe673161de8eed2f","tid":223060,"uid":8858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-30T05:31:29.000Z","msg":"美軍<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"db7a8e0efec90d780a9836887d28e77d952a40af","tid":223060,"uid":48157,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-04-30T05:34:39.000Z","msg":"此回覆已被刪除"},{"pid":"92dfcd1e6bb6a367483dcc87d2671e8e253527be","tid":223060,"uid":45635,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-30T05:39:12.000Z","msg":"又可以落老蘭屌西<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"c27c9c4785a8ba07739dbeec3580a0a5d9870a1f","tid":223060,"uid":15815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-30T06:56:33.000Z","msg":"<blockquote>又可以落老蘭屌西<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n未有老蘭之前都屌緊<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n洋腸文化源遠流長<br />\n係d濕九廢青先會唔抵得"},{"pid":"cba9862e3ac6408db4969209d1fa9f1d0f7d1d6e","tid":223060,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-30T13:20:18.000Z","msg":"<blockquote>陳浩天  當年好似淨係見過德國領事，冇見過美國佬.</blockquote><br />\nNATO"},{"pid":"b06ddc4addbaa802b775bdda61e7335fdff3881f","tid":223060,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-30T13:21:44.000Z","msg":"<blockquote>有美軍we trust<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">如果肥仔金掟核彈黎香港, <br />\n<br />\n都係靠美帝呢隻神盾去頂<br />\n<br />\n靠匪軍, 真係核平啦</span></span>"},{"pid":"4155c8e3d9915b659c1f9dd4db3000fb714f9001","tid":223060,"uid":10680,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-30T13:25:41.000Z","msg":"此回覆已被刪除"}]}