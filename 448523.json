assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"14223761c312ee93cd5b2c905d8fd0b086431df7","tid":448523,"uid":56024,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2017-10-26T12:20:22.000Z","msg":"<span style=\"color: blue;\">藍色</span>[brown][ur<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /> l]網址[/ur<strong><em>粗體</em></strong>l]棕色[/b[i]斜體面前ow<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> n]"},{"pid":"25c94bebc2925df985bc8e473c73a8d67d12c542","tid":448523,"uid":46910,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-26T12:23:41.000Z","msg":"咪撚出tim ar 以後實層層停<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"f1e28855f8f36989299f34e53685a433fddadc63","tid":448523,"uid":75677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-26T12:26:12.000Z","msg":"成班公屋仔諗法，哩啲設計俾一梯一兩伙嘅樓用都幾正"},{"pid":"e276e25c2b5d6f3249599524377db8b0c2623d82","tid":448523,"uid":10009,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-10-26T12:27:45.000Z","msg":"事但啦 一層得一戶 得嗰十幾層 快得去邊 又慢得去邊<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4dc8af5d769a575048d94da5568bab1e621cdd9e","tid":448523,"uid":122331,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-26T13:19:31.000Z","msg":"咁撳法不如行出去撳𨋢仲方便<br />\n反正都要搭𨋢啦 唔爭在嗰幾分鐘"},{"pid":"eceed6572dac4de25fc56569658b5ead94881a17","tid":448523,"uid":36157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-26T16:48:33.000Z","msg":"結果層層停"},{"pid":"d9c80d02f5921b4a93501ad2e96f38469d7e217c","tid":448523,"uid":8687,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-10-26T17:07:24.000Z","msg":"顯示部 lift 樓層上緊定落緊有用過禁 lift"},{"pid":"c14dc01bebd2fee3af3c431fb900920c2076215d","tid":448523,"uid":14719,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T08:28:28.000Z","msg":"我行入去禁算啦"},{"pid":"babbe5dc5c44e2a26c151a983cc5b7095aecd5a6"