 src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-05T03:42:09.000Z","msg":"通你老母都反曬眼"},{"pid":"e73a1ec6e9e47d98dae36edc5a6d27c2d89d9785","tid":690503,"uid":25327,"like":1,"dislike":1,"score":0,"quote":{"pid":"58116829def881b05652dd99a37556861f1be9eb","tid":690503,"uid":4917,"like":1,"dislike":0,"score":1,"quote":{"pid":"6e5a1065ef866e9966598fc3c6858800f0b39abe","tid":690503,"uid":25327,"like":2,"dislike":3,"score":-1,"quote":{"pid":"7325fb9e6fd9580db947ebcd88511be3f717753f","tid":690503,"uid":4917,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2018-06-05T03:08:18.000Z","msg":"坐四個禮拜啫，有乜所謂"},"citedBy":3,"replyTime":"2018-06-05T03:18:03.000Z","msg":"通櫃個樣反曬白眼<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-05T03:42:09.000Z","msg":"通你老母都反曬眼"},"citedBy":0,"replyTime":"2018-06-05T03:47:14.000Z","msg":"通你老母，芝士漢堡"},{"pid":"52048825438742a7abc36dcecf7c6ff6bda8b538","tid":690503,"uid":131064,"like":2,"dislike":0,"score":2,"quote":{"pid":"6cd4b0a3d8c251a7130a94cf6d2039946f9ca2b2","tid":690503,"uid":120575,"like":0,"dislike":0,"score":0,"quote":{"pid":"0a30f3660e903b96028c27c7be7c8bcfe1a966d0","tid":690503,"uid":32473,"like":37,"dislike":1,"score":36,"citedBy":1,"replyTime":"2018-06-05T03:34:56.000Z","msg":"睇晒兩頁留言<br />\n只能講五毛太多<br />\n坐完出返來唔好再搞政治了<br />\n香港已經玩完<br />\n由他吧"},"citedBy":2,"replyTime":"2018-06-05T03:40:29.000Z","msg":"坐完留左案底仲返到正常工咩<br />\n而家已經返唔到轉頭啦"},"citedBy":1,"replyTime":"2018-06-05T03:50:03.000Z","msg":"當一個人被定罪後，留於警方或法庭之案底便不能被刪除（除非該罪犯上訴成功）。但根據《罪犯自新條例》（香港法例第297章）第2條，如罪犯是初犯者（即沒有其他案底），及被判處不超過3個月的監禁或罰款不超過10,000元，只要該罪犯在三年內不再犯案，其案底便可被視為「已喪失時效」。<br />\n<br />\n如案底已喪失時效，該罪犯等同沒有被定罪一樣，因此，如他在求職時被僱主或其他人詢問有無犯過刑事罪，他可立即回答：「無」。該人不得因為沒有披露其案底而被解僱。<br />\n<br />\n但案底喪失時效之安排亦有例外情況。舉例，此安排不適用於高級公務員職位之求職者；如欲申請擔任或認可為律師、會計師、保險代理人或銀行董事，上述安排亦不適用（詳情可參閱《罪犯自新條例》第3條及第4條）。此外，如有關罪犯準備移民而向警方申請無犯罪紀錄証明書（俗稱「良民証」），警方仍會在這文件上列出有關案底，但會註明此案底在香港法律下已喪失時效。"},{"pid":"861dec65807676dae41f4cebe1476eaad8e3cfa0","tid":690503,"uid":48358,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-06-05T03:51:58.000Z","msg":"傍晚約六時四十五分開始領取消夜<br />\n咁早食宵夜<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"60466bb1f83cbe1ea50e35f48d82e84b226bbb53","tid":690503,"uid":32473,"like":1,"dislike":0,"score":1,"quote":{"pid":"6cd4b0a3d8c251a7130a94cf6d2039946f9ca2b2","tid":690503,"uid":120575,"like":0,"dislike":0,"score":0,"quote":{"pid":"0a30f3660e903b96028c27c7be7c8bcfe1a966d0","tid":690503,"uid":32473,"like":37,"dislike":1,"score":36,"citedBy":1,"replyTime":"2018-06-05T03:34:56.000Z","msg":"睇晒兩頁留言<br />\n只能講五毛太多<br />\n坐完出返來唔好再搞政治了<br />\n香港已經玩完<br />\n由他吧"},"citedBy":2,"replyTime":"2018-06-05T03:40:29.000Z","msg":"坐完留左案底仲返到正常工咩<br />\n而家已經返唔到轉頭啦"},"citedBy":0,"replyTime":"2018-06-05T03:54:11.000Z","msg":"咁你話點？"},{"pid":"78657bb7d4be08ef69c784def2e136bb04dd6d6c","tid":690503,"uid":151774,"like":1,"dislike":3,"score":-2,"citedBy":1,"replyTime":"2018-06-05T03:55:03.000Z","msg":"自己攞嚟"},{"pid":"a8c50e0b0071c2ee932603e0a98b14e44e3eec01","tid":690503,"uid":33789,"like":1,"dislike":0,"score":1,"quote":{"pid":"ed1b0a092719555fe915a5dd1d21d95fdceb07b1","tid":690503,"uid":85461,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2018-06-05T02:56:14.000Z","msg":"一個月先食一餐雞翼 搞罷食"},"citedBy":1,"replyTime":"2018-06-05T03:56:59.000Z","msg":"大咪哥"},{"pid":"c5d0ede701ad5c654c1613f9506d1ed6be8270a6","tid":690503,"uid":158920,"like":3,"dislike":6,"score":-3,"citedBy":0,"replyTime":"2018-06-05T03:57:04.000Z","msg":"此回覆已被刪除"},{"pid":"c433b618e640f74e21daab6847d7a3dc0ba1309f","tid":690503,"uid":187489,"like":1,"dislike":0,"score":1,"quote":{"pid":"52048825438742a7abc36dcecf7c6ff6bda8b538","tid":690503,"uid":13