ormal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-16T14:53:10.000Z","msg":"818 BB仔狗仔都可以出呀<br />\n吹大雞呀依加<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"89d309f6d505ac4757c59ad7b74218c4f37270f5","tid":1478524,"uid":28123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T14:54:09.000Z","msg":"<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"f85bf72c64c9c85965c045378b16df26924eaff4","tid":1478524,"uid":31796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T14:58:33.000Z","msg":"勝利方程式<br />\n和理非-&gt;deadline-&gt;升級<br />\n818係第一步和理非<br />\n大家要一齊出黎集氣<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n只要係各大平台做好宣傳<br />\n全部自己人都知818係和理非<br />\n咁啲警察/大陸人自然無所遁形啦<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},{"pid":"f231c7500f9f8f117250a20d9788cc162e7fe106","tid":1478524,"uid":284695,"like":0,"dislike":0,"score":0,"quote":{"pid":"bf841e1adc7f91538e4edadae130e350159238d0","tid":1478524,"uid":28123,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-16T14:19:29.000Z","msg":"唔好再搞分化喇，從來勇武同和理非都唔係二元對立。<br />\n<br />\n你估有冇勇武今晚去咗集會？又有冇和理非71係PP轉右？<br />\n<br />\n和理非同勇武只係視乎你去個活動嘅心態。而我懇請手足們，<strong>818一定要凖備好和理非嘅心態去</strong>。<br />\n<br />\n出面好多人講緊準唔準備gear，<strong>其實帶唔帶定都冇所謂，我係好擔心手足話帶gear係因為有勇武嘅心態</strong>。想講，大家之前叫民陣再搞一次係咩目的？就係想全民吹一次大雞，用民意做武器 + 反駁恐佈勢力。既然係咁，人數同和平一定係818既焦點。<br />\n<br />\n要知道，好多時衝突係有狗挑機、有鬼搞事在先。818永遠要記住兩大共識，<strong>用和理非嘅心態去，守好國際道德高地</strong>，咁所有問題都可以解決得到。禮貌叫停身邊冇守呢兩個共識嘅人，齊上齊落不切割。<br />\n<br />\n我講過，政權狗急跳牆，<strong>一定會有請君入甕嘅局引大家失去國際支持</strong>。落單警、落單高官、一批失槍、放鬼（一堆黑衫大陸人落咗黎啦），全部有可能。<strong>我地冇大台，但係有共識，記得一定要堅守呢啲共識</strong>，破解政權設下嘅局。我地離成功不遠了。<br />\n<br />\nP.S. 所有香港人，不論政見，只要你識分是非黑白，818一定要出。"},"citedBy":0,"replyTime":"2019-08-16T14:59:40.000Z","msg":"推"},{"pid":"9465c452347bf33f2341fb421f3152baa0f0893c","tid":1478524,"uid":28123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:03:13.000Z","msg":"<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"d94ce38489bf06f7dd661bcac5289d0bc9870525","tid":1478524,"uid":28123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:06:37.000Z","msg":"<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"10df4facd0019688387a45e160d02c4b69e8e44c","tid":1478524,"uid":28123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:08:24.000Z","msg":"<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"734c30b975c099a673868d17de7a947ed391ac36","tid":1478524,"uid":137309,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:08:58.000Z","msg":"此回覆已被刪除"},{"pid":"4a7bf54e0630eaced5127aabb2c2999f60335b22","tid":1478524,"uid":28123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:11:41.000Z","msg":"<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"49e791d0f845386f85b05dd46643510916f94933","tid":1478524,"uid":28123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:14:40.000Z","msg":"<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"cd07ffb3cfdfe99dd78d581322db43aaebdee002","tid":1478524,"uid":28123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:15:18.000Z","msg":"<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"fbd89bf6fc48bd92cff6367aed116a501418bd69","tid":1478524,"uid":242083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:16:03.000Z","msg":"出嚟818啦<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n有人整左條片啊，咁高汁嘅片同我share爆佢<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://www.youtube.com/watch?v=bBQAD-1EJMg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DbBQAD-1EJMg&d=GZKRZRfhFQ75XgsIw24e0QsTF5hDypdTwPi8eTnvKzQ%3D&h=1aa34f32\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=bBQAD-1EJMg</a><br />\n<br />\n記得拖埋親朋好友去遊行，我哋要重現百萬人大遊行<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><br />\n<br />\n818見"},{"pid":"abeb349bbf6e6fac382acb13a88bda5e0dd4549d","tid":1478524,"uid":55197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:16:23.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ffb71783a06c7f73ac09118dd2a051a6fd783b18","tid":1478524,"uid":146737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:16:44.000Z","msg":"<img src=\"https://na.cx/i/vu1TVgv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fvu1TVgv.jpg&h=4114d504&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">817</span></strong></span><br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">818</span></strong></span><br />\n<br />\n以後邊個想屌人、互屌、對自己人有不滿，就望住呢堆相<br />\n<a href=\"https://lih.kg/1471935\" data-auto-link target=\"_blank\">https://lih.kg/1471935</a>"},{"pid":"e1a261094b9056ab5082e61015d0f49f181b95f6","tid":1478524,"uid":11143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:17:36.000Z","msg":"此回覆已被刪除"},{"pid":"9d70f9bcf308dc4ba388fffb797c1ba5bf56689b","tid":1478524,"uid":278524,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:19:34.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://na.cx/i/uz68KJX.png\