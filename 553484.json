sets/faces/lomoji/24.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-07T13:44:43.000Z","msg":"海關 is watching you"},"citedBy":1,"replyTime":"2018-02-07T13:45:50.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"5960f732f9aac343e0e883a1ffdcbd2c455adda9","tid":553484,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-07T13:47:20.000Z","msg":"唔用wechat pay一樣俾人監視"},{"pid":"f8c96422e63414f5569aeae6622d7f67f3ae44fc","tid":553484,"uid":24660,"like":0,"dislike":0,"score":0,"quote":{"pid":"5960f732f9aac343e0e883a1ffdcbd2c455adda9","tid":553484,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-07T13:47:20.000Z","msg":"唔用wechat pay一樣俾人監視"},"citedBy":0,"replyTime":"2018-02-07T13:47:51.000Z","msg":"We are watching you!"},{"pid":"b54c2a9ad50a399b18eb388f757a52c16d6cdb3f","tid":553484,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-07T13:52:57.000Z","msg":"Now新聞台】香港海關表示去年網上侵權案件輕微增加，已經首次使用大數據系統打擊網上侵權活動。<br />\n<br />\n海關關長鄧以海率領管理層總結過去一年工作，表示去年共偵破916宗侵犯知識產權的案件及拘捕了718人，分別增加百分之8和2。<br />\n<br />\n而網上侵權案件有202宗，輕微增加百分之0.5。涉及實體店利用網上平台售賣侵權物品的案件就有27宗，較前年上升1.7倍。<br />\n<br />\n海關表示，為了提升執法效能，去年底開始使用大數據系統，<span style=\"color: red;\">廿四小時自動瀏覽不同平台，集合海量的公開資訊。每日可分析兩萬條訊息，進行分類、篩選和比較</span>以調查網上侵權活動，已經成功破獲三宗案件。<br />\n<br />\n<br />\n<a href=\"https://www.news.now.com/home/local/player?newsId=253310\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.news.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D253310&d=xSvKWUVbscBOFdiwHL9LHAhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=2934854c\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.news.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D253310&h=bdadf1bb\" data-auto-link target=\"_blank\">https://www.news.now.com/home/local/player?newsId=253310</a>"},{"pid":"cc2a5d32e71e15776a89509ae99c4d5ef47d085f","tid":553484,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-07T13:57:47.000Z","msg":"原來咁操作：<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n這個新設系統將能24小時全自動運作監察網上不同平台：「一方面針對網上售賣無牌貨品，在不同的網上銷售及社交網平台的海量公開資訊中<span style=\"color: red;\">搜集賣家、銷售貨物的種類、品牌、價錢及潮流用語等數據，並就系統收集所得資料集成數據庫，交由後台分析軟件進行深度分析</span>，偵查出網上熱賣的侵權商品。」<br />\n<br />\n<a href=\"http://www.singpao.com.hk/index.php?fi=history&amp;id=19176\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.singpao.com.hk%2Findex.php%3Ffi%3Dhistory%26id%3D19176&d=xSvKWUVbscBOFdiwHL9LHAhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=9613c707\" data-auto-link target=\"_blank\">http://www.singpao.com.hk/index.php?fi=history&amp;id=19176</a>"},{"pid":"f742b6f62f07dddbe2edf33531b0535b3769a0b6","tid":553484,"uid":36383,"like":0,"dislike":0,"score":0,"quote":{"pid":"e430e2791da4cba7b4535c34b3aa9185284a6213","tid":553484,"uid":19454,"like":0,"dislike":0,"score":0,"quote":{"pid":"743ef7a35d6108d233038e3b5153beb1c0f254a8","tid":553484,"uid":36383,"like":1,"dislike":0,"score":1,"quote":{"pid":"2ec13cc982018bae0df6e60a1cbf697864ca0e29","tid":553484,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-02-07T13:34:30.000Z","msg":"會唔會scan游b photo?<img src=\"/assets/faces/lomoji/24.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-07T13:44:43.000Z","msg":"海關 is watching you"},"citedBy":1,"replyTime":"2018-02-07T13:45:50.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-07T13:58:00.000Z","msg":"<a href=\"http://news.rthk.hk/rthk/ch/component/k2/1293523-20161028.htm?spTabChangeable=0\" data-sr-url=\"https://r.lihkg.com/l