d8da269b7fe385b1f774017234","tid":1592351,"uid":170812,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T00:43:41.000Z","msg":"加油"},{"pid":"b63431e12c31d28bcb65755a943d62be750d53ef","tid":1592351,"uid":242349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T05:21:57.000Z","msg":"推"},{"pid":"739f95a3622efcf786388c77e4cb8e6347211719","tid":1592351,"uid":242349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T05:22:19.000Z","msg":"十連"},{"pid":"1a1580cff15822bad8c2793ec08cc63229095db2","tid":1592351,"uid":31511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T05:22:20.000Z","msg":"sorry ,幫手推<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n[文宣工作]入黎揀個宣傳方法去做！重現69吹大雞！！<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1593328\" target=\"_blank\">https://lih.kg/1593328</a><br />\n<br />\n<br />\n<span style=\"color: green;\"><strong>1.網絡宣傳+airdrop</strong></span><br />\n最易，亦都有好多巴絲做緊<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />辛苦哂<br />\n大家可以幫手post 去 fb,ig,twitter, <span style=\"color: red;\">仲有香討等各大論壇！</span>講真上得連登大部分都了解黎緊有咩活動，但仲有一大班人玩開其他論壇， 我建議可以用洗連登式洗各論壇<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<span style=\"color: green;\"><strong>2.各區連儂牆+各戶大廈𨋢口，洗樓</strong></span><br />\n連儂牆基本啦，唔洗多講，<span style=\"color: red;\">大家可以痴文宣係自己大廈𨋢口度，咁啲人等𨋢就睇到！</span> 最快靚正就痴係𨋢入邊，又或者攝係平時啲公告板入邊<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />仲可以痴𨋢門<br />\n<br />\n<br />\n<span style=\"color: green;\"><strong>3.痴各交通工具入邊</strong></span><br />\n開始有風險既一個做法，比人捉到會比人鬧，或觸犯唔知乜春例<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><br />\n可以揀d 陰濕位痴<br />\n<span style=\"color: red;\">例如番工番學準備定一兩張文宣痴好雙面膠，臨落車先痴</span><br />\n<br />\n<br />\n<span style=\"color: green;\"><strong>4.痴文宣上自己身，番工番學做流動宣傳</strong></span><br />\n難，難在恥力不足<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />一般人唔慣痴野上身比人用異目睇，不過為左香港， i do<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><br />\n<span style=\"color: red;\">可以痴係背脊或背囊，冇咁尷尬</span><br />\n<br />\n<br />\n<br />\n<span style=\"color: green;\"><strong>5. 擺街站，派傳單</strong></span><br />\n最難，但都係最有效接觸到唔同類型既人<br />\n<span style=\"color: red;\">有安全風險，最好約埋幾個一齊做，揀人流多，未入夜既時間，事半功倍</span><br />\n<br />\n<br />\n唔好睇少宣傳，多一個人做，效果雖然唔明顯，但如果多10萬個人做宣傳，個效果就好大<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n大家諗到其他方法都可以做，gogogo<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n一齊copy 去其他post 比大家睇到"},{"pid":"f175dad2639c27f6eeab889cce86d7d60698d192","tid":1592351,"uid":258069,"like":0,"dislike":0,"score":0,"quote":{"pid":"2020d643ce87dd9120f85ccf53440ea41ea4e326","tid":1592351,"uid":253016,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-24T23:59:06.000Z","msg":"哂氣 台仔最叻抽水 要真幫不了 由上到下都係咁 <br />\n<br />\n<br />\n利申:台大政棍出產地"},"citedBy":0,"replyTime":"2019-09-25T05:23:15.000Z","msg":"所以先開個組織想自救"},{"pid":"3b609e89c7762b8ebbbc0ca34dd0f4629a743b33","tid":1592351,"uid":242349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T05:23:35.000Z","msg":"1/10"},{"pid":"5f095dc0014e4571134cd927515779400cf988d9","tid":1592351,"uid":242349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T05:23:45.000Z","msg":"2/10"},{"pid":"c9f88039676054b2e71c6459fa2bf24411267831","tid":1592351,"uid":242349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T05:24:07.000Z","msg":"3/10"},{"pid":"ff2119c12b8a9863ff9979634fdc745795f19084","tid":1592351,"uid":242349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T05:24:17.000Z","msg":"4/10"},{"pid":"10137a60b71933a8d92fbdaef80d75a2b5d9207f","tid":1592351,"uid":242349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-25T05:24:29.000Z","msg":"5/10"},{"pid":"10dfef1250ca5b373175009f22025c278466fadf","tid":1592351,"uid":242349,"like":0,"d