":324629,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-10T10:58:11.000Z","msg":"&ldquo;Tatakae,tatakae&rdquo;.   -Eren Yeager(854)"},{"pid":"b61417d1a1adfcebd0a087d024847072dcbadc06","tid":2482164,"uid":297997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-10T11:03:25.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"53c760f07bec9a6e05bf3c6491ffb3239209d2c7","tid":2482164,"uid":337119,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-10T15:43:04.000Z","msg":"Hkers, Fight! ✊🏾✊🏾"},{"pid":"d50dd06c7f655cff253dadf206293ad0f0d9a9ed","tid":2482164,"uid":24814,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-04-10T15:53:51.000Z","msg":"其實黃色經濟圈係超限戰經濟戰嘅一部分<br />\n所以點解出哂力分化"},{"pid":"f307e5f48a168838c4182913f6fe597925f02936","tid":2482164,"uid":161684,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-11T02:06:01.000Z","msg":"LM"},{"pid":"b79b4603b0f4edd03bd118b28292db19179364df","tid":2482164,"uid":93986,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-11T02:29:12.000Z","msg":"支那既超限戰係指全部領域都可變戰場。<br />\n經濟，網路，外交，科技技術，軍事。<br />\n<br />\n香港人到而家只係做到網路文宣，<br />\n黃色經濟圈都仲係失敗，個個留港繼續交稅交租。<br />\n外交未有流亡海外政府<br />\n軍事，科技直程零起步"},{"pid":"0c17b0523a415bffc108f2c5c1891440a35c5d2d","tid":2482164,"uid":93986,"like":0,"dislike":0,"score":0,"quote":{"pid":"d50dd06c7f655cff253dadf206293ad0f0d9a9ed","tid":2482164,"uid":24814,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-04-10T15:53:51.000Z","msg":"其實黃色經濟圈係超限戰經濟戰嘅一部分<br />\n所以點解出哂力分化"},"citedBy":1,"replyTime":"2021-04-11T02:30:09.000Z","msg":"本土現階段冇武力backup唔會夠玩"},{"pid":"3e371a7c04763fbbf2d3a9b5b90f57760e0409b4","tid":2482164,"uid":93986,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c17b0523a415bffc108f2c5c1891440a35c5d2d","tid":2482164,"uid":93986,"like":0,"dislike":0,"score":0,"quote":{"pid":"d50dd06c7f655cff253dadf206293ad0f0d9a9ed","tid":2482164,"uid":24814,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-04-10T15:53:51.000Z","msg":"其實黃色經濟圈係超限戰經濟戰嘅一部分<br />\n所以點解出哂力分化"},"citedBy":1,"replyTime":"2021-04-11T02:30:09.000Z","msg":"本土現階段冇武力backup唔會夠玩"},"citedBy":0,"replyTime":"2021-04-11T02:31:14.000Z","msg":"唔講交稅交租，<br />\n黃店有咩事就會俾黑警海關 公墓員掃場。"}]}