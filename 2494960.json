ilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2F72HQZAIAHZHPBCAOEZ6O7MURFM.jpg&h=b7bfa98f&s={SIZE}\" /><br />\n<img src=\"https://hk.appledaily.com/resizer/LSLFxcK98z4G1YXO_BrOitNDTS4=/802x1003/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/B2E5UPEG75DLNLOHPYSS2WE5GA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FLSLFxcK98z4G1YXO_BrOitNDTS4%3D%2F802x1003%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FB2E5UPEG75DLNLOHPYSS2WE5GA.jpg&h=bd560c06&s={SIZE}\" /><br />\n<img src=\"https://hk.appledaily.com/resizer/wpgAD-23vMUxzjq-SX-lJRjUqQ8=/802x1003/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/UHIEU47HUZHGNJGH27FSDPQJNI.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FwpgAD-23vMUxzjq-SX-lJRjUqQ8%3D%2F802x1003%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FUHIEU47HUZHGNJGH27FSDPQJNI.jpg&h=de0b2dae&s={SIZE}\" /><br />\n<img src=\"https://hk.appledaily.com/resizer/88NvrRakB3KkRC7kAsycod-C2ac=/802x1154/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/D3LWPAIPKJBDBDM345OH7DB6YM.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2F88NvrRakB3KkRC7kAsycod-C2ac%3D%2F802x1154%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FD3LWPAIPKJBDBDM345OH7DB6YM.jpg&h=2a41c33f&s={SIZE}\" /><br />\n<img src=\"https://hk.appledaily.com/resizer/XtJj861F2k-2jZxxaaJWmUGE2SM=/802x1180/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/2VQRAIVJFVEGVKNAYLXJUUO2IE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FXtJj861F2k-2jZxxaaJWmUGE2SM%3D%2F802x1180%2Ffilters%3Aquality%281