479%2F%25E6%25B8%25AF%25E8%2582%25A1%25E9%2599%25B7%25E6%2581%2590%25E6%2585%258C%2B%25E6%258F%25921349%25E4%25BA%2594%25E5%25B9%25B4%25E6%259C%2580%25E5%2582%25B7&d=s%2ByQnOBpfLb1r8GSWDTSOYGitI067obQ02bu1xQE4oc%3D&h=c33fec01\" data-auto-link target=\"_blank\">https://www2.hkej.com/landing/mobArticle2/id/2473479/%E6%B8%AF%E8%82%A1%E9%99%B7%E6%81%90%E6%85%8C+%E6%8F%921349%E4%BA%94%E5%B9%B4%E6%9C%80%E5%82%B7</a>"},"citedBy":5,"replyTime":"2020-05-23T10:45:39.000Z","msg":"藍絲繼續愛黨<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-23T10:46:15.000Z","msg":"撐黨買中資<br />\n<br />\n快買內銀內險內房，支持黨！！！"},"citedBy":1,"replyTime":"2020-05-23T11:53:06.000Z","msg":"國家隊出力未<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2a97893dff574f84d14a18c838e7b112e441cc91","tid":2031352,"uid":338879,"like":1,"dislike":0,"score":1,"quote":{"pid":"f884bf506c38d3c91bb8e838c467a62e5d7fcd59","tid":2031352,"uid":354682,"like":1,"dislike":0,"score":1,"quote":{"pid":"c898041f3452494ca983080870c663aa0fb0bde9","tid":2031352,"uid":338879,"like":33,"dislike":1,"score":32,"quote":{"pid":"a012dced734327613fd762e3b97d405ff8855d72","tid":2031352,"uid":338879,"like":67,"dislike":1,"score":66,"citedBy":5,"replyTime":"2020-05-23T10:45:39.000Z","msg":"藍絲繼續愛黨<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-23T10:46:15.000Z","msg":"撐黨買中資<br />\n<br />\n快買內銀內險內房，支持黨！！！"},"citedBy":1,"replyTime":"2020-05-23T11:53:06.000Z","msg":"國家隊出力未<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime