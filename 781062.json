s=\"hkgmoji\" />"},{"pid":"fa888bb223d5eff894cb09a3dd5b8855aeeee8b5","tid":781062,"uid":36494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-15T16:27:53.000Z","msg":"陳啟宗身為建制派，一定要講睇好支國㗎喇"},{"pid":"065c116a8cd654559145056349039ce3d6749600","tid":781062,"uid":35430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-15T16:31:53.000Z","msg":"上下一心<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"3e21a2b95e4d17c6f49ab9aec1da9e0d5fed8bf5","tid":781062,"uid":95520,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-08-15T16:32:17.000Z","msg":"點止啊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n係中國都就黎變主流民意啦"},{"pid":"82b20e8b352045ee7fd3c8c1280ace9752f2ee10","tid":781062,"uid":103035,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2018-08-15T16:43:25.000Z","msg":"1) 美國人愈黎愈支持侵<br />\n2) 陳啟宗係美國人<br />\n所以，陳啟宗愈黎愈支持侵<br />\n<br />\n但係中國長遠而言一定贏<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"748213b63d400a8296cf18198ccd9e6577755b20","tid":781062,"uid":13663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-15T16:44:10.000Z","msg":"<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"f405deca8f225faafcc306823f9e1a9c34595380","tid":781062,"uid":102872,"like":0,"dislike":0,"score":0,"quote":{"pid":"3e21a2b95e4d17c6f49ab9aec1da9e0d5fed8bf5","tid":781062,"uid":95520,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-08-15T16:32:17.000Z","msg":"點止啊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n係中國都就黎變主流民意啦"},"citedBy":0,"replyTime":"2018-08-15T16:48:09.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d3448e64d6e974df2eb7f5adf3ce559b40125366","tid":781062,"uid":103035,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-08-15T16:49:28.000Z","msg":"<blockquote>1) 美國人愈黎愈支持侵<span style=\"color: red;\">，愈黎愈不支持中國</span><br />\n2) 陳啟宗係美國人<br />\n所以，陳啟宗愈黎愈支持侵<span style=\"color: red;\">，愈黎愈不支持中國</span><br />\n<br />\n但係中國長遠而言一定贏<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n漏左"},{"pid":"aa332128416dec17e79acaffb047119fca675f86","tid":781062,"uid":42764,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-15T16:50:20.000Z","msg":"中國科技人材未來會持續減少，因為少左人中學讀理科<br />\n香港直頭不斷閹割理科<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"9d66e85302d7d0761ca84f1f816b27a413c63737","tid":781062,"uid":7632,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-15T23:47:54.000Z","msg":"收番陳啟宗本美帝護照啦，咁爰国！"},{"pid":"a0c38148d09c3b94f0739fafac2558c027126887","tid":781062,"uid":58552,"like":0,"dislike":0,"score":0,"quote":{"pid":"82b20e8b352045ee7fd3c8c1280ace9752f2ee10","tid":781062,"uid":103035,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2018-08-15T16:43:25.000Z","msg":"1) 美國人愈黎愈支持侵<br />\n2) 陳啟宗係美國人<br />\n所以，陳啟宗愈黎愈支持侵<br />\n<br />\n但係中國長遠而言一定贏<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-15T23:52:07.000Z","msg":"潛在叛國者"},{"pid":"c8925bd1c5025c28a938154178cb34f81fb2123f","tid":781062,"uid":59898,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-08-15T23:54:54.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7d65ee769535ac08d468ddb5fb428cadbb4cc454","tid":781062,"uid":95138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T13:25:42.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"630e1a0750415a3874c836714d00c13f26f9b2d2","tid":781062,"uid":66943,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T13:27:07.000Z","msg":"鬼佬搞清楚 hong kong &ne; chinese plz"}]}