og/angry.gif\" class=\"hkgmoji\" />"},{"pid":"cff035b6ac95bc09f5cd5c652b5533b064577d93","tid":992780,"uid":231583,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-01-23T14:11:29.000Z","msg":"Dora Milaje J咗好多獲<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"e03f93271c0a14d1f1d01f7b00ec2ef0bb1d446f","tid":992780,"uid":60023,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-23T15:57:46.000Z","msg":"配樂 幾新鮮<br />\n其他就算鳩數"},{"pid":"175ed81aa6e525bacb9467a029b3642de38a5b67","tid":992780,"uid":105567,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-24T13:35:30.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}