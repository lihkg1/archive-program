i/wsoUXUR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwsoUXUR.jpg&h=0b080936&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-06-07T08:16:27.000Z","msg":"張圖有聲<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-07T08:17:53.000Z","msg":"停車呀, ar !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! <img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"824cd92214a615fd0e28349450eb40f129765286","tid":2054494,"uid":1886,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-07T08:18:45.000Z","msg":"部電話 mola mola"},{"pid":"d34275c990de1f51cf0d1ab7ab02a511cfa7f07a","tid":2054494,"uid":51701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-07T08:19:51.000Z","msg":"可唔可以痴晒全港<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"4f4fee4ab980ad6f024bbb817416b80de5f14324","tid":2054494,"uid":1886,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2020-06-07T08:21:27.000Z","msg":"<img src=\"https://na.cx/i/wkbO2or.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwkbO2or.gif&h=da84dccb&s={SIZE}\" />"},{"pid":"0723ccb7bedf925ced90cbb1b3e53409c1f664d7","tid":2054494,"uid":295602,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-07T08:21:41.000Z","msg":"仲可以留意多樣野<br />\n用完啲濕鳩膠水 落個雨就起晒啲磚出黎<br />\n啲膠水到底有乜撚野用"},{"pid":"fc252a56a76be00d7ba5e7221994b83d3dd5d60c","tid":2054494,"uid":205462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-07T08:22:18.000Z","msg":"班仆街乜鳩都倒落雨水渠 - 油膩嘅水，固體垃圾，再加上被雨水沖走嘅樹葉同沙泥 - 真係以為條渠唔會塞?<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"2d9f310076673dafedce91fdd3a70b9d26c7a14d","tid":2054494,"uid":11719,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-06-07T08:22:22.000Z","msg":"以前石屎地去水咪仲差，去水唔係靠雨水渠？無野揾野黎賴"},{"pid":"41fe546406b20252a5bac9438fd2154f8684429b","tid":2054494,"uid":59804,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d9f310076673dafedce91fdd3a70b9d26c7a14d","tid":2054494,"uid":11719,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-06-07T08:22:22.000Z","msg":"以前石屎地去水咪仲差，去水唔係靠雨水渠？無野揾野黎賴"},"citedBy":0,"replyTime":"2020-06-07T08:24:18.000Z","msg":"有樣野叫疏導<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e45ea9d6e3aa14e3462d32345c4bb88dd7b26b04","tid":2054494,"uid":25558,"like":0,"dislike":0,"score":0,"quote":{"pid":"735785188c383b828ced6edb201e3069d82a7987","tid":2054494,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-07T08:09:52.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/20200607/KC2GSHYCUI5PRCKVFZRKUBPH34/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20200607%2FKC2GSHYCUI5PRCKVFZRKUBPH34%2F&d=gQ7zj4J1baFceLD6a1UzUiK1%2BumEGLY4xtueqN3WuFY%3D&h=8006e73d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20200607%2FKC2GSHYCUI5PRCKVFZRKUBPH34%2F&h=cd6fa8f5\" target=\"_blank\">https://hk.news.appledaily.com/local/20200607/KC2GSHYCUI5PRCKVFZRKUBPH34/</a><br />\n<br />\n三年來首發黑雨 多區變水塘<br />\n專家：「黏合磚」加劇水浸<br />\n<br />\n【暴雨成災】<br />\n<br />\n【本報訊】一道低壓槽帶來惡劣天氣，昨凌晨全港雷雨交加，暴雨警告信號在兩個多小時內「三級跳」，黃變紅再變黑，是三年來首個黑色暴雨，傾盆大雨持續近三小時，廣泛地區水浸，道路如激流車輛死火，重災區觀塘變水塘，有小巴被淹浸，乘客頻呼「救命」要由消防員救走。多處行人路亦有大量以膠水黏合的地磚被大水沖散隆起，專家質疑「黏合地磚」阻礙磚與磚之間縫隙去水，是導致水浸加劇原因。<br />\n<br />\n記者：黃江奇 黎志偉 鄭文輝<br />\n<br />\n昨凌晨起風雲變色，天文台凌晨零時40分、1時30分及2時55分，先後發出黃色、紅色及黑色暴雨警告，為2017年5月24日以來首個黑雨。黑雨持續近三小時，在清晨。。。。。。。。過70毫米雨量，荃灣、沙田、馬鞍山、東九龍及西貢一帶更錄得約300毫米雨量，其間亦錄得超過1.4萬次閃電。至早上8時05分黃雨才取消。<br />\n<br />\n<img src=\"https://cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/BE2IGJ3Q5ZS6AHKEL6DM7J2RHU.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FBE2IGJ3Q5ZS6AHKEL6DM7J2RHU.gif&h=340ec992&s={SIZE}\" /><br />\n【觀塘】港鐵觀塘站外水深逾一米，一輛綠Van死火被困在路中心。互聯網<br />\n<br />\n黎廣德<br />\n<br />\n<img src=\"http://thumbor-prod-ap-ne-1.photo.aws.arc.pub/RM0Mg7og0UNYihCp0p4zIXOtkfo=/arc-photo-appledaily/ap-ne-1-prod/public/2HJMXQEN\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fthumbor-prod-ap-ne-1.photo.aws.arc.pub%2FRM0Mg7og0UNYihCp0p4zIXOtkfo%3D%2Farc-photo-appledaily%2Fap-ne-1-prod%2Fpublic%2F2HJMXQEN&h=dd12a481&s={SIZE}\" />P37X4VRW2S5DHMHFLM.gif<br />\n有等待救援的小巴乘客拍下車外情景，見洪水已浸過消防員的膝頭。fb圖片<br />\n<br />\n<img src=\"https://cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/SE4IGD62DGVD5AOYTVB3AEYU3Y.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FSE4IGD62DGVD5AOYTVB3AEYU3Y.gif&h=a0238b82&s={SIZE}\" /><br />\n【牛頭角】牛頭角行人路有多塊地磚隆起，專家質疑「黏合地磚」阻礙去水導致水浸加劇。江子堯攝<br />\n綠Van入水 乘客叫救命<br />\n<br />\n相關新聞：洪水湧北圍村 有狗被浸死<br />\n<br />\n滂沱大雨下多區水浸，港鐵觀塘站外的觀塘道水深逾一米，多部車輛駛經時死火被困，其中一輛綠色專線小巴半個車。。。。。。。萬分，頻呼「救命！救命！」接報消防員身纏救生繩涉水走近小巴，將乘客救出。<br />\n<br />\n洪水衝擊觀塘及牛頭角區內不少行人路，數以百計的地磚隆起，場面罕見；而隆起的地磚明顯是由多塊小地磚「黏合」而成。有居民懷疑，政府過去以阻止抗爭者擲<br />\n。。。。。。。。。。。。。去水，造成今次區內嚴重水浸。<br />\n<br />\n本報記者昨午在牛頭角地鐵站對出、近觀塘道往藍田方向的行人路所見，一段約三米長的行人路上，約百塊「黏合地磚」隆起。翠屏道近觀塘泳池對開一段約兩米乘兩米<br />\n。。。。。。。。<br />\n影響範圍，有待修補重填。另外，觀塘區議員梁翊婷在fb發佈相片，亦顯示區內有行人路出現大範圍「黏合地磚」損毀情況。<br />\n<br />\n暴雨過後，觀塘多處滿地泥濘。<br />\n<br />\n<img src=\"https://cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/4GC67SK4OQUE4MLDMKS6U263IM.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2F4GC67SK4OQUE4MLDMKS6U263IM.gif&h=2334908e&s={SIZE}\" /><br />\n本港昨錄得逾1.4萬次閃電。Wai Wai提供圖片<br />\n撞消防車 的士司機頭部受傷<br />\n<br />\n資深工程師黎廣德直言，行人路的地磚一般只有小量去水功能，主要靠磚與磚之間縫隙疏導雨水，以防止水浸。一旦磚與磚之間縫隙被膠水填封，會大大阻礙去水功能，做法不理想，相信這是暴雨下加劇水浸的原因；加上<br />\n。。。。。。。。。<br />\n及駕駛者構成危險。路政署回覆指，加固路磚行人路並不會影響公共道路的排水，雨水是透過有斜度的路面流往路旁集水溝，經地下排水渠道排走，因此不論行人路是以路磚或混凝土鋪設路面，均不會影響排水功能。<br />\n<br />\n另外，昨凌晨4時許，黑色暴雨警告生效期間，一輛消防車沿九龍灣常<br />\n。。。。。。。。<br />\n，57歲姓梅司機頭部受傷流血，安全氣袋染有大量血迹。至於消防車上一名消防車長及三名消防員均輕傷送院。"},"citedBy":1,"replyTime":"2020-06-07T08:24:54.000Z","msg":"<img src=\"https://hk.appledaily.com/resizer/ydn4Rv_dI2fwhiJE3mgv9esv6bA=/802x1557/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/2HJMXQENP37X4VRW2S5DHMHFLM.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2Fydn4Rv_dI2fwhiJE3mgv9esv6bA%3D%2F802x1557%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2F2HJMXQENP37X4VRW2S5DHMHFLM.gif&h=c9c730d6&s={SIZE}\" />"},{"pid":"13f4f2dccd8e783d26104bc93f626cc2b1a90119","tid":2054494,"uid":25558,"like":0,"dislike":0,"score":0,"quote":{"pid":"e45ea9d6e3aa14e3462d32345c4bb88dd7b26b04","tid":2054494,"uid":25558,"like":0,"dislike":0,"score":0,"quote":{"pid":"735785188c383b828ced6edb201e3069d82a7987","tid":2054494,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-07T08:09:52.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/20200607/KC2GSHYCUI5PRCKVFZRKUBPH34/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20200607%2FKC2GSHYCUI5PRCKVFZRKUBPH34%2F&d=gQ7zj4J1baFceLD6a1UzUiK1%2BumEGLY4xtueqN3WuFY%3D&h=8006e73d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20200607%2FKC2GSHYCUI5PRCKVFZRKUBPH34%2F&h=cd6fa8f5\" target=\"_blank\">https://hk.news.appledaily.com/local/20200607/KC2GSHYCUI5PRCKVFZRKUBPH34/</a><br />\n<br />\n三年來首發黑雨 多區變水塘<br />\n專家：「黏合磚」加劇水浸<br />\n<br />\n【暴雨成災】<br />\n<br />\n【本報訊】一道低壓槽帶來惡劣天氣，昨凌晨全港雷雨交加，暴雨警告信號在兩個多小時內「三級跳」，黃變紅再變黑，是三年來首個黑色暴雨，傾盆大雨持續近三小時，廣泛地區水浸，道路如激流車輛死火，重災區觀塘變水塘，有小巴被淹浸，乘客頻呼「救命」要由消防員救走。多處行人路亦有大量以膠水黏合的地磚被大水沖散隆起，專家質疑「黏合地磚」阻礙磚與磚之間縫隙去水，是導致水浸加劇原因。<br />\n<br />\n記者：黃江奇 黎志偉 鄭文輝<br />\n<br />\n昨凌晨起風雲變色，天文台凌晨零時40分、1時30分及2時55分，先後發出黃色、紅色及黑色暴雨警告，為2017年5月24日以來首個黑雨。黑雨持續近三小時，在清晨。。。。。。。。過70毫米雨量，荃灣、沙田、馬鞍山、東九龍及西貢一帶更錄得約300毫米雨量，其間亦錄得超過1.4萬次閃電。至早上8時05分黃雨才取消。<br />\n<br />\n<img src=\"https://cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/BE2IGJ3Q5ZS6AHKEL6DM7J2RHU.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FBE2IGJ3Q5ZS6AHKEL6DM7J2RHU.gif&h=340ec992&s={SIZE}\" /><br />\n【觀塘】港鐵觀塘站外水深逾一米，一輛綠Van死火被困在路中心。互聯網<br />\n<br />\n黎廣德<br />\n<br />\n<img src=\"http://thumbor-prod-ap-ne-1.photo.aws.arc.pub/RM0Mg7og0UNYihCp0p4zIXOtkfo=/arc-photo-appledaily/ap-ne-1-prod/public/2HJMXQEN\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fthumbor-prod-ap-ne-1.photo.aws.arc.pub%2FRM0Mg7og0UNYihCp0p4zIXOtkfo%3D%2Farc-photo-appledaily%2Fap-ne-1-prod%2Fpublic%2F2HJMXQEN&h=dd12a481&s={SIZE}\" />P37X4VRW2S5DHMHFLM.gif<br />\n有等待救援的小巴乘客拍下車外情景，見洪水已浸過消防員的膝頭。fb圖片<br />\n<br />\n<img src=\"https://cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/SE4IGD62DGVD5AOYTVB3AEYU3Y.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FSE4IGD62DGVD5AOYTVB3AEYU3Y.gif&h=a0238b82&s={SIZE}\" /><br />\n【牛頭角】牛頭角行人路有多塊地磚隆起，專家質疑「黏合地磚」阻礙去水導致水浸加劇。江子堯攝<br />\n綠Van入水 乘客叫救命<br />\n<br />\n相關新聞：洪水湧北圍村 有狗被浸死<br />\n<br />\n滂沱大雨下多區水浸，港鐵觀塘站外的觀塘道水深逾一米，多部車輛駛經時死火被困，其中一輛綠色專線小巴半個車。。。。。。。萬分，頻呼「救命！救命！」接報消防員身纏救生繩涉水走近小巴，將乘客救出。<br />\n<br />\n洪水衝擊觀塘及牛頭角區內不少行人路，數以百計的地磚隆起，場面罕見；而隆起的地磚明顯是由多塊小地磚「黏合」而成。有居民懷疑，政府過去以阻止抗爭者擲<br />\n。。。。。。。。。。。。。去水，造成今次區內嚴重水浸。<br />\n<br />\n本報記者昨午在牛頭角地鐵站對出、近觀塘道往藍田方向的行人路所見，一段約三米長的行人路上，約百塊「黏合地磚」隆起。翠屏道近觀塘泳池對開一段約兩米乘兩米<br />\n。。。。。。。。<br />\n影響範圍，有待修補重填。另外，觀塘區議員梁翊婷在fb發佈相片，亦顯示區內有行人路出現大範圍「黏合地磚」損毀情況。<br />\n<br />\n暴雨過後，觀塘多處滿地泥濘。<br />\n<br />\n<img src=\"https://cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/4GC67SK4OQUE4MLDMKS6U263IM.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2F4GC67SK4OQUE4MLDMKS6U263IM.gif&h=2334908e&s={SIZE}\" /><br />\n本港昨錄得逾1.4萬次閃電。Wai Wai提供圖片<br />\n撞消防車 的士司機頭部受傷<br />\n<br />\n資深工程師黎廣德直言，行人路的地磚一般只有小量去水功能，主要靠磚與磚之間縫隙疏導雨水，以防止水浸。一旦磚與磚之間縫隙被膠水填封，會大大阻礙去水功能，做法不理想，相信這是暴雨下加劇水浸的原因；加上<br />\n。。。。。。。。。<br />\n及駕駛者構成危險。路政署回覆指，加固路磚行人路並不會影響公共道路的排水，雨水是透過有斜度的路面流往路旁集水溝，經地下排水渠道排走，因此不論行人路是以路磚或混凝土鋪設路面，均不會影響排水功能。<br />\n<br />\n另外，昨凌晨4時許，黑色暴雨警告生效期間，一輛消防車沿九龍灣常<br />\n。。。。。。。。<br />\n，57歲姓梅司機頭部受傷流血，安全氣袋染有大量血迹。至於消防車上一名消防車長及三名消防員均輕傷送院。"},"citedBy":1,"replyTime":"2020-06-07T08:24:54.000Z","msg":"<img src=\"https://hk.appledaily.com/resizer/ydn4Rv_dI2fwhiJE3mgv9esv6bA=/802x1557/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/2HJMXQENP37X4VRW2S5DHMHFLM.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2Fydn4Rv_dI2fwhiJE3mgv9esv6bA%3D%2F802x1557%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2F2HJMXQENP37X4VRW2S5DHMHFLM.gif&h=c9c730d6&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-06-07T08:25:53.000Z","msg":"有等待救援的小巴乘客拍下車外情景，見洪水已浸過消防員的膝頭。fb圖片"},{"pid":"7c278594ff3c082ec6cd20fb9805844e6717e664","tid":2054494,"uid":346701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-07T08:27:16.000Z","msg":"係唔係可以搵公正行<br />\n然後有咩損失全部claim尻政府?<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" /><br />\n唔認數就上庭告柒佢<img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" />"},{"pid":"a5522587b0f22abb3076866ebda2347215236897","tid":2054494,"uid":269481,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-07T08:52:29.000Z","msg":"諗住痴實啲磚唔俾人撬磚結果爆晒出黎撬都唔駛撬，呢個政府真係一撚流<img src=\"/assets/faces/lm2/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/good.gif\" class=\"hkgmoji\" />"},{"pid":"2f04a70b0297011738f31878372a69da7362d3e1","tid":2054494,"uid":213877,"like":0,"dislike":0,"score":0,"quote":{"pid":"a5522587b0f22abb3076866ebda2347215236897","tid":2054494,"uid":269481,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-07T08:52:29.000Z","msg":"諗住痴實啲磚唔俾人撬磚結果爆晒出黎撬都唔駛撬，呢個政府真係一撚流<img src=\"/assets/faces/lm2/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-07T09:08:54.000Z","msg":"最慘咪又係住果頭既市民<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"}]}