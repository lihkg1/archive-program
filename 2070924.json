"pid":"d1b79eda5879c4f32ab36e255e53c704d5fe2955","tid":2070924,"uid":295230,"like":0,"dislike":0,"score":0,"quote":{"pid":"6be40689cf262f5c492e2be8a52841c0d4097f27","tid":2070924,"uid":169112,"like":0,"dislike":0,"score":0,"quote":{"pid":"c3398168f7f5b3fdd95e3f641107b8a156dc79bd","tid":2070924,"uid":295230,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-19T12:52:28.000Z","msg":"點解只得人類可以踢波其他動物唔可以，歧視其他物種可恥"},"citedBy":1,"replyTime":"2020-06-19T13:37:43.000Z","msg":"你講的物種 包唔包括外星人"},"citedBy":0,"replyTime":"2020-06-19T23:28:40.000Z","msg":"yes<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}