F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F03%2F22%2F195311_9441606ceb640aa99ec3c03eee1034b6.jpg&h=81ca927a&s={SIZE}\" /><img src=\"https://na.cx/i/252K5QO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F252K5QO.jpg&h=136590c5&s={SIZE}\" />"},{"pid":"8bfb901346b6dcd98a9812ae25819065dc68896a","tid":166802,"uid":32723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-22T11:53:39.000Z","msg":"唉<br />\n<br />\n為有轉食其他野"},{"pid":"b85479cc2d55aa78b7d9393da8df48e3cf23b365","tid":166802,"uid":11977,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-03-22T12:02:16.000Z","msg":"你條撚樣食屎咪啱"},{"pid":"a77b93d182574221a310e1894bbab1c9d0c2a301","tid":166802,"uid":44243,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-22T12:04:49.000Z","msg":"你老婆大派用場"},{"pid":"54b9bc89e0b5d2a730499efd56398b7b5962d05e","tid":166802,"uid":74171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-22T12:07:01.000Z","msg":"去大快活食叉燒飯啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7ad36694369caf02d9527fa53942d4210aad0d46","tid":166802,"uid":34498,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-03-22T12:08:08.000Z","msg":"我補充番少少野。<br />\n<br />\n大家樂而家最抵食既得一隻，叫上海骨菜飯，有豬扒幾舊，炸到酥，跟涼菜、半隻鹵強同菜飯，先29蚊。<br />\n而焗豬呢都要叫得有技巧，唔係乜lan野時候都叫得，你一定要見佢個牌寫成呎長焗豬先叫得，唔係中伏！<br />\n<br />\n拿，大家樂唔可以成日加價，所以佢d野食質素同果期既食材來價有關！<br />\n如果果期d冰凍豬扒平，佢就會入d大大件成個飯盒咁長，而且有1.748cm厚既豬扒。入左筍野佢地當然唔會放過晒命機會，所以個牌就會寫「成呎長一哥焗豬扒飯」！<br />\n<br />\n如果果期d豬扒來價略貴，佢就會縮lan左成呎長幾隻字，淨係寫「一哥焗豬」！咁你叫時就要心中有數了！<br />\n<br />\n如果果期連一哥兩隻字都冇埋，變成乜lan野鴛鴦焗飯，雞球併豬扒之類咁，就係果期豬扒來貨好貴，佢就整d垃圾出黎頂檔，07年～08年就發生過，一唔小心就中伏！！<br />\n<br />\n不過大家唔駛驚會中伏，其實呢d係有路捉既，果期你上美國芝加哥期貨交易所個網睇豬肉期貨既價，如果巴西豬肉期貨價大跌就係準備有成呎長豬扒既時候了！ <br />\n下次叫上海骨飯啦，唔跟野飲29蚊，睇師傅手神，有時會整5～6舊細扒入去，仲有一盒仔涼菜，係炸菜青瓜果d，仲有半隻鹵強，而跟飯有盒仔調味醬油，本來係撈涼菜既，但涼菜既夠味，就咁倒落菜飯到撈更香口。鍾意既加多杯佢地既即磨咖啡，以平價啡黎講算十分香口澴滑，+4蚊抵飲！"},{"pid":"4b75f8b05e304162585d2e76a209e3c262e84e05","tid":166802,"uid":1558,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-03-22T13:10:07.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">屌你老母，想食豬扒食你老婆咪得囉，過主啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> </span></span>"},{"pid":"d6294b4544e83b16155ee8521216a62dd407a0bb","tid":166802,"uid":16960,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-22T13:12:40.000Z","msg":"<blockquote><span style=\"font-size: xx-large;\"><span style=\"color: red;\">屌你老母，想食豬扒食你老婆咪得囉，過主啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> </span></span></blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"04257b7a8753214d6212626989c95e75922ad90c","tid":166802,"uid":92783,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-22T13:13:59.000Z","msg":"<blockquote><span style=\"font-size: xx-large;\"><span style=\"color: red;\">屌你老母，想食豬扒食你老婆咪得囉，過主啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> </span></span></blockquote><br />\n笑到咳<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e9df55a56e66f4d7351b4a1d021b62d196a68b4e","tid":166802,"uid":14509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-22T14:05:38.000Z","msg":"食屎囉撚屌"},{"pid":"9bc15cc4017b25260b383204ba6d1816163a5b47","tid":166802,"uid":12628,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-22T14:40:45.000Z","msg":"我依家廿年嘅焗豬無左，我人生點算呀！<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> 世界末日喇"},{"pid":"4e6ed3ceedf5a482386a23c4fd77149cd9a67f3f","tid":166802,"uid":30991,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-22T14:41:24.000Z","msg":"去大家食<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ee51ee885d4ab7013b2287137b453885dd194e5f","tid":166802,"uid":21423,"like":0,"dis