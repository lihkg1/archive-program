\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c076c3788a1b290fc36081f591c41eed352c39d1","tid":1926800,"uid":46464,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T05:08:23.000Z","msg":"又撚<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"c944c0bc967d6097085a108a6ef8c4df9cb021e2","tid":1926800,"uid":25468,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-16T05:28:41.000Z","msg":"<img src=\"https://upload.cc/i1/2020/03/16/XJbzvf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2020%2F03%2F16%2FXJbzvf.png&h=2bab1325&s={SIZE}\" />"},{"pid":"5013db82476cf4d4683aa7c9a75ece544bb6aa4a","tid":1926800,"uid":58335,"like":0,"dislike":0,"score":0,"quote":{"pid":"428f9dbb5d23aafc4e943bd7623399faeb105fba","tid":1926800,"uid":25468,"like":8,"dislike":0,"score":8,"citedBy":2,"replyTime":"2020-03-15T10:51:16.000Z","msg":"中興2017 年簽果份投降書 , 連向非洲國家行賄都可以管埋 , CLS <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-16T05:31:15.000Z","msg":"唔係咩叫世界警察<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dfcb485a8df1a08fb751742a7b7f4746137ff834","tid":1926800,"uid":119232,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T05:33:54.000Z","msg":"中共唔救佢<br />\n係咪因為出賣華為<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"90c9adc4e68235b123c1f55021754437f021378b","tid":1926800,"uid":165683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T05:34:45.000Z","msg":"Push"},{"pid":"5399c29a485f0ba2cd4fa3f37b96feebdb3993ec","tid":1926800,"uid":144626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T05:43:37.000Z","msg":"用何志平呢招砌支那國企, 高明"},{"pid":"0c33480943300f0bc5e811a758db810bf9e239af","tid":1926800,"uid":144626,"like":0,"dislike":0,"score":0,"quote":{"pid":"a96eafcbcedfd1089f7c1f7e45d093d86315e319","tid":1926800,"uid":25468,"like":0,"dislike":0,"score":0,"quote":{"pid":"5e26be745b9972cce4026183604467cf7e40dfe9","tid":1926800,"uid":236646,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-15T12:24:42.000Z","msg":"中興又可以大跌股價"},"citedBy":2,"replyTime":"2020-03-16T04:25:57.000Z","msg":"今日跌左20%"},"citedBy":0,"replyTime":"2020-03-16T05:45:14.000Z","msg":"今日喺支股跌停板"},{"pid":"3756aac1c3991eb6260fc99bfcc730814b487feb","tid":1926800,"uid":25468,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-16T06:50:18.000Z","msg":"<span style=\"font-size: xx-large;\"><strong>中興通訊澄清未收到美國政府調查通知 股價續挫</strong></span><br />\n<br />\n市傳中興通訊(00763)正被美國司法部調查，周一(16)股價急瀉兩成。中興中午公布，董事會注意到近期新聞報道中，針對公司歷史上已經公開報道過的事項涉嫌賄賂進行調查。公司特此澄清，未收到美國政府相關部門就此事項的通知，會與美國政府相關部門積極溝通，如有應披露事項，會及時披露。公司完全致力於履行法律和合規義務。<br />\n<br />\n該公司指，領導團隊的首要任務，是使公司成為全球市場上值得信賴和可信賴的業務合作夥伴。公司目前生產經營活動一切正常。公司提醒投資者，公司所有信息均以公司在其網站以及聯交所和深圳證券交易所網站上發布的信息爲准，請廣大投資者理性投資，注意風險。<br />\n<br />\n中興股價低開6.4%跌幅擴大，最多挫21.6%，低見24.3港元；午後維持約19%跌幅，暫企25元水平。至於其A股(000063.SZ)則跌停板。<br />\n<br />\n據外電報道，美國司法部正調查中興或涉嫌賄賂外國官員，以獲取在國際市場業務優勢。相關調查涉及可能違返《美國海外反腐敗法》。中興過往曾被指違反美國對伊朗及北韓的制裁令。"}]}