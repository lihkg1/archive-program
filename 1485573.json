/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"1d0ee516b006ef837d83be422e8f52e500dd8ec9","tid":1485573,"uid":214952,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-18T16:22:03.000Z","msg":"大家都係緊張有人會有事受傷<br />\n有啲語氣係重左 但記住我地都仲係同一條船<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f4048aa22f6044a48b97c61cbf13cb5d06a826c2","tid":1485573,"uid":23094,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:22:05.000Z","msg":"<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"2ad67c70c632fd177d05cac4a3c19ab7c5cdcfe6","tid":1485573,"uid":20262,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-08-18T16:22:19.000Z","msg":"好多個夜晚，真係要睇住你地前線散，<br />\n我先安心訓"},{"pid":"1892d612a9505b5180e8de171d04c6821984cca9","tid":1485573,"uid":23094,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:23:29.000Z","msg":"<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"fec26b0b589f06eb356c9e9ef43a679557402d1b","tid":1485573,"uid":53172,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:24:04.000Z","msg":"係時候諗下一步文宣"},{"pid":"99d9dbd4d972d6d0f888622719df47bd3f3976f6","tid":1485573,"uid":16488,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-18T16:24:07.000Z","msg":"咁道歉未<br />\n咁多人捉鬼無人道歉"},{"pid":"25f275f92f744f0e209aedfd356e210a4b9dedb5","tid":1485573,"uid":5967,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:24:19.000Z","msg":"咩講過辜負170萬人心血既人<br />\n<br />\n你好好諗下自己講過乜"},{"pid":"bcc6d43b418365079c4327bdaadb4fc666be6af6","tid":1485573,"uid":25825,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:24:36.000Z","msg":"Yes"},{"pid":"7a49dafd4e510ae0c5a4883774b8d5d023f2e1ce","tid":1485573,"uid":53803,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:24:40.000Z","msg":"其實現場好多都知要走<br />\n但好多mk仔係橋上唔知做乜<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/fac