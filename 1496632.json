c=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwUD4x9z.png&h=426eab8d&s={SIZE}\" /><br />\n點解釋？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"a5b1ea830e6969eac1aa18171ea1d1d743697718","tid":1496632,"uid":67840,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2019-08-23T03:22:50.000Z","msg":"丁子高你都係算鳩數啦<br />\n搵人打篇咁既野就諗住幫你老婆洗白<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6fd1c8910ac5f1d5f44e2ac9807c7a75d7273827","tid":1496632,"uid":179782,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-08-23T03:26:19.000Z","msg":"見到&quot;因為佢喺好多人心目中都好醒好有智慧&quot;呢句已經唔想睇落去"},{"pid":"d6af793ce680161f547b4c81a679f2b116e19b0d","tid":1496632,"uid":67840,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-23T03:29:42.000Z","msg":"<blockquote><br />\n<br />\n🙅🏼&zwj;♀ *聲明非港獨=/=背叛香港*<br />\n我希望大家可以公道少少，而家五大訴求入面，冇一個係港獨！千嬅份聲明，都係澄清「我不是港獨，承認香港是中國不可分割的一部份」我唔想大家不分黑白，佢冇撐警，佢冇做護旗手，佢只係好簡單地想維護返自己被污蔑左嘅名聲。<br />\n</blockquote><br />\n剩係呢點已經夠晒on9啦，你回應唔係港獨ok，但好地地加埋d咩「我生於中國香港」「大家都是中國人」真係好撚肉酸，仲話自己唔係瀨共？算鳩數啦丁子高"},{"pid":"a6fddd56b04c10635489ee454aed38b412880ca6","tid":1496632,"uid":13543,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2019-08-23T03:31:01.000Z","msg":"on9<br />\n收皮啦人瑞"},{"pid":"a9841dc3921259b1cea8cdba1b9bd02f3e81195a","tid":1496632,"uid":253223,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-23T03:32:06.000Z","msg":"不願意 完<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"a895a95d8a607c5bc74966dbcfb5bff43a3ab208","tid":1496632,"uid":48124,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-08-23T03:42:11.000Z","msg":"全文重點：人民幣大於一切"},{"pid":"72cf6928413644739ff74a2d96ce93638bd33865","tid":1496632,"uid":43678,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2019-08-23T03:44:53.000Z","msg":"睇都廢鳩事<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"c2d73a7c0e9da5c9d3b07d83815266112cdf4748","tid":1496632,"uid":238013,"like":