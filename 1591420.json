elete 佢, 成鬼日fake news"},{"pid":"120c638622ff59bdd5dff22fc8abcf4c1a5067a5","tid":1591420,"uid":254383,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-24T12:42:49.000Z","msg":"大穫了"},{"pid":"c299b6babbe091c45ea6619009503dc90d8cfe3d","tid":1591420,"uid":35776,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-24T16:54:36.000Z","msg":"侵侵正式開口<img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://m.facebook.com/story.php?story_fbid=133128714696586&amp;id=110776013598523\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2Fstory.php%3Fstory_fbid%3D133128714696586%26id%3D110776013598523&d=CxVPqDM3fecqSGKEY7rAqAy1DEY80m5I9K8mtjxpzv8%3D&h=31a1cad3\" data-auto-link target=\"_blank\">https://m.facebook.com/story.php?story_fbid=133128714696586&amp;id=110776013598523</a>"}]}