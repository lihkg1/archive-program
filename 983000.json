ji\" />"},{"pid":"f5d0df04c2cde33e2dda62a7819a8ba03bd7d411","tid":983000,"uid":2507,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-17T06:38:49.000Z","msg":"洗定patpat入去坐啦<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"e2a3a004a79542253a65ce46edfc53274ce496a6","tid":983000,"uid":51620,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-17T06:40:26.000Z","msg":"<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"d9b2ab890f955475350eaa1c8debc7502e3d89d2","tid":983000,"uid":39889,"like":0,"dislike":2,"score":-2,"quote":{"pid":"51c6612e68e8ed9a0b1b28f4e4c4f3fdc0cabde9","tid":983000,"uid":53959,"like":1,"dislike":0,"score":1,"quote":{"pid":"5b18d3a0769ad587a75212790fcbe9687b8cfb28","tid":983000,"uid":172844,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-01-16T18:54:00.000Z","msg":"乜咁戇鳩嘅咩<br />\n要半年後先拎得返<br />\nD緊要證件都一早整好<br />\n半年後比返我做咩<br />\n其實點解要咁做"},"citedBy":1,"replyTime":"2019-01-16T19:00:12.000Z","msg":"用黎做上庭做證物<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-17T06:53:17.000Z","msg":"咁想問下唔見銀包報警有咩用<br />\n搵番d證件/卡都要hold 起半年<br />\n都係要自由重新拎過<br />\n同唔見哂有咩分別<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d51cc9efe8b8c7581f5ebb9889ff06259ab52bff","tid":983000,"uid":52817,"like":9,"dislike":6,"score":3,"citedBy":1,"replyTime":"2019-01-17T07:01:54.000Z","msg":"等我翻譯啦！<br />\n樓主半年前跌左個銀包，銀包俾個清潔叔叔執左私有，點知個清潔叔叔又on99俾差佬捉到佢執人銀包私有化，即係當偷野。因為個清潔叔叔連銀包入面個身份証都冇丟，所以差佬就搵到樓主叫佢黎落口供，點知落完口供個銀包要當做證物要半年先拎得番。<br />\n<br />\n（譯者估計：落口供過程差佬應該問過樓主要唔要告個清潔叔叔，樓主堅持要告，所以先會落簿，個銀包先會當證物冇得拎番。）<br />\n<br />\n於是樓主就當自己冇左個銀包算鳩數。點知要樓主上庭作證告鳩清潔叔叔果陣，樓主就嫌麻煩唔想理佢，而家好驚俾法庭通緝。"},{"pid":"c5536eed8ea0d93e323c6f794e19b0afb0e40425","tid":983000,"uid":140769,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-17T07:08:30.000Z","msg":"此回覆已被刪除"},{"pid":"cf74c0f109717dae251fa681a76301570beea5d4","tid":983000,"uid":75993,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-01-17T07:15:10.000Z","msg":"即係樓主一方面想法庭保障佢<br />\n一方面又唔想盡義務去做証人"},{"pid":"8fa55592da2bdf3e9d4dc92546e3677dc9daf3bf","tid":983000,"uid":140769,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-01-17T07:17:29.000Z","msg":"此回覆已被刪除"},{"pid":"ace215dba8b974ba765bd65c92bb9aad84f549b5","tid":983000,"uid":46933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-17T07:19:10.000Z","msg":"淨係依個post都夠做你<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1729ea2b609e6f35355ea6df6b1606d0e9619fc9","tid":983000,"uid":14737,"like":0,"dislike":1,"score":-1,"quote":{"pid":"c5536eed8ea0d93e323c6f794e19b0afb0e40425","tid":983000,"uid":140769,"like":0,"dislike":0,"score":0,"quote":{"pid":"69e76c6cc1af575e6fd63998d8aa67930f1624f1","tid":983000,"uid":14737,"like":2,"dislike":3,"score":-1,"citedBy":1,"replyTime":"2019-01-17T06:06:45.000Z","msg":"身份證冇掉, 如果個清潔想偷錢都唔會keep個銀包係身啦<br />\n<br />\n當時直接話自己跌咗銀包, 個清潔係幫你執返, 不過自己唔得閒唔記得拎咪得<br />\n<br />\n以香港黑警咁撚懶嘅工作態度, 分分鐘即刻close file"},"citedBy":1,"replyTime":"2019-01-17T07:08:30.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-01-17T07:23:27.000Z","msg":"係嘅你啱, 如果真係賊, 我梗係同意點都出庭頂死佢啦, 我都係話如果佢唔係偷錢先咁做o者<br />\n<br />\n樓主篇野冇寫有冇唔見錢, 剩係講垃圾佬俾差佬周到身上有個唔屬於佢嘅銀包, 你當自己係垃圾佬, 執到銀包會唔會即刻野都唔做拎去差館先? 如果想偷錢, 執咗錢就掉咗個銀包啦<br />\n<br />\n至於假口供, 我前面係柒嘅我認, 咁同差佬講, &quot;而家銀包入面冇少到錢冇任何損失, 我相信係清潔叔叔做野發現到執起, 唔係偷我錢&quot; 咁得喇掛? 如果講到咁, 差佬都照落charge, 要上庭咁算係公民責任, 咁咪上囉"},{"pid":"965e952cd714f86f3c15b352e16d6a3371bd8b9c","tid":983000,"uid":50154,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-17T07:24:52.000Z","msg":"半威脅你？執法部門提醒你會比司法部門處分咋啵<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"3ee5e0a02638457fd4fb5d87e50d0a1db540b464","tid":983000,"uid":150959,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-17T07:34:03.000Z","msg":"屌你講乜撚野 小學未畢業？"}]}