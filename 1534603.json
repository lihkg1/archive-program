468e544f8a7001c","tid":1534603,"uid":306592,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-09-03T05:09:43.000Z","msg":"我就係其中一個"},"citedBy":3,"replyTime":"2019-09-03T05:39:51.000Z","msg":"今年year1已經冇返兩日"},{"pid":"b637b73743d0958cc3b59f20bd9ab953d81c9456","tid":1534603,"uid":303772,"like":0,"dislike":0,"score":0,"quote":{"pid":"b7b5737f428b8eb15fd70120af601d26783e714a","tid":1534603,"uid":316697,"like":1,"dislike":0,"score":1,"quote":{"pid":"779aff164f525c50009e7f1ad468e544f8a7001c","tid":1534603,"uid":306592,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-09-03T05:09:43.000Z","msg":"我就係其中一個"},"citedBy":3,"replyTime":"2019-09-03T05:39:51.000Z","msg":"今年year1已經冇返兩日"},"citedBy":0,"replyTime":"2019-09-03T05:42:46.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"ad430e83131dec75b2292121b9c1e191e3da0df3","tid":1534603,"uid":289649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T05:43:09.000Z","msg":"明白大家呢排嘅士氣經過<span style=\"font-size: xx-large;\"><span style=\"color: red;\">831恐襲</span></span>同<span style=\"font-size: xx-large;\"><span style=\"color: blue;\">901大撤退</span></span>之後好低落<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><br />\n我同大家一樣都係<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n但越係呢啲時候<br />\n<span style=\"font-size: x-large;\">我地就越要堅持下去，<span style=\"color: limegreen;\">團結一致</span></span><br />\n唔好比林鄭見我地冇士氣而去捉多啲人<br />\n<br />\n以下兩篇文章<span style=\"font-size: x-large;\">無論<span style=\"color: gold;\">和理非</span>，定係<span style=\"color: red;\">勇武</span>，都應該入黎，打返枝<span style=\"color: violet;\">強心針</span></span><br />\n<br />\n希望可以幫到大家<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><br />\n記得share比身邊因近日事件而唔開心嘅朋友仔<img src=\"/assets/faces/dog/on_hold.gif\" class=\"hkgmoji\" /><br />\n<br />\n［全部人同我入黎］《致眾表》望各位香港市民出自己的一份綿力<br />\n<a href=\"https://lih.kg/1532967\" data-auto-