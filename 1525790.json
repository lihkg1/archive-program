/pig/angry.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/xQ6rr7H.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxQ6rr7H.gif&h=2e882f27&s={SIZE}\" /><br />\n<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"4aee7d41f51e56a025991fce40c846f70ce2719e","tid":1525790,"uid":32140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T08:23:29.000Z","msg":"for Hongkonger's future!!!pish<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"3ace88857eab8bd5e3ff636978efcc3a897bf985","tid":1525790,"uid":314245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T09:35:26.000Z","msg":"香港人永存<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f1c972a4240e41d13e0c41972fda90f8bc334059","tid":1525790,"uid":255486,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-01T10:00:05.000Z","msg":"洋紫荊要戰勝歸來version 3 (lyrics&amp;music) 推到有人唱<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1527117\" data-auto-link target=\"_blank\">https://lih.kg/1527117</a><br />\n<a href=\"https://youtu.be/U9EEdDhnK1U\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FU9EEdDhnK1U&d=LDhKEJhCApGKQi337qR8byEyVFbloTKGHdwbQdNTMZo%3D&h=6f7def85\" data-auto-link target=\"_blank\">https://youtu.be/U9EEdDhnK1U</a><br />\n洋紫荊要戰勝歸來2019 version3<br />\n<br />\n人潮浪，默含淚光衝上街道。<br />\n單眼晴，觀看道德操守殞宕。<br />\n紅日裡，法治藏在警察背後。<br />\n誰願意，任那官商警黑放蕩？<br />\n<br />\n萬劫不改的眼光，無懼噤聲監控狂，用盡四海的筆告狀。<br />\n勇武抗強權和暴政，護手足成為煉鋼，為我家，佢捨身去闖。<br />\n<br />\n催淚煙，老人細蚊街坊中伏。<br />\n黑社會，刀捅棍扑筋斷惡毒。<br />\n無號碼，市民如何追究責任？<br />\n誰又信，實彈真槍能蓋憤怒？<br />\n<br />\n萬眾聲討這惡邦，重建法規真香港，和暴戾黑警對望。<br />\n黑警在悠悠長夜裏，習慣掃射如納粹，忘掉地獄的火，有多燙。<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n後冇方舟渡你跨惡海<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，應五大訴求。<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n還我普選還我真民主<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，應五大訴求。<br />\n<br />\n看那身軀鮮血淌，拿著雨遮抗滅亡，用血書向天主告狀。<br />\n勇武樹和平旗幟，護我香港為後世，無後退，決心反送中。<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n後冇方舟渡你跨惡海<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，應五大訴求。<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n還我普選還我真民主<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，應五大訴求。<br />\n<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n共建香港法規不變改<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，與生命同在。<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n共建香港法規不變改<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，與生命同在。<br />\n<br />\n要自由，與公義常在"},{"pid":"0b95cee61debb00fa9b7fdb6692436fe19f9de45","tid":1525790,"uid":255486,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ee26d01eaa3869c822e85c49135bced40651f92","tid":1525790,"uid":142896,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-09-01T03:00:18.000Z","msg":"開呢個ｐｏｓｔ係想招募人一齊成立一個<span style=\"color: orange;\"><strong>宣揚香港文化同精神既娛樂文化團體</strong></span><br />\n<br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: red;\">今日開始，我地要令全世界係學粵語而唔係普通話；學繁體字而唔係簡體字；學真正中國歷史同真正百家思想而唔係上虛偽既孔子學院。</span></strong></span><br />\n<br />\n<span style=\"font-size: large;\"><ins><strong><span style=\"color: red;\">大家要知道，保護我地民族，必須先保護我地自己既語言同文字，</span></strong></ins></span>先可以保護到自身既文化同民族精神。舉個例，猶太人。佢地即使經歷二千年既逼害同逃亡，至今「猶太人」一詞，仍然長存。猶太人就算身在何方，都一定會學習希伯來文，並嚴謹遵守猶太教既教條，所以，你見到猶太人點解仲可以保留共民族名字，正因佢地身上，猶太人既一切，都完整保留著。<br />\n再睇下港女最愛既韓國，韓國政府支助當地娛樂公司事業同藝術發展，唔講文藝果邊，剩係講韓星同k-pop，大家有目共賭，K-pop個youtube view數同多國music有得揮，多人因而學韓文，學韓式打扮，食韓國野。<br />\n回想我地有哥哥梅豔芬四大天王李小龍既年代，對亞洲甚至全球影響有幾大？同樣道理，可見「明星」同「音樂文化」係有幾大影響力，當你既民族／國家有一個具影響力既文化時，就會有世界既注目，留意你既一切同想學習你既文化，<ins><strong><span style=\"font-size: large;\"><span style=\"color: red;\">甚至你既政治</span></span></strong></ins>。<br />\n<br />\n同時，大家見到，感受到，呢十年來，本地音樂慢慢失去支持，香港人慢慢聽少左廣東歌，睇少左粵語劇，個個都娘娘上身宮廷劇上身，真正既中國文化歷史呢？我睇，以為唔會再有電視劇敢提。<br />\n唔多講，明既人其實呢一刻已經有共鳴，我係度誠邀各位，不論你係學生，做緊野；不論你係做拍劇定音樂定跳舞甚至時裝，非常歡迎你加入。<br />\n<br />\n<strong>當然，金主都非常歡迎！</strong><span style=\"font-size: large;\"></span><br />\n「<span style=\"color: pink;\">我希望，以後來香港旅遊既係有文化同想學真正中國文化既遊客而唔係水貨客</span>」<br />\n「<span style=\"color: red;\">我希望，香港成為最後能堅守粵語既地方</span>」<br />\n「<span style=\"color: orange;\">我希望，比到世界睇到我地香港人既作品</span>」<br />\n「<span style=\"color: gold;\">我希望，香港可以成為一片中華文化既最後一片淨土</span>」<br />\n「<span style=\"color: limegreen;\">我希望&hellip;&hellip;香港人呢三個字，永世長存</span>」<br />\n<br />\n<span style=\"font-size: xx-large;\"><ins>加入表格：<a href=\"https://forms.gle/wnjqx9N6UGJvp39c9 \" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2Fwnjqx9N6UGJvp39c9%20&d=LDhKEJhCApGKQi337qR8byEyVFbloTKGHdwbQdNTMZo%3D&h=8b1c9e95\" target=\"_blank\">https://forms.gle/wnjqx9N6UGJvp39c9 </a> </ins></span><br />\n <br />\n<em><ins><strong><span style=\"font-size: large;\"><span style=\"color: blue;\">初步計劃</span></span></strong></ins></em><br />\n第一步：<br />\n支持本土音樂人，為佢地製作有水準既MV，希望可以有專業音樂人或者導師指導一下比如唱功，甚至有跳舞訓練，令到ＭＶ點擊率提升。<br />\n例子，我近日聽到好多為今次活動創作出來既歌，分享下比大家聽：<br />\n<a href=\"https://www.youtube.com/watch?v=imjZ7aHZRuY&amp;list=RDimjZ7aHZRuY&amp;start_radio=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DimjZ7aHZRuY%26list%3DRDimjZ7aHZRuY%26start_radio%3D1&d=LDhKEJhCApGKQi337qR8byEyVFbloTKGHdwbQdNTMZo%3D&h=4294e3b5\" target=\"_blank\">https://www.youtube.com/watch?v=imjZ7aHZRuY&amp;list=RDimjZ7aHZRuY&amp;start_radio=1</a><br />\n<a href=\"https://www.youtube.com/watch?v=Len-fvBvp4c\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DLen-fvBvp4c&d=LDhKEJhCApGKQi337qR8byEyVFbloTKGHdwbQdNTMZo%3D&h=f6960195\" target=\"_blank\">https://www.youtube.com/watch?v=Len-fvBvp4c</a><br />\n<a href=\"https://www.youtube.com/watch?v=LxJ93vUsDjw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DLxJ93vUsDjw&d=LDhKEJhCApGKQi337qR8byEyVFbloTKGHdwbQdNTMZo%3D&h=23542f9f\" target=\"_blank\">https://www.youtube.com/watch?v=LxJ93vUsDjw</a><br />\n第二步：<br />\n微劇集，充滿正確價值觀，體現到真既中華文化或者本土精神既「偶像劇」<br />\n之後就睇下行成點<br />\n<br />\n最重要係！即使你唔係以上招募對象，<span style=\"color: violet;\"><strong>但你地對本地創作既支持係非常重要！</strong></span><br />\n點解咁多人鍾意去日本？日本文化氣息點解咁濃厚？正正因為日本人對自既文化有極大既尊重同支持。<br />\n<br />\n<strong><span style=\"font-size: xx-large;\">希望大家今日起，重捨你對本地創作既支持，<em><span style=\"color: red;\">令到「香港人」呢三個字，成為一種驕傲同自豪</span></em>。</span></strong>"},"citedBy":0,"replyTime":"2019-09-01T10:00:17.000Z","msg":"洋紫荊要戰勝歸來version 3 (lyrics&amp;music) 推到有人唱<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1527117\" data-auto-link target=\"_blank\">https://lih.kg/1527117</a><br />\n<a href=\"https://youtu.be/U9EEdDhnK1U\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FU9EEdDhnK1U&d=LDhKEJhCApGKQi337qR8byEyVFbloTKGHdwbQdNTMZo%3D&h=6f7def85\" data-auto-link target=\"_blank\">https://youtu.be/U9EEdDhnK1U</a><br />\n洋紫荊要戰勝歸來2019 version3<br />\n<br />\n人潮浪，默含淚光衝上街道。<br />\n單眼晴，觀看道德操守殞宕。<br />\n紅日裡，法治藏在警察背後。<br />\n誰願意，任那官商警黑放蕩？<br />\n<br />\n萬劫不改的眼光，無懼噤聲監控狂，用盡四海的筆告狀。<br />\n勇武抗強權和暴政，護手足成為煉鋼，為我家，佢捨身去闖。<br />\n<br />\n催淚煙，老人細蚊街坊中伏。<br />\n黑社會，刀捅棍扑筋斷惡毒。<br />\n無號碼，市民如何追究責任？<br />\n誰又信，實彈真槍能蓋憤怒？<br />\n<br />\n萬眾聲討這惡邦，重建法規真香港，和暴戾黑警對望。<br />\n黑警在悠悠長夜裏，習慣掃射如納粹，忘掉地獄的火，有多燙。<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n後冇方舟渡你跨惡海<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，應五大訴求。<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n還我普選還我真民主<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，應五大訴求。<br />\n<br />\n看那身軀鮮血淌，拿著雨遮抗滅亡，用血書向天主告狀。<br />\n勇武樹和平旗幟，護我香港為後世，無後退，決心反送中。<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n後冇方舟渡你跨惡海<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，應五大訴求。<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n還我普選還我真民主<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，應五大訴求。<br />\n<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n共建香港法規不變改<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，與生命同在。<br />\n<br />\n洋紫荊要戰勝歸來<br />\n洋紫荊要戰勝歸來<br />\n共建香港法規不變改<br />\n讓法治和平和仁愛，<br />\n公理道義快歸來。<br />\n要自由，與生命同在。<br />\n<br />\n要自由，與公義常在"},{"pid":"c820a127b9dcf2fc2c10a89f1d4dceb102942a76","tid":1525790,"uid":269959,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T15:47:44.000Z","msg":"開學啦！！！好興奮！！<br />\n<br />\n[第一集] 警察：我個仔比人打<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1528939\" data-auto-link target=\"_blank\">https://lih.kg/1528939</a>"},{"pid":"8bf941ffe316593031b20c0fffe27e14a687c0a1","tid":1525790,"uid":19294,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T16:27:15.000Z","msg":"Push"},{"pid":"ed802876de8004030ca7ffe43249fe7ef5c996f8","tid":1525790,"uid":69472,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T16:29:59.000Z","msg":"推"},{"pid":"ff29afd1beb648b0915c042b3296048ccb7e1dfe","tid":1525790,"uid":69314,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T19:19:15.000Z","msg":"搵人理下我 ，支持請留名721 831<br />\n<br />\n《千萬唔好》打爆所有警察出現既地鐵站<br />\n<a href=\"https://lih.kg/1529094\" data-auto-link target=\"_blank\">https://lih.kg/1529094</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"d7c0452121896adc7b298ea7c13522999a914122","tid":1525790,"uid":8075,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T19:39:34.000Z","msg":"正 好似台灣文化局咁<br />\n連一年一度嘅金曲獎佢地都有份搞<br />\n要保育香港文化 就要大力支持本土文化產業<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"42fe702861b65426859e0cf9be4b27249ef2ba55","tid":1525790,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T19:39:58.000Z","msg":"推"},{"pid":"65f30fb640232f7a216d9cfaf47b5ac9acf7d3e4","tid":1525790,"uid":197716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T19:53:25.000Z","msg":"推 香港人"},{"pid":"d59ae42702b2b25c2558044caefd31fec28dbc88","tid":1525790,"uid":149250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T19:56:37.000Z","msg":"聽日三罷，全世界同我去太子獻花<br />\n<a href=\"https://lih.kg/1529701\" data-auto-link target=\"_blank\">https://l