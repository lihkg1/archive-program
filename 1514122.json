f\" class=\"hkgmoji\" />"},{"pid":"a582d12b32bde3e31bff9bd1002b3c55479db253","tid":1514122,"uid":60924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:25:47.000Z","msg":"市民連豬肉都買唔起，仲買咩鬼車<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"76c00e09a1908fab7bc35eecc82b5cd12fd4d9eb","tid":1514122,"uid":198829,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:26:22.000Z","msg":"夜市食乜野？全部都有問題ge"},{"pid":"4f8939b1b09c9eedf9f7973672c4f0a7b7657aed","tid":1514122,"uid":144626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:26:42.000Z","msg":"深咩夜食堂丫<br />\n地溝油食堂就有"},{"pid":"c268fdf495deef58c0bf5df4fab3297241ecc0e5","tid":1514122,"uid":66248,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:29:33.000Z","msg":"屌，豬肉都唔夠<br />\n叫人深夜食樹皮呀？"},{"pid":"16b584a491bf1e9cfeaa32777f63680dc3b0c4df","tid":1514122,"uid":175865,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:32:16.000Z","msg":"深乜撚嘢食堂，用地溝油，食到個個食物中毒<br />\n<br />\n搞返個東莞常平出嚟，乜都振興啊"},{"pid":"ff8f4a687e0bdafb1fd7bcbe98e3746aa375b181","tid":1514122,"uid":52828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:32:17.000Z","msg":"開返東莞啦屌"},{"pid":"93c9a58f53476fd0fa04c756750b0edebd17957d","tid":1514122,"uid":274278,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:43:11.000Z","msg":"唔係所有儲蓄都送哂俾党咩?<br />\n仲邊有錢消費?"}]}