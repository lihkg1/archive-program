d9290c2&s={SIZE}\" />"},{"pid":"f8b0ae850015266d9f234a9e28b8135e0d9bd8b3","tid":1773821,"uid":271864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-08T02:18:54.000Z","msg":"對唔住<br />\n<br />\n其實每次講報仇，始終都係做唔到，點解要搞到最愛嘅人咁唔開心？"},{"pid":"96c18f1932b70694db4e28c2b129b9c15b93a753","tid":1773821,"uid":271864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-08T02:22:04.000Z","msg":"雖然講係陰人，應該冇人比我勁喇哈哈，宜家諗起個計劃都覺得好絕；雖然，如果唔愛，不如用永遠嘅恨嚟記住我都幾好<br />\n但係真係狠心唔落去實踐"},{"pid":"24ea7473190fdc43749efbcabe2a8d2588c20f7e","tid":1773821,"uid":271864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-08T02:24:13.000Z","msg":"不過可能有人short咗條筋真係會報仇都唔定，希望我唔會受到啲乜大刺激啦<br />\n<br />\n宜家晚晚許願可以瞓瞓下覺就咁死咗去，不過我都好想見到光復咗嘅香港"},{"pid":"de57f880bbf84bf33631f9fa0d3918c591718121","tid":1773821,"uid":271864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-08T02:25:31.000Z","msg":"我都好想新年將呢個貼房門，所以唔好死住！<br />\n<br />\n<img src=\"https://na.cx/i/ua4uVwe.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fua4uVwe.jpg&h=c88e6f2d&s={SIZE}\" />"},{"pid":"0e1ea7d216718eb31a79a508eab2985e857106e0","tid":1773821,"uid":271864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-08T02:47:48.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"778def011cf1efae00608a03e76e45f783dc0cec","tid":1773821,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-08T06:32:19.000Z","msg":"做咩搞到咁抑鬱咁呢"},{"pid":"52802de0892f748c427ec9c604ad4dfca8a349be","tid":1773821,"uid":271864,"like":0,"dislike":0,"score":0,"quote":{"pid":"778def011cf1efae00608a03e76e45f783dc0cec","tid":1773821,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-08T06:32:19.000Z","msg":"做咩搞到咁抑鬱咁呢"},"citedBy":1,"replyTime":"2019-12-08T06:59:50.000Z","msg":"Why not"},{"pid":"51cf78aeaf2198efea2d2361d93766355a7cb629","tid":1773821,"uid":174174,"like":0,"dislike":0,"score":0,"quote":{"pid":"52802de08