4c4d4766bb4801","tid":1583832,"uid":272375,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T00:00:21.000Z","msg":"等睇國際特赦組織下一步建議同行動<br />\n<br />\n大家有無咩諗法<br />\n<br />\n我先<br />\n1. 建立事件監察名單 (例如謝黑警)<br />\n2. 終身剝奪黑警嘅移民權 (避免增加移民地嘅犯罪率)"},{"pid":"96b097df17341679685495e04ba06e377058a307","tid":1583832,"uid":100714,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T00:01:52.000Z","msg":"Push"},{"pid":"b2622c1fc2ff0ad3a476b7bb0d591f77f444bde1","tid":1583832,"uid":215876,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T00:03:04.000Z","msg":"佢地就算只可以口交<br />\n<br />\n係咪都可以向全球各國呼籲"},{"pid":"0a5999d6c7eca21e26331dbb5bc74d11b8581991","tid":1583832,"uid":81113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-21T00:04:00.000Z","msg":"推"}]}