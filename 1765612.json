s://embed.lih.kg/frame?u=https%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F2995683&h=13d5b069\" target=\"_blank\">https://news.ltn.com.tw/news/world/breakingnews/2995683</a>"},"citedBy":0,"replyTime":"2019-12-03T19:24:05.000Z","msg":"中國真係慾想控制全球！"},{"pid":"54f2ed10a96b457bc1d94f4d4acab02616b20765","tid":1765612,"uid":165683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-03T19:25:10.000Z","msg":"Push"},{"pid":"d20c5a4e5e7541f6ae2fc6c057caf230c752aa62","tid":1765612,"uid":165683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-03T19:26:00.000Z","msg":"Push"},{"pid":"cb0bb5d3f827cfb71cf4e9defb9dd8f35c236d53","tid":1765612,"uid":165683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-03T19:26:12.000Z","msg":"push"},{"pid":"d4d02c09306ed69259a3319e1c9287a3a2eaadc3","tid":1765612,"uid":281328,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-03T19:26:24.000Z","msg":"<img src=\"https://na.cx/i/szm1cir.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fszm1cir.jpg&h=3867dfbf&s={SIZE}\" />"}],"pinned":{"pid":"ce5d654488ce5adbe00d64e375e261ac1b2e2fbc","tid":1765612,"uid":75656,"like":13,"dislike":0,"score":13,"citedBy":0,"replyTime":"2019-12-02T05:22:19.000Z","msg":"不是王立強<br />\n<br />\n根據《澳洲時代報》報導，澳洲自由黨黨員、墨爾本豪車經銷商<span style=\"font-size: xx-large;\"><span style=\"color: red;\">趙波</span></span>1年前向「澳洲安全情報組織」（ASIO）通報，中國情報單位曾透過陳姓墨爾本商人（Brian Chen）給他100萬澳幣（約新台幣2110萬元），要他投入國會選舉，但<span style=\"font-size: xx-large;\"><span style=\"color: red;\">趙波</span></span>卻在今年3月陳屍在墨爾本一間旅店，死因未明。"}}