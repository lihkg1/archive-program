c=\"https://na.cx/i/n9svLnS.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fn9svLnS.png&h=61440321&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-08-09T10:38:39.000Z","msg":"其實多數只係性格毒啫，佢讀到書咁高分證明佢有能力，只係香港嘅hr多數好閪，如果有條友賞識到佢我覺得可以發揮到佢嘅能力同所長<img src=\"/assets/faces/lm2/frownsmile.gif\" class=\"hkgmoji\" />"},{"pid":"382b655954b9c8b3874a291b799adf4d600036ca","tid":2147131,"uid":64694,"like":4,"dislike":0,"score":4,"quote":{"pid":"76588edf153f02b8e3b77451fe32485906089682","tid":2147131,"uid":248054,"like":22,"dislike":0,"score":22,"quote":{"pid":"21f3ea4c90196dfaa11a08044cfee7dbb6efd9d1","tid":2147131,"uid":312363,"like":3,"dislike":0,"score":3,"quote":{"pid":"cd4548bed7f246cfd957967cfe2bb74f13a85c49","tid":2147131,"uid":58201,"like":0,"dislike":7,"score":-7,"citedBy":2,"replyTime":"2020-08-09T05:02:16.000Z","msg":"讀數明明可以教書<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-09T05:05:24.000Z","msg":"邊撚有咁多人想教書"},"citedBy":1,"replyTime":"2020-08-09T05:08:45.000Z","msg":"邊有咁多機會比人教書"},"citedBy":0,"replyTime":"2020-08-09T10:39:50.000Z","msg":"唔係人人啱教書"},{"pid":"29c462ea3910d68897e1f9fa7510f3a0f1d827e3","tid":2147131,"uid":168381,"like":1,"dislike":4,"score":-3,"quote":{"pid":"fa154fe895d8b713ef2af38a7c4064894796920f","tid":2147131,"uid":225931,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-09T04:52:31.000Z","msg":"俗語有云︰香港周街大學生。很多大學生畢業生都未能找到心儀工作，有中文大學學生在網上分享道，一天在樓下遇上看更，發現對方竟是中大師兄，曾在中大讀數學，對方透露畢業後找不到合適工作，安慰自己做保安時間彈性。一班師弟師妹留言感嘆，還有語文哲學等科好難搵工。<br />\n<br />\n一名中大生投稿至facebook專頁《CUHK Secrets》指出，最近住所樓下新來了一名較年輕的保安員，戴眼鏡、斯斯文文，但欠缺笑容。<br />\n<br />\n有日保安員主動與他交談，稱有次見他穿著中大Soc T（學會T恤），又問他有沒有「上莊」，中大生好奇反問他為何如此熟悉中大，保安員才透露自己是中大畢業生，曾讀數學相關學系。中大生得知原因後感到無奈，並見到他在更亭仍愛閱讀數學理論書，「佢講完倒抽咗一口涼氣。」<br />\n<br />\n帖文引起大批中大生留言熱議，並大讚是「潮文」，更另開帖文將「看更潮文」延伸下去，列出更多前路茫茫的科目，如中文、英文、哲學、商學、物理、社會學，甚至工程、電腦科學及公共衞生等。<br />\n<br />\n有中大生勸告不要選擇數學系，否則前途堪虞，「讀數的命運」；有人則感嘆謂，讀數又斯斯文文的人，多數去教書，人生際遇嘅嘢好難講。"},"citedBy":1,"replyTime":"2020-08-09T10:39:53.000Z","msg":"讀數學可以轉行做IT，做科研，做工程，好多人要架喎。佢成績差咋？唔好水人啦。"},{"pid":"dac21e0493c97bea362ea20c01895a9374167c34","tid":2147131,"uid":64694,"like":1,"dislike":0,"score":1,"quote":{"pid":"bba1fc9fe27242b72cee0404c1783e4f3a9c776c","tid":2147131,"uid":42548,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2020-08-09T05:03:15.000Z","msg":"以前都聽過，無計讀個科係咁<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />，有冇見香港科學家？人要揾食麻"},"citedBy":0,"replyTime":"2020-08-09T10:41:03.000Z","msg":"讀得其實都預咗，可能為咗興趣而讀啫<img src=\"/assets/faces/lm2/frownsmile.gif\" class=\"hkgmoji\" />"},{"pid":"ffa4a1388898e41420c742195eac08c276528cc0","tid":2147131,"uid":293124,"like":8,"dislike":0,"score":8,"quote":{"pid":"4d2e94a462f1cf5f1a812dd2d2d4f1dddde99b68","tid":2147131,"uid":270214,"like":9,"dislike":1,"score":8,"citedBy":3,"replyTime":"2020-08-09T08:42:56.000Z","msg":"呢位巴打好有骨氣<br />\n<br />\n寧願做保安都唔去做狗<br />\n<br />\n大學生考督察四皮幾<img src=\"/assets/faces/fs/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-09T10:53:26.000Z","msg":"有人唔做走去做狗？<img src=\"https://na.cx/i/O91Mky1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FO91Mky1.png&h=11d2ef6f&s={SIZE}\" />"},{"pid":"6f3504c0825f9a07a328ff174665dfe707e293ff","tid":2147131,"uid":59283,"like":2,"dislike":0,"score":2,"quote":{"pid":"f6029a2f6d77eabdfd690cedf97085c290ef77af","tid":2147131,"uid":201414,"like":28,"dislike":0,"score":28,"citedBy":4,"replyTime":"2020-08-09T05:20:14.000Z","msg":"經典回顧<img src=\"/assets/faces/lm2/frown.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/n9svLnS.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fn9svLnS.png&h=61440321&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-08-09T10:56:05.000Z","msg":"呢個心態問題大d<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6b71278b21d86b80b51a07e93e679a4a0fef82d3","tid":2147131,"uid":155815,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-08-09T10:58:18.00