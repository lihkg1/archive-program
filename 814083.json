:2,"dislike":0,"score":2,"quote":{"pid":"93b73cbf6065fd12fe3c6957d181900aa0c1a22c","tid":814083,"uid":24345,"like":2,"dislike":5,"score":-3,"citedBy":1,"replyTime":"2018-09-11T09:58:03.000Z","msg":"池袋西口定南口，支那地帶<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-11T10:00:47.000Z","msg":"北口"},{"pid":"0d11e991b8859c7fed8629c6d987a167a9edbe11","tid":814083,"uid":190928,"like":6,"dislike":1,"score":5,"citedBy":0,"replyTime":"2018-09-11T10:03:20.000Z","msg":"又排華<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"368c9157639db47e46cd2701ef5e05b6ffbfb36d","tid":814083,"uid":190928,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T10:04:10.000Z","msg":"右翼啲大聲公車真係好有型<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b42684660652a931d1ebda5108d8fc830b52fd8a","tid":814083,"uid":180040,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2018-09-11T10:05:01.000Z","msg":"口裡說不 身體卻"},{"pid":"28cee536e7f13741ea70cc9ad2882b6129fa0b4d","tid":814083,"uid":25183,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-09-11T10:19:55.000Z","msg":"有幾多識講日文？"},{"pid":"ea9811cf768c657da7ca68344032bf791a731f6e","tid":814083,"uid":24345,"like":0,"dislike":0,"score":0,"quote":{"pid":"19d957127b490c9bafcb32f85d686c394f635606","tid":814083,"uid":35421,"like":2,"dislike":0,"score":2,"quote":{"pid":"93b73cbf6065fd12fe3c6957d181900aa0c1a22c","tid":814083,"uid":24345,"like":2,"dislike":5,"score":-3,"citedBy":1,"replyTime":"2018-09-11T09:58:03.000Z","msg":"池袋西口定南口，支那地帶<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-11T10:00:47.000Z","msg":"北口"},"citedBy":0,"replyTime":"2018-09-11T10:25:44.000Z","msg":"係喇，之前先有個支那仔當街強姦佢地啲同胞<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"c5322e5186b430fdfe68f3d6d89