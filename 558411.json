ny/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/agree2.gif\" class=\"hkgmoji\" /> <br />\n新年快樂，快樂要進步，同時不忘義士既付出。"},{"pid":"d314da1d80b14694dfb5cfc6b6e981e0f0781d3f","tid":558411,"uid":96732,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-16T12:08:17.000Z","msg":"加油<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n我都想戒<br />\n但打機返工嗰陣好難唔食<img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" />"},{"pid":"4754a39c7dd4da487bdc5b753a81f2231060f30f","tid":558411,"uid":124760,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-17T11:01:35.000Z","msg":"Day4:都係無食，頂住，過左7日退癮反應就無咁強烈！<img src=\"/assets/faces/lny/devil.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/good.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/clown.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/clown2.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/smile2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/smile3.png\" class=\"hkgmoji\" />"},{"pid":"22d0bc79d50d6e49130cec380939952bc8ee509b","tid":558411,"uid":124760,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-18T08:31:07.000Z","msg":"Day5:無食。繼續！繼續！<img src=\"/assets/faces/lny/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/agree2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"7eb1a27b5c1034cfb6807d007b69088a5aadb037","tid":558411,"uid":37299,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-18T10:45:52.000Z","msg":"樓主要成功啊 戰勝自己<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ae25e09a3b0f2c72b408bce7a18e45e35a9148c7","tid":558411,"uid":124760,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-24T08:20:09.000Z","msg":"Refresh <br />\nKeep updating <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"1fa6374d395b2259e7b944d0c4cf0