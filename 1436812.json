ike":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2019-08-09T11:23:59.000Z","msg":"我撐建立大台既，你哋又包唔包容到先?"},{"pid":"5422a75d3fb9ba1328616be685d47d4bda9ce900","tid":1436812,"uid":26050,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:24:27.000Z","msg":"push"},{"pid":"3a66f0c8fd319517cf2f9708abf7602e64075463","tid":1436812,"uid":26050,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:25:12.000Z","msg":"push"},{"pid":"ce69e435bba59a235fffbb014d212d5c6a639988","tid":1436812,"uid":26050,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:25:26.000Z","msg":"pish"},{"pid":"2d3ace685bb1b9b3d56d3b0d857a8044ac94b246","tid":1436812,"uid":201604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:26:24.000Z","msg":"推"},{"pid":"5074bf6588065534c717506c802125ae4b24b157","tid":1436812,"uid":268248,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:27:30.000Z","msg":"依加對家就係想整個大台比我地故技重演<br />\n我地可以堅持咁耐就係因為冇大台<br />\n不割蓆 不分化<br />\n和理勇武一齊合作<br />\n我地冇得再輸喇<br />\n<br />\n五大訴求 決一不可"},{"pid":"09377802256508171b7b8408349229f7972d515c","tid":1436812,"uid":223260,"like":3,"dislike":0,"score":3,"quote":{"pid":"9998e32670277452c04875585cbb0d0d90126986","tid":1436812,"uid":117332,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2019-08-09T11:23:59.000Z","msg":"我撐建立大台既，你哋又包唔包容到先?"},"citedBy":1,"replyTime":"2019-08-09T11:28:06.000Z","msg":"包容到你，唔支持你。"},{"pid":"2f7b402d716c9032979a6f77e9121f013a9f922a","tid":1436812,"uid":33643,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-09T11:29:20.000Z","msg":"同意：<br />\n睇到玩手機燈<br />\n聽到今天我<br />\n都好驚"},{"pid":"533a8d8ea0886a992de8f729d8273b73c03239e8","tid":1436812,"uid":11935,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:31:04.000Z","msg":"推<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"f2add7d99d1325d67bc1b1381f8997137fc0622e","tid":1436812,"uid":130876,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:32:28.000Z","msg":"五大訴求 ！"},{"pid":"8eae50978a78c72b5e0db527761b83fc16aba490","tid":1436812,"uid":293226,"like":3,"dislike":0,"score":3,"quote":{"pid":"33fd63f59274e5aed092534f6a61eb8799f4861c","tid":1436812,"uid":67023,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-09T11:12:29.000Z","msg":"雨革完咗好耐都唔敢再去夏慤<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-09T11:34:06.000Z","msg":"我以為以後都唔會再見到果條馬路全部都係人<img src=\"/assets/faces/lm2/frownsmile.gif\" class=\"hkgmoji\" />"},{"pid":"9bbf9211474623f0bec9ffc26a872cd54adb95fb","tid":1436812,"uid":117332,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-09T11:37:59.000Z","msg":"不過14年死因之一係不停屌人屈人係大台<br />\n<br />\n但偏偏不斷想指揮場運動做暴力抗爭既係班本土派大台<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a443e5a7d1028566371f305d433d20b681576601","tid":1436812,"uid":67023,"like":0,"dislike":0,"score":0,"quote":{"pid":"8eae50978a78c72b5e0db527761b83fc16aba490","tid":1436812,"uid":293226,"like":3,"dislike":0,"score":3,"quote":{"pid":"33fd63f59274e5aed092534f6a61eb8799f4861c","tid":1436812,"uid":67023,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-09T11:12:29.000Z","msg":"雨革完咗好耐都唔敢再去夏慤<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-09T11:34:06.000Z","msg":"我以為以後都唔會再見到果條馬路全部都係人<img src=\"/assets/faces/lm2/frownsmile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-09T11:48:12.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />"},{"pid":"f9a1561c4dd89e8e241ce825704700c5a8ff97d1","tid":1436812,"uid":275723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:49:57.000Z","msg":"巴打我覺得你講得好好，真係講得好好 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />大台係我嘅創傷 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />我可以包容嘅嘢有好多，但絕對不包括大台 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n所有企圖起大台嘅人，都係出賣抗爭者嘅仆街 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"64014cf9c82ab16a4ed672990332096b3969cebd","tid":1436812,"uid":115467,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T11:51:53.000Z","msg":"<img src=\"https://na.cx/i/kpP9o0f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FkpP9o0f.png&h=26376d00&s={SIZE}\" />"},{"pid":"806ddfa76dfef361acbafaff6d5e8a69511f0d42","tid":1436812,"uid":280475,"like":0,"dislike":0,"score":0,"quote":{"pid":"8278098e38d9589300b5f3e796d5aeb1e16545bd","tid":1436812,"uid":223260,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-09T11:07:21.000Z","msg":"各位近排出世嘅手足，<br />\n可能唔知道雨革發生咩事。<br />\n當年就係因爲大台令抗爭者嚴重分裂，<br />\n詳情可以參考下呢個post：<br />\n<br />\n有冇老鬼可以講下 14年嗰陣 係點樣輸<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1434013\" data-auto-link target=\"_blank\">https://lih.kg/1434013</a><br />\n<br />\n大台最主要嘅問題係壟斷話語權，<br />\n令某啲抗爭者比其他抗爭者有更大權力。<br />\n更加嚴重嘅甚至篤勇武派灰同警察報串。<br />\n之後更加演變到要拆大台，勇武派抗爭者圍住大台屌。<br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: xx-large;\">但係呢個post唔係想翻舊賬，而係想解決問題。</span></span><br />\n<br />\n其實每個手足對成個運動嘅立場，甚至每個行動嘅睇法都有差異。<br />\n有啲可能甚至係水火不容嘅，恨不得另一派人消失。<br />\n<span style=\"color: gold;\">但能夠包容所有差異，我地先會強大。</span><br />\n<br />\n但係宜家出現咗個問題，<br />\n就係反大台嘅人屌大台，<br />\n有啲人又屌反大台嘅人分化。<br />\n咁樣互屌本身已經係非常分化。<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: orange;\">反大台嘅手足你好<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />：</span></span><br />\n如果堅持宜家即刻同泛民割蓆，<br />\n翻曬啲舊賬出嚟全面開戰嘅話，<br />\n好快就會時光倒流返去14年咁。<br />\n<br />\n我認同大台係絕對唔應該存在，<br />\n但係泛民鬼極都坐擁龐大嘅支持，<br />\n宜家係極其嚴峻嘅時刻，<br />\n輸咗就全面監控萬劫不復必死無疑。<br />\n次要敵人如果可以嘅話都要we connect。<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">我認爲應該逼使佢地歸隊反大台，</span></span><br />\n正如七月一衝立會宜家已經冇人敢割蓆。<br />\n唔好將想建立大台嘅人標籤做【泛民】，<br />\n而係孤立佢哋，等其他泛民唔敢跟。<br />\n要清算留返勝利後煲底慶祝完先清算。<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: orange;\">覺得反大台係分化嘅手足你好<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />：</span></span><br />\n大台係我哋呢啲雨革老鬼嘅PTSD黎，<br />\n如果有人反應太激烈請包容下。<br />\n如果閣下唔明白有啲人點解咁大反應，<br />\n可以去瞭解下14年嘅歷史，<br />\n唔好一黎就話人三毛，好傷人感情。<br />\n<br />\n<span style=\"color: gold;\">我認爲大台係絕對唔應該存在，<br />\n因爲只會將手足劃分階級，<br />\n大台只會有一個立場，<br />\n但一衆手足有千千萬萬個諗法，<br />\n所以大台支持邊個諗法都好，都會出現分化。<br />\n而且有大台政府就有明確target可以打，<br />\n打散咗民氣就散，返唔到轉頭。<br />\n<br />\n所以時刻警惕，<br />\n唔好俾疑似大台，糾察，呢啲會分階級嘅野出現。<br />\n互相提醒，時刻警惕。<br />\n</span><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">不分化不割蓆，求求大家，香港人一定要贏。</span></span>"},"citedBy":0,"replyTime":"2019-08-09T11:52:55.000Z","msg":"Push"},{"pid":"cd8617ef7680f6c9e2691cfe1298d9affcc8e191","tid":1436812,"uid":2429,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-09T11:55:33.000Z","msg":"泛民唔仆出黎柒其實無人想理佢哋。<img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/ew41YjN.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Few41YjN.jpg&h=d4d7c080&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/hMoYZ13.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhMoYZ13.png&h=a80d5a5a&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/MGdudBr.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FMGdudBr.jpg&h=013f1421&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/JM5XwE0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJM5XwE0.png&h=0aa696d8&s={SIZE}\" /><br />\n<br />\n邊個起大台阻勇武就係鬼！<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"7b9b80d07c31dfaf52b946bd4e7b281f3694c701","tid":1436812,"uid":192824,"like":0,"dislike":0,"score":0,"quote":{"pid":"662f6edbd47d8862d9f7f449dc8c060d0ab2d959","tid":1436812,"uid":4050,"like":6,"dislike":0,"score":6,"citedBy":2,"replyTime":"2019-08-09T11:10:13.000Z","msg":"<span style=\"font-size: x-large;\"><span style=\"color: red;\"><strong>點解一定係佢地開主題我地曬時間去駁佢？ 點解唔係我地開主題佢地之後回應我地</strong>？</span></span><br />\n<br />\n唔想知<span style=\"color: green;\">鐳射筆，外國勢力，大台，經濟差</span><br />\n<br />\n想知<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>葉虎，同志們，過期彈呀</strong></span></span>"},"citedBy":0,"replyTime":"2019-08-09T11:57:50.000Z","msg":"仲有行動攻略post"},{"pid":"8f541d03ebfdac82a48af64288e854ad92591595","tid":1436812,"uid":105511,"like":0,"dislike":0,"score":0,"quote":{"pid":"09377802256508171b7b8408349229f7972d515c","tid":1436812,"uid":223260,"like":3,"dislike":0,"score":3,"quote":{"pid":"9998e32670277452c04875585cbb0d0d90126986","tid":1436812,"uid":117332,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2019-08-09T11:23:59.000Z","msg":"我撐建立大台既，你哋又包唔包容到先?"},"citedBy":1,"replyTime":"2019-08-09T11:28:06.000Z","msg":"包容到你，唔支持你。"},"citedBy":0,"replyTime":"2019-08-09T12:04:39.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"007ec713973682398d3057e8c0571779b3d99792","tid":1436812,"uid":67249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T16:19:44.000Z","msg":"其實冇人有能力起到大台，唔好下下屈大台，好多嘢fact check咗先，唔係好易俾人利用嚟帶風搞分化"},{"pid":"e4d9f3a3c08cbfde0d57d8df8a6fc60f05a99e76","tid":1436812,"uid":232766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T02:18:16.000Z","msg":"Push"}]}