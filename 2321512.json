eplyTime":"2020-12-12T00:56:44.000Z","msg":"支持，已 follow user!"},{"pid":"b0c07927ce7631db2589d0f118fe34cda2d63ddd","tid":2321512,"uid":302225,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-12T01:26:03.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"29144684cb6b57211a4df2a3cce1289fa76d9314","tid":2321512,"uid":40121,"like":0,"dislike":0,"score":0,"quote":{"pid":"fcb7bfca26cb38a95302f4c5f5088d08bbe44abe","tid":2321512,"uid":143589,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-11T16:12:00.000Z","msg":"埋位學嘢 三支金流巴打出po一定g持<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-12T02:55:51.000Z","msg":"<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" />多謝你支持<br />\n會繼續努力學多啲分享多啲<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" />"}]}