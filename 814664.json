&amp;source=web&amp;rct=j&amp;url=https://en.m.wikipedia.org/wiki/Dead_or_Alive_(novel)&amp;ved=2ahUKEwiRo6PUjbTdAhVM94MKHQV3DJwQ5OUBMAp6BAgFEAE&amp;usg=AOvVaw2I_blSZ07xopk-3QpVexQi</a>"},{"pid":"7643fcca8883b1bb470a55c3d12b4d14f3d6a5a7","tid":814664,"uid":89046,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-12T14:31:32.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}