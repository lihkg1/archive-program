f\" class=\"hkgmoji\" />"},{"pid":"c4b7b79fe2ae3515a127cd14336028679717358c","tid":625744,"uid":181662,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c7bcd06565303f3128e3ef9539b05f3a22a4a29","tid":625744,"uid":26829,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-12T05:28:20.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/04/12/132355_73af0433412f272e4cec71a3b646eafb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F12%2F132355_73af0433412f272e4cec71a3b646eafb.jpg&h=36a567ec&s={SIZE}\" /><br />\nGoogle完第一種隻貓面型應該唔係咁樣喎<br />\n第一張圖睇面型似係布偶喎<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-12T05:58:16.000Z","msg":"你試下搵ojos azure longhair<br />\n<br />\n佢有長毛同短毛"},{"pid":"7f18425e686dbe69059ce8711684f9ac7c179d78","tid":625744,"uid":181662,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-12T06:16:58.000Z","msg":"Ojos azule longhair"},{"pid":"f0bfbaca4a7e90ca3864d66ad29355daee3f324d","tid":625744,"uid":127611,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-12T06:57:42.000Z","msg":"最後個隻人扮?"},{"pid":"363108a277227a70dc27c2b30fdb00c39b040d25","tid":625744,"uid":181662,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-12T08:37:34.000Z","msg":"Ojos Azule long hair<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/12/163727_fac371685b1ebdab752721fded41217b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F12%2F163727_fac371685b1ebdab752721fded41217b.jpg&h=4c6d36af&s={SIZE}\" />"},{"pid":"cbd8c594409c227e286008ebbff518aeced7d227","tid":625744,"uid":35648,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-12T08:48:42.000Z","msg":"最尾嗰隻比例咁怪<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3c64286a43e22ce4b493860f0892fd26cfa126e4","tid":625744,"uid":14737,"like":0,"dislike":0,"score":0,"