cx/i/LFN77VV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLFN77VV.jpg&h=e3b7fdff&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/b0KqUAW.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fb0KqUAW.png&h=f5832437&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/VREncnA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVREncnA.jpg&h=0285ec21&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/1J83GfW.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1J83GfW.png&h=36799d46&s={SIZE}\" />"},"citedBy":1,"replyTime":"2021-01-25T11:03:27.000Z","msg":"中國醫院不嬲係中西合璧，鳩來的<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"50dc037f15da9c086c2e297ec62ac2cc3e21d698","tid":2379501,"uid":12991,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-25T11:06:07.000Z","msg":"屌<br />\n早知走去街市買肺炎湯包啦 <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"deef3b1e3da096733136685af147d5409ff983eb","tid":2379501,"uid":15830,"like":1,"dislike":1,"score":0,"quote":{"pid":"fbce1cc11cb6500e98afbffbbfbfaffeb3e9a817","tid":2379501,"uid":325580,"like":1,"dislike":1,"score":0,"quote":{"pid":"36f8815964ec6e4dcb6df560ee289349a25a8230","tid":2379501,"uid":325346,"like":30,"dislike":7,"score":23,"quote":{"pid":"f6297a59b3144ceb85f466ca4a12d55a56f6369c","tid":2379501,"uid":49577,"like":7,"dislike":1,"score":6,"citedBy":3,"replyTime":"2021-01-25T09:22:41.000Z","msg":"汁?"},"citedBy":4,"replyTime":"2021-01-25T09:23:53.000Z","msg":"輔助啫<br />\n唔係個個都用中藥<br />\n只用在輕症病人"},"citedBy":1,"replyTime":"2021-01-25T10:18:15.000Z","msg":"康復就又可以吹中藥完勝西藥<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-25T11:06:52.000Z","msg":"根本唔洗醫嘅程度 食唔食中藥都好得返<br />\n食完中藥又可以吹噓中醫點勁法<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9980201969a6bce498987a79fd32e9a3afbb176c","tid":2379501,"uid":199670