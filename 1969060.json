.cx%2Fi%2F7msB7WJ.jpg&h=2bcb787d&s={SIZE}\" /> 癡半個鐘"},"citedBy":1,"replyTime":"2020-04-15T13:36:02.000Z","msg":"推 真係有用 但我係隔幾日用"},"citedBy":2,"replyTime":"2020-04-16T00:07:02.000Z","msg":"香港起邊買到<br />\n<br />\n用咁密唔傷牙？"},"citedBy":0,"replyTime":"2020-04-21T02:57:41.000Z","msg":"推下先<br />\n<br />\n香港好似唔興"},{"pid":"44628168daf8e31287f21bf801cb1cb9af5ec7fe","tid":1969060,"uid":265168,"like":0,"dislike":0,"score":0,"quote":{"pid":"f72cfc53a04b339503dee8df391e375baaca3455","tid":1969060,"uid":6582,"like":0,"dislike":0,"score":0,"quote":{"pid":"38052fd75dd3abc6b27d259c534a11de751dc514","tid":1969060,"uid":311122,"like":0,"dislike":0,"score":0,"quote":{"pid":"5fef9d8794edf346301292692e0d89f67b0e64d8","tid":1969060,"uid":241879,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-04-12T09:01:23.000Z","msg":"<img src=\"https://na.cx/i/7msB7WJ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7msB7WJ.jpg&h=2bcb787d&s={SIZE}\" /> 癡半個鐘"},"citedBy":1,"replyTime":"2020-04-15T13:36:02.000Z","msg":"推 真係有用 但我係隔幾日用"},"citedBy":2,"replyTime":"2020-04-16T00:07:02.000Z","msg":"香港起邊買到<br />\n<br />\n用咁密唔傷牙？"},"citedBy":0,"replyTime":"2020-04-24T02:41:35.000Z","msg":"萬寧定唔知屈臣氏有 得其中一間獨家有<br />\n呢隻牌子好好用 香港嗰隻好似係普通閃鑽 好有效<br />\n<br />\n我自己就冇乜反應 係用完之後嗰幾日會有少少牙齒敏感<br />\n但係我朋友用完之後就敏感到唔敢再用<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n我印象中好似三百幾蚊一盒 <br />\n一盒十幾包 一包有上下排牙兩張貼<br />\n(有啲牌子好仆街 一包剩係得一張貼 又唔寫喺包裝<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />)<br />\n<br />\nBtw因為我啲牙唔係好大粒<br />\n我會將一張貼再剪開一半<br />\n一來唔使美白埋入邊啲牙 冇咁傷<br />\n二來可以慳啲用 一盒用好耐<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> 仲可以同朋友夾"},{"pid":"079f5eca5e77955335abe45654873ea02c2a958c","tid":1969060,"uid":6582,"like":0,"dislike":0,"score":0,"quote":{"pid":"c6695c63ce900e6cb23d4b83ab0cd18a697c7def","tid":1969060,"uid":325346,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-04-12T07:24:20.000Z","msg":"飲菜<img src=\"/asset