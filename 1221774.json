dBy":0,"replyTime":"2019-06-14T10:03:55.000Z","msg":"Push"},{"pid":"a1bce8ddd10f6d437e62efd3988e68bb5b3bf074","tid":1221774,"uid":159920,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:03:58.000Z","msg":"推"},{"pid":"b3c8f265a1f47690e7a9f20289c57b0bf49ca191","tid":1221774,"uid":105995,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:03:59.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"159eb727f5edf426f1cd50dd9ccf74ec189793aa","tid":1221774,"uid":148987,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:04:34.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"8c46aa6e56c49d5de6d3979e7cf35f589b226744","tid":1221774,"uid":212706,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:04:53.000Z","msg":"推"},{"pid":"21d98cd9a2c1fd206f6b9890438dd49e319ba373","tid":1221774,"uid":96152,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:05:02.000Z","msg":"push"},{"pid":"409cdaa05071727e7d7bfb996ebc30808ad2c47f","tid":1221774,"uid":258696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:05:48.000Z","msg":"推"},{"pid":"7b218e35d83059bffc8a57d9a966d39bd84c25ed","tid":1221774,"uid":201021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:05:49.000Z","msg":"push"},{"pid":"8bdf3dd6fce6eae4af590e2052586cd04b875e3f","tid":1221774,"uid":15394,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:05:52.000Z","msg":"Push"},{"pid":"41cd2e32d11e7345856a115c95c2ab852dc6fd6b","tid":1221774,"uid":38737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:05:54.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2fa3498ebb6b87e3a3130d1cf1058fee05d8e9b2","tid":1221774,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:06:01.000Z","msg":"推"},{"pid":"25125bd34ad439289a1ff2a8b5504fc41c8644ce","tid":1221774,"uid":202730,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-14T10:06:11.000Z","msg":"1) 不如取消616遊行<br />\n痴能線，唔單只唔應該取消，更應該鼓勵更多上次冇出既人一齊黎<br />\n目標要明確「反送中」「林鄭陪同惡法一同收皮」「即時釋放被捕人士」<br />\n要「救人」先係最最最緊要!<br />\n你今日唔救人，下一次到你俾人拉就冇人救到你<br />\n<br />\n2) 我地已經贏左 / 階段勝利論<br />\n更加痴線，而家只係成功拖到，要推翻條例條路「雖遠亦近」<br />\n時間其實好緊迫，一定要做好建制「突擊」既準備<br />\n只要準備唔夠，就會再演一次送頭<br />\n只要一唔小心，就會俾對方搶點<br />\n<br />\n3) 建制派內訌<br />\n唔好傻啦，一個咁有組織，有共同利益既「集團」會內訌? 佢係等緊你地內訌咋。<br />\n佢地會驚美國佬咩? 唔會囉，佢地既資產係「受保護」架<br />\n唔好相信咩「沒收財產」，係唔會發生架<br />\n就算發生，都會響你交既稅度拎番俾佢地，明嘛<br />\n<br />\n4) 警方前線士氣低落<br />\n如果信你就死緊啦，難道你會Expect 當你企響最前線，前面兩個差佬會意見不合互抽?<br />\n冇可能架，就算意見不合，都一定打左你先<br />\n如果唔忍心打學生果班，根本唔會上前線<br />\n有糧出有人打，只會士氣高漲，只會係打你打到累架咋<br />\n你返工恰眼訓會俾人炒，佢地返工走去訓係「職責」阿<br />\n<br />\n5) 中央同林鄭劃清界線<br />\n今日聽既最大個誤導，係，你未出過黎做野，你可能會信<br />\n但你知唔知，冇一個打工仔會自己搞D野出黎搏上位<br />\n做一隻聽話既打工仔，特別係高人工果隻，<br />\n就係老細叫你做咩就做咩，少做少錯，唔做唔錯<br />\n條例過到佢會加人工咩? 唔會架! 所以呢條例唔會係777既意思，佢只係執行者，仲執行我太差，差到令我懷疑佢都係被迫阿，明冇?<br />\n<br />\n6) 示威者已經嬴左光環<br />\n錯曬啦，唔好再圍爐打J啦，你所睇到既並唔係全世界阿<br />\n成件抗爭，岩岩先開始架咋<br />\n媒體係可以被控制架，風向都可以隨時轉，直播都可以取消架<br />\n一個內鬼已經足以斷送所有人既努力<br />\n保持清醒，鼓勵身邊中立人士參與，小心被人領風向，先最重要<br />\n<br />\n7) 連衛兵式追擊黑警 / 反對聲音<br />\n小心阿，物極必反，要適可而止。一個唔小心，就會被人連消帶打。<br />\n一方面幫對面增加仇恨，補血，另一方面仲跌埋自己個光環<br />\n呢個行為「極危險」，我明白大家好嬲，好想報復又苦無方法，呢幾日實在太多啦<br />\n唔好太過依賴呢樣方式鼓勵士氣啦<br />\n<br />\n8) 偶像式崇拜<br />\n冇錯，今次我地欠左一個精神領袖，但我地有既係「共同目標」阿<br />\n但唔該，唔好再依靠得把口既「政棍」唔好再J 果D叫人出去，自己響度睇直播既柒頭，要好好保護「做實事」，為大家企到最前既「兄弟姐妹」<br />\n「政棍」係會響重要時候出賣你架，唔係未試過架啦<br />\n<br />\n9) 美軍來了我帶路<br />\n太天真啦連登仔，真係唔好以為侵侵會幫你，佢係生意人黎，有錢賺既野佢就會做<br />\n香港問題只係棋子，如果要發聲，要幫手，佢老早就出左手<br />\n過份依賴係會令你放棄左鬥心，亦會令你好易失去士氣，醒下啦<br />\n<br />\n記住 記住 記住 以下重點<br />\n不戰而屈人之兵 時機比起兵力重要<br />\n子非魚 對方如火荼既準備 看似平靜 實際上唔係你可以響電視睇到架<br />\n唔好輕敵 唔好鬆懈 唔好內訌<br />\n要團結 目標一致<br />\n希望大家都平平安安 守護香港"},{"pid":"49c7b8861f1631a89bea62a4e43a1505d4b5bd2f","tid":1221774,"uid":192997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:06:20.000Z","msg":"推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"53fd4c79f54e54a3a250f75059007ba4d5aede73","tid":1221774,"uid":124803,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:06:27.000Z","msg":"推"},{"pid":"8b839e1a45f84058dd9facb3c80f4954be8b506d","tid":1221774,"uid":197989,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:06:30.000Z","msg":"pish"},{"pid":"8662b8d65cdd29f5a028f18aaabba7a83a6cd604","tid":1221774,"uid":258696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:06:31.000Z","msg":"推"},{"pid":"0ae8319d8f8f4dc993b7f8d972195103b97afe0b","tid":1221774,"uid":53413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:06:34.000Z","msg":"岩<br />\n打鐵趁熱 <br />\n星期日一定要出來"},{"pid":"fa7d05d61665439ebe308316ca88372c05baf564","tid":1221774,"uid":126054,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:06:36.000Z","msg":"推"},{"pid":"23d1930f238268204949846d016b866b43716200","tid":1221774,"uid":21545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:06:59.000Z","msg":"Push<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ea23519027eeac62e91ff033c296c355920f8966","tid":1221774,"uid":27458,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-14T10:07:14.000Z","msg":"槍口對外，兄弟爬山，各自努力<br />\n不分化，不割蓆，不篤灰<br />\n不被捕，不受傷<br />\n<br />\n維持高度戒備狀態<br />\n隨時動員<br />\n嚴防打飛機論調<br />\n嚴防on9野 例如玩聖經"},{"pid":"0f34048b3c76cc801ad94a7a3115a133e7c73132","tid":1221774,"uid":66221,"like":0,"dislike":0,"score":0,"quote":{"pid":"25125bd34ad439289a1ff2a8b5504fc41c8644ce","tid":1221774,"uid":202730,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-14T10:06:11.000Z","msg":"1) 不如取消616遊行<br />\n痴能線，唔單只唔應該取消，更應該鼓勵更多上次冇出既人一齊黎<br />\n目標要明確「反送中」「林鄭陪同惡法一同收皮」「即時釋放被捕人士」<br />\n要「救人」先係最最最緊要!<br />\n你今日唔救人，下一次到你俾人拉就冇人救到你<br />\n<br />\n2) 我地已經贏左 / 階段勝利論<br />\n更加痴線，而家只係成功拖到，要推翻條例條路「雖遠亦近」<br />\n時間其實好緊迫，一定要做好建制「突擊」既準備<br />\n只要準備唔夠，就會再演一次送頭<br />\n只要一唔小心，就會俾對方搶點<br />\n<br />\n3) 建制派內訌<br />\n唔好傻啦，一個咁有組織，有共同利益既「集團」會內訌? 佢係等緊你地內訌咋。<br />\n佢地會驚美國佬咩? 唔會囉，佢地既資產係「受保護」架<br />\n唔好相信咩「沒收財產」，係唔會發生架<br />\n就算發生，都會響你交既稅度拎番俾佢地，明嘛<br />\n<br />\n4) 警方前線士氣低落<br />\n如果信你就死緊啦，難道你會Expect 當你企響最前線，前面兩個差佬會意見不合互抽?<br />\n冇可能架，就算意見不合，都一定打左你先<br />\n如果唔忍心打學生果班，根本唔會上前線<br />\n有糧出有人打，只會士氣高漲，只會係打你打到累架咋<br />\n你返工恰眼訓會俾人炒，佢地返工走去訓係「職責」阿<br />\n<br />\n5) 中央同林鄭劃清界線<br />\n今日聽既最大個誤導，係，你未出過黎做野，你可能會信<br />\n但你知唔知，冇一個打工仔會自己搞D野出黎搏上位<br />\n做一隻聽話既打工仔，特別係高人工果隻，<br />\n就係老細叫你做咩就做咩，少做少錯，唔做唔錯<br />\n條例過到佢會加人工咩? 唔會架! 所以呢條例唔會係777既意思，佢只係執行者，仲執行我太差，差到令我懷疑佢都係被迫阿，明冇?<br />\n<br />\n6) 示威者已經嬴左光環<br />\n錯曬啦，唔好再圍爐打J啦，你所睇到既並唔係全世界阿<br />\n成件抗爭，岩岩先開始架咋<br />\n媒體係可以被控制架，風向都可以隨時轉，直播都可以取消架<br />\n一個內鬼已經足以斷送所有人既努力<br />\n保持清醒，鼓勵身邊中立人士參與，小心被人領風向，先最重要<br />\n<br />\n7) 連衛兵式追擊黑警 / 反對聲音<br />\n小心阿，物極必反，要適可而止。一個唔小心，就會被人連消帶打。<br />\n一方面幫對面增加仇恨，補血，另一方面仲跌埋自己個光環<br />\n呢個行為「極危險」，我明白大家好嬲，好想報復又苦無方法，呢幾日實在太多啦<br />\n唔好太過依賴呢樣方式鼓勵士氣啦<br />\n<br />\n8) 偶像式崇拜<br />\n冇錯，今次我地欠左一個精神領袖，但我地有既係「共同目標」阿<br />\n但唔該，唔好再依靠得把口既「政棍」唔好再J 果D叫人出去，自己響度睇直播既柒頭，要好好保護「做實事」，為大家企到最前既「兄弟姐妹」<br />\n「政棍」係會響重要時候出賣你架，唔係未試過架啦<br />\n<br />\n9) 美軍來了我帶路<br />\n太天真啦連登仔，真係唔好以為侵侵會幫你，佢係生意人黎，有錢賺既野佢就會做<br />\n香港問題只係棋子，如果要發聲，要幫手，佢老早就出左手<br />\n過份依賴係會令你放棄左鬥心，亦會令你好易失去士氣，醒下啦<br />\n<br />\n記住 記住 記住 以下重點<br />\n不戰而屈人之兵 時機比起兵力重要<br />\n子非魚 對方如火荼既準備 看似平靜 實際上唔係你可以響電視睇到架<br />\n唔好輕敵 唔好鬆懈 唔好內訌<br />\n要團結 目標一致<br />\n希望大家都平平安安 守護香港"},"citedBy":0,"replyTime":"2019-06-14T10:07:38.000Z","msg":"多謝幫手資料，千祈唔好比網軍嘅野上到熱門"},{"pid":"b23c2ddc4a15e46ea960364b8e5dc49acedfedd3","tid":1221774,"uid":260417,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:07:41.000Z","msg":"推"},{"pid":"57a468ff3853b2ece6f63ff07a313ade4313ba41","tid":1221774,"uid":66221,"like":0,"dislike":0,"score":0,"quote":{"pid":"b0103ab4f68863e62de5f29ee20e8519ce28e8cf","tid":1221774,"uid":7818,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-14T09:46:23.000Z","msg":"請尊重返人地宗教 唔好比輿論散播<br />\n<a href=\"https://lihkg.com/thread/1219890/page/1\" target=\"_blank\">https://lihkg.com/thread/1219890/page/1</a><br />\n<br />\n仲有依個"},"citedBy":0,"replyTime":"2019-06-14T10:08:21.000Z","msg":"推埋呢個先"},{"pid":"887b17d090c0a7ea3a680413cbddf03a0cd1fa59","tid":1221774,"uid":111477,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:08:44.000Z","msg":"push"},{"pid":"af13dd7234320d8e8a29e3228f5a9af06d2be3a1","tid":1221774,"uid":36321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:09:20.000Z","msg":"Push"},{"pid":"9fe7df74b773f4670e8812af69298fd56c998220","tid":1221774,"uid":37058,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:09:24.000Z","msg":"推"},{"pid":"441a8999ec1fb3a50c5178c5cda446cd9079261e","tid":1221774,"uid":133928,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:09:59.000Z","msg":"pushhhpushhh"},{"pid":"fe8b169e889222fbfbd91100e4e3ccbf1a77c58f","tid":1221774,"uid":29270,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:09:59.000Z","msg":"agger"},{"pid":"92d61c539adf300a7d44385d58e0de5eb29efaf7","tid":1221774,"uid":1673,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:10:14.000Z","msg":"PUSH"},{"pid":"396dde9787d6e4c684140b8f3b3256baadf2bb32","tid":1221774,"uid":80455,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:11:24.000Z","msg":"推"},{"pid":"cb16d574fbe2ba9ad22bd8289cff99d0fc0aebd0","tid":1221774,"uid":36321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:11:58.000Z","msg":"Push"},{"pid":"7c33331c01fe563e882c29c937eec4ab789d68fd","tid":1221774,"uid":183602,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:12:37.000Z","msg":"推"},{"pid":"9342b65a0dddeb2e3f892cd6c358942d3b78a761","tid":1221774,"uid":7427,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:13:32.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2d0abca5e4554f8f43e0910e994aabe056748e4a","tid":1221774,"uid":134206,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:13:56.000Z","msg":"pushh"},{"pid":"8540cfdb8955dce349fda07923d38c372ae5f27e","tid":1221774,"uid":27194,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:15:20.000Z","msg":"仲有唔好用聖經<br />\n唱聖詩已經好夠<br />\n要尊重人地宗教！"},{"pid":"7b8c213603bf020dd99c520111f12c86ab2c34e0","tid":1221774,"uid":39003,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:15:54.000Z","msg":"推"},{"pid":"88414bbbf0e86b1955cd01af3ea2efad75d1b75f","tid":1221774,"uid":36321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:16:00.000Z","msg":"Push"},{"pid":"884bdba0782ecae92c03eb81647e5273dec045d9","tid":1221774,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:16:16.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"0daf1e45d064e2313a46cdd1d7295625e5261862","tid":1221774,"uid":93451,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-14T10:16:17.000Z","msg":"阻一阻大家<br />\n<br />\n岩岩早上宗教 po 我發現到<br />\n一但上左熱門 就好容易比人操作到輿論<br />\n上左熱門好容易比人利用<br />\n因為好多人見到個po就咁like左就算 令一d 未有驗證 同未有討論既事<br />\n好容易比人帶左風向 令之前既野白費晒<br />\n<br />\n所以開返下邊個po提下大家 希望大家幫手推到上到熱門<br />\n<a href=\"https://lihkg.com/thread/1220056/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1220056/page/1</a><br />\n<br />\n<strong><span style=\"color: red;\">有時講錯左野就好容易比人利用<br />\n見到唔同既消息大家記得同周邊既朋友傾多啲<br />\n驗清楚真假 同諗清楚個樣野既後果<br />\n係而家信息過多既時間<br />\n思考係十分重要既一步<br />\n大家坐埋一條船 尊重係好重要既一樣野<br />\npushhh</span></strong><br />\n<br />\n上邊紅字係我覺得依幾日 時時刻mon po 既結論<br />\n希望大家 <strong>諗完</strong> 覺得岩既幫下手like <br />\n睇到聖經po發現有啲人 真係會like左就算唔會諗<br />\nlike 係好容易比人帶左風向 真係要自己諗<br />\n<br />\n幫下手push下個po 希望人手置頂熱門 提到係連登既大家"},{"pid":"929af4f3964c50bd2e4c87b20c192c6fa06f8e93","tid":1221774,"uid":259799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:17:34.000Z","msg":"Push"},{"pid":"6a5e6c1ccebcf66e55dfde2d416a955d990d6d0a","tid":1221774,"uid":259423,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:18:00.000Z","msg":"push"},{"pid":"e8d2102c7cd2ead2c790dd89527f234c4b32401a","tid":1221774,"uid":140984,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:19:28.000Z","msg":"push"},{"pid":"d7cddd8e4991bffd961e8f98b871d6dd5bea2458","tid":1221774,"uid":138188,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:20:28.000Z","msg":"pish"},{"pid":"09072c6e9d26950c5278b8b0944dbd4f2f6f4fdf","tid":1221774,"uid":122013,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-14T10:23:24.000Z","msg":"就係因為今次民眾冇領袖，對家搵唔到一個目標黎指責，佢地冇得再對焦抹黑混淆視聽！例如黃之鋒呀戴耀庭呀梁天琦呀一個目標人物都冇<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2c4d1c2cccf3299b900b837c02dd5600b6145498","tid":1221774,"uid":217452,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:23:33.000Z","msg":"Push"},{"pid":"e0b44fbe38b98d02817e5ae3cf23aecfe1eae1a5","tid":1221774,"uid":32749,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:24:36.000Z","msg":"Push"},{"pid":"6f35fc59c9f7804ef91af5849e233958abb85c2c","tid":1221774,"uid":90735,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:25:16.000Z","msg":"Push"},{"pid":"a93ec7243fad9be4ccbcdb5412a304b3ade9c6a5","tid":1221774,"uid":35015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T10:26:03.000Z","msg":"push"},{"pid":"7627495f4d2a1379a4420334f0af7fcb269ad277","tid":1221774,"uid":66221,"like":0,"dislike":0,"score":0,"quote":{"pid":"09072c6e9d26950c5278b8b0944dbd4f2f6f4fdf","tid":1221774,"uid":122013,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-14