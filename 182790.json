aces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"e7df560bacbb28660ff5e0c38f08d4c836df5af9","tid":182790,"uid":10465,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-04-02T04:52:25.000Z","msg":"Btw 今朝係試過正常開到機用到，功能正常<br />\n但係熄左機再開又打回原形<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"}]}