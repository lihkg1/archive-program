e":1,"quote":{"pid":"8915cb11cea82b1b395625e370058e34add434a8","tid":1724161,"uid":84471,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-11-15T12:05:51.000Z","msg":"我怕佢會餓死"},"citedBy":1,"replyTime":"2019-11-15T12:16:33.000Z","msg":"24個鐘 應該唔會掛<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-15T13:45:31.000Z","msg":"我剛剛食完放題 我決定絕食25個鍾<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-15T13:49:42.000Z","msg":"24個鐘好難死 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1b1f673a6052f6029fae38c72dcee8c533a9b204","tid":1724161,"uid":107686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T13:51:28.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"3701f822903959a5ee85f77e02afeec8d6fc30b4","tid":1724161,"uid":51960,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T13:55:07.000Z","msg":"push"},{"pid":"ff9648cb52dc91e81be603f332c83c2e97582c09","tid":1724161,"uid":261873,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-15T13:58:34.000Z","msg":"原來唔係第一次<br />\n<br />\n<a href=\"https://hk.news.appledaily.com/local/daily/article/20190611/20701192\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20190611%2F20701192&d=NKgE6Majit0rEYuBm%2F0CvgPtErjweJPees2C482IDEo%3D&h=e2a8a91b\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20190611%2F20701192&h=198ed618\" target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20190611/20701192</a><br />\n<br />\n2019年06月11日<br />\n羅哲斯絕食36小時聲援<br />\n<br />\n【本報訊】過百萬港人上街反送中惡法，要求港府撤回惡法，曾被入境處無理拒絕入境的英國人權組織「香港監察（Hong Kong Watch）」創辦人羅哲斯（Benedict Rogers，圖），香港時間昨日凌晨在facebook宣佈，英國時間今早開始為香港進行36小時絕食抗議，以聲援港人反送中惡法。他稱，本港立法會本周三開始審議有關修訂，不排除本周稍後時間再度絕食，並進行其他抗議行動，他強調商會、外國政府甚至上街市民已清晰表態，批評「港府繼續硬去馬」（all spoken out clearly, but the Hong Kong government still wants to press ahead）。<br />\n<br />\n促港府最起碼押後修例<br />\n羅哲斯指，絕食行動是希望港府撤回送中惡法，又或最起碼押後甚為荒謬、極為危險和具破壞性的《逃犯條例》修例，他批評今次修例將令沒有法治和獨立司法制度的北京政府，可要求引渡在香港的任何人，從而破壞有法治的香港與沒有法治的內地之間的「防火牆」，破壞香港僅餘的一國兩制。"},{"pid":"6431d3a4cb60d6bd29ffadb4a82e3e6b4e9426f7","tid":1724161,"uid":28252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T13:58:45.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"5700991fb109950a6fa1d0b55afafa17c2784b6d","tid":1724161,"uid":296108,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:06:37.000Z","msg":"Thank you Sir"},{"pid":"37d6b4a652a0837e80165d175fe90f1d65d2bf22","tid":1724161,"uid":52969,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:07:08.000Z","msg":"Push"},{"pid":"8c8ef42cc559fdbf1077a32bdb017500c44dc361","tid":1724161,"uid":29643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:08:12.000Z","msg":"推"},{"pid":"5ad2b4ab5827c594c621725f9b80e42aae4be4b4","tid":1724161,"uid":204377,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:11:42.000Z","msg":"推 人地咁有心 比下like都要啦<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"bf2e728dc83e3aad47d6eb1e7c867d53e817afb8","tid":1724161,"uid":218376,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:17:02.000Z","msg":"推"},{"pid":"2296dca6f1390e80f1745ab762735c6e7a2ec9df","tid":1724161,"uid":135211,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:21:36.000Z","msg":"同隻恐龍講絕食<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"10aed9526a9c4a9e2b5907aee10ee4b518accb65","tid":1724161,"uid":13143,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff9648cb52dc91e81be603f332c83c2e97582c09","tid":1724161,"uid":261873,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-15T13:58:34.000Z","msg":"原來唔係第一次<br />\n<br />\n<a href=\"https://hk.news.appledaily.com/local/daily/article/2