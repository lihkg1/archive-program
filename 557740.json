d":557740,"uid":33612,"like":0,"dislike":0,"score":0,"quote":{"pid":"0d1c7c9a287769e786a90eee320bec55ffad6ea2","tid":557740,"uid":126221,"like":2,"dislike":0,"score":2,"quote":{"pid":"49487771867eda5034596cf0a8b7cbd5e863d7bc","tid":557740,"uid":3131,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-02-11T15:46:48.000Z","msg":"兩包應唔應付到體力勞動時候既一餐?"},"citedBy":1,"replyTime":"2018-02-11T16:03:58.000Z","msg":"唔好意思，頭先眼殘睇錯左。<br />\n<br />\n一包份量唔夠，熱量勉強。<br />\n兩包份量 OK，熱量足夠。<br />\n三包 ... 無謂啦，頂住檔放工去食餐好既好過啦。"},"citedBy":1,"replyTime":"2018-02-11T16:06:56.000Z","msg":"一包400yen都幾貴<br />\n食得飽仲貴過叫外賣<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-11T16:10:53.000Z","msg":"我買時特價 300 yen ... <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n不過真係幾貴，如果要平應該優先考慮 calorie mate，<br />\n不過 calorie mate 放得唔耐呢下仆街，唔係我都想入一細箱返黎。<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n要食呢 d 就係因為無外賣，或者行唔開；<br />\n有得叫外賣邊個想食 d 咁既濕鳩野 ... <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ecae84e56797ddf015fbc060d6d9a306c16ac622","tid":557740,"uid":126221,"like":0,"dislike":0,"score":0,"quote":{"pid":"be6db30845c69c4788fe42e99b046cc1704c14a5","tid":557740,"uid":20867,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-11T16:10:24.000Z","msg":"注水 = 熱水？"},"citedBy":0,"replyTime":"2018-02-11T16:12:33.000Z","msg":"我今次落熱水，15 分鐘搞掂食得。"},{"pid":"5bf2fd9150d87bbf269c1079403b95d62ab75b48","tid":557740,"uid":9736,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c41b0322796fa9df14a3f61b14349124f248d29","tid":557740,"uid":36435,"like":0,"dislike":4,"score":-4,"quote":{"pid":"d37e399c89700b7dff3961dded037cd0448ac74a","tid":557740,"uid":9736,"like":7,"dislike":0,"score":7,"quote":{"pid":"467ef0cc4c2814b53507e49706918166f82d7fff","tid":557740,"uid":36435,"like":2,"dislike":24,"score":-22,"citedBy":2,"replyTime":"2018-02-11T15:50:12.000Z","msg":"咁都要出報告<img src=\"/assets/faces/norma