-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Finternational%2Fdaily%2Farticle%2F20121117%2F18069182&d=LSsgDEuqvL%2F6lC7PehFbg9Rt30ToQ9uN2xIpFOlVN1U%3D&h=23a5ea4c\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Finternational%2Fdaily%2Farticle%2F20121117%2F18069182&h=fc9806d9\" target=\"_blank\">https://hk.news.appledaily.com/international/daily/article/20121117/18069182</a>"},{"pid":"3ea8d3a5a5c2b0a972193b5c9f7d17cdeb971061","tid":1475060,"uid":216276,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T11:58:02.000Z","msg":"<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"866a5e31478b3daba00c8cff836908c3e1468c59","tid":1475060,"uid":270307,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-15T12:01:56.000Z","msg":"<img src=\"https://na.cx/i/6974gvh.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6974gvh.gif&h=a41a2418&s={SIZE}\" />"},{"pid":"ce261897ac3253202c234a95a0f3e1be532db3e5","tid":1475060,"uid":216276,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T13:23:21.000Z","msg":"<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"10e5309729418817b3c939202e066929a2ee0996","tid":1475060,"uid":216276,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T14:24:56.000Z","msg":"<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},{"pid":"2f961b177e7621743d6d353e8ccf62f08bf29e97","tid":1475060,"uid":15371,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T14:32:02.000Z","msg":"屈機"},{"pid":"e11d80778d92ef623ce37c2d1aee7f6e9a9ac054","tid":1475060,"uid":216276,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T04:07:58.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"}]}