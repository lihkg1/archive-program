/lm2/smile.gif\" class=\"hkgmoji\" />"},{"pid":"78e84715577d32b8ef926f9190158b67cb0d4e70","tid":2061750,"uid":165749,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-06-12T15:30:08.000Z","msg":"亂咁打針都得？揾十幾萬一個月個啲精神科精英醫生呢？<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" />"},{"pid":"297d2c39a92a485196fe205121818de1cf229146","tid":2061750,"uid":65764,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-12T15:30:13.000Z","msg":"死因裁判官係陳碧橋 <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"6993320b811c55b35066133f5b60128d1057a040","tid":2061750,"uid":26770,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-12T15:30:30.000Z","msg":"明居正教授就係研究港共暴行的權威<br />\n大家得閒睇下就明香港紀律部隊係點殘害香港人"},{"pid":"32b15cc0df6f1d5dd620fc69d053dd6ae6531246","tid":2061750,"uid":239266,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T15:30:49.000Z","msg":"Push"},{"pid":"f8fc525d8f364fb36eadc19016fe738cdc5e8526","tid":2061750,"uid":26770,"like":7,"dislike":0,"score":7,"quote":{"pid":"78e84715577d32b8ef926f9190158b67cb0d4e70","tid":2061750,"uid":165749,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-06-12T15:30:08.000Z","msg":"亂咁打針都得？揾十幾萬一個月個啲精神科精英醫生呢？<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-12T15:32:02.000Z","msg":"<a href=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr02-03%2Fchinese%2Fpanels%2Fse%2Fpapers%2Fse0123cb2-947-01-c.pdf&amp;d=q8peb0UcLz3Z6%2FQAtnUTjJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&amp;h=f3bb84d7\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fr.lihkg.com%2Flink%3Fu%3Dhttps%253A%252F%252Fwww.legco.gov.hk%252Fyr02-03%252Fchinese%252Fpanels%252Fse%252Fpapers%252Fse0123cb2-947-01-c.pdf%26d%3Dq8peb0UcLz3Z6%252FQAtnUTjJ1QB7Ma9ovE6nvZW%252BRTqP4%253D%26h%3Df3bb84d7&d=q8peb0UcLz3Z6%2FQAtnUTjJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=0567789a\" data-auto-link target=\"_blank\">https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr02-03%2Fchinese%2Fpanels%2Fse%2Fpapers%2Fse0123cb2-947-01-c.pdf&amp;d=q8peb0UcLz3Z6%2FQAtnUTjJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&amp;h=f3bb84d7</a><br />\n<br />\n話會完善紀錄<br />\n但次次囚犯離奇死亡,內臟打到爆裂<br />\n<br />\n<ins>監獄閉路就話壞左<br />\n同大陸係一樣的</ins>"},{"pid":"0590a9f79a41cf644f4c29408a7acc144f7489b7","tid":2061750,"uid":26770,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-06-12T15:34:52.000Z","msg":"警暴的做法根本就係黑懲一哥胡英明的手下用開<br />\n班人雞姦囚犯大家知唔知<br />\n<br />\n其實懲教係紀律部隊中最反人類<br />\n<ins>最踴躍撈特務警察害後生係黑懲</ins>"},{"pid":"af221ac4dbc77a3dfffa0f9b27c174ad93033b70","tid":2061750,"uid":220985,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T15:35:37.000Z","msg":"死仆街"},{"pid":"3e88b483b096cbd740852a44e569e278fa92de8c","tid":2061750,"uid":33263,"like":0,"dislike":0,"score":0,"quote":{"pid":"6993320b811c55b35066133f5b60128d1057a040","tid":2061750,"uid":26770,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-12T15:30:30.000Z","msg":"明居正教授就係研究港共暴行的權威<br />\n大家得閒睇下就明香港紀律部隊係點殘害香港人"},"citedBy":0,"replyTime":"2020-06-12T15:36:03.000Z","msg":"沒錯<br />\n下場只有槍決"},{"pid":"af28fda15efd6463653ef7fbeaba8cbbf9530512","tid":2061750,"uid":26770,"like":3,"dislike":0,"score":3,"quote":{"pid":"78e84715577d32b8ef926f9190158b67cb0d4e70","tid":2061750,"uid":165749,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-06-12T15:30:08.000Z","msg":"亂咁打針都得？揾十幾萬一個月個啲精神科精英醫生呢？<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-12T15:42:31.000Z","msg":"呢班藍絲醫生根本無良心<br />\n班人打針時係好清楚呢個份量個犯係會死<br />\n<br />\n因為懲教一哥要靠呢班殺人醫恐嚇囚犯所以班醫生從不受追究<br />\n呢班人睇邊個唔順眼就殺,事後保密到連立法會都查唔到打針者的身份"},{"pid":"1501e5f8d6e27ed48cb92a034a89e9678d625fd0","tid":2061750,"uid":152241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T15:43:56.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"221268a01b912860313e48cc307c2d3d13f4822c","tid":2061750,"uid":161185,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T15:45:03.000Z","msg":"推"},{"pid":"81ff1939b273d058113c9c91aff7adaaa6d18128","tid":2061750,"uid":92385,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T15:46:56.000Z","msg":"Push"},{"pid":"46a98a902bfbbbc56482c726176e99e589b02ae4","tid":2061750,"uid":19126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T15:48:58.000Z","msg":"<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"22b065cc70042ddb8f8d2a71d2e5fbab789f0673","tid":2061750,"uid":26770,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T15:54:29.000Z","msg":"<a href=\"http://akoe123.blogspot.com/2018/11/blog-post.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fakoe123.blogspot.com%2F2018%2F11%2Fblog-post.html&d=q8peb0UcLz3Z6%2FQAtnUTjJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=ecdbe238\" data-auto-link target=\"_blank\">http://akoe123.blogspot.com/2018/11/blog-post.html</a><br />\n<br />\n當時案情<br />\n<br />\n二十四小時監察病房全部無事,但拍攝死者病床的閉路電視死前7小時紀錄遭破壞<br />\n家人認屍期間發現死者的右肩及腋下有十數個針孔及瘀傷, 就算死者入倉前係道友, 屍體上的針孔明顯係新傷<br />\n<br />\n[驗屍時針孔處還有剛凝固血跡顯示死者在被注射藥物不久便暴斃]<br />\n<br />\n-------------------<br />\n屍體藥物反應<br />\n藍偉文剖驗死者屍體時<br />\n發現死者每毫升血液的chlorpromazine<br />\n含量高達九點七微克<br />\n<br />\n<br />\n<ins>如果係條友比人拉前自己打針,身體維持呢個份量一早暴斃左, 注射時間一定係小欖精神病治療中心時</ins><br />\n<br />\n<br />\n死者係中心的<ins>藥物紀錄明顯係管方造假</ins>"},{"pid":"51917fc07409e9565cacc775f577d61f6e72e224","tid":2061750,"uid":287422,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T15:55:16.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"4d6acdc1e51c20bcd5653ee5409cbc6bc91e2672","tid":2061750,"uid":26770,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-12T16:05:19.000Z","msg":"<span style=\"color: red;\">2005年6月，張志堅母親蘇鐵華獲得法援後<br />\n正式入稟高院，控告懲教署署長疏忽<br />\n指其子是遭懲教人員施以酷刑、不人道對待<br />\n或是遭懲署人員毆打致死，要求懲教署賠償<br />\n2006年2月22日，張志堅母親蘇鐵華表示<ins><br />\n政府決定和解，向她賠償四十五萬元</ins><br />\n</span><br />\n<br />\n香港政府指使警畜輪姦少女都唔賠錢仲誣告人<br />\n<ins>呢單賠錢咪就係因為合理化單野的專家證人根本全部9up講大話,香港政府怕攪大</ins>"},{"pid":"006ddc5bb86fe72437e59aa3ed5b6ae4b45d23da","tid":2061750,"uid":315171,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-12T16:11:19.000Z","msg":"老實講呢啲地方透明度極低<br />\n除咗香港其他國家都係精神病院最黑暗<br />\n呢啲地方一曝光實牽涉好多地方<br />\n最後一定係世界級新聞<br />\n<br />\n如果我有能力實幫手查<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"af74b03d008e81ab0e58c0abc878aee2547e64ed","tid":2061750,"uid":70487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T16:59:31.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />推要手足睇到"},{"pid":"fc94acc61ad9c1f564d42970302070496cba4349","tid":2061750,"uid":225798,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T17:06:28.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"ebe137841dee0913be5efe065248830ad71e9f07","tid":2061750,"uid":271603,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T17:06:48.000Z","msg":"P牌仔幫推呀<br />\n屌你老母 所有執法部門都一撚樣"},{"pid":"e7faaa16e6139bd68f0831e5834988e509678c4a","tid":2061750,"uid":223156,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T17:30:16.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"177b26fb035a47fc600d100870359a03ea1d5fc4","tid":2061750,"uid":26770,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-03T22:14:20.000Z","msg":"<span style=\"font-size: xx-large;\">打過百粒入血一定係故意殺人<br />\n最後因裁判官指示陪審團不用考慮「死於意外」或「非法被殺」<br />\n引導他們選擇餘下唯一的裁決，即<span style=\"color: red;\">死因不明<br />\n</span><br />\n</span><br />\n<br />\n<br />\n驗屍時<br />\n發現死者每毫升血液的chlorpromazine含量高達九點七微克<br />\n<br />\n<ins>「一個人要服<ins>過百粒</ins>氯丙嗪<br />\n才會達到這個含量，並且要以<ins>肌肉注射</ins>方式<br />\n才可達致這種高濃度。」</ins>"}}