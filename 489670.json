洗check"},{"pid":"25f6cc460624c2bc2a58329b1b5c6d9906f6fcb4","tid":489670,"uid":100347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-05T08:18:49.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"7cade7a372f8388b22771ad00abf4999d1795cae","tid":489670,"uid":20898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-05T08:19:15.000Z","msg":"你有無搞撚錯呀？<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n得一張咁少<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"29284b14090f4adb455554557278dba14af0d77f","tid":489670,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-05T08:20:39.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"e4918b716f903d78d397ecdb6a33cd8ef4b47c2d","tid":489670,"uid":10323,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-05T08:20:46.000Z","msg":"好中意佢啲手指<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"c6c8a46aec74f2482bdf1069671f4557176d2c83","tid":489670,"uid":2507,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-05T08:29:38.000Z","msg":"cls，我以為伏圖<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n點知入來一睇<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n立刻馬上即刻正評咗<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"eb34f00ca402b12e53cb94c1aec1a76f6ba53de8","tid":489670,"uid":6845,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-05T08:37:38.000Z","msg":"<blockquote>cls，我以為伏圖<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n點知入來一