2F26a0.png&h=b9abaf52&s={SIZE}\" /><br />\n<br />\n謂：「這名教師⋯ 將古人研發紙張的目的說成是代替龜板、動物骨頭等以「防止動物絕種」⋯內容明顯有嚴重錯誤，甚至是無稽之談。」<br />\n<br />\n問題係：這「內容明顯嚴重錯誤⋯甚至無稽之談」的來源、竟然就係香港教育局課程資源組小學常識科、中國四大發明(上) 視訊 <img src=\"https://static.xx.fbcdn.net/images/emoji.php/v9/t52/1/16/1f923.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.xx.fbcdn.net%2Fimages%2Femoji.php%2Fv9%2Ft52%2F1%2F16%2F1f923.png&h=8846d5c4&s={SIZE}\" /><br />\n<br />\n趁教育局未刪除「證據」大家嗱嗱聲快D去睇（02:40）<img src=\"https://static.xx.fbcdn.net/images/emoji.php/v9/t8a/1/16/1f447_1f3fb.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.xx.fbcdn.net%2Fimages%2Femoji.php%2Fv9%2Ft8a%2F1%2F16%2F1f447_1f3fb.png&h=127e7441&s={SIZE}\" /><br />\n<a href=\"https://www.hkedcity.net/etv/resource/538029781\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hkedcity.net%2Fetv%2Fresource%2F538029781&d=28xXuG3%2BZgR4L17YEenOIkBBI%2BG%2BtQAW9Loz3QxUp%2BM%3D&h=28852e00\" target=\"_blank\">https://www.hkedcity.net/etv/resource/538029781</a>"},{"pid":"bcb133aa4ea98c219bd4bb25ac9523af3e321605","tid":2284011,"uid":52946,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-11-13T03:48:13.000Z","msg":"特衰政府不停打壓<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"b18dabed455e09a1689098fde10dc5be46f6bcc5","tid":2284011,"uid":39365,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-11-13T03:51:58.000Z","msg":"有打壓? 無呀, 都無教師抗議, 即係無打壓啦"},{"pid":"5ab1803c5ac41aa4e423b6768fd123ecfdcc57e5","tid":2284011,"uid":810,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-11-13T03:54:38.000Z","msg":"BACKUP"},{"pid":"7ab4d6a86db74f5fb7b51d16fa9a49b484af26ba","tid":2284011,"uid":35430,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-11-13T04:13:51.000Z","msg":"<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />份資料來源明明係教畜局都唔得"},{"pid":"a9e4d7be4b29fc32c0b1d78c5de9d026fa42b504","tid":2284011,"uid":137725,"like":0,"dislike":0,"score":0,"citedB