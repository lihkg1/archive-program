%E5%B9%95%E6%88%AA%E5%9C%96-2021-01-13-22.04.29.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.unwire.hk%2Fwp-content%2Fuploads%2F2021%2F01%2F%25E8%259E%25A2%25E5%25B9%2595%25E6%2588%25AA%25E5%259C%2596-2021-01-13-22.04.29.jpg&h=a18a04a9&s={SIZE}\" />"},"citedBy":0,"replyTime":"2021-01-14T02:40:12.000Z","msg":"傳比藍屍，等冇人用whatsapp<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"4da7fb0cfeb76174b6f482dd4288a840b6fbe992","tid":2365350,"uid":170142,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-14T02:52:09.000Z","msg":"此回覆已被刪除"},{"pid":"f0cbee88b9cf00c6baffb4975d70b7d80906e152","tid":2365350,"uid":113326,"like":1,"dislike":0,"score":1,"quote":{"pid":"004574a6f6d07b185d0c1debb7963307202213e5","tid":2365350,"uid":140335,"like":100,"dislike":0,"score":100,"citedBy":1,"replyTime":"2021-01-13T17:02:38.000Z","msg":"<img src=\"https://na.cx/i/ntPAsvv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FntPAsvv.jpg&h=b7f0f893&s={SIZE}\" />"},"citedBy":1,"replyTime":"2021-01-14T03:29:13.000Z","msg":"第一次見<br />\n好好笑<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4a17f67c7708e9002b1a40781d79009647d7dd2d","tid":2365350,"uid":63940,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-14T03:46:24.000Z","msg":"有人偷睇你沖涼，所以索性除哂衫周街走任人睇？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"900bc1170eedcb01f9c1d42772aa27bd519a4730","tid":2365350,"uid":136147,"like":0,"dislike":0,"score":0,"quote":{"pid":"69734cd25319f12e8e8db495dca30c7f5d3c6b6f","tid":2365350,"uid":52006,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-13T18:03:32.000Z","msg":"支持藍屍轉哂去we7<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-14T04:14:01.000Z","msg":"班藍絲傾走資同移民都記得要用we7 唔好比美帝監視到<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /