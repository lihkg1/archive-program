d":1262840,"uid":781,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-01T16:25:31.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">走狗！</span></span>"},"citedBy":0,"replyTime":"2019-07-01T16:34:59.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">漢奸！</span></span>"},{"pid":"ef4e731e08b519b488d746843bf59f3e80057b82","tid":1262840,"uid":45706,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-01T16:44:30.000Z","msg":"689條撚樣都會出黎做下戲<br />\n屌你老母個柒婆忙撚到咁？"},{"pid":"47b57665fec8589c0668518ab519722fd942c631","tid":1262840,"uid":997,"like":0,"dislike":0,"score":0,"quote":{"pid":"ef4e731e08b519b488d746843bf59f3e80057b82","tid":1262840,"uid":45706,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-01T16:44:30.000Z","msg":"689條撚樣都會出黎做下戲<br />\n屌你老母個柒婆忙撚到咁？"},"citedBy":0,"replyTime":"2019-07-01T16:45:47.000Z","msg":"佢唔會認錯<br />\n不過主因係佢根本唔識拆局 淨係搵班黑警黎頂"}]}