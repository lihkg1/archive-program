."},{"pid":"f36ffb00e4196dce69d75725791669b6b68af276","tid":530723,"uid":40867,"like":7,"dislike":10,"score":-3,"quote":{"pid":"b0bb1bfa55411e20915a530c926f22891d9da3f8","tid":530723,"uid":139815,"like":10,"dislike":4,"score":6,"citedBy":1,"replyTime":"2018-01-16T05:20:15.000Z","msg":"日本萬歲<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-01-16T05:24:38.000Z","msg":"一定係d反日撚作新聞<br />\n日本人咁好<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"1c6bb7711cd6abc1b29614abd97200721fb1e3bc","tid":530723,"uid":139815,"like":2,"dislike":7,"score":-5,"quote":{"pid":"f36ffb00e4196dce69d75725791669b6b68af276","tid":530723,"uid":40867,"like":7,"dislike":10,"score":-3,"quote":{"pid":"b0bb1bfa55411e20915a530c926f22891d9da3f8","tid":530723,"uid":139815,"like":10,"dislike":4,"score":6,"citedBy":1,"replyTime":"2018-01-16T05:20:15.000Z","msg":"日本萬歲<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-01-16T05:24:38.000Z","msg":"一定係d反日撚作新聞<br />\n日本人咁好<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-16T05:25:27.000Z","msg":"係...<br />\n明明中國,韓國,台灣,泰國都會咁<br />\n但班反日撚係都要話日本"},{"pid":"d3b8ff8012f66ec86ec764c1a8bb82b3579f8307","tid":530723,"uid":14812,"like":2,"dislike":11,"score":-9,"citedBy":0,"replyTime":"2018-01-16T05:25:40.000Z","msg":"支那狗又改新聞抹黑日本"},{"pid":"f05cb8cf5811cd05e1ba5a25582a71605a854b47","tid":530723,"uid":34562,"like":18,"dislike":0,"score":18,"citedBy":0,"replyTime":"2018-01-16T05:27:57.000Z","msg":"咁點解日本非禮咁易告得入？"},{"pid":"54e39c20a0d82a279b902416de56ad3df3821fb3","tid":530723,"uid":134071,"like":0,"dislike":1,"score":-1,"quote":{"pid":"f79caa7ad0029c68d5ff6b94daf81ace6fbe75e4","tid":530723,"uid":26506,"like":21,"dislike":1,"score":20,"quote":{"pid":"68a99f23a789415ab0987ff9e157feac516151e2","tid":530723,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-16T05:04:14.000Z","msg":"<a href=\"h