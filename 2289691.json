2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1561306-20201122.htm%3FspTabChangeable%3D0&d=gkHqMR5YDMJAUJmZ80XM4xPX6nNrjY8iteK6A9FjwF0%3D&h=254c9b59\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1561306-20201122.htm%3FspTabChangeable%3D0&h=f4f6dc20\" target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1561306-20201122.htm?spTabChangeable=0</a><br />\n<br />\n全國港澳研究會理事田飛龍日前說，支聯會屬政治顛覆性組織，涉違反3條本地法例和《港區國安法》。支聯會主席李卓人重申，支聯會堅持5大綱領，堅持爭取民主無罪，絕不會放棄或退縮。<br />\n<br />\n李卓人說，支聯會30年來所做的工作，一直以和平方法推行，從來沒有問題，假如現在變得有問題，不是支聯會改變，而是香港改變，明年6月4日會繼續舉辦集會，已預訂維園場地。<br />\n<br />\n對於田飛龍說，支聯會籌辦網上「六四記憶人權博物館」是想搶奪歷史話語權，李卓人說，支聯會要以真相對抗謊言。"},{"pid":"c4cddbafc0e8283dc8d26645ee3567b6b3a6e913","tid":2289691,"uid":313579,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-22T08:05:04.000Z","msg":"民主建港聯盟呢？"},{"pid":"ccfd380c6b4fc95735d433e31f9c757e5bb85bef","tid":2289691,"uid":51701,"like":0,"dislike":0,"score":0,"quote":{"pid":"40db81c6eeab1683d3718eade0baf4c54b4b87b9","tid":2289691,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-22T07:34:25.000Z","msg":"<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1561306-20201122.htm?spTabChangeable=0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1561306-20201122.htm%3FspTabChangeable%3D0&d=gkHqMR5YDMJAUJmZ80XM4xPX6nNrjY8iteK6A9FjwF0%3D&h=254c9b59\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1561306-20201122.htm%3FspTabChangeable%3D0&h=f4f6dc20\" target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1561306-20201122.htm?spTabChangeable=0</a><br />\n<br />\n全國港澳研究會理事田飛龍日前說，支聯會屬政治顛覆性組織，涉違反3條本地法例和《港區國安法》。支聯會主席李卓人重申，支聯會堅持5大綱領，堅持爭取民主無罪，絕不會放棄或退縮。<br />\n<br />\n李卓人說，支聯會30年來所做的工作，一直以和平方法推行，從來沒有問題，假如現在變得有問題，不是支聯會改變，而是香港改變，明年6月4日會繼續舉辦集會，已預訂維園場地。<br />\n<br />\n對於田飛龍說，支聯會籌辦網上「六四記憶人權博物館」是想搶奪歷史話語權，李卓人說，支聯會要以真相對抗謊言。"},"citedBy":0,"replyTime":"2020-11-22T0