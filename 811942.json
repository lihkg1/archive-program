/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-10T15:53:28.000Z","msg":"<a href=\"http://evchk.wikia.com/wiki/%E7%88%B6%E8%A6%AA%E5%9B%A0%E8%B2%B7%E9%8C%AFPSP%E8%A2%AB%E6%AF%86%E6%89%93\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fevchk.wikia.com%2Fwiki%2F%25E7%2588%25B6%25E8%25A6%25AA%25E5%259B%25A0%25E8%25B2%25B7%25E9%258C%25AFPSP%25E8%25A2%25AB%25E6%25AF%2586%25E6%2589%2593&d=SuDdN0eGUOeRjBjatkZNKY9%2BoveFa0K0Z8Wn6wXPu4k%3D&h=139430db\" target=\"_blank\">http://evchk.wikia.com/wiki/%E7%88%B6%E8%A6%AA%E5%9B%A0%E8%B2%B7%E9%8C%AFPSP%E8%A2%AB%E6%AF%86%E6%89%93</a><br />\n《父親因買錯PSP被毆打》，是一篇在2004年12月，日本索尼公司（Sony）手提遊戲機PlayStation Portable（PSP）公開發售初期，開始於日本網絡流傳的潮文。文中聲稱一個父親排隊幫兒子買PSP，但最後卻買了世嘉（SEGA）的Game Gear，因而被兒子用法式麵包毆打。此文章隨著PSP在香港引起的熱潮，成為回帶率極高的潮文。由於此文行文幽默，PSP變Game Gear也太誇張，所以港、日網民多認為此文只是惡作劇的文章。<br />\n<br />\n原來咁多年 之前都唔知<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"55a0c62abcf3acc0c5022095402e9cbeeb80e757","tid":811942,"uid":171594,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2018-09-11T01:20:02.000Z","msg":"樓豬發放假消息，驚已報<img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" />"},{"pid":"a3331d59991618cdaa2c1268a4e8093cbc851683","tid":811942,"uid":76632,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-09-11T01:52:44.000Z","msg":"老豆都冇飛"},{"pid":"fc714395fadeb107690d10d1c2f76950ace18657","tid":811942,"uid":7699,"like":3,"dislike":0,"score":3,"quote":{"pid":"24a1b01f1f38327ad6e9a9f2b1b4871f57ed34a1","tid":811942,"uid":109690,"like":46,"dislike":0,"score":46,"citedBy":1,"replyTime":"2018-09-09T17:55:27.000Z","msg":"<img src=\"https://c1.staticflickr.com/5/4096/4918861762_d693c45a70.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fc1.staticflickr.com%2F5%2F4096%2F4918861762_d693c45a70.jpg&h=73856ee7&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-09-11T02:08:36.000Z","msg":"蔡楓華有咩問題"},{"pid":"32853967616ff01e4add882f8f259d3e6a473142","tid":811942,"uid":62247,"like":0,"di