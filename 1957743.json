ets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1514f16c61f109dd67c76f56a6d2a7096788675c","tid":1957743,"uid":320846,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T06:23:37.000Z","msg":"問卜者稱呼 j<br />\n問卜者性別 絲<br />\n對象稱呼 j<br />\n與對象現時關係 朋友<br />\n問題 和他之前有誤會,請問要如何做才能令佢回心轉意?<br />\n<br />\n謝謝"},{"pid":"bd7f20ce1d90db061a19fe677b69e96514129d2a","tid":1957743,"uid":57070,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T09:57:18.000Z","msg":"問卜者稱呼 S<br />\n問卜者性別 女<br />\n對象稱呼 J<br />\n與對象現時關係 曖昧<br />\n問題 我地有冇機會認真發展<br />\n<br />\nThanks 🙏🏻"},{"pid":"ee3fc8e2a53f1c39dceabefebdc74a3784a29713","tid":1957743,"uid":62152,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T10:54:10.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"2bba4c61892322bb4d8c911132076a0fd66d7f69","tid":1957743,"uid":271362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T11:00:56.000Z","msg":"問卜者稱呼 k<br />\n問卜者性別 女<br />\n對象稱呼 s<br />\n與對象現時關係 好朋友<br />\n問題 有冇機會一齊"},{"pid":"499ca5dba48ffb28b37387fc033d9bdfed9f7a86","tid":1957743,"uid":141550,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T12:14:58.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"0b225769be61c230023dd94c5257f7f4072c8001","tid":1957743,"uid":210059,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T12:26:51.000Z","msg":"<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"cf3b6cc7f7618af653992ed03a95ec2b34f795fa","tid":1957743,"uid":130955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T12:43:31.000Z","msg":"問卜者稱呼 Jo<br />\n問卜者性別 女<br />\n對象稱呼 k<br />\n與對象現時關係 情侶<br />\n問題 : 有冇得長發展落去"},{"pid":"4e1d60c6081192f9379c8fdf2944f67d6f49a134","tid":1957743,"uid":89153,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T13:17:18.000Z","msg":"問卜者稱呼 C<br />\n問卜者性別（愛情/友情適用）F<br />\n對象稱呼（如有）K<br />\n與對象