5%25A5%25B3%25E5%25AD%2590%25E5%25B1%258F%25E9%25A2%25A8%25E5%25BE%258C%25E4%25BD%259C%25E4%25BE%259B%25E5%2593%25BD%25E5%2592%25BD-%25E4%25B8%2589%25E4%25BA%25BA%25E5%2590%25A6%25E8%25AA%258D%25E9%259D%259E%25E6%25B3%2595%25E7%25A6%2581%25E9%258C%25AE%25E5%258F%2597%25E5%25AF%25A9%2F&d=nAM79WGQOJ1S2Ssbv1FDY3s01o1BQ7dYS%2FTJpuaPCiE%3D&h=5196654f\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F7-7-%25E4%25B9%259D%25E9%25BE%258D%25E9%2581%258A%25E8%25A1%258C-%25E8%25A2%25AB%25E8%25B3%25AA%25E7%2596%2591%25E6%2598%25AF%25E4%25BE%25BF%25E8%25A1%25A3%25E8%25AD%25A6%25E9%2581%25AD%25E5%258C%2585%25E5%259C%258D-%25E5%25A5%25B3%25E5%25AD%2590%25E5%25B1%258F%25E9%25A2%25A8%25E5%25BE%258C%25E4%25BD%259C%25E4%25BE%259B%25E5%2593%25BD%25E5%2592%25BD-%25E4%25B8%2589%25E4%25BA%25BA%25E5%2590%25A6%25E8%25AA%258D%25E9%259D%259E%25E6%25B3%2595%25E7%25A6%2581%25E9%258C%25AE%25E5%258F%2597%25E5%25AF%25A9%2F&h=0fa3c9fd\" data-auto-link target=\"_blank\">https://www.thestandnews.com/court/7-7-%E4%B9%9D%E9%BE%8D%E9%81%8A%E8%A1%8C-%E8%A2%AB%E8%B3%AA%E7%96%91%E6%98%AF%E4%BE%BF%E8%A1%A3%E8%AD%A6%E9%81%AD%E5%8C%85%E5%9C%8D-%E5%A5%B3%E5%AD%90%E5%B1%8F%E9%A2%A8%E5%BE%8C%E4%BD%9C%E4%BE%9B%E5%93%BD%E5%92%BD-%E4%B8%89%E4%BA%BA%E5%90%A6%E8%AA%8D%E9%9D%9E%E6%B3%95%E7%A6%81%E9%8C%AE%E5%8F%97%E5%AF%A9/</a>"},"citedBy":1,"replyTime":"2021-02-22T07:16:55.000Z","msg":"佢唔下點解D  黑警打爆人個頭可以無犯法<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-22T07:50:05.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"8141d79c4f4185f6f5b229b3102bdbfa1feb422e","tid":2417811,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"e842e3417238fcbff1abc3126445101ae62378eb","tid":2417811,"uid":110043,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-02-22T07:18:48.000Z","msg":"又係練狗官"},"citedBy":0,"replyTime":"2021-02-22T07:50:15.000Z","msg":"<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" />"},{"pid":"02ebe1554b5e0fd71eda2be4ee35bc59e8b2c025","tid":2417811,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-22T07:51:05.000Z","msg":"前年7月7日網民發起九龍區大遊行，有女子在旺角遭群眾懷疑是拍攝在場人士的便衣女警，遭包圍及要求刪除影片。事後有教師及學生等三名男女分別被控非法禁錮及非禮等罪，案件今於區域法院開審。女事主今出庭作供，當憶述被示威者圍困時語帶哽咽，法官練錦鴻見狀安慰她謂：「你今日上嚟係好勇敢嘅事。」又要求職員遞水給她喝。其後庭上播放現場片段，當畫面顯示記者及旁人拍攝女事主時，練官三番四次強調：「旁邊影相啲人冇人幫手。」<br />\n<br />\n其間X澄清自己並非女警，要求蘇放手，並試圖離開現場。蘇與示威者立即從後追趕。此時次被告吳睿智出現，阻止X離開，緊捉X的左臂，並與蘇及其他人繼續包圍X。吳用雙手抓住X的肩膊，蘇則用雙手抓住X的右前臂。最終X成功逃脫，跑向彌敦道與山東街交界的警方防線，並向警員表示曹示威者包圍施襲。<br />\n<br />\n其後X前往廣華醫院驗傷，被診斷四肢有多處瘀傷，右眼眉上方輕微腫脹及觸痛。稍後她到警署報案。有傳媒清楚拍攝到三名被告於案發現場，警方其後拘捕三人並搜屋。<br />\n<br />\nX嘗試拉起自己的衣衫遮著面容，掙扎時不小心打歪身後男子的面罩，並看見男子臉容。X又自言曾衝向正在拍攝的記者求救，「點知佢哋縮開」。最終X跑向警方防線求救，獲女警帶上警車。<br />\n<br />\n其後庭上播放現場片段，可見X身材瘦削、束短髮。示威者向已遭制服的X叫罵「Madam」、「打人呀」。片中X矢口否認是女警，又不斷大叫「救命」、「搶嘢呀」。當片段顯示記者及旁人拍攝X時，練官三番四次強調：「旁邊影相啲人冇人幫手。」<br />\n<br />\n<a href=\"https://hk.appledaily.com/local/20210222/ZVZWKXOZBFASPEILIWKPSZPC6M/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210222%2FZVZWKXOZBFASPEILIWKPSZPC6M%2F&d=nAM79WGQOJ1S2Ssbv1FDY3s01o1BQ7dYS%2FTJpuaPCiE%3D&h=d84b6ab0\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210222%2FZVZWKXOZBFASPEILIWKPSZPC6M%2F&h=a2c2c96c\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20210222/ZVZWKXOZBFASPEILIWKPSZPC6M/</a>"},{"pid":"ea375a677eb45965016df59ba6e02518b628854d","tid":2417811,"uid":33263,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-22T07:51:28.000Z","msg":"差佬開槍 打爆頭 唔見你話 點解咁<img src=\"/assets/faces/normal/bye.gif\" class=\