,"tid":1359221,"uid":60872,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T09:52:17.000Z","msg":"推"},{"pid":"04219c2172637c2ba72073f3622ac4abe9450b6b","tid":1359221,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T12:34:44.000Z","msg":"推！求圖！"},{"pid":"48fc9c1cf287328035676e32f8b574e7b4f00a0d","tid":1359221,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T12:43:56.000Z","msg":"push"},{"pid":"3f84d102c90a43af816f49e858b27ae2348c9e3b","tid":1359221,"uid":258862,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T12:44:29.000Z","msg":"推"},{"pid":"d482836655918faa4bf5430771db38b95917ffcc","tid":1359221,"uid":277187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T12:47:05.000Z","msg":"藍絲已組早我地一步宣傳緊727<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/8hwdWh6.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8hwdWh6.png&h=ab5286c1&s={SIZE}\" /><br />\n<br />\n所以我寫左呢段野做whatsapp文宣<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: violet;\">各位元朗區嘅居民大家好<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n收到你地whatsapp關於727嘅遊行安排<br />\n睇嚟大家對當日嘅遊行有太多幻想喇<br />\n今次遊行係針對7月21號白衣人於元朗西鐵站及周邊進行嘅大規模恐怖襲擊而成立<br />\n自從721呢個事件，成個元朗變到死城一樣<br />\n大家收工都提心吊膽，人心惶惶，日日唔知幾時再見到班白衫人<br />\n就算行過西鐵站都會有種恐懼<br />\n而家好多即使唔係住喺元朗嘅居民<br />\n都好希望做返一啲野去幫元朗市民打氣<br />\n我地亦都希望透過和平嘅遊行去帶出反三黑嘅訊息<br />\n「反黑警、反鄉黑、反黑政」<br />\n希望透過遊行去話畀今次大規模恐怖襲擊嘅策劃人聽<br />\n我地唔會向黑勢力低頭！<br />\n請大家唔好相信個啲燒村、拆祠堂、破壞閉路電視、大肆破壞、進行復仇之說<br />\n727有嘅只係極度和平同優雅嘅遊行<br />\n希望各位元朗區居民都會一同參與<br />\n表達你地對惡勢力嘅不滿！絕不姑息白衫人嘅暴力行為！<br />\n一方有難，八方支援<br />\n黑勢力當前，十八區為一體，全香港人一同支持元朗居民！</span>"},{"pid":"a185934277ea649c0ea001e5f78578c7547f9909","tid":1359221,"uid":95181,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T12:48:09.000Z","msg":"<span style=\"color: red;\"><strong>無畏無懼 727元朗見</strong></span>"},{"pid":"40319f892819ba82c81af3c1986552af47996c89","tid":1359221,"uid":54303,"like":0,"dislike":0,"score":0,"quote":{"pid":"a185934277ea649c0ea001e5f78578c7547f9909","tid":1359221,"uid":95181,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T12:48:09.000Z","msg":"<span style=\"color: red;\"><strong>無畏無懼 727元朗見</strong></span>"},"citedBy":0,"replyTime":"2019-07-24T13:10:32.000Z","msg":"即係幾點<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e61c6a2b246fad253453c852460228957e290ed4","tid":1359221,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T13:13:05.000Z","msg":"推！"},{"pid":"2a0b661f65fff1502002082aa61bb80ca02a2250","tid":1359221,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T13:13:51.000Z","msg":"推"}]}