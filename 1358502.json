pid":"322bdfb4845befde35b44196e0d7e6abf9f37de6","tid":1358502,"uid":173849,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T21:52:43.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"16a6d9ccc0e8601bd70d6d77eaaf8887cce97516","tid":1358502,"uid":173849,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T21:58:38.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"d777d89091655235ad86cbe2539eadb6dab463a7","tid":1358502,"uid":8687,"like":0,"dislike":1,"score":-1,"quote":{"pid":"d26d7f50d90b001608d2c9c0c40f8945eb908431","tid":1358502,"uid":173849,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T02:49:00.000Z","msg":"【元朗黑夜】39建制議員譴責針對何君堯暴力行為：用意惡毒無比<br />\n元朗周日（21日）晚發生白衣人追打市民事件，被指曾與白衫人握手的立法會議員何君堯，其父母墳墓23日遭人毀壞，被噴上黑油及墓碑受損。39建制議員發聲明，強烈譴責激進暴力分子惡意針對何君堯議員的一連串違法暴力行為。<br />\n<br />\n元朗連串打人事件引起民憤，被拍得與白衫人握手的立法會議員何君堯連日受追擊，多個地區辦事處被市民用鐵支破壞、貼連儂牆及擲雞蛋；何君堯今早離開港台時被市民嘲諷「你啲黑社會啲兄弟呢？」及至下午，其父母位於良田村墓園的墳墓亦遭人毀壞。<br />\n<br />\n39建制議員發聲明，指何君堯受到激進暴力分子的惡意針對，包括在網上公開家人個人資料、辦事處遭破壞圍堵、破壞其先人墓地等。建制議員斥責這些行為卑劣，用意惡毒無比，是香港法律及社會道德不能容許的，認為是天理難容。並要求警方嚴肅追究犯事者。<br />\n<br />\n實政圓桌田北辰未有參與聯署，自行另發聲明譴責，指破壞墓碑與傷害何議員本人身體無異，猶有過之。並向何君堯致以深切慰問。<br />\n<br />\n01:<br />\n<a href=\"https://www.hk01.com/%E6%94%BF%E6%83%85/355475/%E5%85%83%E6%9C%97%E9%BB%91%E5%A4%9C-39%E5%BB%BA%E5%88%B6%E8%AD%B0%E5%93%A1%E8%AD%B4%E8%B2%AC%E9%87%9D%E5%B0%8D%E4%BD%95%E5%90%9B%E5%A0%AF%E6%9A%B4%E5%8A%9B%E8%A1%8C%E7%82%BA-%E7%94%A8%E6%84%8F%E6%83%A1%E6%AF%92%E7%84%A1%E6%AF%94\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E6%2594%25BF%25E6%2583%2585%2F355475%2F%25E5%2585%2583%25E6%259C%2597%25E9%25BB%2591%25E5%25A4%259C-39%25E5%25BB%25BA%25E5%2588%25B6%25E8%25AD%25B0%25E5%2593%25A1%25E8%25AD%25B4%25E8%25B2%25AC%25E9%2587%259D%25E5%25B0%258D%25E4%25BD%2595%25E5%2590%259B%25E5%25A0%25AF%25E6%259A%25B4%25E5%258A%259B%25E8%25A1%258C%25E7%2582%25BA-%25E7%2594%25A8%25E6%2584%258F%25E6%2583%25A1%25E6%25AF%2592%25E7%2584%25A1%25E6%25AF%2594&d=gHNHb7VIn83nczLIzOZu1Y429F%2FWQzM9xP7K%2BddLk1E%3D&h=38f6ef1f\" target=\"_blank\">https://www.hk01.com/%E6%94%BF%E6%83%85/355475/%E5%85%83%E6%9C%97%E9%BB%91%E5%A4%9C-39%E5%BB%BA%E5%88%B6%E8%AD%B0%E5%93%A1%E8%AD%B4%E8%B2%AC%E9%87%9D%E5%B0%8D%E4%BD%95%E5%90%9B%E5%A0%AF%E6%9A%B4%E5%8A%9B%E8%A1%8C%E7%82%BA-%E7%94%A8%E6%84%8F%E6%83%A1%E6%AF%92%E7%84%A1%E6%AF%94</a><br />\n<br />\n經濟：【元朗襲擊】何君堯遭多番針對 建制派議員強烈譴責<br />\n<a href=\"https://topick.hket.com/article/2408565/%E3%80%90%E5%85%83%E6%9C%97%E8%A5%B2%E6%93%8A%E3%80%91%E4%BD%95%E5%90%9B%E5%A0%AF%E9%81%AD%E5%A4%9A%E7%95%AA%E9%87%9D%E5%B0%8D%E3%80%80%E5%BB%BA%E5%88%B6%E6%B4%BE%E8%AD%B0%E5%93%A1%E5%BC%B7%E7%83%88%E8%AD%B4%E8%B2%AC\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftopick.hket.com%2Farticle%2F2408565%2F%25E3%2580%2590%25E5%2585%2583%25E6%259C%2597%25E8%25A5%25B2%25E6%2593%258A%25E3%2580%2591%25E4%25BD%2595%25E5%2590%259B%25E5%25A0%25AF%25E9%2581%25AD%25E5%25A4%259A%25E7%2595%25AA%25E9%2587%259D%25E5%25B0%258D%25E3%2580%2580%25E5%25BB%25BA%25E5%2588%25B6%25E6%25B4%25BE%25E8%25AD%25B0%25E5%2593%25A1%25E5%25BC%25B7%25E7%2583%2588%25E8%25AD%25B4%25E8%25B2%25AC&d=gHNHb7VIn83nczLIzOZu1Y429F%2FWQzM9xP7K%2BddLk1E%3D&h=4e1ec8d2\" target=\"_blank\">https://topick.hket.com/article/2408565/%E3%80%90%E5%85%83%E6%9C%97%E8%A5%B2%E6%93%8A%E3%80%91%E4%BD%95%E5%90%9B%E5%A0%AF%E9%81%AD%E5%A4%9A%E7%95%AA%E9%87%9D%E5%B0%8D%E3%80%80%E5%BB%BA%E5%88%B6%E6%B4%BE%E8%AD%B0%E5%93%A1%E5%BC%B7%E7%83%88%E8%AD%B4%E8%B2%AC</a><br />\n<br />\n信報：39建制派議員聯署 強烈譴責暴力衝擊<br />\n<a href=\"https://www2.hkej.com/instantnews/current/article/2191559/39%E5%BB%BA%E5%88%B6%E6%B4%BE%E8%AD%B0%E5%93%A1%E8%81%AF%E7%BD%B2+%E5%BC%B7%E7%83%88%E8%AD%B4%E8%B2%AC%E6%9A%B4%E5%8A%9B%E8%A1%9D%E6%93%8A\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww2.hkej.com%2Finstantnews%2Fcurrent%2Farticle%2F2191559%2F39%25E5%25BB%25BA%25E5%2588%25B6%25E6%25B4%25BE%25E8%25AD%25B0%25E5%2593%25A1%25E8%2581%25AF%25E7%25BD%25B2%2B%25E5%25B