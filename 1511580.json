s://lihkg.com/thread/1512664/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1512664/page/1</a><br />\n<br />\n【眾籌】 已集合超過1000名巴絲感想 香港編年史<br />\n<a href=\"https://lihkg.com/thread/1379634/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1379634/page/1</a><br />\n<br />\n<br />\n<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"fe08e0a90c3732a7b73008288be530ab01944346","tid":1511580,"uid":197157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T06:17:19.000Z","msg":"我哋要加油！！"},{"pid":"fe7d0f9ba09f971f85a9c556b70c2f020e430816","tid":1511580,"uid":43556,"like":0,"dislike":0,"score":0,"quote":{"pid":"80e326a1124fa3b6296908a44453e47c0ac45e1c","tid":1511580,"uid":249162,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-08-28T05:55:34.000Z","msg":"文宣試下用精神攻擊法，向良知形父母精神攻擊！<br />\n以乖仔乖女聲線錄音：<br />\n<br />\n仔/女：媽/爸，哩到好凍好黑啊。。。。。唔好打我啊。。。。好痛啊。。。。媽/爸。。。我好想返屋企啊，好想食你煮既飯啊。。。好辛苦啊。。。中間加插好驚既大叫。。。。<br />\n<br />\n錄音後不停loop，以換起父母真正良知既精神攻擊！<br />\n<br />\n<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-28T06:22:07.000Z","msg":"暗黑兵法<br />\n唔係個個都受<br />\n有良知一早醒咗"},{"pid":"1cce29f148558fe87e85b62b686bc3490fbf0d6a","tid":1511580,"uid":43556,"like":0,"dislike":0,"score":0,"quote":{"pid":"0ff7d1972f4d934c583c27e13d94e7e18ea92462","tid":1511580,"uid":249162,"like":0,"dislike":0,"score":0,"quote":{"pid":"d020b7b5de30783c3b42ea9f8eb2881ac62690f6","tid":1511580,"uid":205462,"like":7,"dislike":0,"score":7,"quote":{"pid":"71d5c5a324395f0e1795a831c80b085508aecfe9","tid":1511580,"uid":43556,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-27T14:40:56.000Z","msg":"(星島日報報道)法國警察爆發自殺潮，今年至今已有六十四名警員自殺，單是近日就有八人了結生命，包括三名防暴警察、一名指揮官和一名學堂教官。警察工會說，保護者也需要受到保護，要求當局提供更多的幫助去制止問題。<br />\n<br />\n  自殺的警察來自全國各地，年齡遍布各階層，許多自殺警察遺下了年幼兒女，最近一宗於上周三發生在阿爾代什省。<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">當局至今未找出接連有警察輕生的具體原因。法國國會在七月公布一項調查，指出警察感到巨大壓力和絕望的原因，包括二〇一五年一月以來的一系列恐怖襲擊，以及去年十一月起連續二十多個周末的「黃背心示威」等，令他們工作過勞。</span></strong></span><br />\n<br />\n  有警察妻子坦言，警察置身當權者和示威者中間，不但要承受壓力與焦慮，還要面對社會上對警察職業的污名化，並批評法國政府不作為，要求得到更多支持。今年四月二十日，「黃背心」第二十三周抗議時，人群中竟出現「警察，去自殺、去自殺」的標語。<br />\n<br />\n  去年另一份報告指出，法國警察自殺率是百分之三十六，比一般自殺率高。法國政府曾於四月底設立自殺預防機構，但效果不佳。法國去年共有三十五名警察自殺，但今年到七月中已突破去年數字，一個月後更增至六十四人。<br />\n<a href=\"https://www.singtaousa.com/la/11-%E5%9C%8B%E9%9A%9B/2465123-%E6%B3%95%E8%AD%A6%E7%88%86%E8%87%AA%E6%AE%BA%E6%BD%AE%E4%BB%8A%E5%B9%B464%E6%AD%BB+%E5%AE%B6%E5%B1%AC%EF%BC%9A%E8%81%B7%E6%A5%AD%E9%81%AD%E6%B1%A1%E5%90%8D%E5%8C%96/?fromG=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.singtaousa.com%2Fla%2F11-%25E5%259C%258B%25E9%259A%259B%2F2465123-%25E6%25B3%2595%25E8%25AD%25A6%25E7%2588%2586%25E8%2587%25AA%25E6%25AE%25BA%25E6%25BD%25AE%25E4%25BB%258A%25E5%25B9%25B464%25E6%25AD%25BB%2B%25E5%25AE%25B6%25E5%25B1%25AC%25EF%25BC%259A%25E8%2581%25B7%25E6%25A5%25AD%25E9%2581%25AD%25E6%25B1%25A1%25E5%2590%258D%25E5%258C%2596%2F%3FfromG%3D1&d=hq0sVSmFYzKD%2BASQGeqgxrhWJNg3BDkm8i4jVfgHOzw%3D&h=05f6df88\" data-auto-link target=\"_blank\">https://www.singtaousa.com/la/11-%E5%9C%8B%E9%9A%9B/2465123-%E6%B3%95%E8%AD%A6%E7%88%86%E8%87%AA%E6%AE%BA%E6%BD%AE%E4%BB%8A%E5%B9%B464%E6%AD%BB+%E5%AE%B6%E5%B1%AC%EF%BC%9A%E8%81%B7%E6%A5%AD%E9%81%AD%E6%B1%A1%E5%90%8D%E5%8C%96/?fromG=1</a>"},"citedBy":2,"replyTime":"2019-08-27T14:49:35.000Z","msg":"無得比較 - 法國警察經歷過槍手恐怖襲擊，出現與壓力有關嘅精神病都唔奇...咁香港班黑犬呢? 可能係賭錢賭到破鳩咗產，搵示威者出氣囉"},"citedBy":1,"replyTime":"2019-08-28T05:56:31.000Z","msg":"冇野可以創造到佢有！"},"citedBy":0,"replyTime":"2019-08-28T06:22:45.000Z","msg":"職業污名化<br />\n仔女受靶<img src=\"/assets/faces/pig/peanut.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/peanut.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/peanut.gif\" class=\"hkgmoji\" />"},{"pid":"d3b8d6b573c1775be98f2e565c2927c2f519c3bf","tid":1511580,"uid":263174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T06:23:54.000Z","msg":"黑警犯法，謝罪自殺"},{"pid":"a3313b48153dc69c6bd946c0374a54a269a0e6f8","tid":1511580,"uid":133319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T06:24:01.000Z","msg":"之前聽到有人叫香港警察 全家自殺<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"9d43f9b199df1e73bab9ce020412a70283ccd077","tid":1511580,"uid":43556,"like":0,"dislike":0,"score":0,"quote":{"pid":"edeb4748ff1cf389639f05f0657cd11ebb3da497","tid":1511580,"uid":27664,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-27T19:09:00.000Z","msg":"法國人：工時太長了"},"citedBy":0,"replyTime":"2019-08-28T06:24:19.000Z","msg":"多過35小時<br />\n已經要投訴了"},{"pid":"c52896c8e45af5541ac2a1cc20ddb02109296845","tid":1511580,"uid":70487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T06:25:39.000Z","msg":"光復法國<br />\n法國革命"},{"pid":"b12aee28d3b55297e2d6bdb4e6a43a3ea31e9d0e","tid":1511580,"uid":43556,"like":0,"dislike":0,"score":0,"quote":{"pid":"1833bbe3194a03ed1b3428c20706350aa12087ff","tid":1511580,"uid":97978,"like":0,"dislike":0,"score":0,"quote":{"pid":"71d5c5a324395f0e1795a831c80b085508aecfe9","tid":1511580,"uid":43556,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-27T14:40:56.000Z","msg":"(星島日報報道)法國警察爆發自殺潮，今年至今已有六十四名警員自殺，單是近日就有八人了結生命，包括三名防暴警察、一名指揮官和一名學堂教官。警察工會說，保護者也需要受到保護，要求當局提供更多的幫助去制止問題。<br />\n<br />\n  自殺的警察來自全國各地，年齡遍布各階層，許多自殺警察遺下了年幼兒女，最近一宗於上周三發生在阿爾代什省。<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">當局至今未找出接連有警察輕生的具體原因。法國國會在七月公布一項調查，指出警察感到巨大壓力和絕望的原因，包括二〇一五年一月以來的一系列恐怖襲擊，以及去年十一月起連續二十多個周末的「黃背心示威」等，令他們工作過勞。</span></strong></span><br />\n<br />\n  有警察妻子坦言，警察置身當權者和示威者中間，不但要承受壓力與焦慮，還要面對社會上對警察職業的污名化，並批評法國政府不作為，要求得到更多支持。今年四月二十日，「黃背心」第二十三周抗議時，人群中竟出現「警察，去自殺、去自殺」的標語。<br />\n<br />\n  去年另一份報告指出，法國警察自殺率是百分之三十六，比一般自殺率高。法國政府曾於四月底設立自殺預防機構，但效果不佳。法國去年共有三十五名警察自殺，但今年到七月中已突破去年數字，一個月後更增至六十四人。<br />\n<a href=\"https://www.singtaousa.com/la/11-%E5%9C%8B%E9%9A%9B/2465123-%E6%B3%95%E8%AD%A6%E7%88%86%E8%87%AA%E6%AE%BA%E6%BD%AE%E4%BB%8A%E5%B9%B464%E6%AD%BB+%E5%AE%B6%E5%B1%AC%EF%BC%9A%E8%81%B7%E6%A5%AD%E9%81%AD%E6%B1%A1%E5%90%8D%E5%8C%96/?fromG=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.singtaousa.com%2Fla%2F11-%25E5%259C%258B%25E9%259A%259B%2F2465123-%25E6%25B3%2595%25E8%25AD%25A6%25E7%2588%2586%25E8%2587%25AA%25E6%25AE%25BA%25E6%25BD%25AE%25E4%25BB%258A%25E5%25B9%25B464%25E6%25AD%25BB%2B%25E5%25AE%25B6%25E5%25B1%25AC%25EF%25BC%259A%25E8%2581%25B7%25E6%25A5%25AD%25E9%2581%25AD%25E6%25B1%25A1%25E5%2590%258D%25E5%258C%2596%2F%3FfromG%3D1&d=hq0sVSmFYzKD%2BASQGeqgxrhWJNg3BDkm8i4jVfgHOzw%3D&h=05f6df88\" data-auto-link target=\"_blank\">https://www.singtaousa.com/la/11-%E5%9C%8B%E9%9A%9B/2465123-%E6%B3%95%E8%AD%A6%E7%88%86%E8%87%AA%E6%AE%BA%E6%BD%AE%E4%BB%8A%E5%B9%B464%E6%AD%BB+%E5%AE%B6%E5%B1%AC%EF%BC%9A%E8%81%B7%E6%A5%AD%E9%81%AD%E6%B1%A1%E5%90%8D%E5%8C%96/?fromG=1</a>"},"citedBy":1,"replyTime":"2019-08-27T20:23:03.000Z","msg":"自殺率36%即係點？"},"citedBy":0,"replyTime":"2019-08-28T06:26:28.000Z","msg":"星島翻譯問題<br />\n<br />\n法國參議院在去年公布的報告中表示，法國警察自殺率比一般民眾高出36%，但未發現自殺背後的單一原因。<br />\n<br />\n今年4月，法國內政部長卡斯塔納承認不清楚原因，並宣布另一項預防計畫。他是連續第三個這樣做的部長，而這凸顯當局未能解決這項問題。<br />\n<br />\n值得注意的是，卡斯塔納說，警察自殺不應被認為出自「工作以外」的原因，或將其視為個人問題。法國國家警察總署署長莫文也打破禁忌，向所有警察發送了一封信 ，鼓勵他們暢所欲言，不用擔心受到批評，並稱講出苦惱絕非軟弱。"},{"pid":"73614f4be58c5530dc872f01c0603b94af21363d","tid":1511580,"uid":33952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T06:36:34.000Z","msg":"香港警察 死去自殺"},{"pid":"bddd2d90c386887303c4abe6840f7a04e21114d0","tid":1511580,"uid":70487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T06:40:06.000Z","msg":"港警睇到這個post請廣傳去你們的同事群組，大家一起討論一下如何自殺<img src=\"/assets/faces/lm2/good.gif\" class=\"hkgmoji\" />"}]}