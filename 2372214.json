FNP45HMICURD45PABVOS24HSANQ%2F&d=CthjHxCXz%2Bl0vOF3eBkmenGrSSjb4k8A9Srgfm1924U%3D&h=3e3ee181\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210119%2FNP45HMICURD45PABVOS24HSANQ%2F&h=3773540a\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20210119/NP45HMICURD45PABVOS24HSANQ/</a>"},"citedBy":0,"replyTime":"2021-01-19T14:16:42.000Z","msg":"希望桐叔好人一生平安"},{"pid":"e8f8d76749f512e3b5113a937ef3b03df3afa80b","tid":2372214,"uid":267245,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-19T14:19:45.000Z","msg":"黑到盡處總有光 <br />\n我地一定可以見證光復<br />\n手足既犧牲不會白費"},{"pid":"009ef498a45afcc64c1dc7457e4b69641797f4c0","tid":2372214,"uid":47496,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2021-01-19T14:20:56.000Z","msg":"<strong><span class=\"xx-large\">桐仔</span></strong><img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" />"},{"pid":"37e39060cf810a5aa874fe9210a999e68efadfa8","tid":2372214,"uid":411,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-19T14:22:29.000Z","msg":"<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" />72歲都仲咁幫手足"},{"pid":"a2bfbdef82718e2bbfbad43a3e61dbbfd8abe65c","tid":2372214,"uid":324629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-19T14:23:41.000Z","msg":"Shinzou Sasageyo<img src=\"/assets/faces/mouse/notcry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/notcry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"e88de4e1a0cc5ba7c7cfcfc756d578fe1c7a5234","tid":2372214,"uid":85578,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-19T14:24:38.000Z","msg":"老人家仲咁為香港..."},{"pid":"209850f36e0b9fe8fda3fbf1c780c93634104b0b","tid":2372214,"uid":24924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-19T14:26:33.000Z","msg":"多謝桐叔😭"},{"pid":"d2775e6be9f92aa9582287220a801cc5c4f5755c","tid":2372214,"uid"