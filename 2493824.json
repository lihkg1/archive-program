data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1q1fWny.png&h=3203d7a9&s={SIZE}\" />"},{"pid":"b2c2d3a5c37792d52229b4303d1f31635ae448a1","tid":2493824,"uid":261505,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2021-04-18T07:55:19.000Z","msg":"<img src=\"https://ipfs.infura.io/ipfs/QmWnkkzKEfZEnbypZFXZDzpw1eKuS8uxsAyyVtjzjk1kT5?filename=RKSr5dZ.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRKSr5dZ.png&h=121a88ea&s={SIZE}\" /><img src=\"https://ipfs.infura.io/ipfs/QmWP487QAvckUZiXZDCU3zFwCsjCkLZCAdMn6yxunpHtFz?filename=h4F1T7j.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fh4F1T7j.png&h=dd591bf6&s={SIZE}\" />"},{"pid":"93ed8aec9625f8b630463840d480dac4c9b287ed","tid":2493824,"uid":48083,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-04-18T07:56:48.000Z","msg":"<a href=\"http://news.now.com/home/local/player?newsId=431037&amp;refer=Share\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D431037%26refer%3DShare&d=suC3bgMk4yzoLj7oQdk4RBZZVu6JdVYNpUv5YkkCXtQ%3D&h=6af755e0\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D431037%26refer%3DShare&h=f5bb56cd\" target=\"_blank\">http://news.now.com/home/local/player?newsId=431037&amp;refer=Share</a><br />\n<br />\n<br />\n海關副關長何珮珊：「個別案件調查進度在此不評論，但一般而言我們遇到關於保障消費者權益的舉報，我們會安排巡查及試購，事實我們是收多了關於雙語標籤的舉報，正如海關一貫做法，我們會依法辦事，我們會處理這些投訴。」<br />\n<br />\n咁叫處理咗？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/good.gif\" class=\"hkgmoji\" />"},{"pid":"02640d4fc0698c14f6c05c558492a748374451cb","tid":2493824,"uid":48083,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-18T07:57:13.000Z","msg":"温馨提示：海關副關長 何佩珊 係曾國衞老婆 仲有大約一年就坐正<br />\n<a href=\"https://lih.kg/2483185\" data-auto-link target=\"_blank\">https://lih.kg/2483185</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"954e42aa92a793f515d13dc6dd7b54de17b10398","tid":2493824,"uid":108016,"like":0,"dislike":0,"score":0,"quote":{"pid":"c242ff6d8037b2f9d79a9261156248b0b0fa1b2c","tid":2493824,"uid":200070,"like":4,"dislike":3,"score":1,"citedBy":3,"replyTime":"2021-04-18T07:54:54.000Z","msg":"是但啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />第一日住係香港咩 班人仲FF有法律果下先好笑<br />\n我估天真嬌都冇咁天真<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-18T08:00:44.000Z","msg":"志在搞鳩班海狗啫"},{"pid":"27300ecc29a2114a16f480da33683f6601fd862d","tid":2493824,"uid":48083,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-04-18T08:01:13.000Z","msg":"點解阿布泰接到舉報就調查 <br />\n360就唔撚關海關事嘅？<br />\n<br />\n香港海關於連鎖零售店集團檢獲逾八千八百件懷疑違規沐浴露及家居清潔用品（附圖）<br />\n<br />\n2021年4月9日<br />\n<br />\n<br />\n香港海關昨日（四月八日）於一間連鎖零售店集團多個處所檢獲十四款合共八千八百○五件懷疑違規沐浴露、家居清潔劑和衣物漂白劑，涉案貨品包裝上的產品資料均沒有標示中文及英文的雙語警告或警誡字句，涉嫌違反《消費品安全條例》（《條例》）的附屬法例《消費品安全規例》（《規例》）。行動中檢獲產品估計市值共約四十萬元，一人被捕。<br />\n<br />\n<span class=\"xx-large\"><strong><span class=\"red\">海關早前接獲舉報，指一間連鎖零售店集團位於荃灣和沙田的零售店鋪有多款懷疑違規家居清潔劑出售。海關人員隨即進行調查，</span></strong></span>從六間分別位於金鐘、鰂魚涌、旺角、荃灣和沙田的零售店鋪試購涉案共十四款產品。<br />\n<br />\n經調查後，海關發現該些產品包裝上的產品資料沒有標示就安全存放、使用、耗用或處置的中文警告或警誡字句，當中十二款只附有泰文警告或警誡字句，而另外兩款產品則只附有泰文及英文警告或警誡字句。<br />\n<a href=\"https://www.customs.gov.hk/tc/publication_press/press/index_id_3178.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.customs.gov.hk%2Ftc%2Fpublication_press%2Fpress%2Findex_id_3178.html&d=suC3bgMk4yzoLj7oQdk4RBZZVu6JdVYNpUv5YkkCXtQ%3D&h=09e459be\" target=\"_blank\">https://www.customs.gov.hk/tc/publication_press/press/index_id_3178.html</a>"},{"pid":"0034b8b983a9969d6c33fe01f1c4bd1455eac7e0","tid":2493824,"uid":14787,"like":0,"dislike":0,"score":0,"quote":{"pid":"9cd85ea54a8450460e7782da4c4537666784c346","tid"