4d0cb15798a535bae3b9eed9b8737ce","tid":2493824,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-18T08:11:48.000Z","msg":"612基金仲爭一千萬先夠cover今個月開支<br />\n<a href=\"https://lih.kg/2490867\" data-auto-link target=\"_blank\">https://lih.kg/2490867</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"4d29594f4946356e3fb2f5568e9cd7182b4b9e76","tid":2493824,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-18T08:15:02.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"727e594d030ed33189a2f925426fa73fc52579e4","tid":2493824,"uid":274055,"like":0,"dislike":0,"score":0,"quote":{"pid":"98aabfe6ea8ad838fb023ddc61059d94a34041e2","tid":2493824,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-18T07:53:20.000Z","msg":"<img src=\"https://na.cx/i/cCUyfyD.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcCUyfyD.png&h=d4416795&s={SIZE}\" />"},"citedBy":0,"replyTime":"2021-04-18T08:17:34.000Z","msg":"扮下一視同仁都唔做？"},{"pid":"27fd2e2a59f62edb8f00eb03077f49be51d4194f","tid":2493824,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-18T08:44:37.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"17e2d595e5854c3a486798ea23e6d09ea073bbff","tid":2493824,"uid":214,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-18T08:52:23.000Z","msg":"政府部門得返消防架咋c hing"}],"pinned":{"pid":"27300ecc29a2114a16f480da33683f6601fd862d","tid":2493824,"uid":48083,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-04-18T08:01:13.000Z","msg":"點解阿布泰接到舉報就調查 <br />\n360就唔撚關海關事嘅？<br />\n<br />\n香港海關於連鎖零售店集團檢獲逾八千八百件懷疑違規沐浴露及家居清潔用品（附圖）<br />\n<br />\n2021年4月9日<br />\n<br />\n<br />\n香港海關昨日（四月八日）於一間連鎖零售店集團多個處所檢獲十四款合共八千八百○五件懷疑違規沐浴露、家居清潔劑和衣物漂白劑，涉案貨品包裝上的產品資料均沒有標示中文及英文的雙語警告或警誡字句，涉嫌違反《消費品安全條例》（《條例》）的附屬法例《消費品安全規例》（《規例》）。行動中檢獲產品估計市值共約四十萬元，一人被捕。<br />\n<br />\n<span class=\"xx-large\"><strong><span class=\"red\">海關早前接獲舉報，指一間連鎖零售店集團位於荃灣和沙田的零售店鋪有多款懷疑違規家居清潔劑出售。海關人員隨即進行調查，</span></strong></span>從六間分別位於金鐘、鰂魚涌、旺角、荃灣和沙田的零售店鋪試購涉案共十四款產品。<br />\n<br />\n經調查後，海關發現該些產品包裝上的產品資料沒有標示就安全存放、使用、耗用或處置的中文警告或警誡字句，當中十二款只附有泰文警告或警誡字句，而另外兩款產品則只附有泰文及英文警告或警誡字句。<br />\n<a href=\"https://www.customs.gov.hk/tc/publication_press/press/index_id_3178.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.customs.gov.hk%2Ftc%2Fpublication_press%2Fpress%2Findex_id_3178.html&d=suC3bgMk4yzoLj7oQdk4RBZZVu6JdVYNpUv5YkkCXtQ%3D&h=09e459be\" target=\"_blank\">https://www.customs.gov.hk/tc/publication_press/press/index_id_3178.html</a>"}}