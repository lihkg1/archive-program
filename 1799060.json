aces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"049df28baf773e8f5100da61ef009c6418e9f561","tid":1799060,"uid":237838,"like":0,"dislike":11,"score":-11,"citedBy":0,"replyTime":"2019-12-26T16:22:22.000Z","msg":"等fd叫醒<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"2fcf941050453090cbaf5483ae2185734e5b5525","tid":1799060,"uid":8308,"like":33,"dislike":0,"score":33,"citedBy":0,"replyTime":"2019-12-26T16:33:29.000Z","msg":"自然醒 通常好少過9點<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /><br />\n不過出門就通常12點先出 景點睇唔睇冇所謂 <br />\n最緊要食好同休息好<img src=\"/assets/faces/xm/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1e9a6521818bdb701a4823c5d3ee73204bd18ad2","tid":1799060,"uid":186681,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T16:33:43.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"8542a976499ca5a9734f178ffefa2cc9e7dda818","tid":1799060,"uid":292674,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-12-26T16:36:25.000Z","msg":"10點幾"},{"pid":"a7049d02be32f0d95dadf20b0c81b91eed99c9ed","tid":1799060,"uid":317035,"like":29,"dislike":3,"score":26,"citedBy":2,"replyTime":"2019-12-26T16:52:37.000Z","msg":"點解樓上全部都咁早<img src=\"/assets/faces/pigxm/wail.gif\" class=\"hkgmoji\" /><br />\n我如果嗰日唔趕行程 通常都瞓到自然醒 十點幾<br />\n跟住再慢慢準備出門口<img src=\"/assets/faces/pigxm/play.gif\" class=\"hkgmoji\" />去旅行唔鍾意個人咁繃緊"},{"pid":"e9373ec96bfdb3091bd82f6b08d072176ee8ad65","tid":1799060,"uid":61257,"like":7,"dislike":3,"score":4,"citedBy":0,"replyTime":"2019-12-26T17:07:35.000Z","msg":"睇下去邊<br />\n<br />\n長線歐美既一定早起身爭取時間<br />\n<br />\n短線就訓晏少少"},{"pid":"46ad0f53b69f696a22c8c6651d31b717ea3ce868","tid":1799060,"uid":26773,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2019-12-26T17:15:04.000Z","msg":"唔訓嫁喎"},{"pid":"8b0331fc36713137e1382ebffbebab0c17faac3a","tid":1799060,"uid":12618,"like":42,"dislike":0,"score":42,"quote":{"pid":"7f247ff25e492575e06