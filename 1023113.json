-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ffreestylelibre.com.hk%2Ftc%2F%3Fgclid%3DCjwKCAiA45njBRBwEiwASnZT56iR8EdH82IcTLaXEtS_qNO440ezaNMSMz7seZvWd-uQwyvs7gWktRoCaH4QAvD_BwE%26gclsrc%3Daw.ds&d=zBdjJXAkzC5SgMGJ5jx7qpwtdbXJE8TYY9MHUmPwwUI%3D&h=233b2541\" target=\"_blank\">https://freestylelibre.com.hk/tc/?gclid=CjwKCAiA45njBRBwEiwASnZT56iR8EdH82IcTLaXEtS_qNO440ezaNMSMz7seZvWd-uQwyvs7gWktRoCaH4QAvD_BwE&amp;gclsrc=aw.ds</a>"},{"pid":"deb30fd60546dbff1629fa888c5bd93eea38f5de","tid":1023113,"uid":25221,"like":1,"dislike":7,"score":-6,"citedBy":0,"replyTime":"2019-02-16T08:54:02.000Z","msg":"此回覆已被刪除"},{"pid":"4e567c8993efac544928d82d440f249f68c72c16","tid":1023113,"uid":124655,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-16T09:49:38.000Z","msg":"有隻手環係可以, 但我呢刻記唔起係邊隻"},{"pid":"17784dc7511a0d3a364c8f2b487340b5fcda96dc","tid":1023113,"uid":124655,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-16T09:53:57.000Z","msg":"樓主可以 google 手環 血塘"},{"pid":"31e4eb8bb8cd292d9f762acff8b977dc6ca310b4","tid":1023113,"uid":170375,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-02-16T09:56:19.000Z","msg":"冇 遠距離check 心跳就有<img src=\"https://na.cx/i/s8WZwmK.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fs8WZwmK.png&h=fceb0490&s={SIZE}\" />"},{"pid":"cab94e577f902a7b82c44f912f114dc2e3169f00","tid":1023113,"uid":140309,"like":0,"dislike":0,"score":0,"quote":{"pid":"3739d18ebbb67161dfc9fb6a3f7bcb4db54def5b","tid":1023113,"uid":52194,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-02-15T14:11:17.000Z","msg":"唔吉手指就check到血糖<br />\n仲未有咁高科技啊<img src=\"/assets/faces/lny/surprise.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-02-16T14:47:31.000Z","msg":"據 CNBC 報導，Fitbit 最近向一家名為 Sano 的公司投資了 600 萬美元，後者的專長是開發硬幣大小的血糖監測器。在此之前，Fitbit 已經為自己的 Ionic 手錶加入了顯示第三方感應器血糖讀數的功能。如今在 Sano 的幫助下，他們的下一步很有可能是將血糖監測功能直接做到自己未來的產品當中。「這符合我們將眼光放到裝置以外，更多考慮（健康）解決方案的策略方向。」在接受 CNBC 採訪時 CEO James Park 這麼說道，「我認為將監測組件、顯示器和能在適當時間干預的可穿戴裝置融合在一起才是完善的方案。」<br />\n<br />\n實際上，除了 Fitbit 以外，先前也一直有消息稱 Apple 也在努力為自己的手錶加入血糖監測的特性。而且跟 Sano 基於微型針頭的微創式方案相比，Apple 所用的技術據說能實現非侵入式的持續監測。但不管怎麼說，Fitbit 能在血糖這方面考慮至少是找對了接下來的發展方向。Sano 的監測器還需要至少一年的時間才能真正商品化，雖然 James Park 在採訪中沒有確認，但 Fitbit 這邊估計在那之後不久也會有對應的產品出來吧。"},{"pid":"d4033df6e9c8891d2ff2f9764fd4d6e9c800da50","tid":1023113,"uid":140309,"like":0,"dislike":0,"score":0,"quote":{"pid":"4e87fc89e0de037dfa1b34422442a9a632496f46","tid":1023113,"uid":78429,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-02-15T14:25:38.000Z","msg":"聯絡fitbit解釋你個case話唔定有得偷跑呢"},"citedBy":0,"replyTime":"2019-02-16T14:47:50.000Z","msg":"可能仲研發緊<img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" />"},{"pid":"aa73cf7e5a674937e985b4a8d6983b018134afc5","tid":1023113,"uid":140309,"like":0,"dislike":0,"score":0,"quote":{"pid":"8acb46d69c65fc7c0092ba0501457ea4b7ee1cff","tid":1023113,"uid":220368,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-02-15T14:32:11.000Z","msg":"半無創有一部叫freestyle Libre<br />\n塊貼有枝針，貼在手臂14日換一次<br />\ncheck 血糖 時嘟一吓就顯示到<br />\n要搖控傳data好似未出<br />\n<a href=\"https://freestylelibre.com.hk/tc/?gclid=CjwKCAiA45njBRBwEiwASnZT56iR8EdH82IcTLaXEtS_qNO440ezaNMSMz7seZvWd-uQwyvs7gWktRoCaH4QAvD_BwE&amp;gclsrc=aw.ds\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ffreestylelibre.com.hk%2Ftc%2F%3Fgclid%3DCjwKCAiA45njBRBwEiwASnZT56iR8EdH82IcTLaXEtS_qNO440ezaNMSMz7seZvWd-uQwyvs7gWktRoCaH4QAvD_BwE%26gclsrc%3Daw.ds&d=zBdjJXAkzC5SgMGJ5jx7qpwtdbXJE8TYY9MHUmPwwUI%3D&h=233b2541\" target=\"_blank\">https://freestylelibre.com.hk/tc/?gclid=CjwKCAiA45njBRBwEiwASnZT56iR8EdH82IcTLaXEtS_qNO440ezaNMSMz7seZvWd-uQwyvs7gWktRoCaH4QAvD_BwE&amp;gclsrc=aw.ds</a>"},"citedBy":0,"replyTime":"2019-02-16T14:50:09.000Z","msg":"我老母都有提過,話唔想成日吉手指咁痛<br />\n但我係想隨時掌握血糖度數,緊急通知同人嘅位置"},{"pid":"baa3d6b2005ef7e00869a4367941fb08c6f9f0fa","tid":1023113,"uid":143621,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2019-02-16T14:55:14.000Z","msg":"樓豬認真問問題 點解都可以咁多小學雞亂入<img src=\"/assets/faces/