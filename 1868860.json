d=%2FXNhycaKVB9NPWqbniWxn%2FZtcVXZMMHuQDZeBHkLh3U%3D&h=9eb10e4c\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fstd.stheadline.com%2Fdaily%2Farticle%2Fdetail%2F2138352%2F%25E6%2597%25A5%25E5%25A0%25B1-%25E4%25B8%25AD%25E5%259C%258B%25E7%25B6%259C%25E5%2590%2588-%25E7%2597%2585%25E4%25BE%258B%25E7%25A0%25B4%25E5%258D%2583-%25E7%2582%25BA%25E4%25BD%2595SARS%25E7%2594%25A8%25E4%25BA%25864%25E5%2580%258B%25E6%259C%2588-%25E6%25AD%25A6%25E6%25BC%25A2%25E8%2582%25BA%25E7%2582%258E%25E9%259A%25BB%25E7%2594%25A8%25E4%25BA%258625%25E5%25A4%25A9&h=7ad5be2d\" data-auto-link target=\"_blank\">https://std.stheadline.com/daily/article/detail/2138352/%E6%97%A5%E5%A0%B1-%E4%B8%AD%E5%9C%8B%E7%B6%9C%E5%90%88-%E7%97%85%E4%BE%8B%E7%A0%B4%E5%8D%83-%E7%82%BA%E4%BD%95SARS%E7%94%A8%E4%BA%864%E5%80%8B%E6%9C%88-%E6%AD%A6%E6%BC%A2%E8%82%BA%E7%82%8E%E9%9A%BB%E7%94%A8%E4%BA%8625%E5%A4%A9</a>"},"citedBy":0,"replyTime":"2020-02-07T22:55:32.000Z","msg":"如果病毒有智慧佢都係想不止境繁殖姐，如果下下都咁快殺死宿主咁樣好快就絕種，最識玩既就係減低自己毒性增強傳播能力。"}]}