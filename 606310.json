ces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"6fc9abdb40bcb6e7456ae77337fb50976b417737","tid":606310,"uid":11001,"like":11,"dislike":1,"score":10,"quote":{"pid":"a80022e09a92ca58eb9a0b0d58e949ed529b7055","tid":606310,"uid":101976,"like":49,"dislike":3,"score":46,"citedBy":1,"replyTime":"2018-03-26T11:28:06.000Z","msg":"睇左咁耐太空新聞,我覺得其實有又點?冇又點?<br />\n<br />\n太陽系中唯一一樣永恆不變既就係聽日都係要番工"},"citedBy":0,"replyTime":"2018-03-26T11:50:03.000Z","msg":"所以你咪屬於係永恆不變聽日要翻工嘅人囉 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"bd81c69586883612a8f14f247ce195a0f48ef54c","tid":606310,"uid":56240,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-26T11:51:24.000Z","msg":"揾到又點啊<br />\n搞翻掂地球先啦"},{"pid":"8414d9c767c6b93bc4887d21bb68871337614a56","tid":606310,"uid":71568,"like":1,"dislike":0,"score":1,"quote":{"pid":"24bf12b0ba54fcd5e956421c3455ed264f7ad997","tid":606310,"uid":132847,"like":0,"dislike":1,"score":-1,"quote":{"pid":"d2b5d3cda30a1c8f26d30f052c16683fc373f618","tid":606310,"uid":71568,"like":20,"dislike":0,"score":20,"citedBy":2,"replyTime":"2018-03-26T11:33:09.000Z","msg":"我唔夠時間做好詳細時research<br />\n搵人幫手google下<br />\n<br />\n但係點解生物一般係based on碳carbon或者矽silicon 係因為佢地有4粒電子同人組成bonding<br />\n<br />\n4粒電子令到係化學上佢地可以同其他element做到最多唔同bonding既可能性 而生物一定係複雜既 而且佢地同其他element bond完之後既果粒電子可以同hydrogen氮黎bond 令到呢兩個element相對stable<br />\n<br />\n所以一般除左地球上所有生物都係base on碳之外科學家一般都認為silicon係第2個最大可能性 果d生物就應該同我地極唔同<br />\n<br />\n但係碳生物未必同我地差太遠<br />\n<br />\n但係點解一定要有水我就唔知<br />\n<br />\n但係覺得會同化學有關 但係冇時間google所以等你地黎<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-26T11:47:59.000Z","msg":"如果真係silicon 會唔會imply 外星生物一般嚟講會大過人類好多？<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-26T11:52:56.000Z","msg":"唔知<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 因為粒atom大d?<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n呢d都係我以前google落既記憶<br />\n<br />\n但係我知既係地球上一大堆生物結構上用好多silicon但係dna全部carbon<br />\n<br />\n會唔會imply左一d限制令到silicon冇生物我就唔知<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n同埋好似話carbon係宇宙係其中一個最常見既element<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"41bbf354c53096cb9d2ff7350becd26a44cc4983","tid":606310,"uid":54486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-26T11:52:57.000Z","msg":"知唔知咩叫收窄目標<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n宇宙咁撚大，唔定一d目標點搵吖"},{"pid":"ab6ec35e24c6ee47d7d5c58a006eb3f9f55f96ed","tid":606310,"uid":189,"like":0,"dislike":5,"score":-5,"citedBy":0,"replyTime":"2018-03-26T11:54:37.000Z","msg":"因為未發現有生物唔需要水生存"},{"pid":"757d2dcbf62487b233498b96df55a5d342b461a0","tid":606310,"uid":12449,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2018-03-26T11:56:55.000Z","msg":"其實NASA目標係搵適合人類居住嘅星球<br />\n<br />\n而唔係有冇外星生物"},{"pid":"e15c31b57daf16bb0b4ec97a3322b5c330784c5f","tid":606310,"uid":48083,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2018-03-26T12:03:58.000Z","msg":"見過書咁講：<br />\nUv或其他勁幅射可以分解水成為氫氣同氧氣<br />\n氫氣太輕，會飄出大氣層<br />\n氧氣會同金屬react變oxide<br />\n所以，宇宙過咗咁耐，正路一個星球上既水應該冇哂<br />\n<br />\n但如果有生物做光合作用或同cyanide, sulphate嗰啲有反應，<br />\n就會喺大氣中製造額外氧氣同氫氣react變番水<br />\n咁可以留住啲水喺嗰星球<br />\n<br />\n所以有水imply 有可能有生物<br />\n<br />\n錯咗就住屌<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"a619f8fc8e38a520a1d26154861d0af233d84236","tid":606310,"uid":294,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T12:04:05.000Z","msg":"如果倒n噸水落火星, 形成一個海洋<br />\n<br />\n咁火星會唔會加速孕育生命???"},{"pid":"3836db8aa542578980f8c7719f058854d22e17bd","tid":606310,"uid":136765,"like":0,"dislike":0,"score":0,"quote":{"pid":"a619f8fc8e38a520a1d26154861d0af233d84236","tid":606310,"uid":294,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T12:04:05.000Z","msg":"如果倒n噸水落火星, 形成一個海洋<br />\n<br />\n咁火星會唔會加速孕育生命???"},"citedBy":0,"replyTime":"2018-03-26T12:14:41.000Z","msg":"會蒸發曬"},{"pid":"fe8aa316e7505bce67517958bc215c781677fadb","tid":606310,"uid":372,"like":0,"dislike":0,"score":0,"quote":{"pid":"308d64c97159abc0e7cd91720e17aa5d3b3c62f9","tid":606310,"uid":5649,"like":4,"dislike":28,"score":-24,"citedBy":1,"replyTime":"2018-03-26T11:22:50.000Z","msg":"人類有70%係水份囉柒頭"},"citedBy":0,"replyTime":"2018-03-26T12:22:29.000Z","msg":"剩低嘅由簡迪覆蓋"},{"pid":"11077edcf6dd5e4cba1c84c1b4849017dd103f2e","tid":606310,"uid":128869,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-26T12:30:04.000Z","msg":"因為地球上所有生物都係碳基生物<br />\n對碳基生物黎講 水係必需<br />\n<br />\n而以人類依家既知識<br />\n以水為標準去搵外星生物<br />\n係因為有水就係我地已知生物既必要條件<br />\n咁即係搵到水就有可能有生物<br />\n所以用水最方便<br />\n<br />\n當然其他元素都可能構成生物而只係人類唔知<br />\n但問題係人類唔知<br />\n咁咪用住水先"},{"pid":"ee16d708cf3fbfdf614dcad928fe37a5de0b8d4b","tid":606310,"uid":37869,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2b5d3cda30a1c8f26d30f052c16683fc373f618","tid":606310,"uid":71568,"like":20,"dislike":0,"score":20,"citedBy":2,"replyTime":"2018-03-26T11:33:09.000Z","msg":"我唔夠時間做好詳細時research<br />\n搵人幫手google下<br />\n<br />\n但係點解生物一般係based on碳carbon或者矽silicon 係因為佢地有4粒電子同人組成bonding<br />\n<br />\n4粒電子令到係化學上佢地可以同其他element做到最多唔同bonding既可能性 而生物一定係複雜既 而且佢地同其他element bond完之後既果粒電子可以同hydrogen氮黎bond 令到呢兩個element相對stable<br />\n<br />\n所以一般除左地球上所有生物都係base on碳之外科學家一般都認為silicon係第2個最大可能性 果d生物就應該同我地極唔同<br />\n<br />\n但係碳生物未必同我地差太遠<br />\n<br />\n但係點解一定要有水我就唔知<br />\n<br />\n但係覺得會同化學有關 但係冇時間google所以等你地黎<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-26T12:32:43.000Z","msg":"好似冇乜人話一定要有水<br />\n不過一定要有液體<br />\n水係一種好適合比唔同元素／化合物產生化學反應的地方"},{"pid":"60ac4308f5b6bc5e8e77ccee5d2cc3ca8b4e91a4","tid":606310,"uid":50856,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-26T12:37:30.000Z","msg":"可能想住過去掛"},{"pid":"a3c87d15b63529d22ba1253263b0e9a575c8f903","tid":606310,"uid":112197,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2018-03-26T12:46:15.000Z","msg":"水係極強既solvent 可以提供一個<span style=\"color: red;\">媒介</span>,浴解好多化合物去提升結合出需要有複雜機制既生命｡水存在亦係該星球<span style=\"color: red;\">氣候</span>係宜居既證明, 而温度重要性相當大｡<br />\n <br />\n<span style=\"color: red;\">過熱</span>粒子運動加速令粒子間既bond<span style=\"color: red;\">唔穩定</span>｡就好似煲雞湯咁,餡都比你滾到出汁仲點生命｡而且蛋白質60度左右就變性, 代表大部份地球生物都生存唔到, 有複雜機制如人類更冇可能生存｡<br />\n<br />\n<span style=\"color: blue;\">過冷</span>甚至結冰, 粒子運動極緩慢<span style=\"color: blue;\">無法結合</span>｡生物各種所需元素, 食物, 都冰封隔絕, 郁都郁唔到點生命<br />\n<br />\n粒子運動係物理定律, 去到邊都apply到｡ 以水冰點同沸點去篩選都篩走九成星球｡"},{"pid":"ece68f4129bbb99ebc123b1ddc85191e91f41b3a","tid":606310,"uid":43839,"like":0,"dislike":0,"score":0,"quote":{"pid":"ab49d7ac96d42098a584647a95b1273c6542ae06","tid":606310,"uid":132847,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T11:19:30.000Z","msg":"頭先見有個post話有超級地球，令我諗起之前同人argue咗呢樣嘢好耐:<br />\n<br />\n到底點解要用水去決定一個星球有冇生命存在<br />\n<br />\n呢個根本只係對人類先啱用嘅決定因素，點解外星生物一定要水？如果外星生物根本唔可以掂到水，或者根本用肉眼睇唔到，或者根本冇形態？<br />\n<br />\n咁又引申出另一個問題:<br />\n<br />\n點先知一個星球上面有冇生命？ 生命嘅定義係宇宙層面上應該係點？<br />\n<br />\n小弟冇乜學過太多呢方面嘅知識，有冇人可以賜教一下細路<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-26T12:47:20.000Z","msg":"因為啲科學家明為搵外星生物,實為搵一個同地球一樣既星球,等人類可以繼續 破壞星球<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n老老實實地球最多玩多1-2 千年"},{"pid":"040dd332259c753db20857a76249862316d1431c","tid":606310,"uid":35660,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-03-26T12:48:01.000Z","msg":"一日要飲八杯水囉"},{"pid":"b25652555be615b51bfbbefe99524f5bdb1659c0","tid":606310,"uid":30186,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-26T12:49:19.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"200df4c281e6046a33cfa6b2663d401d51d64b1f","tid":606310,"uid":3255,"like":0,"dislike":0,"score":0,"quote":{"pid":"a3c87d15b63529d22ba1253263b0e9a575c8f903","tid":606310,"uid":112197,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2018-03-26T12:46:15.000Z","msg":"水係極強既solvent 可以提供一個<span style=\"color: red;\">媒介</span>,浴解好多化合物去提升結合出需要有複雜機制既生命｡水存在亦係該星球<span style=\"color: red;\">氣候</span>係宜居既證明, 而温度重要性相當大｡<br />\n <br />\n<span style=\"color: red;\">過熱</span>粒子運動加速令粒子間既bond<span style=\"color: red;\">唔穩定</span>｡就好似煲雞湯咁,餡都比你滾到出汁仲點生命｡而且蛋白質60度左右就變性, 代表大部份地球生物都生存唔到, 有複雜機制如人類更冇可能生存｡<br />\n<br />\n<span style=\"color: blue;\">過冷</span>甚至結冰, 粒子運動極緩慢<span style=\"color: blue;\">無法結合</span>｡生物各種所需元素, 食物, 都冰封隔絕, 郁都郁唔到點生命<br />\n<br />\n粒子運動係物理定律, 去到邊都apply到｡ 以水冰點同沸點去篩選都篩走九成星球｡"},"citedBy":2,"replyTime":"2018-03-26T12:49:30.000Z","msg":"會唔會有其他protein like 嘅嘢唔只六十度denature？"},{"pid":"f7d75f9d1762af6ee0893d885ff50a4ccbd2a41e","tid":606310,"uid":134421,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-26T12:53:12.000Z","msg":"因為已知地球既所有生物都要水先生存到<br />\n咁唔向呢個目標搵生物可以向邊個？"},{"pid":"a984b43fecdb81140a5e8898d47ef8444be124b0","tid":606310,"uid":135132,"like":0,"dislike":0,"score":0,"quote":{"pid":"200df4c281e6046a33cfa6b2663d401d51d64b1f","tid":606310,"uid":3255,"like":0,"dislike":0,"score":0,"quote":{"pid":"a3c87d15b63529d22ba1253263b0e9a575c8f903","tid":606310,"uid":112197,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2018-03-26T12:46:15.000Z","msg":"水係極強既solvent 可以提供一個<span style=\"color: red;\">媒介</span>,浴解好多化合物去提升結合出需要有複雜機制既生命｡水存在亦係該星球<span style=\"color: red;\">氣候</span>係宜居既證明, 而温度重要性相當大｡<br />\n <br />\n<span style=\"color: red;\">過熱</span>粒子運動加速令粒子間既bond<span style=\"color: red;\">唔穩定</span>｡就好似煲雞湯咁,餡都比你滾到出汁仲點生命｡而且蛋白質60度左右就變性, 代表大部份地球生物都生存唔到, 有複雜機制如人類更冇可能生存｡<br />\n<br />\n<span style=\"color: blue;\">過冷</span>甚至結冰, 粒子運動極緩慢<span style=\"color: blue;\">無法結合</span>｡生物各種所需元素, 食物, 都冰封