cLsKty6om5R6Uo%2BMV3ZOx7awwfaZg%3D&h=6efb9e9f\" target=\"_blank\">https://www.reo.gov.hk/ch/voter/gcnr.htm</a><br />\n電子表格傳送門-&gt; <a href=\"https://www.reo.gov.hk/pdf/form/REO-1(C).pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.reo.gov.hk%2Fpdf%2Fform%2FREO-1%28C%29.pdf&d=Ns8Dgi7AEu9liZcLsKty6om5R6Uo%2BMV3ZOx7awwfaZg%3D&h=b275d45a\" target=\"_blank\">https://www.reo.gov.hk/pdf/form/REO-1(C).pdf</a><br />\n實體表格傳送門-&gt; 各區民政事務處<br />\n<a href=\"https://www.had.gov.hk/tc/contact_us/comment_c.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.had.gov.hk%2Ftc%2Fcontact_us%2Fcomment_c.htm&d=Ns8Dgi7AEu9liZcLsKty6om5R6Uo%2BMV3ZOx7awwfaZg%3D&h=61e31e72\" target=\"_blank\">https://www.had.gov.hk/tc/contact_us/comment_c.htm</a><br />\n或公共屋邨辦事處<br />\n<a href=\"http://gia.info.gov.hk/general/201901/29/P2019012900776_303015_1_1548761314431.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fgia.info.gov.hk%2Fgeneral%2F201901%2F29%2FP2019012900776_303015_1_1548761314431.pdf&d=Ns8Dgi7AEu9liZcLsKty6om5R6Uo%2BMV3ZOx7awwfaZg%3D&h=c4b00ae3\" target=\"_blank\">http://gia.info.gov.hk/general/201901/29/P2019012900776_303015_1_1548761314431.pdf</a><br />\n或選舉事務處(香港灣仔港灣道25號海港中心10樓/九龍九龍灣展貿徑1號九龍灣國際展貿中心13樓)<br />\n<br />\n<strong><span style=\"color: red;\">交表</span></strong><br />\n<a href=\"https://www.reo.gov.hk/ch/voter/vrsubmit.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.reo.gov.hk%2Fch%2Fvoter%2Fvrsubmit.htm&d=Ns8Dgi7AEu9liZcLsKty6om5R6Uo%2BMV3ZOx7awwfaZg%3D&h=9c7f92e5\" target=\"_blank\">https://www.reo.gov.hk/ch/voter/vrsubmit.htm</a><br />\n<span style=\"color: violet;\">如你持有有效的香港郵政或電子核證服務有限公司的電子核證（個人）證書 &lt;- 呢個基本冇人有，所以唔使試</span><br />\n<br />\n<strong><span style=\"color: red;\">免費傳真方法 </span></strong><br />\nHelloFax 免費黑白5張 / FAX.PLUS 免費黑白10張<br />\n<br />\n【教學】選民登記7月2日截止仲未搞？ 教你手機內3分鐘完成手續<br />\n<a href=\"https://unwire.hk/2019/06/17/votersubmit/software/android-app/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2