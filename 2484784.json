s/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"a8055a8459ab00fc17ac80e428641d763f58e9e2","tid":2484784,"uid":170893,"like":6,"dislike":0,"score":6,"quote":{"pid":"45610aa61e8a2f551c6abe6b9c67f6a687ad4832","tid":2484784,"uid":159990,"like":3,"dislike":0,"score":3,"quote":{"pid":"56acc933fb1e2485613a78281f917989354e165d","tid":2484784,"uid":103230,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-11T22:28:51.000Z","msg":"佢本人都算唔錯<br />\n但google下佢官網<br />\n究竟呢個miss id 係選d乜<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://miss-id.jp/2021\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmiss-id.jp%2F2021&d=WFG5iCHEkkmufTvr7zh8K8yZng7V5AOcQmv89xdKlzQ%3D&h=82be5644\" target=\"_blank\">https://miss-id.jp/2021</a>"},"citedBy":1,"replyTime":"2021-04-11T23:25:17.000Z","msg":"無錯 係一個唔知選咩的比賽<br />\n<br />\n但我見以前都有出道有一定人氣的明星參加 然後贏下獎  以為係都會鬥下人氣 點知香港人又贏到（相信日本參賽者係日本人氣會比較高吧） 證明人氣都唔一定係全部"},"citedBy":0,"replyTime":"2021-04-12T14:21:36.000Z","msg":"LikeJapan有講大約係選乜<br />\n<br />\nミスiD2021 （miss iD2021）是什麼？<br />\n「ミスiD」是2013年起由日本講談社舉辦的試鏡甄選企劃，目的是找出可成為多樣化新時代女性的榜樣的人，演員及模特兒玉城Tina正是第一屆（ミスiD2013）的冠軍。「ミスiD」中的「iD」是「identity」，而「i」亦等於「我」、「D」表示「diversity」的多樣性。「iD」也有「idol」偶像的意思。歷屆「ミスiD」試鏡均有不同的主題標語，而ミスiD2021的標語為「夢見る頃を、過ぎても」（即使已過了做夢的時刻）、「私だけの物語」（只屬於我自己的故事）。<br />\n<br />\n「ミスiD2021」在2020年4月18日起接受報名，只要是在1980年4月2日 &ndash; 2009年4月1日期間出生的女生，無論國藉、婚姻狀況等均可參加。受疫情影響，ミスiD2021初次以視像的方式進行試鏡，2676名參加者需拍攝30秒的自我介紹，入圍者方會進入之後數輪甄選，最終在2021年4月11日的畢業式上公布勝出者。<br />\n<br />\n<a href=\"https://www.likejapan.com/entertainment/maho-miss-id-2021/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.likejapan.com%2Fentertainment%2Fmaho-miss-id-2021%2F&d=WFG5iCHEkkmufTvr7zh8K8yZng7V5AOcQmv89xdKlzQ%3D&h=4e705666\" data-auto-link target=\"_blank\">https://www.likejapan.com/entertainment/maho-miss-id-2021/</a>"},{"pid":"77589b05af20282d2cd03206d43fc9a7b80ca556","tid":2484784,"uid":15730,"lik