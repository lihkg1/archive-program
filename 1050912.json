l-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fencrypted-tbn0.gstatic.com%2Fimages%3Fq%3Dtbn%253AANd9GcRXCnM0oH_qg8w_YDFC_IpsF99LXXJJnDaJvrwhLJ42xExzTNF0&h=7e2871be&s={SIZE}\" />"},{"pid":"f70c0e181734c79848975412679c047313995124","tid":1050912,"uid":14433,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-03-07T08:15:45.000Z","msg":"簡體字<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />蝗味濃"},{"pid":"6bdee9722fa1d6132dfa95c9d0c907a672659360","tid":1050912,"uid":153615,"like":9,"dislike":49,"score":-40,"quote":{"pid":"d0e17b7d6bf3a67bebea96a761df9e67e9516d91","tid":1050912,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-07T07:55:28.000Z","msg":"叶？<br />\n<img src=\"https://na.cx/i/ay2gRzM.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fay2gRzM.png&h=ef9947d7&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-03-07T08:18:15.000Z","msg":"關仔你查下先啦<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />啦<br />\n<br />\n雖然「葉」字的簡化字寫作「叶」，但不能因此便說「叶」字是簡化字，因為「叶」字本身是另一個字來的。 <br />\n<br />\n《說文解字》云：「協，眾之同和也。从劦，从十。古文協从曰、十，或从口。」 <br />\n<br />\n可見「叶」字是「協」的古文。《廣韻》作「胡頰切」，讀音仍與「協」同。 <br />\n<br />\n至於其同法，則有「叶光」（古代神話中黑帝名）、「叶洽」（歲在未叫叶洽）以及較為常見的「叶韻」（以今韻讀古韻多不同，故南北朝時有「叶韻」之說）。 <br />\n<br />\n主要用例中，並無「姓氏」，可見「叶」字不是姓氏。 <br />\n<br />\n至於「葉」字的簡化字「叶」，不論讀音、用法皆與「葉」同，與上述「叶」字不同。"},{"pid":"ae36fff6947c7e33da4cd3b87f0f512ebfa960b1","tid":1050912,"uid":153615,"like":1,"dislike":16,"score":-15,"citedBy":1,"replyTime":"2019-03-07T08:18:54.000Z","msg":"<blockquote><blockquote>叶？<br />\n<img src=\"https://na.cx/i/ay2gRzM.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fay2gRzM.png&h=ef9947d7&s={SIZE}\" /></blockquote>關仔你查下先啦<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n雖然「葉」字的簡化字寫作「叶」，但不能因此便說「叶」字是簡化字，因為「叶」字本身是另一個字來的。 <br />\n<br />\n《說文解字》云：「協，眾之同和也。从劦，从十。古文協从曰、十，或从口。」 <br />\n<br />\n可見「叶」字是「協」的古文。《廣韻》作「胡頰切」，讀音仍與「協」同。 <br />\n<br />\n至於其同法，則有「叶光」（古代神話中黑帝名）、「叶洽」（歲在未叫叶洽）以及較為常見的「叶韻」（以今韻讀古韻多不同，故南北朝時有「叶韻」之說）。 <br />\n<br />\n主要用例中，並無「姓氏」，可見「叶」字不是姓氏。 <br />\n<br />\n至於「葉」字的簡化字「叶」，不論讀音、用法皆與「葉」同，與上述「叶」字不同。</blockquote>"},{"pid":"5895952b4e81c4b78d9acbfb0ebb627b26ec3cda","tid":1050912,"uid":45914,"like":1,"dislike":17,"score":-16,"citedBy":1,"replyTime":"2019-03-07T08:20:15.000Z","msg":"此回覆已被刪除"},{"pid":"5ea2b29a1384b007b646d54c3323619b2e3e7f5d","tid":1050912,"uid":47359,"like":30,"dislike":2,"score":28,"quote":{"pid":"6bdee9722fa1d6132dfa95c9d0c907a672659360","tid":1050912,"uid":153615,"like":9,"dislike":49,"score":-40,"quote":{"pid":"d0e17b7d6bf3a67bebea96a761df9e67e9516d91","tid":1050912,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-07T07:55:28.000Z","msg":"叶？<br />\n<img src=\"https://na.cx/i/ay2gRzM.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fay2gRzM.png&h=ef9947d7&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-03-07T08:18:15.000Z","msg":"關仔你查下先啦<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />啦<br />\n<br />\n雖然「葉」字的簡化字寫作「叶」，但不能因此便說「叶」字是簡化字，因為「叶」字本身是另一個字來的。 <br />\n<br />\n《說文解字》云：「協，眾之同和也。从劦，从十。古文協从曰、十，或从口。」 <br />\n<br />\n可見「叶」字是「協」的古文。《廣韻》作「胡頰切」，讀音仍與「協」同。 <br />\n<br />\n至於其同法，則有「叶光」（古代神話中黑帝名）、「叶洽」（歲在未叫叶洽）以及較為常見的「叶韻」（以今韻讀古韻多不同，故南北朝時有「叶韻」之說）。 <br />\n<br />\n主要用例中，並無「姓氏」，可見「叶」字不是姓氏。 <br />\n<br />\n至於「葉」字的簡化字「叶」，不論讀音、用法皆與「葉」同，與上述「叶」字不同。"},"citedBy":1,"replyTime":"2019-03-07T08:21:26.000Z","msg":"主要用例中，並無「姓氏」，可見「叶」字不是姓氏。"},{"pid":"477943c86cb3c996d03162fa66469864f36fba4e","tid":1050912,"uid":60545,"like":4,"dislike":2,"score":2,"quote":{"pid":"f70c0e181734c79848975412679c047313995124","tid":1050912,"uid":14433,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-03-07T08:15:45.000Z","msg":"簡體字<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />蝗味濃"},"citedBy":0,"replyTime":"2019-03-07T08:21:35.000Z","msg":"支那雞<img src=\"/assets/faces/lm2/ok.gif\" class=\"hkgmoji\" />"},{"pid":"e71c547161c1e0def0e2427b7b3efed9cf5e5459","tid":10