1993121,"uid":226387,"like":0,"dislike":0,"score":0,"quote":{"pid":"4bd9e4108778f0deedb92292f26a3195c1e1033b","tid":1993121,"uid":295056,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-28T16:38:13.000Z","msg":"樓主知唔知答案咖？"},"citedBy":0,"replyTime":"2020-04-28T16:44:28.000Z","msg":"唔知<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}