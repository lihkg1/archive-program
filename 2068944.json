mal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"86942f4246386bd5ec3ff27828bad7c8001e1efd","tid":2068944,"uid":8738,"like":0,"dislike":0,"score":0,"quote":{"pid":"8631393341deb510d665e2313810cabdda69dfc8","tid":2068944,"uid":267563,"like":0,"dislike":0,"score":0,"quote":{"pid":"1b633d98882b35bda82d8774646bc7f2e254fb25","tid":2068944,"uid":44786,"like":0,"dislike":0,"score":0,"quote":{"pid":"e52d1c23b93eed5d1c20544ac0b5f3048b082972","tid":2068944,"uid":267563,"like":3,"dislike":6,"score":-3,"citedBy":3,"replyTime":"2020-06-18T06:16:18.000Z","msg":"當年鄭鈞傑條撚樣話自己唔會做校長，唔鐘意揸權，想做班主任多啲<br />\n<br />\n好啦，由副校升校長代理，又話一年後點都唔會繼續做校長，會另覓人選，結果一做就做到依家<br />\n<br />\n口講一套做就另一套，鐘意揸權又要扮唔鐘意，呢啲戀棧權力嘅撚屌最撚陰濕，最後咪一條仆街為咗揸權就賣撚咗間校之前嗰200年建立嘅文化同聲譽<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">奶共奶到咁撚樣你對唔對得住校訓呀英華舊生鄭鈞傑</span></span>"},"citedBy":2,"replyTime":"2020-06-18T06:32:52.000Z","msg":"屌 咪on9喇你<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />黃唔黃唔使開咪上報紙講既 你有同佢傾過計 有留意下佢fb就知佢咩取態喇 <br />\n<br />\n佢呢個角色 唔通擺到明咁講話支持港獨咩？ <br />\n再者英華有公眾形象 都唔可以做到咁出面喇 <br />\n<br />\n我就唔覺佢會真係記班學生過喇<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n伸利：舊生<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-18T07:38:17.000Z","msg":"真係畀你吹漲<br />\n16年就話唔會阻止講港獨議題<br />\n14反國教嗰年assembly邵中仲可以上台屌龐狗開聲反國教<br />\n依家悼個念校方就發聲明話不認同又話要見家長，高調打壓學生，仲邊有人敢喺到搞本土活動？最後咪好似以前咁得嗰十幾個搞手搞囉<br />\n仲有呀，英華黃係班學生黃呀，唔撚係班高層黃，關佢地撚事咩<br />\n家教會個副主席咪係好例子囉，紅到黑呀<br />\n個人立場係黃又點？我都可以話郭偉健係黃，唔通要擺到明支持港獨咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n利申: 成家都係舊生"},"citedBy":0,"replyTime":"2020-06-18T08:07:40.000Z","msg":"屌你幾年前點同而家比呀<br />\n幾年前教畜局有冇染紅得咁緊要<br />\n幾年前夠唔夠膽DQ DSE題目<br />\n如果英華高層唔係黃（校董除外）班師弟一早比人割撚左蓆十世啦<br />\n上年到而家英華校園抗爭都見過幾次報<br />\n有冇見過有師弟比人清算？<br />\n今次呢單野搞到咁大，高層真心冇可能唔做野<br />\n有時我覺得既然大家都有類似立場，都算係同路人，就唔好搞到大家難做啦<br />\n希望師弟都可以體諒下學校<br />\n我覺得反而你地集體走堂去和你lunch都冇呢單野迴響咁大，當然唔好著住校服啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"efa52b930eaf32b2708315da12673546eb2f5c8d","tid":2068944,"uid":259732,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-18T08:09:18.000Z","msg":"盡做 大過小過冇用唔使驚<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e448f23018a22f78354a40b2a28b38d91fb375c7","tid":2068944,"uid":185544,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-18T08:11:22.000Z","msg":"狗都未驚 驚你？"},{"pid":"9090cbe26445434188f141a03ad0948e0817eeed","tid":2068944,"uid":131772,"like":0,"dislike":0,"score":0,"quote":{"pid":"804d13ce08bf6413f6155b65b5bf9032dd344c46","tid":2068944,"uid":318980,"like":53,"dislike":0,"score":53,"citedBy":2,"replyTime":"2020-06-18T05:03:30.000Z","msg":"如果見家長果時個家長對住個校長講同唱, 洗唔洗罰埋個家長<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-18T08:27:40.000Z","msg":"學校報驚<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}