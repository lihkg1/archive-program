ces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1b157d781da544116a72a5534c3596180f67f0ec","tid":1486182,"uid":251246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T19:45:39.000Z","msg":"<span style=\"font-size: x-large;\"><span style=\"color: red;\">殺人政權 一拖再拖<br />\n五大訴求 刻不容緩</span></span>"},{"pid":"79ef5110d16d1af422f912157870ef077ef463e8","tid":1486182,"uid":251246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T19:46:17.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: x-large;\">殺人政權 一拖再拖<br />\n五大訴求 刻不容緩</span></span>"},{"pid":"fefcf1fb68005d1d02f15cbfd6d0c1d62b115d1d","tid":1486182,"uid":89160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T19:52:23.000Z","msg":"幫推"},{"pid":"4f6b8c99f99f52504259e27374efb4b73ce8fb0e","tid":1486182,"uid":139409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T19:52:37.000Z","msg":"幫推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n【英重量級議員 促給港人完整英國國籍】<br />\n<br />\n<img src=\"https://na.cx/i/bnf9O7G.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fbnf9O7G.jpg&h=5ee9af01&s={SIZE}\" /><br />\n<br />\n// 英國下議院外交委員會主席圖根達特（Tom Tugendhat）呼籲，政府應給予香港人完整的英國國籍，作為與北京對峙的一種保障。（法新社）//<br />\n<br />\n👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻<br />\n<br />\n1分鐘時間幫幫手簽<br />\n夠10萬個就有機會喺英國國會討論<br />\n<br />\n喺香港住嘅tick返Hong Kong<br />\nPostal code 就打0852<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=L%2B62T2%2Bn9M6BECqB4mLSsudgoykoOisTuuABwIAScok%3D&h=c5fb65ee\" target=\"_blank\">https://petition.parliament.uk/petitions/244402</a><br />\n<br />\nQ&amp;A<br />\nQ: 簽咗咁多聯署 / 英國佬唔會幫我地 / 英國佬講咗咁耐都冇做過嘢簽嚟都冇用<br />\n<br />\nA: 唔洗1分鐘搞掂又冇成本嘅嘢點解唔做咗先 <br />\n<br />\n六合彩咁難中你又買<br />\n夠10萬個就有機會喺英國國會討論<br />\n<br />\n今次係有下議會議員帶頭講要俾full citizenship BNO holder<br />\n10萬人都簽唔到叫人地點幫你啊<br />\n我地要送子彈啊<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n🔥⭐️Q: 好多97後都冇BNO 我地唔可以扔低佢地⭐️🔥<br />\n<br />\nA: 有BC又有幾多人會即刻走 <br />\n反而有咗後路可以更盡情咁去抗爭<br />\n同埋到時大量英國國民喺香港 可以增加英國嘅談判籌碼<br />\n真係去到最壞情況都可以諗方法帶埋d細路走<br />\n<br />\nQ: 佢要tick Only British citizens or UK residents have the right to sign<br />\n我 得 / 冇BNO簽唔簽得？<br />\n<br />\nA: 唔洗verify citizenship 自己諗簽唔簽<br />\n只要提供 email address + 英文名 ＋選Location + Postal code<br />\n<br />\nQ: Postal code 打咩好？<br />\n<br />\nA: 記住喺香港住嘅tick返Hong Kong<br />\nPostal code 成功例子參考<br />\n852 <br />\n0852 <br />\n00000 <br />\n000000<br />\n<br />\n再貼多次條Link:<br />\n<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=L%2B62T2%2Bn9M6BECqB4mLSsudgoykoOisTuuABwIAScok%3D&h=c5fb65ee\" target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"af3e88779beacf29ef6ec7ae5a353d1b663279c3","tid":1486182,"uid":136221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T19:52:49.000Z","msg":"個人覺得可以俾5日政府回應我哋五大訴求<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><br />\n<br />\n立即回應五大訴求 否則全面升級武力<br />\n<a href=\"https://lih.kg/1486060\" data-auto-link target=\"_blank\">https://lih.kg/1486060</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n８２３人鏈：香港之路Hong Kong Way正！式！上！線！！！！！！<br />\n<a href=\"https://lih.kg/1486119\" data-auto-link target=\"_blank\">https://lih.kg/1486119</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"3a02dc3226ad364f8d815b6768b65fbf1fa5956b","tid":1486182,"uid":120729,"like":0,"dislike":0,"score":0,"citedBy":0,"reply