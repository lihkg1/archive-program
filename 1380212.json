讓步係起點由花墟公園改去楓樹街球場。<br />\n<br />\n改完又完，依家都係要等警察下星期再覆，希望各位手足記得811出嚟深水埗，依家2點半，楓樹街遊樂場見！"},{"pid":"72d4a1157342e45b010c0a8877baa2e8c50507d2","tid":1380212,"uid":190178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T07:56:35.000Z","msg":"<img src=\"https://na.cx/i/r9NYOU4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fr9NYOU4.jpg&h=5201a62b&s={SIZE}\" />"},{"pid":"7cb303f5514df2d4e2719cdf12e9ee3e0f72ad54","tid":1380212,"uid":190178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T17:36:22.000Z","msg":"<img src=\"https://na.cx/i/OcwSb8m.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOcwSb8m.jpg&h=4b3191fc&s={SIZE}\" />"},{"pid":"e0b25c8ea3e7b855878d9718eb9af2a10ca6e00f","tid":1380212,"uid":190178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T17:36:37.000Z","msg":"<img src=\"https://na.cx/i/OcwSb8m.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOcwSb8m.jpg&h=4b3191fc&s={SIZE}\" />"},{"pid":"d19393e072b2786594cc0c55022d29a3b573dc00","tid":1380212,"uid":205761,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T16:45:47.000Z","msg":"<img src=\"https://na.cx/i/gezH54T.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgezH54T.png&h=5c7244c3&s={SIZE}\" />"}]}