48d788b82f59b14e997dd3f36","tid":1979621,"uid":91914,"like":1,"dislike":0,"score":1,"quote":{"pid":"1cc530ce935719f19efe728e45557b44136263c3","tid":1979621,"uid":109759,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-04-19T16:16:45.000Z","msg":"Thx 輸緊了"},"citedBy":1,"replyTime":"2020-04-19T16:18:58.000Z","msg":"連登吹奏既3175同7500，你入左邊飯？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-04-19T16:24:27.000Z","msg":"3175😃"},"citedBy":2,"replyTime":"2020-04-19T16:29:07.000Z","msg":"坐多陣，可能下月轉倉前彈返呢"},{"pid":"f9dcee97f6700df59acb3d4292b1ec81de16cd20","tid":1979621,"uid":91914,"like":4,"dislike":0,"score":4,"quote":{"pid":"64f9cd892487e4bbf52349d5f6c6ad4dff611416","tid":1979621,"uid":131892,"like":0,"dislike":1,"score":-1,"quote":{"pid":"14794e19b93fcd32eb54b02e1b84550319290f30","tid":1979621,"uid":109759,"like":0,"dislike":0,"score":0,"quote":{"pid":"0e90faef0b3c90848d788b82f59b14e997dd3f36","tid":1979621,"uid":91914,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-04-19T16:18:58.000Z","msg":"連登吹奏既3175同7500，你入左邊飯？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-04-19T16:24:27.000Z","msg":"3175😃"},"citedBy":2,"replyTime":"2020-04-19T16:29:07.000Z","msg":"坐多陣，可能下月轉倉前彈返呢"},"citedBy":1,"replyTime":"2020-04-19T16:32:33.000Z","msg":"【炒油輸大鑊】對賭油價 3175長輸之謎（股榮）<br />\n<br />\n「先求知，再投資」，簡單六個字，對於很多散者而言，卻會視為「先落注，再睇睇」。近日收到幾封查詢，針對一隻聲稱與國際油價掛鈎的ETF股份有關:三星標普高盛原油ER期貨ETF（下簡稱3175）。<br />\n<br />\n3175近月成交高得誇張，上周每日成交動輒逾十億元，高於多隻藍籌股。有網友揚言，用了籌備結婚的數十萬元押注3175，滿以為國際油價早前急瀉，欲選擇以3175作為博油價反彈的工具，但股價不似預期，油價升，3175升唔足；油價跌，3175跌得更多，滿腦子是陰謀論，是否發行商食價、或是產品特性有如窩輪等有時間值問題，以致跟不足油價。<br />\n絕大部份投資者，應該未曾望過3175的發行章程，有揸貨的散戶應該睇下，而散戶欲對原油市場有初步了解，這個亦是很好的教學文件。（ <a href=\"https://www1.hkexnews.hk/listedco/listconews/sehk/2019/1231/2019123100835_c.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww1.hkexnews.hk%2Flistedco%2Flistconews%2Fsehk%2F2019%2F1231%2F2019123100835_c.pdf&d=BjPUJoueJJBj8huYKMWPWpLurRSHZiEGX9rhKonVocs%3D&h=bbcdfb5c\" target=\"_blank\">https://www1.hkexnews.hk/listedco/listconews/sehk/2019/1231/2019123100835_c.pdf</a>）<br />\n<br />\n簡單講，3175絕非如盈富基金（2800）跟蹤恒指般咁簡單直接，而是透過投資於紐約期油（WTI）不同期限合約，以追蹤一項石油期貨指數的表現。3175追蹤的指數是標普高盛原油額外回報指數（下稱指數），該指數不單包括即月期油合約、還包括了下一個月的期油合約，由於指數每個月有五日會進行轉倉，即月與翌月的合約價差，就會令指數產生正價差或負價差，直接影響到3175價格變化，就算油價造好，亦會因出現正價差而錄得負數的「轉倉收益」。<br />\n<br />\n如果睇到這裡仍然一頭霧水，原因是大家所投資的，不是油價，而是由不同合約期建構的一項結構產品。下面一個例子，希望能使大家有較清晰概念。<br />\n3175所持有的資產，是「最近期」期油合約+「第二最近期」合約。以今年4月為例，最近期合約是今年5月WTI紐約期油合約，上周五收報18.27美元。由於期油每逢每月下旬要轉倉，指數要根據標普高盛商品指數營業日在第五、第六、第七、第八、及第九日（見表），分五日轉倉至下一個月期油合約（今年6月份），而6月份紐約期油為25.03美元（見表），兩個月期貨價相差6.76美元或37%。<br />\n根據玩法，於第5日，指數會沽出20%即月（5月）合約、而買入20%下月（6月）合約。而到了第6日，會再沽出20%即月合約、再買入額外20%下月合約，直至第九日，3175所持有的，是100%6月份期油合約。換言之，如果在轉倉期間， 6月期油價高於5月期油價，低賣高買下，出售所得收益不足以購入相同數目的WTI期貨合約，遂出現所謂負數「轉倉收益」，令資產淨值下跌，3175股價亦會作出調整。<br />\n三星網站有個模擬對比紐約期油與3175兩者之間的表現，過去四年，3175累跌66%，而紐約期油則跌45%，3175跑輸期油21個百分點（見圖）。將時間縮短至2016至2018年油價急彈期間，紐約期油升約60%，反觀3175同期僅升30%，回報相差一倍。過去一年油價急跌，3175同樣跑輸期油達8個百分點。<br />\n因此，3175跑輸油價，不是發行商食價、或是產品縮vol輸時間值等問題，而是先天性產品結構，並不是散戶應該買的產品。大家一窩蜂落注前，完全沒有了解產品背後性質及風險，輸錢與人無尤。如果以為油價一定升，3175長揸等運到，更屬自殺行為，結果相當慘淡。<br />\n股榮<br />\n<a href=\"https://www.facebook.com/stockwing1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fstockwing1&d=BjPUJoueJJBj8huYKMWPWpLurRSHZiEGX9rhKonVocs%3D&h=bc6e625a\" target=\"_blank\">https://www.facebook.com/stockwing1</a>"},{"pid":"ff033eb35bf8f33b4f9d5156221af47d7c923c29","tid":1979621,"uid":109759,"like":0,"dislike":0,"score":0,"quote":{"pid":"64f9cd892487e4bbf52349d5f6c6ad4dff611416","tid":1979621,"uid":131892,"like":0,"dislike":1,"score":-1,"quote":{"pid":"14794e19b93fcd32eb54b02e1b84550319290f30","tid":1979621,"uid":109759,"like":0,"dislike":0,"score":0,"quote":{"pid":"0e90faef0b3c90848d788b82f59b14e997dd3f36","tid":1979621,"uid":91914,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-04-19T16:18:58.000Z","msg":"連登吹奏既3175同7500，你入左邊飯？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-04-19T16:24:27.000Z","msg":"3175😃"},"citedBy":2,"replyTime":"2020-04-19T16:29:07.000Z","msg":"坐多陣，可能下月轉倉前彈返呢"},"citedBy":1,"replyTime":"2020-04-19T16:33:13.000Z","msg":"希望 回本馬上走 入3桶油"},{"pid":"ec27f006ee162cb7dda68c0d67d435f3af164023","tid":1979621,"uid":33874,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-19T16:33:28.000Z","msg":"你以為自己媽咪麵呀"},{"pid":"8dac00ee8e01bcefcf557acaf0033d23710feffd","tid":1979621,"uid":131892,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec27f006ee162cb7dda68c0d67d435f3af164023","tid":1979621,"uid":33874,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-19T16:33:28.000Z","msg":"你以為自己媽咪麵呀"},"citedBy":0,"replyTime":"2020-04-19T16:35:01.000Z","msg":"點都唔會燈到啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"afd68f3b263c6e030fa68458855030386b9bbe97","tid":1979621,"uid":91914,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff033eb35bf8f33b4f9d5156221af47d7c923c29","tid":1979621,"uid":109759,"like":0,"dislike":0,"score":0,"quote":{"pid":"64f9cd892487e4bbf52349d5f6c6ad4dff611416","tid":1979621,"uid":131892,"like":0,"dislike":1,"score":-1,"quote":{"pid":"14794e19b93fcd32eb54b02e1b84550319290f30","tid":1979621,"uid":109759,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-04-19T16:24:27.000Z","msg":"3175😃"},"citedBy":2,"replyTime":"2020-04-19T16:29:07.000Z","msg":"坐多陣，可能下月轉倉前彈返呢"},"citedBy":1,"replyTime":"2020-04-19T16:33:13.000Z","msg":"希望 回本馬上走 入3桶油"},"citedBy":0,"replyTime":"2020-04-19T16:35:53.000Z","msg":"入左幾多7500？"},{"pid":"7add696242026f8f338057e6002731e5cb8ddca5","tid":1979621,"uid":109759,"like":0,"dislike":0,"score":0,"quote":{"pid":"f9dcee97f6700df59acb3d4292b1ec81de16cd20","tid":1979621,"uid":91914,"like":4,"dislike":0,"score":4,"quote":{"pid":"64f9cd892487e4bbf52349d5f6c6ad4dff611416","tid":1979621,"uid":131892,"like":0,"dislike":1,"score":-1,"quote":{"pid":"14794e19b93fcd32eb54b02e1b84550319290f30","tid":1979621,"uid":109759,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-04-19T16:24:27.000Z","msg":"3175😃"},"citedBy":2,"replyTime":"2020-04-19T16:29:07.000Z","msg":"坐多陣，可能下月轉倉前彈返呢"},"citedBy":1,"replyTime":"2020-04-19T16:32:33.000Z","msg":"【炒油輸大鑊】對賭油價 3175長輸之謎（股榮）<br />\n<br />\n「先求知，再投資」，簡單六個字，對於很多散者而言，卻會視為「先落注，再睇睇」。近日收到幾封查詢，針對一隻聲稱與國際油價掛鈎的ETF股份有關:三星標普高盛原油ER期貨ETF（下簡稱3175）。<br />\n<br />\n3175近月成交高得誇張，上周每日成交動輒逾十億元，高於多隻藍籌股。有網友揚言，用了籌備結婚的數十萬元押注3175，滿以為國際油價早前急瀉，欲選擇以3175作為博油價反彈的工具，但股價不似預期，油價升，3175升唔足；油價跌，3175跌得更多，滿腦子是陰謀論，是否發行商食價、或是產品特性有如窩輪等有時間值問題，以致跟不足油價。<br />\n絕大部份投資者，應該未曾望過3175的發行章程，有揸貨的散戶應該睇下，而散戶欲對原油市場有初步了解，這個亦是很好的教學文件。（ <a href=\"https://www1.hkexnews.hk/listedco/listconews/sehk/2019/1231/2019123100835_c.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww1.hkexnews.hk%2Flistedco%2Flistconews%2Fsehk%2F2019%2F1231%2F2019123100835_c.pdf&d=BjPUJoueJJBj8huYKMWPWpLurRSHZiEGX9rhKonVocs%3D&h=bbcdfb5c\" target=\"_blank\">https://www1.hkexnews.hk/listedco/listconews/sehk/2019/1231/2019123100835_c.pdf</a>）<br />\n<br />\n簡單講，3175絕非如盈富基金（2800）跟蹤恒指般咁簡單直接，而是透過投資於紐約期油（WTI）不同期限合約，以追蹤一項石油期貨指數的表現。3175追蹤的指數是標普高盛原油額外回報指數（下稱指數），該指數不單包括即月期油合約、還包括了下一個月的期油合約，由於指數每個月有五日會進行轉倉，即月與翌月的合約價差，就會令指數產生正價差或負價差，直接影響到3175價格變化，就算油價造好，亦會因出現正價差而錄得負數的「轉倉收益」。<br />\n<br />\n如果睇到這裡仍然一頭霧水，原因是大家所投資的，不是油價，而是由不同合約期建構的一項結構產品。下面一個例子，希望能使大家有較清晰概念。<br />\n3175所持有的資產，是「最近期」期油合約+「第二最近期」合約。以今年4月為例，最近期合約是今年5月WTI紐約期油合約，上周五收報18.27美元。由於期油每逢每月下旬要轉倉，指數要根據標普高盛商品指數營業日在第五、第六、第七、第八、及第九日（見表），分五日轉倉至下一個月期油合約（今年6月份），而6月份紐約期油為25.03美元（見表），兩個月期貨價相差6.76美元或37%。<br />\n根據玩法，於第5日，指數會沽出20%即月（5月）合約、而買入20%下月（6月）合約。而到了第6日，會再沽出20%即月合約、再買入額外20%下月合約，直至第九日，3175所持有的，是100%6月份期油合約。換言之，如果在轉倉期間， 6月期油價高於5月期油價，低賣高買下，出售所得收益不足以購入相同數目的WTI期貨合約，遂出現所謂負數「轉倉收益」，令資產淨值下跌，3175股價亦會作出調整。<br />\n三星網站有個模擬對比紐約期油與3175兩者之間的表現，過去四年，3175累跌66%，而紐約期油則跌45%，3175跑輸期油21個百分點（見圖）。將時間縮短至2016至2018年油價急彈期間，紐約期油升約60%，反觀3175同期僅升30%，回報相差一倍。過去一年油價急跌，3175同樣跑輸期油達8個百分點。<br />\n因此，3175跑輸油價，不是發行商食價、或是產品縮vol輸時間值等問題，而是先天性產品結構，並不是散戶應該買的產品。大家一窩蜂落注前，完全沒有了解產品背後性質及風險，輸錢與人無尤。如果以為油價一定升，3175長揸等運到，更屬自殺行為，結果相當慘淡。<br />\n股榮<br />\n<a href=\"https://www.facebook.com/stockwing1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fstockwing1&d=BjPUJoueJJBj8huYKMWPWpLurRSHZiEGX9rhKonVocs%3D&h=bc6e625a\" target=\"_blank\">https://www.facebook.com/stockwing1</a>"},"citedBy":0,"replyTime":"2020-04-19T16:35:57.000Z","msg":"咁可以點"},{"pid":"7659e6a111e7e2c02bf78b62b65032cebdd93e8e","tid":1979621,"uid":291750,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-04-19T16:36:57.000Z","msg":"大家蠃多啲<br />\n<br />\n幫推「資訊戰」 有個痴線佬準備好晒中宣部旗下Youtuber嘅report<br />\n<a href=\"https://lih.kg/1957525\" data-auto-link target=\"_blank\">https://lih.kg/1957525</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"86cb5246b5449d1dd3639de801a784a16e5435be","tid":1979621,"uid":55533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T16:37:45.000Z","msg":"7200+2800 雙收<img src=\"/assets/faces/lm2/yeah.gif\" class=\"hkgmoji\" />"},{"pid":"680e10e0ad8cf9ffaac10e93e7c8ec2828e28690","tid":1979621,"uid":208722,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T16:38:39.000Z","msg":"其實財經台係咪平行時空嚟？"},{"pid":"8fb14e588a2bff837d88fe8f35c4992646675ebe","tid":1979621,"uid":191613,"like":1,"dislike":1,"score":0,"quote":{"pid":"4627c0f1dd999bbba8392c5ec4fd40969f883f9f","tid":1979621,"uid":19725,"like":12,"dislike":1,"score":11,"quote":{"pid":"007e1dccd4755ef2d9e780019790f035cd7525eb","tid":1979621,"uid":149494,"like":18,"dislike":1,"score":17,"citedBy":2,"replyTime":"2020-04-19T15:12:51.000Z","msg":"樓主無錯<br />\n根本今次擺明係全球放水唔比個巿再好似08年咁跌"},"citedBy":3,"replyTime":"2020-04-19T15:53:05.000Z","msg":"如果係咁救到市 世界都無窮人 津巴布偉都唔會收皮<br />\n人估人人都係美國 人人都渣美金 ？<br />\n中國放4萬億炸到成個房地產泡沫幾勁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-19T16:40:05.000Z","msg":