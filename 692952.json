assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"bcc63e8973964403d8d424752a09d4cf10553415","tid":692952,"uid":25028,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-06-07T14:19:00.000Z","msg":"依排食左幾次雞胸都麻麻地<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4f76e8acde397f971c76f992206b1739d387de34","tid":692952,"uid":25635,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-06-07T14:24:29.000Z","msg":"Ok,呢篇可以按合約有糧出<br />\n另外見你有誠意promote埋咕嚕肉<br />\n24小時內收到500正皮就出1.5倍糧，淨值係正數有1.1倍<br />\n淨值有500正皮出3倍"},{"pid":"30413032b112a86072446ca0e5d9b97991c10965","tid":692952,"uid":49918,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-07T14:27:01.000Z","msg":"此回覆已被刪除"},{"pid":"2da02e97e9df593103650656dfb6b0cb0c5789bc","tid":692952,"uid":5422,"like":0,"dislike":0,"score":0,"quote":{"pid":"ac5ca2401cd2f64ce4f665d904d76b5b79608719","tid":692952,"uid":13914,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-06-07T14:17:51.000Z","msg":"咕嚕肉睇落幾好<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-07T14:42:46.000Z","msg":"超正<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />  咕嚕肉外脆內軟<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"06ae848e826615f033ca87cb0a0bc605db1cc8a1","tid":692952,"uid":5422,"like":0,"dislike":0,"score":0,"quote":{"pid":"bcc63e8973964403d8d424752a09d4cf10553415","tid":692952,"uid":25028,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-06-07T14:19:00.000Z","msg":"依排食左幾次雞胸都麻麻地<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-07T14:44:20.000Z","msg":"我食嚿雞胸超嫩滑軟熟<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5841c55e37a4d329c2d726d12e03dbbed27e5dad","tid":692952,"uid":172536,"like":0,"dislike":0,"score":0,"quote":{"pid":"cf14d1aa244cd1b446615106e23fc1ee96c9ac96","tid":692952,"uid":172536,"like":1,"dislike":2,"score":-