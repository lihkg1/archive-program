rc=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"dbe00ee571d12b29f65756460e3a7b683d43ed60","tid":1535441,"uid":17399,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2019-09-04T00:07:10.000Z","msg":"又話2020年取代香港<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><br />\n仲有4個月時間 deadline fighter<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"317b3f76e534ac2285ea1e10f34cb35621bfabd6","tid":1535441,"uid":46746,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T00:14:04.000Z","msg":"冇香港支共晨早支爆左喇<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7cdccc583a3d241ed11fb12ba453556a8d6a7f83","tid":1535441,"uid":192754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T00:17:20.000Z","msg":"垃撚圾"},{"pid":"2d577c988475fb1fbaeb8ebd47d5e51bcd46f3cb","tid":1535441,"uid":57542,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-09-04T00:18:59.000Z","msg":"依家討論區俾人帶住風向走<br />\n真正有心post唔會有人覆<br />\n<br />\n如果獨立調查委員會話你知&quot;無高官需要問責&quot;你係咪要接受呀？<br />\n<br />\n<br />\n<a href=\"https://lih.kg/1441577\" data-auto-link target=\"_blank\">https://lih.kg/1441577</a>"},{"pid":"10a0ee3769b40fed2463fcf67dc5da95ca952089","tid":1535441,"uid":121146,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T00:19:38.000Z","msg":"香港人又輸"},{"pid":"a38347c6c64f825b75e1d58e60aaf4bdaeadc500","tid":1535441,"uid":275884,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T00:20:43.000Z","msg":"香港慘啦，比上海取代國際金融中心地位啦😭"},{"pid":"64bdc52eb432911a2daa4734b2df062839946dec","tid":1535441,"uid":10064,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T00:21:39.000Z","msg":"中国式自由"},{"pid":"49f24c9c16057c6e9da6b13a9655db5aebb033ff","tid":1535441,"uid":264988,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T00:25:47.000Z","msg":"又系外國勢力 報假新聞"},{"pid":"c362f652a34443d9ca0425f8f173917aed79706a","tid":1535441,"uid":138012,"like":0,"dislike":0,"score":0,"quote":{"pid":"2acf7558b4f062badbee7788e27dd7ac45a52b91","tid":1535441,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-09-03T11:01:03.000Z","msg":"<img src=\"https://img.ltn.com.tw/Upload/business/page/800/2019/09/02/phpoDStFV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.ltn.com.tw%2FUpload%2Fbusiness%2Fpage%2F800%2F2019%2F09%2F02%2FphpoDStFV.jpg&h=0c71a6b8&s={SIZE}\" /><br />\n<br />\n〔財經頻道／綜合報導〕中國的「上海自由貿易試驗區」2013年推行時曾喧騰一時，也曾引發各種討論，當時官員曾宣稱這將吸引更多外國投資，深化與週遭各國的貿易關係，不過6年過去後，當《路透》實地探訪時，卻發現此地現在已是「環堵蕭然」的狀態。<br />\n<br />\n《路透》在以「銀行離去徒留殭屍帳戶 中國上海自貿區發展艱難」為題的報導中這樣描述現在上海自貿區的「上海外高橋保稅區」：「辦公室人去樓空，玻璃大門深鎖，椅子胡亂堆疊，曾經上班族人滿為患的食堂，進駐餐館一間一間關門，用過的筷子及塑膠餐具散亂在地。」<br />\n<br />\n上海華瑞銀行在上海自貿區的業務傳出不振，招商銀行據傳已經解散自貿區業務團隊，寧波銀行在自貿區有4間分行，但基本上只執行一般銀行業務，自貿區的帳戶基本不太使用，成為「殭屍帳戶」。<br />\n<br />\n報導指出，除了因美中貿易戰而導致的經濟放緩以外，造成上海自貿區這種慘況的理由，更多來自當局對資本的管控：雖然2013年自貿區成立時，中國官員曾承諾更自由的貨幣流通及更簡便的國際貿易，但事實上卻反其道而行，使企業逐步離開自貿區。<br />\n<br />\n寧波銀行內部人士曾抱怨，自貿區帳戶不但每筆交易都要上報，而且還不能與普通帳戶共用，「根本無用」；南京銀行內部人士則批評，自貿區業務比較像在服務政府目標，而非商業機會；上海財經大學教授丁劍平則直言，上海自貿區現在已「不再便捷」。<br />\n<br />\n東方資本研究公司（Orient Capital Research）總經理克立爾（Andrew Collier）認為，上海自貿區減少地方政府稅收，且與政府阻止資金外流的目標矛盾，使得難以達成政府想要的效果，即使有新的自貿區也一樣。"},"citedBy":0,"replyTime":"2019-09-04T00:26:48.000Z","msg":"冇理由嘅上海2020年要超越香港嫁嘛 很肯定路透記者被fake啦 <img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"da2f69bd8e510a4cbd804bc4b834066b68570a87","tid":1535441,"uid":31069,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T00:28:47.000Z","msg":"上海已超越香港<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"ab437ed8343dc80abf6cbcd5ba302070a55f16ff","tid":1535441,"uid":137627,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-04T00:29:50.000Z","msg":"用下腦都知（如果有），求其劃個圈就可以覆制香港既話，每個國家都有一個啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e44a5ee39d8be