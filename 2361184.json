1184,"uid":51752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-10T12:27:25.000Z","msg":"<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"642e3c66fbcc5c7098fce0a053b40b20f1a8e42e","tid":2361184,"uid":39710,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2021-01-10T12:28:28.000Z","msg":"香港啲狗幾時先拎返公安級別人工, 憑咩有特權收咁多"},{"pid":"165f0c80a5107c44a86a6a016358deccaebfa369","tid":2361184,"uid":78947,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-01-10T12:29:52.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b5b7f1ce11ba30978b4cb08f1fb42baf7cd24f24","tid":2361184,"uid":51271,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-01-10T12:30:30.000Z","msg":"出支那人工囉"},{"pid":"0d393222efc02713dc77882d9bf0b1cc943cbc55","tid":2361184,"uid":25468,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-10T12:36:15.000Z","msg":"香港係 9月99號"},{"pid":"626307ab9ba2318fc24d739de7623758b441d77c","tid":2361184,"uid":126919,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-10T13:51:40.000Z","msg":"<img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" />"},{"pid":"dc32c8c4e812ffa6fc940740c77fd097266395e5","tid":2361184,"uid":146621,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-10T13:55:28.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"7d6228b21174fbb59dd18a9907fad90c57173dad","tid":2361184,"uid":166729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-10T14:00:31.000Z","msg":"好感動, 支持香港警察拼入大陸公安部 <img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"ce1813c30a634abbadce0ebf39a05926c63e6800","tid":2361184,"uid":34010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-10T14:02:52.000Z","msg":"狗肉節"},{"pid":"d11f45acff540826d9e9827fe11a122ca86bea9f","tid":2361184,"uid":335434,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-10T14:10:49.000Z","msg":"//警務人員在內地嫖妓，即在境外犯案，被行政拘留或罰款，返港後需面臨警隊的紀律聆訊及處分。事實上，警員被揭北上嫖妓早有前科，一名駐守牛頭角警署綽號「肥田料」的姓廖軍裝警員，北上深圳沙嘴村嫖妓被捕後出示香港警察委任證「撻朵」，又要求公安「畀面」，但公安依法辦事，判他行政拘留十五日，事件轟動一時。<br />\n<br />\n○四年八月，廣東省公安廳展開針對黃色事業的「夏季百日行動」，<strong><span class=\"red\">公安在沙嘴村一幢出租屋掃黃時，發現「肥田料」與一名年輕女子「鬼混」，他慌亂中拿出一張香港警察委任證，聲稱自己是香港警察，冀公安看在同行分上能酌情處理，但公安秉公處理，將他帶回派出所。翌日，他即被判處行政拘留十五天。</span></strong><br />\n<br />\n「肥田料」被拘留十五天後獲釋返港，警方對他進行紀律聆訊，翌年聆訊完成後，警方表示鑑於涉案警員在聆訊中承認損害警隊聲譽，聆訊委員會裁定他須接受嚴重申斥或以下的懲罰，但毋須革職。//<br />\n<br />\n希望兩地公安籍今次「淫民警賊節」好好溝通 避免同類型唔認自己人嘅事件再次發生<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c214b96cde82fb535252337a6e498e016b895a00","tid":2361184,"uid":155818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-10T14:11:41.000Z","msg":"你999喎師兄"},{"pid":"80f2ce27a6d82546802cc061df489eaa43b465db","tid":2361184,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"626307ab9ba2318fc24d739de7623758b441d77c","tid":2361184,"uid":126919,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-10T13:51:40.000Z","msg":"<img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-10T14:12:54.000Z","msg":"<img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" />"},{"pid":"cc38dc1ccd3455594556f6fa651ecbed5ea6f68b","tid":2361184,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"b5b7f1ce11ba30978b4cb08f1fb42baf7cd24f24","tid":2361184,"uid":51271,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-01-10T12:30:30.000Z","msg":"出支那人工囉"},"citedBy":0,"replyTime":"2021-01-10T14:13:04.000Z","msg":"<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"}]}