/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3c44c565f022e7e04343d471b953566fbacc39fc","tid":427202,"uid":55851,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-10-07T11:46:05.000Z","msg":"失敗者論壇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 所有成功嘅人都會比佢地反<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e78f4d5bdea7e0793e153d2dd2da451b78ee2793","tid":427202,"uid":31173,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-10-07T11:47:26.000Z","msg":"建國？？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />  等睇自己人打柒自己人啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bbff5727134b42657341ac9370952887ebc8bf2b","tid":427202,"uid":31173,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-07T11:47:59.000Z","msg":"<blockquote>失敗者論壇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 所有成功嘅人都會比佢地反<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n特別係香港人成功左，更加要反<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f22ff08ea5a273747ecf6a656ab3d4b9cee54e73","tid":427202,"uid":54373,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-07T11:47:59.000Z","msg":"我唔反佢，只係睇吳過眼班打手<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"04b088d31a8976fa9c65746dc2d785d98f3ea810","tid":427202,"uid":35400,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-07T11:55:05.000Z","msg":"香港人只會踩自己人 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n難怪君如近年好少拍戲"},{"pid":"195a01179f24e77300544ea63998ba013967555e","tid":427202,"uid":68081,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-07T11:55:07.000Z","msg":"<blockquote><blockquote>失敗者論壇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 所有成功嘅人都會比佢地反<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /