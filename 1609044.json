2019-10-01T14:09:13.000Z","msg":"強烈要求用最大武力，令呢條8婆安靜"},{"pid":"a144889cb71ba3c10241941ebbfc7bac347b21a3","tid":1609044,"uid":41171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T14:09:33.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"1e118490b549154d6ea763df2309d83ab512dd73","tid":1609044,"uid":242623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T14:09:49.000Z","msg":"收皮啦"},{"pid":"758fad16462b679cfa1d5153400985e5761ddb51","tid":1609044,"uid":105905,"like":0,"dislike":0,"score":0,"quote":{"pid":"55b7c597a8c32255786b6353776749de67fbe2c9","tid":1609044,"uid":53026,"like":0,"dislike":0,"score":0,"quote":{"pid":"ea88b45cc5fbca810977d04dd4d019dd04c06712","tid":1609044,"uid":76776,"like":45,"dislike":3,"score":42,"citedBy":2,"replyTime":"2019-10-01T13:18:52.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-10-01T13:51:55.000Z","msg":"唔怕，英籍囉<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-01T14:10:15.000Z","msg":"美國做得g7實跟"},{"pid":"f9abcd1a8ffe436d48083208be7c385de913f277","tid":1609044,"uid":6604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T14:12:08.000Z","msg":"佢無份上北京？"},{"pid":"0a66f3804c1965dc3855b312676b131ed498c5a0","tid":1609044,"uid":4285,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T14:13:18.000Z","msg":"成班上晒北京擦鞋啦"},{"pid":"8a3854fe2fac890d295271de5cd38065cc859c68","tid":1609044,"uid":304321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T14:13:35.000Z","msg":"姐姐<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"f230772c91988588e91bcf01c074400e49bdca8c","tid":1609044,"uid":84585,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T14:13:59.000Z","msg":"此回覆已被刪除"},{"pid":"b96aecdc50221b2fce205c16e0ac83c83b6686c7","tid":16