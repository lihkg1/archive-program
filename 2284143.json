A%2F%2Fna.cx%2Fi%2F8Nnp2Ks.jpg&h=a705c708&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-11-13T10:17:21.000Z","msg":"繼上年 Excel 事件後又一力作<br />\n係自己個page 到貼堂 <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><br />\n最正係隔左一晚賴大方完又 delete post <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n處理手法仲衰過一個壞左嘅人<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><br />\n跑 X 堂有無人幫佢做公關？<br />\n食女唔係問題，食完之後ou6 先係問題～ <img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-14T05:39:29.000Z","msg":"excel 事件??  願聞其詳~"},"citedBy":0,"replyTime":"2020-11-15T02:43:18.000Z","msg":"<img src=\"https://na.cx/i/SjYAECc.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSjYAECc.png&h=30191c34&s={SIZE}\" /><img src=\"https://na.cx/i/d3WeVay.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fd3WeVay.png&h=228c5dbf&s={SIZE}\" /><img src=\"https://na.cx/i/7qHJOvz.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7qHJOvz.png&h=524a1cfc&s={SIZE}\" /><img src=\"https://na.cx/i/dQaCSXf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FdQaCSXf.png&h=183e7a90&s={SIZE}\" />"},{"pid":"0814e5cd71643f405126c3d4b6aa769abedfc2b4","tid":2284143,"uid":1067,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2020-11-15T02:46:50.000Z","msg":"自己心甘情願俾人食，投資失敗就公審人，邊有咁著數？"},{"pid":"82b4170f6b3ef9e07937f73b85e686de36d9fe07","tid":2284143,"uid":59678,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-15T02:51:23.000Z","msg":"咁醜樣都食到你 你係咪要反省下"},{"pid":"316132fc4d02b95b384133cbf9c7609e8a82ba0f","tid":2284143,"uid":168212,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-15T16:58:17.000Z","msg":"😰😰"},{"pid":"88878cd502b24c5119afe7d66e84d8b078fa8a6b","tid":2284143,"uid":168212,"like":17,"dislike":0,"score":17,"citedBy":0,"replyTime":"2020-11-15T18:08:13.000Z","msg":"(人生第一篇千字文）<br />\n今天這位受害者用唇膏在手臂上作出申訴，<br />\n他日另一位受害者會否用刀在手臂上作出控訴呢？<br />\n<br />\n再次看到這個人的桃色新聞。<br />\n<br />\n我所感到的，是痛心和惋惜。<br />\n<br />\n我十九歲那年，跟這個人在浸會副學士課程上認識。可能大家同樣都是運動員，加上為人態度同樣都有點兒囂張輕浮，所以我跟這個人很快便變得十分投契。<br />\n<br />\n我們由同學變成朋友，再由朋友變成兄弟。<br />\n<br />\n在課堂的小休時間一起在城門河跑步，臨近考試時就一起在圖書館裡溫習，入夜後則到蘭桂坊或棉登徑一帶喝酒、抽茹、胡混。不經不覺間，我們的生活步伐逐漸變得一致。（當然在跑步方面，這個人要把速度調慢很多來遷就我這名三項鐵人吧。）<br />\n<br />\n記得有一回，他財政出現問題，而當天也就是繳交學費的到期日，他找上我幫忙。當時每月零用錢只有3000塊的我，整個銀行戶口裡也只得8000塊，所以我便立刻致電父親，告訴父親我有一位很要好的朋友缺錢，指他很大可能會因為未能如常繳交學費而被懸空學位，父親聽了後，他二話不說，就幫這個人付了那四萬元學費。<br />\n<br />\n再有一回，他父母鬧離婚，他晚上致電給我，說他心情很懷，我得知後亦馬上由灣仔趕至元朗來陪伴他。當晚他訴說家庭事至落下男兒淚，並說他自己不斷盟生自殺這個念頭，而在他身旁的我除了替他抹眼淚之外便是不斷安慰他，叫他不要往歪處想。當時，天真的我在元朗的某一個公園裡跟他許下承諾，說自己會為他獻出一邊肩膀，來為他扛下生活上的一邊重擔。<br />\n<br />\n結果怎麼樣呢？<br />\n<br />\n這個人送了頂綠帽給我。<br />\n<br />\n坦白說，我這三十三年來人生上最大的陰影，除了在拔萃中一那年，給整隊田徑隊脫光了褲子並把玩我下體外，就是他這一頂綠帽。<br />\n<br />\n其實若沒有這一頂綠帽，我想我在這次患癌後，是會嘗試追回那名女子並跟她一起共渡餘生。(這名女子除了在我患癌時不斷支持我之外，當她知道我所動的癌症手術是會出現失血過多的風險後，她還向我問及她能否到醫院直接捐血给我。)<br />\n<br />\n但很可惜，可能這頂綠帽的威力實在太大，對我傷害實在太深，所以我始終也沒嘗試去追回她。<br />\n<br />\n而在副學士的綠帽事件後，我與這個人再有互動之時，已經是我們在升讀了浸會大學本科PERM後，我在final year的跳舞課堂上當著所有同學和課堂老師Dr. Yip 跟前揍他一頓。<br />\n<br />\n那次動粗事件令一整節課堂停了下來，幸得各同學出手阻止和Dr Yip的寬容，我才沒闖下更嚴重的大禍或被校方停學。（在此，我要為我這個魯莽行為再三道歉。）我很記得，該次課堂將近完結時，Dr Yip擔心我會再次襲擊這個人，所以Dr Yip容許他先行離開。可是，我還是在課堂完结後馬上奔離許士芬體育館，衝上聯合道找他悔氣。<br />\n<br />\n當時怒得眼眶充滿熱淚的我對他拋出了一句很老土的對白：「我視你為兄弟，你為甚麼這樣對我！。」<br />\n<br />\n然後我依稀聽到他咽哽地說：「我也視你為兄弟的。」（他意思可能是指襟兄弟吧。)<br />\n<br />\n自這句說話後，我倆也再沒什麼往來。<br />\n<br />\n後來，從商的我偶然聽到他跟自己跑會內的不同學生發生關係，這些事對一眾視他為偶像的跑壇新手來說當然是一件不可置信之事，但對我來說，其實也不過一些貓吃魚的日常事。<br />\n<br />\n但當中最令我感到奇怪的，並不是他捕魚，玩弄魚或吃魚這個行為，而是他身邊一羣真正認識他的朋友，竟然從沒阻止他、勸喻他，反而還繼續吹捧他，支持他。<br />\n<br />\n我想這大概是因為他自小了得的交際手碗吧。<br />\n(因為在過去的日子裡，同樣是喜歡吃魚的我早已被身邊的朋友唾棄、咒罵，甚至是批鬥。)<br />\n<br />\n再過了若干年，當這個人放下了運動員身份，當我亦經歷過化療的日子，當香港不在是以前的香港時，我看到他開的士來幫補身計的報道。<br />\n<br />\n那一刻我原以為我會馬上去諷刺他，取笑他。<br />\n(本人無意輕視任何在運輸業工作的朋友們，那是我當刻有機會所產生的一個差劣念頭，望各位見諒🙇&zwj;♂️🙇&zwj;♂️🙇&zwj;♂️)<br />\n<br />\n但我始終都沒有作出這無知的行為。<br />\n<br />\n相反我竟為他感到有點兒難過，並出乎意料地誠心希望他可以跟所有香港人一起挨過這個難關，並希望他能運用他在跑步上那永不放棄的信念來克服眼前障礙。<br />\n<br />\n那麼這是否等於我已原諒了他呢？<br />\n<br />\n對不起，患過癌症的我比以前變得更加小氣和更加記仇。<br />\n<br />\n原諒他？下輩子吧。<br />\n<br />\n因此我會為他的拮据而感到難過，大概是因為我抱著香港人應當同舟共濟的信念而已。<br />\n<br />\n但今天我再次看見有關他的桃色新聞，我感到非常痛心和惋惜，我不明白為何相隔這麼多年，並且在香港人經歷了這麼多困難，大家好應該互助互勉之時，這個人依舊是那麼喜歡玩弄他身邊的人對他的信任，朋友如是，學生如是，伴侶如是。<br />\n<br />\n被愛情衝昏了頭腦的人是會變得較為愚笨的，希望不會有任何受害者會因為他而幹出一些傻事來。<br />\n<br />\n在此我誠心希望這個人能早日學會用一顆善良的心去對待身邊的人，特別是那些被他才華深深所吸引而對他極為傾慕的支持者，因為她們對這個人的傾慕之情，是完全出於一份單純的尊重和欽佩。這些得來不易的傾慕之情，是好應該珍而重之，而不是隨意踐踏和摧毀的。<br />\n<br />\n一名曾視這個人為兄弟的陌生人上。"},{"pid":"04decb1c71b0968ecc8eb07c4d933b4a5243e27e","tid":2284143,"uid":34047,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-15T18:13:50.000Z","msg":"推"},{"pid":"461079c31c266b392effad8f55002859feaec389","tid":2284143,"uid":46976,"like":1,"dislike":0,"score":1,"quote":{"pid":"fa4d82c4a7a2bac0c54a0be0ec79dd170896cff7","tid":2284143,"uid":384376,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-11-13T05:27:30.000Z","msg":"事緣呢個人渣開左跑會好耐，有d知名度咁樣，於是就有愈來愈多人去佢跑會報名跟佢練習(收好貴架)&hellip;<br />\n嘩~刷新左我對教練嘅新定義！經常上堂開頭出現咗5分鐘之後就火速唔見人&hellip;訓喺度等d學員幫佢按摩&hellip; 佢當自己係皇帝定乜&hellip; d人仲叫佢乜9教主啦頂！唔知以為係邪教！<br />\n呢d就當係條友搞個人崇拜，tum d學生簇擁下慰藉下佢空虛嘅心靈！<br />\n但條友仲唔知足，仲要不停食女！<br />\n繁忙嘅香港人真係要向呢位時間管理KOL學習一下點樣可以multi-task咁食女,<br />\n誇張到一日幾個都食得落！仲花言巧語咁tum到d女死心塌地.<br />\n但呢個世界冇永遠嘅秘密, 佢嘅狗公行為俾d女學員識破後竟然喺度唱d女自己送上門！隻字不提自己有幾咁飢渴！又借d咦非禮人，摸人, 無啦啦咬人個鼻, 俾人兜口兜面屌9佢就扮話係同你玩吓咁啫！由學生妹至到大媽通通不放過！<br />\n簡單d講就係一個徹頭徹尾嘅7版羅志祥！<br />\n<br />\n唔明點解到而家條pk都有大把忠粉盲撐！醒下啦跑x堂嘅人！<br />\n<br />\n奉勸大家千其唔好跟呢條友上堂，尤其係女！否則成為受害者嘅話唔好喊！<br />\n<br />\n最後祝曾受傷嘅心靈盡快康復！一世遠離人渣！"},"citedBy":0,"replyTime":"2020-11-15T18:24:52.000Z","msg":"忍無可忍不過唔開名<br />\n咁你忍多陣啦屌你老母<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"f1c9bcb2e95c11e950a015dbb0bd712f872efcd0","tid":2284143,"uid":34047,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-15T18:25:03.000Z","msg":"樓主不如重開過個post<br />\n第一版就貼啲資料"},{"pid":"52d