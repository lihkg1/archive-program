kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwEsZC4F.jpg&h=5ad9bf56&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-12-01T12:37:34.000Z","msg":"ehentai碎料都咁認真 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d2e54ef8a86051c91da660bce09f1f6de66f6668","tid":923583,"uid":77473,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-01T12:37:34.000Z","msg":"撚狗大會"},{"pid":"9aa17f479f78c0b177ea3b80eb38f692bbb0c470","tid":923583,"uid":2148,"like":17,"dislike":0,"score":17,"quote":{"pid":"c83f50f146b92b6ffacde1fa773b642bcc90384c","tid":923583,"uid":9082,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-01T12:16:44.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-12-01T12:38:01.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 唔同日本<br />\n<br />\n你設定個年齡係十八歲以上你畫成點佢吹你唔漲<br />\n<br />\n但鬼佬唔會理<br />\n<br />\n佢覺得係就拉你<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2c9aeaff018b8b2c8228aa937504436d5ceaf344","tid":923583,"uid":29702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-01T12:38:06.000Z","msg":"此回覆已被刪除"},{"pid":"51db74225441fbda20c44f14aa7e598e598c9e1f","tid":923583,"uid":121131,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-12-01T12:38:10.000Z","msg":"呢個post無人屌大陸人<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3d19294d61c9735dbb63131e644d850447b0d683","tid":923583,"uid":59328,"like":1,"dislike":0,"score":1,"quote":{"pid":"98b880c0508014bb95aa509b0c7b26605a87b0d9","tid":923583,"uid":177578,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2018-12-01T12:21:15.000Z","msg":"啲300歳吸血鬼蘿莉點計？？<br />\n<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-01T12:39:52.000Z","msg":"<a href=\"https://e-hentai.org/tag/flandre+scarlet\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fe-hentai.org%2Ftag%2Fflandre%2Bscarlet&d=iZ4i5QPyjiZkb3EFLGXVpp4f2li5K%2Fs6EGgmwhpeblA%3D&h=9dc70da3\