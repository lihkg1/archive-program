ps%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F25%2F150223_ebb482119cf278c89d7a091cc36ee21c.png&h=8c9c4239&s={SIZE}\" /><br />\n（來源：wiki)"},{"pid":"7f57aab267e360b680491e21452f66842c668363","tid":715984,"uid":35701,"like":4,"dislike":2,"score":2,"citedBy":1,"replyTime":"2018-06-25T07:07:48.000Z","msg":"此回覆已被刪除"},{"pid":"e87a791d7b3107711f6fce6488e5dc2bc28a25cf","tid":715984,"uid":183383,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T07:12:55.000Z","msg":"好串"},{"pid":"e9f8fcd871a5eea3a4fbfbdb56f6c64d98989f40","tid":715984,"uid":28054,"like":1,"dislike":2,"score":-1,"quote":{"pid":"7f57aab267e360b680491e21452f66842c668363","tid":715984,"uid":35701,"like":4,"dislike":2,"score":2,"quote":{"pid":"c094a172c300fd3ebd720415c490184aff598fff","tid":715984,"uid":28054,"like":2,"dislike":2,"score":0,"quote":{"pid":"c7b96afaf6fd38146ef7478b14a11c238d66fd5f","tid":715984,"uid":35701,"like":15,"dislike":2,"score":13,"citedBy":1,"replyTime":"2018-06-25T05:27:21.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-06-25T07:02:01.000Z","msg":"用香港小圈子頒獎禮比人地認受性高n倍既金曲獎<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-25T07:07:48.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-06-25T07:20:13.000Z","msg":"獎項數目係唔關事，但你用個垃圾獎比就完全係唔恰當<br />\n冇認受性既獎 好似叱咤呢d 垃圾拎幾多次都係冇用<br />\n有認受性既獎就係專業音樂人對歌手果一年既肯定<br />\n你覺得用獎去睇歌手係on9<br />\n但可惜連d 歌手自己都好恨要呢個獎做肯定囉<br />\n定係你想話d 歌手自己都on9 咁介意d 獎<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f305c343a8d921e9eb80fd3167c4cf3911f07e78","tid":715984,"uid":41351,"like":0,"dislike":2,"score":-2,"quote":{"pid":"e4966e725d3ebd627904a5f8e6b0fc616ecba7df","tid":715984,"uid":150595,"like":2,"dislike":6,"score":-4,"citedBy":1,"replyTime":"2018-06-25T07:02:42.000Z","msg":"Wiki 寫張學友請教受過正統聲樂訓練嘅陳奕迅點唱歌，係咪真﹖<img src=\"https://img.eservice-hk.net/upload/2018/06/25/150223_ebb482119cf278c89d7a091cc36ee21c.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F25%2F150223_ebb482119cf278c89d7a091cc36ee21c.png&h=8c9c4239&s={SIZE}\" /><br />\n（來源：wiki)"},"citedBy":0,"replyTime":"2018-06-25T09:07:39.000Z","msg":"真，Eason同學友講過覺得佢唱得唔夠放<br />\n其實技巧上EaSon真係勁過學友"},{"pid":"d66bdd381dee9416f80889d213a6f17913c3b45f","tid":715984,"uid":135336,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-06-28T18:42:15.000Z","msg":"占士拎咗好多個東岸冠軍添，Jordan 都仲未做到呀，占士又超越咗佢？點解你唔將陳奕迅同張學友啲賣碟銷量一齊嚟比較？張學友銷量全球第二？請問邊度全面超越？<br />\n<br />\n全部華人社會一諗起歌神都會話係張學友而非陳奕迅，<br />\n<br />\n利申：兩位歌星都鍾意，但以暫時嚟講都仲係冇人可以超越到張學友，唔信你可以聽返陳奕迅唱李香蘭<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"1787b11c017fdbfe50754bef623c3ad9d0c4b73d","tid":715984,"uid":53855,"like":1,"dislike":0,"score":1,"quote":{"pid":"5878224a5becc01a07ef488b20758195481b572a","tid":715984,"uid":35701,"like":12,"dislike":0,"score":12,"quote":{"pid":"f70c6d3f09b60b289594710b9def96768a08e972","tid":715984,"uid":56720,"like":3,"dislike":10,"score":-7,"citedBy":1,"replyTime":"2018-06-25T03:28:18.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-06-25T05:28:50.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-06-28T20:04:09.000Z","msg":"台灣金曲獎唔係豬肉獎"}]}