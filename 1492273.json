ss=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-20T18:13:31.000Z","msg":"即係唔係大和解<br />\n其實睇到我有啲眼濕濕<br />\n佢嘅勇武 比食子彈其實有得揮<br />\n返到上去俾人虐待"},{"pid":"e56c48822665750f36f9c2ae4c1cf945ea0a9c21","tid":1492273,"uid":288924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T18:13:57.000Z","msg":"<img src=\"/assets/faces/big/shocking.gif\" class=\"hkgmoji\" />good luck"},{"pid":"bdedcd8b7ebfecde845b9635c46a2462e5b2561a","tid":1492273,"uid":58984,"like":0,"dislike":0,"score":0,"quote":{"pid":"fdcc4e7e8e56a7e154817eb32e0bf4cb79088d3e","tid":1492273,"uid":130695,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-08-20T18:12:49.000Z","msg":"呢個真係烈士勇武好過班支那小粉紅各種嘔心"},"citedBy":0,"replyTime":"2019-08-20T18:14:02.000Z","msg":"大佬人哋返到上去俾人折磨<br />\n唔係一下死就可以解決"},{"pid":"1129d602753de182d2b00d4051251afcb3d39010","tid":1492273,"uid":95499,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T18:14:37.000Z","msg":"證明大陸人都有能力去搵真相<br />\n只係大多數人自願放棄呢個能力啫"},{"pid":"9b37dfecd8105cf308236d59baff393950e7db73","tid":1492273,"uid":58984,"like":1,"dislike":0,"score":1,"quote":{"pid":"eedc97f8b2ce8edb4c6e3d146dafc9c2213f35a2","tid":1492273,"uid":57542,"like":0,"dislike":0,"score":0,"quote":{"pid":"4704dc5105dc645c456371547933604bf48b3a52","tid":1492273,"uid":58984,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T18:11:59.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-20T18:12:56.000Z","msg":"咁sad啦，我都以一人之力傳達緊一個信念"},"citedBy":1,"replyTime":"2019-08-20T18:14:46.000Z","msg":"依個中國律師絕對係六四嘅後代"},{"pid":"e067380916f532783896c7d5a06ccae2afba76a3","tid":1492273,"uid":58984,"like":0,"dislike":0,"score":0,"quote":{"pid":"1129d602753de182d2b00d4051251afcb3d39010","tid":1492273,"uid":95499,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T18:14:37.000Z","msg":"證明大陸人都有能力去搵真相<br />\n只係大多數人自願放棄呢個能力啫"},"citedBy":0,"replyTime":"2019-08-20T18:16:10.000Z","msg":"唔好傻啦<br />\n每個人都有能力去搵真相<br />\n只不過有冇人有勇氣散播出去<br />\n結果依個律師有呢個勇氣<br />\n6月18號睇到佢段片<br />\n結果依家俾人叫佢返大陸<br />\n好明顯依個係遺言"},{"pid":"49ed5ec91d137ba131cf00e7efdce85321024b14","tid":1492273,"uid":58984,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-20T18:18:09.000Z","msg":"其實大家唔好諗住再打飛機<br />\n其實到今時今日我哋一樣嘢都冇贏過<br />\n五大訴求至今冇回應過<br />\n被捕人士只會越來越多<br />\n當被捕人士數目多到一個地步嘅時候<br />\n你覺得特赦呢一部係咪真係行到呢<br />\n咁如果行唔到 依班義士為咗我哋犧牲左幾多"},{"pid":"adb9e53ac007248a76cd6e47c950eaa483e33f04","tid":1492273,"uid":58984,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T18:18:33.000Z","msg":"<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"abd51bace76bc38d392c4328bff4b17ccbb26c02","tid":1492273,"uid":58984,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T18:19:26.000Z","msg":"<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"e118d11a138da55dab8ad829cf028c62f7c87d16","tid":1492273,"uid":248404