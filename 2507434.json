lass=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b08d6ce74adaf987e65bfa4269f2eb9129426209","tid":2507434,"uid":112747,"like":0,"dislike":2,"score":-2,"citedBy":3,"replyTime":"2021-04-28T04:12:10.000Z","msg":"上到終院起碼判坐3,4年喎<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" />"},{"pid":"b5cef5802c935f6314edc3309053cdb173261829","tid":2507434,"uid":240362,"like":1,"dislike":0,"score":1,"quote":{"pid":"b08d6ce74adaf987e65bfa4269f2eb9129426209","tid":2507434,"uid":112747,"like":0,"dislike":2,"score":-2,"citedBy":3,"replyTime":"2021-04-28T04:12:10.000Z","msg":"上到終院起碼判坐3,4年喎<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-28T04:13:21.000Z","msg":"律政司並不尋求推翻三人的無罪裁決，惟裁決對之後的案件有深遠影響。<br />\n<br />\n上訴聆訊由高院首席法官潘兆初、上訴庭副庭長麥機智及原訟庭法官彭寶琴審理。上訴庭上月底頒下判詞，裁定律政司勝訴，直指一些即使並非身處現場的參與者，明顯也是「共同犯罪」，包括在遙距指揮行動的人士或駕駛「家長車」協助犯罪者逃脫的人。<br />\n<br />\n上訴庭指出，根據普通法原則，除非相關條文明示或暗示排除共同犯罪原則，否則共同犯罪原則適用於所有罪名，當中包括《公安條例》下的非法集結罪與暴動罪。"},{"pid":"555ca66e36db52082e0477a16d21c6f309e2e1d3","tid":2507434,"uid":160592,"like":0,"dislike":9,"score":-9,"citedBy":0,"replyTime":"2021-04-28T04:16:02.000Z","msg":"cctoy又水人出去<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"176cc32c00b9a92b6ffd3e56d52e64d998d85bf8","tid":2507434,"uid":342828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-28T04:17:03.000Z","msg":"Push."},{"pid":"99ac0bdbc72262179254c797e6b8face87ce9d9c","tid":2507434,"uid":110043,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-28T04:18:01.000Z","msg":"感謝"},{"pid":"54f1dc3788b44bf3580e61f8ed77fd1f0