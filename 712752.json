/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"5fefbd1eab649fa4faee86e51829d2cb2dfb03fc","tid":712752,"uid":157579,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-06-22T10:53:17.000Z","msg":"舊日回憶的山丘"},{"pid":"e44d3eab44683db11eab5943ada12fc142965154","tid":712752,"uid":56716,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-06-22T10:54:39.000Z","msg":"怎麼我眼內人人像你<br />\n人人是你<br />\n沿途萬里 完全被封鎖"},{"pid":"0dc60d1e9a823c60fd5b18bac03a8e6ab20fcad8","tid":712752,"uid":71166,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e0deba4767b0e358fda30d8de892d62ecfcbd76f","tid":712752,"uid":56716,"like":0,"dislike":1,"score":-1,"quote":{"pid":"a8b668b419d5120740c4c900ee14a8614c9d8e3b","tid":712752,"uid":71166,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ab4f74550dda447096e0f371b5c5b8f8a5ae442","tid":712752,"uid":56716,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-06-22T10:51:19.000Z","msg":"弘b都經歷過？<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-22T10:52:17.000Z","msg":"弘b is a 有過去的女人<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-22T10:53:11.000Z","msg":"弘b攬攬<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n愛是最易去令女人死心失望<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-22T10:54:46.000Z","msg":"吉<br />\n是愛 讓女人一敗塗地<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"0babcc9e26b603f549fc71512b6738903f31f1b3","tid":712752,"uid":183383,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-06-22T10:55:06.000Z","msg":"心淡啦!"},{"pid":"9e79fe188b8b362842e5d3a4b12fcff1a0f8b888","tid":712752,"uid":162567,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-06-22T10:55:07.000Z","msg":"16號愛人"},{"pid":"f454ec04daf55f7348db4878ab2cd500db9e4731","tid":712752,"uid":162567,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0babcc9e26b603f549fc71512b6738903f31f1b3","tid":712752,"uid":183383,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-06-22T10:55:06.000Z","msg":"心淡啦!"},"citedBy":0,"replyTime":"2018-06-22T10:55:40.000Z","msg":"屎沖開了便臭<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ba56ebd6e5528009bb0f3546d81b16edac967000","tid":712752,"uid":71166,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-06-22T10:58:20.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">羅馬時差</span></span><br />\n<a href=\"https://youtu.be/YhvIZ_DuHC4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FYhvIZ_DuHC4&d=PuaKngDH%2FZM%2BerZQRb5l9TQ9OVC7k%2FvddpU5ARN7O10%3D&h=3f43c11a\" target=\"_blank\">https://youtu.be/YhvIZ_DuHC4</a><br />\n<span style=\"color: red;\">他走的剎那 我卻剛剛 到達</span><br />\n沒留一句話 一封電郵都來不及發<br />\n從海角 到天涯 隔一座羅馬 路太多分叉<br />\n<br />\n<span style=\"color: red;\">我們之間 永遠的時差<br />\n他留給我 浪漫的童話<br />\n如果早兩千年 能不能遇見他</span><br />\n<br />\n誰來調整 愛情的時差<br />\n勇敢跨越 宿命的步伐<br />\n公元前的密碼 誰給我解答<br />\n<span style=\"color: red;\">再也沒有辦法 回到當年的 羅馬</span><br />\n<img src=\"/assets/faces/lomoji/21.png\" class=\"hkgmoji\" />"},{"pid":"3dd742914a5f11a3ed47c7dca7bd76339622de5d","tid":712752,"uid":71166,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-06-22T11:03:04.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\"> 圓謊</span></span><br />\n<a href=\"https://youtu.be/riP8oILLYZo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FriP8oILLYZo&d=PuaKngDH%2FZM%2BerZQRb5l9TQ9OVC7k%2FvddpU5ARN7O10%3D&h=aa4ce1d9\" target=\"_blank\">https://youtu.be/riP8oILLYZo</a><br />\n<br />\n只要能一世陪住你<br />\n可以就一世瞞住你<br />\n<span style=\"color: red;\">秘密藏櫃裡　打開會分離<br />\n彼此關係如夢幻才完美</span><br />\n不顧良心去留住你<br />\n<span style=\"color: red;\">不再回憶瞞住自己<br />\n這麼好的天氣　陰影早已遠離<br />\n驚真相重頭講起　你受不起<br />\n不坦白為你</span><br />\n<br />\n今天我們一起　快樂歡喜<br />\n值得忍到金禧<br />\n<span style=\"color: red;\">當雪泥消散於天地　足跡踢不起</span>"},{"pid":"60a90ca0cd31f8df8e2b1ff72ded429ca4a63571","tid":712752,"uid":71166,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-06-22T11:06:24.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">摩登時代</span></span><br />\n<a href=\"https://youtu.be/xg-1OvlfSbM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fxg-1OvlfSbM&d=PuaKngDH%2FZM%2BerZQRb5l9TQ9OVC7k%2FvddpU5ARN7O10%3D&h=eda72f14\" target=\"_blank\">https://youtu.be/xg-1OvlfSbM</a><br />\n<br />\n恨就恨在太堅持　忍得到都忍不過<br />\n<span style=\"color: red;\">到約會場合裡　怨也沒怨一句<br />\n冷清得可以　都敷衍了事</span><br />\n<br />\n投足舉手太多　神經開始痛楚<br />\n<span style=\"color: red;\">當我不夠你善忘<br />\n死撐下去　太造作　為了甚麼<br />\n不說話也　會換來　浮躁大動作更多</span><br />\n離開講得太多　情感一早洩光<br />\n默劇到尾聲　不要你認錯<br />\n<span style=\"color: red;\">你我　分手吧<br />\n這對白　默契好到不用講</span>"},{"pid":"71470c432db5c7f670a7196a374a9ec34accb187","tid":712752,"uid":71166,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-06-22T11:14:25.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">男朋友與歌</span></span><br />\n<a href=\"https://youtu.be/olDfx4b9q6g\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FolDfx4b9q6g&d=PuaKngDH%2FZM%2BerZQRb5l9TQ9OVC7k%2FvddpU5ARN7O10%3D&h=25fbbf4a\" target=\"_blank\">https://youtu.be/olDfx4b9q6g</a><br />\n<br />\n<span style=\"color: red;\">哪位擁抱過我 親吻過我 縱沒下落<br />\n在那一日 亦並非揀錯</span><br />\n讓故事忠於那陣時<br />\n情懷在變 聽歲月唱歌<br />\n<br />\n被哪首 吸引過 感染過 對號入座<br />\n隨潮流 及處境 一再變過<br />\n<span style=\"color: red;\">哪位安慰過我 體貼過我 按序就坐<br />\n來來回 男朋友 就似歌<br />\n</span><br />\n<img src=\"/assets/faces/lomoji/21.png\" class=\"hkgmoji\" />"},{"pid":"9b84d91317a720bcaccfefcfe33db36c484296b9","tid":712752,"uid":56384,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-06-22T21:11:34.000Z","msg":"麻煩你<br />\n<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"fc880fc2ea97750d6e1144eb42c2ceb90c075b3b","tid":712752,"uid":56384,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-06-22T21:13:27.000Z","msg":"為何還沒有初吻便要怕失戀<br />\n約會未完便掛念"},{"pid":"934c30bbb291fc9ae0f3d20f773bee519c61033c","tid":712752,"uid":85220,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2018-06-22T21:14:20.000Z","msg":"此回覆已被刪除"},{"pid":"81d0672b648db2e2e0e4fe5140859de1c0403d74","tid":712752,"uid":56384,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-06-22T21:15:48.000Z","msg":"沈溺需要深 需要一種氣氛🚬"},{"pid":"94f74fa68ea885ff42ea3ee3a26a36f30959a652","tid":712752,"uid":82917,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-06-23T00:49:49.000Z","msg":"佢首怯<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"b4ffb4b5f3db3273a877839754d364efeef598bd","tid":712752,"uid":52702,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-06-23T01:01:43.000Z","msg":"候鳥樹<br />\n<br />\n當時你爲未來但未來到"},{"pid":"94a178cbddf33a7b5642116ec01d2ffa84a1e45e","tid":712752,"uid":27064,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-06-23T02:37:49.000Z","msg":"損友<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"1274f7d66dbf8b69b2d77686b9f191a43986b476","tid":712752,"uid":71166,"like":5,"dislike":1,"score":4,"citedBy":0,"replyTime":"2018-06-23T02:49:38.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">損友</span></span><br />\n<a href=\"https://youtu.be/KICwmS5Da90\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FKICwmS5Da90&d=PuaKngDH%2FZM%2BerZQRb5l9TQ9OVC7k%2FvddpU5ARN7O10%3D&h=9cd7e4f5\" target=\"_blank\">https://youtu.be/KICwmS5Da90</a><br />\n<br />\n<span style=\"color: red;\">誰昨晚共你一起<br />\n用情如像遊戲<br />\n我沒福氣去責備你<br />\n無謂揭露誰在妒忌<br />\n<br />\n就怪我太清楚<br />\n清楚你的風流<br />\n明白你 一世亦貪新厭舊<br />\n我寧願當好友<br />\n無愁無慮地碰頭</span><br />\n<br />\n<img src=\"/assets/faces/lomoji/22.png\" class=\"hkgmoji\" /> 屌 真係句句夭心夭肺<img src=\"/assets/faces/lomoji/19.png\" class=\"hkgmoji\" />"},{"pid":"02587a012d64e017c8a524569c6b65f01d420718","tid":712752,"uid":102745,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-06-23T04:34:48.000Z","msg":"<a href=\"https://youtu.be/onQ-sQFQ8eY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FonQ-sQFQ8eY&d=PuaKngDH%2FZM%2BerZQRb5l9TQ9OVC7k%2FvddpU5ARN7O10%3D&h=ada85512\" data-auto-link target=\"_blank\">https://youtu.be/onQ-sQFQ8eY</a><br />\n<br />\n算吧　愛情遲一秒便遲一秒<br />\n留不低　離得開　無論遺憾有多少<br />\n即使差距十秒　她早我十秒<br />\n遇上你只好擠出苦笑<br />\n無緣拍婚紗照　回頭看都不少　難堪的歡笑"},{"pid":"7c0b94eb029f65c813dc2570fca5b11e7549a120","tid":712752,"uid":79382,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2018-06-23T05:28:58.000Z","msg":"肥閪你識好多side track喎 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"80bf8e89d2b49f7a1b6340ba390c371d377e3b3f","tid":712752,"uid":27616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-23T07:02:21.000Z","msg":"上次坐飛機"},{"pid":"54a8a4020504c60301a6a07f35b1c57a2ee9dcdf","tid":712752,"uid":86925,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-23T12:27:19.000Z","msg":"原來情難自控 我與你二人浴<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"69b9b8496dd98732b7b21f37f3680912973f4d8b","tid":712752,"uid":71166,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-06-26T00:22:59.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>與蝶同眠</strong></span></span><br />\n<a href=\"https://youtu.be/WWz2NOCycMs\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FWWz2NOCycMs&d=PuaKngDH%2FZM%2BerZQRb5l9TQ9OVC7k%2FvddpU5ARN7O10%3D&h=715389eb\" target=\"_blank\">https://youtu.be/WWz2NOCycMs</a><br />\n<br />\n<span style=\"color: red;\">隨緣吧 玩耍的當時 免問未說的謊</span><br />\n磨蝕這上半生下半生同樣要與浪蝶風中跌蕩<br />\n不相信 情人若像孔雀不會飛翔才可寄望<br />\n<span style=\"color: red;\">飛不起找得起這一世怎保證花與蝶擁抱後能合葬<br />\n隨便吧 貪歡有貪歡好青春也得一次淒美在流光冷汗</span><br />\n<br />\n<br />\n<br />\n歌詞好殘酷<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"0d62092162147992c0a8e140c1edb76823678d16","tid":712752,"uid":36084,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-06-26T00:36:49.000Z","msg":"就當所有痛楚 成長的經過<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"83e7013b0f45568086622c3d9b8e26cc820f753d","tid":712752,"uid":10825,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-26T00:46:44.000Z","msg":"流淚眼望流淚眼<br />\n小日子<br />\n愛怪物的你<br />\n朱古力萬歲<br />\n蒸餾"},{"pid":"8d496d500ae75665e60b43a147eeaff3502e43e6","tid":712752,"uid":71166,"like":0,"dislike":0,"score":0,"quote":{"pid":"0d62092162147992c0a8e140c1edb76823678d16","tid":712752,"uid":36084,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-06-26T00:36:49.000Z","msg":"就當所有痛楚 成長的經過<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-26T01:29:59.000Z","msg":"睇到歌詞 個鼻酸一酸 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"b7441a6c4a9eee3c5a46ee19e71600006fa97577","tid":712752,"uid":71166,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-26T01:45:50.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>上次坐飛機</strong></span></span><br />\n<a href=\"https://youtu.be/9HWzUqOdE_c\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F9HWzUqOdE_c&d=PuaKngDH%2FZM%2BerZQRb5l9TQ9OVC7k%2FvddpU5ARN7O10%3D&h=89ced705\" target=\"_blank\">https://youtu.be/9HWzUqOdE_c</a><br />\n<br />\n<span style=\"color: red;\">我在你敷衍之中 得到快樂</span><br />\n結伴到淺草等於 身在天國<br />\n<span style=\"color: red;\">約定過瀏覽遠方 走遍異國<br />\n卻怕以後無寄託</span><br />\n<br />\n<span style=\"color: red;\">但覺得 多麼愛你得不到你陪伴半天<br />\n多麼蠢都會令我相信 共你承諾漸變<br />\n這失約如何倖免 整個地球我們難遇見</span><br />\n但覺得 多麼愛你應該已可成佛化仙<br />\n清高得有著條件 快樂來受騙<br />\n鳴謝你 日日夜夜受鍛鍊<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n一首對弘好有意義嘅歌<br />\n因為寂寞賠上寂寞<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n明就明。。。唔明就唔明。。。"},{"pid":"e271a0c940ffe30984720311ab2896bb71177863","tid":712752,"uid":19712,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-06-26T01:53:34.000Z","msg":"愛一個上一課"},{"pid":"30c5dcecaeb5abcd301decfba10aa4c68d7d1ce0","tid":712752,"uid":45627,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-26T04:11:57.000Z","msg":"我好想他 我不得不想他 眼淚一直流下<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"33f5fe75ef6f4997395e185429d6b9129c31af39","tid":712752,"uid":35504,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-26T07:07:38.000Z","msg":"cuc-ku-koo 來把光陰辜負<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"05d6aa6c50dada86160484a12fcc38c7516815b5","tid":712752,"uid":71166,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-06-28T14:15:42.000Z","msg":"今日聽呢首，我好鍾意嘅歌<br />\n<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">蜃樓</span></span><br />\n<a href=\"https://youtu.be/B9FSVMa5BmY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FB9FSVMa5BmY&d=PuaKngDH%2FZM%2BerZQRb5l9TQ9OVC7k%2FvddpU5ARN7O10%3D&h=0b7203de\" target=\"_blank\">https://youtu.be/B9FSVMa5BmY</a><br />\n<br />\n當掌心是你的　都會想　想去接觸<br />\n當呼吸是暖的　可種出我的翠綠<br />\n城內歲月老　幻想都乾燥<br />\n<span style=\"color: red;\">而我順著思念迷路<br />\n想得到半滴美好　這渴望大到</span><br />\n世界末日未碰到<br />\n<br />\n美麗　在驟眼間會沒有<br />\n變出一千扎鏡花的今後<br />\n<span style=\"color: red;\">我相信蜃樓　相信荒謬<br />\n從來憧憬的都不永久　總好過沒有</span>"},{"pid":"b0e788258dadcb36e1b364158c799a9194f820f9","tid":712752,"uid":192356,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-28T14:24:09.000Z","msg":"若你敢講一句 做別人伴侶<br />\n你滿口祝福字句 我會不想聽一句<br />\n為了不想失去 盡量逃避再找你<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"df71b5602011c748aabb33bf726ceef53f065d25","tid":712752,"uid":71166,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-02T11:23:14.000Z","msg":"一首曾經好代表到自己嘅歌<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">我也不想這樣</span></span><br />\n<a href=\"https://youtu.be/NO0DZGaoV0A\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FNO0DZGaoV0A&d=PuaKngDH%2FZM%2BerZQRb5l9TQ9OVC7k%2FvddpU5ARN7O10%3D&h=deb982d8\" target=\"_blank\">https://youtu.be/NO0DZGaoV0A</a><br />\n<br />\n<span style=\"color: red;\">情人太多 你愛得幾多個<br />\n換口味都不錯<br />\n在你味覺內存在過 還敢追究甚麼</span><br />\n<br />\n<span style=\"color: red;\">如若你做到 日和夜各自抱 何以為我苦惱</span><br />\n<br />\n你也不想這樣 但別講出真相<br />\n各自纏著你才會馨香<br />\n我放得開你最理想<br />\n要繼續受內傷 好過無法可分享<br />\n我也不想這樣利用自己的修養<br />\n來求你 分開不堪設想<br />\n<span style=\"color: red;\">如你 有歌請准我陪著唱<br />\n容忍兩把聲音不算太 牽強<br />\n如果 多她一位會多一點愛<br />\n兩個人被憐愛 一點都不勉強</span>"},{"pid":"25ddb22652284e71c8b3afb529f14c7991f7448a","tid":712752,"uid":71166,"like":0,"dislike":0,"score":0,"quote":{"pid":"df71b5602011c748aabb33bf726ceef53f065d25","tid":712752,"uid":71166,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-02T11:23:14.000Z","msg":"一首曾經好代表到自己嘅歌<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">我也不想這樣</span></span><br />\n<a href=\"https://yo