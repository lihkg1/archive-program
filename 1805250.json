624643390a4f6ce558f815946","tid":1805250,"uid":122915,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-31T15:10:31.000Z","msg":"推"},{"pid":"053581729497099e33cf995edea937a31d420c16","tid":1805250,"uid":243677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-31T15:11:30.000Z","msg":"<img src=\"/assets/faces/pigxm/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/wail.gif\" class=\"hkgmoji\" />"},{"pid":"3e00f73b251caae2815fb976fbf43f30c203b647","tid":1805250,"uid":304160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-31T15:15:09.000Z","msg":"<img src=\"/assets/faces/pigxm/wail_r.gif\" class=\"hkgmoji\" />報仇"},{"pid":"eb4f6e6cee31ca1162d5b83a1e1d73270b8e8330","tid":1805250,"uid":187181,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-31T15:16:06.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"0b8b34bf343abb4ae5790be074760cec972daff0","tid":1805250,"uid":325953,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2019-12-31T13:49:11.000Z","msg":"【「我們的2019」年度回顧－結果發佈】<br />\n<br />\n民間記者會以「我們的2019年度回顧」為題發起全民投票，在48小時內收到42,580份回應，感謝各位參與。<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n「我們的2019」年度回顧結果如下：最高票數的「<span style=\"font-size: x-large;\">十大難忘事件</span>」主要圍繞近七個月抗爭以來日趨嚴重的警暴問題，包括<span style=\"font-size: x-large;\">7.21及8.31</span>等，而<span style=\"font-size: x-large;\">林鄭月娥、 香港警察及何君堯</span>則獲選為「年度可恥人物」三甲。民間記者會認為三人正好是官警黑合作的代表人物，結果反映警隊及制度的崩壞令市民深惡痛絕，令2019年的香港觸目驚心。另外，市民亦以選票表揚抗爭中的無名英雄如<span style=\"font-size: x-large;\">報導真相的傳媒、志願救護人員及星火同盟</span>， 把他們選為「年度人物」。而街坊多次群起阻止警方濫暴濫捕的<span style=\"font-size: x-large;\">黃大仙區</span>則被冠以「年度首都」美名。<br />\n<br />\n民記舉辦是次2019大事回顧，希望可以帶香港人回到反送中抗爭的第一天，再一次回首、憶起七個月以來香港人一同度過的每一個無眠之夜。踏入新一年，我們帶著2019的悲痛之情，反思過去，2020繼續不忘抗爭，直至光復香港。<img src=\"/assets/faces/dogxm/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dogxm/cheerup.gif\" class=\"hkgmoji\" /><br />\n<br />\n<div style=\"text-align: center;\"><img src=\"https://na.cx/i/OkL1WAk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOkL1WAk.jpg&h=6884ca17&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/dgZaPVq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FdgZaPVq.jpg&h=2cffbcc3&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/VMS0sG6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVMS0sG6.jpg&h=f7760c69&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/TJhS3ft.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTJhS3ft.jpg&h=a76ef87f&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/tLBMofu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FtLBMofu.jpg&h=abebe576&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/arYyNHa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FarYyNHa.jpg&h=4301298a&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/CTX0sHb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCTX0sHb.jpg&h=59b264b9&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/r2tu5tS.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fr2tu5tS.jpg&h=699ff0ee&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/NuQtBAy.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNuQtBAy.jpg&h=71dba44e&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/TeKVgAA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTeKVgAA.jpg&h=b6da57b4&s={SIZE}\" /></div>"}}