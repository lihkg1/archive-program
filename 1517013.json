=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnGpDR8f.png&h=d3cc8786&s={SIZE}\" /><br />\n<br />\n<a href=\"https://www.facebook.com/105259197447/posts/10158003338362448?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F105259197447%2Fposts%2F10158003338362448%3Fsfns%3Dmo&d=Fe1Xron1KfJbBj576sEg8tVSC25YwgVwXuaRRXYDXIw%3D&h=48811821\" data-auto-link target=\"_blank\">https://www.facebook.com/105259197447/posts/10158003338362448?sfns=mo</a>"}]}