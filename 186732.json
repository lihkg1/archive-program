:57.000Z","msg":"正皮左<br />\n利申：阿"},{"pid":"613e59bfb42c6d01316b509971a7cd7e79638ff1","tid":186732,"uid":28041,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:13:59.000Z","msg":"垃圾滾啦"},{"pid":"b367792ce15417d7beedb151d8c30cfd5e3b57d1","tid":186732,"uid":76753,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:19:36.000Z","msg":"如果雲膠加盟車路士呢?"},{"pid":"4f3e55cb7a28663d6e9348e1c825c9c54f634d54","tid":186732,"uid":24235,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:20:33.000Z","msg":"<blockquote>如果雲膠加盟車路士呢?</blockquote><br />\n我會恭喜車路士<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" />"},{"pid":"e6f7253687524f49675bcb32696a76bfb39be29d","tid":186732,"uid":54635,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:21:11.000Z","msg":"直接負評<br />\n出國踢先體諒"},{"pid":"7fc69c667bb5e1793db9895c5fb41c8fc31b234e","tid":186732,"uid":41524,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:22:41.000Z","msg":"離開英超/去英冠先體諒"},{"pid":"3460fed45eda13b92858d7cbfdeb32e612862133","tid":186732,"uid":54025,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:24:01.000Z","msg":"山齊士經理人：山齊士正在為加盟車路士尋找居住的地方 <br />\n<br />\n干地：阿仙奴在禁錮山齊士<br />\n<br />\n干堤：阿仙奴在摧毀山齊士的未來 <br />\n<br />\n藍戰士喉舌《天空體育報》：阿仙奴配不上 山齊士<br />\n<br />\n英媒：阿仙奴願高薪留  山齊士<br />\n<br />\n干地：山齊士 永遠都是藍戰士<br />\n<br />\n夏殺特：山齊士已想好怎樣在史丹福橋慶祝他的入球了 <br />\n<br />\n比洛迪雙親：成為藍戰士是兒子的夢想 <br />\n<br />\n英媒爆料：山齊士快將穿上「車」袍 <br />\n<br />\n英權威學者： 山齊士的袓先是英國人 <br />\n<br />\n意大利《米蘭體育報》表示：車路士是來自另一個星球的球隊！山齊士的加盟會使這支隊伍更加強大！ <br />\n<br />\n柏度：他（山齊士)的確與我很相似 <br />\n<br />\n馬迪： 山齊士之前已向我透露想加盟車路士<br />\n<br />\n泰利：山齊士是車路士最後一塊拼圖 <br />\n<br />\n泰利: 山齊士告訴我他在睡覺時也穿著車路士的球衣 <br />\n<br />\n大衛雷斯警告阿仙奴：你們還有兩個月時間尋找山齊士的替補 <br />\n<br />\n龍虎切說山齊士的心一早已在車路士，促阿仙奴放人 <br />\n<br />\n馬高斯阿朗素表示山齊士更嚮往在西倫敦生活 <br />\n<br />\n域陀摩西斯：我已急不及待與山齊士合作 <br />\n<br />\n法比加斯：山齊士的夢想是代表車路士出賽 <br />\n<br />\n卡希爾：山齊士只想加盟車路士踢球 <br />\n<br />\n古圖奧斯 :  山齊士向我說他找不到理由向車路士說不!!!!!!!!!!! <br />\n<br />\n法比加斯：阿仙奴強行留住山齊士是殘忍的 <br />\n<br />\n法比加斯警告阿仙奴：山齊士是屬於車路士<br />\n<br />\n夏殺特認為山齊士無可能繼續停留在低水平球會比賽 <br />\n<br />\n韋利安坦言, 不怕山齊士來到後位置受動搖"},{"pid":"8a91c309eff0fc4ab2a58d1c5ba01ae1084e590a","tid":186732,"uid":36497,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:34:16.000Z","msg":"我竟然睇哂段野<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"1ba47e487fd4b8ec4d960f03c1c60fbee13197d0","tid":186732,"uid":54025,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:38:37.000Z","msg":"<blockquote>我竟然睇哂段野<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n豬蛇<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"10b47705975745f00f6ee864153d408ee80ba040","tid":186732,"uid":10290,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:39:21.000Z","msg":"正皮左"},{"pid":"5527b5ee3d8e0f256e61310b3ac43d387fd2d441","tid":186732,"uid":2169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:41:28.000Z","msg":"老鼠真係有心機改<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"1f838eecdbb33051551e47f7b0a3a0bf23804b15","tid":186732,"uid":18669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-04T12:42:06.000Z","msg":"<blockquote>山齊士經理人：山齊士正在為加盟車路士尋找居住的地方 <br />\n<br />\n干地：阿仙奴在禁錮山齊士<br />\n<br />\n干堤：阿仙奴在摧毀山齊士的未來 <br />\n<br />\n藍戰士喉舌《天空體育報》：阿仙奴配不上 山齊士<br />\n<br />\n英媒：阿仙奴願高薪留  山齊士<br />\n<br />\n干地：山齊士 永遠都是藍戰士<br />\n<br />\n夏殺特：山齊士已想好怎樣在史丹福橋慶祝他的入球了 <br />\n<br />\n<span style=\"color: red;\">比洛迪雙親：成為藍戰士是兒子的夢想 </span><br />\n<br />\n英媒爆料：山齊士快將穿上「車」袍 <br />\n<br />\n英權威學者： 山齊士的袓先是英國人 <br />\n<br />\n意大利《米蘭體育報》表示：車路士是來自另一個星球的球隊！山齊士的加盟會使這支隊伍更加強大！ <br />\n<br />\n柏度：他（山齊士)的確與我很相似 <br />\n<br />\n馬迪： 山齊士之前已向我透露想加盟車路士<br />\n<br />\n泰利：山齊士是車路士最後一塊拼圖 <br />\n<br />\n泰利: 山齊士告訴我他在睡覺時也穿著車路士的球衣 <br />\n<br />\n大衛雷斯警告阿仙奴：你們還有兩個月時間尋找山齊士的替補 <br />\n<br />\n