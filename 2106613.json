而家當免檢疫証明係生意咁做，搵班阿姐派傳單幫人攪。<br />\n每日中港司機都幾千人出出入入。<br />\n<br />\n4.煲大件事！比全世界多D人知道，只有多D人覺醒，知道個政府係棄全香港巿民安危不顧，先會爭取到更多人企係我哋呢邊，同我哋一齊抗疫！<br />\n<br />\n兄弟姊妹各自爬山 他日平安相聚<br />\n<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"f07beeed652122c1d7b56efecacfdf76dd455e8e","tid":2106613,"uid":186,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-13T12:27:02.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"7a0d9a8b62214145c1c2baa241d44808c912723b","tid":2106613,"uid":291448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-13T12:27:04.000Z","msg":"此回覆已被刪除"},{"pid":"39bc00c9a73c8c96361bd5f1572e51aa87153296","tid":2106613,"uid":186,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-13T12:28:08.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"1401bfd4563a988dd42918fdc952e27b4e5ef6cd","tid":2106613,"uid":16503,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-13T12:30:35.000Z","msg":"消息指林鄭又中計"},{"pid":"70c35395e2287f12efc0a24960631d49cff3303e","tid":2106613,"uid":186,"like":0,"dislike":0,"score":0,"quote":{"pid":"1401bfd4563a988dd42918fdc952e27b4e5ef6cd","tid":2106613,"uid":16503,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-13T12:30:35.000Z","msg":"消息指林鄭又中計"},"citedBy":0,"replyTime":"2020-07-13T14:49:12.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" 