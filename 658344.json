":15815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-09T08:36:36.000Z","msg":"死刑好無？"},{"pid":"79270a06acd664901d692d711353dcc41eed4526","tid":658344,"uid":26003,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6fb0ee57b8efe3ccdd6053a24e7eba67d3d0b31a","tid":658344,"uid":37675,"like":1,"dislike":4,"score":-3,"citedBy":1,"replyTime":"2018-05-09T01:47:50.000Z","msg":"阿妹<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-09T08:47:14.000Z","msg":"有啲奶路<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"}]}