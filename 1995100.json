_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fbiodiversityinhk%2Foriginals%2Fmfile_8895_681936_1_l.jpg&h=033fbf47&s={SIZE}\" /><br />\n<img src=\"https://www.rthk.hk/oldassets/images/rthk/dtt31/biodiversityinhk/originals/mfile_8895_681936_2_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fbiodiversityinhk%2Foriginals%2Fmfile_8895_681936_2_l.jpg&h=e8080444&s={SIZE}\" /><br />\n<img src=\"https://www.rthk.hk/oldassets/images/rthk/dtt31/biodiversityinhk/originals/mfile_8895_681936_3_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fbiodiversityinhk%2Foriginals%2Fmfile_8895_681936_3_l.jpg&h=07ca6f7a&s={SIZE}\" /><br />\n<img src=\"https://www.rthk.hk/oldassets/images/rthk/dtt31/biodiversityinhk/originals/mfile_8895_681936_4_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fbiodiversityinhk%2Foriginals%2Fmfile_8895_681936_4_l.jpg&h=e5167403&s={SIZE}\" /><br />\n<img src=\"https://www.rthk.hk/oldassets/images/rthk/dtt31/biodiversityinhk/originals/mfile_8895_681936_5_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fbiodiversityinhk%2Foriginals%2Fmfile_8895_681936_5_l.jpg&h=0ad41f3d&s={SIZE}\" /><br />\n<img src=\"https://www.rthk.hk/oldassets/images/rthk/dtt31/biodiversityinhk/originals/mfile_8895_681936_7_l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.rthk.hk%2Foldassets%2Fimages%2Frthk%2Fdtt31%2Fbiodiversityinhk%2Foriginals%2Fmfile_8895_681936_7_l.jpg&h=0e21cf00&s={SIZE}\" /><br />\n<a href=\"https://www.rthk.hk/tv/dtt31/programme/biodiversityinhk/episode/681936\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.rthk.hk%2Ftv%2Fdtt31%2Fprogramme%2Fbiodiversityinhk%2Fepisode%2F681936&d=u41oPESRP74RcK6mblIGZxnxOJLX742lx1SCoot1iYY%3D&h=345f0382\" data-auto-link target=\"_blank\">https://www.rthk.hk/tv/dtt31/programme/biodiversityinhk/episode/681936</a><br />\n蟹類是節枝動物的其中一目，物種非常豐富，現時全球已發現蟹類超過7000種，在香港亦紀錄到近300種蟹。我們或許以為蟹類只在海洋中生活，但其實不同種類的蟹，分別棲息在海洋、沙灘或者淡水河流之中，甚至在樹林、高山之間都可以見到它們的蹤跡，究竟不同蟹類在演化的過程中，發展了甚麼獨特的結構，能夠適應不同的棲息環境？"},{"pid":"9b031ec89db4bdecabe068d5c5c24320d7cbec7e","tid":1995100,"uid":345819,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-05-17T19:36:00.000Z","msg":"So far 覺得馬騮呢集最好睇<br />\n除咗拍得好睇，個配樂好得<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"63375b0c7aa958a34c5ed41e875f4eb57eeda3ab","tid":1995100,"uid":4643,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-05-24T12:27:46.000Z","msg":"推一推<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"cc13e6171eddc0e09bd720d631bc9f9ba54c57d3","tid":1995100,"uid":30294,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-24T12:30:31.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b86df1387a8c8907c9c47313fc03a2e16386b693","tid":1995100,"uid":41818,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-05-24T12:31:02.000Z","msg":"rthk自家拍<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"216e8554dd77234b6b881e5c726b4378ae72bbdb","tid":1995100,"uid":4643,"like":0,"dislike":0,"score":0,"quote":{"pid":"b86df1387a8c8907c9c47313fc03a2e16386b693","tid":1995100,"uid":41818,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-05-24T12:31:02.000Z","msg":"rthk自家拍<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-24T12:33:36.000Z","msg":"本身以為係買返嚟"},{"pid":"b4d354aaa19494dab455c59601e3359349966f53","tid":1995100,"uid":41818,"like":1,"dislike":0,"score":1,"quote":{"pid":"216e8554dd77234b6b881e5c726b4378ae72bbdb","tid":1995100,"uid":4643,"like":0,"dislike":0,"score":0,"quote":{"pid":"b86df1387a8c8907c9c47313