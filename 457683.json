ead72faf3a68c0cefcf037ec852a6%26src%3Dhttp%3A%2F%2Fimgsrc.baidu.com%2Fbaike%2Fpic%2Fitem%2F838ba61ea8d3fd1f304bad92384e251f94ca5fd3.jpg&h=28bbafe5&s={SIZE}\" />"},{"pid":"17f85619df6d3d5408645a6e6f6aa4f568eea020","tid":457683,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-04T07:22:29.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>老貓點睇頭先搭車<br />\n前面班細路都話要讀ict<br />\n將來從事it工作？</blockquote><br />\n你有幻覺</blockquote><br />\n個個都好開心咁....<br />\n笑到四萬咁口</blockquote><br />\n<img src=\"https://timg04.bdimg.com/timg?wapbaike&amp;quality=60&amp;size=b600_395&amp;sec=1349839550&amp;di=5e8ead72faf3a68c0cefcf037ec852a6&amp;src=http://imgsrc.baidu.com/baike/pic/item/838ba61ea8d3fd1f304bad92384e251f94ca5fd3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ftimg04.bdimg.com%2Ftimg%3Fwapbaike%26quality%3D60%26size%3Db600_395%26sec%3D1349839550%26di%3D5e8ead72faf3a68c0cefcf037ec852a6%26src%3Dhttp%3A%2F%2Fimgsrc.baidu.com%2Fbaike%2Fpic%2Fitem%2F838ba61ea8d3fd1f304bad92384e251f94ca5fd3.jpg&h=28bbafe5&s={SIZE}\" /></blockquote><br />\n<img src=\"https://img.eservice-hk.net/upload/2017/11/01/115312_b1adb9a1e60c88bf663847937c52eba0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F01%2F115312_b1adb9a1e60c88bf663847937c52eba0.jpg&h=8520ccaf&s={SIZE}\" />"},{"pid":"29f4563e4da4615f6dcb9ec55cdb4e697e732ccb","tid":457683,"uid":20449,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-04T07:26:18.000Z","msg":"此回覆已被刪除"},{"pid":"330566529f308a7dea21c1265ee20869541557e1","tid":457683,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-04T07:29:35.000Z","msg":"【論壇投稿】青年新政游蕙禎：動物警察與權力分配問題<br />\n<br />\n【論壇投稿】青年新政游蕙禎：動物警察與權力分配問題<br />\n近年不少動保人士促請政府成立動物警察，參考外國做法，一般而言皆隸屬執法部門，被賦予全面調查和拘捕涉案人士的權力，因為動物警察本身便是正規警察，入職前曾接受嚴格的相關訓練，以跟進虐待動物及相關案件，並能在必要時即時拘捕或請涉案人士協助調查。而這項政策倡議涉及三個部門或機構的權力分配：警務處、漁護署及愛協。<br />\n<br />\n拙文曾提及，不論警方抑或愛協，均對成立動物警察持保留態度。警務處反對設立動物警察原因有二：其一是他們早於2011年展開「動物守護計劃」，其功能相當於動物警察的正式訓練，並且將相關知識擴展至全警隊；其二，則是他們認為部份個案不屬刑事罪行的範疇，應交由漁護署或食物及衛生局跟進。故他們實際上將動物警察的職能一分為二，並認為自己已盡責地履行當中一半的職務。而愛協則聲稱他們有足夠的技術和經驗處理虐待動物的個案，並指修訂法例才是當務之急，故對成立動物警察表示「強烈反對」。<br />\n<br />\n就愛協指修例才是當務之急的論點，翻查資料，政府曾於2006年修訂《防止殘酷對待動物條例》，將條例的最高罰則由罰款五千元及監禁六個月，大幅提高至罰款二十萬元及監禁三年，加強虐待動物及相關刑事條例的罰則。然而待我們再查看2013年立法會議員就《防止殘酷對待動物條例》之執法情況提出的書面質詢，政府部門的答覆令人不禁質疑，即使提高罰則，也無法收阻嚇之效。事源根據當年提供的數字，由2006年修例起至2012年9月共六年的時間，每年平均有約一百餘宗舉報個案，而這六年之間，有充分證據作出檢控的相關案件只有100宗，當中有9宗個案未能定罪。我們固然不能排除舉報個案當中有不相關甚至虛報的個案，但政府方也坦言執法人員在搜集證據及舉證方面遇到較大的困難，因為「大多數舉報所涉及的動物都是流浪貓狗及在僻靜地點（如後巷等）被發現」。而警務處自2011年推行「動物守護計劃」，強調「自2008年開始，警方已經將內所有殘酷對待動物案件交由刑事調查單位調查。刑事調查隊的人員受過專門訓練，具備足夠的經驗和調查技巧跟進該類案件」，既然如此，「久經專業訓練」的警務人員理應清楚虐待事件多發生於僻靜地點和涉及流浪動物。若地點偏僻是偵查困難甚至無法調查的原因，那何以稱得上是「足夠經驗和調查技巧」？<br />\n<br />\n加上修例方面，罰則只是其一，上回筆者亦曾提及，部份未涉及虐待動物，但與動物有關的糾紛，應同時列明處理守則和標準，令執法人員有例可循。事實上，若有關部門無意嚴正執法以守護受害動物，任政府如何修例，也無法改善現況；而現況則是，警方有權判斷是否檢控涉案人士，而就上述六年間成功檢控個案的數字，的確有執法過於寬鬆之嫌。無法成功檢控，當中是否涉及巡邏人手不足及專業知識不足等問題，我們無從考證。唯一肯定的，是警方完全無考慮成立動物警察，每一次接報後皆只成立一臨時調查隊跟進事件，因他們一直輕視虐待動物個案所需的調查技巧，政府亦無心額外投放資源培訓專業的動物警察。而愛協雖聲稱有專業知識和動物督察協助打擊罪案，但就其「強烈反對」成立動物警察的立場，可見愛協寧可堅持，其並無調查和拘捕權、僅能對涉案人士作出勸喻或報警求助的「動物督察」是恆之有效的制度，也絕不願意承認成立正式的動物警察才是長治之計，畢竟動物警察一旦成立，其專業訓練和調查權力將完全取代愛協現有職能，使之除推行領養計劃外，無異於政府的漁護署。<br />\n<br />\n筆者下筆之始，原想分析以香港情況，一旦成立動物警察，應如何制訂其職權和分工。但行文至此，已一目了然，動保議題、成立動物警察這種「利他」的動物福利政策，再一次淪為政府機構互相推卸責任、得過且過，某些團體獨攬職能和話語權的戰場。警務與愛協不願就民間聲音成立動物警察，非不能，實不願也，警方一方面不願增派人手專門負責在他們看來是「次等重要、無功可領」的案件，愛協一方面不願將其動保界話語權、以至動物督察的職能拱手讓出。不同機構和部門之間的周旋角力、以至權力鬥爭，幾乎無處不在，唯有改變、重組權力架構，由民眾重新賦權，動物警察、動物福利，以至其他議題，方有成事的可能。"},{"pid":"5d6bedbadded685f6341582b12df7183ae3d641b","tid":457683,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-04T07:31:12.000Z","msg":"游b最新文章Link，可以J佢文字<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n<a href=\"https://prism.news/ShowArt.php?ref=20171103001\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fprism.news%2FShowArt.php%3Fref%3D20171103001&d=CBPArazkphjuhTk%2BmDAdN54f2li5K%2Fs6EGgmwhpeblA%3D&h=b65adb89\" target