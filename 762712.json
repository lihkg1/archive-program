>\n　　　想要變成大師傅　天天數錢數到笑<br />\n　　　每天都貪戀著錢的好<br />\n<br />\n＃,＊,＊<br />\n<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"697df94c660684feb8196dac964d7a44c3dd14f7","tid":762712,"uid":35930,"like":0,"dislike":0,"score":0,"quote":{"pid":"a27305ab07e085e99c32862cb92bb53854739e61","tid":762712,"uid":57424,"like":0,"dislike":0,"score":0,"quote":{"pid":"59ea158a58a892b02014086502083b089bb141f6","tid":762712,"uid":35930,"like":0,"dislike":0,"score":0,"quote":{"pid":"587c35a68d52ca4def3f2d75b5b065c0ffe54604","tid":762712,"uid":57424,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-31T15:16:06.000Z","msg":"又跌<img src=\"/assets/faces/lomoji/32.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-31T15:19:05.000Z","msg":"升到仆晒街喎"},"citedBy":1,"replyTime":"2018-07-31T15:34:12.000Z","msg":"邊到呢"},"citedBy":0,"replyTime":"2018-07-31T15:53:11.000Z","msg":"度度都升喎"},{"pid":"57d43d94e48f98de852ecc01501e25af1dd5f6af","tid":762712,"uid":155608,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-31T15:55:50.000Z","msg":"夜期升緊2百幾 <img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"e69bdb7394dbaa8384e4cf0cb841121a0dde8d8b","tid":762712,"uid":42815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-31T15:57:40.000Z","msg":"升爆廠<img src=\"/assets/faces/lomoji/29.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/29.png\" class=\"hkgmoji\" />"},{"pid":"a185daa08a60d92dfe3599f034a8ae4c980ffdfb","tid":762712,"uid":66271,"like":0,"dislike":1,"score":-1,"quote":{"pid":"57d43d94e48f98de852ecc01501e25af1dd5f6af","tid":762712,"uid":155608,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-31T15:55:50.000Z","msg":"夜期升緊2百幾 <img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-31T18:39:08.000Z","msg":"三百幾呀"},{"pid":"9910d0f841d22f66ae35ebb28525d930b52828d3","tid":762712,"uid":103035,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-07-31T23:18:2