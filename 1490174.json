normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-20T15:24:09.000Z","msg":"<span style=\"font-size: large;\"><span style=\"color: red;\">【眾籌 Google 廣告】 本地文宣 : 多媒體廣告</span></span><br />\n<a href=\"https://lih.kg/dHmAsS\" data-auto-link target=\"_blank\">https://lih.kg/dHmAsS</a>"},{"pid":"e82a7793b1fb768d61cc559147315e07ab7d41ac","tid":1490174,"uid":54785,"like":0,"dislike":0,"score":0,"quote":{"pid":"4dc5eb92e9290e10747a11d675d52fedfba5c4b3","tid":1490174,"uid":306681,"like":0,"dislike":0,"score":0,"quote":{"pid":"cecfdd93356c79a9fc81bea6c43fa18180ba435f","tid":1490174,"uid":54785,"like":1,"dislike":0,"score":1,"quote":{"pid":"1e9dbf909aac328afa84318954f42e860696f354","tid":1490174,"uid":306681,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-20T10:18:17.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-08-20T15:11:53.000Z","msg":"點樣大台法, 而家民記無人話係大台, 佢地亦處理得好好, 「民庭」亦可以在民記之下用同一種模式誕生<br />\n<br />\n暫時係要做到公審, 用人民雪亮嘅眼睛去見證罪行, 目的係要係喺輿論再下一成<br />\n<br />\n例如尋晚斬人, 人民法庭可以定性為謀殺罪, 而打老人家單嘢就定性為酷刑罪, 以正視聽<br />\n<br />\n呢啲都係和理非, 口誅筆伐嘅範圍, 但中共用得最多力嘅地方係咩? 係輿論呀! 所以輿論戰一定要有多個炮台反攻<br />\n<br />\n以香港人鐘意食花生嘅性格, 你有民間法庭一定會有人留意更多我地嘅核彈, 何樂而不為?"},"citedBy":1,"replyTime":"2019-08-20T15:18:23.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-08-20T15:24:13.000Z","msg":"不如你講下你認為咩係大台?"},{"pid":"ae517e2ba8b085763787b78f009a867f000a49ce","tid":1490174,"uid":289350,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T15:25:03.000Z","msg":"推，有自衞隊先有條件解散黑警團隊"},{"pid":"764ec6967905e1f5ecab9f9daa7f03449769d8c1","tid":1490174,"uid":1673,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T15:25:53.000Z","msg":"民間立法會都係必須"},{"pid":"0ff898668b6c86c0b8cc557dc220d8bfab666b68","tid":1490174,"uid":306681,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T15:30:43.000Z","msg":"此回覆已被刪除"},{"pid":"8c1b719880f9d0434a2830363258f86956294349","tid":1490174,"uid":306681,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T1