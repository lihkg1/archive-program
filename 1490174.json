=\"hkgmoji\" />"},{"pid":"eeac6a26ced1ed259bbcccc19775a1dcb23f9e95","tid":1490174,"uid":9448,"like":0,"dislike":0,"score":0,"quote":{"pid":"9db1183f6189cdc4ce2efb2536c2223a1dc1bb39","tid":1490174,"uid":54785,"like":2,"dislike":0,"score":2,"quote":{"pid":"b087357b7d4e94cdcce97c3adad738e5d32ccd53","tid":1490174,"uid":61101,"like":7,"dislike":0,"score":7,"citedBy":4,"replyTime":"2019-08-20T04:51:11.000Z","msg":"整埋民間立會啦"},"citedBy":1,"replyTime":"2019-08-20T05:03:32.000Z","msg":"認同好重要, 不過到而家都搞唔成<br />\n<br />\n但民記算有啲成果, 呢啲同人民生活相關嘅嘢有機會獲得更多關注"},"citedBy":0,"replyTime":"2019-08-20T14:31:16.000Z","msg":"推"},{"pid":"f4a63990d7422e939c69d95159d0cb59997a6cc2","tid":1490174,"uid":9448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T14:31:30.000Z","msg":"推"},{"pid":"dcb05c73146ce640411c500c582df3f9a38f0327","tid":1490174,"uid":263485,"like":0,"dislike":0,"score":0,"quote":{"pid":"1ec3acbc8f9d1a7133d57381a4a3c96169988a68","tid":1490174,"uid":54785,"like":0,"dislike":0,"score":0,"quote":{"pid":"264597c1b36d13660d05ef79c5ce8420f36dda5f","tid":1490174,"uid":61115,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T10:00:57.000Z","msg":"<span style=\"font-size: xx-large;\">要有人民劊子手</span>"},"citedBy":1,"replyTime":"2019-08-20T10:06:16.000Z","msg":"法國大革命都有斷頭台"},"citedBy":0,"replyTime":"2019-08-20T14:35:21.000Z","msg":"五金鋪有冇得買？"},{"pid":"52b756dd88d4aa65f85a0403fd14bb05e74c1fe1","tid":1490174,"uid":298859,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T14:49:39.000Z","msg":"幫推"},{"pid":"cecfdd93356c79a9fc81bea6c43fa18180ba435f","tid":1490174,"uid":54785,"like":1,"dislike":0,"score":1,"quote":{"pid":"1e9dbf909aac328afa84318954f42e860696f354","tid":1490174,"uid":306681,"like":0,"dislike":0,"score":0,"quote":{"pid":"185e09eafc056e27b0ac4859dca458d148b8306e","tid":1490174,"uid":54785,"like":0,"dislike":0,"score":0,"citedBy":5,"replyTime":"2019-08-20T04:47:12.000Z","msg":"兩者並行, 先有公信力, 民間自衛隊先有權力<br />\n<br />\n一開頭唔可妄想有乜實際作用, 但會係一個開端<br />\n<br />\n形式可用民間記者會形式, 人民法庭公告當時人犯下咩罪, 罪名可以包括國際法及香港法律<br />\n<br />\n起碼以輿論去反擊暴行, 同時令大眾明白黑警選揀性執法而無法庭可作出判決但不等於白衣暴徒或藍衫刀手無罪<br />\n<br />\n人民法庭可以用NYT, 特赦組織果種方式, 以visual inspection 去搜證, 甚至可以傳召傷者, 目擊證人去作供<br />\n<br />\n將來運作落去, 可以搵執業律師 或前執業律師擔任法官, 搵議員監察等, 抗爭者可以到場聽審, 細節可以再討論<br />\n<br />\n可能有人話搞呢啲嘢都係自己打飛機, 只係小圈子, 無人會理, 但請諗深一層, 究竟邊個給予法庭權利去判人罪? 究竟邊個給予警察權利? 就係人民本身。香港人唔慢慢脫離呢個框架, 唔明白社會契約失效, 咁我地永遠要玩中共嘅遊戲<br />\n<br />\n一個機構, 包括民間自衛隊, 人民法庭, 有無jurisdiction, 係睇實際人民夠竟對你有無信心<br />\n<br />\n到呢一刻仍然未有組織可以取締警隊係因為:<br />\n<br />\n1. 人民未完全理解社會契約, 亦不知道其已失去效用<br />\n2. 不知道有選擇權而社會上亦未有任何選擇<br />\n3. 黑衫自發保護人民的行動未得到廣泛人民關注及理解, 所以之前有巴打提出行動約章<br />\n4. 香港人民道德界線高, 唔會承認未審先判, 或者會行使私刑嘅組織, 就算對家無抹黑中傷, 人民始終會擔心呢類無監察嘅組織變成第二隊中國警察, 甚至恐怖組織, 所以要有人民法庭的角色為民自開路<br />\n<br />\n如果認同以上嘅論述, 請將我地想成立人民法庭嘅聲音帶到民記<br />\n<br />\n如不認同, 或部分認同, 請留低看法, 睇下可以點樣改善<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-08-20T10:18:17.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-08-20T15:11:53.000Z","msg":"點樣大台法, 而家民記無人話係大台, 佢地亦處理得好好, 「民庭」亦可以在民記之下用同一種模式誕生<br />\n<br />\n暫時係要做到公審, 用人民雪亮嘅眼睛去見證罪行, 目的係要係喺輿論再下一成<br />\n<br />\n例如尋晚斬人, 人民法庭可以定性為謀殺罪, 而打老人家單嘢就定性為酷刑罪, 以正視聽<br />\n<br />\n呢啲都係和理非, 口誅筆伐嘅範圍, 但中共用得最多力嘅地方係咩? 係輿論呀! 所以輿論戰一定要有多個炮台反攻<br />\n<br />\n以香港人鐘意食花生嘅性格, 你有民間法庭一定會有人留意更多我地嘅核彈, 何樂而不為?"},{"pid":"586a04573562c908ef7fa85f716aba3af65d91af","tid":1490174,"uid":19255,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T15:13:39.000Z","msg":"推爆"},{"pid":"d47428278830b4eb82e585a248bcf73768c9bc1d","tid":1490174,"uid":216603,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T15:14:15.000Z","msg":"tui"},{"pid":"4dc5eb92e9290e10747a11d675d52fedfba5c4b3","tid":1490174,"uid":306681,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T15:18:23.000Z","msg":"此回覆已被刪除"},{"pid":"97336783015e8cf4d1a745a6e70b732cb7313c05","tid":1490174,"uid":54785,"like":0,"dislike":0,"score":0,"quote":{"pid":"a02402070d25b77270396511c8d6582288edbd8e","tid":1490174,"uid":58104,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T10:52:31.000Z","msg":"先有民間自衛隊 再有人民法庭<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n一個國家可以無左軍隊定係無左法庭？"},"citedBy":0,"replyTime":"2019-08-20T15:19:05.000Z","msg":"唔反對, 不過我係強調緊另一面咁解<br />\n<br />\n呢一刻我地需要嘅係取締警隊嘅力量, 而並非真正意義上嘅軍隊, 取締警隊要由人民奪回警權, 而警察嘅角色無可能係無法庭嘅狀態下存在"},{"pid":"9746e199b6b85944861e0f1d5bce6908c97d11ed","tid":1490174,"uid":71092,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T15:20:17.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"c680d1a34ee5311e710814dfebe1ec38cf1e0fce","tid":1490174,"uid":67069,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T15:21:49.000Z","msg":"推<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n好無助<br />\n好想喊<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n但我係街&hellip; <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"f09a2365189b9a47552561740a5eda9f5fefa052","tid":1490174,"uid":54785,"like":0,"dislike":0,"score":0,"quote":{"pid":"9beab1957e0badaee329a3ef00d1c771e89b32a9","tid":1490174,"uid":82640,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T10:52:50.000Z","msg":"人民監獄？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-20T15:22:09.000Z","msg":"呢個相信無可能, 因為拉嘅都係對家嘅人, 對家一定會用壓倒性嘅力量阻止呢樣嘢發生<br />\n<br />\n但對應一般係香港生活嘅人, 包括警察, 打人藍絲, 斬人白衫佬, 基本上有大部分香港人認為佢地有罪, 已經可以有一定制裁力同阻嚇力<br />\n<br />\n再多嘅係逼現有警隊實際作出檢控, 但就算佢地唔做, 輿論上起碼我地嬴返"},{"pid":"4907830d73bac9a7ce56b1c924b51a99e0957d7c","tid":1490174,"uid":54785,"like":0,"dislike":0,"score":0,"quote":{"pid":"52b756dd88d4aa65f85a0403fd14bb05e74c1fe1","tid":1490174,"uid":298859,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T14:49:39.000Z","msg":"幫推"},"citedBy":0,"replyTime":"2019-08-20T15:22:23.000Z","msg":"感謝<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"7cec