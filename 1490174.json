庭判終身<br />\n<br />\n同埋有jurisdiction 後, 可以再討論刑罰, 究竟點樣懲治窮兇極惡嘅黑警, 例如, 開槍奪眼之人應有咩下場? 係咪坐終身等香港人養成世, 人民就會接受?"},{"pid":"b2c5bf091c964baa3beec59959cf89ec04506073","tid":1490174,"uid":27718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T10:15:55.000Z","msg":"掟撚哂啲黑警去坐監"},{"pid":"3b7dedbc1473d5698ae38c10c8a3eb99a54c191c","tid":1490174,"uid":247934,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T10:16:02.000Z","msg":"光復香港"},{"pid":"bc837406d05b5ce3800e801350b96ea2a16e9584","tid":1490174,"uid":27718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T10:16:06.000Z","msg":"仆佢個臭街"},{"pid":"5328ffeb0ef7268f7ac4097eea1ac4e76b2a3f70","tid":1490174,"uid":27718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T10:16:34.000Z","msg":"捉落單休班警去受審"},{"pid":"d6f89c9bfae6adf7d2fc6df2bca0ba22b05655c0","tid":1490174,"uid":27718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T10:17:16.000Z","msg":"證據確鑿就禁固佢"},{"pid":"225908cbd9a5249fa45f510e95aa69ff7bc22af3","tid":1490174,"uid":27718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T10:17:27.000Z","msg":"屌你班死黑警"},{"pid":"16a0e3b536f49b5a3f63f569140c75548e074003","tid":1490174,"uid":27718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T10:17:39.000Z","msg":"仆街啦黑社會黑警"},{"pid":"89e68687ec8bf6e16be6ccadcdbadb48e1967ce7","tid":1490174,"uid":27718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T10:17:53.000Z","msg":"推撚到有人制裁"},{"pid":"4f661950bd97159c26dbb7fa4761a7585877c0ec","tid":1490174,"uid":27718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T10:18:07.000Z","msg":"捉撚左佢去密室度受審"},{"pid":"1e9dbf909aac328afa84318954f42e860696f354","tid":1490174,"uid":306681,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-20T10:18:17.000Z","msg":"此回覆已被刪除"},{"pid":"fb72fcc3217970ad9f1db564af55d3aa52c16506","tid":1490174,"uid":27718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-2