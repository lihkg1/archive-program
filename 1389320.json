stantnews%2Fcurrent%2Farticle%2F2204996%2F&d=z0v15oAQEaIuorZt047Ij6npKMFcuJZ7CRl7dpp3bCg%3D&h=93ff93c0\" target=\"_blank\">https://www2.hkej.com/instantnews/current/article/2204996/</a>"},"citedBy":1,"replyTime":"2019-07-31T01:33:43.000Z","msg":"譴責譴責譴撚完未<br />\n 直接開記招 屌柒黑警啦<br />\n揾2個被架空既人傾有咩用"},{"pid":"db11e59cf47457941658c740827a6e7f9a71d784","tid":1389320,"uid":268801,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T01:35:47.000Z","msg":"<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><br />\n想保護手足就做d野啦"},{"pid":"032a60643d8bc7a75fdb3cdb855f0140c2b141c4","tid":1389320,"uid":44783,"like":0,"dislike":0,"score":0,"quote":{"pid":"9de2da4994d966884bfd443e14c4a129a4c0a7e8","tid":1389320,"uid":81668,"like":1,"dislike":0,"score":1,"citedBy":4,"replyTime":"2019-07-31T01:21:47.000Z","msg":"記者係得大公文匯tvb少啲俾警察打架遮<br />\n<br />\n其他記者喺佢地視線範圍都係敵人「記者朋友<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />行撚開啦」<br />\n<br />\n黑警死全家"},"citedBy":0,"replyTime":"2019-07-31T01:35:48.000Z","msg":"大公文匯tvb 都知自己係低等D<br />\n比狗打完都唔敢出聲<br />\n怕比到麻煩阿SIR"},{"pid":"9e7a64217dad45e26f46186f99be2079e163ee31","tid":1389320,"uid":50414,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T01:36:13.000Z","msg":"推"},{"pid":"8fe0814bb7a44d57254c94d0497971ced0d7b42b","tid":1389320,"uid":41914,"like":0,"dislike":0,"score":0,"quote":{"pid":"b709e8b0d4f44e27eff07072b22b6b0337e1ca41","tid":1389320,"uid":186338,"like":2,"dislike":0,"score":2,"quote":{"pid":"8e1b79059e23b726d62b98c37af42e378a1dba00","tid":1389320,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-31T01:16:23.000Z","msg":"香港記者協會和攝影記者協會聯合發表聲明，稱昨日(30日)深夜時分，示威者到葵涌警署外抗議，警察驅趕期間，有警員蓄意衝前襲擊正在後退的攝影記者，該記者被警盾重擊頭部倒地。有女記者離開時被警員再三追打驅趕，亦有警員向現場記者噴發胡椒噴劑，甚至以槍指嚇在場記者。<br />\n<br />\n協會表示，警員蓄意攻擊記者的行為絕不能被接受，予以最嚴厲的譴責。<br />\n<br />\n聲明指出，深夜時分大批防暴警察從葵涌警署走出驅趕示威者，期間<span style=\"color: red;\">《蘋果日報》</span>一名攝影記者在警方防線前後退，已表明記者身份並舉手示意正在離開，一名警員先後兩次用警盾推撞記者，第二次更從兩米外突然衝前，用警盾揮打攝影記者的頭部，該攝影記者咀角被擊中倒地。及