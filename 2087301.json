ke":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T17:28:24.000Z","msg":"<a href=\"https://lihkg.com/thread/2086300/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/2086300/page/1</a><br />\n<br />\n<strong><span style=\"font-size: x-large;\">係時候到我地守護番正義女神</span></strong><img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /><br />\n<br />\n我想破2千正評, 留個紀念得唔得, 推番行動POST優先"},{"pid":"8011ea08afff1ef4be884264026da4a7669cfe4e","tid":2087301,"uid":114074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T17:32:20.000Z","msg":"推"},{"pid":"785a37c8ad8a56c7a31ac42836964d1267129967","tid":2087301,"uid":61797,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T17:38:48.000Z","msg":"thx巴打"},{"pid":"e5552aaf475fbb38d559d61d92d954bab3fac221","tid":2087301,"uid":72859,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T18:03:18.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"008cc6eb235d86d5435aa94fdb7b1afbae3c58f6","tid":2087301,"uid":99608,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T18:09:15.000Z","msg":"推"},{"pid":"f4c77bdcb4a8e1cb2b5db163e8ec4b9c8d636e7c","tid":2087301,"uid":175346,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-30T18:10:27.000Z","msg":"此回覆已被刪除"},{"pid":"da410a5a393e4dacc7e0b04cd11ae902cd592fc9","tid":2087301,"uid":325346,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T18:10:47.000Z","msg":"有用post<br />\n推"},{"pid":"2e643d88b073c8d4d847bec3ce0783ad7975d834","tid":2087301,"uid":325346,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T18:11:09.000Z","msg":"推"},{"pid":"3d9331ea9dfbd342c84ef6ba6b4b77e837dde766","tid":2087301,"uid":90282,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-01T03:19:07.000Z","msg":"推"},{"pid":"cd11a968824a7d45d4841b58b8218648cc7328b8","tid":2087301,"uid":90282,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-01T03:20:29.000Z","msg":"推！！"}]}