但佢每次好快又會唔開心返 又要再花心力去氹而我都冇可能即刻飛返去陪伴佢 有時我想同佢分享下分擔下 就叫我唔好講政治野  其實我都係想有人聽下我講嘢 所以同佢鬧咗場交 冷淡左一排 當我想搵返佢嘅時候，身體突然有事入咗醫院 出院第二日約咗同屋企人去旅行 原本諗住放鬆心情搵返佢 但咁岩係外地 就要即刻搵口罩 又要望住個網 又要唔嚇親屋企人 唔想大家去旅行冇心情 過多幾日終於買夠 俾自己屋企人同身邊朋友 先有機會再講 但可能佢已經心淡 畢竟我係個兩三個禮拜都冇搵佢講返 一開始係鬥氣之後係太忙"},{"pid":"30bd9aad23ace65fa9f4d7ec303c53a9d56655a8","tid":1877153,"uid":219583,"like":0,"dislike":0,"score":0,"quote":{"pid":"40e67e38f6c504a8733d1609909a623177389ed2","tid":1877153,"uid":260328,"like":0,"dislike":0,"score":0,"quote":{"pid":"c56e57ffe007fbb11c3c9e9834716b5c16dd0a77","tid":1877153,"uid":219583,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-13T02:13:57.000Z","msg":"GFFMC 40TH RX78-2<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-13T02:18:23.000Z","msg":"<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />你巴定絲?"},"citedBy":1,"replyTime":"2020-02-13T02:55:22.000Z","msg":"紅巴"},{"pid":"1fe0ae114f0118d7759e53397b294bb716f57faa","tid":1877153,"uid":6275,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-13T03:37:58.000Z","msg":"<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},{"pid":"7e7b7526fd9684fffc3e571691e727651893048b","tid":1877153,"uid":260328,"like":0,"dislike":0,"score":0,"quote":{"pid":"1fe0ae114f0118d7759e53397b294bb716f57faa","tid":1877153,"uid":6275,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-13T03:37:58.000Z","msg":"<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-13T05:31:23.000Z","msg":"咁味好細隻<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 心機野"},{"pid":"6f7ef0c81fae65197ef5aaf267bbc268c469fd67","tid":1877153,"uid":260328,"like":0,"dislike":0,"score":0,"quote":{"pid":"30bd9aad23ace65fa9f4d7ec303c53a9d56655a8","tid":1877153,"uid":219583,"like":0,"dislike":0,"score":0,"quote":{"pi