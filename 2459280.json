ps%3A%2F%2Fna.cx%2Fi%2F67bUmw9.png&h=e6e4b2c8&s={SIZE}\" />"},{"pid":"72bf54b30c3d391fd50388098300f7219170c161","tid":2459280,"uid":73942,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-24T06:07:36.000Z","msg":"胸牙脷呢啲垃圾國踢出歐盟同北約算鳩數啦，叫支蛾聯盟照住佢啦"},{"pid":"d61f83b95f7c398c8f8e1de1c5cc4aea1b09ddfe","tid":2459280,"uid":93784,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-24T06:10:17.000Z","msg":"快D加入做中華人民移民國不可分割既一部分啦<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"}]}