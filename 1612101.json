7634,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T07:21:31.000Z","msg":"推"},{"pid":"08b939bee43dc32e7d9d35f11b07d9e6f46b6ea4","tid":1612101,"uid":51111,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T07:22:28.000Z","msg":"推"},{"pid":"94becfd8ba2be053fc8f354d6c79f778156a6582","tid":1612101,"uid":279895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T07:22:45.000Z","msg":"前線行動的確需要有個人話畀大家要點配合<br />\n當然唔係指同狗埋牙仲要解釋要點做啦<br />\n指準備砌防線，點攻點守都畀大家有個共識<br />\n而且現場可能有新人想加入，未必可以跟到前線步伐<br />\n避免之後嘅混亂，事前有個小brief其實好有用<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"76a7629b3ad533cf69310c832c1deb0a00e0fb25","tid":1612101,"uid":167634,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T07:24:22.000Z","msg":"推"},{"pid":"2e1742122921ecb9463de8b554c0e4890cb4bf42","tid":1612101,"uid":167634,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T07:26:29.000Z","msg":"Push"}]}