assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"2abb21a5d6bdc297b7fbc9dfd66f14edde658c2e","tid":164272,"uid":82829,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-20T15:43:44.000Z","msg":"加油<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"c89ab6a31490b3ee22b70db44e44910b182c417b","tid":164272,"uid":56139,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-20T23:12:27.000Z","msg":"<blockquote>咩病房呀<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n骨科<br />\n<br />\n<blockquote>悶啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n痛我冇野 本身有幫我吊止痛藥 點知第二日話塞左<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n塞左咪打第隻手<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 果時痛到係口服兩隻止痛藥 再吊止痛藥<br />\n<br />\n<blockquote>加油<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"6fce8ed0483fc88568c463fdf1d6d239b84fbb13","tid":164272,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-20T23:13:04.000Z","msg":"RIP<br />\n<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"cb164f5f9e1629649ce98ba1fc4423f57eea679b","tid":164272,"uid":56139,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-21T01:07:45.000Z","msg":"<blockquote>RIP<br />\n<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n屌你路姆西<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"6ca69f8a444b20123b899c2d96e0b245f960bc83","tid":164272,"uid":40499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-21T01:16:12.000Z","msg":"有無護士睇下"},{"pid":"4f9b47a23e711cb5b416d44f311a01f596e38c72","tid":164272,"uid":1345,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-21T01:42:18.000Z","msg":"B4<img src=\"/assets/faces/n