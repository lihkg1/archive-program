al/agree.gif\" class=\"hkgmoji\" />"},{"pid":"55cd87f01fdc775b14158d770336683f98b47062","tid":1507194,"uid":287051,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T08:07:18.000Z","msg":"簽左先 <img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"61e242fb4600ba190c5b40e5712ec7bd4d1119b6","tid":1507194,"uid":268712,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T08:12:33.000Z","msg":"推"},{"pid":"f42bdeda5fce56849dcdb6f954edb2444d0d9e96","tid":1507194,"uid":293798,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-08-26T10:35:35.000Z","msg":"此回覆已被刪除"},{"pid":"7a4de50166c655817cd16d2d28aac9e1e57e22f2","tid":1507194,"uid":275109,"like":1,"dislike":0,"score":1,"quote":{"pid":"60e85b79935e8b7322ddb7df48e9564cd56ee5fd","tid":1507194,"uid":208573,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2019-08-26T05:10:42.000Z","msg":"<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=TNp%2FFCzVUvAW3I%2FC9AhTY84e4tfxBia5339duguOAPM%3D&h=8766d642\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a><br />\n<br />\n希望大家幫下手，而家仲爭大約四萬個網上簽名 ，儲齊10萬個簽名，就可以畀壓力英國議會，將呢個話題擺上會議討論 。<br />\n<br />\n目的係想將擁有bno passport嘅15至16萬個市民可以拎到英國居英權 。其實唔只呢15至16萬個市民嘅，因為如果佢哋拎到居英權，佢哋嘅直屬家屬，甚至乎伴侶，都可以拎到英國居英權。<br />\n<br />\n 而且喺香港仲有好多人其實係冇續令到bno passport。只要你一日有keep住嗰本舊嘅英國bno passport，你都仲可以續領一本新嘅passport。所以數字上係絕對唔止十六萬咁少。<br />\n<br />\n其實佢個deadline好快就到啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />希望大家幫下手，畫隻龜簽名，就可以畀壓力比英國，俾壓力比香港政府同埋中國 。<br />\n<br />\n如果你撳入去，你會留意到佢淨係畀有英國護照嘅人或者目前住喺英國嘅居民先可以簽名，但其實你只要求其喺google搵一個英國postcode填上去就ok㗎喇。你淨係需要填上你嘅姓名電郵同埋postcode。你個姓名都唔一定需要係你嘅真名 ，希望大家如果可以除咗畫隻龜之餘，都將啲條link share畀身邊嘅朋友。成個過程唔會嘥你多過三分鐘。<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-26T13:00:40.000Z","msg":"古怪細節 <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><br />\nHong Kongers will come in as political refugees. <span style=\"color: red;\">We will need a lot of effort to house them and bad for the British reputations</span> to the International community then."},{"pid":"5e02117efbd9d2cbe3d6d6b909d3d45e45f17083","tid":1507194,"uid":278283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T13:05:33.000Z","msg":"簽啦"},{"pid":"aea034ca0fd218fd9b8d0f95a83e460f02ba5925","tid":1507194,"uid":304769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T13:30:53.000Z","msg":"BNO平權文宣方向<br />\n不過, 從7月開始, 英國輿論 &ndash; 從每日快報, 衛報, 觀察者, 甚至太陽報紛紛鼓吹<span style=\"color: red;\"><strong><ins>英國政府應給予BNO持有者BC身份</ins></strong></span>. 值得一提的是英國智庫Adam Smith Institute在8月15日出了一份名為Doing Our Duty的研究報告, 建議<strong><ins><span style=\"color: red;\">英國政府應將BNO權利擴大至與BC同等</span></ins></strong>, 因為若BNO人成為BC, 這&rdquo;<span style=\"color: red;\"><strong><ins>將會促使中國和平地行事</ins></strong></span>&rdquo; (p. 6), 香港人可以&rdquo;在自由的環境下生活, 而中國則失去一整代人,<strong><ins><span style=\"color: red;\"> 英國會得到道德和物質上的勝利</span></ins></strong>&rdquo; (p. 7). 不只如此, <strong><ins><span style=\"color: red;\">香港人&rdquo;人均收入高, 高學歷及具備專業技能, 對英國經濟會有實質益處</span></ins></strong>&rdquo; (p. 8). 最後, <strong><ins><span style=\"color: red;\">英國幫BNO升級可顯示英國&rdquo;並未忘記其角色和放棄原則&rdquo;</span></ins></strong> (p. 9). 這份報告暗示: a. BNO是&rdquo;和平時代&rdquo;的產物. 只要中英間利益衝突, BNO會是英國的招數: 中國領土內突然出現大批BC會<strong><ins><span style=\"color: red;\">使英國有理由介入香港事務</span></ins></strong>, 這也是為什麼當初英國不給港人BC身份, 卻要弄出BNO, 而中國則要強加中國籍給香港人的根本原因 (英國不要收留港人; 中國收港人, 但條件是&rdquo;管得了&rdquo;的港人. 反正要抓人只要說句他是&rdquo;中國人&rdquo;就行) (結論1和3); b. 英國對香港的&rdquo;道義和責任&rdquo;乃建基在利益上, 尤其<strong><ins><span style=\"color: red;\">正值英國脫歐, 香港將可成為英國經濟的救火員</span></ins></strong> (結論2)."},{"pid":"2c167f27f516810d1da66553df1975ec07a0f012","tid":1507194,"uid":171302,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T16:23:17.000Z","msg":"Push"},{"pid":"3872c72322cddcb4f2a32ba87d63b0319a64b7fe","tid":1507194,"uid":45524,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T16:48:34.000Z","msg":"Push"},{"pid":"decf62c042d15bf03fc7b4c323d1ac75d33dba8e","tid":1507194,"uid":301260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T17:55:00.000Z","msg":"Push"},{"pid":"3d299e4724d51f1c3730309b6de651c79e03e8ce","tid":1507194,"uid":19037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T19:48:30.000Z","msg":"<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=TNp%2FFCzVUvAW3I%2FC9AhTY84e4tfxBia5339duguOAPM%3D&h=8766d642\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a><br />\n<br />\n幫推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"59dc4bcbeca68452bc18c6dc00a63d526ff27321","tid":1507194,"uid":279401,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T19:50:22.000Z","msg":"手足快簽呀！"},{"pid":"b277caf0284d85f3c8d62a7d947167ba8e78416d","tid":1507194,"uid":171259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T20:01:16.000Z","msg":"Push"},{"pid":"c01254aca806961cac7bbdaf030232039ebe8440","tid":1507194,"uid":299984,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T20:35:27.000Z","msg":"幫推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"25e8e4cf4ed79c48454b7854a1624fd23a7c1ee4","tid":1507194,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-26T23:53:12.000Z","msg":"detail 段英文好似寫得有啲威脅性？定我英文差？"},{"pid":"bcc066fbd2d2d480c6afa6ed7b63b536dc481a8a","tid":1507194,"uid":158404,"like":0,"dislike":0,"score":0,"quote":{"pid":"f42bdeda5fce56849dcdb6f954edb2444d0d9e96","tid":1507194,"uid":293798,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-08-26T10:35:35.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-08-26T23:53:23.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"3980508a73e2de50ca0106a628fed2083f5b8f83","tid":1507194,"uid":63669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T02:58:33.000Z","msg":"推"},{"pid":"48739d06b9ec5e870385e067df126b7153bc59ba","tid":1507194,"uid":39478,"like":0,"dislike":0,"score":0,"quote":{"pid":"25e8e4cf4ed79c48454b7854a1624fd23a7c1ee4","tid":1507194,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-26T23:53:12.000Z","msg":"detail 段英文好似寫得有啲威脅性？定我英文差？"},"citedBy":1,"replyTime":"2019-08-27T03:10:45.000Z","msg":"講咗好耐，所以好多人先唔簽住"},{"pid":"26dadbdab7dd67be76448d411888025fbbf799e1","tid":1507194,"uid":10402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T03:13:49.000Z","msg":"push"},{"pid":"f0eb827511694eac60c55aaa814ac063a45dba28","tid":1507194,"uid":309989,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T03:56:50.000Z","msg":"十萬個支持"},{"pid":"c746ff7b8caf48b7381e90cedaec892687556221","tid":1507194,"uid":170143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T03:59:12.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"1e94901dd9fb4640eb43a293be0931298d1bf085","tid":1507194,"uid":262264,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T04:11:24.000Z","msg":"推推推推"},{"pid":"96fd897b64db58fb92bef801df4569fa8c3297e2","tid":1507194,"uid":112164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T04:58:50.000Z","msg":"1分鐘時間幫幫手簽<br />\n夠10萬個就有機會喺英國國會討論<br />\n<br />\n為你同你嘅摰愛<br />\n<br />\nPostal code 就打000000<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=TNp%2FFCzVUvAW3I%2FC9AhTY84e4tfxBia5339duguOAPM%3D&h=8766d642\" target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"1f967834e0008ecf61c7fe63e7eb02e5b9b2cff5","tid":1507194,"uid":272795,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T05:24:56.000Z","msg":"個發起人英文1999，不過唔理，照簽左先"},{"pid":"d864eab48c9c4223cb1fff7c32a2ed37d2aefe91","tid":1507194,"uid":304769,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-27T07:11:46.000Z","msg":"BNO平權最後一件事（一定成功）（必看必推長文）（要人）(文宣入)<br />\n我們要採取更主動的方式來推動BNO平權，目前最實際的方法就是<strong><ins><span style=\"color: red;\">大家聯合起來用xxx（到時結尾可以用連登編號聯署）位British Hongkonger的名義</span></ins></strong>來<ins><strong><span style=\"color: red;\">發信給1.英國首相 2.下議院議長 3.內政大臣 4.外交事務大臣 5.全體下議院議員</span></strong></ins>人手一封<br />\n在此請求英語超級好的入來（IELTS7.5+，writing6.5+）幫忙寫,當中<ins><strong><span style=\"color: red;\">必須強調脫歐後香港人能幫助英國，因為脫歐才是目前英國最頭疼的事</span></strong></ins><br />\n<br />\n內容如下：<br />\n1. 說之以理<br />\n對當前<br />\na. 香港的概況，<br />\nb. 我們如何受到<ins><strong><span style=\"color: red;\">迫害(HSBC,CX,Swire&hellip;&hellip;)</span></strong></ins>，<br />\nc. 英國政府對香港的道義責任，<br />\nd. BNO的詳細介紹，因為英國人絕大部分根本不清楚BNO是什麼東西，<br />\ne. 我們必須強調我們都<strong><ins><span style=\"color: red;\">是忠君愛國的英國人</span></ins></strong>，<br />\nf. 目前<ins><strong><span style=\"color: red;\">我們的安全，自由和法治受到前所未有的嚴重威脅</span></strong></ins>，<br />\ng. 而<ins><strong><span style=\"color: red;\">所有英國人都應該有權在安全，自由和法治和免於恐懼的環境下生活</span></strong></ins>的，<br />\nh. 這是<span style=\"color: red;\"><strong><ins>英國政府保護國民的責任</ins></strong></span>。<br />\n<br />\n2. 動之以情<br />\na. 我們必須強調我們都是<ins><strong><span style=\"color: red;\">忠君愛國的英國人</span></strong></ins><br />\nb. 我們都是<ins><strong><span style=\"color: red;\">奉行英國價值觀</span></strong></ins>，民主，自由，法治，廉潔，崇尚一以辯論為本的教育，政治和法治，崇尚獨立思考和批判性思考，重視個人基本權利和利益<br />\n3. 誘之以利<br />\na. 因為若BNO人成為BC, 這<ins><strong><span style=\"color: red;\">&rdquo;將會促使中國和平地行事&rdquo; </span></strong></ins><br />\nb. 香港人可以&rdquo;在自由的環境下生活, 而中國則失去一整代人, <ins><strong><span style=\"color: red;\">英國會得到道德和物質上的勝利</span></strong></ins>&rdquo; <br />\nc. 不只如此,<ins><strong><span style=\"color: red;\"> 香港人&rdquo;人均收入高, 高學歷及具備專業技能, 對英國經濟會有實質益處&rdquo; </span></strong></ins><br />\nd. 最後, 英國幫BNO升級可顯示<ins><strong><span style=\"color: red;\">英國&rdquo;並未忘記其角色和放棄原則&rdquo; </span></strong></ins><br />\ne. BNO是&rdquo;和平時代&rdquo;的產物. 只要中英間利益衝突, BNO會是英國的招數: 中國領土內突然出現大批BC會<ins><strong><span style=\"color: red;\">使英國有理由介入香港事務</span></strong></ins>,<br />\nf. 正值英國脫歐, <ins><strong><span style=\"color: red;\">香港將可成為英國經濟的救火員</span></strong></ins><br />\ng.香港比非常多的英聯邦國家（例如加拿大）更能保持英國制度，故此<ins><strong><span style=\"color: red;\">香港大多專業人士和技術人員無需太多訓練即可完成註冊並投入英國工作</span></strong></ins>，萬一英國<ins><strong><span style=\"color: red;\">脫歐後出現人手短缺，香港人可以幫上大忙</span></strong></ins><br />\n<br />\n大家有補充請在下面留言"},{"pid":"f1851fc78692b3b957c6f3ec99ba157be6cc21d5","tid":1507194,"uid":10402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T08:19:43.000Z","msg":"push"},{"pid":"8ecfc5382b99fa991efe4368a04b3ee82fb1ca94","tid":1507194,"uid":107898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T08:23:59.000Z","msg":"聯署收返香港就簽"},{"pid":"1188aabd75f3b3a44bcbed09f78bb1d867c0162c","tid":1507194,"uid":13053,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T08:25:33.000Z","msg":"呢個堅有用<br />\n推上去丫！！！"},{"pid":"e75d647e46b52f6e41923e3f8f232fee261c935d","tid":1507194,"uid":51698,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T08:26:04.000Z","msg":"<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"3d07b9fb5e0268c03d9dba3a58a3a2d231700e48","tid":1507194,"uid":43311,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T08:28:30.000Z","msg":"9月入機場"},{"pid":"86a5036d13607d1bcf96acbee6cec61c822c15d9","tid":1507194,"uid":286513,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T08:29:45.000Z","msg":"推<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=TNp%2FFCzVUvAW3I%2FC9AhTY84e4tfxBia5339duguOAPM%3D&h=8766d642\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"d7c9ef14a27d9014415a46d485b5dab5f7cd6ccc","tid":1507194,"uid":90421,"like":0,"dislike":0,"score":0,"quote":{"pid":"7a4de50166c655817cd16d2d28aac9e1e57e22f2","tid":1507194,"uid":275109,"like":1,"dislike":0,"score":1,"quote":{"pid":"60e85b79935e8b7322ddb7df48e9564cd56ee5fd","tid":1507194,"uid":208573,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2019-08-26T05:10:42.000Z","msg":"<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=TNp%2FFCzVUvAW3I%2FC9AhTY84e4tfxBia5339duguOAPM%3D&h=8766d642\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a><br />\n<br />\n希望大家幫下手，而家仲爭大約四萬個網上簽名 ，儲齊10萬個簽名，就可以畀壓力英國議會，將呢個話題擺上會議討論 。<br />\n<br />\n目的係想將擁有bno passport嘅15至16萬個市民可以拎到英國居英權 。其實唔只呢15至16萬個市民嘅，因為如果佢哋拎到居英權，佢哋嘅直屬家屬，甚至乎伴侶，都可以拎到英國居英權。<br />\n<br />\n 而且喺香港仲有好多人其實係冇續令到bno passport。只要你一日有keep住嗰本舊嘅英國bno passport，你都仲可以續領一本新嘅passport。所以數字上係絕對唔止十六萬咁少。<br />\n<br />\n其實佢個deadline好快就到啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />希望大家幫下手，畫隻龜簽名，就可以畀壓力比英國，俾壓力比香港政府同埋中國 。<br />\n<br />\n如果你撳入去，你會留意到佢淨係畀有英國護照嘅人或者目前住喺英國嘅居民先可以簽名，但其實你只要求其喺google搵一個英國postcode填上去就ok㗎喇。你淨係需要填上你嘅姓名電郵同埋postcode。你個姓名都唔一定需要係你嘅真名 ，希望大家如果可以除咗畫隻龜之餘，都將啲條link share畀身邊嘅朋友。成個過程唔會嘥你多過三分鐘。<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-26T13:00:40.000Z","msg":"古怪細節 <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><br />\nHong Kongers will come in as political refugees. <span style=\"color: red;\">We will need a lot of effort to house them and bad for the British reputations</span> to the International community then."},"citedBy":0,"replyTime":"2019-08-27T08:30:26.000Z","msg":"<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" />各位簽前睇睇先"},{"pid":"da2e62ce6f70578d5165d7122abb3d27e82e3d1e","tid":1507194,"uid":158404,"like":0,"dislike":0,"score":0,"quote":{"pid":"48739d06b9ec5e870385e067df126b7153bc59ba","tid":1507194,"uid":39478,"like":0,"dislike":0,"score":0,"quote":{"pid":"25e8e4cf4ed79c48454b7854a1624fd23a7c1ee4","tid":1507194,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-26T23:53:12.000Z","msg":"detail 段英文好似寫得有啲威脅性？定我英文差？"},"citedBy":1,"replyTime":"2019-08-27T03:10:45.000Z","msg":"講咗好耐，所以好多人先唔簽住"},"citedBy":0,"replyTime":"2019-08-27T13:11:46.000Z","msg":"agree 唔好柒出國際<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"91d76cdd8c823021745667907401bc01932e86a2","tid":1507194,"uid":156767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T16:24:34.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"5b98b670857530d20f4bc487b423d17c9b3d7971","tid":1507194,"uid":52228,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T17:00:29.000Z","msg":"推！"},{"pid":"12997714cd74af420c59ef53e14d952ca184142d","tid":1507194,"uid":41967,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T17:05:48.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5c494619238a276276c29088f99e14d41895b38c","tid":1507194,"uid":143526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T17:10:10.000Z","msg":"置頂"},{"pid":"56a6e08c973c42642051a848c27e4519e333bb75","tid":1507194,"uid":308875,"like":0,"dislike":0,"score":0,"cite