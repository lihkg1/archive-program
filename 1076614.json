{"tid":1076614,"cid":5,"subCid":0,"title":"太古城女子留遺書墮樓亡","createTime":"2019-03-25T03:41:15.000Z","updateTime":"2019-03-25T08:48:54.000Z","uid":3090,"like":5,"dislike":0,"uniUserReply":12,"replies":[{"pid":"11320266a0c7094927fb8b8b44460ed5d3846684","tid":1076614,"uid":3090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-25T03:41:15.000Z","msg":"<img src=\"https://na.cx/i/mY5HWoh.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmY5HWoh.png&h=a606afd9&s={SIZE}\" /><br />\n墮樓女子送院後不治。溫瑞麟攝<br />\n<br />\n【20:20】傷者送院後不治，警方撿獲一封遺書<br />\n<br />\n鰂魚涌太古城金星閣，下午5時許，保安發現一名43歲姓羅女子倒卧1樓簷篷上，懷疑她由高處墮下，於是報案。消防接報趕至，將墮樓女子救下，交由救護車送院搶救，惟抵院後證實不治。警方正在場調查。"},{"pid":"bcd8d2231959f3148466dab1fd00d24e10173b5f","tid":1076614,"uid":55924,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-25T03:42:22.000Z","msg":"太古城都跳<img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" />"},{"pid":"d9a552f2beaa8faae22ee4fe19861f8ae7db0c3a","tid":1076614,"uid":206895,"like":1,"dislike":5,"score":-4,"citedBy":2,"replyTime":"2019-03-25T03:43:45.000Z","msg":"SSR都要重刷<img src=\"/assets/faces/lm2/donno.gif\" class=\"hkgmoji\" />"},{"pid":"22ece03c78eb28b35021201b5e1842643afa5efa","tid":1076614,"uid":163347,"like":6,"dislike":0,"score":6,"quote":{"pid":"d9a552f2beaa8faae22ee4fe19861f8ae7db0c3a","tid":1076614,"uid":206895,"like":1,"dislike":5,"score":-4,"citedBy":2,"replyTime":"2019-03-25T03:43:45.000Z","msg":"SSR都要重刷<img src=\"/assets/faces/lm2/donno.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-25T03:45:11.000Z","msg":"太古城頂盡咪A<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"163f61d635e139221d39847e2cb608c5a7c90262","tid":1076614,"uid":189160,"like":0,"dislike":0,"score":0,"quote":{"pid":"bcd8d2231959f3148466dab1fd00d24e10173b5f","tid":1076614,"uid":55924,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-25T03:42:22.000Z","msg":"太古城都跳<img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" />"},"cite