ass=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"92f7bd45dbd3af2ddf1b47be8512b06d76d465eb","tid":1309253,"uid":39478,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T06:38:02.000Z","msg":"push"},{"pid":"5953a34c3484fc1367c276fc16444ddee7b06b31","tid":1309253,"uid":90743,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T06:38:12.000Z","msg":"Up"},{"pid":"f3c4e6fb09e88796f7509eb6e7db4fbe133021c8","tid":1309253,"uid":267969,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T06:38:21.000Z","msg":"<span style=\"font-size: xx-large;\"><strong>推返呢個</strong><br />\n白宮聯署：支持香港人權法，7月21日集會前儲齊10萬，尚欠43,262個簽名 - 重開<br />\n<a href=\"https://lihkg.com/thread/1309287/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1309287/page/1</a></span>"},{"pid":"d587536322e27830d284a3612edbaddb3f6a1314","tid":1309253,"uid":208796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T06:40:54.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"49c9281af9927607dd197b9b453fded03a9f2e0b","tid":1309253,"uid":272030,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T06:45:19.000Z","msg":"如果取消香港政策法 香港因為親中政策冇左獨立關稅 咁就同其他大陸城市冇分別 大陸一直想香港國際地位下降 若果大陸想強行立法玩死香港 呢條法案反而令香港冇左優勢 變成要跟大陸搵錢 <br />\n有錯請糾正 我實在唔知要不要支持條法案"},{"pid":"fe5b7b19d42bc2a1d72678fbbaf609b0b9299b00","tid":1309253,"uid":94771,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T06:50:12.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"29194d9a44cbcb983d030bd479b0e43245bf59ce","tid":1309253,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T06:54:21.000Z","msg":"推"}]}