c3npyj.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fec3npyj.jpg&h=648ef6a3&s={SIZE}\" /><br />\n<br />\n<img src=\"https://na.cx/i/avbtvJ0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FavbtvJ0.jpg&h=e1c98503&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/hppS6Sz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhppS6Sz.jpg&h=867a6106&s={SIZE}\" /><br />\n唔好唔記得831幫警甴殘殺手足兇手<br />\n<img src=\"https://na.cx/i/YJzPCRN.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FYJzPCRN.jpg&h=f8ccc6b5&s={SIZE}\" /><br />\n<br />\n齊心祝福<br />\n<img src=\"https://na.cx/i/ug7anh2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fug7anh2.png&h=2bf968e4&s={SIZE}\" />"},{"pid":"a8bd112181b388b66c8cf69ab2acf96073bea31f","tid":1815060,"uid":29021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T14:34:07.000Z","msg":"pish"},{"pid":"34d6a8e08fa3468a192a390abd36372fe815cebd","tid":1815060,"uid":158270,"like":0,"dislike":0,"score":0,"quote":{"pid":"8b44931b62675cbb7cd1e4f7341400d9afd63ef9","tid":1815060,"uid":29021,"like":0,"dislike":0,"score":0,"quote":{"pid":"6db62c4b5af48ae2ae87b3039fd596df9765beac","tid":1815060,"uid":158270,"like":0,"dislike":0,"score":0,"quote":{"pid":"61a6cd5e404f50d2b4d1a1220054dfeddc978b9e","tid":1815060,"uid":29021,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-01-12T14:18:40.000Z","msg":"咁和理非缺乏嘅就係勇氣、勇武需要嘅就係才智；只有大家都互補長短、互相信任，先至可以令大家都變得更強去對抗政權"},"citedBy":1,"replyTime":"2020-01-12T14:22:22.000Z","msg":"小弟和理非，正思考點樣練大膽啲，然後鼓勵其他人大膽啲。"},"citedBy":1,"replyTime":"2020-01-12T14:31:26.000Z","msg":"喺練大膽之前，首先要突破心防，唔好驚咗人地大膽嘅行為<br />\n<br />\n然後要明白集體力量先至可以成事嘅道理，要罷就一齊罷、要勇就一齊勇，咁先唔會有「送頭」嘅情況"},"citedBy":0,"replyTime":"2020-01-12T14:36:57.000Z","msg":"有次拉人我捉住手足隻手，但俾popo凶走咗。我諗如果當時有多十個同我一樣冇裝嘅人，佢就唔使俾人拉。"}]}