 />\n一係就乜都唔好食<br />\n<br />\n煩過閪"},{"pid":"7b3632f719f996ee64c4ac655c17d2323755f7b8","tid":1124840,"uid":30384,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-26T04:56:22.000Z","msg":"<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"468f5c56bb5b48d564c72903e840abc24644ac25","tid":1124840,"uid":64854,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2019-04-26T05:07:06.000Z","msg":"<span style=\"font-size: x-large;\">呢隻種啲肉 ok喎</span>"},{"pid":"f66d2973836af7f19751419ff03b5137ed2992b7","tid":1124840,"uid":124741,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-04-26T05:11:35.000Z","msg":"做人唔養狗，做黎做乜？"},{"pid":"5d76e36a39bc80f9e17dcc55e9fa1ccbda6d6093","tid":1124840,"uid":2054,"like":0,"dislike":0,"score":0,"quote":{"pid":"468f5c56bb5b48d564c72903e840abc24644ac25","tid":1124840,"uid":64854,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2019-04-26T05:07:06.000Z","msg":"<span style=\"font-size: x-large;\">呢隻種啲肉 ok喎</span>"},"citedBy":0,"replyTime":"2019-04-26T05:12:50.000Z","msg":"中國人<img src=\"/assets/faces/lm2/eating.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/eating.gif\" class=\"hkgmoji\" />"},{"pid":"8fb091cf94b8129e5f6e3da3524cd5b151231243","tid":1124840,"uid":49853,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-26T05:14:04.000Z","msg":"<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"e6ea0be6665bee3b9615bfd33d33a9fd8ca770cd","tid":1124840,"uid":79471,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-04-26T05:16:16.000Z","msg":"想食咗佢咋"},{"pid":"59b8bce0f5b50fd9a8625f3d3d31dc231117b3e1","tid":1124840,"uid":170223,"like":3,"dislike":0,"score":3,"quote":{"