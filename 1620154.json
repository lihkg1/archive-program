ke":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T09:57:48.000Z","msg":"推"},{"pid":"73cf6966a9663371e5cd0261ea6780eb78b6e36c","tid":1620154,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T09:58:01.000Z","msg":"推"},{"pid":"12cc447b8a248b7f6cfe709226cdd7fc13c60034","tid":1620154,"uid":169665,"like":15,"dislike":1,"score":14,"citedBy":1,"replyTime":"2019-10-04T09:58:23.000Z","msg":"前大學教授<br />\n廢事啲人因人廢言"},{"pid":"354b03d64c1dadd344369d8115ce44c51b3c251a","tid":1620154,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T09:58:50.000Z","msg":"推"},{"pid":"aa1904c8797073b87e3c4fabea542ba56cab3094","tid":1620154,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T09:59:06.000Z","msg":"推"},{"pid":"4b0e7bcb120676741efab4c49de0ae236a2daca4","tid":1620154,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T09:59:20.000Z","msg":"推"},{"pid":"2e4813fdd4319c27dba791b4b88893abcee81567","tid":1620154,"uid":259329,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-04T09:59:26.000Z","msg":"此回覆已被刪除"},{"pid":"c93dc2cca7fa218804591a0121208ebc0fce15f5","tid":1620154,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T09:59:42.000Z","msg":"推"},{"pid":"2b3357caaf48ac2ec0e228434981b34701efa818","tid":1620154,"uid":54636,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T09:59:54.000Z","msg":"推"},{"pid":"567d5f725ed0767d4f87568d2ea195b5c282b1af","tid":1620154,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T10:00:00.000Z","msg":"推"},{"pid":"e22fa0317ad2044e0de19e58c01ba87282b82c02","tid":1620154,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T10:00:13.000Z","msg":"推"},{"pid":"bd05f61114b95b032ff35f154b5322b6ed93ec33","tid":1620154,"uid":149630,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-04T10:00:26.000Z","msg":"推"},{"pid":"12d4b