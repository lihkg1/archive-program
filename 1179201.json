ddd2cf298","tid":1179201,"uid":55493,"like":0,"dislike":0,"score":0,"quote":{"pid":"839b9000764036f44d94d466360502a9b18d2b15","tid":1179201,"uid":200288,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-31T04:24:30.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-31T04:33:40.000Z","msg":"一人一個post有錢齊齊搵"},{"pid":"d21644b8b50f49b2354259189f1e13c58d43fbe0","tid":1179201,"uid":220779,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-05-31T04:34:14.000Z","msg":"你今日支持得喜茶，第日更容易接受抖音，過多兩日接受埋簡體字都唔怪，最後變晒講普通話。<br />\n<br />\n係<br />\n我有個friend 本身好反共 之前去同佢出街佢買左杯喜茶 飲完一杯之後就成個人變左咁<br />\n係咁嗌 我愛共產黨 64無死人之類<br />\n連母語廣東話都唔講 <br />\n亦都論證左樓主論點無係滑坡"},{"pid":"28c252f3ee2cc4134beaeb2452efa9bb348368f9","tid":1179201,"uid":200288,"like":0,"dislike":0,"score":0,"quote":{"pid":"d21644b8b50f49b2354259189f1e13c58d43fbe0","tid":1179201,"uid":220779,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-05-31T04:34:14.000Z","msg":"你今日支持得喜茶，第日更容易接受抖音，過多兩日接受埋簡體字都唔怪，最後變晒講普通話。<br />\n<br />\n係<br />\n我有個friend 本身好反共 之前去同佢出街佢買左杯喜茶 飲完一杯之後就成個人變左咁<br />\n係咁嗌 我愛共產黨 64無死人之類<br />\n連母語廣東話都唔講 <br />\n亦都論證左樓主論點無係滑坡"},"citedBy":0,"replyTime":"2019-05-31T04:35:49.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />g持樓主"},{"pid":"55d65b032e96829baefdd7c15a86d53ef182fb69","tid":1179201,"uid":214972,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-31T04:35:49.000Z","msg":"聖人先可以講政治論<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"011dce400b5a49e826d2f9daaac5c72a7511b53c","tid":1179201,"uid":55493,"like":0,"dislike":0,"score":0,"quote":{"pid":"05fa08a32290265123324c9ac32f29376243d64c","tid":1179201,"uid":115953,"like":0,"dislike":0,"score":0,"quote":{"pid":"38ea393e1e9194c6e59b1727aad9640e7a9641fa","tid":1179201,"uid":55493,"like":0,"dislike":0,"score":0,"quote":{"pid":"d79ef582a243c4d3509715dc006ffd77