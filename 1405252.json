eae379b9510ad9d","tid":1405252,"uid":29836,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-08-04T08:55:12.000Z","msg":"唔好玩食物<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-04T10:13:45.000Z","msg":"所以d變壞變臭既就大派用場"},{"pid":"464eddbe05f791884b26ba18a62ee31a9ea4f31f","tid":1405252,"uid":153864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T10:14:58.000Z","msg":"游擊呀 撚完狗好走啦<br />\n<a href=\"https://lih.kg/1405528\" data-auto-link target=\"_blank\">https://lih.kg/1405528</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"4267f592e2c176de8d5b876377c7e4f9a7778929","tid":1405252,"uid":31907,"like":0,"dislike":0,"score":0,"quote":{"pid":"3dcf0e75181ca72ac1ce02234672142bbe739f41","tid":1405252,"uid":66260,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-08-04T08:35:05.000Z","msg":"<a href=\"https://www.facebook.com/TWSupport/photos/a.259664934154654/2329644867156640/?type=3&amp;theater\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FTWSupport%2Fphotos%2Fa.259664934154654%2F2329644867156640%2F%3Ftype%3D3%26theater&d=LFOX9O72C3pH7rxPP1PUB3vcSryOYOd41eK7VOq09cM%3D&h=9069cb31\" data-auto-link target=\"_blank\">https://www.facebook.com/TWSupport/photos/a.259664934154654/2329644867156640/?type=3&amp;theater</a><br />\n<br />\n（轉發）全副武裝的抗暴警察，在獨裁國家是許多示威遊行者的惡夢，面對這樣的武裝，遊行示威的一方似乎是雞蛋碰石頭，但比起丟石頭，丟雞蛋似乎是更有效的武器。<strong><span style=\"color: red;\">雞蛋破裂後的蛋汁會黏附在頭盔及透明盾牌上，更會對防護眼鏡帶來一陣模糊</span></strong>。若再加上水球，這種抗議方式往往會更加有力。在抗議現場，<strong><span style=\"color: red;\">這種蛋洗戰術，能夠有效的減緩武裝警察的攻勢，畢竟看不清楚，就很難正確的推進及抓補</span></strong>，就算抗議者被抓，雞蛋跟水球很難說的上是致命武器。<strong><span style=\"color: red;\">而且價格低廉，隨處可買，補充迅速</span></strong>。<br />\n<br />\n而且雞蛋跟水，雖然對人不具殺傷力，但對這些抗暴裝備，卻是十分的難以維護，<strong><span style=\"color: red;\">溫度會讓濕掉的設備發黴，雞蛋腐壞的氣味會讓配戴者難以接受。而要清潔，需要大量的人力去清洗</span></strong>，抗議就是這麼回事，增加對方的成本，維持自己抗議的能量，不讓對方贏。<br />\n<br />\n網友加碼：<strong><span style=\"color: red;\">在雞蛋面前，架設在路口的監視器也是難逃一劫</span></strong>。"},"citedBy":0,"replyTime":"2019-08-04T10:16:47.000Z","msg":"我一早講強係最有效"},{"pid":"41cf5b8ba3e5760f2f6590913dbba2dbaffa39dc","tid":1405252,"uid":66260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T15:53:23.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"741dd32bcf94ca9d6ba3011812ae9ebcdd7876de","tid":1405252,"uid":283166,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T15:57:11.000Z","msg":"千祈唔好玩牛奶呀，<br />\n一發酵陣味好難洗架<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"f16544e8a1343be68682a76f80816e13d18c88e7","tid":1405252,"uid":283166,"like":0,"dislike":0,"score":0,"quote":{"pid":"3dcf0e75181ca72ac1ce02234672142bbe739f41","tid":1405252,"uid":66260,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-08-04T08:35:05.000Z","msg":"<a href=\"https://www.facebook.com/TWSupport/photos/a.259664934154654/2329644867156640/?type=3&amp;theater\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FTWSupport%2Fphotos%2Fa.259664934154654%2F2329644867156640%2F%3Ftype%3D3%26theater&d=LFOX9O72C3pH7rxPP1PUB3vcSryOYOd41eK7VOq09cM%3D&h=9069cb31\" data-auto-link target=\"_blank\">https://www.facebook.com/TWSupport/photos/a.259664934154654/2329644867156640/?type=3&amp;theater</a><br />\n<br />\n（轉發）全副武裝的抗暴警察，在獨裁國家是許多示威遊行者的惡夢，面對這樣的武裝，遊行示威的一方似乎是雞蛋碰石頭，但比起丟石頭，丟雞蛋似乎是更有效的武器。<strong><span style=\"color: red;\">雞蛋破裂後的蛋汁會黏附在頭盔及透明盾牌上，更會對防護眼鏡帶來一陣模糊</span></strong>。若再加上水球，這種抗議方式往往會更加有力。在抗議現場，<strong><span style=\"color: red;\">這種蛋洗戰術，能夠有效的減緩武裝警察的攻勢，畢竟看不清楚，就很難正確的推進及抓補</span></strong>，就算抗議者被抓，雞蛋跟水球很難說的上是致命武器。<strong><span style=\"color: red;\">而且價格低廉，隨處可買，補充迅速</span></strong>。<br />\n<br />\n而且雞蛋跟水，雖然對人不具殺傷力，但對這些抗暴裝備，卻是十分的難以維護，<strong><span style=\"color: red;\">溫度會讓濕掉的設備發黴，雞蛋腐壞的氣味會讓配戴者難以接受。而要清潔，需要大量的人力去清洗</span></strong>，抗議就是這麼回事，增加對方的成本，維持自己抗議的能量，不讓對方贏。<br />\n<br />\n網友加碼：<strong><span style=\"color: red;\">在雞蛋面前，架設在路口的監視器也是難逃一劫</span></strong>。"},"citedBy":0,"replyTime":"2019-08-04T15:58:26.000Z","msg":"再者雞蛋都好配合我地的身份<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"77b5ebb73389665444ed4330c9b4e878c9c2d62a","tid":1405252,"uid":66260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T05:49:38.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"664777304f632079251578f226b15a77fd4434df","tid":1405252,"uid":133903,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T05:50:14.000Z","msg":"推"},{"pid":"04fc77cd355a6244128a449b49286aabb73bf2e5","tid":1405252,"uid":40250,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-08-05T05:51:02.000Z","msg":"咪撚on9喇屌你老母<br />\n咁點解唔用漆彈呀？<br />\n<br />\n成日係到開埋d垃圾post"},{"pid":"328eb04f17bfb230e68db09654ac7971b5ecdba4","tid":1405252,"uid":260367,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T05:51:56.000Z","msg":"push push push"},{"pid":"62a60114af2a381670dc92badb59c2f4158626c4","tid":1405252,"uid":295616,"like":0,"dislike":0,"score":0,"quote":{"pid":"84c87da195479b378c3e9844c985b33ec639ad1d","tid":1405252,"uid":238275,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-08-04T08:53:45.000Z","msg":"<img src=\"https://na.cx/i/0KQLLdK.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0KQLLdK.png&h=53c3a20c&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-08-05T05:52:15.000Z","msg":"正"},{"pid":"6c285450e76c707b0ec42c27f6b8630ebb1d1431","tid":1405252,"uid":231408,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T05:53:15.000Z","msg":"「緊急」5/8出屯門嘅全部同我入嚟！！<br />\n<a href=\"https://lih.kg/1411986\" data-auto-link target=\"_blank\">https://lih.kg/1411986</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"93c84ebfb9d88cafdf20d38fd0fa65a6236ed13f","tid":1405252,"uid":282048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T05:53:35.000Z","msg":"Push"}]}