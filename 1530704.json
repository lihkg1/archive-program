":0,"dislike":0,"score":0,"quote":{"pid":"e67eb22f41de0b49712f86538c0f7b65c176067a","tid":1530704,"uid":186715,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-09-02T04:51:11.000Z","msg":"要諗下點改善徹退方法"},"citedBy":1,"replyTime":"2019-09-02T04:51:47.000Z","msg":"東涌商場內等家長"},"citedBy":3,"replyTime":"2019-09-02T05:05:44.000Z","msg":"咁樣家長就要比過橋費可能影響數量"},"citedBy":0,"replyTime":"2019-09-02T06:11:31.000Z","msg":"做得家長，有架車，過橋費算d咩，你去睇下助養group既物資+食卷８仔，嚇死你"},{"pid":"1731122f25fb78ff5fd284fb1e7e5182a62faa0d","tid":1530704,"uid":224916,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c2d24f784a2592c39e0006bb9fd3d48e1468cd1","tid":1530704,"uid":8873,"like":0,"dislike":1,"score":-1,"quote":{"pid":"619c93ea58c738c19c0c6192ff8070975c326d50","tid":1530704,"uid":47222,"like":0,"dislike":0,"score":0,"quote":{"pid":"e67eb22f41de0b49712f86538c0f7b65c176067a","tid":1530704,"uid":186715,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-09-02T04:51:11.000Z","msg":"要諗下點改善徹退方法"},"citedBy":1,"replyTime":"2019-09-02T04:51:47.000Z","msg":"東涌商場內等家長"},"citedBy":3,"replyTime":"2019-09-02T05:05:44.000Z","msg":"咁樣家長就要比過橋費可能影響數量"},"citedBy":0,"replyTime":"2019-09-02T06:12:25.000Z","msg":"如果出得，就唔會理果Ｄ錢<br />\n<br />\n唔想出黎幫手既，唔洗錢都唔會渣車出"},{"pid":"409c6c339054ae60f09dc79937982b2031ab45ea","tid":1530704,"uid":247112,"like":0,"dislike":0,"score":0,"quote":{"pid":"ccf253a8a87115bda3fbb2c060d2ca805e77510e","tid":1530704,"uid":210612,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-09-02T05:55:51.000Z","msg":"麻煩大家準時好冇。。。"},"citedBy":0,"replyTime":"2019-09-02T06:12:48.000Z","msg":"係咪得我on99發夢1點夢遊到左<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ef0bbacf43cade1ca4e542ccbd3eb7076705aab7","tid":1530704,"uid":61235,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-02T06:14:40.000Z","msg":"講真成效唔叫好大<br />\n但對比街戰,我覺得琴日個成效一定多過街戰<br />\n整體付出既體力分分鍾會比街戰多<br />\n不過呢D和理非都可以出一分力<br />\n同時武力程度真係低過市區好多<br />\n<br />\n機管局雖然唔理旅客,死都唔取消航班<br />\n但你話冇影響就假<br />\n沿途見有旅客真係由東涌推住個行李行去機場<br />\n總數字真係唔知有幾多呢D情況<br />\n經濟上可能減少得唔多,但信譽冇左就係冇左<br />\n<br />\n貨運呢,你都塞左幾個鍾先出到黎<br />\n何況D貨,骨牌效應下我深信點都有影響,不過未必大<br />\n等行內人士分享下今次個影響<br />\n<br />\n今次睇得出班狗有備而戰,佢地既戰術對機場係有效<br />\n先唔比你聚人數,一開始已經驅散,截交通等,之後再各區大圍捕<br />\n但同時都睇得出,佢地真係唔敢係機場使用過份武力<br />\n<br />\n之後既渣春袋行動就真係未必樂觀<br />\n好多人會因為交通問題未必會再出黎<br />\n呢方面既文宣要做多D,等大眾明白春袋既重要性<br />\n春袋真係好緊要,起碼好過街頭戰,安全好多"},{"pid":"abe6b1735eea63026afe5c68321be3ac6540fb15","tid":1530704,"uid":315793,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T06:15:39.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: x-large;\">Be water 勿gear</span></span><br />\n著咩3都得<br />\n口罩可有可無<br />\n行完即散或者達成目的就走<br />\n唔好留。今次有幸走得甩，下次就唔知<br />\n啲🐶一定提升對策<br />\n而且場地不利我地。只會比克警玩同圍捕<br />\n<br />\n如果要散嘅話，最好仲係各區嘅手足行下街 分散警力<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">不過最主要嘅係人數！如果香港再再再團結啲！損失風險冇咁大</span></span>"},{"pid":"5047f79d3b1588917d933c47d0847bdf28a118f1","tid":1530704,"uid":47222,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T06:20:05.000Z","msg":"機場907戰術：全部唔中途落車唔黑衫拖gip/接機 有車出車<br />\n到左就入返東涌再流水式入機場 或者機鐵唔落車<br />\n如果有必要情況下set roadblock既set完即走做返市民<br />\n冇車走就商場shopping食飯唔洗心虛 等家長接<br />\n琴日證實青馬塞車會塞班警犬增援 不必過份擔心"},{"pid":"650a4377ff1ead6f485959744fdf04e961cd77cd","tid":1530704,"uid":257109,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-09-02T06:21:37.000Z","msg":"直接佔領機場 學太陽花咁 你夠1百幾十萬人 佢地乜都做唔到"},{"pid":"dca4d4c402c3cde3f3bb3d50e484a07ca1d199a0","tid":1530704,"uid":8873,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T06:27:22.000Z","msg":"其實尋日係有班機取消㗎好似有個post講話十幾班我自己上幾管局個網好似係14班大部份係去中國同埋台灣嘅短程路線<br />\n<br />\n不過政府同埋基本覺梗係唔講出嚟啦費事以為我哋有成功咁咪再做<br />\n<br />\n如果機場禁制令同埋太過長路程要避免嘅話可唔可以諗將個戰線擺返係青馬大橋因為只要航空人員入唔到去就可以阻止飛行<br />\n<br />\n約喺青馬大橋收費亭前面等得唔得呢"},{"pid":"a6da7125647706418d1b87be757e632948a6e625","tid":1530704,"uid":8873,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T06:34:05.000Z","msg":"定一係全部人做篋神旅行裝束大個喼扮嘢想去排隊然後話唔記得帶Passport同飛機票<br />\n依家啲人排隊就係要逐個檢查有冇機票先至入得去機場我哋就喺車個樽頸位排隊然後話冇帶"},{"pid":"ba92ae0161b08a02db60a68080524f361f7a74c5","tid":1530704,"uid":37135,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T06:36:41.000Z","msg":"推"},{"pid":"0f1d721a9d716124e6c43e7c20c57bee0607466a","tid":1530704,"uid":210612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T06:38:15.000Z","msg":"勿Blackbloc"},{"pid":"ed7a53c1c6fa138f8de503f8897a22c1d0ea0025","tid":1530704,"uid":210612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T07:40:27.000Z","msg":"push"},{"pid":"e74b2b484515024d5bc4d808d39c625f05b0492f","tid":1530704,"uid":210612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T07:41:47.000Z","msg":"開咗學d post真係慢咗"},{"pid":"ac90288513644d37a4a7dc9e462b8f061bb22323","tid":1530704,"uid":158480,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T08:08:52.000Z","msg":"721 811"},{"pid":"ad53a0d0cc53d01dfad38f2cc2f01dcbeb514183","tid":1530704,"uid":158480,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T09:45:05.000Z","msg":"721 811"},{"pid":"1fda1a1359782504ea69922f59f2d39d6e4dc608","tid":1530704,"uid":210612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T10:25:01.000Z","msg":"推"},{"pid":"ce3587cfe32af0102558b1ba00250cfd7efb7320","tid":1530704,"uid":158480,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T17:43:58.000Z","msg":"721 831"},{"pid":"fe3cd2f822fd4d6eab99989f2d75a09d0fc6a7a7","tid":1530704,"uid":169207,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T18:01:16.000Z","msg":"<img src=\"https://na.cx/i/oaBbTAC.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FoaBbTAC.png&h=2beb762c&s={SIZE}\" />"},{"pid":"47df7576b41c35e35b52b143ddb2cd27a1efd13e","tid":1530704,"uid":90883,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T18:02:44.000Z","msg":"推 機場"},{"pid":"798c0048095506b1599c2043286512