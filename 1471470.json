:09:01.000Z","msg":"自推"},{"pid":"5f3f12bbff040c41a3b9c5af908c4f36ac6d5ee0","tid":1471470,"uid":276665,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T10:09:26.000Z","msg":"推到有人入黎"},{"pid":"2eff6126012ff1de5f39de9462e1d3f95d17b507","tid":1471470,"uid":276665,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T10:16:23.000Z","msg":"推"},{"pid":"d9d490a07102258e56417c459c80a13bd760995a","tid":1471470,"uid":276665,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T10:17:59.000Z","msg":"推"},{"pid":"c41a58454a504fd16c1a2417e26db0ed37f80c55","tid":1471470,"uid":113924,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-14T10:25:04.000Z","msg":"諗到個文宣，唔知有無人提過<br />\n個支那記者喊出一句<br />\n我支持警察，你可以打我了<br />\n最後只係輕傷出院<br />\n<br />\n如果係支那，你件tee 上面寫<br />\n我支持黑衣，你可以槍斃我吧<br />\n我諗真係遞老毛都救唔到你"},{"pid":"673522cd15dc405707e27fa941f7859a8a02195f","tid":1471470,"uid":276665,"like":0,"dislike":0,"score":0,"quote":{"pid":"c41a58454a504fd16c1a2417e26db0ed37f80c55","tid":1471470,"uid":113924,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-14T10:25:04.000Z","msg":"諗到個文宣，唔知有無人提過<br />\n個支那記者喊出一句<br />\n我支持警察，你可以打我了<br />\n最後只係輕傷出院<br />\n<br />\n如果係支那，你件tee 上面寫<br />\n我支持黑衣，你可以槍斃我吧<br />\n我諗真係遞老毛都救唔到你"},"citedBy":0,"replyTime":"2019-08-16T01:59:13.000Z","msg":"好似已經有人寫左d好似咁嘅野，就係用就警察暴力同黑社會暴力做對比"}]}