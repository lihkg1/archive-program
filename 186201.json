.000Z","msg":"再講就&quot;省&quot;你"},{"pid":"244336040531141f8eb2aff3f0d8725433641287","tid":186201,"uid":17008,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-12T11:30:10.000Z","msg":"食完野就yang"},{"pid":"f21797ca4fd864434f62f727fb36473e3879be69","tid":186201,"uid":79874,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-12T11:37:22.000Z","msg":"<blockquote>sir滑梯有無？</blockquote><br />\n<br />\n即係削滑梯<br />\n<br />\n其實全部都有得寫, 但屬唐宋漢語, 到宜家有變咗讀音, 字音源頭已難追尋<br />\n<br />\n就算攞番本隸韻, 都好難界定, 但如你睇唐宋文人筆記, 可以搵到啲真身<br />\n<br />\n漢字裡, 唔會有音冇形"},{"pid":"ff7d8963cd542fd1b1a463dd44e886828ee174e7","tid":186201,"uid":17008,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-16T16:30:19.000Z","msg":"夠pot"},{"pid":"5004e539015b405a8384d411ebe24886fb56b64a","tid":186201,"uid":17008,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-13T12:47:44.000Z","msg":"Liu lung<br />\n𠮩𠹌"}]}