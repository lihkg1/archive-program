g src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"c45379f681cf91add6ac81f9fae1938beb7181ea","tid":154552,"uid":55913,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-13T16:41:39.000Z","msg":"嘩 幾有用"},{"pid":"18a1188eda544ce71bf7a817c14d80fcbb6dc571","tid":154552,"uid":42435,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-13T16:54:11.000Z","msg":"支那義和團"},{"pid":"adec3b567679de391db289d289d5365afa627158","tid":154552,"uid":35430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-13T16:54:28.000Z","msg":"<blockquote>愛國我有錯？<br />\n<br />\n<a href=\"http://m.weibo.cn/status/EztCMv3Xh?luicode=20000061&amp;lfid=4018565004496715&amp;featurecode=20000180\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fm.weibo.cn%2Fstatus%2FEztCMv3Xh%3Fluicode%3D20000061%26lfid%3D4018565004496715%26featurecode%3D20000180&d=qjQisgq6tteJ1Wb%2FuF84HzQ9OVC7k%2FvddpU5ARN7O10%3D&h=28dbd477\" target=\"_blank\">http://m.weibo.cn/status/EztCMv3Xh?luicode=20000061&amp;lfid=4018565004496715&amp;featurecode=20000180</a></blockquote><br />\n愛國不嬲都係流氓避難所"},{"pid":"abe888c5b16d22cceffc9173a03154599da6261f","tid":154552,"uid":91432,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-14T09:17:56.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"baa379bbe57c3bd7d01ab4b672fd2e846fc5e3f1","tid":154552,"uid":230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-14T09:21:37.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/03/14/172136_d831f64f8fe35e2bf48cfab86ecb9feb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F03%2F14%2F172136_d831f64f8fe35e2bf48cfab86ecb9feb.jpg&h=8bb69aec&s={SIZE}\" />"}]}