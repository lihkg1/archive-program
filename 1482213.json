x%2Fi%2FSMXXdwc.jpg&h=1ed51696&s={SIZE}\" />"},{"pid":"87af5b9c967d22afc3eebf8ab9a2dc3d84ba5aa9","tid":1482213,"uid":43061,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T04:27:09.000Z","msg":"宮脇咲良<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4b291bb9bd397ff6caedb7121e898919f2490cf7","tid":1482213,"uid":76632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T04:29:52.000Z","msg":"今日陽光猛烈，要記得防曬消暑<img src=\"/assets/faces/pig/bye.gif\" class=\"hkgmoji\" />"},{"pid":"52976f413dc3ed5e7911649ac89e449d2706cfa2","tid":1482213,"uid":4574,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-18T04:31:09.000Z","msg":"牙窩撐港？"},{"pid":"a225ebe974c0c1ecd09433aa519e2a3b4b394b67","tid":1482213,"uid":4574,"like":0,"dislike":0,"score":0,"quote":{"pid":"52976f413dc3ed5e7911649ac89e449d2706cfa2","tid":1482213,"uid":4574,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-18T04:31:09.000Z","msg":"牙窩撐港？"},"citedBy":0,"replyTime":"2019-08-18T04:31:21.000Z","msg":"牙宮"},{"pid":"eeb6e5f5f888a858c76cddaf2f81b0694ae18f89","tid":1482213,"uid":229026,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T04:31:56.000Z","msg":"我愛小櫻花<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"8ae7d5c4571c47125c38829ff8593457922afb3b","tid":1482213,"uid":139409,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-18T04:39:14.000Z","msg":"幫推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n【英重量級議員 促給港人完整英國國籍】<br />\n<br />\n<img src=\"https://na.cx/i/bnf9O7G.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fbnf9O7G.jpg&h=5ee9af01&s={SIZE}\" /><br />\n<br />\n// 英國下議院外交委員會主席圖根達特（Tom Tugendhat）呼籲，政府應給予香港人完整的英國國籍，作為與北京對峙的一種保障。（法新社）//<br />\n<br />\n👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻👇🏻<br />\n<br />\n1分鐘時間幫幫手簽<br />\n夠10萬個就有機會喺英國國會討論<br />\n<br />\n喺香港住嘅tick返Hong Kong<br />\nPostal code 就打0852<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=MqHS405OUPR0rJ167hdmPJR%2B4kUINcy65scadR%2F1ewI%3D&h=1f2a668b\" target=\"_blank\">https://petition.parliament.uk/petitions/244402</a><br />\n<br />\nQ&amp;A<br />\nQ: 簽咗咁多聯署 / 英國佬唔會幫我地 / 英國佬講咗咁耐都冇做過嘢簽嚟都冇用<br />\n<br />\nA: 唔洗1分鐘搞掂又冇成本嘅嘢點解唔做咗先 <br />\n<br />\n六合彩咁難中你又買<br />\n夠10萬個就有機會喺英國國會討論<br />\n<br />\n今次係有下議會議員帶頭講要俾full citizenship BNO holder<br />\n10萬人都簽唔到叫人地點幫你啊<br />\n我地要送子彈啊<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n🔥⭐️Q: 好多97後都冇BNO 我地唔可以扔低佢地⭐️🔥<br />\n<br />\nA: 有BC又有幾多人會即刻走 <br />\n反而有咗後路可以更盡情咁去抗爭<br />\n同埋到時大量英國國民喺香港 可以增加英國嘅談判籌碼<br />\n真係去到最壞情況都可以諗方法帶埋d細路走<br />\n<br />\nQ: 佢要tick Only British citizens or UK residents have the right to sign<br />\n我 得 / 冇BNO簽唔簽得？<br />\n<br />\nA: 唔洗verify citizenship 自己諗簽唔簽<br />\n只要提供 email address + 英文名 ＋選Location + Postal code<br />\n<br />\nQ: Postal code 打咩好？<br />\n<br />\nA: 記住喺香港住嘅tick返Hong Kong<br />\nPostal code 成功例子參考<br />\n852 <br />\n0852 <br />\n00000 <br />\n000000<br />\n<br />\n再貼多次條Link:<br />\n<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=MqHS405OUPR0rJ167hdmPJR%2B4kUINcy65scadR%2F1ewI%3D&h=1f2a668b\" target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"9b642b2823601d904badf479a6f181f1077dda01","tid":1482213,"uid":87730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T04:41:18.000Z","msg":"由hkt就推到呢家<img src=\"/assets