kgmoji\" />"},{"pid":"ee7f72cf2a949a1e5059e7bf4765a37a32fee311","tid":1505891,"uid":28628,"like":11,"dislike":0,"score":11,"quote":{"pid":"48212b18015e531ee4104d4dff842a739639dcf0","tid":1505891,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-25T16:01:31.000Z","msg":"就算小弟用滅火隊級數嘅gear<br />\n但唔多唔少都有啲入到<br />\n次次發完夢都會頭痛，同埋嘔<br />\n最長試過維持兩三日<br />\n身邊有幾個手足會肚痾同無胃口<br />\n雖然呢啲傷勢無得同手足俾人斬手斬腳相題並論，<br />\n但都傷咗啲元氣<br />\n唔知呢兩個半月來，咁多位手足有冇出現呢啲情況，同埋有冇咩方法應對？<br />\n<br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />有，黑警用生化武器正仆街<br />\n<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />無，樓主正on9，體弱多病"},"citedBy":2,"replyTime":"2019-08-25T16:13:15.000Z","msg":"Tear gas <br />\n真正有效既成份 *CS*<br />\n唔係氣體嚟 <br />\n係固體 300幾度先會melt<br />\n佢要靠粒彈藥爆開<br />\n嚟disperse 到d 粉 去做*aerosol*<br />\n所以有時會煙味到已經開始喊<br />\n粒彈一爆開 d CS powder <br />\n大量cs會痴哂你件衫<br />\n就算d煙走左 但d粉仍然係痴實件衫<br />\n經皮膚吸收<br />\n所以你長著住見滅火衫實奶野<br />\n用梳打水洗走<br />\n<br />\n利申： Chem PhD 學生"},{"pid":"69b73e1b9a74c1cdbf4e44f0a67adca29229bd20","tid":1505891,"uid":248118,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-25T16:14:58.000Z","msg":"<img src=\"https://na.cx/i/Sh9zweC.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSh9zweC.jpg&h=6a5aca4b&s={SIZE}\" />"},{"pid":"995d827cc1d051647f63f1c4d7a4c6174fcdd3cb","tid":1505891,"uid":285481,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T16:20:50.000Z","msg":"<img src=\"https://na.cx/i/XkCJpAP.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXkCJpAP.jpg&h=b14a41ff&s={SIZE}\" />"},{"pid":"1957275ed495e938d9e679b90a7d2ce1394af7eb","tid":1505891,"uid":174174,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-25T16:20:55.000Z","msg":"有冇女性出現呢個情況？<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/UqZjHn8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUqZjHn8.jpg&h=baa79d52&s={SIZE}\" />"},{"pid":"fa2431f4f40db3a7c148243628fb38b510aeaab0","tid":1505891,"uid":174174,"like":0,"dislike":0,"score":0,"quote":{"pid":"ee7f72cf2a949a1e5059e7bf4765a37a32fee311","tid":1505891,"uid":28628,"like":11,"dislike":0,"score":11,"quote":{"pid":"48212b18015e531ee4104d4dff842a739639dcf0","tid":1505891,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-25T16:01:31.000Z","msg":"就算小弟用滅火隊級數嘅gear<br />\n但唔多唔少都有啲入到<br />\n次次發完夢都會頭痛，同埋嘔<br />\n最長試過維持兩三日<br />\n身邊有幾個手足會肚痾同無胃口<br />\n雖然呢啲傷勢無得同手足俾人斬手斬腳相題並論，<br />\n但都傷咗啲元氣<br />\n唔知呢兩個半月來，咁多位手足有冇出現呢啲情況，同埋有冇咩方法應對？<br />\n<br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />有，黑警用生化武器正仆街<br />\n<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />無，樓主正on9，體弱多病"},"citedBy":2,"replyTime":"2019-08-25T16:13:15.000Z","msg":"Tear gas <br />\n真正有效既成份 *CS*<br />\n唔係氣體嚟 <br />\n係固體 300幾度先會melt<br />\n佢要靠粒彈藥爆開<br />\n嚟disperse 到d 粉 去做*aerosol*<br />\n所以有時會煙味到已經開始喊<br />\n粒彈一爆開 d CS powder <br />\n大量cs會痴哂你件衫<br />\n就算d煙走左 但d粉仍然係痴實件衫<br />\n經皮膚吸收<br />\n所以你長著住見滅火衫實奶野<br />\n用梳打水洗走<br />\n<br />\n利申： Chem PhD 學生"},"citedBy":0,"replyTime":"2019-08-25T16:33:04.000Z","msg":"多謝巴打<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n下次唔敢發完夢之後<br />\n去索吓自己啲衫有冇tg味了"},{"pid":"2470cfc52287a8dbcee97b2dd92677794224bb91","tid":1505891,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T16:45:35.000Z","msg":"Pish"},{"pid":"f92fbdf81592fc8fb1bdc78b5e6d70bc4d29d955","tid":1505891,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T16:54:42.000Z","msg":"<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n<br />\n如果短期內經由皮膚吸收殘留喺現場嘅氰化氫，劑量足夠嘅話，會引致呼吸困難、頭暈、面紅、頭痛、噁心、嘔吐、脈搏加速、血壓下降、昏厥。累積到足夠致死量嘅話，會抽搐，然後四小時內死亡。<br />\n<br />\n［科普］成日講山埃，其實你哋究竟知唔知山埃係乜嘢<br />\n<a href=\"https://lih.kg/1505760\" data-auto-link target=\"_blank\">https://lih.kg/1505760</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"16a19ec4bac12f80eb173aed6725cbf0e8313028","tid":1505891,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:16:56.000Z","msg":"Pish"},{"pid":"96b9f7a5636e1018502844f1f84d20857aad0f60","tid":1505891,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:42:48.000Z","msg":"嘔到仆街<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n用水濕一濕個頭好似無咁頭暈"},{"pid":"5c4803f1d60089bfdd88f8bc24918a3fdd6b3ccc","tid":1505891,"uid":50904,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-26T02:33:36.000Z","msg":"<span style=\"color: red;\"><strong>[濕L晒，你要驚]防毒濾棉濕哂水會打柴，請立即更換</strong></span><br />\n<a href=\"https://lihkg.com/thread/1506772\" target=\"_blank\">https://lihkg.com/thread/1506772</a><br />\n整合左啲濕水對濾棉影響嘅資料，大家幫手入去推比更多手足睇<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"color: red;\">利申:唔係呢方面專家，只係問人+整合資料，需要人實測</span></strong><br />\n<br />\n琴日落左成日大雨，好多裝修師傅都被迫做左海底奇兵<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><br />\n雖然濾棉有一定「抗水」能力去過濾有毒蒸汽，但係「唉屌濕撚晒」之下都會打柴<br />\n<br />\n<strong><span style=\"color: red;\">為防TL;DR 先寫結論:<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /></span></strong><br />\n1. 外露濾棉如 2297/2097 + 單罐豬嘴3311K 等，如濕哂請即更換<br />\n2. 如501蓋 + 5N11 有外殼包下嘅，請打開檢查有無全濕<br />\n3. 內置濾棉嘅綜合濾罐 如60926/3系列，正路入水位唔多，但好睇實際有幾濕<br />\n4. 單純濾罐部份 如6006/3 系列，活性碳唔吸水，乾返應該唔大影響，有待實測<br />\n5. 雨天環境，重課可考慮502蓋 + 3M 7093 有殼防水式P100濾棉"},{"pid":"30a112f490c2215bc368d38f811fa398b6fc5585","tid":1505891,"uid":50904,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T02:46:40.000Z","msg":"回返正題，之以前明報有訪問左45位手足嘅TG徵狀<br />\n<a href=\"https://www.mpweekly.com/culture/%e5%8f%8d%e9%80%81%e4%b8%ad-%e5%82%ac%e6%b7%9a%e5%bd%88-612-117834\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.mpweekly.com%2Fculture%2F%25e5%258f%258d%25e9%2580%2581%25e4%25b8%25ad-%25e5%2582%25ac%25e6%25b7%259a%25e5%25bd%2588-612-117834&d=06o7JzqVhDqA6Aam%2BaIp8yNFMfcMnrnh95DLK%2BYL5kQ%3D&h=bfa68d19\" target=\"_blank\">https://www.mpweekly.com/culture/%e5%8f%8d%e9%80%81%e4%b8%ad-%e5%82%ac%e6%b7%9a%e5%bd%88-612-117834</a><br />\n<br />\n1.毒性係會累積<br />\n2.上面都有巴打講左，TG係毒粉+毒煙，所以長衫重要<br />\n3.一般認為腸胃問題係因為吞左啲含毒嘅口水，但化學資料庫亦都有寫到啲毒粉可能會皮膚被吸收<br />\n<a href=\"https://www.facebook.com/Dr.Incognito.HK/photos/a.692361591212579/713530835762321/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FDr.Incognito.HK%2Fphotos%2Fa.692361591212579%2F713530835762321%2F&d=06o7JzqVhDqA6Aam%2BaIp8yNFMfcMnrnh95DLK%2BYL5kQ%3D&h=c4880bf8\" target=\"_blank\">https://www.facebook.com/Dr.Incognito.HK/photos/a.692361591212579/713530835762321/</a><br />\n4.TG隻毒係無解毒劑，但多飲水可以舒緩一下<br />\n<br />\n我之前嘅整嘅圖，資料出自唔同研究報告，應該準確，可以參考<br />\n<img src=\"https://na.cx/i/xJDTQgq.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxJDTQgq.png&h=83eb5404&s={SIZE}\" />"},{"pid":"d4f80fd5c94bab04c4d183c34aca42e41c6ff956","tid":1505891,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T13:02:53.000Z","msg":"推"},{"pid":"24e5555595846f8445e0d241133b3abfb13dec6c","tid":1505891,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T13:28:29.000Z","msg":"推"},{"pid":"9d1b2d487911e24504d1f85b57501731ae8d156c","tid":1505891,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T14:03:47.000Z","msg":"推"}]}