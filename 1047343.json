gmoji\" />"},{"pid":"f55dc064858cb34bd6145305d49ae529a8aa9db5","tid":1047343,"uid":1330,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-03-05T07:06:18.000Z","msg":"笑匠係最孤獨<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"6f4733dfe875e6efef82ff44e3bd2a4da14c65c9","tid":1047343,"uid":91742,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-05T13:17:45.000Z","msg":"係時候要學下割捨別人嘅議題 唔好好似我咁屈到抑鬱先知"},{"pid":"af092b600b375b03962efa833e46564aaaa2e06f","tid":1047343,"uid":57185,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-05T15:32:49.000Z","msg":"摺一摺先"},{"pid":"ca17e8a6e0aabfd0c64ad176c0d12e7be0e5afe4","tid":1047343,"uid":19745,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-05T15:49:32.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"a4f46dabec2bbbf0586420586f5807d6ec601b69","tid":1047343,"uid":128364,"like":0,"dislike":0,"score":0,"quote":{"pid":"ca17e8a6e0aabfd0c64ad176c0d12e7be0e5afe4","tid":1047343,"uid":19745,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-05T15:49:32.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-05T16:00:25.000Z","msg":"咁你而家點，同埋你點舒緩自己呢種情緒"},{"pid":"95041237a3ebbcc63727f8578cdcbd4973714803","tid":1047343,"uid":19745,"like":1,"dislike":0,"score":1,"quote":{"pid":"a4f46dabec2bbbf0586420586f5807d6ec601b69","tid":1047343,"uid":128364,"like":0,"dislike":0,"score":0,"quote":{"pid":"ca17e8a6e0aabfd0c64ad176c0d12e7be0e5afe4","tid":1047343,"uid":19745,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-05T15:49:32.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-05T16:00:25.000Z","msg":"咁你而家點，同埋你點舒緩自己呢種情緒"},"citedBy":0,"replyTime":"2019-03-05T16:22:03.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"}]}