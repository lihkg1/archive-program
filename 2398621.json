%81%B2%E9%80%80%E4%BC%91-%E7%9B%BC%E7%BA%8C%E7%95%99%E6%B8%AF%E6%95%99%E6%9B%B8%E6%8D%8D%E8%A8%80%E8%AB%96%E8%87%AA%E7%94%B1/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E5%25B1%25A2%25E5%258F%2583%25E8%2588%2587%25E5%258F%258D%25E9%2580%2581%25E4%25B8%25AD%25E9%2581%258A%25E8%25A1%258C-%25E4%25B8%25AD%25E5%25A4%25A7%25E6%2595%2599%25E6%258E%2588%25E9%25BA%25A5%25E9%25AB%2598%25E7%2599%25BB%25E5%25BB%25B6%25E9%2581%25B2%25E9%2580%2580%25E4%25BC%2591-%25E7%259B%25BC%25E7%25BA%258C%25E7%2595%2599%25E6%25B8%25AF%25E6%2595%2599%25E6%259B%25B8%25E6%258D%258D%25E8%25A8%2580%25E8%25AB%2596%25E8%2587%25AA%25E7%2594%25B1%2F&d=NdDBecmRZzhky7sLgKmJOZLurRSHZiEGX9rhKonVocs%3D&h=7222fb91\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E5%25B1%25A2%25E5%258F%2583%25E8%2588%2587%25E5%258F%258D%25E9%2580%2581%25E4%25B8%25AD%25E9%2581%258A%25E8%25A1%258C-%25E4%25B8%25AD%25E5%25A4%25A7%25E6%2595%2599%25E6%258E%2588%25E9%25BA%25A5%25E9%25AB%2598%25E7%2599%25BB%25E5%25BB%25B6%25E9%2581%25B2%25E9%2580%2580%25E4%25BC%2591-%25E7%259B%25BC%25E7%25BA%258C%25E7%2595%2599%25E6%25B8%25AF%25E6%2595%2599%25E6%259B%25B8%25E6%258D%258D%25E8%25A8%2580%25E8%25AB%2596%25E8%2587%25AA%25E7%2594%25B1%2F&h=06b97de8\" data-auto-link target=\"_blank\">https://www.thestandnews.com/politics/%E5%B1%A2%E5%8F%83%E8%88%87%E5%8F%8D%E9%80%81%E4%B8%AD%E9%81%8A%E8%A1%8C-%E4%B8%AD%E5%A4%A7%E6%95%99%E6%8E%88%E9%BA%A5%E9%AB%98%E7%99%BB%E5%BB%B6%E9%81%B2%E9%80%80%E4%BC%91-%E7%9B%BC%E7%BA%8C%E7%95%99%E6%B8%AF%E6%95%99%E6%9B%B8%E6%8D%8D%E8%A8%80%E8%AB%96%E8%87%AA%E7%94%B1/</a>"},"citedBy":0,"replyTime":"2021-02-07T13:37:58.000Z","msg":"好人一生平安。<br />\n個look好型。"},{"pid":"c121ba3c76c108793ee2356d59105024d4e96e2a","tid":2398621,"uid":51271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-07T13:39:13.000Z","msg":"真係要小心"},{"pid":"0f08859dbf10e9816ff99a40edbeb7397c5040a1","tid":2398621,"uid":161711,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-07T14:04:19.000Z","msg":"respect"},{"pid":"40bc8e483ead09e4b0fae70d632a39d53ff91003","tid":2398621,"uid":42767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-07T14:06:08.000Z","msg":"四大頹系嘅之首嘅final boss<img src=\"/assets/faces/dog/play.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/play.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/play.gif\" class=\"hkgmoji\" />"},{"pid":"10a2e194d8d0fb121bb61a5a199db1df4e5f430d","tid":2398621,"uid":42767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-07T14:06:40.000Z","msg":"<blockquote>四大頹系<del>嘅</del>之首嘅final boss<img src=\"/assets/faces/dog/play.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/play.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/play.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"b1ece4d462dfab72d4f81511ac155fe749a4cfc4","tid":2398621,"uid":53026,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-07T14:16:57.000Z","msg":"支那：操你嗎咱們中國無教授要請外國人？"},{"pid":"e736602553d1b436d7c641d7bd21fae605cee4b4","tid":2398621,"uid":267548,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-07T14:42:59.000Z","msg":"Respect<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"78afc67f018aceb1e784d19e6f9f615a7719df93","tid":2398621,"uid":51752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-07T17:25:12.000Z","msg":"<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"0b3e29b8279844781393ac53eccb7a99025d2007","tid":2398621,"uid":240362,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2021-02-07T12:54:04.000Z","msg":"<a href=\"https://www.facebook.com/gordon.mathews1/posts/3721621294543134\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fgordon.mathews1%2Fposts%2F3721621294543134&d=NdDBecmRZzhky7sLgKmJOZLurRSHZiEGX9rhKonVocs%3D&h=6ddd4459\" data-auto-link target=\"_blank\">https://www.facebook.com/gordon.mathews1/posts/3721621294543134</a><br />\n<br />\nI have just signed a contract to keep teaching anthropology in Hong Kong for another three years; I could retire in August, when I become emeritus, and move to Japan, my other home, but have decided to stay on. Partly I do this for my postgraduate students, seven or so of whom I need to see through to their theses' completion.  But even more, I do it because of the importance of teaching classes in accordance with critical thinking in Hong Kong--teaching classes like &quot;Culture and Globalization&quot; and &quot;Culture of Hong Kong&quot; and &quot;Meanings of Life&quot; in a way that provides multiple points of view, and encourages students to decide among these views on the basis of how they themselves read the evidence.  Hong Kong is definitely becoming more restrictive in what it allows in terms of freedom of expression, but I think it is extraordinarily important to defend this freedom by teaching in a conscientious and responsible way--that's what I seek to do.  None of us in Hong Kong know what the future may hold, with the reach of the National Security Law growing ever longer, its grip ever tighter. There also are red lines that, if they are crossed by the authorities, will make this place unlivable. But not yet--for now, my wife Yoko and I will stay and do what we can in our own tiny way to keep Hong Kong Hong Kong."}}