:8,"score":-7,"citedBy":0,"replyTime":"2019-06-07T15:53:06.000Z","msg":"此回覆已被刪除"},{"pid":"38dcedf878ac0e2c0a7e1a1abad180ca4f171485","tid":1190902,"uid":62891,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-07T16:04:39.000Z","msg":"淪落獌"},{"pid":"3f9c60193ef44d864708d59bd8f380a5357fa350","tid":1190902,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-07T16:10:57.000Z","msg":"仲有59個"},{"pid":"c34373bc581d80e9c9bea1a9f857f799c214f554","tid":1190902,"uid":13955,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-06-07T16:37:30.000Z","msg":"其實篇文幾好<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"d48c9a3850e49cfb2cec7858a2a38992ce634365","tid":1190902,"uid":33872,"like":22,"dislike":5,"score":17,"quote":{"pid":"39bae2d1eb14a322ba0fc8235034b135da90c8c8","tid":1190902,"uid":173952,"like":52,"dislike":9,"score":43,"citedBy":4,"replyTime":"2019-06-07T15:52:14.000Z","msg":"<img src=\"https://na.cx/i/CtLb7Y5.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCtLb7Y5.gif&h=dfdb1755&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-06-07T16:39:01.000Z","msg":"好尷尬"},{"pid":"927ed5bc1471d53bece0bc9f798e71b9ea477b2b","tid":1190902,"uid":75028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-07T16:43:31.000Z","msg":"吾皇<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"40d0a009f73df840531e5498aefc2e14e111af28","tid":1190902,"uid":67225,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-07T16:46:45.000Z","msg":"60人入面連傳曼聯三劍俠都無<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"830ffb09677daa5e730d5664eedf24cc2a0afcfa","tid":1190902,"uid":101971,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-07T16:54:16.000Z","msg":"去猁抱團啦，仲去獌？"},{"pid":"7267167d058dea9969366ea90eb1781b4c44d2e0","tid":1190902,"uid":158145,"like":1,"dislike":1,"score":0,"quote":{"pid":"a7d114e19024a3d90ec7b423043057d213d431fa","tid":1190902,"uid":173952,"like":141,"dislike":1,"score":140,"quote":{"pid":"30be867ae406199fd4206191039d73d9d4c4d923","tid":1190902,"uid":31314,"like":14,"dislike":3,"score":11,"citedBy":1,"replyTime":"2019-06-07T15:22:52.000Z","msg":"1500萬有幾重磅呀樓主？"},"citedBy":4,"replyTime":"2019-06-07T15:25:33.000Z","msg":"阿仙奴今夏預算一半"},"citedBy":0,"replyTime":"2019-06-07T16:55:19.000Z","msg":"連登數學家<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"61f097078ffdeb9637b0d1b29290f3ad9da7e251","tid":1190902,"uid":6152,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-06-07T16:56:37.000Z","msg":"仲留意個曼聯球迷本身 真係辛苦"},{"pid":"5bf343064b72c9af2b5d9a757b63e67d4a3f2233","tid":1190902,"uid":4661,"like":8,"dislike":0,"score":8,"quote":{"pid":"830ffb09677daa5e730d5664eedf24cc2a0afcfa","tid":1190902,"uid":101971,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-07T16:54:16.000Z","msg":"去猁抱團啦，仲去獌？"},"citedBy":0,"replyTime":"2019-06-07T16:57:13.000Z","msg":"<img src=\"https://static.businessinsider.com/image/4e9d71eaeab8ea9a2c000030-400/image.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.businessinsider.com%2Fimage%2F4e9d71eaeab8ea9a2c000030-400%2Fimage.jpg&h=2b8e2392&s={SIZE}\" />"}]}