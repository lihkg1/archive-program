ces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"c6873f32e8541d17bdc04047d945903ed5371884","tid":324453,"uid":95520,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2017-07-16T18:16:25.000Z","msg":"<blockquote>白湯中伏機率80%<br />\n紅湯中伏機率20%</blockquote><br />\n其實白湯先難伏喎<br />\n紅湯好易煮得衰"},{"pid":"1bd9aad4cfdfcafb7e3691bf645347a22cf995b5","tid":324453,"uid":55789,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-16T19:32:27.000Z","msg":"以前上舊登睇過話紅湯會擺過夜<br />\n白湯唔會"},{"pid":"9565acd47cff2acf6841a52f358596c58b8cbc02","tid":324453,"uid":1152,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-16T19:33:54.000Z","msg":"紅湯啲菜中伏率高喎"},{"pid":"1fd5ffe849cc456837525d38ea72dffc00841578","tid":324453,"uid":27221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-16T19:35:06.000Z","msg":"夏天紅<br />\n冬天白"},{"pid":"5ad950a929b8c0e7bbf70d99ed7919058ccaf61d","tid":324453,"uid":30947,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-16T19:38:00.000Z","msg":"紅湯<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d7ca572a1f6afbdefc060f051a59b3a73d5fb161","tid":324453,"uid":88907,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-16T19:39:30.000Z","msg":"<blockquote>以前上舊登睇過話紅湯會擺過夜<br />\n白湯唔會</blockquote><br />\n<br />\n奶類格夜好易酸<br />\n<br />\n其實西湯都幾多元化嫁 一般餐廳既紅白湯大多數係垃圾 紅湯煮唔出啲雜菜味 白湯又奶溝粉好少真係落忌廉<br />\n<br />\n不過一分錢一分貨冇計啦"},{"pid":"4e3f0ec964a8d25f6382f193907e106a1992d1e7","tid":324453,"uid":51978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-16T19:45:04.000Z","msg":"中湯"},{"pid":"aa610c1a13d2735903daa5a5503fc9545c7d0002","tid":324453,"uid":52112,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-16T19:59:27.000Z","msg":"記得有人講過白湯吐痰都無人知"},{"pid":"62a0edcef2e2842a758181dec3efee4d290ea3f2","tid":324453,"uid":15796,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-07-16T20:02:00.000Z","msg":"貴餐廳白湯 平餐廳紅湯"},{"pid":"e7d4edb25daa2c15386e8df3cb07269db2d976a5","tid":324453,"uid":26084,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-16T20:25:41.000Z","msg":"有時D紅湯好似落咗醋咁"},{"pid":"3b6cdf57b3096658f93721b786c2af1b83c87cfd","tid":324453,"uid":19858,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-07-16T21:02:03.000Z","msg":"<blockquote><blockquote>白湯中伏機率80%<br />\n紅湯中伏機率20%</blockquote><br />\n其實白湯先難伏喎<br />\n紅湯好易煮得衰</blockquote><br />\n但我經常飲到啲白湯<br />\n係又稀又無奶油香甚至得2粒粟米<br />\npizza hut嘅忌廉雞湯曾經好高質<br />\n近2次去都跌哂watt<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n反而紅湯只要夠熱，有啲酸辣<br />\n已經可以呃到味覺<br />\n如果再加上有少少好淋嘅椰菜紅蘿蔔<br />\n甚至有2粒牛肉粒<br />\n你都咪話唔爽<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"}]}