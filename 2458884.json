aha.gif\" class=\"hkgmoji\" />"},{"pid":"e452f2cfc346dac9783b82e0d07775427f1c7ea9","tid":2458884,"uid":261873,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-24T03:25:13.000Z","msg":"毒撚性格<br />\n三歲定八十"},{"pid":"bbc272b574b68dde277bb55416c25e04dd41ca6f","tid":2458884,"uid":367538,"like":0,"dislike":0,"score":0,"quote":{"pid":"e452f2cfc346dac9783b82e0d07775427f1c7ea9","tid":2458884,"uid":261873,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-24T03:25:13.000Z","msg":"毒撚性格<br />\n三歲定八十"},"citedBy":0,"replyTime":"2021-03-24T03:29:47.000Z","msg":"<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"dcf07336e88a5fa9210aae144710180ba8e4cc32","tid":2458884,"uid":367539,"like":0,"dislike":0,"score":0,"quote":{"pid":"15a7f2a514557d66ed5b81af30832fffa439fd71","tid":2458884,"uid":228051,"like":0,"dislike":0,"score":0,"quote":{"pid":"715b0516a586e2e5b1f90c15aea5d6d126c0ffd5","tid":2458884,"uid":228051,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2021-03-24T03:17:15.000Z","msg":"我細個淨係記得幼稚園某d堂係坐係地下上, 老師就會坐係張椅高高在上咁望住我地<br />\n<br />\n記得有個老師好鐘意著較短既裙(未到好短但唔過膝), 我地同學坐地下會望到佢三角位<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n有次有同學舉手問老師係咪走光, 個陣我連走光係咩都唔知<br />\n<br />\n個次之後我就成日望d老師有冇走光, 結果係成日都見到<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><br />\n<br />\n就係因為個同學舉手問, 搞到我由細到大對短裙充滿幻想<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-24T03:19:17.000Z","msg":"sor呢個唔關蠢事<br />\n<br />\n蠢係細個知道唔講得粗口, 覺得好辛苦好想講粗口, 之後對住廁所講勁多粗口之後沖廁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />  覺得好爽"},"citedBy":0,"replyTime":"2021-03-24T03:32:52.000Z","msg":"好得意<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"}]}