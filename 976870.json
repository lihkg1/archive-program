/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b7534f4e4d8a5872c010b13e3c8a9d27fc3954cb","tid":976870,"uid":245399,"like":0,"dislike":0,"score":0,"quote":{"pid":"ed140ceaf4853692119d62fee418dbc9af9a83c5","tid":976870,"uid":144406,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-01-10T19:00:05.000Z","msg":"Math.pow(10,Math.pi());<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-04-25T22:43:31.000Z","msg":"<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><br />\nMath.pow(10,Math.PI);<br />\r\n或<br />\n10**Math.PI;"}]}