jq5h1C.png&h=cd7919bc&s={SIZE}\" />"},{"pid":"4e5ca46d6d737360a25b708ed4134fb675899461","tid":1452370,"uid":27133,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T01:59:13.000Z","msg":"用空殻手機太空卡再用vpn"},{"pid":"19eb2fabe99171cc66bce612b69f52754d445a6d","tid":1452370,"uid":245670,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-12T02:08:10.000Z","msg":"戇鳩有撚用<br />\n你講嘢唔啱聽佢會直接del"},{"pid":"3e4b2ac794ec7b627f1bbbc8ce9d89aa18819778","tid":1452370,"uid":167142,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T02:11:25.000Z","msg":"On9"},{"pid":"e58791a0022efffc2510a8b015be801e902e65ad","tid":1452370,"uid":53524,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-12T02:11:59.000Z","msg":"監控程式黎"},{"pid":"eac080f3834b553d8d5c969ea4064feac5f840d3","tid":1452370,"uid":27133,"like":0,"dislike":0,"score":0,"quote":{"pid":"19eb2fabe99171cc66bce612b69f52754d445a6d","tid":1452370,"uid":245670,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-12T02:08:10.000Z","msg":"戇鳩有撚用<br />\n你講嘢唔啱聽佢會直接del"},"citedBy":0,"replyTime":"2019-08-12T02:16:32.000Z","msg":"所以就要玩數量等佢刪唔切，我試過好多次，都冇刪我，所以有可能係人手，或者系統過濾唔夠全面<br />\n<br />\n例如有人質問如何安全拍攝，我地就可以留言大作文章，等佢思考<br />\n<img src=\"https://na.cx/i/2ek80mp.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F2ek80mp.png&h=d3a14296&s={SIZE}\" />"},{"pid":"8753c02d68c68c7db1f3f9cb0603d49ff77c36c1","tid":1452370,"uid":296350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T02:17:24.000Z","msg":"重新整理<br />\n記者可唔可以有共識！！<br />\n呢啲係我哋最關心嘅問題<br />\n<br />\n<strong>每日無論邊個問先，頭幾條都要係呢幾條！！<br />\n每一次問都數， 呢條問題係第幾次第幾日問，未有答案！ 幾時先會有答案？</strong><br />\n<br />\n<strong><span style=\"font-size: large;\"><span style=\"color: green;\">請準備好每條問題嘅影片及圖片</span></span></strong><br />\n<br />\n1. 721點解唔執法？點解只告非法集會？點解全部未落charge？<br />\n播圖播片<br />\n指揮官喺村公所同白衣人對話，當時佢哋手持武器， 點解唔執法？<br />\n播片<br />\n<br />\n2 有證據顯示警方用過期Tear Gas?用咗幾多?點解用?<br />\n請準備圖及片<br />\nfollow up questions<br />\n過期催淚彈 成分變質變山埃， 警方會否道歉及賠償？<br />\n<br />\n3. 警察係咪扮示威者，然後執法？ 點解用咁嘅策略 ？點證明佢哋冇掉磚？冇煽動？冇放火？會否Charge佢哋參與暴動?<br />\n準備圖及片<br />\n<br />\n4. 點解會係地鐵站 內放催淚彈同胡椒彈？目的係驅趕定拘捕？<br />\n準備片<br />\nFollow up questions<br />\n如果係驅趕，佢哋已經喺地鐵站走緊！ 點解仲要放？ 如果係拘捕，你應該衝入去拉人而唔係放催淚彈胡椒彈！可唔可以解釋下<br />\n<strong>預設答案：</strong>情況混亂，個別事件<br />\nfollow up questions<br />\n警察冇專業訓練處理混亂情況？<br />\n個別例子係合理解釋？殺人放火強姦都係個別例子！ 示威者都係混亂情況下先做出唔尋常，唔理智行為，警方接唔接受呢個解釋唔落charge？<br />\n<br />\n5. 有片影到警察放武器入示威者背囊，點解？係唔係插贓嫁禍？<br />\n<strong>預設答案&nbsp;：</strong>&nbsp;冇資料<br />\n預備嗰條片， 講埋時間地點<br />\n叫佢解釋！<br />\n<br />\n6. 太古零距離開槍， 做法是否恰當？咩原因同情況下要咁做？<br />\n準備片<br />\n<br />\n7. 北角警察無視白衣人攻擊黑衣人及記者， 荃灣白衣人 一離場，場警察就進場，又係一個巧合？<br />\n準備片<br />\n<br />\n一齊畀意見！！<br />\n葵芳地鐵站內放催淚彈<br />\n<a href=\"https://www.facebook.com/chishing87/videos/10156292523426674/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fchishing87%2Fvideos%2F10156292523426674%2F&d=hP6DzN64O1sWLJLr9GARkYPST22DtV%2BdF%2FIIxhOvvTQ%3D&h=73bfaa4f\" data-auto-link target=\"_blank\">https://www.facebook.com/chishing87/videos/10156292523426674/</a><br />\n<br />\n追打並推落扶手電梯<br />\n<a href=\"https://www.facebook.com/groups/hkincident/permalink/2196364073824126\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fgroups%2Fhkincident%2Fpermalink%2F2196364073824126&d=hP6DzN64O1sWLJLr9GARkYPST22DtV%2BdF%2FIIxhOvvTQ%3D&h=4e16f5f8\" data-auto-link target=\"_blank\">https://www.facebook.com/groups/hkincident/permalink/2196364073824126</a><br />\n<br />\n太古站開槍 1米內射示威者<br />\n<a href=\"https://www.facebook.com/1178706375559427/posts/2424996360930416\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F1178706375559427%2Fposts%2F2424996360930416&d=hP6DzN64O1sWLJLr9GARkYPST22DtV%2BdF%2FIIxhOvvTQ%3D&h=d3df9cab\" data-auto-link target=\"_blank\">https://www.facebook.com/1178706375559427/posts/2424996360930416</a><br />\n<br />\n竹支嫁禍<br />\n<a href=\"https://www.facebook.com/1178706375559427/posts/2424974427599276\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F1178706375559427%2Fposts%2F2424974427599276&d=hP6DzN64O1sWLJLr9GARkYPST22DtV%2BdF%2FIIxhOvvTQ%3D&h=9d35bd7a\" data-auto-link target=\"_blank\">https://www.facebook.com/1178706375559427/posts/2424974427599276</a><br />\n<br />\n唔回應是否扮示威者<br />\n<a href=\"https://www.facebook.com/groups/hkincident/permalink/2196515767142290\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fgroups%2Fhkincident%2Fpermalink%2F2196515767142290&d=hP6DzN64O1sWLJLr9GARkYPST22DtV%2BdF%2FIIxhOvvTQ%3D&h=0f8c6f59\" data-auto-link target=\"_blank\">https://www.facebook.com/groups/hkincident/permalink/2196515767142290</a><br />\n<br />\n<br />\n記者會共識<br />\n<a href=\"https://lih.kg/1449180\" data-auto-link target=\"_blank\">https://lih.kg/1449180</a><br />\n- 分享自 LIHKG 討論區"}]}