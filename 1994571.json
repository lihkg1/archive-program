lass=\"hkgmoji\" />"},{"pid":"9b3c09f33c7c0db26e8d14cb56fed9778046b4fd","tid":1994571,"uid":165336,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-30T00:31:03.000Z","msg":"正常有良知既人類見到咁既野仲會唸咁多野？<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}