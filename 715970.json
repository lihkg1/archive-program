assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n咪學足中國咁，塗咗人哋個名寫自己名當自己<br />\n<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"eec8b272b26bedb3046b0639e71b52a2da42f7ad","tid":715970,"uid":24730,"like":0,"dislike":0,"score":0,"quote":{"pid":"48ee309f001430e566f3e972a9f5e6fe8e99d314","tid":715970,"uid":184679,"like":1,"dislike":0,"score":1,"quote":{"pid":"1f8ec0c8e9584ca1895244ae124dbcfcf65e9f7c","tid":715970,"uid":191926,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-25T02:01:16.000Z","msg":"是爆就好<br />\n<br />\n如果支那樓爆  <br />\n香港樓市真係無可能唔爆<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-25T02:07:48.000Z","msg":"<img src=\"/assets/faces/fifa/goal.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-25T03:22:50.000Z","msg":"就係因為支那人驚支爆，先至將現金攞晒嚟香港買樓，支那樓爆香港樓價反而看高一線"},{"pid":"16dc4ea123e64270d48c316afb3b6486c6b51e70","tid":715970,"uid":184679,"like":0,"dislike":0,"score":0,"quote":{"pid":"eec8b272b26bedb3046b0639e71b52a2da42f7ad","tid":715970,"uid":24730,"like":0,"dislike":0,"score":0,"quote":{"pid":"48ee309f001430e566f3e972a9f5e6fe8e99d314","tid":715970,"uid":184679,"like":1,"dislike":0,"score":1,"quote":{"pid":"1f8ec0c8e9584ca1895244ae124dbcfcf65e9f7c","tid":715970,"uid":191926,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-25T02:01:16.000Z","msg":"是爆就好<br />\n<br />\n如果支那樓爆  <br />\n香港樓市真係無可能唔爆<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-25T02:07:48.000Z","msg":"<img src=\"/assets/faces/fifa/goal.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-25T03:22:50.000Z","msg":"就係因為支那人驚支爆，先至將現金攞晒嚟香港買樓，支那樓爆香港樓價反而看高一線"},"citedBy":0,"replyTime":"2018-06-25T04:28:42.000Z","msg":"尸老闆又FAT FAT<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ad0ab48b0539cb26301b3e9f244fe913347f49d1","tid":715970,"uid":19