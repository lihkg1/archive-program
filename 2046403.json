鈴成熟時裂開，露出柔軟的纖維。纖維白色至白中帶黃，長約2至4厘米，含纖維素約87-90%。"},{"pid":"c84bfe9458899a1d91b8c1edffa57a095f0021dd","tid":2046403,"uid":115847,"like":1,"dislike":0,"score":1,"quote":{"pid":"48d6478f9a344790d782f0329cb7c1b14f34d8e9","tid":2046403,"uid":1049,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2020-06-01T11:34:39.000Z","msg":"大麻種植園就差唔多<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-01T12:33:08.000Z","msg":"<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"}]}