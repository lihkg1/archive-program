g src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-25T12:42:26.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-25T13:22:47.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-25T14:10:26.000Z","msg":"許嘉淇<br />\n希望各位記得佢<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4610d4f9e85cb58a727e5d388b2a80a8df5c7d9f","tid":605152,"uid":39464,"like":0,"dislike":0,"score":0,"quote":{"pid":"f9bb8017fd50e8a791b9dec84b482a1e434e438f","tid":605152,"uid":5489,"like":4,"dislike":0,"score":4,"quote":{"pid":"a77fcd168ac815d3f071b5808e4e91b3e5396fa5","tid":605152,"uid":1524,"like":0,"dislike":0,"score":0,"quote":{"pid":"497d473e45fa65b9552fe111ad50d3bd92a61c1b","tid":605152,"uid":33864,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-25T12:42:26.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-25T13:22:47.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-25T14:10:26.000Z","msg":"許嘉淇<br />\n希望各位記得佢<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-26T01:55:59.000Z","msg":"<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0b4eefec145e55cc42c2d2c9f2a7014a59fb213f","tid":605152,"uid":37735,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-03-26T02:14:39.000Z","msg":"係海外搞港獨，民主 再入口香港係一條要行的路<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n單純係香港搞議會抗爭已經用途有限<br />\n(話dq就dq 連結束一黨專政都唔敢叫)<br />\n<br />\n陳雲講過陳浩天醒  <br />\n都係的 堅持坐係港獨車頭<br />\n<br />\n我諗起詹濟南 一開頭又係 唔惦(做工程呢行屌地產商 唔洗開工  但佢成功坐左係驗樓呢行的車頭  堆工友 撈得再好 單單人氣就輸鳩哂<br />\n<br />\n陳浩天原理一樣<br />\n如果美國有人覺得港獨都有資助價值 ......"},{"pid":"03fe0a6198fd62e2e9b233d7277f841345e1d489","tid":605152,"uid":45368,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-03-26T03:04:07.000Z","msg":"台灣獨立有可能，因為人地有獨立政府；<br />\n但香港要獨立除非以後唔做中國生意唔做轉口港都生存到，而且要有能力令香港政府倒台先有得傾。<br />\n<br />\n精神上支持獨立，但現實層面既問題唔解決就永遠都只會係句口號<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"38fe03265509a05629917f20222f78ced6094f67","tid":605152,"uid":2429,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-03-26T04:11:19.000Z","msg":"陳浩天說香港人較懷念的英國統治時代，因此該旗子就代表反對中國的統治<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"}]}