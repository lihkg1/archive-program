tps%3A%2F%2Fna.cx%2Fi%2FwLUARSi.jpg&h=77affe68&s={SIZE}\" /><br />\n<br />\n辛苦係值得</span></strong>"},{"pid":"b4879edf54eb91da033bf408e66e6d10537a8bdb","tid":1753793,"uid":222499,"like":0,"dislike":0,"score":0,"quote":{"pid":"0233f03bc38329e4c09574801a4d307e46e06cdd","tid":1753793,"uid":389,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-27T01:57:26.000Z","msg":"唔怪之得咁瘦"},"citedBy":0,"replyTime":"2019-11-27T02:09:21.000Z","msg":"蘋果日報提過佢有哮喘, 所以佢當日俾黑警壓落地嗰陣佢猛嗌抖唔到氣<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1eef5d794dfaa016450b6133c9d49ab78eadf56e","tid":1753793,"uid":290176,"like":1,"dislike":0,"score":1,"quote":{"pid":"ddaf63c6b9fe60280421907b6b0df773b2f15929","tid":1753793,"uid":290176,"like":1,"dislike":0,"score":1,"quote":{"pid":"efd417a50943e2334bc6c39b35b6800613a17f0d","tid":1753793,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-25T04:33:20.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/20191125/UEBFESXO4UG5DVZDCHWS3Y734A/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20191125%2FUEBFESXO4UG5DVZDCHWS3Y734A%2F&d=dTdn096UhK%2BcydR5vLM298v4r%2BPR%2BKiJG6VnsQYGapQ%3D&h=0916f6dc\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20191125%2FUEBFESXO4UG5DVZDCHWS3Y734A%2F&h=141bfa7a\" target=\"_blank\">https://hk.news.appledaily.com/local/20191125/UEBFESXO4UG5DVZDCHWS3Y734A/</a><br />\n<br />\n仇栩欣捱肚餓為接觸街坊<br />\n<br />\n<img src=\"https://static.appledaily.hk/images/apple-photos/apple/20191125/large/1574612168_2866.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fapple-photos%2Fapple%2F20191125%2Flarge%2F1574612168_2866.jpg&h=913adc45&s={SIZE}\" /><br />\n仇栩欣昨與競選團隊在炮台山油街爭取支持。<br />\n<br />\n<br />\n【北角城市花園】<br />\n<br />\n【本報訊】被喻為福建幫地盤的北角城市花園選區選情激烈，曾在地區擺設街站時遇襲的「北炮同盟」成員仇栩欣昨日為爭取時間接觸街坊，從早上從中午都未有進食，到下午更宣佈選情告急；對手之一、聲稱屬中間派的大學客座教授樊熙泰則對選情樂觀，指投票率高反映中間派選民多了投票，但當