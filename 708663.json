58:15.000Z","msg":"屌你老母樓主收下把垃圾口啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-19T14:19:51.000Z","msg":"扣佢口德分"},{"pid":"e8e3969402a519dc9437426613a9b20729894f86","tid":708663,"uid":167186,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-06-19T14:22:34.000Z","msg":"Child登"},{"pid":"70c4c6ae6ca27473cf0dbfc3f663708687d1858e","tid":708663,"uid":146275,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-06-19T14:24:58.000Z","msg":"樓主把世事看透，先講得出咁嘅說話苦中作樂，黑色幽默。先不談論樓主有無尊重死者，佢咁講得有兩個可能性: 一，可能樓主有相同經歷，係過來人先講得出咁嘅說話，繼承龐大遺產嘅佢確實係人生大贏家；二，佢無咁嘅經歷，但就連人性都捨棄埋先會講得出咁嘅說話。既然人性都捨棄埋，佢係值得大家敬佩嘅！為此我亦祝福佢早日成為人生大贏家<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"901d452d8809401e6255537b8fd562e48d68d5c0","tid":708663,"uid":106291,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-19T14:26:11.000Z","msg":"好撚多五毛<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n梁天琦坐緊呀 D五毛係到開廢POST分散連登仔注意力<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"2544a74a6442f40355c397432705ecde2affc49c","tid":708663,"uid":21141,"like":1,"dislike":3,"score":-2,"citedBy":0,"replyTime":"2018-06-19T14:26:38.000Z","msg":"其實我想講好耐<br />\n日日都有人死<br />\n間屋一死左人 就要出租或者轉售架啦<br />\n唔通一死過人就成棟折左佢咩<br />\n下下都話間屋死過人 係凶宅咁又點<br />\n咪又係有人俾錢入來住<br />\n尤其是香港呢啲地方<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 學咩人講凶唔凶宅阿？<br />\n你平小小已經有大把人淨住買啦<br />\n<br />\n利申：平過同區樓價即deal<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0b7b8e7717904d5509bc5be096bc03baa7e40ec2","tid":708663,"uid":93190,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-06-19T14:29:02.000Z","msg":"樓主積下口德"},{"pid":"a99e81cfcd09b7a02afed3cf26eaecda37845a18","tid":708663,"uid":47819,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-06-19T14:30:08.000Z","msg":"你呢d冚家剷把口臭少陣唔得嘅咩？"},{"pid":"da3d4691ccdca48809ad45580fc039860d87369d","tid":708663,"uid":133565,"like":1,"dislike":