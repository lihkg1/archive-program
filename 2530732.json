e":0,"citedBy":1,"replyTime":"2021-05-14T15:36:09.000Z","msg":"推<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-05-14T15:52:51.000Z","msg":"<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><br />\n多謝底線巴打G持"},"citedBy":0,"replyTime":"2021-05-14T15:55:43.000Z","msg":"見到你ig有新po就等緊連登版<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"907f0683c8a14b82c8f36d6ee1482179928c135a","tid":2530732,"uid":17335,"like":0,"dislike":0,"score":0,"quote":{"pid":"da0ee33fd9b8b5611fc1dda9cc51f197c2d31618","tid":2530732,"uid":227062,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-14T15:36:57.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-05-14T16:09:57.000Z","msg":"<img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" /><br />\n李清照已經算好，有學問有才名"},{"pid":"0eaa44826e88e5864fc23630ad13c78b458d8162","tid":2530732,"uid":158886,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-14T16:10:07.000Z","msg":"<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />支持"},{"pid":"3cf38f6c3cd102257ea4663b90c15fc27c400ec4","tid":2530732,"uid":101554,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-14T16:10:56.000Z","msg":"笑右"},{"pid":"33fb8d6016faae2d5755f9173893e38fbc022e83","tid":2530732,"uid":17335,"like":0,"dislike":0,"score":0,"quote":{"pid":"b83ebb547f7bbcdbfe98e0d132199aa01117094e","tid":2530732,"uid":59832,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-14T15:38:29.000Z","msg":"留名<img src=\"/assets/faces/mouse/pray.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-05-14T16:26:48.000Z","msg":"<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />又見到巴打<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"3517f28e8d25a578930514fd510d4e03678e9ca8","tid":2530732,"uid":17335,"like":0,"dislike":0,"score":0,"quote":{"pid":"7b064d19d568766b4cdc607bb337107ed3347207","tid":2530732,"uid":26878,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-14T15:39:41.000Z","msg":"李清照！<br />\n<br />\n幾時講埋其他<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-05-14T16:39:48.000Z","msg":"<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><br />\n成日講，日日講，天天講"},{"pid":"8512629cdc4b85e9580efec41f35eb471175d9b9","tid":2530732,"uid":394187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-14T17:17:26.000Z","msg":"<img src=\"/assets/faces/mouse/miracle.gif\" class=\"hkgmoji\" />"},{"pid":"4e180ce03bb1cdb8d26c783ef76121ad11d3f190","tid":2530732,"uid":21141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-05-14T17:56:16.000Z","msg":"易安居士<img src=\"/assets/faces/cow/sorry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/sorry.gif\" class=\"hkgmoji\" />"},{"pid":"f2ee8f57281ce726edf4d46bdad1e3f4767a4744","tid":2530732,"uid":17335,"like":0,"dislike":0,"score":0,"quote":{"pid":"0eaa44826e88e5864fc23630ad13c78b458d8162","tid":2530732,"uid":158886,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-14T16:10:07.000Z","msg":"<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />支持"},"citedBy":0,"replyTime":"2021-05-14T22:20:05.000Z","msg":"<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />多謝支持"}]}