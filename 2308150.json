9dbcf1d52e15e7b19882","tid":2308150,"uid":255476,"like":0,"dislike":0,"score":0,"quote":{"pid":"4c5b2bf59894ce4bc090bb07e92b574b9fa7e073","tid":2308150,"uid":188482,"like":1,"dislike":0,"score":1,"quote":{"pid":"f575135e0565476be006d333fad10e3dcf344e82","tid":2308150,"uid":75889,"like":0,"dislike":5,"score":-5,"quote":{"pid":"da9686010602d881b273f6cc5e6555c317f50e4e","tid":2308150,"uid":188482,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-12T13:17:44.000Z","msg":"周圍都缺貨"},"citedBy":1,"replyTime":"2020-12-12T14:34:08.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-13T05:57:53.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-13T08:49:18.000Z","msg":"大炮 +大對翼=青少年最愛<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\nBTW，由細到大去幫襯福利都覺得平(5算~6.5算)，其他鋪6.5算~7.5，又有得睇貓貓<br />\n<br />\n係衰在成日西你面<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n中學雞果時唔識野，拎1000蚊去福利問有冇最平果枝星星噴筆賣，比個店員黑面咁串我： 細路噴筆雙星好貴架，你有冇錢買？ (真人真事)<br />\n<br />\n早排去買半光澤top coat，個爆炸頭店員拎錯全消光top coat比我，仲比佢鬧返轉頭話世上冇半光澤top coat呢樣野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c56e58520ef239f9c2fcd5ad4860a217faee9612","tid":2308150,"uid":140335,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-12-13T09:00:56.000Z","msg":"奇趣天地呢?<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n因為住葵青區<br />\n細個成個葵廣都好多模型鋪<br />\n但現加就執q曬<br />\n<br />\n得番d大公司 千色 反斗城<br />\n奇趣天地都平過佢地<br />\n上次搵盒rg沙煞比同nu<br />\n奇趣係平過福利<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n(雖知福利都貴開<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />)"},{"pid":"ca996f8b8c26bda21256476fdb334862c0004e96","tid":2308150,"uid":18177,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-12-13T09:08:05.000Z","msg":"覆你真係串過馬撚，中間通道長期有隻人肉cctv，掂吓盒摸型就怒啤你<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><br />\n<br />\n試過問佢想搵隻hg天狼巴巴托C，仲問返我即係第幾型態，一啲常識都冇<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />，唔想答咪出聲囉<br />\n<br />\n收銀個老細仲串，買2盒MG叫佢俾個袋，即刻look大隻閪眼，大大聲話要收1蚊架喎，好似我俾唔起果一蚊咁，以後寧願買貴啲都唔再幫襯福利<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},{"pid":"3180aa2ef685a81bab222a6ac1df3e69915a9662","tid":2308150,"uid":188482,"like":0,"dislike":0,"score":0,"quote":{"pid":"c56e58520ef239f9c2fcd5ad4860a217faee9612","tid":2308150,"uid":140335,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-12-13T09:00:56.000Z","msg":"奇趣天地呢?<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n因為住葵青區<br />\n細個成個葵廣都好多模型鋪<br />\n但現加就執q曬<br />\n<br />\n得番d大公司 千色 反斗城<br />\n奇趣天地都平過佢地<br />\n上次搵盒rg沙煞比同nu<br />\n奇趣係平過福利<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n(雖知福利都貴開<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />)"},"citedBy":0,"replyTime":"2020-12-13T09:13:25.000Z","msg":"落葵芳 好似新開左模型倉"},{"pid":"76780eb299037f9baa88bb34b049fbc1fe4fefe1","tid":2308150,"uid":61589,"like":3,"dislike":1,"score":2,"quote":{"pid":"c56e58520ef239f9c2fcd5ad4860a217faee9612","tid":2308150,"uid":140335,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-12-13T09:00:56.000Z","msg":"奇趣天地呢?<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n因為住葵青區<br />\n細個成個葵廣都好多模型鋪<br />\n但現加就執q曬<br />\n<br />\n得番d大公司 千色 反斗城<br />\n奇趣天地都平過佢地<br />\n上次搵盒rg沙煞比同nu<br />\n奇趣係平過福利<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n(雖知福利都貴開<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />)"},"citedBy":1,"replyTime":"2020-12-13T12:03:10.000Z","msg":"<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"bda5a9915823843c864676bf6142648ed2ed1d9e","tid":2308150,"uid":147292,"like":0,"dislike":1,"score":-1,"quote":{"pid":"42bd5ab66fed5623f4cde8e4006340fc7bf9238c","tid":2308150,"uid":79589,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-12T17:06:52.000Z","