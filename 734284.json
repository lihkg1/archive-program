鳩"},{"pid":"3d669b107f8608883a57d618fb3a464ec33f1e09","tid":734284,"uid":160291,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-08T15:21:51.000Z","msg":"香港人可唔可以效法?<br />\n香港2.0?<br />\n<br />\n如果真係有呢一日就好啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"a83f69e5fdc1fae1275349b0b52c6765f0ced995","tid":734284,"uid":86383,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T05:38:24.000Z","msg":"啲圖係唔係ANNO<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"}]}