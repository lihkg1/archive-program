9.000Z","msg":"痴撚線<br />\n解除左外匯管制<br />\n即刻走資..."},{"pid":"7f321699158920e7715e4e4379202dd7900ed033","tid":782624,"uid":165773,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T05:23:03.000Z","msg":"講個爛鬼一籃子貨幣講左N年<br />\n其實係廢up<br />\n好L容易比人買起你"},{"pid":"2e6a757190ddf3ea7a115f963971804370608a14","tid":782624,"uid":39800,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T05:24:19.000Z","msg":"冇人叻得過我"},{"pid":"5045052ceb8d2ba5fa7a303f4271e942c2e3c51b","tid":782624,"uid":14422,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-17T05:25:45.000Z","msg":"以上海樓價總值黎睇, 的確超越左香港<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4d92d17a97ad441a00be18426d84a82146aff33f","tid":782624,"uid":14009,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T05:26:33.000Z","msg":"又 回帶<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"c3c3807bf79329c2ff78de297ae166170d3e44c6","tid":782624,"uid":77196,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-17T05:26:40.000Z","msg":"定期鞭屍系列 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"375ef684a50ffe3180466f72ef4fe9919500fd33","tid":782624,"uid":201512,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-08-17T05:41:11.000Z","msg":"張五<span style=\"color: red;\">毛</span>"},{"pid":"3f7b42905efbad2c2d09db81a33581d2ee325e38","tid":782624,"uid":41818,"like":0,"dislike":0,"score":0,"quote":{"pid":"5045052ceb8d2ba5fa7a303f4271e942c2e3c51b","tid":782624,"uid":14422,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-17T05:25:45.000Z","msg":"以上海樓價總值黎睇, 的確超越左香港<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-17T06:02:18.000Z","msg":"樓價<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"9023cf2f2bc8b35807b38938e871f132a04242a8","tid":782624,"uid":4964,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T06:05:5