{"tid":1425474,"cid":5,"subCid":0,"title":"路西法效應 請大家發夢時要清醒同冷静 唔係的話會令自己愈來愈危險","createTime":"2019-08-06T18:19:17.000Z","updateTime":"2019-08-06T18:56:21.000Z","uid":248105,"like":38,"dislike":15,"uniUserReply":17,"replies":[{"pid":"2c2c68d72e041cb703d26e7ac4f1ff7c64944855","tid":1425474,"uid":248105,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-06T18:19:17.000Z","msg":"第一次開正常Post别屌<br />\n唔出呢個Post真係訓唔著<br />\n路西法效應<br />\n<a href=\"https://youtu.be/2X5W8mM_Wek\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F2X5W8mM_Wek&d=%2FAyHQi%2FQiMXiPJLA4RPCZlEyhmTkDJ%2BTCVbHNRNdZc8%3D&h=298af342\" target=\"_blank\">https://youtu.be/2X5W8mM_Wek</a><br />\n我唔知有幾多人有聽過OR<br />\n有人睇過呢條片<br />\n去到依家希望多啲人去了解下呢個路西法效應<br />\n詳情就睇下條片<br />\n<br />\n咁開Post嘅目標的係唔想同路人變成效應裏面所講嘅&ldquo;魔鬼&ldquo;<br />\n依家班狗同班狗官係我眼中已經進化到&rdquo;魔鬼&ldquo;呢樣嘢<br />\n眼見好多Post都有提醒同路人控制自己嘅情緒<br />\n我覺得係做得好好 <br />\n首先要有禮貌去對市民 不論佢反對我哋又好<br />\n利申 (人係有情緒 比人屌到仆街 唔通真係On99比人屌咩 點都會講番兩咀 對方郁手就另計 要好好保護自己)<br />\n如果我哋冇好好控制自己嘅情緒<br />\n唔係的話只係同班狗冇分别<br />\n變成&ldquo;魔鬼&ldquo;<br />\n成為市民眼中嘅&ldquo;過街老鼠&ldquo;<br />\n<br />\n發夢夢見唔少手足都幾衝動 <br />\n但有唔少人都即刻勸手足冷静<br />\n同埋手足會聽同冷靜咗<br />\n呢樣係值得欣賞<br />\n<br />\n有人影相請禮貌啲 叫佢唔好影個時語氣係最重要<br />\n不合作運動比人屌 係手足預左<br />\n因為點都有班要番工嘅(港豬)<br />\n同埋辛苦比人屌到仆街嘅手足<br />\n加埋所有發夢人士<br />\n千其千其唔好變成&ldquo;魔鬼&ldquo;<br />\n<br />\n光復香港 時代革命"},{"pid":"fae095208096f18b485ab876f7ece53047a76aa7","tid":1425474,"uid":248105,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-06T18:20:16.000Z","msg":"自己推十次"},{"pid":"a5399dad419f87a5d918352f035e0a8ecb47ff9e","tid":1425474,"uid":248105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:20:37.000Z","msg":"自己推十次"},{"pid":"415c9ff49f7eeb6c3b037e7dddf522eb36c4fe70","tid":1425474,"uid":248105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:20:49.000Z","msg":"自己推十次"},{"pid":"f3d46660ed8cd9d77f64f1bcdd01fbcca6e79ed4","tid":1425474,"uid":248105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:20:59.000Z","msg":"自己推十次"},{"pid":"2a1494e6a2392909cc516692a6c8aa8977cb53b9","tid":1425474,"uid":248105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:21:14.000Z","msg":"自己推十次"},{"pid":"a4c95a5e0488da1519c1b243c72ff67ac5146dc5","tid":1425474,"uid":248105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:21:36.000Z","msg":"自己推十次"},{"pid":"d2581adf716974822a75f04ece7fd9dc3ffb1204","tid":1425474,"uid":248105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:22:01.000Z","msg":"自己推十次"},{"pid":"f4b59da72232eb791c74f88ffc61abf91eb04c37","tid":1425474,"uid":248105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:22:29.000Z","msg":"自推十次"},{"pid":"81931c5742cc5a70e0462f7daedf89749aaadb3b","tid":1425474,"uid":248105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:22:39.000Z","msg":"自推十次"},{"pid":"2347f6e89563f74e2697545bc62c26990e56e254","tid":1425474,"uid":248105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:23:04.000Z","msg":"自推十次"},{"pid":"067f34e73bc4cc161fc9176a9aa78fddd16146eb","tid":1425474,"uid":272243,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T18:25:23.000Z","msg":"冷*靜*<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"560d81056fb9829f98df203cc45073bd60e8d4ac","tid":1425474,"uid":206335,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-08-06T18:26:19.000Z","msg":"本來大家同是<br />\n一班背景差不多<br />\n學歷差不多<br />\n年齡差不多<br />\n<br />\n種種因素也是差不多<br />\n<br />\n但附予部份人<br />\n強勢權力，施壓武器，絕對命令<br />\n<br />\n令這部份人漸漸迷失 漸漸享受<br />\n逐漸同化 享受所帶來嘅無上虛榮<br />\n<br />\n其實褪去一切附予嘅事物<br />\n<br />\n大家都係平等 同是普通人 同是平民"},{"pid":"cb2860d031fd3e6921cd0495a512f3eb55bcb43d","tid":1425474,"uid":264051,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-08-06T18:27:08.000Z","msg":"忠言逆耳<br />\n<br />\n各位手足要冷靜D，尤其係處理其他人影相，唔好係咪都屌左先&hellip;<br />\n<br />\n之前我都有屌影相既花生友，E家有少少後悔點解唔禮貌D..."}