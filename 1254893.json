a1c911bf50fd5f7092659e0a74a1b5","tid":1254893,"uid":53481,"like":1,"dislike":1,"score":0,"quote":{"pid":"6bcadd751b82c36edfb4de3300a1073f7df5ea08","tid":1254893,"uid":185628,"like":0,"dislike":1,"score":-1,"quote":{"pid":"4da26dbd07cda9c73707837bb20857d72e4938b8","tid":1254893,"uid":53481,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2019-06-24T10:08:48.000Z","msg":"幫金鍾義士搞仲好啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-24T10:13:09.000Z","msg":"去林鄭道幫義士公祭？"},"citedBy":2,"replyTime":"2019-06-24T10:16:12.000Z","msg":"如果搞個大規模黃雨衣公祭得唔得？畫面一定震撼，又有意義，又唔會點樣擾民，只會加分唔會扣分"},"citedBy":0,"replyTime":"2019-06-24T10:21:17.000Z","msg":"地點上唔好擾民"},{"pid":"58bef175826130b238147cab28afab01bd9ccbae","tid":1254893,"uid":81424,"like":0,"dislike":0,"score":0,"quote":{"pid":"c69b00269661158181ad96552fe07b19c45b2fbf","tid":1254893,"uid":92340,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-24T10:03:15.000Z","msg":"「中國人的性情是總喜歡調和，折中的。譬如你說，這屋子太暗，須在這裏開一個窗，大家一定不允許的。但如果你主張拆掉屋頂，他們就會來調和，願意開窗了。沒有更激烈的主張，他們總連平和的改革也不肯行。」 ---- 魯迅<br />\n<br />\n現時個問題係，政府明顯係希望冷處理呢排發生既所有運動 - 「評論而不回應」<br />\n冷處理雖然會令到內部士氣下落，但用係香港人到似乎係一種相當適合既手法<br />\n政府個如意算盤就係過多幾個月，香港人就會熱情冷卻甚至忘記<br />\n到時佢地就出啲小因小惠政策黎收買民情<br />\n幾年後就秋後算賬，香港人就再一次經歷如夢初醒，不停loop<br />\n<br />\n套用魯迅上面既句子，我地既4/5大訴求就係「開一個窗」，依據呢個邏輯，我地既訴求得唔到回應，明顯係「主張唔夠激烈」，至使冇人嚟「調和」<br />\n呢幾日有所謂「更激烈既主張」，就係我地或者中大都主張再得唔到回應，「行動會升級」或者寄望G20<br />\n<br />\n「升級」主張係6/9日已經提出，之後嗰幾日行動都的而且確係激烈「升級」，以至政府不得不作出回應，而之所以得到回應，相信係有人從中「調和」（大家睇新聞都知）<br />\n<br />\n依加再一次提出「升級」主張，對政府黎講明顯係「唔激烈」，亦都唔會有人黎「調和」，可想而知得到回應既機會相當少<br />\n<br />\n所以我地既方向係，因為我地本來既訴求一直得唔到正面回應，係哀莫大過於心死既情況下，所以我地「不得不」提出「更激烈的主張」，呢個主張要足以「拆掉屋頂」，先會有人出黎調和，而令政府最起碼願意「開窗」<br />\n<br />\n睇番呢期大勢，小不免會見到台灣大選，亦會令某啲人聯想到台灣獨立，香港有咩「更激烈的主張」(我覺得gphone行緊呢個方向)可以配合到台灣足夠令政府肯至少「開一個窗」，大家有咩建議？"},"citedBy":0,"replyTime":"2019-06-24T10:21:34.000Z","msg":"講咗好耐要真普選<br />\n但個個都話未係時候<br />\n其實616係最好時機升級要求<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"36e33598365d0b67bf205df4c1a204994ca59b85","tid":1254893,"uid":53481,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-24T10:22:41.000Z","msg":"見到隔離post講正苦搵啲新移民扮交稅扮受阻，博同情打輿論戰<br />\n<br />\n所以各位做嘅嘢真係唔好重複，唔好比政苦慢慢諗計仔拆。要創新，要突擊！"},{"pid":"9f318ee88765096f87a2af83b768130903de7658","tid":1254893,"uid":185628,"like":0,"dislike":1,"score":-1,"quote":{"pid":"95a9b69e0ba1c911bf50fd5f7092659e0a74a1b5","tid":1254893,"uid":53481,"like":1,"dislike":1,"score":0,"quote":{"pid":"6bcadd751b82c36edfb4de3300a1073f7df5ea08","tid":1254893,"uid":185628,"like":0,"dislike":1,"score":-1,"quote":{"pid":"4da26dbd07cda9c73707837bb20857d72e4938b8","tid":1254893,"uid":53481,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2019-06-24T10:08:48.000Z","msg":"幫金鍾義士搞仲好啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-24T10:13:09.000Z","msg":"去林鄭道幫義士公祭？"},"citedBy":2,"replyTime":"2019-06-24T10:16:12.000Z","msg":"如果搞個大規模黃雨衣公祭得唔得？畫面一定震撼，又有意義，又唔會點樣擾民，只會加分唔會扣分"},"citedBy":1,"replyTime":"2019-06-24T10:22:55.000Z","msg":"去工賊會道？義士支持過工賊會"},{"pid":"6c035fd0141008f2bbbf5b8fcc5dd90a6650112b","tid":1254893,"uid":46534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-24T10:23:50.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"fa55bab58b947d6a6f017fc7d2e4798befc027b6","tid":1254893,"uid":53481,"like":0,"dislike":1,"score":-1,"quote":{"pid":"9f318ee88765096f87a2af83b768130903de7658","tid":1254893,"uid":185628,"like":0,"dislike":1,"score":-1,"quote":{"pid":"95a9b69e0ba1c911bf50fd5f7092659e0a74a1b5","tid":1254893,"uid":53481,"like":1,"dislike":1,"score":0,"quote":{"pid":"6bcadd751b82c36edfb4de3300a1073f7df5ea08","tid":1254893,"uid":185628,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-06-24T10:13:09.000Z","msg":"去林鄭道幫義士公祭？"},"citedBy":2,"replyTime":"2019-06-24T10:16:12.000Z","msg":"如果搞個大規模黃雨衣公祭得唔得？畫面一定震撼，又有意義，又唔會點樣擾民，只會加分唔會扣分"},"citedBy":1,"replyTime":"2019-06-24T10:22:55.000Z","msg":"去工賊會道？義士支持過工賊會"},"c