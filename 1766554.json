ss=\"hkgmoji\" />"},{"pid":"5ce80d49ff18e0f7162cc3b31732613c36d01b6d","tid":1766554,"uid":37870,"like":1,"dislike":0,"score":1,"quote":{"pid":"636fe994c6764db8802deef6b0ae46ac504ca932","tid":1766554,"uid":140912,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-12-02T16:27:05.000Z","msg":"好辛苦 辛苦到好想死<br />\n日日都好想死<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-12-02T16:29:49.000Z","msg":"搵fd，坦白咩都講出黎俾fd知<br />\nd野係心越屈越病，藥係有用既話，精神病院就唔會咁多人住"},{"pid":"fd41ca4bd657f3d34504583335e93aa4f4a700a8","tid":1766554,"uid":140912,"like":0,"dislike":0,"score":0,"quote":{"pid":"5ce80d49ff18e0f7162cc3b31732613c36d01b6d","tid":1766554,"uid":37870,"like":1,"dislike":0,"score":1,"quote":{"pid":"636fe994c6764db8802deef6b0ae46ac504ca932","tid":1766554,"uid":140912,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-12-02T16:27:05.000Z","msg":"好辛苦 辛苦到好想死<br />\n日日都好想死<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-12-02T16:29:49.000Z","msg":"搵fd，坦白咩都講出黎俾fd知<br />\nd野係心越屈越病，藥係有用既話，精神病院就唔會咁多人住"},"citedBy":1,"replyTime":"2019-12-02T16:31:44.000Z","msg":"講完 用好大勇氣先講到出嚟<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n但朋友覺得瞓醒就冇事叫我開心d<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n開心唔到<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"e8ee87d0c4eff1e49ebaba5a5eee28ce7b25f339","tid":1766554,"uid":140912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-02T16:32:03.000Z","msg":"垃圾自推8/10"},{"pid":"bc3c5b231d825cbd96bb987662a328d7d3bcb8f6","tid":1766554,"uid":140912,"like":0,"dislike":0,"score":0,"citedBy