ass=\"hkgmoji\" />"},{"pid":"9dc3a84f05139fa9488748646673233edc77714c","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T12:08:03.000Z","msg":"push"},{"pid":"b3010dda5f429805212126c99821aa04fdcec50e","tid":1281593,"uid":216253,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T12:08:44.000Z","msg":"推"},{"pid":"94cd18870d889d873be5ec34c69a24e6e5053fdb","tid":1281593,"uid":49795,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T12:09:08.000Z","msg":"推佢老母<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"63838a3b0fa2f589db428ba53ef4515fc3f7fb18","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T12:09:16.000Z","msg":"推"},{"pid":"0c62bc1861bfae55bb0861becfbaaee4ad721ef6","tid":1281593,"uid":272057,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T12:09:39.000Z","msg":"推一推"},{"pid":"2e9e7ff71c44abaac22e0811b6d61999ea6c09b9","tid":1281593,"uid":179379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T12:09:39.000Z","msg":"好慘<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n我幫你推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8af12685987962e547833db22dd7938452c53b0b","tid":1281593,"uid":263197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T12:11:01.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"02b9bd7b72e7e01c4df8c13e2539a7bb9bd6d455","tid":1281593,"uid":76366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T12:21:36.000Z","msg":"推"},{"pid":"badb5c15319a9e92a55d3046e8a671b46b2b7f7f","tid":1281593,"uid":270179,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T13:08:29.000Z","msg":"推爆 <img src=\"/assets/faces/lm2/love.gif\" class=\"hkgmoji\" />"},{"pid":"df6c0f1cea3661dd7c6b4e53b139b7050f023328","tid":1281593,"uid":158317,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T13:08:44.000Z","msg":"推"},{"pid":"a47a782663187f2a4df5f639c604a49d4a9652fd","tid":1281593,"uid":52609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T13:10:34.000Z","msg":"【文宣組回合、鍵盤戰士集合】入嚟拎文宣材料整合，一齊打贏輿論戰<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/PRfELU\" data-auto-link target=\"_blank\">https://lih.kg/PRfELU</a>"},{"pid":"b93549018be629bff61785ccc4ea04fe3dbc73d5","tid":1281593,"uid":118827,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T13:50:36.000Z","msg":"推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a523542e8ed8e68a88910c36d6617a926e2c041b","tid":1281593,"uid":263464,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T13:58:21.000Z","msg":"#被捕支援<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">記得保持緘默</span></span><br />\n伍展邦律師 @hksup（tg) / 5690 2877（whatsapp） / 2608 1400<br />\n韋智達律師 9167 7091<br />\n星火同盟 （fb inbox）<br />\n民權觀察 9463 2945（tg/sms/whatsapp）<br />\n本土民主前線 5934 5588 (whatsapp/sms) @Hkibackup （tg)<br />\n民陣 6549 9452 (whatsapp/telegram/sms)<br />\n港大 9139 0589<br />\n中大 9443 3459<br />\n科大 6019 6339 / 2335 1732 / 2335 5672<br />\n浸大 6110 3860<br />\n城大 9545 4172 / 3442 5570<br />\n理大 6800 0560 / 2766 7025 / 6253 2359<br />\n教大 5108 3519<br />\n演藝 6679 0772 / 9464 5078<br />\n<br />\n如見抗爭者被捕，請大家連同以下資料，聯絡上述單位：<br />\n1. 被捕者中文姓名<br />\n2. 被捕者英文姓名<br />\n3. 被捕者身份證號碼<br />\n4. 被捕者乘坐之警車號碼 / 所在警署<br />\n問：「出得嚟（遊）行」，有甚麼可以保護自己？<br />\nＣ：&rarr; 戴口罩（理論跟「速龍小隊」無警員號碼一樣，無仇報。）<br />\nㅤㅤ&rarr; 記得離開示威區才取下口罩。<br />\n<br />\n問：「出得嚟（遊）行」之前，除了帶水、雨傘、口罩，還有甚麼要預備？<br />\nＣ：&rarr; 把姓名和身份證號碼交給可信賴的朋友、律師或可信任的支援組織；一旦被捕，律師亦較容易在各區警署「撈」到你。<br />\nㅤㅤ&rarr; 把重要的聯絡電話，包括律師及相關支援組織等，寫在紙上，好好收起，又或者寫到手上。<br />\n<br />\n問：被警方拘捕，第一件事該做甚麼？<br />\nＣ：&rarr; 要求通知律師，在律師到來前，任何情況下，都只說：[red][size=6]「我無嘢講」[size=6][red]，亦不要簽署任何文件。<br />\nㅤㅤ&rarr; 未必一定可見家人，可請律師代通知家人。<br />\n<br />\n問：警方在拘捕你後，是否有權搜身？<br />\nＣ：&rarr; 有，但搜身需由相同性別警員進行。<br />\nㅤㅤ&rarr; 一般搜身是拍拍衫袋褲袋，除非懷疑藏有毒品或危險物品，才會要求除衫褲及內衣褲，而如有此情況，必須要求警員落簿記錄，保留日後投訴的權利。<br />\n<br />\n問：警方在拘捕你後，是否有權沒收手機？<br />\nＣ： 有，但[red][size=6]無權要求你解鎖手機/電腦[size=6][red]，你可要求警方封袋處理。[red][size=6]除非搜查令上寫要查手機/電腦的資料[size=6][red] <br />\n<br />\n問：律師到來前，要做甚麼？<br />\nＣ：&rarr; 就所有要求，都要警員落簿記下，例如 10:00 至 13:00，要求吃飯無飯吃，或者要求驗傷不獲處理，要求見律師話律師不會見你等等，方便律師寫到誓章，日後有機會呈上法庭。<br />\nㅤㅤ&rarr; 如果警員無落簿，自己要想方法記下參考時間。<br />\n<br />\n問： 見到律師前，會遇到甚麼情況？<br />\nＣ：&rarr; 你會好驚， 然後向警員如數家珍般，和盤托出參與的來龍去脈。請謹記，任何情況下，只需說：「我無嘢講。」<br />\nㅤㅤ&rarr; 警員會有不同技巧盤問你，請謹記，你只需說：「我無嘢講。」<br />\nㅤㅤ&rarr; 沒收手機後，你會好驚，但你是有對外聯絡的權利，請冷靜找出那張緊急聯絡電話的紙，然後聯絡律師。<br />\nㅤㅤ&rarr; 不要以為你只可以打一次電話，你是[red][size=6]有權隨時要求見律師[size=6][red] 。<br />\n<br />\n問：律師來到，會問甚麼、幫到甚麼？<br />\nＣ：&rarr; 基本資料，包括姓名、年齡、身份證號碼等（18 歲以下或通知有跟進個案的社工）<br />\nㅤㅤ&rarr; 可代通知家人、朋友<br />\nㅤㅤ&rarr; 有無受傷或不適（例如給警察踢了幾多腳，可以日後投訴），可要求到醫院驗傷<br />\nㅤㅤ&rarr; 額外處理事項，包括有否被沒收眼鏡（連律師個樣都看不清楚）、可有被搜身、搜屋等<br />\nㅤㅤ&rarr; 有無投訴（無飯吃、無水飲、無得去洗手間、無毛氈禦寒等等） <br />\nㅤㅤ&rarr; 特殊需要（例如定時需要服用藥物、聽障等）<br />\n<br />\n問：落口供時，應該如實道來嗎？<br />\nＣ：&rarr; 只須說：「我無嘢講」 。<br />\nㅤㅤ&rarr; 如果夠硬淨，可以自己落，記得只說：「我無嘢講」；如果驚，就請律師陪同。<br />\nㅤㅤ&rarr; 記得取口供副本。<br />\n<br />\n問：是否要求保釋？<br />\nＣ：&rarr; 建議「踢保」（即不接受保釋，「坐爆」48 小時）；電視、電影都睇得多，一般情況下，警方不能拘留你多於 48 小時；坐夠 48 小時，身份就回復 innocent person，亦等於無被拉過；而 48 小時是由警方說拘捕時間開始計，一般是上警車起跳，如果之後要到醫院，時間亦計在內。<br />\nㅤㅤ&rarr; 不建議要求保釋，因為需要定時返警署報到，帶來不必要麻煩。<br />\n<br />\n問：不保釋期間，會遭受甚麼對待？<br />\nＣ：&rarr; 警方在拘捕你後，有權沒收手機；在沒有手機的 48 小時，正常的你應該會悶到發癲。<br />\nㅤㅤ&rarr; 會安排到羈留室（俗稱臭格），內有一張 bench（水泥椅）和一個蹲廁，不是密封的。<br />\nㅤㅤ&rarr; 可要求吃飯、飲水、毛氈（因為冷氣大）。<br />\n<br />\n問：家人來到警署，應該注意甚麼事項？<br />\nＣ：&rarr; [red][size=6]你只是被拘捕，來落案檢控、未定罪[size=6][red]，所以不要問律師你會否有案底、要坐幾耐、會否影響到海外升學（可能出世以來都未諗過）、會否影響移民申請（同樣可能從未諗過）等。<br />\nㅤㅤ&rarr; 家人請謹記配合被捕者的那句：「我無嘢講。」<br />\nㅤㅤ&rarr; 此時此刻，沉默是金。<br />\n<br />\n問：假如朋友或家人懷疑你被拘捕，可以怎樣做？<br />\nＣ：&rarr; 通知律師，提供全名及身份證號碼（所以咪話在參與示威、遊行前要交低），一般律師團隊會到各區警署查詢，大約半小時可以找到。"},{"pid":"3b2b05208cb4252bc6d5abb4c8193b90654e70da","tid":1281593,"uid":179715,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T14:20:05.000Z","msg":"推"},{"pid":"aa6ff7462f9e92344c59e6a26c5518ed1900721d","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:46:42.000Z","msg":"Push"},{"pid":"f45a6760b485e4ffd5dbc9f6b8fd515db520c0f0","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:46:53.000Z","msg":"Pish"},{"pid":"622a372e1a1cf3c210de691580234cabee4b001e","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:47:05.000Z","msg":"Push"},{"pid":"284b3bc5f7b8e185c84779352d12d56d83600850","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:47:29.000Z","msg":"Push"},{"pid":"62f5cc419cf8f69907b8b80da610ed5713585f83","tid":1281593,"uid":37232,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-03T15:47:31.000Z","msg":"我無野講<br />\n我要見律師<br />\n我唔會解鎖"},{"pid":"26d10ab5e79233fc0343218586ea3377b9533ae8","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:49:23.000Z","msg":"Push"},{"pid":"967e105996d84c1ef25301f3ad4c443182ce5154","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"quote":{"pid":"62f5cc419cf8f69907b8b80da610ed5713585f83","tid":1281593,"uid":37232,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-03T15:47:31.000Z","msg":"我無野講<br />\n我要見律師<br />\n我唔會解鎖"},"citedBy":0,"replyTime":"2019-07-03T15:49:43.000Z","msg":"學到野👍🏻"},{"pid":"f0300f4e6b1da4e67b7d2f741f9c719dd3171954","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:49:54.000Z","msg":"Push"},{"pid":"85c1b2b196567ff21a247a05df7e1cc633ece0de","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:50:27.000Z","msg":"Push"},{"pid":"06cb8f3a85d65a0fda82927e976ede3699dd1640","tid":1281593,"uid":213379,"like"