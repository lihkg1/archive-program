bdb31c8f7aaa6ac86e4e3e488f160591198999c7","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:54:08.000Z","msg":"我無野講"},{"pid":"21f518fe7ddc8abeba7031ec452647699a68a285","tid":1281593,"uid":272454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:54:09.000Z","msg":"我無野講"},{"pid":"ad5585d1983b9d35d1206aba944ff881c01951f7","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:54:18.000Z","msg":"我無野講"},{"pid":"0bc9d7c40e97a2512ad1e37c3cbeb96026f0a6d1","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:54:34.000Z","msg":"我無野講"},{"pid":"0cdb4eb1d0a8d211c82f49b20c4e0baf89796e03","tid":1281593,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:55:02.000Z","msg":"我無野講"},{"pid":"8e35e5ea778fafd87de552afdadf7d132ad6b5af","tid":1281593,"uid":53870,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:55:41.000Z","msg":"我無野講"},{"pid":"a7d0dd80d1d08993783ce6e487725122a7919bd2","tid":1281593,"uid":272454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:57:04.000Z","msg":"我無野講"},{"pid":"80089cc46d5d832f686328a28ff4ed5c8d560416","tid":1281593,"uid":272454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T15:59:03.000Z","msg":"我無野講"}]}