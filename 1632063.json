ts/faces/dog/fight_connect.gif\" class=\"hkgmoji\" />"},{"pid":"c46ebc0b6ef6fb18a8f9e3b9476cdd23b0a7bdb9","tid":1632063,"uid":16291,"like":0,"dislike":0,"score":0,"quote":{"pid":"88a698b9d509768c4dbefbf50c10f55da5299eeb","tid":1632063,"uid":310883,"like":0,"dislike":0,"score":0,"quote":{"pid":"7f2b68770dec7b39cfea47f4ef17db17c71a106b","tid":1632063,"uid":16291,"like":0,"dislike":0,"score":0,"quote":{"pid":"91964724a4c0b876fc5bc1f43ddf18c3b1d288e6","tid":1632063,"uid":310883,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-06T17:05:00.000Z","msg":"黨鐵都爛晒 有咩好搞<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n暫時淨粉飾唔裝修住?"},"citedBy":1,"replyTime":"2019-10-06T17:06:50.000Z","msg":"繼續水魔法？仆街黨鐵休息左2日，<br />\n星期二開得番又打回原形"},"citedBy":1,"replyTime":"2019-10-06T17:08:43.000Z","msg":"水舞間幾好<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-06T17:12:30.000Z","msg":"啱啊！！好睇又實用！！"},{"pid":"59dd2d00e5aef37a51d0c595cac9ecf5fd9cb579","tid":1632063,"uid":16291,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T17:15:25.000Z","msg":"推！！"},{"pid":"2e9f319d61cc5f9975a6ef1152292446a287776d","tid":1632063,"uid":130079,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T17:15:36.000Z","msg":"<span style=\"color: gold;\"><strong><span style=\"font-size: xx-large;\">係外國既香港人都可以一齊係連登出力！ 而家只係要你入黎推post</span></strong></span><br />\n<br />\n<br />\n<br />\n［眾籌俾連登］開一個英文版面俾連登仔<br />\n【重開】［眾籌俾連登］開一個英文版面俾連登仔<br />\n<a href=\"https://lih.kg/1630849\" target=\"_blank\">https://lih.kg/1630849</a><br />\n<a href=\"https://lih.kg/1630201\" target=\"_blank\">https://lih.kg/1630201</a><br />\n<br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<br />\n現時連登急需亦好要一個<span style=\"color: gold;\"><span style=\"font-size: x-large;\">英文台/或者係新既英文介面，全部台都有英文版咁。</span></span><br />\n<br />\n主要用途係對外文宣用，如果個論壇冧左，<span style=\"color: purple;\">外國人更加清楚lihkg被攻擊同香港自由被剝既嚴重性</span>。<br />\n<br />\ntwitter有lihkg,reddit開post<br />\n但始終都唔係lihkg開英文台<br />\n<br />\n<br />\n好處：<br />\n1.連登多左流覽量，廣告費多左<br />\n2.同上，每次被攻擊都睇到香港無自由，the world is watching<br />\n3.理論上少風向文宣，因為如果要落手帶風向，對家就要大學畢業既人，文宣戰立即少左散仔協會參戰，但香港市民最多就係呢一堆人。<br />\n4.<span style=\"font-size: x-large;\"><strong><span style=\"color: gold;\">外國巴打可以幫手文宣，尤其exchange學生，仲可以介紹俾其他國家既人</span></strong></span><br />\n5.擴大和理非平台，快速文宣，一個巴絲可翻譯，另一巴絲亦可做搬運工，快速輸出文宣<br />\n<br />\n<br />\n大家如果見到既<br />\n幫手：<br />\n1.<span style=\"color: red;\">幫推，唔該3連推一次</span><br />\n2.連登search其他 英文台 國際台，<span style=\"color: green;\">將入面相關要求既post再推</span><br />\n<br />\n3.share link去fb tg，叫其他有account既人入黎再一齊做返1同2<br />\n4.<span style=\"color: orange;\">堅持每日全部post再一推</span><br />\n5.Fb 連登到留comment，叫連仔開英文台<br />\n6. Fb進行洗版式接龍活動，令到連仔開到/知道要開英文台為止<br />\n7.太舊既post只可以推番三個上水，幫手推埋thx<br />\n<br />\n如果你係要求開英文台post樓主既：<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">集中連推自己所有既英文台post，我會幫推，唔好放棄推<br />\n</span></span>"},{"pid":"c4b3e25ba5bbda2106f585a74825a3ae8450ec78","tid":1632063,"uid":264717,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T17:15:39.000Z","msg":"推"},{"pid":"56ed8e151982b4a2cbef7786506a55dda009b192","tid":1632063,"uid":228458,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T17:15:51.000Z","msg":"今日風向：勇武退場<br />\n<a href=\"https://lih.kg/1631974\" data-auto-link target=\"_blank\">https://lih.kg/1631974</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"a59f302805616adfc04ee54aef8d74630d561e88","tid":1632063,"uid":92170,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-10-06T17:16:08.000Z","msg":"<img src=\"https://na.cx/i/xqv1Bji.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fxqv1Bji.jpg&h=55df6b55&s={SIZE}\" /><br />\n<br />\n最好刪app <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n自衛 自衛 自衛<br />\n<br />\n唔好再講獅鳥，當玩講笑咁講 <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/a