oQdk4RJtjV1Wc7Scp8ABb8MCffMw%3D&h=edfa8298\" data-auto-link target=\"_blank\">https://bit.ly/2OqI0lA</a><br />\n<br />\n- Hannum, &ldquo;The Right of Self-Determination in the Twenty-First Century,&rdquo; 55 Wash. &amp; Lee L Rev 773 (1998): <a href=\"https://bit.ly/2Oxom7z\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F2Oxom7z&d=suC3bgMk4yzoLj7oQdk4RJtjV1Wc7Scp8ABb8MCffMw%3D&h=7bb74c58\" data-auto-link target=\"_blank\">https://bit.ly/2Oxom7z</a><br />\n- Ginsburg &amp; Versteeg, &ldquo;From Catalonia to California: Secession in Constitutional Law,&rdquo; 70(4) Ala L Rev 924 (2019), Parts I&ndash;V.B: <a href=\"https://bit.ly/35NGDTv\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F35NGDTv&d=suC3bgMk4yzoLj7oQdk4RJtjV1Wc7Scp8ABb8MCffMw%3D&h=7e6cdd7b\" data-auto-link target=\"_blank\">https://bit.ly/35NGDTv</a><br />\n<br />\n- Hogg, Constitutional Law of Canada &sect; 5.7 (2007 student ed.): <a href=\"https://bit.ly/3sWjPe0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F3sWjPe0&d=suC3bgMk4yzoLj7oQdk4RJtjV1Wc7Scp8ABb8MCffMw%3D&h=f262a6d4\" data-auto-link target=\"_blank\">https://bit.ly/3sWjPe0</a><br />\n<br />\n- Ginsburg &amp; Versteeg, &ldquo;When to Overthrow Your Government: The Right to Resist in the World&rsquo;s Constitutions,&rdquo; 60 UCLA L Rev 1183 (2013), pp. 1187&ndash;1193, 1195&ndash;98 (Chinese tradition), 1217&ndash;24<br />\n<br />\nOptional reading:<br />\n- Quebec Secession Reference [1998] 2 SCR 217 excerpts: <a href=\"https://bit.ly/3wDx19K\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F3wDx19K&d=suC3bgMk4yzoLj7oQdk4RJtjV1Wc7Scp8ABb8MCffMw%3D&h=3ff3d266\" data-auto-link target=\"_blank\">https://bit.ly/3wDx19K</a><br />\n<br />\n- B&ouml;ckenf&ouml;rde, &ldquo;International Law and Constitution-Making: Sudan,&rdquo; parts 2 and 3.1&ndash;3.2 (CIC)【篇文未出版，麻煩自己問教授攞】<br />\n<br />\n- Petersen, &ldquo;Not an Internal Affair: Hong Kong&rsquo;s Right to Autonomy,&rdquo; 49 HKLJ