":0,"citedBy":1,"replyTime":"2019-08-08T14:49:42.000Z","msg":"改左撐黑警潮文<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"2e092d41e3281b2ff4d8932bb90ce6111dfccf9c","tid":1433390,"uid":253016,"like":0,"dislike":0,"score":0,"quote":{"pid":"9eef732f005f0b02780c82ef29728b2ac9dd5549","tid":1433390,"uid":193233,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-08T14:49:42.000Z","msg":"改左撐黑警潮文<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-08T14:54:50.000Z","msg":"SHAR牙<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"3be45d065b0bc5a9e95c2e24a9ab40e8108751ed","tid":1433390,"uid":273670,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-08T14:57:16.000Z","msg":"<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"}]}