faces/lm2/wet.gif\" class=\"hkgmoji\" />"},{"pid":"13d963c1591aa3e51e4195c6cf8b4912991fff85","tid":1328103,"uid":53805,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-17T23:26:48.000Z","msg":"沒用架 而家全世界用緊有地圖功能既電話<br />\n都係有柒頭問你路"},{"pid":"4207813309edf2843e19577d12686663b40189c4","tid":1328103,"uid":131696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T23:30:45.000Z","msg":"香港一早有啦 班警察行得走得 係無腦姐<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1a5caac7a791e400aff5c3572e75f4c29a33b31b","tid":1328103,"uid":169994,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T23:30:59.000Z","msg":"終極監控<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><br />\n最後人類社會由電腦系統統治"},{"pid":"72ebc10df29bca28c31d5877e8fba6bbfec0e06f","tid":1328103,"uid":49853,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T23:34:22.000Z","msg":"matrix<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n想學咩直接download<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"876eaf014fdb2abdcddfa1ec15bf78f2dbdba700","tid":1328103,"uid":40979,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T23:37:23.000Z","msg":"Black Mirror"},{"pid":"95c00745a059d76e42d1ba13f216212ac564fdab","tid":1328103,"uid":30561,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-18T00:59:37.000Z","msg":"這舉動一但只係比一啲權貴階級或者獨裁者掌握，加個指令，便做到極權控制人類。所以學生應自行設計大腦晶片<br />\n<br />\n<a href=\"https://lihkg.com/thread/1328257/page/1\" target=\"_blank\">https://lihkg.com/thread/1328257/page/1</a>"},{"pid":"d80669cfa273d50e62cb16bb2e3829c885e2c8b8","tid":1328103,"uid":4811,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-18T01:10:21.000Z","msg":"遲下強国分分鐘一出世就要強制植入晶片，好似terminator裡面咁<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />人面識別都唔使"},{"pid":"38766b4