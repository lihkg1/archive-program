sets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"c6f7ca8e1174a265cb2ba11adbccfc5c4b01d678","tid":1605110,"uid":121995,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T16:00:21.000Z","msg":"哇 做得過窩"},{"pid":"5a1bb58435bab87dbc5282f78861f61924217fee","tid":1605110,"uid":236171,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T16:12:38.000Z","msg":"認真，可以救到好多人<br />\n仲可以加重狗嘅工作量"},{"pid":"a0df69f37e80d00842baa8076e1b6a22597abc96","tid":1605110,"uid":188810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T16:19:27.000Z","msg":"推推推"},{"pid":"80adc5e2aaf7916d489a8b0bf712b415005a31fa","tid":1605110,"uid":56224,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T02:12:39.000Z","msg":"推"},{"pid":"efcba126d6c9796b8153348611f5bef842cfb744","tid":1605110,"uid":15259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T02:18:46.000Z","msg":"<strong><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">六區開花要對準政權，梗係去議員辦事處賀佢老母啦</span></span></strong><br />\n<br />\n<span style=\"color: red;\"><strong><span style=\"font-size: xx-large;\">唔好再</span></strong></span>企起街上面<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>圍警局</strong></span></span>，分區活動就應該<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>打游擊戰去搵該區既建制派議員</strong></span></span>同佢地開party一齊賀一賀<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />，至於邊一區去邊間就大家自己衡量下喇﹗<br />\n<br />\n屯門區區議員<br />\n<a href=\"https://zh.wikipedia.org/wiki/%E5%B1%AF%E9%96%80%E5%8D%80%E8%AD%B0%E6%9C%83\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E5%25B1%25AF%25E9%2596%2580%25E5%258D%2580%25E8%25AD%25B0%25E6%259C%2583&d=l0hx0y7EoyLX%2BzZhnd86ZvUbXA8pdDK36CymbYVYMuw%3D&h=0fc444bf\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/wiki/%E5%B1%AF%E9%96%80%E5%8D%80%E8%AD%B0%E6%9C%83</a><br />\n荃灣區議員<br />\n<a href=\"https://zh.wikipedia.org/wiki/%E8%8D%83%E7%81%A3%E5%8D%80%E8%AD%B0%E6%9C%83\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E8%258D%2583%25E7%2581%25A3%25E5%258D%2580%25E8%25AD%25B0%25E6%259C%2583&d=l0hx0y7EoyLX%2BzZhnd86ZvUbXA8pdDK36CymbYVYMuw%3D&h=fa0d6c8b\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/wiki/%E8%8D%83%E7%81%A3%E5%8D%80%E8%AD%B0%E6%9C%83</a><br />\n沙田區議員<br />\n<a href=\"https://zh.wikipedia.org/wiki/%E6%B2%99%E7%94%B0%E5%8D%80%E8%AD%B0%E6%9C%83\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E6%25B2%2599%25E7%2594%25B0%25E5%258D%2580%25E8%25AD%25B0%25E6%259C%2583&d=l0hx0y7EoyLX%2BzZhnd86ZvUbXA8pdDK36CymbYVYMuw%3D&h=7c169c75\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/wiki/%E6%B2%99%E7%94%B0%E5%8D%80%E8%AD%B0%E6%9C%83</a><br />\n黃大仙區議員<br />\n<a href=\"https://zh.wikipedia.org/wiki/%E9%BB%83%E5%A4%A7%E4%BB%99%E5%8D%80%E8%AD%B0%E6%9C%83\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E9%25BB%2583%25E5%25A4%25A7%25E4%25BB%2599%25E5%258D%2580%25E8%25AD%25B0%25E6%259C%2583&d=l0hx0y7EoyLX%2BzZhnd86ZvUbXA8pdDK36CymbYVYMuw%3D&h=f82624ce\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/wiki/%E9%BB%83%E5%A4%A7%E4%BB%99%E5%8D%80%E8%AD%B0%E6%9C%83</a><br />\n深水埗區議員<br />\n<a href=\"https://zh.wikipedia.org/wiki/%E6%B7%B1%E6%B0%B4%E5%9F%97%E5%8D%80%E8%AD%B0%E6%9C%83\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E6%25B7%25B1%25E6%25B0%25B4%25E5%259F%2597%25E5%258D%2580%25E8%25AD%25B0%25E6%259C%2583&d=l0hx0y7EoyLX%2BzZhnd86ZvUbXA8pdDK36CymbYVYMuw%3D&h=0136b7e6\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/wiki/%E6%B7%B1%E6%B0%B4%E5%9F%97%E5%8D%80%E8%AD%B0%E6%9C%83</a><br />\n灣仔區議員<br />\n<a href=\"https://zh.wikipedia.org/wiki/%E7%81%A3%E4%BB%94%E5%8D%80%E8%AD%B0%E6%9C%83\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E7%2581%25A3%25E4%25BB%2594%25E5%258D%2580%25E8%25AD%25B0%25E6%259C%2583&d=l0hx0y7EoyLX%2BzZhnd86ZvUbXA8pdDK36CymbYVYMuw%3D&h=bfd7462e\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/wiki/%E7%81%A3%E4%BB%94%E5%8D%80%E8%AD%B0%E6%9C%83</a><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">1.打電話（呢個係每日都可以做既）</span></span></strong><br />\n打電話搵議員(之前有巴打post過出黎，可以自己搵下)問下國慶期間區內有咩最新活動、巴士路線、有咩醫生診所好介紹呀等等，電話打唔通既whatsapp都可以，無whatsapp既巴絲打可以send email去，連email都無既可以fax過去查詢下，無人應既話可以搵下無限fax大法fax到佢應機為止。<br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: xx-large;\"><strong>2.連儂牆</strong></span></span><br />\n都係搵立法會議員/區議員辦事處啦，無開門既咪留張紙起度寫低自己有咩問或者有咩訴求囉。<br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: xx-large;\"><strong>3.裝修</strong></span></span><br />\n有好多議員都扎根起屋邨做左好耐，裡面啲裝修又殘又舊，有心既手足可以襯國慶幫佢地補下油、翻新下添置返少少國慶節日既氣氛，用咩色就自己決定啦。<br />\n補充:好多office既出入口好窄，大家入office查詢既時候動作唔好太大呀，唔小心撞到佢地d玻璃就大鑊喇。<br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: xx-large;\"><strong>4.餵office既龜龜食野(蟲系魔法師出動)</strong></span></span><br />\n巴絲打們都可以準備少少紅蟲、蚯蚓、生雞蛋、甜野呀個d比入面既龜龜食，可以吸引到更多蟲蟲輕易大量繁殖既就更好。大家知啦，議員們公事繁忙，萬一無時間餵佢地，龜龜都仲有少少野食丫嘛。<br />\n補充：拉開櫃桶餵既時候記住小心啲，唔好倒瀉手上罐可樂呀，會惹到成地蟻架！<br />\n<br />\n<span style=\"color: red;\"><strong>原post:</strong></span><br />\n國慶咁大件事 緊係要約埋建制議員賀佢老母<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1605409\" data-auto-link target=\"_blank\">https://lih.kg/1605409</a>"}]}