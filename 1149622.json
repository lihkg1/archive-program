i\" />"},{"pid":"8e6964a93d62a78776f34210ae0c0e2052963627","tid":1149622,"uid":6833,"like":0,"dislike":0,"score":0,"quote":{"pid":"745082566a717e0ab6814fd531a8caa325a031df","tid":1149622,"uid":142576,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-11T09:35:07.000Z","msg":"免簽返住烏得唔得<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-11T09:35:52.000Z","msg":"車狗續多佢一年"},{"pid":"85dad9195f56d72b96626e3fd8c3e7e4307ac0c0","tid":1149622,"uid":187726,"like":2,"dislike":4,"score":-2,"citedBy":1,"replyTime":"2019-05-11T09:36:18.000Z","msg":"<span style=\"font-size: xx-large;\">有請史上奪得歐霸冠軍次數最多的領隊<br />\n<img src=\"https://images2.minutemediacdn.com/image/upload/c_fill,w_912,h_516,f_auto,q_auto,g_auto/shape/cover/sport/58a82f4cc9c15a13fd000001.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimages2.minutemediacdn.com%2Fimage%2Fupload%2Fc_fill%2Cw_912%2Ch_516%2Cf_auto%2Cq_auto%2Cg_auto%2Fshape%2Fcover%2Fsport%2F58a82f4cc9c15a13fd000001.jpg&h=222008a1&s={SIZE}\" /><br />\n綽號歐霸之王的<span style=\"color: red;\">烏拿&middot;艾瑪利</span></span><br />\n<img src=\"https://e00-marca.uecdn.es/assets/multimedia/imagenes/2018/09/27/15380563577221.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fe00-marca.uecdn.es%2Fassets%2Fmultimedia%2Fimagenes%2F2018%2F09%2F27%2F15380563577221.jpg&h=4e9b78f8&s={SIZE}\" /><br />\n<br />\n<strong><span style=\"font-size: x-large;\">加盟初期被大部分阿迷寄予厚望，希望一洗頹風</span></strong><br />\n<span style=\"font-size: x-large;\">雖然頭兩場未適應，不幸落敗</span><br />\n<img src=\"https://scontent.fhkg3-2.fna.fbcdn.net/v/t1.0-9/39015021_10156217523517713_417866357594390528_n.jpg?_nc_cat=103&amp;_nc_ht=scontent.fhkg3-2.fna&amp;oh=af28968b3ca0eed6216e1fde322fc5bc&amp;oe=5D6F3654\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg3-2.fna.fbcdn.net%2Fv%2Ft1.0-9%2F39015021_10156217523517713_417866357594390528_n.jpg%3F_nc_cat%3D103%26_nc_ht%3Dscontent.fhkg3-2.fna%26oh%3Daf28968b3ca0eed6216e1fde322fc5bc%26oe%3D5D6F3654&h=f251c161&s={SIZE}\" /><br />\n<img src=\"https://scontent.fhkg3-2.fna.fbcdn.net/v/t1.0-9/39568117_10156231894402713_6581310638293778432_n.jpg?_nc_cat=103&amp;_nc_ht=scontent.fhkg3-2.fna&amp;oh=41c663d4fb38de39e392b3c548c2ae72&amp;oe=5D62135D\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg3-2.fna.fbcdn.net%2Fv%2Ft1.0-9%2F39568117_10156231894402713_6581310638293778432_n.jpg%3F_nc_cat%3D103%26_nc_ht%3Dscontent.fhkg3-2.fna%26oh%3D41c663d4fb38de39e392b3c548c2ae72%26oe%3D5D62135D&h=fc552edc&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><strong>但愛SIR其後亦不負眾望，曾經熱血打狗成功</strong></span><br />\n<img src=\"https://i.ytimg.com/vi/5ZetF4HToNE/maxresdefault.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.ytimg.com%2Fvi%2F5ZetF4HToNE%2Fmaxresdefault.jpg&h=ebae0c75&s={SIZE}\" /><br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">在廿二場不敗期間甚至有手足開始有爭冠的感覺</span></span><br />\n<img src=\"https://na.cx/i/qk7HkVA.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fqk7HkVA.png&h=773ba921&s={SIZE}\" /><br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\"><strong>但是好景不常，對修咸頓爆冷輸波後就開始崩盤</strong></span></span><br />\n<img src=\"https://e.amonpointv.com/wp-content/uploads/2018/12/DujEEoxWwAYQoT_.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fe.amonpointv.com%2Fwp-content%2Fuploads%2F2018%2F12%2FDujEEoxWwAYQoT_.jpg&h=9678cbd3&s={SIZE}\" /><br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: red;\">到季尾竟然締造神奇戰績，聯賽四戰只得一分<br />\n由爭三弟變五弟</span></strong></span><br />\n<img src=\"https://na.cx/i/nMFLaH3.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnMFLaH3.png&h=c6e5944d&s={SIZE}\" /><br />\n<br />\n<strong><span style=\"font-size: x-large;\">呢個時候等我哋回顧吓愛SIR今季嘅輝煌戰績</span></strong><br />\n<span style=\"font-size: x-small;\">柒嗰方面</span><br />\n<img src=\"https://bit.ly/307lbo8\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fbit.ly%2F307lbo8&h=10e86fde&s={SIZE}\" /><br />\n<img src=\"https://bit.ly/2LwSiyw\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fbit.ly%2F2LwSiyw&h=d81bf9fd&s={SIZE}\" /><br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: red;\">和波已經係小事，睇吓下面</span></strong></span><br />\n<br />\n<img src=\"https://scontent.fhkg3-1.fna.fbcdn.net/v/t1.0-9/49811006_10156571994302713_3485454905181732864_n.jpg?_nc_cat=104&amp;_nc_ht=scontent.fhkg3-1.fna&amp;oh=96ef986eff68d7675dcbde13643e83a7&amp;oe=5D633FF4\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg3-1.fna.fbcdn.net%2Fv%2Ft1.0-9%2F49811006_10156571994302713_3485454905181732864_n.jpg%3F_nc_cat%3D104%26_nc_ht%3Dscontent.fhkg3-1.fna%26oh%3D96ef986eff68d7675dcbde13643e83a7%26oe%3D5D633FF4&h=affea28a&s={SIZE}\" /><br />\n<img src=\"https://scontent.fhkg3-2.fna.fbcdn.net/v/t1.0-9/56301755_10156767954432713_5770533701729386496_n.jpg?_nc_cat=103&amp;_nc_ht=scontent.fhkg3-2.fna&amp;oh=ea1cb6ab4b0771a2c579c3e71aab9b99&amp;oe=5D594C95\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg3-2.fna.fbcdn.net%2Fv%2Ft1.0-9%2F56301755_10156767954432713_5770533701729386496_n.jpg%3F_nc_cat%3D103%26_nc_ht%3Dscontent.fhkg3-2.fna%26oh%3Dea1cb6ab4b0771a2c579c3e71aab9b99%26oe%3D5D594C95&h=b96aac98&s={SIZE}\" /><br />\n<img src=\"https://scontent.fhkg3-2.fna.fbcdn.net/v/t1.0-9/57556856_10156802639067713_3496306019795992576_n.jpg?_nc_cat=101&amp;_nc_ht=scontent.fhkg3-2.fna&amp;oh=f3f78097f595f44412a75d8b3a04cae7&amp;oe=5D75655C\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg3-2.fna.fbcdn.net%2Fv%2Ft1.0-9%2F57556856_10156802639067713_3496306019795992576_n.jpg%3F_nc_cat%3D101%26_nc_ht%3Dscontent.fhkg3-2.fna%26oh%3Df3f78097f595f44412a75d8b3a04cae7%26oe%3D5D75655C&h=fb10f4f6&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: red;\">原來輸一球唔係好柒啫<br />\n<img src=\"https://na.cx/i/dSAZZ6G.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FdSAZZ6G.png&h=e880fd59&s={SIZE}\" /><br />\n<br />\n因為可以輸兩球</span></strong></span><br />\n<img src=\"https://bit.ly/2VkNmRE\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fbit.ly%2F2VkNmRE&h=bb4a8451&s={SIZE}\" /><br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: red;\">睇吓</span></strong></span><img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://scontent.fhkg3-2.fna.fbcdn.net/v/t1.0-9/57821844_10156811289167713_2795313481019031552_n.jpg?_nc_cat=111&amp;_nc_ht=scontent.fhkg3-2.fna&amp;oh=44e4a03be3d771a557e647b061302eab&amp;oe=5D659CE2\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg3-2.fna.fbcdn.net%2Fv%2Ft1.0-9%2F57821844_10156811289167713_2795313481019031552_n.jpg%3F_nc_cat%3D111%26_nc_ht%3Dscontent.fhkg3-2.fna%26oh%3D44e4a03be3d771a557e647b061302eab%26oe%3D5D659CE2&h=815e0c76&s={SIZE}\" /><img src=\"https://scontent.fhkg3-2.fna.fbcdn.net/v/t1.0-9/51800990_10156623437072713_5612464534276014080_n.jpg?_nc_cat=106&amp;_nc_ht=scontent.fhkg3-2.fna&amp;oh=6f853e7536405ac84d585d96ecf603be&amp;oe=5D646A6D\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fhkg3-2.fna.fbcdn.net%2Fv%2Ft1.0-9%2F51800990_10156623437072713_5612464534276014080_n.jpg%3F_nc_cat%3D106%26_nc_ht%3Dscontent.fhkg3-2.fna%26oh%3D6f853e7536405ac84d585d96ecf603be%26oe%3D5D646A6D&h=a6187bf8&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: red;\">兩球未夠？咁就要輸夠三球喇</span></strong></span><br />\n<img src=\"https://scontent.fhkg3-2.fna.fbcdn.net/v/t1.0-9/58419831_10156820768072713_2347557269190737920_n.jpg?_nc_cat=108&amp;_nc_ht=scontent.fhkg3-2.fna&amp;oh=a04a38a9f39254a5f9ab176bf595826b&amp;oe=5D2FE7E1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2F