ww.chiphell.com/thread-1732606-1-1.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.chiphell.com%2Fthread-1732606-1-1.html&d=WHMLQMiyWmfm849WKe725MVakpCEQgWe3bOYm8oES40%3D&h=20141f2d\" target=\"_blank\">https://www.chiphell.com/thread-1732606-1-1.html</a></div>"},{"pid":"4c00412c909d3e6b4a50d85c0995d8eeea8cf1cd","tid":232440,"uid":13741,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-06T17:45:36.000Z","msg":"真心想AMD快啲出<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"13c0774ed30772232f6e88b0df4eca7373ff12ab","tid":232440,"uid":1886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-06T17:47:13.000Z","msg":"<span style=\"color: limegreen;\">早前AMD的技術營銷主管Robert Hallock曾經表示，<br />\nAMD Ryzen處理器想要獲得最好的兼容性以及超頻能力，<br />\n使用來自三星的B DieDRAM顆粒至關重要。<br />\n<br />\n怎麼區分三星的B Die、E DieDRAM？<br />\n其實很簡單，一般單面4GB、雙面8GB都是E Die顆粒，<br />\n單面8GB、雙面16GB則是B Die，<br />\n不過買了E Die或者是其他廠商DRAM顆粒的用戶也不用擔心，<br />\n因為本月更新的BIOS將會增加20+型號的DRAM條，<br />\n<span style=\"color: red;\">還會支持使用海力士顆粒的DRAM條<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> </span>。</span>"},{"pid":"9333bd0924a8f45de3b82e6330a4b678582459e7","tid":232440,"uid":14049,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-06T19:09:33.000Z","msg":"AMD戰未來.呢句說話真係冇講錯<br />\n<br />\n永遠都係之後慢慢先發揮到真正實力"},{"pid":"1df8d95b55de761a2548931ba5e4d52edcfb0d17","tid":232440,"uid":57677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-07T06:13:38.000Z","msg":"支持<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8b7b91b4459324dac8ac8f47d38b49fce3d3c910","tid":232440,"uid":18790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-07T06:19:58.000Z","msg":"AMD<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n明顯有heart<br />\nIntel當班顧客狗咁撚"},{"pid":"d1c8662bbfd994c