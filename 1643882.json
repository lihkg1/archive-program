s/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7b121de60676a8a5b5afa7facf719d0d72d59931","tid":1643882,"uid":186,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:10:07.000Z","msg":"高質"},{"pid":"f18a925f0c8313407c5213889e5758ed9ed2a18e","tid":1643882,"uid":268894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:26:41.000Z","msg":"推"},{"pid":"2d7ac478649dd838a482e93f10c9c000015a00ec","tid":1643882,"uid":268894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:26:52.000Z","msg":"推"},{"pid":"05a4855ad2f7054e7e61a8e664e20d9e820755ac","tid":1643882,"uid":268894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:27:03.000Z","msg":"推"},{"pid":"47d4b9542118a48f16dcc21d7da00b05c74e5a14","tid":1643882,"uid":268894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:27:13.000Z","msg":"推"},{"pid":"5419e27eee5c63d44c977268e96eae94ba10cae8","tid":1643882,"uid":268894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:27:34.000Z","msg":"p牌唔夠力， 大家請幫手推"},{"pid":"839356ffbe26ea3c6f355c68b67791a48cbda157","tid":1643882,"uid":268894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:27:46.000Z","msg":"推"},{"pid":"fec20c34622582f8f77d69096bd19c4ce9cac4b7","tid":1643882,"uid":268894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:27:57.000Z","msg":"推"},{"pid":"dc73eae1bfbf7fab1a6264130887548dd43ce96a","tid":1643882,"uid":254544,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:28:26.000Z","msg":"推！"},{"pid":"dadd24e6d0a33dc97c6df98f30670d6023dac701","tid":1643882,"uid":50873,"like":0,"dislike":0,"score":0,"quote":{"pid":"97bbccd45048418dd73602c6ff99f0c37ac5b232","tid":1643882,"uid":221265,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-10-10T11:37:11.000Z","msg":"嘩乜咁潮"},"citedBy":1,"replyTime":"2019-10-10T12:29:29.000Z","msg":"佢哋就係守護孩子果班"},{"pid":"9b00aee5d5fde750a7dcade70785d66402bbe0e8","tid":1643882,"uid":72676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:32:40.000Z","msg":"推！！好有創意啊！"},{"pid":"40dadfbe2ba4cb39898724c3347e81dfe1139aa1","tid":1643882,"uid":65260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:38:51.000Z","msg":"新世紀蒙面戰士<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\nNERV香港分部<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n成篇都喺到FF<br />\n我鐘意<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ca84bf5719cf811470c29559f9fd7fcfb5fb0cfc","tid":1643882,"uid":267654,"like":5,"dislike":0,"score":5,"quote":{"pid":"d9e4391d2687a04c10118d94549f3446617ea377","tid":1643882,"uid":267654,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-10T10:35:29.000Z","msg":"<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" />【好鄰舍北區教會呈獻：新世紀福音戰士蒙面運動】<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><br />\n(「禁止蒙面規例」豁免宗教理由)<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><br />\n<br />\n作為新世紀福音戰士，除左sing sing hallelujah to the lord 之外，本會今個月要推出新既蒙面祈禱活動，誠邀各位參加，於不同場所蒙面祈禱，成為新世紀蒙面戰士<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\nA. 點參加<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" /><br />\n各位新世紀福音戰士可以有唔同程度既參與，以下係兩個唔同既參加方法，最好係兩樣都參加保持同NERV既香港分部好鄰舍北區教會聯繫，以獲得最大既保障:<br />\n<br />\n1. 帶口罩<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><br />\n並加以十字架作記認，例如戴十字架、劃個十字架係個口罩到等任何你想到既識別，就可以變身為新世紀蒙面戰士<img src=\"/assets/faces/lm2/ok.gif\" class=\"hkgmoji\" /><br />\n<br />\n2. 填下個google form <br />\n(<a href=\"https://forms.gle/PRZ3tcJB2D3SeEuW6\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2FPRZ3tcJB2D3SeEuW6&d=N3SWmacea4shigR4hA2Em8ls9Dgy9T8na9BfJ9hiblc%3D&h=873883c1\" target=\"_blank\">https://forms.gle/PRZ3tcJB2D3SeEuW6</a>)，留低你想留底既資料(保證保密)，就可以成為本會既嘉賓版新世紀福音戰士，以確認你參與本會既蒙面祈禱運動，運動結束後，就可以通知我地退出<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><br />\n<br />\nB. 對象︰<br />\n<br />\n有志成為新世紀蒙面戰士既<span style=\"color: blue;\">基督徒</span><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><br />\n希望認識<span style=\"color: gold;\">神</span>既<span style=\"color: red;\">全港市民</span><img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\nC. 用咩黎蒙面呢<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><br />\n所有遮到塊面既野都得，包括頭巾、口罩、初號機頭盔(如有)，所有蒙面既物品都可以架。<br />\n<br />\nD. 為期：10月4日至11月4日，視乎情況而定<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n<br />\nE. 會唔會因為戴口罩而犯反蒙面法????<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><br />\n<br />\n因宗教理由而蒙面係合法架！<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" /><br />\n但都要留意法庭會唔會接受呢個理由做合理辯解，所以我地都鼓勵你做齊兩項活動<img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" /><br />\n<br />\nF. <span style=\"color: red;\">聖經神學</span>(信仰理據/因由)<br />\n<br />\n基督教聖經中一重要人物︰摩西，第一次於何烈山荊棘中面見神時，神說︰「「我是你父親的神，是亞伯拉罕的神，以撒的神，雅各的神。」摩西蒙上臉，因為怕看神。」(出埃及記3:6)。舊約傳統中， 如人直接見到神，就會有更死亡的可能。因有罪的人見到聖潔身的神，神必審判那不潔的罪，人定必死亡。摩西見到神後，因害怕(fear，在聖經其他地方中譯「敬畏」)直接面見神，蒙起面(hid his face)來。蒙面是表達一份對神的害怕、敬畏，明白神對人的要求。<br />\n<br />\n常言道，人在緊張關頭所作的決定是表示人所深信的。摩西在遇到生與死之間，以蒙面表達對神的敬虔，確定神的聖潔、自己的罪疚。<br />\n<br />\nG. 蒙面祈禱的實踐<br />\n<br />\n以上述經文為基礎，學習摩西如何害怕神、敬畏神，不論何時何地以蒙面作禱告、靈修/思想，認識自己的罪與不潔，確認上主的聖潔，提醒自己需要敬虔。<br />\n祈禱、靈修從來沒有地域、時間長短限制，最重要是你的心。因此，實踐是全港性的，在任何時刻，包括清醒、還是睡著也是可以的。當然，在危急時，更須要這樣的學習。<br />\n<br />\nH. 參加「蒙面祈禱敬虔運動」的人如參加犯法行為，是否等於 貴會縱容信徒犯法？<br />\n<br />\n主耶穌說︰「康健的人用不著醫生，有病的人才用得著。 ...我來本不是召義人，乃是召罪人。」(馬太福音9:12-13) 本會一向主張合法行為，但主耶穌卻指教會就是接納罪人的地方；而成聖(成為一個敬虔的人)非一蹴就成，乃是歷程。正如有紀律的公職人員，也有犯法的可能。所以，有信仰的人不是「神」，而是學習成聖的人，亦會有軟弱、犯罪。因此，若你見到有參加本會行動的犯法者，盼你能以愛勸勉他們回轉，接納並饒恕。若有會友做犯法的事情，我們定當全力了解、擁抱，希望作更好的指導、牧養。<br />\n<br />\nI. 政府推出反蒙面法後推出呢個運動，係咪以宗教之名保護暴徒合法蒙面<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />?<br />\n<br />\n因應6月12日一名警員對一名基督徒講「叫你耶穌落黎見我」，由於耶穌再落黎代表世界末日，現階段未見有此可能，但本會仍絞盡腦汁希望回應該名警員，終於10月政府推出「反蒙面法」受到啓發，我地可以由聖經中向摩西學習，成為敬畏神既人，時刻祈禱，令該名警員可以感受主耶穌既大能無處不在<img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">仲有文宣圖啊，快D同我廣傳<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /></span></span><br />\n<img src=\"https://na.cx/i/eiX71FK.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeiX71FK.jpg&h=b1ceba77&s={SIZE}\" /> <img src=\"https://na.cx/i/geHzGFL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgeHzGFL.jpg&h=2a4c82f3&s={SIZE}\" /> <img src=\"https://na.cx/i/UR5Nhd6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUR5Nhd6.jpg&h=17692e39&s={SIZE}\" /> <img src=\"https://na.cx/i/xcURJT7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxcURJT7.jpg&h=92953bb5&s={SIZE}\" /> <img src=\"https://na.cx/i/8ZHgay7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8ZHgay7.jpg&h=5c49bd1c&s={SIZE}\" /> <img src=\"https://na.cx/i/C2zN1FO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FC2zN1FO.jpg&h=9f042620&s={SIZE}\" /><br />\n<br />\n我地既facebook page:<a href=\"https://www.facebook.com/GoodNeighbournd/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FGoodNeighbournd%2F&d=N3SWmacea4shigR4hA2Em8ls9Dgy9T8na9BfJ9hiblc%3D&h=a32e37d9\" target=\"_blank\">https://www.facebook.com/GoodNeighbournd/</a><br />\n相關既post: <a href=\"https://www.facebook.com/GoodNeighbournd/posts/2119357225025308?__tn__=-R\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FGoodNeighbournd%2Fposts%2F2119357225025308%3F__tn__%3D-R&d=N3SWmacea4shigR4hA2Em8ls9Dgy9T8na9BfJ9hiblc%3D&h=713920a6\" target=\"_blank\">https://www.facebook.com/GoodNeighbournd/posts/2119357225025308?__tn__=-R</a><br />\n<br />\n最後，多謝大家一直關注我地教會狀況，我地會繼續努力！<br />\n香港人加油，兄弟爬山啊！<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-10T12:38:55.000Z","msg":"其實這是我哋教會最能夠為各手足提供的幫忙。希望大家廣推，帶個十架登過記，記念神，亦能幫助你行過死陰谷<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />警話你做咩帶面罩，你表示正參加這宗教活動，好人一生平安<img src=\"/assets/faces/big/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"58a8ef6f43535ce864a90686aacd197ab2e1bce7","tid":1643882,"uid":254544,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:47:50.000Z","msg":"好人一生平安！<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"e6663f94632c0a272619810b44ccef23314a1baf","tid":1643882,"uid":30347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:50:06.000Z","msg":"香港補完計劃<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7842f90a870962dfcc3e501217822d441a580974","tid":1643882,"uid":54598,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T12:54:15.000Z","msg":"Push"},{"pid":"f92b213dc8e7b5ed48279b834e316e32239704d0","tid":1643882,"uid":104086,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T13:16:09.000Z","msg":"推"},{"pid":"ee135e3ed4dd03e09b2c0a60f3a08d8d78218de9","tid":1643882,"uid":221265,"like":0,"dislike":0,"score":0,"quote":{"pid":"dadd24e6d0a33dc97c6df98f30670d6023dac701","tid":1643882,"uid":50873,"like":0,"dislike":0,"score":0,"quote":{"pid":"97bbccd45048418dd73602c6ff99f0c37ac5b232","tid":1643882,"uid":221265,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-10-10T11:37:11.000Z","msg":"嘩乜咁潮"},"citedBy":1,"replyTime":"2019-10-10T12:29:29.000Z","msg":"佢哋就係守護孩子果班"},"citedBy":0,"replyTime":"2019-10-10T13:16:21.000Z","msg":"我知<br />\n<br />\n佢哋唔係只得老㗎<br />\n都有啲後生<br />\n成日見到佢哋"},{"pid":"b179478988647e5cc6b65ffc885bfa4cd6b2ad77","tid":1643882,"uid":294,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T13:17:02.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"117649dd349bdaac780b59f47261a7678173652a","tid":1643882,"uid":48868,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-10T13:18:35.000Z","msg":"咁另煩類 推<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},{"pid":"ebc2aec4297906bfa198779db99b8a9ccf49a9d5","tid":1643882,"uid":48868,"like":0,"dislike":0,"score":0,"quote":{"pid":"117649dd349bdaac780b59f47261a7678173652a","tid":1643882,"uid":48868,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-10T13:18:35.000Z","msg":"咁另煩類 推<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-10T13:18:53.000Z","msg":"咁另類"},{"pid":"5d17dfd7235cd98267fd8fde6adeb9b638bb9e36","tid":1643882,"uid":231413,"like":0,"dislike":0,"score":0,"quote":{"pid":"d9e4391d2687a04c10118d94549f3446617ea377","tid":1643882,"uid":267654,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-10T10:35:29.000Z","msg":"<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" />【好鄰舍北區教會呈獻：新世紀福音戰士蒙面運動】<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><br />\n(「禁止蒙面規例」豁免宗教理由)<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><br />\n<br />\n作為新世紀福音戰士，除左sing sing hallelujah to the lord 之外，本會今個月要推出新既蒙面祈禱活動，誠邀各位參加，於不同場所蒙面祈禱，成為新世紀蒙面戰士<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\nA. 點參加<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" /><br />\n各位新世紀福音戰士可以有唔同程度既參與，以下係兩個唔同既參加方法，最好係兩樣都參加保持同NERV既香港分部好鄰舍北區教會聯繫，以獲得最大既保障:<br />\n<br />\n1. 帶口罩<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><br />\n並加以十字架作記認，例如戴十字架、劃個十字架係個口罩到等任何你想到既識別，就可以變身為新世紀蒙面戰士<img src=\"/assets/faces/lm2/ok.gif\" class=\"hkgmoji\" /><br />\n<br />\n2. 填下個google form <br />\n(<a href=\"https://forms.gle/PRZ3tcJB2D3SeEuW6\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2FPRZ3tcJB2D3SeEuW6&d=N3SWmacea4shigR4hA2Em8ls9Dgy9T8na9BfJ9hiblc%3D&h=873883c1\" target=\"_blank\">https://forms.gle/PRZ3tcJB2D3SeEuW6</a>)，留低你想留底既資料(保證保密)，就可以成為本會既嘉賓版新世紀福音戰士，以確認你參與本會既蒙面祈禱運動，運動結束後，就可以通知我地退出<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><br />\n<br />\nB. 對象︰<br />\n<br />\n有志成為新世紀蒙面戰士既<span style=\"color: blue;\">基督徒</span><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><br />\n希望認識<span style=\"color: gold;\">神</span>既<span style=\"color: red;\">全港市民</span><img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\nC. 用咩黎蒙面呢<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><br />\n所有遮到塊面既野都得，包括頭巾、口罩、初號機頭盔(如有)，所有蒙面既物品都可以架。<br />\n<br />\nD. 為期：10月4日至11月4日，視乎情況而定<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n<br />\nE. 會唔會因為戴口罩而犯反蒙面法????<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><br />\n<br />\n因宗教理由而蒙面係合法架！<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" /><br />\n但都要留意法庭會唔會接受呢個理由做合理辯解，所以我地都鼓勵你做齊兩項活動<img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" /><br />\n<br />\nF. <span style=\"color: red;\">聖經神學</span>(信仰理據/因由)<br />\n<br />\n基督教聖經中一重要人物︰摩西，第一次於何烈山荊棘中面見神時，神說︰「「我是你父親的神，是亞伯拉罕的神，以撒的神，雅各的神。」摩西蒙上臉，因為怕看神。」(出埃及記3:6)。舊約傳統中， 如人直接見到神，就會有更死亡的可能。因有罪的人見到聖潔身的神，神必審判那不潔的罪，人定必死亡。摩西見到神後，因害怕(fear，在聖經其他地方中譯「敬畏」)直接面見神，蒙起面(hid his face)來。蒙面是表達一份對神的害怕、敬畏，明白神對人的要求。<br />\n<br />\n常言道，人在緊張關頭所作的決定是表示人所深信的。摩西在遇到生與死之間，以蒙面表達對神的敬虔，確定神的聖潔、自己的罪疚。<br />\n<br />\nG. 蒙面祈禱的實踐<br />\n<br />\n以上述經文為基礎，學習摩西如何害怕神、敬畏神，不論何時何地以蒙面作禱告、靈修/思想，認識自己的罪與不潔，確認上主的聖潔，提醒自己需要敬虔。<br />\n祈禱、靈修從來沒有地域、時間長短限制，最重要是你的心。因此，實踐是全港性的，在任何時刻，包括清醒、還是睡著也是可以的。當然，在危急時，更須要這樣的學習。<br />\n<br />\nH. 參加「蒙面祈禱敬虔運動」的人如參加犯法行為，是否等於 貴會縱容信徒犯法？<br />\n<br />\n主耶穌說︰「康健的人用不著醫生，有病的人才用得著。 ...我來本不是召義人，乃是召罪人。」(馬太福音9:12-13) 本會一向主張合法行為，但主耶穌卻指教會就是接納罪人的地方；而成聖(成為一個敬虔的人)非一蹴就成，乃是歷程。正如有紀律的公職人員，也有犯法的可能。所以，有信仰的人不是「神」，而是學習成聖的人，亦會有軟弱、犯罪。因此，若你見到有參加本會行動的犯法者，盼你能以愛勸勉他們回轉，接納並饒恕。若有會友做犯法的事情，我們定當全力了解、擁抱，希望作更好的指導、牧養。<br />\n<br />\nI. 政府推出反蒙面法後推出呢個運動，係咪以宗教之名保護暴徒合法蒙面<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />?<br />\n<br />\n因應6月12日一名警員對一名基督徒講「叫你耶穌落黎見我」，由於耶穌再落黎代表世界末日，現階段未見有此可能，但本會仍絞盡腦汁希望回應該名警員，終於10月政府推出「反蒙面法」受到啓發，我地可以由聖經中向摩西學習，成為敬畏神既人，時刻祈禱，令該名警員可以感受主耶穌既大能無處不在<img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">仲有文宣圖啊，快D同我廣傳<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /></span></span><br />\n<img src=\"https://na.cx/i/eiX71FK.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeiX71FK.jpg&h=b1ceba77&s={SIZE}\" /> <img src=\"https://na.cx/i/geHzGFL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgeHzGFL.jpg&h=2a4c82f3&s={SIZE}\" /> <img src=\"https://na.cx/i/UR5Nhd6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUR5Nhd6.jpg&h=17692e39&s={SIZE}\" /> <img src=\"https://na.cx/i/xcURJT7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxcURJT7.jpg&h=92953bb5&s={SIZE}\" /> <img src=\"https://na.cx/i/8ZHgay7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8ZHgay7.jpg&h=5c49bd1c&s={SIZE}\" /> <img src=\"https://na.cx/i/C2zN1FO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FC2zN1FO.jpg&h=9f042620&s={SIZE}\" /><br />\n<br />\n我地既facebook page:<a href=\"https://www.facebook.com/GoodNeighbournd/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FGoodNeighbournd%2F&d=N3SWmacea4shigR4hA2Em8ls9Dgy9T8na9BfJ9hiblc%3D&h=a32e37d9\" target=\"_blank\">https://www.facebook.com/GoodNeighbournd/</a><br />\n相關既post: <a href=\"https://www.facebook.com/GoodNeighbournd/posts/2119357225025308?__tn__=-R\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FGoodNeighbournd%2Fposts%2F2119357225025308%3F__tn__%3D-R&d=N3SWmacea4shigR4hA2Em8ls9Dgy9T8na9BfJ9hiblc%3D&h=713920a6\" target=\"_blank\">https://www.facebook.com/GoodNeighbournd/posts/2119357225025308?__tn__=-R</a><br />\n<br />\n最後，多謝大家一直關注我地教會狀況，我地會繼續努力！<br />\n香港人加油，兄弟爬山啊！<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-10T13:21:52.000Z","msg":"辛苦你了"},{"pid":"c4b72ce3bc8877cffea5425ff53ca7c6b1c8c820","tid":1643882,"uid":37528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T13:29:26.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"37ce47062d9531540c84335ef8a635baba26d873","tid":1643882,"uid":104086,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T13:34:44.000Z","msg":"推"},{"pid":"f3da167f6e8836c25ee5687839311a399b998bb9","tid":1643882,"uid":198214,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T13:35:54.000Z","msg":"推"},{"pid":"74c121d5e7e4b192675338e47b5cef814338ddd0","tid":1643882,"uid":254544,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T13:38:50.000Z","msg":"<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"818b0843cc92dff94acd6dea0de3f5c3c7e7d933","tid":1643882,"uid":12179,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T13:41:23.000Z","msg":"推"},{"pid":"754075a5e55d8dcabf8663faa8d564c9f1b4100e","tid":1643882,"uid":104086,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T13:43:33.000Z","msg":"推"},{"pid":"0ef405933235a5b1c01403e20cbb999871761dbe","tid":1643882,"uid":143743,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTi