ke":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-10-10T11:46:52.000Z","msg":"佢哋係最勇武嘅和理非"},{"pid":"4d170f9bfb42d087ae269b2aa8a6926513fd3991","tid":1643882,"uid":54564,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-10-10T11:47:17.000Z","msg":"幾有創意"},{"pid":"982d08bf95f523ae3003ac6a02ca2b4dcbec5c4f","tid":1643882,"uid":218315,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T11:48:49.000Z","msg":"推"},{"pid":"b50db8765b02159125f2b66b27c365ed9ea3d447","tid":1643882,"uid":275243,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-10-10T11:50:06.000Z","msg":"cls<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><br />\n大義凜然到<br />\n夠膽咪ban呢個<img src=\"/assets/faces/lm2/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"17fceed083e03b5b937c433c5c9abedc464a86a0","tid":1643882,"uid":321216,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T11:51:13.000Z","msg":"空氣推"},{"pid":"03feedf28d0cbe939e61584de689118c0e104328","tid":1643882,"uid":279253,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-10T11:51:27.000Z","msg":"<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"398752b098474475a0caa2e09457eed861e6793b","tid":1643882,"uid":80814,"like":0,"dislike":0,"score":0,"citedB