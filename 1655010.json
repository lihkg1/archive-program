s=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"cc629d73d9964db5d1776f6309eaee4bcaa8f043","tid":1655010,"uid":226594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T07:58:19.000Z","msg":"<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"b6f092132f0ed5d621720042d708f9ea3eca9287","tid":1655010,"uid":288255,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T08:05:56.000Z","msg":"<img src=\"https://na.cx/i/Rc5m0XW.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRc5m0XW.jpg&h=c9b20cda&s={SIZE}\" /><br />\n<br />\nP牌狗推唔郁，照推<img src=\"/assets/faces/dog/stop.gif\" class=\"hkgmoji\" />"},{"pid":"47d6c9d9244ad3fd63161e89077240eafae151d3","tid":1655010,"uid":74778,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T08:07:38.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"}]}