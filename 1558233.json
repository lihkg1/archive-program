e54589af5719","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:39:33.000Z","msg":"推"},{"pid":"5ea7a31a0a2c1a0a88f753625061e8ad95cf3bff","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:40:26.000Z","msg":"831"},{"pid":"5761a67e2c9fd3677b744fedcbafd75482c42944","tid":1558233,"uid":208227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:41:06.000Z","msg":"推"},{"pid":"c415afe5574857a889aa3cdf932754f985a06eea","tid":1558233,"uid":208227,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-10T11:41:49.000Z","msg":"911全城自發戒嚴日"},{"pid":"dca687fbc5e61ca5c3e2ff7280a83a9c133c6430","tid":1558233,"uid":280648,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:41:59.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"48a9f74a4466299623aff85b212580c9f16eec84","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:42:30.000Z","msg":"推"},{"pid":"d460c6b9e4e82562ecb1457bf8b08f5928021a2a","tid":1558233,"uid":74778,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-10T11:43:37.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\nRetwit please"},{"pid":"ff65e4a1186381597cf49ac9a10aaf5a583c72bd","tid":1558233,"uid":314549,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-09-10T11:45:04.000Z","msg":"連登熱門有幾個POST 都有講到，聽日港共好有可能做嘢，造成人命傷亡，然後屈襲擊係示威者所做，企圖嫁禍抹黑。<br />\n<br />\n如果港共真係咁做,簡直可以話係一石四鳥，請睇吓我以下嘅分析：<br />\n<br />\n1. 示威者內部分裂<br />\n<br />\n從運動一開始我哋一直強調和理非同勇武不割席，但係如果真係發生示威者（當然係梅）無差別攻擊普通平民，對於唔係日日睇住連登嘅淺黃人來講，係會非常討厭同埋覺得好過份，之前中環燒地鐵已經開始有和理非唔同意。雖然我哋都知道唔係示威者所做，但係可能做到嘅效果係和理非同勇武割席，會有啲五毛開始出嚟帶風向，對成場運動嘅團結會有好大嘅傷害<br />\n<br />\n2. 中共出師有名<br />\n<br />\n之前國務院開記者會已經講明而家嘅示威活動有恐怖主義嘅苗頭，如果聽日出事嘅話咁中共就名正言順繼續喺官媒抺黑，甚至可以大條道理出緊急法，又或者立法推更箝制香港人身自由嘅法例。另外耿爽又可以話美國支持恐怖主義活動，令到美國人更難支持我地<br />\n<br />\n3. 道德光環失去，美國民心背向<br />\n<br />\n911係每一個美國人都會記得恐怖襲擊痛苦嘅人，如果美國時間911嘅早上，美國人打開Facebook見到香港發生恐襲，有好多無辜婦孺傷亡，美國人仲會唔會支持示威者？發生左呢件事會同當地悼念九一一形成強烈對比，更加reinforce 美國人唔應該支持恐怖主義活動，咁樣亦都會令到參眾議會非常難做，變成兩邊不是人，令美國處於尷尬狀態。<br />\n<br />\n4. 藍絲黑警更加猖狂<br />\n發生左恐怖襲擊之後，藍絲口中嘅甲甴思想更會深入民心，黑警亦都會更加合理化自己所做嘅濫權濫捕，因為佢哋覺得打嘅係恐怖分子。入咗新屋嶺嘅手足會受到更加唔人道嘅對待，白色恐怖將籠罩全港。將會發生更加多藍絲攻擊手足嘅事情發生<br />\n<br />\n本身我都覺得我諗多咗，但係見到工聯會, China daily 開始講聽日會有示威人士發動襲擊,令到我相信我嘅憂慮。我希望各位聽日能夠平平安安，同時我哋都應該諗定辦法點樣拆解呢個有可能係成場運動以來最嚴峻嘅考驗<br />\n<br />\n另外我估計如果真係不幸有事情發生，將會發生嘅時間會喺傍晚之前，因為需要等待民意發酵，同埋要就翻美國朝頭早的air time. <br />\n<br />\n我非常希望我估錯，各位手足入嚟諗下計"},{"pid":"d574427b27b5aa3ed2f343974494f0852cbc70d4","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:45:42.000Z","msg":"64"},{"pid":"8b4c24c1109444a08c629e6690a0fc141bd605b2","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:46:11.000Z","msg":"721"},{"pid":"c113eb18b0fd047931842b61c0911302f3410c55","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:47:25.000Z","msg":"831"},{"pid":"4428d0a8f2f62693f6040fb61a9b451073191fbe","tid":1558233,"uid":97716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:48:29.000Z","msg":"I SWEAR"},{"pid":"2d8800a5614649d240ac15d3675b9f8c1b2b2233","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:48:51.000Z","msg":"推"},{"pid":"2150b6851de302883d12c2099eac95a2ba0929b8","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:49:11.000Z","msg":"大家幫手推<br />\n文宣組呢"},{"pid":"4c03103dba606b39f71c21a4cb079951cd10ab2e","tid":1558233,"uid":296056,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:49:53.000Z","msg":"推"},{"pid":"34aeabd447462b5a3f2ac81d78352adf321f974c","tid":1558233,"uid":84267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:51:53.000Z","msg":"Protestors will NEVER burn down any forests/parks <br />\nProtestors will NEVER indiscriminately attack innocents <br />\nProtestors are NOT terrorists as CHINAZI describes. <br />\n<br />\n9/11 is an important date. CHINAZI will most likely send undercover and commit terrorism to defame Hong Kong protestors."},{"pid":"9e1a4aefb7ce32151ba97461cbd81783bf1c75f3","tid":1558233,"uid":146720,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:51:53.000Z","msg":"Tui"},{"pid":"d22d0c39fe99bc8e63721a0eb6b12bba9d37763c","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:51:54.000Z","msg":"發誓呀<br />\n中共出招11/9 搞殺人<br />\n13/9中秋前佢完晒所有野"},{"pid":"5192208930b8517feaea8dc0b18ff48b423b9111","tid":1558233,"uid":98141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:52:05.000Z","msg":"push"},{"pid":"2fa30699c4c489cd3e7ad469853878b85ab95c26","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:52:14.000Z","msg":"推"},{"pid":"854fa91dbd35b83fe41b4c1592a1b5c7ff99b84d","tid":1558233,"uid":53612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:52:31.000Z","msg":"老共 殺警 全城留家中"},{"pid":"d35094357f8a9f5882f3ff0caf0a78b7c17bccb9","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:53:40.000Z","msg":"推 文宣"},{"pid":"8d9c60f51ba64dac2c0238ac5915088ffd6f284e","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:53:54.000Z","msg":"911"},{"pid":"9a6850afa42fbe39cf5c7acad9a9353c3e440c68","tid":1558233,"uid":51790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:54:58.000Z","msg":"same"},{"pid":"d86586129380565776527f0a7560004382ce5309","tid":1558233,"uid":136992,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-10T11:55:55.000Z","msg":"911"},{"pid":"3d28fa91877be9be5c0e40ed0bd1946ed9f19d47","tid":1558233,"uid":253573,"like":0,"dislike":0,"score":0,"quote":{"pid":"d460c6b9e4e82562ecb1457bf8b08f5928021a2a","tid":1558233,"uid":7