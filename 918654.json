c=\"http://i.imgur.com/DZprlkB.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi.imgur.com%2FDZprlkB.jpg&h=04b53d46&s={SIZE}\" />"},{"pid":"973a3e0f2aa37a1c5a8f5e648924b6b7d29f865c","tid":918654,"uid":78971,"like":1,"dislike":20,"score":-19,"citedBy":0,"replyTime":"2018-11-27T11:43:30.000Z","msg":"你冇樣冇料又同阿姐頂撞<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n轉行轉得遲啦"},{"pid":"62c1d2c87565b76f36ca44c1ff8f681c7a56666a","tid":918654,"uid":62815,"like":12,"dislike":0,"score":12,"citedBy":0,"replyTime":"2018-11-27T11:43:39.000Z","msg":"個撚個都綠葉王<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n萬能鍾都未到佢啦"},{"pid":"8e06e1f5d73a4ea194f9200fcee560a83eeee3f0","tid":918654,"uid":5649,"like":0,"dislike":26,"score":-26,"citedBy":1,"replyTime":"2018-11-27T11:44:20.000Z","msg":"依條撚樣專做奸角<br />\n現實都唔荒係好人，仲有人請佢做保安員<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"eae00d23701341e0fa77e9c190a31e1f40e28000","tid":918654,"uid":24160,"like":15,"dislike":1,"score":14,"quote":{"pid":"a9feceb9bb8be2c34751df9fb993bd43fc7c7c11","tid":918654,"uid":35580,"like":17,"dislike":2,"score":15,"citedBy":1,"replyTime":"2018-11-27T11:36:33.000Z","msg":"想知阿姐每次開演唱會做幾多功課<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-27T11:54:07.000Z","msg":"<img src=\"https://i.imgur.com/zVQm2a4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FzVQm2a4.jpg&h=113739c3&s={SIZE}\" />"},{"pid":"80218666a14d905f948acff9d8811a79f655005d","tid":918654,"uid":6604,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-11-27T12:55:46.000Z","msg":"明荃之友照入嚟報到<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"24839a1c58337d927a3fc5ca5dd62fbf021c692f","tid":918654,"uid":103263,"like":0,"dislike":1,"score":-1,"quote":{"pid":"7750df6b727e60d2a46e254ee0d47ec8f1acf07d","tid":918654,"uid":171192,"like":26,"dislike":2,"score":24,"citedBy":1,"replyTime