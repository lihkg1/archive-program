r />\n<strong>特別鳴謝被捕人士關注組公海手足cc整合以上資訊</strong>"},{"pid":"23828117ee47b77a469a4f5240297f121a6e9653","tid":2076592,"uid":292499,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-06-23T15:45:02.000Z","msg":"手足24號判刑<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n【父親節】愛妻病逝 獨子在囚 手足爸：我一定撐到你出嚟，我哋從頭嚟過<br />\n<a href=\"https://hk.appledaily.com/local/20200621/4KRKPKCIMANMRPOWBLMO4Q2QYA/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200621%2F4KRKPKCIMANMRPOWBLMO4Q2QYA%2F&d=91nyg34XrGq4aGOua7i4Je6cow1LS9WQT%2BeJ8I%2F17x8%3D&h=1a095b2d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200621%2F4KRKPKCIMANMRPOWBLMO4Q2QYA%2F&h=242150d3\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20200621/4KRKPKCIMANMRPOWBLMO4Q2QYA/</a>"},{"pid":"81f8ab6f1395d19d08d559511ca4f1531d049f78","tid":2076592,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-23T15:46:24.000Z","msg":"推"},{"pid":"3bd1cae82e4c5578263ba05887944e9300b1d117","tid":2076592,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-23T15:46:46.000Z","msg":"推"},{"pid":"3249e7ab4d6ad73555c5e9dc87647f55b32a585e","tid":2076592,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-23T15:46:57.000Z","msg":"推"},{"pid":"b9c3a69b807ecdf9d8b582049dfa1d20fa346ed0","tid":2076592,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-23T15:47:07.000Z","msg":"推"},{"pid":"f8ec54b53a4183817c72ada967e4cd03aac1800a","tid":2076592,"uid":55496,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-23T15:47:08.000Z","msg":"<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"ee59b3dcb532bd680c9c15ac1d4a392e5755b0b0","tid":2076592,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0