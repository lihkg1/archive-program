1fb17ecffefdc4782","tid":1546122,"uid":200912,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2019-09-06T07:51:42.000Z","msg":"每次想跳都有黃衫/狗<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-06T08:10:24.000Z","msg":"捐可能無咁起眼"},{"pid":"33020f205d8090f951dd0b2ed12a54f6a8025e6e","tid":1546122,"uid":146535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T08:11:01.000Z","msg":"推"},{"pid":"091a3a2dd946664197923f053519ad6a8bc60268","tid":1546122,"uid":146535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T08:12:51.000Z","msg":"推"},{"pid":"4f41e62ee4674c4a7f81b6c523be829950969697","tid":1546122,"uid":146535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T08:14:22.000Z","msg":"推"},{"pid":"cb3c0d08f836962bcf25a733f69a42d12814f192","tid":1546122,"uid":246340,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-06T08:16:23.000Z","msg":"唔好咁心急即刻就想跳/chok入閘<br />\n扮去買嘢/等人/搵人/搵路<br />\n望多一兩分鐘 觀察下有冇可疑人物先<br />\n<br />\n好似我頭先咁<br />\n 一入站見到有個男人企閘機隔離<br />\n又翹囇手眼望望咁 <br />\n我行去扮睇路牌觀察咗佢一陣<br />\n<br />\n哦 原來佢有架車仔喺隔離 等緊人<br />\n<span style=\"color: limegreen;\">冇便衣狗冇職員冇popo 安全嘅</span><br />\n<br />\n然後就當住班學生面跳入閘<br />\n頭也不回咁上咗月台<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"c487688645b82a71733eb2fa66a581838be6f461","tid":1546122,"uid":146535,"like":0,"dislike":0,"score":0,"quote":{"pid":"cb3c0d08f836962bcf25a733f69a42d12814f192","tid":1546122,"uid":246340,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-06T08:16:23.000Z","msg":"唔好咁心急即刻就想跳/chok入閘<br />\n扮去買嘢/等人/搵人/搵路<br />\n望多一兩分鐘 觀察下有冇可疑人物先<br />\n<br />\n好似我頭先咁<br />\n 一入站見到有個男人企閘機隔離<br />\n又翹囇手眼望望咁 <br />\n我行去扮睇路牌觀察咗佢一陣<br />\n<br />\n哦 原來佢有架車仔喺隔離 等緊人<br />\n<span style=\"color: limegreen;\">冇