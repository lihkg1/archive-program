ng><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"3c0cad1a74cb4e4f121327df12f4e0fc121c0b88","tid":1204654,"uid":33874,"like":0,"dislike":0,"score":0,"quote":{"pid":"0acfbb29870dd3fe44b5bff16f35cd5aa6f1495b","tid":1204654,"uid":57566,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-11T15:55:54.000Z","msg":"仲用3毛post講阻人返工<br />\n煽動情緒"},"citedBy":1,"replyTime":"2019-06-11T16:21:12.000Z","msg":"聽日返你老母啦<br />\n仲返嗰啲返大陸啦"},{"pid":"e01adbec0ad6de53fe6630dfa7d14beac04ec864","tid":1204654,"uid":112061,"like":1,"dislike":0,"score":1,"quote":{"pid":"c2f41b5f1839a9472dfd17b11f1fd3c3db4dfca9","tid":1204654,"uid":147317,"like":2,"dislike":11,"score":-9,"citedBy":1,"replyTime":"2019-06-11T15:52:40.000Z","msg":"塞死地鐵會搞到市民反感"},"citedBy":1,"replyTime":"2019-06-11T16:21:51.000Z","msg":"反你老母，送終唔反感？"},{"pid":"28337446ee8a4db25a4bc29d3a2e29b0b8746bb8","tid":1204654,"uid":147317,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e01adbec0ad6de53fe6630dfa7d14beac04ec864","tid":1204654,"uid":112061,"like":1,"dislike":0,"score":1,"quote":{"pid":"c2f41b5f1839a9472dfd17b11f1fd3c3db4dfca9","tid":1204654,"uid":147317,"like":2,"dislike":11,"score":-9,"citedBy":1,"replyTime":"2019-06-11T15:52:40.000Z","msg":"塞死地鐵會搞到市民反感"},"citedBy":1,"replyTime":"2019-06-11T16:21:51.000Z","msg":"反你老母，送終唔反感？"},"citedBy":1,"replyTime":"2019-06-11T16:23:08.000Z","msg":"要有民心先會成功<br />\n港豬大部份都唔接受<br />\n<br />\n你要諗受眾點諗"},{"pid":"4b23c93248507268450cbca3b400acb637e65ee3","tid":1204654,"uid":226405,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T16:23:34.000Z","msg":"塞爆上水站"},{"pid":"68b9b9cdfe66395c4a0d1e963aa00f56c345bb9f","tid":1204654,"uid":212419,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-11T16:23:56.000Z","msg":"話塞地鐵班小朋友智商係咁上下<img src=\"/assets/faces/dog/lihkg.gif\" class=\"hkgmoji\" />"},{"pid":"8731ce450151a50a47a3d4517b5a7ca1903f72a2","tid":1204654,"uid":4422,"like":2,"dislike":0,"score":2,"quote":{"pid":"0b6aa3454ff56b6ce8a287fc2834a324