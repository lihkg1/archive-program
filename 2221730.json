:3,"citedBy":1,"replyTime":"2020-09-28T14:49:19.000Z","msg":"<img src=\"https://i.pinimg.com/originals/3c/73/90/3c7390c2ea241d0d00141a0ff73adfe4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.pinimg.com%2Foriginals%2F3c%2F73%2F90%2F3c7390c2ea241d0d00141a0ff73adfe4.jpg&h=d108633f&s={SIZE}\" />"},{"pid":"f33369afa0d0cf4409e277e6baa06a8418604d16","tid":2221730,"uid":54337,"like":0,"dislike":0,"score":0,"quote":{"pid":"1198829f9a06c8961c90903ee9f41089906c5dc2","tid":2221730,"uid":54337,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-09-28T14:49:19.000Z","msg":"<img src=\"https://i.pinimg.com/originals/3c/73/90/3c7390c2ea241d0d00141a0ff73adfe4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.pinimg.com%2Foriginals%2F3c%2F73%2F90%2F3c7390c2ea241d0d00141a0ff73adfe4.jpg&h=d108633f&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-09-28T14:49:55.000Z","msg":"1940年6月4日<br />\n<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"28208f388cd160fe1a88194e873d5fa8ecea4507","tid":2221730,"uid":31151,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-09-28T14:51:32.000Z","msg":"美國參戰一刻 邱吉爾話大局已定<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"bdffb57585b17e740de31af6b1c3041400358b77","tid":2221730,"uid":54337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-28T14:55:25.000Z","msg":"【二戰歷史】【邱吉爾：We shall never surrender】面對納粹極權，我們絕不投降<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/2151814\" data-auto-link target=\"_blank\">https://lih.kg/2151814</a><br />\n<br />\n嘩屌<br />\n一個月前我討論邱吉爾二戰歷史<br />\n邊個引用邱公句說話<br />\n搞D乜嘅野呀大佬<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://i.redd.it/28l1etn3qhj31.jpg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fi.redd.it%2F28l1etn3qhj31.jpg&d=Wx0cKZaQlto0GELw8F4hIQOzzNjRw9ZJ5YgnvwIkb18%3D&h=7f46ffb1\" data-auto-link target=\"_blank\">https://i.redd.it/28l1etn3qhj31.jpg</a><br />\n<br />\n本人只係討論二戰英國立場<br />\n絕無射沙射影指桑罵槐借古諷今之意喎<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n我對天發誓<br />\n絕對無<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"110999b9899548441c954ef31017f49019ff3379","tid":2221730,"uid":54337,"like":1,"dislike":0,"score":1,"quote":{"pid":"28208f388cd160fe1a88194e873d5fa8ecea4507","tid":2221730,"uid":31151,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-09-28T14:51:32.000Z","msg":"美國參戰一刻 邱吉爾話大局已定<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-28T14:56:02.000Z","msg":"二戰嚟講，絕對係<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n我絕對明你意思<img src=\"/assets/faces/lm2/yeah.gif\" class=\"hkgmoji\" />"},{"pid":"2a33b36691a817d35bd7c11bfb2bcde20f34a95c","tid":2221730,"uid":54337,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-09-28T15:03:37.000Z","msg":"<img src=\"https://images-na.ssl-images-amazon.com/images/I/31caAp6LEJL._AC_.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimages-na.ssl-images-amazon.com%2Fimages%2FI%2F31caAp6LEJL._AC_.jpg&h=f94e2b27&s={SIZE}\" /><br />\n<br />\n只要堅持，一定會勝利 (victory) 。<br />\n<br />\n二戰英國邱吉爾真係擁有鋼鐵意志。<br />\n<br />\n邱公呢個動作，真係好有感染力，令到英國人上上下下，萬眾一心。<br />\n<br />\n邱公<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"000603fd16c4b1a7