na.cx%2Fi%2FHdZnMF4.jpg&h=fab1499e&s={SIZE}\" />"},{"pid":"3b589c091c1083728d6d20c599d428e068d5a2af","tid":1175733,"uid":31626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-29T15:00:25.000Z","msg":"擺低啲野之後就即刻去櫻島了<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/jKjrtZH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjKjrtZH.jpg&h=d79d976b&s={SIZE}\" /><br />\n<br />\n去櫻島嘅惟一方式就係坐船 船費張pass包埋<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/G5npfEJ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FG5npfEJ.jpg&h=a47cb66a&s={SIZE}\" /><br />\n<br />\n離遠都見到個火山噴梗煙<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/hmP3wc4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhmP3wc4.jpg&h=5eea96f1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/ZPVRE6q.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZPVRE6q.jpg&h=1fdeed14&s={SIZE}\" /><br />\n<br />\n時間有限 衹好坐觀光巴士遊櫻島<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/7AsXAEN.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7AsXAEN.jpg&h=b37d87ee&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/8SCAnjO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8SCAnjO.jpg&h=df94f972&s={SIZE}\" /><br />\n最後一班車<br />\n<img src=\"https://na.cx/i/9Dpvbc9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F9Dpvbc9.jpg&h=35a9cc2f&s={SIZE}\" /><br />\n原來而家啲觀光巴士衹會喺湯之平展望所停10分鐘 其他展望台都唔會稍作停留<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/FKZSpya.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFKZSpya.jpg&h=37997fec&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/nFeZOZR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnFeZOZR.jpg&h=babeddc1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/0Jysdrx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0Jysdrx.jpg&h=de754d0a&s={SIZE}\" />"},{"pid":"2553c9f126d732884eb1c57e82aaf395f1f7a0a0","tid":1175733,"uid":31626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-29T15:17:47.000Z","msg":"沿途啲風景其實好靚 唔怕悶親<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/nS6A6Rw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnS6A6Rw.jpg&h=d5b66303&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/neEvbic.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FneEvbic.jpg&h=c4c51b86&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/8NdvVKT.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8NdvVKT.jpg&h=8e382a6f&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/WDiWRie.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWDiWRie.jpg&h=5b187fd3&s={SIZE}\" /><br />\n<br />\n湯之平展望所<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/TikurRB.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTikurRB.jpg&h=f16aef9a&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/mv3LKDh.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fmv3LKDh.jpg&h=2d47927d&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/7ypvbjD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7ypvbjD.jpg&h=259126e4&s={SIZE}\" /><br />\n<br />\n之後坐番船出市區 即刻搵間拉麵醫下肚<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/xUzyTyz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxUzyTyz.jpg&h=025046ce&s={SIZE}\" /><br />\n<br />\n<br />\n<img src=\"https://na.cx/i/XszbFdA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXszbFdA.jpg&h=f70b5269&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/2mWdTyC.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F2mWdTyC.jpg&h=b5da4e6a&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/AoCsX0i.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAoCsX0i.jpg&h=cbe04138&s={SIZE}\" /><br />\n<br />\n黃雲 味噌拉麵<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/RnJLKFj.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRnJLKFj.jpg&h=eb318316&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/SsVNX0k.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSsVNX0k.jpg&h=57e13d52&s={SIZE}\" /><br />\n<br />\n之後去番鹿兒島中央車站嘅AEON超市買魚生當宵夜 哈根 可爾必斯啤酒<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/8trYkeQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8trYkeQ.jpg&h=da81ccb6&s={SIZE}\" /><br />\n<br />\n臨尾都係嫌未夠飽 落去街揾間拉麵再食過<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/674rt78