rmal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"30c22f63b4d6d79cc82dbdad88bb6f2e55a34974","tid":1457644,"uid":257527,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T12:18:52.000Z","msg":"唔沖佢，日日人多好過你勇武"},{"pid":"8ccfae29e32c5033d37246226b3cea2c9c5d4770","tid":1457644,"uid":61886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T12:19:21.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"937082ebfb3f8df6b17d6c91b82552b8c59b7a48","tid":1457644,"uid":238275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T12:40:02.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"cca52b1cb5c774260c5c48df1ab1e6c42d874aea","tid":1457644,"uid":254361,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-12T12:41:01.000Z","msg":"借位講幾句野<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" /><br />\n<br />\n我求下各位巴打絲打<br />\n用下個腦諗嘢<br />\n留又好，唔留又好請交給在場人士去決定<br />\n你哋唔好喺度發文喺度煽動<br />\n佢地成功分化我地了啦<br />\n<br />\n和理非非會驚好多野係正常<br />\n（唔驚又有行動力做左勇武）<br />\n但係但係呢到我有幾句野想講<br />\n<br />\n直面面對「恐怖」，知道它的「傷害」<br />\n理解會造成的「後果」，站起來、面對它<br />\n這才是「勇氣」，這才是「抗爭」<br />\n<br />\n<br />\n<br />\n唔知大家有沒有看過周星馳的電影「少林足球」<br />\n當然還有其他優秀的電影，如「讓子彈飛一會」等等<br />\n<br />\n「少林足球」里而的大反派說了這麼幾句 <br />\n<br />\n強雄：「我是打人,怎麼樣? 我要把你全隊的人打得像你一樣殘廢、殘廢、殘廢... 跟我鬥?」<br />\n強雄：「還有球證、旁證加上主辦、協辦所有的單位，全部都是我的人，怎麼和我鬥?」<br />\n<br />\n係呀點鬥呀，只剩下咩可以去鬥呀<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n加油呀，香港人<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n然後這再講返幾句名言<br />\n曼德拉語錄:<br />\n如果天空是黑暗的，那就摸黑生存;<br />\n如果發出聲音是危險的，那就保持沉默;<br />\n如果自覺無力發光，那就蜷伏於牆角。<br />\n但是，不要習慣了黑暗就為黑暗辯護;<br />\n也不要為自己的苟且而得意;<br />\n不要嘲諷那些比自己更勇敢的人。<br />\n我們可以卑微如塵土，但不可扭曲如蛆蟲。<br />\n&mdash;&mdash;曼德拉《漫漫人生路》"},{"pid":"3c65d5f0eabc04d2be263141bdeb25362f174065","tid":1457644,"uid":254044,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T12:46:19.000Z","msg":"721 811"},{"pid":"6b0af666650a3da1e1abfabbe9f9270a561cd290","tid":1457644,"uid":201581,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T14:07:21.000Z","msg":"推"},{"pid":"197df0181eb5cf528a07b35bb874c1470302e74c","tid":1457644,"uid":511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T14:23:43.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}