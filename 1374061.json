286,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T18:31:30.000Z","msg":"10"},{"pid":"b3fd7f7859019d9591032289657d1d70d781c1c0","tid":1374061,"uid":8286,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T18:34:05.000Z","msg":"11"},{"pid":"b86c5333299256fb862b2d85c9eea535d218b2b3","tid":1374061,"uid":8286,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T18:34:29.000Z","msg":"12"},{"pid":"b906f521ae61a58231a0152c2c833648ba3f1ef0","tid":1374061,"uid":45082,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b222114fbe852f38c20d5c2094532c06bfe4538","tid":1374061,"uid":8286,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-27T18:24:45.000Z","msg":"200個都冇<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-27T18:40:02.000Z","msg":"呢個時間好多人都瞓咗覺 聽日先再推啦"},{"pid":"ec051bf27e8d007a3ce6fbb64074ea8343db84e7","tid":1374061,"uid":246026,"like":0,"dislike":0,"score":0,"quote":{"pid":"a946a5576d66e84375389612e4e92eb32d4696ec","tid":1374061,"uid":8286,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-27T17:06:12.000Z","msg":"呢一兩個星期見到不論係大小公司/公營機構/政府部門都有一堆聯署信，要求政府盡快回應訴求，我諗每一個公司/機構都有大約10-20%既人係要政府盡快回應訴求。六、七月令每一個香港人都好痛心同憤怒，甚至其實有好多中間遊走既人都轉向屌鳩政府同黑警，其實真係一個好好既機會去無限期罷工<br />\n<br />\n罷工講咗十世，但始終一係罷得一日，根本唔足以影響政府/社會運作，好希望大家認真考慮無限期罷工<br />\n<br />\n相信呢個係一個最佳既不合作運動，就算只係得10%，甚至全部都係small potato 都好(當然都希望愈多人罷就愈安全，冇咁容易被人秋後算帳)，其實對公司既運作都有一定既影響，如果影響大的話甚至可以迫使到公司/機構/工會/商會要主動要求政府回應我地既訴求<br />\n<br />\n希望港鐵車長唔好覺得孤單，要罷一齊罷，唔好淨係要佢地付出<br />\n<br />\n做個好簡單既調查<br />\n<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />=真係會無限期罷工<br />\n<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />=要返工，不了"},"citedBy":0,"replyTime":"2019-07-27T18:40:57.000Z","msg":"[急] [ 突發] 聽日會出席嘅和理非同勇武入一入嚟<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1373809\" data-auto-link target=\"_blank\">https://lih.kg/1373809</a>"},{"pid":"70ec97a184efb1666ff688622595aa2ea72ccc19","tid":1374061,"u