 src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" />"},{"pid":"b38d969d62aca183210913afab465e7c2a5e50a9","tid":2308291,"uid":108337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-01T21:47:39.000Z","msg":"我想拎懸賞<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"26fde8aeaafd93d3e8ad135ae1198638bde3360e","tid":2308291,"uid":310867,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-01T22:36:32.000Z","msg":"<img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" />"},{"pid":"8ce67b86b38fc9d93433b2ca0f536684f94108ce","tid":2308291,"uid":310867,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-01T23:25:59.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"60596901d44aad5225f497cc739ad956c383d858","tid":2308291,"uid":1989,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-12-01T23:29:14.000Z","msg":"如果柒婆篤灰<br />\n國務院俾錢佢會唔會違反制裁令<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"c00fc027a7b114f1729633d34f81e2bee5992e10","tid":2308291,"uid":166308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-01T23:29:24.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"}]}