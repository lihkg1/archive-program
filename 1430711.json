248-8B19-0425C2CA0738_cx1_cy16_cw66_w1023_r1_s.jpg&h=f63d5961&s={SIZE}\" /><br />\n貼埋新聞入面張圖"},{"pid":"a7b89354487f3190affe704c64681691c59f5da4","tid":1430711,"uid":271539,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2019-08-07T21:50:28.000Z","msg":"<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},{"pid":"e6a06d55ee59838f12d6719821881c1afef79aa2","tid":1430711,"uid":271539,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2019-08-07T21:50:48.000Z","msg":"<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"a205b64c8825f862e4620616259d14f312f988ed","tid":1430711,"uid":131188,"like":163,"dislike":1,"score":162,"citedBy":1,"replyTime":"2019-08-07T21:51:01.000Z","msg":"其實好正常, 佢都係要俾番個警示自己國民<br />\n而家行行下街都隨時可能俾差佬打喎, 啲差佬又唔識英文, 俾著你都唔會去啦"},{"pid":"e19b9ec1a4b73c7da029b6856fea595ae399cbcd","tid":1430711,"uid":58841,"like":66,"dislike":2,"score":64,"citedBy":1,"replyTime":"2019-08-07T21:51:47.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"935485892fd92dbcc44fc61c41f026f7aba81965","tid":1430711,"uid":271539,"like":3,"dislike":37,"score":-34,"quote":{"pid":"048734182423b8b0f921a91e11f3496fe23477e6","tid":1430711,"uid":235754,"like":243,"dislike":4,"score":239,"quote":{"pid":"5c2dfab0225b0ba765db42682a24dc650b756079","tid":1430711,"uid":271539,"like":16,"dislike":260,"score":-244,"citedBy":6,"replyTime":"2019-08-07T21:33:50.000Z","msg":"咁即係對香港逆權人士信任度降低級別?"},"citedBy":1,"replyTime":"2019-08-07T21:43:38.000Z","msg":"點解唔可以係對香港所謂警察信任度降低級別呢？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-07T21:51:49.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"2246cf10a8937e931ef5f7553b0db1a7c5e0822d","tid":1430711,"uid":264457,"like":138,"dislike":0,"score":138,"citedBy":1,"replyTime":"2019-08-07T21:52:18.000Z","msg":"帶風狗屌你老母，<br />\n<br />\n支持美國旅遊警示啦，希望全世界都可以發出，咁就可以攪抄<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"e90c7b0c507e3f453ba01490a2645d6988c27067","tid":1430711,"uid":145909,"like":16,"dislike":1,"score":15,"citedBy":0,"replyTime":"2019-08-07T21:54:24.000Z","msg":"<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"},{"pid":"a4c3f378cd4e48e5cbc3de3ec8c9ddf346b99bf3","tid":1430711,"uid":271539,"like":24,"dislike":1,"score":23,"citedBy":1,"replyTime":"2019-08-07T21:54:56.000Z","msg":"<img src=\"https://na.cx/i/D676SeT.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FD676SeT.png&h=e27fac96&s={SIZE}\" /><br />\n籌備多時，謹此宣布「我要攬炒」團隊 正式聯同 大專學界，於下星期五8月16日晚上8時，於中環遮打花園舉辦萬人集會！<br />\n<br />\n務求國際本土戰線會師，發動第十陣攻勢，全力破局！<br />\n<br />\n816晚會主題是「英美港盟 主權在民」。我們期望以這個集會為契機，聚合本地及國際力量，抵擋政權打壓。<br />\n<br />\n六月至今，香港人努力不懈、萬眾一心，誓要改變香港眼下的種種黑暗。那怕是警隊襲擊市民、黑社會橫行無忌、當權者濫捕和抹黑抗爭者，香港人仍然堅守最後防線，保衛香港。<br />\n<br />\n攬炒團隊在此重申，我們定必無懼奮戰，永不割𥱊，堅守五大訴求，勢與港人同行到底。<br />\n<br />\n我們與學界深信本土、國際戰線唇齒相依，互為表裡，理應全力互相支援，以圖破局。<br />\n<br />\n因此，在8月16日的遮打萬人集會中，我們會就着過去兩個月的五大訴求之首（立即實行真雙普選，拒絕政治篩選），透過嘉賓演講和英國、美國和香港的短片分享，呼籲：<br />\n<br />\n(1) 英國確認中國違反《中英聯合聲明》國際條約<br />\n<br />\n(2) 英美國會各自制訂通過香港人權民主法案，制裁損害香港自治、自由、人權與民主的官員，如凍結他們的英美資產、禁止他們入境。<br />\n<br />\n假如中國決不撤回2014年的831決定、歸還香港應得的真普選，即使林鄭下台、展開獨立調查，過去兩個月的亂局只會一再重演，香港與中國將玉石俱焚。<br />\n<br />\n由二百年前開埠起，香港一直為世界的自由港、國際城市。此抗爭絕非僅僅是港人自主之戰，更是自由世界對抗極權的重要一役。<br />\n<br />\n願我們香港人於生死存亡之秋，以悲憤心情為鐵志，化慘痛經歷為睿智，在國際社會與本土層面跟中國極權以死相搏，重光香港。<br />\n<br />\n謹記 不是有希望才走下去，而是走下去才有希望。"},{"pid":"611fb96326d146dc7efa95cd83aee2bf048fc137","tid":1430711,"uid":119283,"like":7,"dislike":0,"score":7,"quote":{"pid":"e19b9ec1a4b73c7da029b6856fea595ae399cbcd","tid":1430711,"uid":58841,"like":66,"dislike":2,"score":64,"citedBy":1,"replyTime":"2019-08-07T21:51:47.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-07T21:55:15.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"bf1e186e724d845724a87a596886dbe9aff2a3e3","tid":1430711,"uid":271539,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-08-07T21:55:22.000Z","msg":"<img src=\"https://na.cx/i/TmWGGaz.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTmWGGaz.png&h=e225f9e9&s={SIZE}\" />"},{"pid":"55be5a93b57edc1dc4ea7c95faed9da6b2f0c882","tid":1430711,"uid":295353,"like":30,"dislike":0,"score":30,"citedBy":1,"replyTime":"2019-08-07T21:55:36.000Z","msg":"大家回覆呢個post嘅時候記得要開「不推文功能」<br />\n由得佢沉就OK<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/FcAz6UP.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFcAz6UP.png&h=9d244279&s={SIZE}\" />"},{"pid":"34a3605a16d9814f47712fdcb8d78649565ae6d8","tid":1430711,"uid":271539,"like":2,"dislike":3,"score":-1,"citedBy":0,"replyTime":"2019-08-07T21:55:44.000Z","msg":"<img src=\"https://media.giphy.com/media/RhkvtuUcntXSuoVzay/giphy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2FRhkvtuUcntXSuoVzay%2Fgiphy.gif&h=254e8117&s={SIZE}\" />"},{"pid":"d1eaa218defc86255be9ab4031f3f52731ff32f9","tid":1430711,"uid":51701,"like":7,"dislike":0,"score":7,"quote":{"pid":"3cc41975f72822788a14dc6889cd67dc5e8de663","tid":1430711,"uid":271539,"like":3,"dislike":69,"score":-66,"citedBy":1,"replyTime":"2019-08-07T21:40:34.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-07T21:56:14.000Z","msg":"想問下遊擊撚狗勁啲<br />\n定一日800 粒tg未計其他武器勁啲<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"4d2d143d81d0f8c22f733fc6d0a3825be2b6c19d","tid":1430711,"uid":271539,"like":1,"dislike":6,"score":-5,"quote":{"pid":"55be5a93b57edc1dc4ea7c95faed9da6b2f0c882","tid":1430711,"uid":295353,"like":30,"dislike":0,"score":30,"citedBy":1,"replyTime":"2019-08-07T21:55:36.000Z","msg":"大家回覆呢個post嘅時候記得要開