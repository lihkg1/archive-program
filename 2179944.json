hkgmoji\" />"},{"pid":"179b61add4332f86dbc307715f4617b48d4c3701","tid":2179944,"uid":107138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T15:11:41.000Z","msg":"<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"a42ca49a4119997a250de54aeb9c12bd8383765f","tid":2179944,"uid":67105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T15:12:16.000Z","msg":"當然"},{"pid":"3727bc5a4412ce1df332616947901acc2eba1701","tid":2179944,"uid":65439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T15:14:55.000Z","msg":"呢樣野好撚基本 <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"ae7fda9f2bb222210951320e68ed9672a970544e","tid":2179944,"uid":149566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T15:16:42.000Z","msg":"always<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"7a4259d1c7f8fcaa1fcf8d01fe417ee9571e09cb","tid":2179944,"uid":329415,"like":0,"dislike":0,"score":0,"quote":{"pid":"5569671e805b497760a418251f967f73238baa3e","tid":2179944,"uid":264429,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-29T13:13:46.000Z","msg":"<img src=\"https://na.cx/i/0aoJQd3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0aoJQd3.jpg&h=1f3728e5&s={SIZE}\" /><br />\n<br />\n<em><strong><span class=\"red\"><span class=\"x-large\">【8.31 重拾罷鐵初衷】</span></span></strong></em><br />\n<br />\n國安法生效至今，不少人都感到無力，不知道前路何去何從。然而，每天日常生活中仍有很多可做之事，罷搭黨鐵便是其一。<br />\n<br />\n你還記得8.31當日的憤怒嗎？魔警於黨鐵將市民打到頭破血流，急救員跪地哭求仍無法入站救人。黨鐵事後更拒絕公開閉路電視片段，罷鐵風潮因而展開。至今，當日死傷數字未明，魔警及黨鐵卻在法網外逃之夭夭。然而，不少同路人亦因各種原因，重新拍卡走進了黨鐵月台。<br />\n<br />\n星期一將是8.31一周年，讓我們重拾初衷，全民罷搭黨鐵，堅守生活中每一寸可抗爭的土壤。<br />\n<br />\n抗爭未竟，唯拒絕遺忘、堅持到底，才能看見出路。"},"citedBy":0,"replyTime":"2020-08-29T15:26:15.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"4f4a25f0225f3477b7fbd6d5219d0408401456b4","tid":2179944,"uid":89517,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T15:32:24.000Z","msg":"<img src=\"/assets/faces/big/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b1361c6054e23d1be9aba41a51982bd3d01497d7","tid":2179944,"uid":115579,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T15:49:52.000Z","msg":"推！"},{"pid":"a51bf6124efcf3f5dfc779e81c8bd4fe1b4eeafe","tid":2179944,"uid":146535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T15:50:31.000Z","msg":"推"},{"pid":"a52c0e41cf0b5382865ec921cb99a75837333fb9","tid":2179944,"uid":233338,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T15:55:14.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"fb669351db895a267c9eff27bedd8b50bf3dd204","tid":2179944,"uid":96091,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T15:59:48.000Z","msg":"推"},{"pid":"7d61f7f3277370de24844733f61acb7aa5f5e31e","tid":2179944,"uid":96091,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T15:59:59.000Z","msg":"推"},{"pid":"af2f23ce6e0c7c37a3ad3c4e00f4651c2e543a81","tid":2179944,"uid":96091,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T16:00:10.000Z","msg":"推"},{"pid":"c698626d54d3317d32ac458dd6ed945d58168809","tid":2179944,"uid":96091,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T16:00:31.000Z","msg":"罷咗成年"},{"pid":"eb13325e47e38d334322304f923d5274ca453ce1","tid":2179944,"uid":225100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-29T16:08:22.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"4cb549be31b35f7179d107d5d53393bf6c509e79","tid":2179944,"uid":78769,"like":0,"dislike":0,"score":0,"cited