normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-02T09:04:39.000Z","msg":"咁又唔同,好似索隆一開始拎到秋水果陣,出劍風效果都勁好多"},{"pid":"1b017cd6e8f92dedf76e690673d2f7229b997851","tid":764414,"uid":109629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-02T09:09:31.000Z","msg":"見到佢係到抽牌諗起遊戲王<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"87cb47ef7b11eef8ced283341d7046a16228d67c","tid":764414,"uid":52265,"like":0,"dislike":0,"score":0,"quote":{"pid":"e85e699af265417b30cdd41fbc49d9c77039072b","tid":764414,"uid":8636,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-08-02T07:49:56.000Z","msg":"霍金斯點成大器呀<br />\n啲招咁撚陰濕 玩尻自己友<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-02T09:21:59.000Z","msg":"基德<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"63163442e51ce9ddff5b92450ce2519643bb08c8","tid":764414,"uid":43785,"like":10,"dislike":1,"score":9,"citedBy":0,"replyTime":"2018-08-02T09:36:48.000Z","msg":"913 鶴的報恩<br />\n扉頁：17點，在感謝中出航，作為海賊的首秀大失敗<br />\n霍金斯問你們知道現在控制著這個國家的是誰嗎<br />\n路飛：是凱多對吧！<br />\n索隆：錦衛門也說這些是不能說的&hellip;&hellip;<br />\n路飛：剛才的是騙人的！<br />\n霍金斯：&hellip;&hellip;你們一個月以後還能活下來的機率是19%<br />\n霍金斯的手下迫近，索隆對路飛手裡拿著的刀非常感興趣<br />\n路飛自滿的說這是名刀對吧？<br />\n因為真的覺得有名刀的感覺，所以索隆拜託路飛把刀給他看看<br />\n路飛無視了索隆的請求，直接用握著刀的手打了過去，手下們乘著坐騎衝了過來<br />\n但是路飛抓住了蜥蜴，把蜥蜴朝著霍金斯扔了過去<br />\n霍金斯用了刀身是稻草的刀，用稻草備手刀刺殺了蜥蜴<br />\n索隆對著霍金斯的臉砍了過去，結果霍金斯無傷<br />\n霍金斯用稻草的能力在手下那裡存好了作為分身的稻草人偶<br />\n對霍金斯造成的傷害會通過稻草人偶轉到手下身上<br />\n稻草備手刀的刀身變成了巨大的咒術師的樣子<br />\n霍金斯說開始遊戲吧，然後抽出了手裡拿著的一張塔羅牌<br />\n抽到的愚者的逆位（倒過來的卡牌）<br />\n因為卡牌的效果，霍金斯的手下們開始鬧矛盾<br />\n不知道為什麼開始焦急的狛犬，然後離開了索隆和路飛<br />\n好像是因為阿玉的身體開始惡化了，所以不能耽誤時間了要趕緊去找醫生<br />\n霍金斯又抽出了另一張卡<br />\n抽到的是法王的逆位，是追擊的卡牌<br />\n稻草備手刀的刀身開始朝著狛犬追了過去<br />\n乘坐在狛犬的後背上準備迎擊的路飛和索隆<br />\n稻草備手刀的刀身好像和霍金斯自身是連接在一起的，霍金斯揮了一下劍，然後刀身也開始揮自己手裡的帶著尖刺的棒子<br />\n索隆用二斬登樓砂文砍斷了刀身，但是受傷的卻是霍金斯的一個手下<br />\n霍金斯的手裡握著法王、援護之卡<br />\n預言到了路飛他們會因為某人的援助而從這裡逃脫，所以放棄了追擊<br />\n坐在狛犬的背上移動的時候，一個女人過來說要表達謝意<br />\n那個是在和路飛匯合前，索隆從惡人手裡救下的女性<br />\n在剛才的騷動中一直躲在狛犬的尾巴里<br />\n她的名字叫鶴，在附近的城鎮裡經營著茶屋<br />\n阿鶴好像認識阿玉，所以提議把阿玉帶到自己的店裡然後服藥<br />\n和之國，九里【殘鎮】<br />\n在阿鶴的茶屋裡，看板娘阿菊在被和之國的頂尖相撲力士【橫綱的浦島】搭話<br />\n浦島說如果你成為了我的花嫁，那就可以不用工作，在農園裡享受美味的飯了<br />\n就在這時路飛他們到達了<br />\n阿鶴立馬讓阿菊去準備藥<br />\n在稍微有一點距離的山上，用望遠鏡看著這裡的情況的紅心海賊團<br />\n企鵝：沒錯吧那個？是草帽他們吧！ ？<br />\n貝波：要在引起騷亂前去叫他們嗎？<br />\n虎鯨：你太顯眼了啊，貝波<br />\n<br />\n本周合刊，下下周再會"},{"pid":"a19d6c6353378a3de07e79b47771ec06948ab59b","tid":764414,"uid":12438,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-02T09:52:26.000Z","msg":"好奇怪<br />\n點解佢地用劍會有火有冰<br />\n<br />\n卓洛打龍馬疆屍個陣已經都到隻龍馬著火"},{"pid":"663ecdeff2d5c18af2813fb78dde98431097257c","tid":764414,"uid":25831,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-02T09:57:43.000Z","msg":"此回覆已被刪除"},{"pid":"72061d9ad8b4c16862062c27548ae86382e8bbcd","tid":764414,"uid":12438,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-08-02T09:59:24.000Z","msg":"不過相比外行員，我覺得阿後game講得好似正d"},{"pid":"42e55fbba98464effabab2ccfef1a8254410313c","tid":764414,"uid":110832,"like":4,"dislike":0,"score":4,"quote":{"pid":"da69405705f4cad7ec59739458ffa8ccc3f6ba05","tid":764414,"uid":52122,"like":0,"dislike":0,"score":0,"citedBy":6,"replyTime":"2018-08-02T04:25:20.000Z","msg":"其實有名刀係點<br />\n我意思係名刀既定位係點樣 <br />\n你武裝色夠勁乜野名刀都無用架喎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n定係佢好似錦衛門咁識出火<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-02T10:13:45.000Z","msg":"又係啲戇鳩問題<br />\n咁如果兩條友武裝色不分上下<br />\n自然要靠其他野分高下啦"},{"pid":"61a3b7e8eb53299e499fc5578b4d790e23e5d86d","tid":764414,"uid":37326,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-02T10:18:34.000Z","msg":"正阿， 羅又出場啦<img src=\"/