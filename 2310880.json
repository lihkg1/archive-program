1563449-20201203.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1563449-20201203.htm&d=tqH%2BXDs9hgzl%2F07an0tGPXHDV1nRQV6f8GM9BbigJgY%3D&h=c1d28c6a\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1563449-20201203.htm&h=8ddbb89a\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1563449-20201203.htm</a>"},"citedBy":0,"replyTime":"2020-12-03T16:42:24.000Z","msg":"收嗲啦11驊"},{"pid":"e8203aef94b5a97fa541f1721a32f150da5b7198","tid":2310880,"uid":55941,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-03T16:43:37.000Z","msg":"政治檢控 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n又食左豆沙包"},{"pid":"40f816cd79fd7e4b4c2ffeb4fb0d3e9e718e083b","tid":2310880,"uid":247896,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-03T16:49:36.000Z","msg":"大家都好驚疑犯模仿湯渣11做法<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"719bd29aebadbbb0fe2abe24261c5962431bc67a","tid":2310880,"uid":45836,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-03T16:52:22.000Z","msg":"仲咩唔派3萬精兵去丹麥捉人牙?"},{"pid":"92db1c4fb764f9b80f00512b2716f82976539dbb","tid":2310880,"uid":267178,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa27de9ada32f810ef6f7ca0380367d173ef9fd6","tid":2310880,"uid":42434,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-12-03T15:31:32.000Z","msg":"湯家驊表示，香港與世界各地移交疑犯的協議差不多已經不存在，增加了疑犯棄保潛逃的誘因。<br />\n<br />\n<br />\n又話唔可以做逃犯天堂既<br />\n明明立埋國安法<br />\n而家點算<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-03T17:13:37.000Z","msg":"只係外國變逃犯天堂。中國又贏。"},{"pid":"78da5403a5d640e2f761f584df615a52a2e682c2","tid":2310880,"uid":289900,"like":1,"dislike":0,"score":1,"quote":{"pid":"478563b4ec72317d8d89709c83a1c8a71dea2