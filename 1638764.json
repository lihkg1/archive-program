tu.be%2FccIoQ2kXTdE&d=NaStGCRJdOSKaO4BfYueNrXdyKWV89KwSxbYnQ5zRIM%3D&h=bd7a8607\" target=\"_blank\">https://youtu.be/ccIoQ2kXTdE</a><br />\n<br />\nI found this video only and it&rsquo;s a bit old <img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-08T12:40:04.000Z","msg":"It&rsquo;s pathetic that we never try to do the math. <br />\nFeel so sorry about the &ldquo;suicide cases&rdquo; <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1adffce6531f805467ee825a03cef6a95c7f4497","tid":1638764,"uid":243366,"like":0,"dislike":0,"score":0,"quote":{"pid":"eeee6fbb5a2c4e0f84812bc6eb90a601f5669e85","tid":1638764,"uid":56260,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-08T12:37:37.000Z","msg":"post with #AskLIHKG and see if we could catch your question<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-08T12:40:27.000Z","msg":"We can always catch you, try me <img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"23d47cb94425dda4e8135859315e0945dbedd37d","tid":1638764,"uid":243366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T12:54:53.000Z","msg":"Tui <img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" />"},{"pid":"20441c84ebe629a2dd84dc84d8c16739909dae59","tid":1638764,"uid":243366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T12:59:32.000Z","msg":"<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" />"},{"pid":"a7fd3b89db120c8a2a5e15d47d55aab068f22120","tid":1638764,"uid":193721,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-10-08T13:00:59.000Z","msg":"<a href=\"https://csrp.hku.hk/statistics/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fcsrp.hku.hk%2Fstatistics%2F&d=NaStGCRJdOSKaO4BfYueNrXdyKWV89KwSxbYnQ5zRIM%3D&h=1533cc3e\" data-auto-link target=\"_blank\">https://csrp.hku.hk/statistics/</a><br />\nIf you take a look here, there are more than 900 suicide deaths annually over the pass few years.<br />\n<br />\nFrom here: <a href=\"https://docs.google.com/spreadsheets/d/1o3TcfJm2NdpeSQ3OAg-peEHlO2pKn9wZaMe2OiWiknQ/edit#gid=0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdocs.google.com%2Fspreadsheets%2Fd%2F1o3TcfJm2NdpeSQ3OAg-peEHlO2pKn9wZaMe2OiWiknQ%2Fedit%23gid%3D0&d=NaStGCRJdOSKaO4BfYueNrXdyKWV89KwSxbYnQ5zRIM%3D&h=f47345f1\" data-auto-link target=\"_blank\">https://docs.google.com/spreadsheets/d/1o3TcfJm2NdpeSQ3OAg-peEHlO2pKn9wZaMe2OiWiknQ/edit#gid=0</a><br />\nIn short, in 2019, there are 819 attempted suicide case, 566 death, (avg. 2.91 daily), 93 during Sep (avg. 3.1 daily). and is 1.45% higher than the three month average (92 per month)<br />\nTens or twenty suspicious death doesn't have a big impact on the rate, as the set of data is huge.<br />\n<br />\n<br />\nHowever, there are several reason that creates suspicious case. <br />\n1. report by <a href=\"http://on.cc\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fon.cc&d=NaStGCRJdOSKaO4BfYueNrXdyKWV89KwSxbYnQ5zRIM%3D&h=1d83c3f0\" data-auto-link target=\"_blank\">on.cc</a> 東網 within 20 min after the death is discovered.<br />\n2. tied up with stones or heavy object and found in the sea<br />\n3. jumped off a building but people nearby did not heard a loud sound.<br />\n4. dead body was found at a location that is quite far from a jump-able location of a building<br />\n5. HKPF declare the case is not suspicious after a short research<br />\n6. a lihkg post predicted a location before the death was discovered<br />\n7. no disclosure of CCTV related to 831 incident<br />\n<br />\nI DO NOT have an exact number, but the number itself is not suspicious. The details of some case is what make them suspicious. <br />\n<br />\nRIP."},{"pid":"0f01a9dd0678003aae9991fd33d1df26b21548c8","tid":1638764,"uid":243366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T13:17:19.000Z","msg":"Tui <img src=\"/assets/faces/pig/bye.gif\" class=\"hkgmoji\" />"},{"pid":"d3e6893f5565a145ebbebefdfd439ad7798ab841","tid":1638764,"uid":199523,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T13:19:59.000Z","msg":"upvote"},{"pid":"f51d58360bc9b695c5fe7d1db007c49880c4f420","tid":1638764,"uid":189650,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T13:36:31.000Z","msg":"bump, feel free to ask or share everything using #AskLIHKG in twitter"},{"pid":"01036f3918832b86e9189c70ee4f84fc85b30750","tid":1638764,"uid":243366,"like":1,"dislike":0,"score":1,"quote":{"pid":"a7fd3b89db120c8a2a5e15d47d55aab068f22120","tid":1638764,"uid":193721,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-10-08T13:00:59.000Z","msg":"<a href=\"https://csrp.hku.hk/statistics/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fcsrp.hku.hk%2Fstatistics%2F&d=NaStGCRJdOSKaO4BfYueNrXdyKWV89KwSxbYnQ5zRIM%3D&h=1533cc3e\" data-auto-link target=\"_blank\">https://csrp.hku.hk/statistics/</a><br />\nIf you take a look here, there are more than 900 suicide deaths annually over the pass few years.<br />\n<br />\nFrom here: <a href=\"https://docs.google.com/spreadsheets/d/1o3TcfJm2NdpeSQ3OAg-peEHlO2pKn9wZaMe2OiWiknQ/edit#gid=0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdocs.google.com%2Fspreadsheets%2Fd%2F1o3TcfJm2NdpeSQ3OAg-peEHlO2pKn9wZaMe2OiWiknQ%2Fedit%23gid%3D0&d=NaStGCRJdOSKaO4BfYueNrXdyKWV89KwSxbYnQ5zRIM%3D&h=f47345f1\" data-auto-link target=\"_blank\">https://docs.google.com/spreadsheets/d/1o3TcfJm2NdpeSQ3OAg-peEHlO2pKn9wZaMe2OiWiknQ/edit#gid=0</a><br />\nIn short, in 2019, there are 819 attempted suicide case, 566 death, (avg. 2.91 daily), 93 during Sep (avg. 3.1 daily). and is 1.45% higher than the three month average (92 per month)<br />\nTens or twenty suspicious death doesn't have a big impact on the rate, as the set of data is huge.<br />\n<br />\n<br />\nHowever, there are several reason that creates suspicious case. <br />\n1. report by <a href=\"http://on.cc\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fon.cc&d=NaStGCRJdOSKaO4BfYueNrXdyKWV89KwSxbYnQ5zRIM%3D&h=1d83c3f0\" data-auto-link target=\"_blank\">on.cc</a> 東網 within 20 min after the death is discovered.<br />\n2. tied up with stones or heavy object and found in the sea<br />\n3. jumped off a building but people nearby did not heard a loud sound.<br />\n4. dead body was found at a location that is quite far from a jump-able location of a building<br />\n5. HKPF declare the case is not suspicious after a short research<br />\n6. a lihkg post predicted a location before the death was discovered<br />\n7. no disclosure of CCTV related to 831 incident<br />\n<br />\nI DO NOT have an exact number, but the number itself is not suspicious. The details of some case is what make them suspicious. <br />\n<br />\nRIP."},"citedBy":1,"replyTime":"2019-10-08T13:39:27.000Z","msg":"Gwei lo say thank you <img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://twitter.com/michaeltitter/status/1181561895464996865?s=21\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Fmichaeltitter%2Fstatus%2F1181561895464996865%3Fs%3D21&d=NaStGCRJdOSKaO4BfYueNrXdyKWV89KwSxbYnQ5zRIM%3D&h=fa88114e\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftwitter.com%2Fmichaeltitter%2Fstatus%2F1181561895464996865%3Fs%3D21&h=9e9967f3\" data-auto-link target=\"_blank\">https://twitter.com/michaeltitter/status/1181561895464996865?s=21</a><br />\n<img src=\"https://na.cx/i/LMG06OT.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLMG06OT.png&h=60f5fd39&s={SIZE}\" />"},{"pid":"9c5b8d483ba2fa736f03d4e08331648c3ebe000e","tid":1638764,"uid":244149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T13:42:37.000Z","msg":"I wonder if any foreigners are here<br />\nSay hi<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}