es/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"a4407d20b9eb27bc1d1b50eb58d24f92dff7a2b1","tid":34111,"uid":31314,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T12:18:26.000Z","msg":"成班cc台憤青唔敢入嚟講野呀？<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e0cb745c9b3a93f1ada93b92c8ff1762d65efab0","tid":34111,"uid":4722,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T12:35:54.000Z","msg":"波C戰爭2.0"},{"pid":"40f050f1de3a0de1cd6aca0831d9ac288df189a9","tid":34111,"uid":2588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T12:38:47.000Z","msg":"ching好波<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b491c2e719b7e1c80a82baf6a448b7d7557c36e6","tid":34111,"uid":29784,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T12:39:40.000Z","msg":"吹呀"},{"pid":"9297ece16f5ad744624e188e4f59703d75367749","tid":34111,"uid":3659,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T12:55:40.000Z","msg":"<blockquote>每個台都有自己文化架啦<br />\n人不犯我，我不犯人<br />\n人地冇搞到你，你又何必拙拙迫人呢？<br />\n好似動物台咁，人地用咩睇片關你撚事咩？你憑咩去反對人地用大陸app睇片。仲話唔好睇中文字幕，要睇英文字幕。<br />\n你又唔去屌潮流台班人上淘寶？On9！<br />\n<br />\n波台又係，每個台都有自己文化，佢地鍾意打5p字咪由得佢地，佢地有冇係cc台打5p字？有冇搞到你地？咁你地又可必話入侵波台，收返波台等等？<br />\n<br />\n根本好多野都係你地一班憤青，睇唔過眼人地做既野而發生，人地講野唔啱聽，5毛，打5p字，5毛<br />\n總之乜柒都係錯既，cc台就最好最勁，咁你地玩撚埋佢啦！慢慢鍵國啦！</blockquote><br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 冇人叫你走過去其他台開埋d 膠post博屌架喎<br />\n如果真係人不犯我 我不犯人嘅話<br />\n點解係大事大非嘅時候/認真post會有假膠係到覆埋d垃圾？<br />\n有時候有d野唔係立即爆發，而係經過一次又一次嘅容忍累積落去，最後先頂唔順爆發<br />\n你係認真post玩膠，阻住人討論事少，但分分鐘因爲你依句引起罵戰，搞到一個正常post冇得討論落去事大啊<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n同埋你上高登唔會單單上一個台啊化？<br />\n咁有時侯見到d討厭嘅，開post批評下或者討論下有問題咩？討論區唔係拎黎討論拎黎做咩？<br />\n上得高登/連登，自然大家就有共識，就係唔撚鍾意支那，除非你第一日上啦。唔鍾意人地批評你支那嘅咪上香討uwant囉，你或者會開心d。<br />\n<br />\n仲有，你知唔知點解高登會搞成依家咁？就係因為堆打手同埋五毛，搞到高登烏煙瘴氣，冇得正常討論。喂大佬，五毛係依到不嬲都係過街老鼠啦，唔通你認同佢果套，覺得佢地講嘅歪理係岩嘅？<br />\n<br />\n當然，邊個台都有害群之馬，依樣各位應該最清楚<br />\n我唔知你點解會聯想到去獨派，對社會現況不滿有錯咩？照你咁講，你都係憤青喎<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d52d891547f6dd29fe3a4000bcfc8a248bdee209","tid":34111,"uid":13468,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T12:58:42.000Z","msg":"cc台都一班專橫跋扈嘅憤青，不願面對現實社會"},{"pid":"bb24128f4e9439871a42f98f1ee3ed08c2acffb5","tid":34111,"uid":16343,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T12:59:29.000Z","msg":"時事台班垃圾 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"adabc6a1a867051d34c69c02c6c965be34d4569d","tid":34111,"uid":3659,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T13:03:09.000Z","msg":"每個人對一件事可以有唔同反應<br />\n例如5p字咁，有d人覺得冇咩問題，或者有d人對此敏感d，好正常。但有時你不斷挑戰其他人底線，咁就唔好怪人批評你"},{"pid":"581f2dc5145ebe10e05e881c7c2cb297d759512c","tid":34111,"uid":24227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T13:04:14.000Z","msg":"又波時之爭<br />\n戇鳩仔咁睇得起自己 <img src=\"/assets/faces/fs/jj.gif\" class=\"hkgmoji\" />"},{"pid":"13fcb23592775f22425493c859023743e6c0fe1f","tid":34111,"uid":3659,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T13:05:48.000Z","msg":"<blockquote>cc台都一班專橫跋扈嘅憤青，不願面對現實社會</blockquote><br />\n<br />\n面對社會現況<br />\n有人會選擇對抗<br />\n有人會選擇去挑戰<br />\n<br />\n但總好過去放棄去逃避，默默接受囉<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> 香港沉淪某程度就係香港人太軟弱<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"21ecae7b10b9488e958e7f88ca2a40d2909e3922","tid":34111,"uid":3659,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T13:06:43.000Z","msg":"<blockquote><blockquote>cc台都一班專橫跋扈嘅憤青，不願面對現實社會</blockquote><br />\n<br />\n面對社會現況<br />\n有人會選擇對抗<br />\n有人會選擇去挑戰<br />\n<br />\n但總好過去放棄去逃避，默默接受囉<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> 香港沉淪某程度就係香港人太軟弱<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n所以你話佢地唔願意面對現實？sorry,其實佢地日日都面對嘅現實"}]}