normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"fed2c3b7656a3fe340246c6524a6736cb8e0385d","tid":1771883,"uid":249015,"like":5,"dislike":1,"score":4,"citedBy":0,"replyTime":"2019-12-06T08:27:59.000Z","msg":"屌做男人爽啲啦，直接同佢講<br />\n跪低! 含!<br />\n如果佢報警你咪知即係收左皮囉<br />\n簡單<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"b9a8d32202af9d3e1a21615f246539c035ef82c5","tid":1771883,"uid":30176,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2019-12-06T08:29:11.000Z","msg":"你根本想追人<br />\n<br />\n唔通巴打叫你收皮 唔好去<br />\n你會真係唔去咩<br />\n<br />\n你開Post都係想有人支持你<br />\n<br />\n<br />\n巴打 年青無女<br />\n想去就去啦<br />\n唔得咪下個<br />\n<br />\n唔洗咁多思考"},{"pid":"5a9033f964e2993b6d24f2e31d600ea1f19504b3","tid":1771883,"uid":316979,"like":13,"dislike":0,"score":13,"quote":{"pid":"86314c06c11617e894880c0cec9b0b9155dd3005","tid":1771883,"uid":137134,"like":45,"dislike":1,"score":44,"citedBy":3,"replyTime":"2019-12-06T07:34:13.000Z","msg":"約下人出一次街就知可唔可以追 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-06T08:30:00.000Z","msg":"冇錯  約出街最實際<br />\n由遊行開始  之後行山  行街  睇戲  送佢番屋企<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><br />\n每個星期約一次  好快到手<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"490344231021a0eabecde8f038e01a070dacd0cb","tid":1771883,"uid":51436,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-06T08:30:42.000Z","msg":"追左你就知"},{"pid":"f219a799d4ba2e1dbb9f9026d3ac2f42c165eafd","tid":1771883,"uid":4586,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-06T08:31:28.000Z","msg":"你唔可以追"},{"pid":"a35b664575d99dfca43a144c3a45152c375d9bf7","tid":1771883,"uid":2772,"like":0,"dislike":0,"score":0,"quote":{"pid":"aecfa67b4fbf33ec90b0f3cd9634a7f5eab5872d","tid":1771883,"uid":17429,"like":