imgur.com/h69ddRQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2Fh69ddRQ.jpg&h=f6b69be8&s={SIZE}\" /><br />\n<br />\n<img src=\"https://i.imgur.com/RNAEIWK.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FRNAEIWK.jpg&h=17bbedff&s={SIZE}\" /><br />\n<br />\n<img src=\"https://i.imgur.com/Mwe8g3u.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FMwe8g3u.jpg&h=49acdf55&s={SIZE}\" /><br />\n<br />\n兩年前入咗部死黑Fujil<br />\n不過夜空timelapse仲未學影<br />\n樓下行人路兩旁嘅樹又仲未影<br />\n新入相機個時轉影街拍<br />\n去到最近幾個月  星期一到五都做野做到好勞累<br />\n週未都係屋企  無再有心力出去掃街<br />\n<br />\n樓主問起  先醒返下最初做乜想買部相機<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-09T01:43:04.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 既然記得起最初既原因<br />\n就記得去實踐返啦<br />\n襯住夏天銀河依加唔算好夜可以去挑戰下<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"02a7833dc6c2b6bec1e1b9468d8a19bd35a8b4f2","tid":772133,"uid":51747,"like":2,"dislike":0,"score":2,"quote":{"pid":"a588a158f649cfae002af619b2ba1fb849259d5c","tid":772133,"uid":110463,"like":0,"dislike":0,"score":0,"quote":{"pid":"c7a0e23d59a695a77eef71380114e27db2727607","tid":772133,"uid":51747,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2018-08-08T14:28:51.000Z","msg":"2000年月全食<br />\n<br />\n叫亞爸教我用佢部FM2<br />\n然後就一條友出咗文化中心通頂影相<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-09T01:26:47.000Z","msg":"一個人通頂影月亮？<br />\n作為開始都幾深刻<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-09T01:50:43.000Z","msg":"<img src=\"https://farm3.staticflickr.com/2648/4121697607_08f5ed52e9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffarm3.staticflickr.com%2F2648%2F4121697607_08f5ed52e9.jpg&h=8b7f736c&s={SIZE}\" /><br />\n<br />\n深刻，但都記錯咗日期，原來係2001<img src=\"/assets/faces/normal/sosad.