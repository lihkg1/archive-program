729f6f29b2b4eb1a3f9171e819acaa44c1f5a1e","tid":509261,"uid":82394,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-12-25T13:50:11.000Z","msg":"去茶記飲熱華田/立克唔會落糖"},{"pid":"3bd62c700e95e81d13edc22575d7b6884410e599","tid":509261,"uid":8439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T13:56:04.000Z","msg":"好耐無飲過有甜既茶記野飲了"},{"pid":"9a037b46a50547167d5794bf66b007c938363ce7","tid":509261,"uid":85205,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-12-25T13:56:53.000Z","msg":"我以前會飲甜不過宜家又係飲唔到甜，反而食甜野又ok<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" />  唔知點解<br />\n宜家茶記淨係飲熱檸水，連咩好立克阿華田都飲唔到<br />\n之前屋企人話我因為食太多甜野，搞到糖尿有d問題先突然飲唔到甜<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" />"},{"pid":"3b78088257f569db8fb59edfae1d5bc388921dad","tid":509261,"uid":1954,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-12-25T13:58:10.000Z","msg":"食得多糖真係好快老<br />\n而家飲品都唔會落糖<br />\n不過仲好鍾意食軟糖<br />\n戒唔到<img src=\"/assets/faces/xm/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"26547bc1e70c01912fe3e9014dbb25ba88e6896c","tid":509261,"uid":41243,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T14:14:33.000Z","msg":"唯一會飲既甜嘢就係牛奶或者蛋白粉<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c73133f63c91753ad63cb35c4ce0e65dee88fd25","tid":509261,"uid":129586,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-12-25T14:30:35.000Z","msg":"基本上已經唔會叫甜嘅嘢飲<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <br />\n唔想飲水就自己沖一泡茶慢慢嘆<img src=\"/assets/faces/xm/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c15cc5a1c79ce4b4d81ef7bae35ade15cb26d53d","tid":509261,"uid":22355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T14:36:45.000Z","msg":"我一半一半<br />\n叫野飲少甜甚至唔落糖<br />\n紙包/汽水呢啲極少飲但絕對唔會飲少甜<br />\n糖又係極少食<br />\n但食飯餸口味依然偏甜"},{"pid":"8905fe816a71fdff01c2f25eb3070daf1b4e7e03","tid":509261,"uid":100760,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T14:41:21.000Z","msg":"人越大就越鍾意飲水"},{"pid":"d8f026b6497d48c0a74a7527a7c4756a7ce1b09d","tid":509261,"uid":52542,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T14:44:27.000Z","msg":"食少左甜嘢，對魚生都無乜興趣 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n口味轉左"},{"pid":"04f96e8eacdac4454b54c062c18aecd4420279b3","tid":509261,"uid":30694,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T14:47:41.000Z","msg":"出街每次都係凍檸水/茶走甜，唔知點解唔想飲甜野，已經飲左走甜幾年"},{"pid":"da0062010d0666a9d69d1e9699f410047385a0dc","tid":509261,"uid":34771,"like":0,"dislike":0,"score":0,"quote":{"pid":"733cde1f720a8088ee5afb1c20f291e73c143473","tid":509261,"uid":15813,"like":4,"dislike":1,"score":3,"citedBy":2,"replyTime":"2017-12-25T11:54:43.000Z","msg":"咁你食royal級日本桃會點<img src=\"/assets/faces/xm/@.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2017-12-25T16:01:46.000Z","msg":"都唔會買到<img src=\"/assets/faces/xm/slick.gif\" class=\"hkgmoji\" />"},{"pid":"23a63f0e2f55347867574025b66104321baf89c0","tid":509261,"uid":29405,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-12-25T16:02:31.000Z","msg":"維他檸檬茶低糖貴過普通嘅<img src=\"/assets/faces/xm/clown2.gif\" class=\"hkgmoji\" />"},{"pid":"ed31bae7b4b4432fc9e44fc92cadcbecf4fc9c69","tid":509261,"uid":34771,"like":1,"dislike":0,"score":1,"quote":{"pid":"c73133f63c91753ad63cb35c4ce0e65dee88fd25","tid":509261,"uid":129586,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-12-25T14:30:35.000Z","msg":"基本上已經唔會叫甜嘅嘢飲<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <br />\n唔想飲水就自己沖一泡茶慢慢嘆<img src=\"/assets/faces/xm/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2017-12-25T16:02:36.000Z","msg":"飲茶最舒服<img src=\"/assets/faces/xm/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d1624469382842aa0f62cbc5e0dac25881266a77","tid":509261,"uid":75100,"like":0,"dislike":0,"score":0,"quote":{"pid":"23a63f0e2f55347867574025b66104321baf89c0","tid":509261,"uid":29405,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-12-25T16:02:31.000Z","msg":"維他檸檬茶低糖貴過普通嘅<img src=\"/assets/faces/xm/clown2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2017-12-25T16:03:42.000Z","msg":"仲要浸味唔同架，好難飲<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2dbcbc734f80b7e71d7ba3a5e2191250a2df1535","tid":509261,"uid":136637,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:07:03.000Z","msg":"我都係 平時食野太清淡 郁啲就會覺得太甜太鹹太辣 有時出街食避唔到 個腸胃會頂唔順勁肚痛"},{"pid":"18fe605f4603fe4a366104c0352b080dd8e45d69","tid":509261,"uid":63432,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:07:59.000Z","msg":"最鐘意飲水<br />\n茶都唔鐘意飲<img src=\"/assets/faces/xm/angel.gif\" class=\"hkgmoji\" />"},{"pid":"aedd4cb368b10ea90045e3c30c68a64660df3afa","tid":509261,"uid":69961,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:08:02.000Z","msg":"依家鐘意飲水or茶<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b4175a91600e55240856f27213c9fc40fb8eaa44","tid":509261,"uid":92185,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:16:38.000Z","msg":"我細個係勁鐘意甜野，檸檬茶可樂當水飲<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /> <br />\n試過暑假一日起碼一罐可樂<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /> <br />\n卒之飲到個人又多痰又呼吸困難咁<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /> <br />\n到左依家大個反而好鐘意飲水，出街頸渴淨係買支裝水都唔會買其他野飲<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"571c415c64b83e21c826983e520b7a3b8ccb5146","tid":509261,"uid":76249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:22:53.000Z","msg":"<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5ef6069fa54c8323f901b0248bf858ef1ee8621f","tid":509261,"uid":3004,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:23:11.000Z","msg":"我都係飲唔到甜 食唔到朱古力<br />\n但開始鍾意食朱古力味以外既甜品 唔知咩事<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"15423d23009879b7643839535117dc146164845d","tid":509261,"uid":7081,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:28:38.000Z","msg":"19歲，奶茶完全唔落糖，鍾意飲茶同水，汽水盡量唔掂...."},{"pid":"8c736317f6bf5d24060c0c825640fe4a333be873","tid":509261,"uid":111644,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:34:39.000Z","msg":"飲到更都淨係飲津路<br />\n<br />\n一個月都飲唔到一次汽水呀"},{"pid":"9be6b0760491f4b18303ca610147277d831e15f7","tid":509261,"uid":33357,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:34:58.000Z","msg":"廿歲頭但已經乜都走甜少甜<br />\n咖啡唔加奶加糖<br />\n飲檸水走甜<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"70064dd2dcc7c015937fd83f9edb51173a6f1fd7","tid":509261,"uid":52271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:35:00.000Z","msg":"好少飲甜同有卡路里嘅飲品"},{"pid":"181c382165e19fd888dc01fa97de059ddac706c0","tid":509261,"uid":111644,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:35:18.000Z","msg":"<blockquote>飲到厭都淨係飲津路<br />\n<br />\n一個月都飲唔到一次汽水呀</blockquote>"},{"pid":"3e76ad6a32735ca00fbda978017e6cd40517ab5a","tid":509261,"uid":72334,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:37:13.000Z","msg":"屌一樣 以前係茶餐廳飲熱野 最少都畢五六羹糖<br />\n而家可以連一羹都唔落<br />\n利申廿頭"},{"pid":"499511f9321d802e779c580bb2d7c64c15f46221","tid":509261,"uid":11809,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:39:41.000Z","msg":"糖 = 毒藥"},{"pid":"6b62b3554d5306cd24cb3e9c1ffc5d0e6b54fa3e","tid":509261,"uid":37005,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:43:11.000Z","msg":"一模一樣<img src=\"/assets/faces/xm/shocking_b.gif\" class=\"hkgmoji\" /> <br />\n之前真係唔甜到甩牙都唔飲 而家飲杯檸茶都覺得好甜<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /> <br />\n老了<img src=\"/assets/faces/xm/frown.gif\" class=\"hkgmoji\" />"},{"pid":"7535a991b78f116b32c6e11ff078106b8ffeba96","tid":509261,"uid":139605,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-12-25T16:50:39.000Z","msg":"雖然其他野飲都有飲<br />\n但有得簡都係飲水<br />\n暖水係天下最正嘅飲品<img src=\"/assets/faces/xm/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\nbtw紙包檸茶真係好撚難頂<img src=\"/assets/faces/xm/dead.gif\" class=\"hkgmoji\" /> <br />\n覺得同直接倒砂糖入口無分別<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e15160cd20d67a93b299e816b7e19ddb03090d32","tid":509261,"uid":32464,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:52:05.000Z","msg":"茶<img src=\"/assets/faces/xm/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"db32b454e0fa46ed29049a56b48b723ce9c14cd4","tid":509261,"uid":29093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:53:47.000Z","msg":"認真,   飲少左啲勁多糖既野之後,  病少左好多"},{"pid":"bfaece208133d81d1e2cf96f5b58e8feb4fa313b","tid":509261,"uid":132587,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T16:57:53.000Z","msg":"凍飲反而好抗拒<br />\n甜間唔中ok"},{"pid":"892271f6ff738b499d39b34bea44ae468e12d558","tid":509261,"uid":26161,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T17:44:50.000Z","msg":"以前好鍾意飲可樂 朱古力 阿華田<br />\n而家次次都係飲凍檸水"},{"pid":"e0e335fdb03b6f2d5365e4c29f9a1e4fdbff4419","tid":509261,"uid":84507,"like":0,"dislike":0,"score":0,"quote":{"pid":"36b5853dc4b62992f87f80f25f7d7dbbedf5b4e5","tid":509261,"uid":75100,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2017-12-25T06:30:51.000Z","msg":"有陣見維他檸檬茶特價，口渴買枝諗住試下，點知超甜又澀喉，飲完好似喉嚨仲唔舒服左<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n岩岩朋友買完一排益力多送左枝比我，我見好耐無飲過咪要左，點知甜到飲唔到落口，逼自己先飲到<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n<br />\n明明得20幾歲, 但已經覺得茶先係世界第一，係咪好老積<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 明明以前飲阿華田仲可以加2匙糖<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2017-12-25T17:57:38.000Z","msg":"<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /> <br />\n以前飲阿華田都係2匙糖......<br />\n<br />\n阿華田唔放三匙糖點飲呀......"},{"pid":"371335549faa5f44cac2d389c67de9d042b5bd82","tid":509261,"uid":151933,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2017-12-25T18:14:58.000Z","msg":"樓主好老 不如番高登個老人院"},{"pid":"90fe66280c7df7fc5b01c539af01b708a7098e9a","tid":509261,"uid":6869,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2017-12-25T18:19:01.000Z","msg":"此回覆已被刪除"},{"pid":"d49bf218b68bbf30c3f1a876ac3afd7f54964285","tid":509261,"uid":58955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T18:19:24.000Z","msg":"呢排鐘意飲暖水<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" />"},{"pid":"804c90da5366bd889c0da9b845468fe6d9432046","tid":509261,"uid":34782,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T18:27:11.000Z","msg":"<blockquote>自細都係咁 依家二十歲已經唔識嚟月經<br />\n樓主下世小心啲</blockquote><br />\n男人老狗黎咩月經"},{"pid":"c654fcc6884f85a39c381898767f256d93b032ab","tid":509261,"uid":4998,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-12-25T19:01:03.000Z","msg":"唔好話飲甜野 連食甜野都少左 無乜胃口<br />\n以前細個乜糖都食 好中意食<br />\n依家都少左食<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7693ca9cae300c50e564798e7d103b76e05283c3","tid":509261,"uid":1440,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T19:29:29.000Z","msg":"去戲院忍唔到唔洗爆谷 自己好中意食<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> 尤其是焦糖 唯有係咁飲水"},{"pid":"1db33d9da8128d821ca9deef1cbdbeba2aaaf0d3","tid":509261,"uid":154702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T19:48:51.000Z","msg":"小學勁鍾意飲芬達橙汁汽水<br />\n唔知幾時開始出街買野飲只會買津露同埋水<br />\n食茶記m記會叫齋啡或凍檸啡<br />\n但有時有啲地方啡底難飲都幾伏下<img src=\"/assets/faces/xm/dead.gif\" class=\"hkgmoji\" />"},{"pid":"aa90f0ecc60c635deeca02eb94c5f99dfa8d9c84","tid":509261,"uid":107950,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-25T21:31:56.000Z","msg":"我都係廿幾，呢一兩年飲少咗甜野，鍾意咗飲茶<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"536c2759e4583ff820d2d66c1213e1f007f9bb3f","tid":509261,"uid":36437,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2017-12-25T21:46:21.000Z","msg":"咁都有得打飛機<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" />"},{"pid":"69aa9c1afbd40d3318983bc9c7f607d956a80735","tid":509261,"uid":71728,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-12-25T22:09:13.000Z","msg":"<img src=\"https://ogsan.me/wp-content/uploads/2015/04/DSC0190a-500x476.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fogsan.me%2Fwp-content%2Fuploads%2F2015%2F04%2FDSC0190a-500x476.jpg&h=93a34b46&s={SIZE}\" /><br />\n唔知幾時開始由每日一罐可樂變左每日一罐呢d<img src=\"/assets/faces/fs/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"d10b9fcb8b8b29b2868d14f76f1265ee8c848e07","tid":509261,"uid":38772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-26T00:30:23.000Z","msg":"看⼁"},{"pid":"1be629bdcb09705b5175ed415e93c4f97944078f","tid":509261,"uid":50641,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-26T00:31:30.000Z","msg":"早幾年飲野已經叫少甜或者走甜<br />\n汽水1個月或者會飲到1次<br />\n<br />\n少少甜我okay<br />\n但太甜我寧願成杯野唔飲"},{"pid":"c928cf1aa151e3159b7ce395c03f64f4706f1d5a","tid":509261,"uid":78574,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-26T00:53:05.000Z","msg":"去左英國幾日，最miss都係樽裝茶<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /> <br />\n呢度淨係有果汁汽水買<img src=\"/assets/faces/xm/donno.gif\" class=\"hkgmoji\" />"},{"pid":"018f45a2411e056ef87d425f75d564b16354814a","tid":509261,"uid":4559,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-26T01:04:43.000Z","msg":"此回覆已被刪除"},{"pid":"dd6d56a246f206b33bd0f85308dd684858738c5d","tid":509261,"uid":65530,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-26T01:08:17.000Z","msg":"此回覆已被刪除"},{"pid":"d398