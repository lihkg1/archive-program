quiv 63*125 \\equiv 3*1 \\equiv 3 (mod 4)"},{"pid":"270563dfe1287a0620f4c06c7076a6b8df7d99c6","tid":2439834,"uid":32511,"like":0,"dislike":7,"score":-7,"quote":{"pid":"061a2e00cc0c46483ecbdc83da252b4f0d2b8ebb","tid":2439834,"uid":143474,"like":19,"dislike":0,"score":19,"quote":{"pid":"aad3b603dfa57bb0bf940550dd3b0f9b43717f61","tid":2439834,"uid":209398,"like":46,"dislike":0,"score":46,"citedBy":2,"replyTime":"2021-03-09T16:22:41.000Z","msg":"<img src=\"https://na.cx/i/pStxp3K.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpStxp3K.jpg&h=fd3ef22b&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/oEqPsg2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FoEqPsg2.jpg&h=0a903bf6&s={SIZE}\" />"},"citedBy":2,"replyTime":"2021-03-09T16:40:52.000Z","msg":"痴撚線咁撚好心翻譯<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><br />\n仲要整LaTeX（好似係，唔係數學人）<br />\n俾個正評你"},"citedBy":4,"replyTime":"2021-03-10T01:10:15.000Z","msg":"第一條已收皮<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6e002aaa03d5ad44a7675e754a215905e544ab97","tid":2439834,"uid":292710,"like":0,"dislike":0,"score":0,"quote":{"pid":"270563dfe1287a0620f4c06c7076a6b8df7d99c6","tid":2439834,"uid":32511,"like":0,"dislike":7,"score":-7,"quote":{"pid":"061a2e00cc0c46483ecbdc83da252b4f0d2b8ebb","tid":2439834,"uid":143474,"like":19,"dislike":0,"score":19,"quote":{"pid":"aad3b603dfa57bb0bf940550dd3b0f9b43717f61","tid":2439834,"uid":209398,"like":46,"dislike":0,"score":46,"citedBy":2,"replyTime":"2021-03-09T16:22:41.000Z","msg":"<img src=\"https://na.cx/i/pStxp3K.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpStxp3K.jpg&h=fd3ef22b&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/oEqPsg2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FoEqPsg2.jpg