dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"d16f1230118737c982766607d75cae0a937b19c6","tid":1878333,"uid":30506,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2d43ee7b1dd3e32a0d59eb53ed9176eb11b3f72","tid":1878333,"uid":52763,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-13T21:43:55.000Z","msg":"班鐵膠好毒<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-13T21:48:09.000Z","msg":"啲高層同班膠一齊迫車係咩感覺<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n頭先睇live 有個仲要扮列車加速嘅聲<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d84d9d8429d8737b72fc9896f240ec3d4aa9f7f1","tid":1878333,"uid":221265,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-13T21:52:52.000Z","msg":"<a href=\"https://twitter.com/yoshiefans/status/1228074227137277953?s=21\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Fyoshiefans%2Fstatus%2F1228074227137277953%3Fs%3D21&d=3BA04jbrysekxL3Ytp5IvR%2FwB%2Fd2Hr%2Bf%2F5fgrRWXORU%3D&h=4af0e09e\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftwitter.com%2Fyoshiefans%2Fstatus%2F1228074227137277953%3Fs%3D21&h=817656c9\" target=\"_blank\">https://twitter.com/yoshiefans/status/1228074227137277953?s=21</a><br />\n<img src=\"https://na.cx/i/V80f0dV.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FV80f0dV.png&h=fcedc001&s={SIZE}\" />"},{"pid":"a9a90efe859aeb281adce2f8f4a15b51065a90cf","tid":1878333,"uid":149978,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-02-14T00:13:23.000Z","msg":"屯馬綫一期在早上5時45分通車，特別頭班車由啟德站開往烏溪沙方向。<strong>百多名鐵路迷見證通車的一刻，表現興奮。</strong><br />\n<br />\n在月台有簡單的儀式，港鐵管理層與乘客一同倒數，等候車門打開，之後百多名乘客上車，<strong>他們不時舉起手機拍照，又高叫好開心。</strong>港鐵行政總裁金澤培被問到今日情人節通車是否特別日子，他表示大家很開心及雀躍。<strong>常務總監劉天成說，對於首班車順利開出，表示好開心。</strong><br />\n<br />\n在新型肺炎疫情下，大部分鐵路迷都有戴口罩，表示雖然擔心疫情，不能迴避，但認為有開心的日子就應該盡情投入。他又說，本身不是屯馬沿綫的居民，但日後能夠有多一條鐵路綫過海是好事。<br />\n<br />\n<strong>亦有鐵路迷表示毋懼肺炎影響，又認為今早無人到場示威，沒有破壞，感到高興。</strong><br />\n<br />\n<a href=\"https://hk.news.yahoo.com/%E5%B1%AF%E9%A6%AC%E7%B6%AB-%E6%9C%9F%E9%96%8B%E9%80%9A-%E9%90%B5%E8%B7%AF%E8%BF%B7%E8%A6%8B%E8%AD%89%E9%80%9A%E8%BB%8A-%E5%88%BB%E8%A1%A8%E7%8F%BE%E8%88%88%E5%A5%AE-220119655.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.yahoo.com%2F%25E5%25B1%25AF%25E9%25A6%25AC%25E7%25B6%25AB-%25E6%259C%259F%25E9%2596%258B%25E9%2580%259A-%25E9%2590%25B5%25E8%25B7%25AF%25E8%25BF%25B7%25E8%25A6%258B%25E8%25AD%2589%25E9%2580%259A%25E8%25BB%258A-%25E5%2588%25BB%25E8%25A1%25A8%25E7%258F%25BE%25E8%2588%2588%25E5%25A5%25AE-220119655.html&d=3BA04jbrysekxL3Ytp5IvR%2FwB%2Fd2Hr%2Bf%2F5fgrRWXORU%3D&h=db97418a\" data-auto-link target=\"_blank\">https://hk.news.yahoo.com/%E5%B1%AF%E9%A6%AC%E7%B6%AB-%E6%9C%9F%E9%96%8B%E9%80%9A-%E9%90%B5%E8%B7%AF%E8%BF%B7%E8%A6%8B%E8%AD%89%E9%80%9A%E8%BB%8A-%E5%88%BB%E8%A1%A8%E7%8F%BE%E8%88%88%E5%A5%AE-220119655.html</a>"},{"pid":"70240039b38c27dc30a0aab489ba797fa4165aa8","tid":1878333,"uid":38216,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-14T00:20:43.000Z","msg":"又可以加車費，即係加人工<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c3a86c0cae028e084773a1435334ec6d07b0a00c","tid":1878333,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"3db38e87fa06b5d219112bd93766470673fdb7ec","tid":1878333,"uid":4243,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-13T15:14:55.000Z","msg":"一大班popo入去慶通車叫人點搭?"},"citedBy":0,"replyTime":"2020-02-14T00:22:32.000Z","msg":"咩都冇"},{"pid":"ae97942901e2827eb020bc27d63be19286f59e44","tid":1878333,"uid":247934,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-14T00:25:52.000Z","msg":"生日緊係要有火<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" />"},{"pid":"d8d58dbfcab6e6e786f19ae2c8ab30f4cf30438e","tid":1878333,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"ae97942901e2827eb020bc27d63be19286f59e44","tid