i\" />"},{"pid":"986bac216ae640bf3ca9641f9f1325794d608e9e","tid":52401,"uid":20896,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T05:53:09.000Z","msg":"<blockquote><blockquote><blockquote><br />\n<br />\nX7</blockquote><br />\n<br />\nX8</blockquote><br />\n<br />\n屌你老母接夠未 無人想知你有無睇錯post名</blockquote><br />\n<br />\nX11"},{"pid":"7a818ae2136069dbf922ebbc4faed997cf272e42","tid":52401,"uid":35271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T05:55:13.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><br />\n<br />\nX7</blockquote><br />\n<br />\nX8</blockquote><br />\n<br />\n屌你老母接夠未 無人想知你有無睇錯post名</blockquote><br />\n<br />\nX11</blockquote><br />\n<br />\nX12"},{"pid":"5fc8823a29cf471c434d27679dd94fdff5fd2d13","tid":52401,"uid":8207,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T05:55:41.000Z","msg":"試過堂家姐結婚擺酒<br />\n我幫手幫d 親戚扣花<br />\n見到姑媽就話幫佢扣啦<br />\n姑媽：唔洗扣啦～<br />\n問多幾次佢都堅持咁咪算<br />\n<br />\n隔左陣我堂哥黎問做咩唔幫姑媽扣<br />\n我：下<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n堂哥：姑媽問係咪唔當佢係自己人所以唔幫佢扣呀<br />\n我即時火起話：我問左佢好幾次佢自己話唔扣架<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <br />\n<br />\n屌都on99<br />\n之後我同堂哥講：總之問我就問左，佢咁黎屈我都冇計，但我都唔會幫佢扣，叫佢自己黎<br />\n<br />\n<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"635789949c8fa010e036ab16dd614236dcea7b69","tid":52401,"uid":581,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T05:56:26.000Z","msg":"<blockquote><blockquote><blockquote><br />\n<br />\n屌你老母接夠未 無人想知你有無睇錯post名</blockquote><br />\n<br />\nX11</blockquote><br />\n<br />\nX12</blockquote><br />\n<br />\nX13"},{"pid":"a0dbf154756c95cfaf071db2f54a280e90f38086","tid":52401,"uid":2550,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T05:57:08.000Z","msg":"唔怪得睇唔明個內容..."},{"pid":"89c458211ed7351abe339bc409d894d0794066e9","tid":52401,"uid":22628,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T05:57:20.000Z","msg":"<blockquote><blockquote><blockquote><br />\n<br />\nX11</blockquote><br />\n<br />\nX12</blockquote><br />\n<br />\nX13</blockquote><br />\n<br />\nX14"},{"pid":"f3c29581a894a3587ff587bbfaa047589c82a163","tid":52401,"uid":26003,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T05:58:02.000Z","msg":"姑姐永遠唔會同爸爸爭比錢食飯<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"41c282f2f2b1ccac41e4596690310ae60cc6a6e9","tid":52401,"uid":57695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T05:58:09.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><blockquote>老豆喺醫院，大家面前啱啱過咗身，個身都仲未凍，有條八婆親戚指撚住我老豆隻耳仔話佢短命種<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n屌，佢真係好仆街<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <br />\n比我都想當場煎佢幾巴</blockquote><br />\n成班女親戚都係口沒遮攔，好鐘意細細聲講大大聲笑喺後面講埋啲好撚惡毒嘅嘢，自從呢件事之後冇再同佢哋見過</blockquote><br />\n<br />\n無當場打柒佢，你份人都算唔錯</blockquote><br />\n緊係有咁嘅衝動，但係唔想再畀我老母任何壓力，佢嗰排精神真係好差好差，一陣真係打柒咗佢，我自己唔同班親戚來往就緊係冇所謂，但係我老母仲要同佢哋打交道，盞煩到佢自己</blockquote><br />\n同埋如果真係打落手，我有預感班八婆親戚又會借題發揮話我哋成家人都有問題，又喺我老母面前講嘢句句有骨咁，有咩都係我老母受<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n樓主好成熟<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n比我就唔忍開9她拖<br />\n<br />\n咁都忍得食得屎<br />\n<br />\n短你老母你仲短<br />\n<br />\n指返她耳仔話她個頭近因住收尾個兩年"},{"pid":"da35f1d81997ef1d96a00730ef4a3d55b756c06b","tid":52401,"uid":27247,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:00:43.000Z","msg":"<blockquote>睇錯咸濕行為 睇完內文先知<br />\n出返去先<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n一樣<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"015fa7f29cdfb508d36a6bccb2541e6c8592ea14","tid":52401,"uid":45232,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:01:58.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><br />\n<br />\nX11</blockquote><br />\n<br />\nX12</blockquote><br />\n<br />\nX13</blockquote><br />\n<br />\nX14</blockquote><br />\nX15"},{"pid":"dfc8dc51441f4349982962efdeea4ff434ce69da","tid":52401,"uid":55797,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:04:47.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><br />\n<br />\nX11</blockquote><br />\n<br />\nX12</blockquote><br />\n<br />\nX13</blockquote><br />\n<br />\nX14</blockquote><br />\nX15</blockquote><br />\nX16"},{"pid":"9096059221b04422ded55c08f4ff3fba59f86197","tid":52401,"uid":18398,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:05:14.000Z","msg":"<blockquote><blockquote><blockquote><br />\n<br />\nX14</blockquote><br />\nX15</blockquote><br />\nX16</blockquote><br />\n<br />\nx71"},{"pid":"e9ee491af73390238be80e88ccc0d5bdd2e8081e","tid":52401,"uid":20625,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:07:20.000Z","msg":"利申：表姐係加拿大番黎<br />\n<br />\n表姐：喂，偽毒（後面大大力拍我個頭）<br />\n我：？？（一個轉身，對眼得對波同黑絲長腿）<br />\n表姐：入左邊個垃圾學校呀（一野托起我下巴）<br />\n我：香港大學（心諗你條仆街唔係我表姐仲唔屌穿你個閪）<br />\n表姐：屌柒你咩，問你入邊間大學呀，鬼唔撚知你係香港讀大學咩（一巴聲落黎）<br />\n我：我讀University of Hong Kong呀屌，拿，我唔係耶撚，咪打左面（摸住俾人摑既右邊面頰）<br />\n表姐：呀屌，講英文咪得囉，咪話表姐我唔益你，介紹啲姐妹你識（將我個頭夾住係佢加拿大度）<br />\n我：你唔撚下世先講，有女朋友啦（扮反抗，明磨波，順勢抱住條腰）<br />\n<br />\n後續就係老母係廚房煮完飯叫我幫手<br />\n我大大力咁推開表姐<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n然後仲收撚左我老母封500蚊利是<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"7a8bc32fe2ce0ce837919d12fd12d6097460bc7e","tid":52401,"uid":35094,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:12:47.000Z","msg":"<blockquote>姑姐永遠唔會同爸爸爭比錢食飯<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"887bbb3c940e92a959c9aba72d7b3deecca61f32","tid":52401,"uid":14439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:14:14.000Z","msg":"我都睇錯<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"483ee034bcbf72172f053d17bb764924cc4600a2","tid":52401,"uid":2181,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:40:21.000Z","msg":"<blockquote>睇左做咸濕行為</blockquote><br />\n<br />\n我都係<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9a3d33711508ea23a268e7a3cc3e1a5465d7b23f","tid":52401,"uid":31020,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:42:05.000Z","msg":"<blockquote>有次親戚聚會見返個好耐無見嘅表姐 以前細個成日一齊玩就算好耐無見見返都即刻好friend 完咗親戚聚會之後佢問我一唔一齊去搵個地方坐我 我就話夜喇返屋企啦 點知佢死纏爛打跟咗我返屋企 又話自己啱啱同俾公司炒咗好唔開心咪俾佢上黎 上到黎就不停借啲依摸黎摸去 我問佢做乜鳩 佢就話我地細個嗰陣都係咁架啦 玩玩下就咀埋黎 之後我又唔知發咩神經覺得佢幾正 波雖然唔係大 但腳長長又白 之後就同佢扑咗 嗰次之後見返面都幾老尷 諗返起都覺得濕鳩<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n呢個真係女親戚咸濕行為<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"723ea426652e497430b5304da7891cdecd72aae2","tid":52401,"uid":45772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:43:03.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><blockquote>老豆喺醫院，大家面前啱啱過咗身，個身都仲未凍，有條八婆親戚指撚住我老豆隻耳仔話佢短命種<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n屌，佢真係好仆街<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <br />\n比我都想當場煎佢幾巴</blockquote><br />\n成班女親戚都係口沒遮攔，好鐘意細細聲講大大聲笑喺後面講埋啲好撚惡毒嘅嘢，自從呢件事之後冇再同佢哋見過</blockquote><br />\n<br />\n無當場打柒佢，你份人都算唔錯</blockquote><br />\n緊係有咁嘅衝動，但係唔想再畀我老母任何壓力，佢嗰排精神真係好差好差，一陣真係打柒咗佢，我自己唔同班親戚來往就緊係冇所謂，但係我老母仲要同佢哋打交道，盞煩到佢自己</blockquote><br />\n同埋如果真係打落手，我有預感班八婆親戚又會借題發揮話我哋成家人都有問題，又喺我老母面前講嘢句句有骨咁，有咩都係我老母受<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n叫你個垃圾親戚死全家啦屌"},{"pid":"907c79e1ddfb91ddc718daf11992f3a6eb1e6710","tid":52401,"uid":22313,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:43:33.000Z","msg":"個姑姐新年俾利事，入面係一張十蚊老麥現金卷，佢兩個女就現兜兜收其他人真錢，火都嚟，死肥婆屌你老未臭閪"},{"pid":"a13df0bda52d6e6267a6e6ad16ee47f136198fed","tid":52401,"uid":31020,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:43:41.000Z","msg":"<blockquote>利申：表姐係加拿大番黎<br />\n<br />\n表姐：喂，偽毒（後面大大力拍我個頭）<br />\n我：？？（一個轉身，對眼得對波同黑絲長腿）<br />\n表姐：入左邊個垃圾學校呀（一野托起我下巴）<br />\n我：香港大學（心諗你條仆街唔係我表姐仲唔屌穿你個閪）<br />\n表姐：屌柒你咩，問你入邊間大學呀，鬼唔撚知你係香港讀大學咩（一巴聲落黎）<br />\n我：我讀University of Hong Kong呀屌，拿，我唔係耶撚，咪打左面（摸住俾人摑既右邊面頰）<br />\n表姐：呀屌，講英文咪得囉，咪話表姐我唔益你，介紹啲姐妹你識（將我個頭夾住係佢加拿大度）<br />\n我：你唔撚下世先講，有女朋友啦（扮反抗，明磨波，順勢抱住條腰）<br />\n<br />\n後續就係老母係廚房煮完飯叫我幫手<br />\n我大大力咁推開表姐<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n然後仲收撚左我老母封500蚊利是<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n表姐真係d好濕鳩嘅親戚<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"7714b4f0adf409a5d1d26304f808ac86808d60f2","tid":52401,"uid":64392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-24T06:59:17.000Z","msg":"<blockquote><blockquote><blockquote><br />\n緊係有咁嘅衝動，但係唔想再畀我老母任何壓力，佢嗰排精神真係好差好差，一陣真係打柒咗佢，我自己唔同班親戚來往就緊係冇所謂，但係我老母仲要同佢哋打交道，盞煩到佢自己</blockquote><br />\n同埋如果真係打落手，我有預感班八婆親戚又會借題發揮話我哋成家人都有問題，又喺我老母面前講嘢句句有骨咁，有咩都係我老母受<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n叫你個垃圾親戚死全家啦屌</blockquote><br />\n<br />\n咁同呢條臭西而家仲有冇來往？"},{"pid":"40c2c2eea6542f269407fc4d2e3df83e5dc24b53","tid":52401,"uid":5399,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016