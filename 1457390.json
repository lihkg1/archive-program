g/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"3ce3dad494fb0815c18bd2de5ce73ca5515d8797","tid":1457390,"uid":113155,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T11:59:01.000Z","msg":"推！<br />\n不互屌，但要自我反省"},{"pid":"c1deb5d510e27db75c1e247ba881c494e42bf924","tid":1457390,"uid":291625,"like":0,"dislike":0,"score":0,"quote":{"pid":"8edeab4750eaaaad0b9808c93fb22c6e10c8a38b","tid":1457390,"uid":294772,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-12T11:40:31.000Z","msg":"<a href=\"https://www.hongkongairport.com/tc/flights/departures/passenger.page\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hongkongairport.com%2Ftc%2Fflights%2Fdepartures%2Fpassenger.page&d=5%2F0N1eX%2FnGDFGLWAFE16zvS0i%2BS8%2FYHgnNJfWlbrK%2Bw%3D&h=927debad\" data-auto-link target=\"_blank\">https://www.hongkongairport.com/tc/flights/departures/passenger.page</a>"},"citedBy":0,"replyTime":"2019-08-12T11:59:32.000Z","msg":"推！ 其實今日真係做到效果出嚟， Be Water"},{"pid":"9b27c48d865406f74a8b61c50269227de9d7baa2","tid":1457390,"uid":76078,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T11:59:49.000Z","msg":"推"},{"pid":"4ee2af43f57b24802886077be475127541a08ef2","tid":1457390,"uid":254361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T11:59:56.000Z","msg":"借位講幾句野<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" /><br />\n<br />\n我求下各位巴打絲打<br />\n用個下腦諗嘢<br />\n留又好，唔留又好請交給在場人士去決定<br />\n你哋唔好喺度發文喺度煽動<br />\n佢地成功分化我地了啦<br />\n<br />\n和理非非會驚好多野係正常<br />\n（唔驚又有行動力做左勇武）<br />\n但係但係呢到我有幾句野想講<br />\n<br />\n直面面對「恐怖」，知道它的「傷害」<br />\n理解會造成的「後果」，站起來、面對它<br />\n這才是「勇氣」，這才是「抗爭」<br />\n<br />\n<br />\n<br />\n唔知大家有沒有看過周星馳的電影「少林足球」<br />\n當然還有其他優秀的電影，如「讓子彈飛一會」等等<br />\n<br />\n「少林足球」里而的大反派說了這麼幾句 <br />\n<br />\n強雄：「我是打人,怎麼樣? 我要把你全隊的人打得像你一樣殘廢、殘廢、殘廢... 跟我鬥?」<br />\n強雄：「還有球證、旁證加上主辦、協辦所有的單位，全部都是我的人，怎麼和我鬥?」<br />\n<br />\n係呀點鬥呀，只剩下咩可以去鬥呀<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n加油呀，香港人<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n然後這再講返幾句名言<br />\n曼德拉語錄:<br />\n如果天空是黑暗的，那就摸黑生存;<br />\n如果發出聲音是危險的，那就保持沉默;<br />\n如果自覺無力發光，那就蜷伏於牆角。<br />\n但是，不要習慣了黑暗就為黑暗辯護;<br />\n也不要為自己的苟且而得意;<br />\n不要嘲諷那些比自己更勇敢的人。<br />\n我們可以卑微如塵土，但不可扭曲如蛆蟲。<br />\n&mdash;&mdash;曼德拉《漫漫人生路》"},{"pid":"685b4d6fb99093f5aebf09057a58967019c13e2b","tid":1457390,"uid":211270,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-12T12:01:39.000Z","msg":"利伸 唔熟飛機<br />\n我淨係睇到22:20仲有機<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/yhY273g.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyhY273g.jpg&h=d31eaf5a&s={SIZE}\" />"},{"pid":"c3e4f2822c374466190e91d443d994dbfb0698a5","tid":1457390,"uid":104502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-12T12:02:32.000Z","msg":"根本就係要引佢地入黎清場<br />\n比全世界都見到咩事"},{"pid":"4331d1a74c22cfc4f9274c0e704491826cb01aa4","tid":1457390,"uid":211270,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-12T12:03:53.000Z","msg":"乜鳩6點鐘清場個d<br />\n聽日唔好再信喇<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"7f17dc534bfb9e83bfdca729cb5a5c3fec3ab598","tid":1457390,"uid":104502,"like":0,"dislike":0,"score":0,"quote":{"pid":"4331d1a74c22cfc4f9274c0e704491826cb01aa4","tid":1457390,"uid":211270,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-12T12:03:53.000Z","msg":"乜鳩6點鐘清場個d<br />\n聽日唔好再信喇<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-12T12:04:13.000Z","msg":"就算佢地清<br />\n咪比全世界望住囉<br />\n另一場64"},{"pid":"bc