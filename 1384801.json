e=\"color: red;\"><span style=\"font-size: xx-large;\">伸冤啊大人</span></span>"},{"pid":"2fec5b399b20f68c9e4ddead6846bd74b7d1d753","tid":1384801,"uid":138410,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:10:26.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"784e9ddf1e1e12cb61a0812c2e5e0e61ae946e55","tid":1384801,"uid":33668,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-07-30T03:10:26.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />集思廣益令藍絲醒腦字眼<br />\n<br />\n重點: 要明白反送中暫緩但唔繼續抗爭 就會開通咗以後惡法越民意而行先例 好快大陸咁<br />\n<br />\n對藍絲媽媽<br />\n1) 將來仔女受<br />\n2) 將來俾大陸人蝦<br />\n3) 將來子女未來不保 你退休生活都係老人院/大陸生活<br />\n4) 今日香港不保 將來子女移民離港 你呢世見唔到子孫<br />\n5) 香港警察好似公安咁<br />\n6) 香港警察今日怕政權助就為弱 將來大陸賊落嚟打劫佢地都唔敢捉賊<br />\n7) 冧市第時後生好似大陸咁月薪5千 點養你<br />\n<br />\n對上班族<br />\n1) 白領: 香港變到深圳咁 請人點解請香港人貪貴?<br />\n2) 藍領: 將來反送中(及一干國策)通過, 香港冧市 情況仲慘過當年沙士通縮 一個月無一次工返既日子<br />\n3)"},{"pid":"e48194baec66c2152f7315b47836c1c65ca65fea","tid":1384801,"uid":239250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:10:40.000Z","msg":"推"},{"pid":"387cce712ec85a414cc925283d0d114ce5eef2fb","tid":1384801,"uid":81195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:11:08.000Z","msg":"6"},{"pid":"0c2351eb1ab0ffb9755ee9b3f3f3eed652ba54ac","tid":1384801,"uid":81195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:11:18.000Z","msg":"5"},{"pid":"a1b1e9f932f016d74a3a5ae8437742ffffd19871","tid":1384801,"uid":275588,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-30T03:11:22.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"d72f67d59ea3a6f0a5a8f2f94d5e44db687da937","tid":1384801,"uid":81195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:11:28.000Z","msg":"4"},{"pid":"76e91a28a10d55bcf100211040dda8d0c9f072e8","tid":1384801,"uid":81195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30