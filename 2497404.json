d":2497404,"uid":110265,"like":0,"dislike":0,"score":0,"quote":{"pid":"c3f9baf39a60e8154d2a42f5731d8b4b08cf4898","tid":2497404,"uid":346248,"like":0,"dislike":0,"score":0,"quote":{"pid":"84444d58519f7561e272f7127a41fbdbdb779420","tid":2497404,"uid":224510,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-20T13:44:48.000Z","msg":"砌MH GK<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-20T13:46:00.000Z","msg":"我有㗎不過pack咗係箱咋嘛<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-20T13:50:06.000Z","msg":"CLS<img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" /><br />\n個撚個都GK高手<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-20T13:51:17.000Z","msg":"有幾盒未砌嘅GK ＝/＝ 高手<br />\n<br />\n<span class=\"x-small\"><span class=\"pink\">我係真新手</span></span>"},{"pid":"4952bcdb815974a496ddccb15b79da0187b7277b","tid":2497404,"uid":75448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-20T13:52:31.000Z","msg":"樓主<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><br />\n岩岩本身都想搶1001開呢個topic<br />\n見到你開左差唔多topic名真係眼濕濕<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"}]}