/>"},{"pid":"fe526671b45f54ec8fbb8184b26ae6249ca23a7d","tid":2023990,"uid":19557,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T15:36:00.000Z","msg":"推"},{"pid":"938aae591c680172a00f883cc94fe0148ddecd28","tid":2023990,"uid":88743,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-05-19T15:47:14.000Z","msg":"聽講班友而家有新朵喎<br />\n屎家軍已outdated<br />\n而家叫<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>網絡垃圾</strong></span></span><img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://youtu.be/u-TtDRyIlEA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fu-TtDRyIlEA&d=lEFZiSwVnaVog3Ki0s%2BD%2F9MQoCHxbgs64DeXVNsql00%3D&h=b6470754\" target=\"_blank\">https://youtu.be/u-TtDRyIlEA</a>"},{"pid":"0c7a364b762c99ec6d58a86bb61f57597a3216a3","tid":2023990,"uid":116960,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-19T16:08:15.000Z","msg":"幫推"},{"pid":"6382fb533da80e5f2911b8f3a524603e6fc25770","tid":2023990,"uid":91546,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-05-20T07:52:52.000Z","msg":"求爸打整個list出黎<br />\nBlock曬佢地<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"2d640d687d1368981d0fa8f7f0b3f0079bb2c91c","tid":2023990,"uid":40902,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-20T08:15:27.000Z","msg":"推"},{"pid":"1ba43623c72f27be8b610e082ac0a74eecec47fd","tid":2023990,"uid":291448,"like":0,"dislike":0,"score":0,"quote":{"pid":"413750c5e428af4e0688fd3fe30eff3c9c69177f","tid":2023990,"uid":88743,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-19T10:54:01.000Z","msg":"片段link放係PO最底<br />\n<br />\n8:30<br />\n<img src=\"https://na.cx/i/JWCzEJ8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJWCzEJ8.jpg&h=8cbeca59&s={SIZE}\" /><br />\n封殺二字<br />\n覺唔覺得似曾相識?<br />\n<br />\n9:27<br />\n<img src=\"https://na.cx/i/ekMD6o8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FekMD6o8.jpg&h=ccb818d0&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/Qz9BS39.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQz9BS39.jpg&h=b7a8a120&s={SIZE}\" /><br />\n<br />\n17:17<br />\n<img src=\"https://na.cx/i/FyrdaQQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFyrdaQQ.jpg&h=3b584d01&s={SIZE}\" /> <br />\n<br />\n慕容呢條片絕對係有質素既片<br />\n封殺二字<br />\n覺唔覺得似曾相識?<br />\n香港藝人被封殺 報章被封殺 <br />\n要異口同聲一種聲音先可以生存<br />\n你覺得咁樣對香港係咪好事?<br />\n<img src=\"https://na.cx/i/B3O3yke.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FB3O3yke.jpg&h=f0c41c0d&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/sm1D6Fe.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fsm1D6Fe.jpg&h=331cae4d&s={SIZE}\" /><br />\n<br />\n<br />\n可能你會諗 屌唔好講到呢班友咁高<br />\n要黃既youtuber有大把 有燒山 有細良 有沈旭暉 有杜汶澤 洗撚睇呢班濕鳩咩<br />\n睇得呢班D濕鳩youtuber UP埋D ON9野拍下打機生活片既都係D不問世事淨係識飲飲食食打機既小朋友<br />\n但你要明白 呢兩種youtuber既target group係完全唔同既<br />\n<span style=\"color: red;\">上面燒山果班係全部都係資訊型既時事討論節目<br />\ntarget group係普遍年長少少既 同埋最重要係<ins>有心主動</ins>留意時事既人</span><br />\n下面果班你可以話係做緊類似娛樂節目型既youtuber KOL<br />\n<strong><span style=\"color: red;\">正正係下面呢一班youtuber<br />\n先target到平時唔留意時事既人<br />\ntarget到既人既層面先至係最廣</span></strong><br />\n可能佢地targer group平均都係10至18歲左右<br />\n但就係咁 <strong><span style=\"color: red;\">呢一班人係可塑性最高既人</span></strong><br />\n<span style=\"color: red;\">將來變成藍定黃 就好睇佢地接收乜野資訊</span><br />\n<span style=\"color: red;\"><strong>將來會唔會變成水魚中傳銷陷阱 <br />\n會唔會渴望做<strong><ins>台主</ins></strong>!(<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />) 就好睇佢地接收乜野資訊</strong></span><br />\n所以都解釋左 點解政府會APPROACH呢一班KOL<br />\n同埋BUMP水養呢班KOL<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n而家呢班人話自己係黃 食緊兩家茶禮<br />\n你估係真黃 定係滲透?<br />\n即使呢一刻食緊兩家茶禮既係背後都係真黃<br />\n但你儲左一班fans<br />\n過多幾年會唔會因為生計去變淺藍 影響呢班fans既價值觀?<br />\n你覺得過多幾年剷除異己之後班友會唔會現形?<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">所以呢單野同黃色經濟圈背後既理念基本上係相同</span></span></strong><br />\n<br />\n唔好同我講呢D係叫做捉鬼 係鬥黃<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n又唔好同我講唔好理屎家軍 有更重要既23條國歌法要理<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n所有野係可以同步進行既<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<span style=\"color: red;\">呢幾日就係黃金時期去令更多人認識屎家軍 令更多人認識YOUTUBER KOL背後既生態<br />\n而家丟淡左既話 學片主話齋 暑假動漫節又係呢一班友既收成期了</span><br />\n<br />\n條片係提供哂証據同合理疑點<br />\n唔信既 下面呢度係原片 值得睇哂佢<br />\n再自己慢慢分析<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://youtu.be/aQyYZ7YIVyY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FaQyYZ7YIVyY&d=lEFZiSwVnaVog3Ki0s%2BD%2F9MQoCHxbgs64DeXVNsql00%3D&h=b0eab209\" target=\"_blank\">https://youtu.be/aQyYZ7YIVyY</a>"},"citedBy":0,"replyTime":"2020-05-20T14:42:35.000Z","msg":"一個制衡屎家軍嘅簡單方法<br />\n<a href=\"https://lih.kg/2025872\" data-auto-link target=\"_blank\">https://lih.kg/2025872</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"18acde561beacd6eddd41d79dd86275c541c4205","tid":2023990,"uid":88743,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6382fb533da80e5f2911b8f3a524603e6fc25770","tid":2023990,"uid":91546,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-05-20T07:52:52.000Z","msg":"求爸打整個list出黎<br />\nBlock曬佢地<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-20T15:13:56.000Z","msg":"唔係好識佢地有乜人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n睇下有無有心人整啦<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"b619c904d580594ae9c220d62df94df12855348c"