ets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},{"pid":"477cbb2acedeb1cac3f01d13f9ccbc09a7caf83a","tid":1394571,"uid":281418,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:07:49.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"1c296c943856fa85e33da50c0cbf52ff6a5b3009","tid":1394571,"uid":31,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:08:04.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"8f3e3697a52387927667175d521423a0f77eccd1","tid":1394571,"uid":105067,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:09:27.000Z","msg":"<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"626c895bbd1526e1eeb0326c537973fefa5ee494","tid":1394571,"uid":158457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:11:01.000Z","msg":"管好啲狗喇<img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"d68fe9b4b713b3bf368e8abae9a402720b6cfbf9","tid":1394571,"uid":4189,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2019-08-01T13:11:21.000Z","msg":"以下係一班漁護署公務員嘅公開聲明：<br />\n<br />\n致 香港特區政府 林鄭獨裁政權:<br />\n<br />\n過去一個多月，因 (送終條例) 引發多宗紛爭，建制人犬及警犬當道導致不少市民不論身心都受到不可磨滅的傷痛。<br />\n<br />\n林鄭月娥女士，請你做個盡責任的帶狗人士<br />\n<br />\n根據法例規定，在公眾地方，所有狗隻須以狗帶牽引或以其他方式妥善控制。<br />\n懇請閣下作個盡責的帶狗人士，好好管理你旗下的犬隻，勿讓牠們再胡亂哮叫及傷害大眾市民。任何人士如有違反規例，可被處罰<br />\n<br />\n現附上漁護署相關條例: <br />\n危險狗隻規例(第167D章)第9條規定了「大型狗隻」的管制，任何人士如違反這條規例，一經定罪，可被罰款$25,000及監禁 3個月。<br />\n<br />\n同時要求政府回應市民5大訴求:<br />\n<br />\n一 : 徹底撤回修例<br />\n<br />\n二 : 收回暴動定義<br />\n<br />\n三 : 撤銷對所有反送中抗爭者控罪<br />\n<br />\n四 : 徹底追究警隊濫權情況 (成立獨立調查委員會)<br />\n<br />\n五 : 立即實行雙真普選<br />\n<br />\n一群漁護署小薯敬上<br />\n<br />\nP.S. 致建制人犬及警犬們<br />\n<br />\n係當權者眼中，你地只係一條好狗，係人民眼中，你地只係一條惡狗，既然有得選擇，點解唔做返一個人呢？"},{"pid":"1b415eb8ff8bb8e1964d6401dcc0b1bad52c8c98","tid":1394571,"uid":258088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:11:38.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"96c3afb65d4f287c333ff19942f20f2083d627c9","tid":1394571,"uid":26711,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-01T13:12:12.000Z","msg":"都反了<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"aee2d79f67b6cdfd21c53ba194201e18320e38ea","tid":1394571,"uid":173849,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:12:32.000Z","msg":"工聯會掌握香港各行業主要工會，手足快d去佢地fb支持下<br />\n<a href=\"https://lih.kg/1394346\" data-auto-link target=\"_blank\">https://lih.kg/1394346</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"b4e67c46f4a703c5d7be163112188b0584a491f9","tid":1394571,"uid":14983,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:12:37.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"894ba48b7c4d33c430608b18491f665daf6948f0","tid":1394571,"uid":25617,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:14:22.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"c66379764e0f0a70e7191ec1c6148aab2ed5a69d","tid":1394571,"uid":259329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:17:44.000Z","msg":"此回覆已被刪除"},{"pid":"b998fd1b3b6dff943e8be24fd8ae1e8e7e973190","tid":1394571,"uid":36134,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:18:32.000Z","msg":"<img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/nosee.gif\" class=\"hkgmoji\" />"},{"pid":"5f07d6bdf55896b9ee9bed87e4ffd633f0329db7","tid":1394571,"uid":279333,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:18:41.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmo