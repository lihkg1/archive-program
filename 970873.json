ly &ndash; can generate such waves by displacing water."},{"pid":"577fa792503abc4156642672d5b6ad5e0e612ccc","tid":970873,"uid":1977,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-01-06T09:17:04.000Z","msg":"anger from the sea"},{"pid":"f2dcbd61c7a996f497ed3b58e7af745636bd0452","tid":970873,"uid":128321,"like":7,"dislike":1,"score":6,"citedBy":0,"replyTime":"2019-01-06T09:17:16.000Z","msg":"Hoi Siu"},{"pid":"e870f8d0354bf246056a08bd1c26160eaeb7f124","tid":970873,"uid":127898,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2019-01-06T09:18:16.000Z","msg":"I go to school by bus"},{"pid":"fabe7374909910dd2aea3bbf5fa8b4798ae53b3e","tid":970873,"uid":15935,"like":2,"dislike":0,"score":2,"quote":{"pid":"66f267388454e53e9552de6846d9a58378a5fa6d","tid":970873,"uid":192754,"like":3,"dislike":2,"score":1,"citedBy":2,"replyTime":"2019-01-06T09:13:03.000Z","msg":"別要我洗去我的雙腳泥濘<br />\n沉淪在這夢裡我不想清醒"},"citedBy":0,"replyTime":"2019-01-06T09:18:44.000Z","msg":"如海嘯 如山崩"},{"pid":"e4262de236f6a85c8ff8fcdac1cbf6fe0bdd1fcb","tid":970873,"uid":125976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-06T09:27:37.000Z","msg":"brim brogdettan<img src=\"/assets/faces/xm/angel.gif\" class=\"hkgmoji\" />"},{"pid":"5ce3f109b42fe0ac7bdc83ad6e1b8aff7b8d4ba6","tid":970873,"uid":66546,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-06T09:32:17.000Z","msg":"RUN!!!!!!!!"},{"pid":"dee7666f312d01c77c880597c4e6293c0382ec11","tid":970873,"uid":62167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-06T09:32:25.000Z","msg":"OMG"},{"pid":"405850fa094682455c66fe0120ae3b0e40f455ad","tid":970873,"uid":16783,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-01-06T09:36:40.000Z","msg":"run la diu"},{"pid":"7669de1e62da056da576c14eeb9ce3a7c372d964","tid":970873,"uid":119979,"like":12,"dislike":0,"score":12,"quote":{"pid":"a0c742620a83974f55144aa4e3d3ec6437b9519b","tid":970873,"uid":200550,"like":18,"dislike":0,"score":18,"quote":{"pid":"ffce