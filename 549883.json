tps://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F02%2F10%2F164324_a28d0639a365b0cfcd0e8ba74c49c230.png&h=73969d8c&s={SIZE}\" /><br />\nS1E5 The understudy <br />\n將莎士比亞嘅麥克白濃縮拍成呢一集<br />\n編劇果然功力深厚<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n又係玩open end <br />\n結局最後係男主角精神分裂殺咗人丫<br />\n定真係女主角幫佢殺人呢<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" />"},{"pid":"5d26683b87ffb1b42d95bb6305b6e92b1b286906","tid":549883,"uid":97114,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-02-10T09:14:33.000Z","msg":"想腸 搵唔到邊到有<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"8c63275fe267c5ef87601ae7b64aeacfabaf1b31","tid":549883,"uid":123456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-10T09:21:12.000Z","msg":"追哂<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"446584cfbeae5ec004f727f7c473ff856f7e4651","tid":549883,"uid":27909,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-10T10:02:02.000Z","msg":"要等到下年<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"940bbbeac8723fb20c22d04070813961dac4b941","tid":549883,"uid":67702,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d26683b87ffb1b42d95bb6305b6e92b1b286906","tid":549883,"uid":97114,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-02-10T09:14:33.000Z","msg":"想腸 搵唔到邊到有<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-10T13:54:37.000Z","msg":"我手機用人人視頻睇<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"985d3964da9f847a3ac24bf76ad0736ef116cbae","tid":549883,"uid":27440,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d26683b87ffb1b42d95bb6305b6e92b1b286906","tid":549883,"uid":97114,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-02-10T09:14:33.000Z","msg":"想腸 搵唔到邊到有<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-11T12:26:31.000Z","msg":"<a href=\"http://Vmus.co\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2FVmus.co&d=DnNAoCEY61nQzabBFrNAfJ4f2li5K%2Fs6EGgmwhpeblA%3D&h=268d8224\" data-auto-link target=\"_blank\">Vmus.co</a>"},{"pid":"80bd75f49dfbaa100ca82de66d33c7dfc3774b6e","tid":549883,"uid":26540,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-12T09:05:47.000Z","msg":"多謝樓主介紹，剛剛睇哂追左一季，好過癮！<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<span style=\"font-size: x-small;\"><span style=\"color: pink;\">Btw, s1e6 其實個twist 係咪就係無twist</span> </span>"},{"pid":"6cb73683b38b720573510ff3d663b01d6e8dd123","tid":549883,"uid":52947,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-12T09:08:21.000Z","msg":"Lm"}]}