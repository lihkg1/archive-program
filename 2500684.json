":0,"score":1,"quote":{"pid":"53e27ab3b955930f320eeddf861808455acaf0a2","tid":2500684,"uid":22553,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2021-04-23T00:44:41.000Z","msg":"兩千萬仲要做租租"},"citedBy":1,"replyTime":"2021-04-23T00:46:55.000Z","msg":"可能買唔起佢租果度"},{"pid":"648156d8cd747d7ac7aaabd2d03d49a6f87f6a37","tid":2500684,"uid":3177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-23T00:47:26.000Z","msg":"租樓win"},{"pid":"6f58e47f38576c230f01012e9fc7e3b34482681a","tid":2500684,"uid":3177,"like":0,"dislike":0,"score":0,"quote":{"pid":"53e27ab3b955930f320eeddf861808455acaf0a2","tid":2500684,"uid":22553,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2021-04-23T00:44:41.000Z","msg":"兩千萬仲要做租租"},"citedBy":1,"replyTime":"2021-04-23T00:49:01.000Z","msg":"租住先好<br />\n啲豪宅無細碼樓咁好升的<br />\n<br />\n再拎現錢買股買coin"},{"pid":"e905ac44ffb60d13c0e1200c545a91b0556a3fb5","tid":2500684,"uid":250308,"like":0,"dislike":0,"score":0,"quote":{"pid":"6f58e47f38576c230f01012e9fc7e3b34482681a","tid":2500684,"uid":3177,"like":0,"dislike":0,"score":0,"quote":{"pid":"53e27ab3b955930f320eeddf861808455acaf0a2","tid":2500684,"uid":22553,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2021-04-23T00:44:41.000Z","msg":"兩千萬仲要做租租"},"citedBy":1,"replyTime":"2021-04-23T00:49:01.000Z","msg":"租住先好<br />\n啲豪宅無細碼樓咁好升的<br />\n<br />\n再拎現錢買股買coin"},"citedBy":0,"replyTime":"2021-04-23T00:51:04.000Z","msg":"有錢仲買股買coin比人割咩 有錢就買國債啦 你估人人做到連登仔股神<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"fea912789181c2c5736571521932e9d9eaf3febb","tid":2500684,"uid":250308,"like":0,"dislike":0,"score":0,"quote":{"pid":"7fffee32822b8200fca08943398613701d986775","tid":2500684,"uid":19986,"like":0,"dislike":0,"score":0,"quote":{"pid":"a6f0c88101d84aa0f5d136bbe91a968d4822c530","tid":2500684,"uid":240890,"like":0,"dislike":0,"score":0,"quote":{"pid":"1d177cb24c61ba5cc27bbef0f7e7a4f93474e5bf","tid":2500684,"uid":235678,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04