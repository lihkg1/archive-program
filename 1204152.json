faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"67288367fbb3ff355c61cac63f1adba47217a6e7","tid":1204152,"uid":232082,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T14:50:27.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"3dc4a9cd0b6ca380711c18048cff33e4b734c882","tid":1204152,"uid":6435,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T14:51:35.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">避免午夜現身，因午夜交通暢順，警察能夠快速調配警力。</span></span><br />\n街道少行人亦會令到警察容易採取更進取嘅行動針對抗爭者。<br />\n<br />\n日間繁忙時間係較安全嘅選擇，日間有更多交通工具選擇方便快速增援/撤離，路上行人同遊客亦會大大限制警察使用大規模攻擊武器等行動。<br />\n<br />\n假如發生衝突，<span style=\"font-size: xx-large;\"><span style=\"color: orange;\">首要評估自己及附近人群體力，且抗爭者人數最少要大於警力四倍</span></span>。 <span style=\"color: red;\"><span style=\"font-size: xx-large;\">事發後5-8分鐘尚算安全時機，超過以上時間警察就有足夠時間調派大量增援同部署，難以確保自身安全。</span></span>"},{"pid":"d1fdcff328a81e3deb66bef71467458e2ce92df8","tid":1204152,"uid":232082,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T14:52:48.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"dd265fc1df8d6ef248c0271832a408293001612a","tid":1204152,"uid":16743,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T14:56:04.000Z","msg":"推"},{"pid":"3d89d0e78992136396422cca8a2e62da3a27bf5b","tid":1204152,"uid":232082,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T15:02:11.000Z","msg