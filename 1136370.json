f","tid":1136370,"uid":70786,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-03T04:49:53.000Z","msg":"嘩之前唔係好大牌<br />\n台灣要求司法互助3次都唔理人咩?<img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" /><br />\n做咩突然又同人傾呀777"},{"pid":"392818148a27fb767f0b9c45e743dffb12112891","tid":1136370,"uid":81113,"like":0,"dislike":0,"score":0,"quote":{"pid":"5dee263241a2942852634a78ee31346904936cc7","tid":1136370,"uid":55960,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-05-03T03:33:05.000Z","msg":"打到好撚大力<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-03T04:53:54.000Z","msg":"啪啪聲<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"}]}