/09/09/212651_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F09%2F212651_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=6a8e548e&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-09-09T16:09:30.000Z","msg":"咁應該我睇錯了<br />\n488RMB我覺得合理<br />\n如果有年票就好<br />\n世窗真係無選擇下既選擇<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a74ad8df137d07eff7a88fdb25e3330824907848","tid":809464,"uid":152232,"like":1,"dislike":0,"score":1,"quote":{"pid":"4daaba799855c6f09ba47f6f7f8a622f1888f940","tid":809464,"uid":160361,"like":0,"dislike":0,"score":0,"quote":{"pid":"84fa3467f781ba33497023ba2dc92baa63043b9e","tid":809464,"uid":152232,"like":0,"dislike":0,"score":0,"quote":{"pid":"e64791db32d5b6bd4c8ae1806d8f751002d51ba4","tid":809464,"uid":160361,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-09T07:31:25.000Z","msg":"我見哈爾濱個萬達都係250RMB <br />\n希望廣州果個順利開得成唔使貴<br />\nweekend 過去stay 一晚滑兩日<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-09T13:26:55.000Z","msg":"250RMB? 應該冇咁平喎... 除非有門路買到特價票。<br />\n官網正價滑全日要488RMB...<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/09/09/212651_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F09%2F212651_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=6a8e548e&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-09-09T16:09:30.000Z","msg":"咁應該我睇錯了<br />\n488RMB我覺得合理<br />\n如果有年票就好<br />\n世窗真係無選擇下既選擇<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-10T01:21:22.000Z","msg":"佢通常有特價票，但要上大陸嘅網或團體買。或者住佢嘅酒店會有套票就平啲。<br />\n如果有年票而且價錢吸引，都應該會好多香港人去。"},{"pid":"0716313e40f663452f005ccf8f6427b213d34fce","tid":809464,"uid":18702,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-10T01:42:44.000Z","msg":"想問下巴打們第一次滑雪係自學定有人教<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n年頭果時去玩左幾日 <br />\n即使睇過下啲教學片都係勉強鳩流流咁<br />\n單板都仲控制到左右 但雙板直頭失控<br />\n雖然跌左幾日 但係都到滑雪呢樣運動好有興趣<br />\n希望下年可以舞得掂<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"94090aa04e25a77fa7edd51ba862b41bb88a08a5","tid":809464,"uid":152232,"like":0,"dislike":0,"score":0,"quote":{"pid":"0716313e40f663452f005ccf8f6427b213d34fce","tid":809464,"uid":18702,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-10T01:42:44.000Z","msg":"想問下巴打們第一次滑雪係自學定有人教<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n年頭果時去玩左幾日 <br />\n即使睇過下啲教學片都係勉強鳩流流咁<br />\n單板都仲控制到左右 但雙板直頭失控<br />\n雖然跌左幾日 但係都到滑雪呢樣運動好有興趣<br />\n希望下年可以舞得掂<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-10T16:16:31.000Z","msg":"我第一次係北京南山，請咗兩日一個來自哈爾濱嘅教練。個教練自己滑得好勁，但就冇受過系統性嘅教學訓練，所以唔係咁識教。我之後再冇跟過教練學，淨係自學，直到考教練。<br />\n<br />\n睇返轉頭，我係好後悔，自學真係走咗好多冤枉路，如果有個好嘅教練教，我成個滑雪生涯會好唔同。<br />\n<br />\n如果你有興趣滑，想認真學，就一定要跟教練。你可選擇去日本一啲比較多香港教練駐守嘅雪場，咁樣比較易搵到香港教練教。"},{"pid":"61b28d7535a2ab8a8f81470979cd59a3ab50e7f8","tid":809464,"uid":16552,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2018-09-10T16:54:31.000Z","msg":"有冇機會ab test埋feiyu g6防潑水果支穩定器?<br />\n見佢防潑水好似幾岩滑雪用<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n想off topic問下少少關於買板既野<br />\n上年開始滑單板, 綠線紅線普通s turn落山冇乜大問題<br />\n之前剩係租過板, 租到既例如burton LTR之類我估應該係camber板<br />\n黎緊今年想買自己板,<br />\nhybrid camber(即係rocker-camber-rocker),<br />\n或hybrid rocker(camber-rocker-camber)會唔會同普通camber板有好大分別?<br />\n睇中左果d板全部都係hybrid黎, 自己又未接觸過<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n今年想試下carve同練下d press/ollie/nollie之類既野<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"825626a5f1c5c7070a5212c9350ba1d813dd1a00","tid":809464,"uid":152232,"like":0,"dislike":0,"score":0,"quote":{"pid":"61b28d7535a2ab8a8f81470979cd59a3ab50e7f8","tid":809464,"uid":16552,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2018-09-10T16:54:31.000Z","msg":"有冇機會ab test埋feiyu g6防潑水果支穩定器?<br />\n見佢防潑水好似幾岩滑雪用<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n想off topic問下少少關於買板既野<br />\n上年開始滑單板, 綠線紅線普通s turn落山冇乜大問題<br />\n之前剩係租過板, 租到既例如burton LTR之類我估應該係camber板<br />\n黎緊今年想買自己板,<br />\nhybrid camber(即係rocker-camber-rocker),<br />\n或hybrid rocker(camber-rocker-camber)會唔會同普通camber板有好大分別?<br />\n睇中左果d板全部都係hybrid黎, 自己又未接觸過<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n今年想試下carve同練下d press/ollie/nollie之類既野<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-11T01:17:23.000Z","msg":"答咗第一條問題先<br />\n我測試嘅 gimbal 正正就係 Feiyutech G6 嚟~<br />\n<br />\n係室內場滑，冇落雪就唔係咁試到防潑水嘅效果。不過我相信用嚟拍滑雪 ok 嘅。比起防水，我更在意佢係低溫下嘅表現，因為低溫加上 wind chill 可以令到部機好涷，驚舊電頂唔住。"},{"pid":"f41dd030ba02cf2ecba7b38f7b4e807da764c9cd","tid":809464,"uid":152232,"like":1,"dislike":0,"score":1,"quote":{"pid":"61b28d7535a2ab8a8f81470979cd59a3ab50e7f8","tid":809464,"uid":16552,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2018-09-10T16:54:31.000Z","msg":"有冇機會ab test埋feiyu g6防潑水果支穩定器?<br />\n見佢防潑水好似幾岩滑雪用<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n想off topic問下少少關於買板既野<br />\n上年開始滑單板, 綠線紅線普通s turn落山冇乜大問題<br />\n之前剩係租過板, 租到既例如burton LTR之類我估應該係camber板<br />\n黎緊今年想買自己板,<br />\nhybrid camber(即係rocker-camber-rocker),<br />\n或hybrid rocker(camber-rocker-camber)會唔會同普通camber板有好大分別?<br />\n睇中左果d板全部都係hybrid黎, 自己又未接觸過<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n今年想試下carve同練下d press/ollie/nollie之類既野<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-11T01:27:45.000Z","msg":"答第二部分：<br />\n坊間呢啲 hybrid terms 好玩死人，有時候唔同牌子唔同媒體會用唔同定義。<br />\n但有一樣係肯定公認的：<br />\nCamber 即係 Traditional Camber.<br />\n非 Traditional Camber 嘅板就一律屬於 Rocker.<br />\n<br />\n我理解嘅 hybrid 同你剛則相反。<br />\nHybrid camber 係 camber-rocker-camber.<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/09/11/092338_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F11%2F092338_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=06f3153f&s={SIZE}\" /><br />\n<br />\nHybrid rocker 係 rocker-camber-rocker<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/09/11/092414_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F11%2F092414_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=aa3f0e08&s={SIZE}\" /><br />\n<br />\n<br />\n一般嚟講，hybrod camber 偏 camber 特性，想要 carving，高速時穩定性就用佢。<br />\n而 hybrid rocker 就偏 rocker 特性，要 playful 啲，滑powder好啲就佢。<br />\n<br />\n我會建議你選 hybrid camber，始終你想練 carving，需要穩定性。你有機會一直 carving 落山，但唔會一路 ground tricks 落山。"},{"pid":"e20e59b4fd634e9adf47d41d11b4df09e6c2a955","tid":809464,"uid":152232,"like":0,"dislike":0,"score":0,"quote":{"pid":"61b28d7535a2ab8a8f81470979cd59a3ab50e7f8","tid":809464,"uid":16552,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2018-09-10T16:54:31.000Z","msg":"有冇機會ab test埋feiyu g6防潑水果支穩定器?<br />\n見佢防潑水好似幾岩滑雪用<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n想off topic問下少少關於買板既野<br />\n上年開始滑單板, 綠線紅線普通s turn落山冇乜大問題<br />\n之前剩係租過板, 租到既例如burton LTR之類我估應該係camber板<br />\n黎緊今年想買自己板,<br />\nhybrid camber(即係rocker-camber-rocker),<br />\n或hybrid rocker(camber-rocker-camber)會唔會同普通camber板有好大分別?<br />\n睇中左果d板全部都係hybrid黎, 自己又未接觸過<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n今年想試下carve同練下d press/ollie/nollie之類既野<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-11T01:31:57.000Z","msg":"另外，嚟緊有個免費滑雪講座幾啱你，係俾啲想進階嘅雪友聽的，你可以參考下：<br />\n<br />\n白馬 Evergreen Alpine Acadamy (EAA) 免費分享會<br />\n<br />\n報名連結: <a href=\"https://goo.gl/forms/9h7kDYCFPKVo7ES23\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgoo.gl%2Fforms%2F9h7kDYCFPKVo7ES23&d=OZDGa8eCb4G2idw2znjWXDPUa9iY%2BpOmOVTB4fMSqaQ%3D&h=6bfdf1ad\" data-auto-link target=\"_blank\">https://goo.gl/forms/9h7kDYCFPKVo7ES23</a><br />\n費用: 全免<br />\n日期: 2018年9月29日(星期六)<br />\n時間: 上午場 10:00am-12:00noon; 下午場 3:00pm-5:00pm(下午場已滿，只能後補)<br />\n地點: 尖沙咀科學館道 14 號新文華中心 A 座13 樓1316 室<br />\n人數: 每場上限40人, 先報先得<br />\n<br />\n要了解 Evergreen, 首先要知道它的創辦人 Mr. Dave Enright.<br />\nDave 在2000年成立 Evergreen Outdoor Center, 在那以前他說已經在白馬很久了, 甚至是頭幾位落地生根的西方人. 關於他的背景可以看這個訪問(<a href=\"https://www.evergreen-hakuba.com/an-interview-with-dave-enright/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.evergreen-hakuba.com%2Fan-interview-with-dave-enright%2F&d=OZDGa8eCb4G2idw2znjWXDPUa9iY%2BpOmOVTB4fMSqaQ%3D&h=f0bcd951\" data-auto-link target=\"_blank\">https://www.evergreen-hakuba.com/an-interview-with-dave-enright/</a>), 就不重覆說了. <br />\n<br />\n重點需要知道的是, 他在白馬的大山野雪裏做嚮導已經很久很久了, 是推動白馬開放off piste滑雪的人, 也是FWT(Freeride World Tour), 即是每年Travis Rice會參加的那個比賽, Dave正是比賽的安全顧問, 雪崩的風險有幾高導至能否比賽是他說了算. 去年在 滑雪控 Snowkon Caf&eacute; 聽他和死神擦身而過的雪崩分享, 真的感受良多, 有沒有各種雪地和雪崩知識, 可能就是生死一線的差別. 重視專業, 表現專業, Evergreen在多年間建立起超過200位教練的專業教學團隊, 加上各種雪崩課程和野雪嚮導服務.<br />\n<br />\nEvergreen Alpine Acadamy (EAA) 是專為進階滑雪者而設. 它為整所滑雪學校的教練提供訓練(即是教練的教練), 裏面全是經驗豐富的高階訓練官和滑雪專家. 同時也提供各種滑雪教練的考核服務, 也有一些短期訓練班和工作坊為進階滑雪愛好者而設.<br />\n<br />\n這次EAA派出其最高負責人 Mr. Javier Calzada 來香港和大家作分享, 內容將會圍繞:<br />\n- Evergreen 的願景和服務內容<br />\n- CASI 教練課程<br />\n- 雙板教練課程<br />\n- Gap year 計劃資料<br />\n- 雪崩與山岳認知<br />\n- 高山滑行與FWT比賽<br />\n- 裝備知識與推介<br />\n- 白馬村的資料<br />\n(實質內容或會因應報名雪友之偏好而稍作調整)<br />\n<br />\n另外, EAA會在11月第一個星期(暫定)再派出CASI考官級教練到港舉辦針對教練考試的準備講座, 介時將會是收費課程. 而為答謝雪友, 如於本次活動中即場報名CASI教練考試, 可免費參加11月份之考試講座!<br />\n<br />\n報名連結: <a href=\"https://goo.gl/forms/9h7kDYCFPKVo7ES23\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgoo.gl%2Fforms%2F9h7kDYCFPKVo7ES23&d=OZDGa8eCb4G2idw2znjWXDPUa9iY%2BpOmOVTB4fMSqaQ%3D&h=6bfdf1ad\" data-auto-link target=\"_blank\">https://goo.gl/forms/9h7kDYCFPKVo7ES23</a><br />\n<br />\n注意:<br />\n- 成功填寫Google Form報名表格後會收到Google自動回郵作記錄, 並非代表成功報名, 請等候大會通知作實.<br />\n- 此活動並非鼓勵雪友盲目報考滑雪教練, 反過來希望有對滑雪教練牌照有興報的雪友, 可以借此良機去了解詳情和考牌的背後意義."},{"pid":"88f19084e05d92eda242901f2efd910af4aae35d","tid":809464,"uid":135,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-11T01:49:13.000Z","msg":"支持滑雪post <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n我有部Sony as300 唔用雲台都好定<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"b3c6fe791bff055bb46ff43625858bd336c09e31","tid":809464,"uid":152232,"like":0,"dislike":0,"score":0,"quote":{"pid":"88f19084e05d92eda242901f2efd910af4aae35d","tid":809464,"uid":135,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-11T01:49:13.000Z","msg":"支持滑雪post <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n我有部Sony as300 唔用雲台都好定<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-11T01:52:08.000Z","msg":"多謝師兄!!<br />\n係呀 Sony 部 action cam 有光學穩定，幾唔錯的!"},{"pid":"1cf2de14712779f63ab3fb3b36c29b729fd58fb1","tid":809464,"uid":18702,"like":1,"dislike":0,"score":1,"quote":{"pid":"94090aa04e25a77fa7edd51ba862b41bb88a08a5","tid":809464,"uid":152232,"like":0,"dislike":0,"score":0,"quote":{"pid":"0716313e40f663452f005ccf8f6427b213d34fce","tid":809464,"uid":18702,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-10T01:42:44.000Z","msg":"想問下巴打們第一次滑雪係自學定有人教<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n年頭果時去玩左幾日 <br />\n即使睇過下啲教學片都係勉強鳩流流咁<br />\n單板都仲控制到左右 但雙板直頭失控<br />\n雖然跌左幾日 但係都到滑雪呢樣運動好有興趣<br />\n希望下年可以舞得掂<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-10T16:16:31.000Z","msg":"我第一次係北京南山，請咗兩日一個來自哈爾濱嘅教練。個教練自己滑得好勁，但就冇受過系統性嘅教學訓練，所以唔係咁識教。我之後再冇跟過教練學，淨係自學，直到考教練。<br />\n<br />\n睇返轉頭，我係好後悔，自學真係走咗好多冤枉路，如果有個好嘅教練教，我成個滑雪生涯會好唔同。<br />\n<br />\n如果你有興趣滑，想認真學，就一定要跟教練。你可選擇去日本一啲比較多香港教練駐守嘅雪場，咁樣比較易搵到香港教練教。"},"citedBy":1,"replyTime":"2018-09-11T02:32:00.000Z","msg":"多謝巴打細心解答<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n下次去之前睇定啲料先<br />\n上次去適逢新年 莫講話無教練 <br />\n連個reception都無開<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /> <br />\n跌左半日 後來想搵教練都搵唔到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}