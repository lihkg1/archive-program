e":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-25T07:25:45.000Z","msg":"嚇鬼咩屌你老母，道指升到30,000點呀<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"2a97bf556ee89a61fe8a3bc8993e812c63ef8697","tid":131340,"uid":9264,"like":0,"dislike":0,"score":0,"quote":{"pid":"e8dab98329e2aa63dbbc655dcb63259237920f7c","tid":131340,"uid":62755,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-02-23T13:44:03.000Z","msg":"<blockquote>通常見到呢d文之後就大升</blockquote>"},"citedBy":1,"replyTime":"2019-07-16T12:44:56.000Z","msg":"美股新高<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fc42ee65010e6a738854e500b6b13891435c2d85","tid":131340,"uid":62755,"like":0,"dislike":0,"score":0,"quote":{"pid":"2a97bf556ee89a61fe8a3bc8993e812c63ef8697","tid":131340,"uid":9264,"like":0,"dislike":0,"score":0,"quote":{"pid":"e8dab98329e2aa63dbbc655dcb63259237920f7c","tid":131340,"uid":62755,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-02-23T13:44:03.000Z","msg":"<blockquote>通常見到呢d文之後就大升</blockquote>"},"citedBy":1,"replyTime":"2019-07-16T12:44:56.000Z","msg":"美股新高<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-16T16:55:15.000Z","msg":"乜料兩年前嘅po都推"},{"pid":"9ea42b03101625835fd44c350349d81ff53dca06","tid":131340,"uid":9264,"like":0,"dislike":0,"score":0,"quote":{"pid":"fc42ee65010e6a738854e500b6b13891435c2d85","tid":131340,"uid":62755,"like":0,"dislike":0,"score":0,"quote":{"pid":"2a97bf556ee89a61fe8a3bc8993e812c63ef8697","tid":131340,"uid":9264,"like":0,"dislike":0,"score":0,"quote":{"pid":"e8dab98329e2aa63dbbc655dcb63259237920f7c","tid":131340,"uid":62755,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-02-23T13:44:03.000Z","msg":"<blockquote>通常見到呢d文之後就大升</blockquote>"},"citedBy":1,"replyTime":"2019-07-16T12:44:56.000Z","msg":"美股新高<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyT