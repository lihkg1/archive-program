mal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"f4ce2e5fc105680d2fe49d280c961344aedc6b72","tid":601053,"uid":34243,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-22T15:54:06.000Z","msg":"why not both<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"9d15f869212ac956c7bc130fca64e4ba5def5fea","tid":601053,"uid":117552,"like":6,"dislike":1,"score":5,"citedBy":0,"replyTime":"2018-03-22T16:50:32.000Z","msg":"04最好睇"},{"pid":"78b79de8a6bfe9a062c4ce8ce5d1ebe3083fb1e4","tid":601053,"uid":14274,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-22T17:03:38.000Z","msg":"正評<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<br />\nXY 未做結尾嗰陣投<br />\n差距應該無咁大<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"dbc623b59076eda9236078cb19f8965ffa53e0e4","tid":601053,"uid":141210,"like":1,"dislike":12,"score":-11,"citedBy":1,"replyTime":"2018-03-22T17:09:21.000Z","msg":"寵物小精靈d劇情認真好多<br />\n一套接一套都有連貫性,我係睇到小智輸比鎖血水抗X噴先放棄<br />\n<br />\n數碼暴龍d劇情on撚鳩,中二病,小學雞,少少熱血<br />\n好老實,除左01劇情好d之外,好多都有病<br />\n02大家心照,03on99樹莉破壞成套,明明劇情展開得好地地,多左班新既馴獸師就中哂伏<br />\n04拖泥帶水,05值得睇既係大門大獸,d皇騎同世界樹都弱智<br />\nxros玩合體已經有病,但第一季劇情接受到,第二季又玩小學雞模式"},{"pid":"fbca1a134ee2b52473ff644dd0b54afca434243a","tid":601053,"uid":141210,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-22T17:10:41.000Z","msg":"講漏左,其實兩邊都好難揀<br />\n<br />\n但講焦點對戰一定係寵精贏,一定好睇過數碼暴龍鳩出技<br />\n人地寵精講戰略性,小智打輸左除左屈主角威能係有用腦"},{"pid":"1a0abfdb6c654247083413182a12c79ee4246492","tid":601053,"uid":126622,"like":9,"dislike":3,"score":6,"quote":{"pid":"dbc623b59076eda9236078cb19f8965ffa53e0e4","tid":601053,"uid":141210,"like":1,"dislike":12,"score":-11,"citedBy":1,"replyTime":"2018-03-22T17:09:21.000Z","msg":"寵物小精靈d劇情認真好多<br />\n一套接一套都有連貫性,我係睇到小智輸比鎖血水抗X噴先放棄<br />\n<br />\n數碼暴龍d劇情on撚鳩,中二病,小學雞,少少熱血<br />\n好老實,除左01劇情好d之外,好多都有病<br />\n02大家心照,03on99樹莉破壞成套,明明劇情展開得好地地,多左班新既馴獸師就中哂伏<br />\n04拖泥帶水,05值得睇既係大門大獸,d皇騎同世界樹都弱智<br />\nxros玩合體已經有病,但第一季劇情接受到,第二季又玩小學雞模式"},"citedBy":0,"replyTime":"2018-03-23T02:09:42.000Z","msg":"<span style=\"font-size: large;\">Pokemon d劇情認真<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 我聽到真係得淡笑</span><br />\n你可以話佢有連貫，但d劇情真係完全濕尻商業卡通<br />\n漫畫版寵物小精靈特別篇個故事就真係有劇情有伏線解線，動畫版就千篇一律去唔同地方捉寵識朋友，<span style=\"color: red;\">難聽講劇情級數同哈姆太郎一尻樣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n</span>小智果d死人性格，套野做左十幾年，我小計當你大左兩歲，但思想同當年出發係完全都冇成長過，咁都唔叫熱血中二我真係冇野講<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n至於數碼暴龍，基本04打後唔洗睇<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <br />\n<br />\n你可以話佢小學雞熱血，咁人地角色真係成堆小學生中間有個熱血撚好正常，唔通你叫佢行小圓咁黑暗風咩<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 但中二同on9就真係唔知你指乜<br />\n<br />\n02柒就係人都知，但03係當時可以話係救起左因為02而衰左既數碼暴龍系列。<br />\n<br />\n03可以話係最貼近當時細路幻想自己可以似太一佢地咁有屬於自己既數碼精靈，同時又要面對現實不同困境既作品黎。<br />\n<br />\n個心路歷程好寫實講班細路由只係想同數碼精靈做朋友玩下，到發現原來數碼精靈既弱肉強食套用係現實既殘酷同埋隨住佢地進化會影響到身邊既人造成其他人既恐慌等，大家既調停者獅子獸之死既哀傷，到樹莉走出陰霾放心都寫實表現佢地既成長。<br />\n<br />\n04既表現就中規中矩，劇情上冇左數碼精靈拍擋反而自己變做精靈依點偏特攝風其實我就唔多討好，幸好劇情上未至於太差，唔會一面倒偏向主角勝利，中間都會有主角打輸要走佬思考策略既劇情補番少少分。最成功係引入左七大魔王同皇家騎士依個引人入勝既概念。<br />\n<br />\n睇咁多年仲鐘意睇一成不變既寵物小精靈，我睇你個人都冇乜成長過<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"5602e88c300b7515066f4a75bd0fd7a621f7c69e","tid":601053,"uid":33733,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-23T03:17:11.000Z","msg":"寵物小精靈<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n日月前好睇啲 日月改哂風格 但都覺得ok 既 等緊睇打巡島"},{"pid":"d9d0ba1853ed4c07c09673d6361aaa9153ce5371","tid":601053,"uid":56657,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-23T03:23:52.000Z","msg":"正評係for無印<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"7647eec979ee674625e3e1705df0d79f71483e4a","tid":601053,"uid":133502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-23T03:47:29.000Z","msg":"尋晚睇到火車站d poster<br />\n而家叫精靈寶可夢喇 唉"},{"pid":"56c41c1f08cecbde07e31b737159550ed279142c","tid":601053,"uid":73890,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-03-23T03:55:47.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /> digimon 嗰兩隻網絡偵探個故事線仲吸引過tri<br />\n應該攞去整動畫<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"16a34026e1b2b2b10100baff8580352361f390d8","tid":601053,"uid":31542,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-23T05:51:11.000Z","msg":"Pokemon一直都係兒童向<br />\n係去到XY&amp;Z先係比青少年以上睇"},{"pid":"e99c5f80f19559991e1a30fad24f7e61c061fcce","tid":601053,"uid":82743,"like":0,"dislike":0,"score":0,"quote":{"pid":"880f14f02fe7dc57bacc85a71a69082e128b4268","tid":601053,"uid":165817,"like":69,"dislike":4,"score":65,"citedBy":3,"replyTime":"2018-03-22T01:51:35.000Z","msg":"不過其實應該好多人同我一樣，覺得動畫係數、打機係寵<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-24T02:55:45.000Z","msg":"之前果集數碼偵探+DLC好正呀....反而PKM我真係好耐無玩啦....新果D真係唔係幾提得起興趣....對上一隻已經係重製紅寶石"},{"pid":"2edf1d0d47b9be54d5b657666ebe03d9adf10cc1","tid":601053,"uid":139242,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-24T03:01:07.000Z","msg":"pkm好少少<br />\n超世代去dp都好正"},{"pid":"f33d73829d370e77cc499ed7164c5aa7dc18657b","tid":601053,"uid":118127,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-24T03:01:16.000Z","msg":"依家個d數碼暴龍應該係gundam黎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b371fd2609c637405ea5e4f5e3bfef37ea33fbe0","tid":601053,"uid":22046,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-24T03:06:58.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/03/24/110548_c1b78797ce8adb17fea00b59eb50e8c5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F24%2F110548_c1b78797ce8adb17fea00b59eb50e8c5.png&h=d5cf79b9&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/24/110624_a2987a95840491a317cf32bcd59bf5b1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F24%2F110624_a2987a95840491a317cf32bcd59bf5b1.png&h=09667559&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/24/110549_c1b78797ce8adb17fea00b59eb50e8c5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F24%2F110549_c1b78797ce8adb17fea00b59eb50e8c5.png&h=3dd8e918&s={SIZE}\" /><br />\n<br />\n呢排又玩返<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n仲有美版睇劇情"},{"pid":"736a383f34397db0441ca36bfbdd76fef12b8e93","tid":601053,"uid":46389,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-24T03:34:56.000Z","msg":"pokemon dp劇情好有深意<br />\n除左日常太拖同畫面差距我唔覺有乜差過xy，就算xy結局係小智贏都係咁話"}]}