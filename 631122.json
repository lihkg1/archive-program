h.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F16%2F145542_7d90ff57c635385f61c7f442b00e5e93.PNG&h=e085e6f1&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/16/145546_fbc8302c5d3cdad350b78d300bd8ec29.PNG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F16%2F145546_fbc8302c5d3cdad350b78d300bd8ec29.PNG&h=cf00f699&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/16/145554_97f53ff508859c9475d89835d94ab9fc.PNG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F16%2F145554_97f53ff508859c9475d89835d94ab9fc.PNG&h=0b1ffde8&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/16/145558_bca75245b6eec83aa8cc2a4509fa1ffa.PNG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F16%2F145558_bca75245b6eec83aa8cc2a4509fa1ffa.PNG&h=9c623e6b&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/16/145606_ceb2e98e40c9c729481a4967729a9e9a.PNG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F16%2F145606_ceb2e98e40c9c729481a4967729a9e9a.PNG&h=ade1a75f&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/16/145609_b2a3887475ca70945f1e34a601057c06.PNG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F16%2F145609_b2a3887475ca70945f1e34a601057c06.PNG&h=abad62c0&s={SIZE}\" /><br />\n<br />\n而每當受害人發現男方出軌、背叛，男方就會當下老羞成怒，打到女方傷痕纍纍，鬧到佢狗都不如，多次離合，男方每次又會對受害人甜言蜜語，苦苦哀求，又多次衝到受害人屋企哀求做成滋擾，唯受害人太愛佢、好撚唔理智，盲Q左，一直比機會佢，望佢會改過，而冇報警拉佢。<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/16/145713_a398b1f6e30ac390d2490b1696a687c9.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F16%2F145713_a398b1f6e30ac390d2490b1696a687c9.jpeg&h=f412a038&s={SIZE}\" /><br />\n<br />\n而佢呢幾年都食盡天下唔同既女，而每次食完女都會以為自己係食女blogger拍片同人分享，好撚威咁。而當下如果d女唔同佢搞就即刻發嬲，覺得自己一定要食硬人。<br />\n佢聲稱曾經搞大其中一條女個肚，隨即消失走人。<br />\n佢自稱搞過超過100個女人，而自己每搞完一個都會紀錄自己名單到。<br />\n<a href=\"https://youtu.be/F0VHIdt0hLM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FF0VHIdt0hLM&d=B3wWFzDYCiY6GGcomhzFmozZXVCnaYNE8CBFJ%2F%2FgXXY%3D&h=eb549207\" data-auto-link target=\"_blank\">https://youtu.be/F0VHIdt0hLM</a><br />\n<a href=\"https://youtu.be/TeVJkgL3mDo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FTeVJkgL3mDo&d=B3wWFzDYCiY6GGcomhzFmozZXVCnaYNE8CBFJ%2F%2FgXXY%3D&h=1668dcbc\" data-auto-link target=\"_blank\">https://youtu.be/TeVJkgL3mDo</a><br />\n<a href=\"https://youtu.be/NGV0FFeln1A\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FNGV0FFeln1A&d=B3wWFzDYCiY6GGcomhzFmozZXVCnaYNE8CBFJ%2F%2FgXXY%3D&h=473c9a9c\" data-auto-link target=\"_blank\">https://youtu.be/NGV0FFeln1A</a><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/16/150452_2e7ef5071e5c4110ad2435ff02bba26c.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F16%2F150452_2e7ef5071e5c4110ad2435ff02bba26c.jpeg&h=d2faf238&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/16/150452_d7c4b534a16fafcb17bcbfbbdc7b3989.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F16%2F150452_d7c4b534a16fafcb17bcbfbbdc7b3989.jpeg&h=2042b6a1&s={SIZE}\" /><br />\n<br />\n佢經常以自己就黎成為機師之名透過交友apps,蘭桂芳，吸引唔同嘅女仔同自己扑野。男方亦有噁心既僻好，包括鐘意搞年紀比佢大二十歲嘅中年女人，心理變態。另外，佢亦有拍片紀錄同唔同女仔搞野嘅過程，而果d女仔未必知情。<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/16/150603_9cb30ec2473f42e9bce48cd671b25e44.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F16%2F150603_9cb30ec2473f42e9bce48cd671b25e44.jpg&h=075e5095&s={SIZE}\" /><br />\n<img src=\"htt