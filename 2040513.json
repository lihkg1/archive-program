s/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"df05e73ffd1af92efeac12c9ea1180cf1ffdfec9","tid":2040513,"uid":65116,"like":0,"dislike":0,"score":0,"quote":{"pid":"df017c67fc76dd7739b91f2ba5dc31967517c8fe","tid":2040513,"uid":35420,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-30T16:25:40.000Z","msg":"買啦"},"citedBy":0,"replyTime":"2020-05-30T17:14:23.000Z","msg":"只係覺得有能力養既話想將啲愛比未有人養既貓先<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 諗到如果佢地成世都無一個主人比100%愛佢好慘<br />\n寵物店嗰啲咁可愛一定唔缺人錫"},{"pid":"d4d536e9fa63256b01c138c7fcd256d770436ef8","tid":2040513,"uid":156298,"like":0,"dislike":5,"score":-5,"quote":{"pid":"b9e384c139fa2f39bacd222c47ce6f8b0b57ef0e","tid":2040513,"uid":65116,"like":1,"dislike":1,"score":0,"quote":{"pid":"f427267b3fa796ab7566cb139ba1abe7ea82a26d","tid":2040513,"uid":156298,"like":1,"dislike":7,"score":-6,"citedBy":1,"replyTime":"2020-05-30T16:25:09.000Z","msg":"因為你講就易....<br />\n兩個月都唔等得證明你三分鐘熱度.<br />\n你知唔知湊一隻奶貓到佢可以比人認養係幾辛苦."},"citedBy":1,"replyTime":"2020-05-30T17:12:12.000Z","msg":"咩兩個月 等啲咩 你UP緊乜<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-30T17:27:44.000Z","msg":"領養準備同等既時間最少都兩三個月<br />\n三分鐘熱度就自然放棄，肯一步一步來既先可以到老。當然，有時去救貓即刻就入屋，但責任仲大，你係咪有心理準備先？<br />\n<br />\n我隻貓係救返來既，入屋果幾個月，唔好話錢，冬天室內要恒溫31度，另加暖爐。每日餵藥餵食。<br />\n<br />\n收養想快靚正？如果隻貓係你救返來既，晚晚冇覺好瞓咁照顧佢，人地話想快靚正，你屌唔屌佢？"},{"pid":"3f029544aca1e2930d32e3e7b754842df0ca7bcb","tid":2040513,"uid":2140,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-30T17:36:39.000Z","msg":"愛協超易喎<br />\n上去兩三次就搞掂"}]}