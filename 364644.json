nX9jywtYe9GXZmhCU%3D&h=551ee08f\" target=\"_blank\">https://youtu.be/GOPNlVrcVW8</a></blockquote><br />\n<br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 唔該曬, 仲有少少格式問題想問一問<br />\n<br />\n衣家用左師兄寫既程式碼排序成功左，但係可唔可以一次過做到圖2既效果?  即係空格係後面，而唔係係前面??<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /></blockquote><br />\n我上載咗新版本的程式碼<br />\n你可以再試一試</blockquote><br />\n最新果個版本係夜晚8點10分上載</blockquote><br />\n<br />\n師兄有料, 唔該曬<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\n有個問題幫人問，衣家有A表格 (圖1) 同B表格 (圖2)<br />\nA表格係已排序好既數值 (如1~15)<br />\nB表格係要Print出黎既格式 (其中有一格係a表格中既數值)<br />\n<br />\n點樣可以係a表格拉曬1~15過去b表格然後自動print曬15張分別係1~15<br />\n<br />\n麻煩曬師兄，公司有呢d Excel要做，最衰自己學得唔好<br />\n<br />\n圖1<br />\n<br />\n <img src=\"https://img.eservice-hk.net/upload/2017/08/20/232648_e85dd68da8a530bca42fa02938f272d6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F20%2F232648_e85dd68da8a530bca42fa02938f272d6.jpg&h=160bc450&s={SIZE}\" /><br />\n<br />\n圖2<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/08/20/232703_961cdf263aaa8b6e7c9be23d974f35fe.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F20%2F232703_961cdf263aaa8b6e7c9be23d974f35fe.jpg&h=58009eed&s={SIZE}\" />"},{"pid":"34c409aa1a597e7c56151d61e6389829c9e094c6","tid":364644,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-20T15:57:10.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote>用vba會好簡單<br />\n拍咗段Youtube片教你用<br />\n<a href=\"https://youtu.be/GOPNlVrcVW8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FGOPNlVrcVW8&d=t8MnJK60ueCJAo%2FMvIiSep7TfgnX9jywtYe9GXZmhCU%3D&h=551ee08f\" target=\"_blank\">https://youtu.be/GOPNlVrcVW8</a></blockquote><br />\n<br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 唔該曬, 仲有少少格式問題想問一問<br />\n<br />\n衣家用左師兄寫既程式碼排序成功左，但係可唔可以一次過做到圖2既效果?  即係空格係後面，而唔係係前面??<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /></blockquote><br />\n我上載咗新版本的程式碼<br />\n你可以再試一試</blockquote><br />\n最新果個版本係夜晚8點10分上載</blockquote><br />\n<br />\n師兄有料, 唔該曬<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\n有個問題幫人問，衣家有A表格 (圖1) 同B表格 (圖2)<br />\nA表格係已排序好既數值 (如1~15)<br />\nB表格係要Print出黎既格式 (其中有一格係a表格中既數值)<br />\n<br />\n點樣可以係a表格拉曬1~15過去b表格然後自動print曬15張分別係1~15<br />\n<br />\n麻煩曬師兄，公司有呢d Excel要做，最衰自己學得唔好<br />\n<br />\n圖1<br />\n<br />\n <img src=\"https://img.eservice-hk.net/upload/2017/08/20/232648_e85dd68da8a530bca42fa02938f272d6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F20%2F232648_e85dd68da8a530bca42fa02938f272d6.jpg&h=160bc450&s={SIZE}\" /><br />\n<br />\n圖2<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/08/20/232703_961cdf263aaa8b6e7c9be23d974f35fe.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F20%2F232703_961cdf263aaa8b6e7c9be23d974f35fe.jpg&h=58009eed&s={SIZE}\" /></blockquote><br />\n唔知道你地實際的format + Pattern係咩做唔到wor<br />\n點樣決定邊張sheets(表格)係拎邊個數字？<br />\n<br />\n同埋你數字的擺法咁奇怪, 點解要分3行擺<br />\n同埋依堆數字係咪一定係由1-15？定係可能係任何數字？"},{"pid":"9bd372176ebe300142dce9051f39e75c26de7e03","tid":364644,"uid":131703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-20T16:02:57.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><blockquote>用vba會好簡單<br />\n拍咗段Youtube片教你用<br />\n<a href=\"https://youtu.be/GOPNlVrcVW8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FGOPNlVrcVW8&d=t8MnJK60ueCJAo%2FMvIiSep7TfgnX9jywtYe9GXZmhCU%3D&h=551ee08f\" target=\"_blank\">https://youtu.be/GOPNlVrcVW8</a></blockquote><br />\n<br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 唔該曬, 仲有少少格式問題想問一問<br />\n<br />\n衣家用左師兄寫既程式碼排序成功左，但係可唔可以一次過做到圖2既效果?  即係空格係後面，而唔係係前面??<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /></blockquote><br />\n我上載咗新版本的程式碼<br />\n你可以再試一試</blockquote><br />\n最新果個版本係夜晚8點10分上載</blockquote><br />\n<br />\n師兄有料, 唔該曬<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\n有個問題幫人問，衣家有A表格 (圖1) 同B表格 (圖2)<br />\nA表格係已排序好既數值 (如1~15)<br />\nB表格係要Print出黎既格式 (其中有一格係a表格中既數值)<br />\n<br />\n點樣可以係a表格拉曬1~15過去b表格然後自動print曬15張分別係1~15<br />\n<br />\n麻煩曬師兄，公司有呢d Excel要做，最衰自己學得唔好<br />\n<br />\n圖1<br />\n<br />\n <img src=\"https://img.eservice-hk.net/upload/2017/08/20/232648_e85dd68da8a530bca42fa02938f272d6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F20%2F232648_e85dd68da8a530bca42fa02938f272d6.jpg&h=160bc450&s={SIZE}\" /><br />\n<br />\n圖2<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/08/20/232703_961cdf263aaa8b6e7c9be23d974f35fe.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F08%2F20%2F232703_961cdf263aaa8b6e7c9be23d974f35fe.jpg&h=58009eed&s={SIZE}\" /></blockquote><br />\n唔知道你地實際的format + Pattern係咩做唔到wor<br />\n點樣決定邊張sheets(表格)係拎邊個數字？<br />\n<br />\n同埋你數字的擺法咁奇怪, 點解要分3行擺<br />\n同埋依堆數字係咪一定係由1-15？定係可能係任何數字？</blockquote><br />\n<br />\n唔一定係由1~15, 可以係任何數字<br />\n圖2既表格，粗體字數字果格就係拎圖1表格既數字<br />\n<br />\n或者可以咁講  圖1表格已經係完成好(排好序)<br />\n衣家要做就係將圖1表格數值拉去另一個表格然後自動列印曬呢一堆數值<br />\n<br />\n如果1999, sorry巴打"},{"pid":"3d2ac1c6086c0c3c13ce9bbd5b1be2f028497066","tid":364644,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-20T16:06:45.000Z","msg":"我當你有15張sheets要列印，咁依15張sheets的內容除咗數字唔同之外，仲有冇其他地方唔同？"},{"pid":"00eb40b7594b3255a7d1e57ae0f56fd596510292","tid":364644,"uid":131703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-20T16:09:49.000Z","msg":"<blockquote>我當你有15張sheets要列印，咁依15張sheets的內容除咗數字唔同之外，仲有冇其他地方唔同？</blockquote><br />\n<br />\n無，除左數字唔同之外，其他格式相同"},{"pid":"ee5266bb47f41870c9417c8b4bd3956b18d019a6","tid":364644,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-20T16:10:28.000Z","msg":"第2個問題，你圖一點解係分3行排列？<br />\n每行有幾多個數值？總共有幾多行？<br />\n圖一果張sheets有冇其他information<br />\n<br />\n無依D資料，咁個程式唔會自己識得睇你的圖一"},{"pid":"0ebbc9b8508f5c7b346109191fa77c06137bfb07","tid":364644,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-20T16:14:26.000Z","msg":"<blockquote><blockquote>我當你有15張sheets要列印，咁依15張sheets的內容除咗數字唔同之外，仲有冇其他地方唔同？</blockquote><br />\n<br />\n無，除左數字唔同之外，其他格式相同</blockquote><br />\n咁一開始唔洗排序啦<br />\n係咪都直接印哂出黎"},{"pid":"75fcd1d20aed072b2a010373f67242deeb3d665f","tid":364644,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-20T16:24:22.000Z","msg":"我寫到啦<br />\n其實你根本唔洗十幾張Sheets，只要一張sheet就得，我們只需要不停改同一張sheet的value，然後即刻印出黎就得<br />\n<br />\n不過今次我唔拍片啦<br />\nStep 1. 你改一改以下依個程式<br />\n紅色地方改做你想列印果張sheet的名稱<br />\n藍色地方改做你想改數值果一格，例如C3就係3,3，如果B4就係4,2，如果C5就係5,3<br />\nStep 2. 你揀返你排序完果堆數字<br />\nStep 3. 執行以下程式<br />\n<br />\n不過依個程式印出黎的次序同你想要的唔一樣。佢係由上至下，由左至右咁印。<br />\n你想要的應該係由左至右，由上至下。不過依個我唔處理住。<br />\n你做個小測試睇下work唔work先（印住兩三張先），我自己都未測試過依個程式。<br />\n<br />\nSub test()<br />\n<br />\nFor Each Item In Selection.Value<br />\n    Worksheets(&quot;<span style=\"color: red;\">5KG EVERSAFE-EEC</span>&quot;).Cells(<span style=\"color: blue;\">3, 3</span>) = Item<br />\n    Worksheets(&quot;<span style=\"color: red;\">5KG EVERSAFE-EEC</span>&quot;).PrintOut<br />\nNext Item<br />\n<br />\nEnd Sub"},{"pid":"ffbd7748ddba90d88c37009735f75e0e1abc42d7","tid":364644,"uid":131703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-21T06:58:19.000Z","msg":"<blockquote>我寫到啦<br />\n其實你根本唔洗十幾張Sheets，只要一張sheet就得，我們只需要不停改同一張sheet的value，然後即刻印出黎就得<br />\n<br />\n不過今次我唔拍片啦<br />\nStep 1. 你改一改以下依個程式<br />\n紅色地方改做你想列印果張sheet的名稱<br />\n藍色地方改做你想改數值果一格，例如C3就係3,3，如果B4就係4,2，如果C5就係5,3<br />\nStep 2. 你揀返你排序完果堆數字<br />\nStep 3. 執行以下程式<br />\n<br />\n不過依個程式印出黎的次序同你想要的唔一樣。佢係由上至下，由左至右咁印。<br />\n你想要的應該係由左至右，由上至下。不過依個我唔處理住。<br />\n你做個小測試睇下work唔work先（印住兩三張先），我自己都未測試過依個程式。<br />\n<br />\nSub test()<br />\n<br />\nFor Each Item In Selection.Value<br />\n    Worksheets(&quot;<span style=\"color: red;\">5KG EVERSAFE-EEC</span>&quot;).Cells(<span style=\"color: blue;\">3, 3</span>) = Item<br />\n    Worksheets(&quot;<span style=\"color: red;\">5KG EVERSAFE-EEC</span>&quot;).PrintOut<br />\nNext Item<br />\n<br />\nEnd Sub</blockquote><br />\n<br />\n麻煩曬巴打  我試一試先<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n係咪用番上一次個模組方法咁RUN就OK?"}]}