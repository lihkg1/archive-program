7968713bca101bf759129d4c9362","tid":2011371,"uid":81236,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-11T13:06:44.000Z","msg":"推"},{"pid":"e02d76834382c39ebc5e9a71e1478ce022409b41","tid":2011371,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-12T00:32:41.000Z","msg":"推"},{"pid":"adbd70172f531b169d686bb538271bb036584b2d","tid":2011371,"uid":225192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-12T01:18:53.000Z","msg":"香港人開Twitter啦"},{"pid":"13b825daba5bffef3cf7ef9590cb6c19bbffdfce","tid":2011371,"uid":44358,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-12T01:23:20.000Z","msg":"實用<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n眾志個ＴＷＩＴＴＥＲ，其實跟時事好足，大家可以ＦＯＬＬＯＷ然後ＲＥＴＷＥＥＴ。又或者港台都係<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"0816b35fa6cacf055c5185cae9a179bb6a52c025","tid":2011371,"uid":259674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-12T01:31:03.000Z","msg":"推"},{"pid":"0fbf4305538b5b403c8155e22d0babe3f9cc01ec","tid":2011371,"uid":340040,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-12T02:03:23.000Z","msg":"Push"},{"pid":"3512b7dc18dd5c5ec39fb0aa636763fb13d9e785","tid":2011371,"uid":213037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-12T07:30:39.000Z","msg":"Twitter 戰線手足整咗個網站出嚟比大家做task<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n以後大家無藉口唔打國際線喇<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><br />\n快啲bookmark 佢啦<br />\n<a href=\"https://act4hk.com/twitter\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fact4hk.com%2Ftwitter&d=jhMTXyFjUfd7nN31cC%2BnyZmjxQ%2Bt9FMRZQKIc78GZWw%3D&h=104cf591\" data-auto-link target=\"_blank\">https://act4hk.com/twitter</a><br />\n<br />\n入bot 拎任務24小時更新：<br />\n<a href=\"https://t.me/TwitterHelpBot\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FTwitterHelpBot&d=jhMTXyFjUfd7nN31cC%2BnyZmjxQ%2Bt9FMRZQKIc78GZWw%3D&h=93c49346\" data-auto-link target=\"_blank\">https://t.me/TwitterHelpBot</a><br />\n<br />\n另有手足會係佢Twitter Account 每日更新任務:<br />\n<a href=\"https://twitter.com/TweetingforHK\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2FTweetingforHK&d=jhMTXyFjUfd7nN31cC%2BnyZmjxQ%2Bt9FMRZQKIc78GZWw%3D&h=ceb70b0f\" data-auto-link target=\"_blank\">https://twitter.com/TweetingforHK</a><br />\n<br />\n或者download 香城online 個app 都有Twitter 任務做<br />\n<a href=\"http://bit.ly/HKOnlinePortal\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2FHKOnlinePortal&d=jhMTXyFjUfd7nN31cC%2BnyZmjxQ%2Bt9FMRZQKIc78GZWw%3D&h=fe7ff144\" data-auto-link target=\"_blank\">http://bit.ly/HKOnlinePortal</a><br />\n<br />\nLike retweet reply<br />\nTask2係國際戰線，唔好淨係推Task 1,Task2都好重要。<br />\n*如果見到想用嘅圖已經有手足用咗請搵第二張圖<br />\n*如果見到已經有好多圖就唔好再放圖，只留文字（短短地都得）<br />\n*唔好只係扔低張圖咩字都唔打<br />\n*唔知留咩好就like 手足留言或者啲對我哋有利嘅留言<br />\n<br />\n將Twitter 變成日常，每人每日做少少。<br />\n每人嘅一小步加埋就係一大步。<br />\n我哋唔知做咩先有用，所以咩都試下咩都做下。<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"}]}