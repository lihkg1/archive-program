2F%2Fpbs.twimg.com%2Fmedia%2FBZaVEM4CAAALZY1.jpg&h=ce7b6fa7&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-10-10T12:19:50.000Z","msg":"唔知幾時先發酵完成<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n癲過西班牙黑毛豬"},{"pid":"88756f016f7de1cb7e3728381c456dee35211ca0","tid":2237590,"uid":21279,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2020-10-10T12:19:54.000Z","msg":"拿<br />\n我就中立嘅<br />\n不過如果南京人唔搞事人地點會殺佢"},{"pid":"a010e955d42f3ef921d6dd1f9e1a96ee6a921b53","tid":2237590,"uid":330057,"like":1,"dislike":0,"score":1,"quote":{"pid":"88756f016f7de1cb7e3728381c456dee35211ca0","tid":2237590,"uid":21279,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2020-10-10T12:19:54.000Z","msg":"拿<br />\n我就中立嘅<br />\n不過如果南京人唔搞事人地點會殺佢"},"citedBy":0,"replyTime":"2020-10-10T12:20:15.000Z","msg":"好人好姐點會無啦啦出現喺南京<br />\n根本就係諗住搞事"},{"pid":"4fff15154aa01f7b285375f37e9b8222d7ff66b1","tid":2237590,"uid":52946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-10T12:21:09.000Z","msg":"<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"ee3c956d72cd2fd205712a98f23431702da58a55","tid":2237590,"uid":154312,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-10-10T12:25:10.000Z","msg":"<img src=\"https://na.cx/i/BcvFxBy.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBcvFxBy.jpg&h=153fa2fa&s={SIZE}\" /><br />\n南海關係緊張 中國第一個自主研發嘅陸上攔扯導彈成功係天津發射  以應付美軍赤裸裸嘅挑引"},{"pid":"8191a7c38a30623d25638456754e2da13ecf4cbe","tid":2237590,"uid":80814,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-10-10T12:25:21.000Z","msg":"今天早上晨跑完，在公園伸展區域又遇到了隔壁的韓粉老王，他怒氣沖沖的說：「我今天要電爆你，中國有一個英雄叫岳飛，這你沒話說了吧？」<br />\n我說：「岳飛？跟我什麼關係？」<br />\n老王說：「他是零缺點的中華英雄。」<br />\n我說：「那可不一定喔，<span class=\"red\">宋高宗明明不孕</span>，<span class=\"red\">岳飛在旁邊一直唧唧歪歪，叫人家立太子</span>，這就好像人家硬不起來，你故意在旁邊看A片一樣，何況武將干預皇帝廢立之事，難不成是想篡權？」<br />\n老王說：「哇幹，我怎麼不知道？」<br />\n<br />\n我說：「你不知道的歷史還很多咧，<span class=\"red\">岳飛的朱仙鎮大捷，號稱500人消滅十萬金兵，歷史考證此事根本不存在，金國將軍根本沒有什麼夏金吾這號人物</span>。」<br />\n老王說：「什麼？沒有朱仙鎮大捷！那以前歷史課本寫假的嗎？怎麼可能！？」<br />\n我說：「國立殯儀館那些死人骨頭編的國語課本都可以騙說蔣公在浙江親睹鮭魚返鄉往上游了，歷史課本為什麼不能欺騙你？」<br />\n<br />\n老王說：「我知道臭頭仔（ 老一輩的人稱呼蔣介石 ）的魚兒往上游是假的，但你說岳飛的歷史造假？不可能吧！我今天一定要辯倒你！！」<br />\n我說：「你知道<span class=\"red\">所謂岳飛傳奇故事，是岳飛的孫子岳珂誇大造假的嗎？趙匡胤的直系子孫宋孝宗為了清除趙光義的子孫宋高宗的朝廷人馬，必須恢復岳飛名譽，於是命令岳珂將家族自傳上呈，作為正史，岳珂嚴重誇大了祖父岳飛的戰功</span>。」<br />\n老王說：「哪有可能！岳飛還有郾城大捷啊！！」<br />\n我說：「<span class=\"red\">郾城大捷其實是岳飛兩萬兵馬打敗完顏宗弼（金兀朮）一萬兵馬。岳飛其他戰事都是敗仗。還有，岳飛不是人格沒有瑕疵，他的軍隊所到之處，會掠奪民財、殺害金國人民、姦淫當地婦女，為金人所痛恨</span>。」<br />\n老王說：「太扯了！岳爺爺會做這種事？」<br />\n<br />\n我說：「還有更扯的，<span class=\"red\">岳飛的舅舅是宋高宗的遠親，大概是宋高宗的堂伯父，也姓趙，岳飛為了震攝朝廷，竟然把這位親舅舅打得半死，只為細故，根本不給宋高宗面子</span>。」<br />\n老王：「我怎麼都不知道⋯」<br />\n我接著說：「你還不知道<span class=\"red\">岳飛常常和其他抗金的宋朝官方部隊內鬥，殺害同朝為將的宋朝將軍，掠奪人家的糧草和兵力，為時人所痛恨；還有常常為小事毆打士兵，更是不得軍心，當時所有人早就在等囂張跋扈的岳飛被皇帝剝皮了，岳飛出事之後，只有物以類聚的炒房色鬼韓世忠幫他說話，其他文武百官皆鄙夷岳飛的為人，等著看他受刑</span>。」<br />\n老王癱軟坐在椅上：「太誇張了⋯太誇張了⋯」<br />\n<br />\n我說：「<span class=\"red\">岳飛遇金兵，非敗即遁，這才是正史，郾城戰役之外，皆是敗仗，岳飛擁兵自重，卻又不敢自立為王，因為軍心不服他，所以他只好回朝接受宋高宗的司法制裁，依法處決，史學家呂思勉說：岳飛勢力覆滅，南宋政權才真正成立</span>。」<br />\n老王說：「你剛剛說，岳飛的歷史是他的孫子編的？憑什麼說他孫子編的故事就有假啊？」<br />\n<br />\n我說：「岳珂被任命為置茶鹽使之後，沒有自愛，一樣繼承著他祖父那鴨霸流氓的習性，到處搜刮民財，強佔他人土地房產，終被舉發，宋孝宗顧念他整肅秦檜勢力有功，所以只將岳珂關了半年，就放他回去爽領18%了。岳珂這種貪官寫的書能信嗎？何況從古至今早就很多史料與史學家逐一打臉岳飛的戰功是造假的了。」<br />\n老王聽罷，面容崩潰：「我這次頭暈，早上忘了吃降血壓藥⋯下次再聊，下次再聊⋯」<br />\n<br />\n我說：「阿北，等等，你不是說要辯倒我？」<br />\n老王說：「挖賽咧棍啦！！」語畢，不見蹤影。"},{"pid":"b20bed90cf6deba5ed0011b64419e50ea879a3d8","tid":2237590,"uid":330057,"like":0,"dislike":0,"score":0,"quote":{"pid":"ee3c956d72cd2fd205712a98f23431702da58a55","tid":2237590,"uid":154312,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-10-10T12:25:10.000Z","msg":"<img src=\"https://na.cx/i/BcvFxBy.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBcvFxBy.jpg&h=153fa2fa&s={SIZE}\" /><br />\n南海關係緊張 中國第一個自主研發嘅陸上攔扯導彈成功係天津發射  以應付美軍赤裸裸嘅挑引"},"citedBy":0,"replyTime":"2020-10-10T12:28:29.000Z","msg":"秘密研發<br />\n航母殺手<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5ca50b0deb16a42e7c956a9a3b