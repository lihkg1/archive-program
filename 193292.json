31_738a7c8902262d9b76a43a3fd43f5675.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F04%2F09%2F161931_738a7c8902262d9b76a43a3fd43f5675.jpg&h=deb4f4c9&s={SIZE}\" /><img src=\"https://na.cx/i/bRR82H0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbRR82H0.jpg&h=9fb3b3cb&s={SIZE}\" />"},{"pid":"59c388295832c8d6a2484aedb1537a0a5aed0c2e","tid":193292,"uid":54733,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-09T08:23:53.000Z","msg":"以前好靚"},{"pid":"36d8a66cc72589a79ed011350418a6ab6836d85a","tid":193292,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-09T08:26:35.000Z","msg":"路上==&gt;輕鐵/電車? <br />\n香港冇street-running啫"},{"pid":"6e15fd09bac83d740c203dbc2ef1c9732e6bdcb9","tid":193292,"uid":14625,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-09T08:27:52.000Z","msg":"上gwulo搵下<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"4617c36a2d679533d4c373fb512fdeff0deac4cc","tid":193292,"uid":36901,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-09T08:45:14.000Z","msg":"以前d路闊好多"},{"pid":"e36a7af22463137eacc11a6b09f7eae5f01534f0","tid":193292,"uid":67338,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-09T08:46:04.000Z","msg":"<blockquote>以前好多地方都有鐵路支線<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/04/09/161931_738a7c8902262d9b76a43a3fd43f5675.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F04%2F09%2F161931_738a7c8902262d9b76a43a3fd43f5675.jpg&h=deb4f4c9&s={SIZE}\" /><img src=\"https://na.cx/i/bRR82H0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbRR82H0.jpg&h=9fb3b3cb&s={SIZE}\" /></blockquote><br />\n<br />\n<br />\n未起何文田站前既溫思勞街隧道真係好有feel<br />\n<br />\n出左隧道仲有堆樹林係頂<br />\n<br />\n漆咸道果邊又唔覺條隧道<br />\n<br />\n<br />\n但係出左樹林就由死人多過生人既街變左調番轉"},{"pid":"1c751c6cb75f9420c8bfbdff2f4948cc9ee4e05c","tid":193292,"uid":67338,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-09T08:46:38.000Z","msg":"<blockquote>以前好多地方都有鐵路支線<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/04/09/161931_738a7c8902262d9b76a43a3fd43f5675.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F04%2F09%2F161931_738a7c8902262d9b76a43a3fd43f5675.jpg&h=deb4f4c9&s={SIZE}\" /><img src=\"https://na.cx/i/bRR82H0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbRR82H0.jpg&h=9fb3b3cb&s={SIZE}\" /></blockquote><br />\n<br />\n唔爭在介紹埋和合石鐵路<br />\n<br />\n不過我印像中你係舊登講過"},{"pid":"3057453f89ea009e1aedeb49171a48a9dd52c595","tid":193292,"uid":51720,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-09T10:35:49.000Z","msg":"有些鐵路支線，係興建臨時鐵路車廠時鋪設；<br />\n永久車廠建成後拆除支線。<br />\n例子：<br />\n西灣河鯉景灣原址（港島綫）<br />\n荔枝角公園第三期以南土地（東涌綫）<br />\n將軍澳車廠以南土地（將軍澳綫）"},{"pid":"25ca9d7e3f3dfb5bed3fe3cb97e5a262bc5f0e75","tid":193292,"uid":24335,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-09T12:57:18.000Z","msg":"<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"3380659292dc175818251df68767268215c8ad2b","tid":193292,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-10T06:49:50.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"83532afa3a2f234c9ccdcba503209845ae714c88","tid":193292,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-10T06:53:18.000Z","msg":"<blockquote>有些鐵路支線，係興建臨時鐵路車廠時鋪設；<br />\n永久車廠建成後拆除支線。<br />\n例子：<br />\n西灣河鯉景灣原址（港島綫）<br />\n荔枝角公園第三期以南土地（東涌綫）<br />\n將軍澳車廠以南土地（將軍澳綫）</blockquote><br />\n港島綫臨時車廠唔係一出隧道就入車廠?"}]}