F%2Fzh.wikipedia.org%2Fzh-hk%2F%25E7%2581%25AB%25E6%25A3%259A&d=Nir3tYOHphhhp6JQHhB5AP755KD0hvcRsprRlRVhNBc%3D&h=f43f4dae\" target=\"_blank\">https://zh.wikipedia.org/zh-hk/%E7%81%AB%E6%A3%9A</a>"},{"pid":"a0d3816c60bfd370c3dcffc337a052a9c3119474","tid":423114,"uid":79563,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-10-03T15:54:29.000Z","msg":"<blockquote>紅磡永別亭支線<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/10/03/234723_d0096ec6c83575373e3a21d129ff8fef.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F03%2F234723_d0096ec6c83575373e3a21d129ff8fef.jpg&h=bc6a7c13&s={SIZE}\" /></blockquote><br />\n<br />\n點解叫永別亭?"},{"pid":"2c54213b6125b5ddbadc8b7afe69f4417ba104eb","tid":423114,"uid":142771,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-03T15:56:00.000Z","msg":"<blockquote><blockquote>紅磡永別亭支線<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/10/03/234723_d0096ec6c83575373e3a21d129ff8fef.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F03%2F234723_d0096ec6c83575373e3a21d129ff8fef.jpg&h=bc6a7c13&s={SIZE}\" /></blockquote><br />\n<br />\n點解叫永別亭?</blockquote><br />\n<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"f2e47baa0a715ea5e3e8e446d2759fa55ae80b66","tid":423114,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-03T15:56:23.000Z","msg":"<blockquote><blockquote>紅磡永別亭支線<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/10/03/234723_d0096ec6c83575373e3a21d129ff8fef.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F03%2F234723_d0096ec6c83575373e3a21d129ff8fef.jpg&h=bc6a7c13&s={SIZE}\" /></blockquote><br />\n<br />\n點解叫永別亭?</blockquote><br />\n人生Last day"},{"pid":"90032cbb94d8ed38811e2766efc0b677ec121b2c","tid":423114,"uid":2466