es/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"01334937740f021d44039be2211116ab089ba60a","tid":2265252,"uid":240362,"like":11,"dislike":1,"score":10,"quote":{"pid":"d0b7e92b8d48d5f59d6083bbf3984c25bf17467c","tid":2265252,"uid":201359,"like":0,"dislike":0,"score":0,"quote":{"pid":"d1eedae89e62dad5aa57ccf169f7fc23aa81ddc5","tid":2265252,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"480fe7e3658ffabfaf438fa8496859ddddc31f0c","tid":2265252,"uid":201359,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-31T09:51:40.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-31T10:02:37.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-31T10:02:49.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-31T10:20:21.000Z","msg":"<a href=\"https://bit.ly/34FLDcO\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F34FLDcO&d=DHxvyf