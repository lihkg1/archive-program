lass=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6853e01f3825aed5745b5d29336c5711062ba219","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-16T10:43:23.000Z","msg":"桐叔<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"446bc859e08c655d7746e66a498b03c7c789b93b","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-18T09:16:06.000Z","msg":"歐盟唔賣武器畀香港"},{"pid":"e06a0c9a1a4a0bd9a23501accf5034e183d3ce64","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-18T11:34:34.000Z","msg":"我唔同意李慧玲既諗法<br />\n<br />\n話港鐵唔停沙田係為搭客著想,  因為新城巿廣場打得好混亂.<br />\n<br />\n<br />\n我嗰日有去遊行,  我 7點幾排緊隊入閘搭車嗰陣, (嗰陣直情係街都未開始趕人走呀)<br />\n有個人係我後邊細細聲話畀我聽話收到料話沙田唔停站, 佢逐個人細細聲同啲帶口罩人仕講),<br />\n嗰陣我唔信, 結果我都須利撘到車離開咗.<br />\n<br />\n但係番到屋企睇到10點到真係唔停沙田.<br />\n<br />\n我依家估係嗰個人係幕後收到料有關人仕(例如港鐵職員之類.....etc)"},{"pid":"140d7157bbf4c259b87ccd7b724e54f93f51e7bf","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-18T11:43:06.000Z","msg":"沙田打入新城巿廣場  幕後少少資料揭密<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/dkvLnT\" data-auto-link target=\"_blank\">https://lih.kg/dkvLnT</a>"},{"pid":"21c9391635e7132426872d22e9ff13bde6db9d54","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"quote":{"pid":"140d7157bbf4c259b87ccd7b724e54f93f51e7bf","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-18T11:43:06.000Z","msg":"沙田打入新城巿廣場  幕後少少資料揭密<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/dkvLnT\" data-auto-link target=\"_blank\">https://lih.kg/dkvLnT</a>"},"citedBy":0,"replyTime":"2019-07-18T11:43:37.000Z","msg":"沙田打入新城巿廣場 幕後少少資料揭密<br />\n<br />\n<br />\n我唔同意李慧玲啱啱係D100既諗法, <br />\n佢話港鐵唔停沙田係可能為搭客安全著想, 因為新城巿廣場打得好混亂.<br />\n( 7點幾嗰陣新城巿不知幾安全)<br />\n<br />\n<br />\n我嗰日有去遊行, 我 7點3到排緊隊入閘搭車嗰陣, (嗰陣直情係街都未開始趕人走呀)<br />\n有個人係我後邊細細聲話畀我聽話收到料話沙田唔停站, (佢逐個人細細聲同啲有帶口罩人仕講, 我有帶口罩),<br />\n嗰陣我唔信, 結果我都須利撘到車離開咗.<br />\n<br />\n但係番到屋企睇到10點到真係唔停沙田.<br />\n<br />\n我依家估係嗰個人係幕後收到料有關人仕(例如港鐵職員之類, .....etc)( 佢著住便裝+有帶口罩)"},{"pid":"152a84e7123a541fd720134028e18aaa3f4b1369","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-19T09:44:20.000Z","msg":"講緊保皇集會"},{"pid":"e22d525b8707c735ce781e6247ba0afb7c786370","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T09:28:46.000Z","msg":"講緊林鄭記招"},{"pid":"f2de1c74db5df9fe91a8dd4126332ba253c30f9e","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T11:12:33.000Z","msg":"聽眾 phone in"},{"pid":"cfd74f97303f14fea105b7263d27160f96bafd88","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T09:28:20.000Z","msg":"講緊元朗"},{"pid":"a1188d4b1fc5b6d0cb3bbb24ade949797117e3a3","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T10:52:19.000Z","msg":"講緊元朗"},{"pid":"2f4f45d475dde29d80ebf04921853c1f64465ad8","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T10:55:16.000Z","msg":"公務員 phone in"},{"pid":"692fcef264e31c374f7af365a0f5d306858bcb8e","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T09:13:33.000Z","msg":"講緊何君堯"},{"pid":"89959050892763d0b70adbe02eeef95533013cc3","tid":1277990,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T10:15:33.000Z","msg":"林卓廷講緊"},{"pid":"43843892ff36b071a870e91921f5c8fe69852ec1","tid":1277990,"uid":25558,"like