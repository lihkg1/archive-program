ts/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"7016cc83ef365f2119b45d2ec65e89739850b575","tid":2366071,"uid":50386,"like":0,"dislike":0,"score":0,"quote":{"pid":"b15cbc59a411dfecb2d93133f835db519d3268e5","tid":2366071,"uid":177168,"like":0,"dislike":18,"score":-18,"citedBy":2,"replyTime":"2021-01-14T08:41:11.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2021-01-14T09:57:33.000Z","msg":"個個法庭post都見你回呢句<br />\n你示範下先啦"},{"pid":"390f2bb9556f39f4e13803647b6ce533e7d54606","tid":2366071,"uid":177168,"like":0,"dislike":3,"score":-3,"quote":{"pid":"7016cc83ef365f2119b45d2ec65e89739850b575","tid":2366071,"uid":50386,"like":0,"dislike":0,"score":0,"quote":{"pid":"b15cbc59a411dfecb2d93133f835db519d3268e5","tid":2366071,"uid":177168,"like":0,"dislike":18,"score":-18,"citedBy":2,"replyTime":"2021-01-14T08:41:11.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2021-01-14T09:57:33.000Z","msg":"個個法庭post都見你回呢句<br />\n你示範下先啦"},"citedBy":1,"replyTime":"2021-01-14T10:12:53.000Z","msg":"香港無法庭，只有集中營"},{"pid":"22dde8362afddc58426c9e53e44bbda971de2a7a","tid":2366071,"uid":240362,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-01-14T11:02:25.000Z","msg":"四名少年男女被指前年11月在觀塘一個商場內破壞美心集團旗下咖啡連鎖店星巴克的玻璃櫃，及後遭退休警員跟蹤，同日在區內被捕。四人被控刑事毀壞罪，惟案件經審訊後，裁判官梁少玲指案中退休警只能稱「認到」四人，卻沒有具體供詞能穩妥確認他們便是破壞者，形容他「說法空白」，裁定四名少年男女罪名不成立。惟案中17歲青年早前承認管有攻擊性武器罪，將於月底判刑，其間先索取多份報告。<br />\n<br />\n兩男兩女被告依序為16歲女學生Y、12歲女學生X、19歲青年以及17歲男學生。四人否認於2019年11月5日在觀塘的東廣場地下星巴克分店內犯案。翁早前承認一項管有攻擊性武器罪，涉及被捕時被搜出身藏雷射筆及伸縮棍。<br />\n<br />\n梁官今裁決指，對於出庭作供的退休警劉文斐供詞有不少疑問，指劉的證供只稱「認到」四人，「但從冇形容係點樣」，形容劉的說法空白。<br />\n<br />\n梁官又指，案中多名警員供詞對於各被告的衣著打扮，亦出現多個不同版本，認為不能就此推論破壞者就是四名被告。縱使被告行為可疑，又稱逃跑只為害怕警察，但她未能信納控方案情為單一合理推論、從而排除其他可能，故裁定四人罪名不成立。<br />\n<br />\n至於被搜出伸縮棍及雷射筆的17歲翁姓男學生，早前承認一項管有攻擊性武器罪，今求情指前年社會運動期間，全港警員獲發伸縮警棍，再加上發生浸大學生會會長因購買雷射筆被捕的事件，市民及後聚集於尖沙嘴以雷射筆作燈光匯演。被告出於貪玩及心智不成熟下購買雷射筆，屬一時魯莽下犯案，希望以社會服務令方式處理。<br />\n<br />\n梁官聽畢求情後，下令先行索取勞教、更生中心、教導所及社會服務令報告，再作判刑，但明言索取服務令報告只是應律師要求，並指案情嚴重，提醒被告「好大機會判監」。案件押後至本月29日判刑，其間被告還柙。被告遭帶進犯人欄時，公眾席上人士大叫：「撐住呀，手足！」<br />\n<br />\n<a href=\"https://hk.appledaily.com/local/20210114/SEO2BE7GVJHIDAYT73TILBPCJE/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210114%2FSEO2BE7GVJHIDAYT73TILBPCJE%2F&d=qXcR1A%2FTALq%2FhnoNE0cJVeoeOpwBOZOods3%2BbOb6780%3D&h=ca142697\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210114%2FSEO2BE7GVJHIDAYT73TILBPCJE%2F&h=263b4420\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20210114/SEO2BE7GVJHIDAYT73TILBPCJE/</a>"},{"pid":"338a16905eea9ee882e4984ed5590f448c6a8e1d","tid":2366071,"uid":51752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-14T11:07:56.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"5d000ffc09600dcd4a46439a244a10bee068e4b8","tid":2366071,"uid":289946,"like":2,"dislike":0,"score":2,"quote":{"pid":"390f2bb9556f39f4e13803647b6ce533e7d54606","tid":2366071,"uid":177168,"like":0,"dislike":3,"score":-3,"quote":{"pid":"7016cc83ef365f2119b45d2ec65e89739850b575","tid":2366071,"uid":50386,"like":0,"dislike":0,"score":0,"quote":{"pid":"b15cbc59a411dfecb2d93133f835db519d3268e5","tid":2366071,"uid":177168,"like":0,"dislike":18,"score":-18,"citedBy":2,"replyTime":"2021-01-14T08:41:11.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2021-01-14T09:57:33.000Z","msg":"個個法庭post都見你回呢句<br />\n你示範下先啦"},"citedBy":1,"replyTime":"2021-01-14T10:12:53.000Z","msg":"香港無法庭，只有集中營"},"citedBy":0,"replyTime":"2021-01-14T11:15:54.000Z","msg":"人地叫你示範呀，9唔撘8呃like你就叻<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"47bb7ce6c552dd4e739a5afe7bebd1b8595624dc","tid":2366071,"uid":10670,"like":0,"dislike":0,"score":0,"quote":{"pid":"787744eed91569f204ba2e7011f8fb994d3cf229","tid":2366071,"uid":36995,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-01-14T09:05:25.000Z","msg":"好快拎住牙簽都要坐監<img src=\"/a