bb5d1eab9129969b3d204555d1f8c8b86f","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"quote":{"pid":"3f4cbb0bf59eeb56496aa7c9ecabb7da9172f5a1","tid":1543860,"uid":249323,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-05T10:51:54.000Z","msg":"推唔郁都推<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-05T10:56:41.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> 多謝支持"},{"pid":"87d2e131b43efcf04b31f5c0fb7550d0b3d83175","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T10:57:05.000Z","msg":"自推10次<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"fde44b8e41d9d0b891bfa7cbfb94b977ccd12c31","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T10:57:15.000Z","msg":"自推10次<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"523833c4be83f0d3999f726dc77073c3e7a45276","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T10:57:28.000Z","msg":"自推10次<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"814365c7f2c0259c1af12e6f541dc78bc9b835fa","tid":1543860,"uid":4050,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-05T10:57:57.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://img.eservice-hk.net/upload/2019/09/05/180335_bc2a7bc8ed32685993e3ce454afa663e.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F09%2F05%2F180335_bc2a7bc8ed32685993e3ce454afa663e.png&h=7689e06d&s={SIZE}\" /><br />\n<br />\n中共對待知道秘密既人既手法：<br />\n<br />\n澳門中聯辦主任鄭曉松2018年10月20日，在其澳門住所墮樓身亡，官方稱其生前患有抑鬱症。<br />\n<br />\n香港君怡酒店老闆劉希泳，2017年3月遭到中共羈押后，被剝奪睡眠並酷刑折磨80小時后死亡，如今酷刑內容全數曝光。<br />\n<br />\n瀘州市人大常委會副主任黃勇因患抑鬱症，於2018年12月5日下午在自家車庫自縊身亡。<br />\n<br />\n同月，重慶市榮昌區政府披露，榮昌區公安局常務副局長吳修遠在辦公室自殺死亡。<br />\n<br />\n2018年5月26日，天津農商銀行董事長殷金寶在辦公室割腕，排除他殺；24日，江西上饒市廣豐區公安局長鄭金車跳樓，原因不明；23日，江蘇建湖縣委組織副部長成萬東自殺，原因不明；21日，北京市政府副祕書長王曉明墮樓，疑患抑鬱症。<br />\n<br />\n科學家張首晟被自殺。"},{"pid":"b705f974d3dfb29b1b032c966496d5bee1abe9f5","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T10:58:39.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"db28f571f4c4fa3873e0c6a457750a8c8264c0d4","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T10:59:47.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"753b9d3d8eeba411eddc971c4a7874e7c7f20a31","tid":1543860,"uid":35215,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-05T11:00:59.000Z","msg":"幫推，expat我覺得可以癲D玩埋LinkedIn"},{"pid":"e0deed3046d63b6405e946c8a193ced0a6993c4b","tid":1543860,"uid":1806,"like":1,"dislike":0,"score":1,"quote":{"pid":"753b9d3d8eeba411eddc971c4a7874e7c7f20a31","tid":1543860,"uid":35215,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-05T11:00:59.000Z","msg":"幫推，expat我覺得可以癲D玩埋LinkedIn"},"citedBy":0,"replyTime":"2019-09-05T11:07:03.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n多謝支持"},{"pid":"1ebe5829f2b72eb1375be5accccfc4d94bc347e3","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T11:07:13.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"8f0d41ddc9f3a00342fd0bd283791b3701da6234","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T11:07:24.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"4002ed3b85db4bddc705aaadea92e41358f101d3","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T11:10:23.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b126b33acc6bdd5f2b13544f7d9b1a035f5985c1","tid":1543860,"uid":276026,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-05T11:16:09.000Z","msg":"<span style=\"font-size: x-large;\"><span style=\"color: orange;\">嗯嗯有得諗<br />\n<br />\n眾籌推文宣去各大社交媒體+報章，或者講以下內容：<br />\n<br />\n1. 解釋點解香港人唔會袋住先<br />\n<br />\n<img src=\"https://na.cx/i/Y3TJ6rn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FY3TJ6rn.jpg&h=13138a59&s={SIZE}\" /><br />\n<br />\n<img src=\"https://na.cx/i/1zZ5Akt.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1zZ5Akt.png&h=9674ba18&s={SIZE}\" /><br />\n<br />\n2. 831太子涉嫌謀殺，如果有時間就講埋之前Popo各種濫權濫暴行為<br />\n<br />\nP牌仔拋磚引玉，睇睇手足有冇更好既諗法<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n</span></span>"},{"pid":"a23d8531240ef4a50161b8b9c52e6700691187d6","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T11:16:48.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"fe7b7582746f06c864d911bfc5027edd55212d2b","tid":1543860,"uid":205482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T11:23:01.000Z","msg":"各地區連儂牆要人，文宣大量要大人<br />\n解釋清楚！！！<br />\n<br />\n<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" /><br />\n全民抗爭，長久戰、拖垮邪惡、打倒腐敗<br />\n<br />\n每日任務：<br />\n1. 抵制支持「邪惡」「無良」的商店，例如cctvb廣告、黨鐵商埸、黑社會、打壓員工的店鋪、減少淘寶<br />\n2. 安全情況下跳閘，免費搭港鐵<br />\n3. 夜晚十點咆哮！！！<br />\n4. 做運動，身體健康，鬥長命<br />\n4. 每日一個post，社交媒體戰（Twitter, IG, Facebook, Reddit)<br />\nTwitter 共識頻道 <a href=\"https://t.me/twittermansyunzou\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Ftwittermansyunzou&d=g6cJT0UyhZ9RanxftZ%2B8MPZtcVXZMMHuQDZeBHkLh3U%3D&h=32b6384a\" data-auto-link target=\"_blank\">https://t.me/twittermansyunzou</a><br />\n<br />\n5. 不要說推，試著將呢段訊息copy and paste嚟推post<br />\n<br />\n每星期任務：<br />\n1. 罷買Bye Buy Day：星期日、星期五(唔買非必需品）<br />\n2. 每星期做孝子，關心下老母老豆老人家，自己老母自己救<br />\n3. 每星期去連儂牆貼3張文宣<br />\n<br />\n每月任務：<br />\n1. 出糧換美金、買美股、少掂中港股票<br />\n2. MPF都買美股<br />\n3. 搵多幾個人參與<br />\n或者做唔足，但我會堅持到尾，Best effort，你呢？<br />\nVersion 2019.09.05"},{"pid":"244fba7ab62392fa3fc69d57af578da269d2873b","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T11:23:42.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a1612da4a910e931ee00f6b55bbe0f2ea906c3cf","tid":1543860,"uid":51937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T11:24:37.000Z","msg":"Push"},{"pid":"abe309d3ff95b30c5d0497679b66e1c15b451c20","tid":1543860,"uid":35215,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T11:29:05.000Z","msg":"係要做啦，啲香港expat都未搞掂<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"1a1b072d0cc97a2e88189d763ca86a23a54a1019","tid":1543860,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T11:29:17.000Z","msg":"<img src=\"/assets/faces/normal/kill