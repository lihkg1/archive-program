%2FKemNjey.png&h=64939c71&s={SIZE}\" /><img src=\"https://na.cx/i/fWPWczz.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfWPWczz.gif&h=33b929ed&s={SIZE}\" /><img src=\"https://na.cx/i/z9dsjez.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fz9dsjez.jpg&h=4c3f844e&s={SIZE}\" /><img src=\"https://na.cx/i/rnkN3Gf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrnkN3Gf.jpg&h=58e711f8&s={SIZE}\" /><img src=\"https://na.cx/i/qtJcvmf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqtJcvmf.jpg&h=0b0e6541&s={SIZE}\" /><img src=\"https://na.cx/i/akg177V.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fakg177V.png&h=36d36824&s={SIZE}\" />"},{"pid":"eb243aa30c71c47ce2f0d8e926fbac05d9ccba80","tid":1494093,"uid":202426,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T16:15:54.000Z","msg":"<img src=\"https://na.cx/i/y3TG778.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fy3TG778.jpg&h=fd6d68b1&s={SIZE}\" /><br />\n<a href=\"https://twitter.com/maryhui\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Fmaryhui&d=qWTZpUodHfCf2bB0mbfn05uyGkzLGvEkvhYecc72uXM%3D&h=f89ceebb\" data-auto-link target=\"_blank\">https://twitter.com/maryhui</a>"},{"pid":"9d0815b487c65241a5ed3fe777840e12603d8f23","tid":1494093,"uid":293677,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T16:18:09.000Z","msg":"<span style=\"color: red;\"><strong>左膠</strong></span>先係鬼<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"6cb1dad5796bca65b2d1427e7641a7b296da39fc","tid":1494093,"uid":288786,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T16:28:38.000Z","msg":"評論白兵的一點短視<br />\nYouTube嘅白兵及其朋友白兵頭係我非常佩服的分析能力極高的青年KOL，各位如果未聽過他們的video就一定要聽聽：<a href=\"https://youtu.be/eif-Fe6_UAw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Feif-Fe6_UAw&d=qWTZpUodHfCf2bB0mbfn05uyGkzLGvEkvhYecc72uXM%3D&h=8e40a084\" target=\"_blank\">https://youtu.be/eif-Fe6_UAw</a>  <br />\n<br />\n香港有白兵這樣的青年才俊，香港的前途無可限量。但是白兵有時候刻意與和理非及泛民割席，這雖然有其可接受的理據：<a href=\"https://youtu.be/wS0PDYcWh8U\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FwS0PDYcWh8U&d=qWTZpUodHfCf2bB0mbfn05uyGkzLGvEkvhYecc72uXM%3D&h=63cacd90\" target=\"_blank\">https://youtu.be/wS0PDYcWh8U</a><br />\n就顯示了年輕人一些短視。因為後來有網友問白兵這場運動最後如何勝出呢？白兵沒能提供一個好的答覆。請恕我淺薄提供一些觀點給白兵及其聽眾參考：<br />\n<br />\n1.年輕人急於求成往往忽略了要長期地全方位地對抗。八十年代九十年代的香港年輕人也曾為香港前途激烈抗爭（其激烈程度由前港督尤德在北京心臟病亡可証），當年的年輕人現在的中年人一直都有通過議會選舉、71遊行、64集會等抗爭，<span style=\"color: red;\"><span style=\"font-size: large;\">請傘後一代不要放棄這些戰場</span></span>。<br />\n<br />\n2.年輕人可能會對中共的惡魔本質瞭解不深，雖然爭取真普選是<span style=\"color: blue;\"><span style=\"font-size: large;\">與虎謀皮</span></span>，但是只要全方位錙銖必較（請參考以下幾點），一定可以玩殘十幾億人的老虎加跳蚤的。<br />\n<br />\n3.中共計劃用深圳取代香港，這是<span style=\"color: red;\"><span style=\"font-size: x-large;\">一個好機會趕走香港的親中財團，他們放棄香港自然就不會為其利益而介意香港人自主</span></span>。香港人要趁機說服歐美如果中共不給予香港真普選，歐美要制裁香港的親中財團的產品，同時培植和不制裁香港的<span style=\"color: purple;\"><span style=\"font-size: x-large;\">反共經濟</span></span>。<br />\n<br />\n4.香港的反共經濟可以在各行各業包括金融及新經濟同歐美同行建立緊密聯繫，要建立全球網絡，可借助全球各地的香港移民。<br />\n<br />\n5.香港的反共經濟要有百萬人或更多人參與，要有自己的產業規劃，要更多更快地使用人工智能等等新科技，要利用與深圳的就近地理位置借鑒深圳的成功經驗。<br />\n<br />\n6.香港人要為反共經濟作出長期的抗爭，因為會被中共及親中財團打壓，因此要在區議會、立法會、選委會中爭取每一票。不要過於依賴某些歐美政治人物，要依賴歐美市場及在歐美經濟轉型中的各種需要。"},{"pid":"ee44255ae39a419af6862c272ddb24549f81c290","tid":1494093,"uid":26491,"like":0,"dislike":0,"score":0,"quote":{"pid":"b5050ba41e4d9684cedbfc717dd9e4d14f2e3796","tid":1494093,"uid":135475,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T16:14:54.000Z","msg":"<img src=\"https://na.cx/i/KemNjey.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKemNjey.png&h=64939c71&s={SIZE}\" /><img src=\"https://na.cx/i/fWPWczz.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfWPWczz.gif&h=33b929ed&s={SIZE}\" /><img src=\"https://na.cx/i/z9dsjez.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fz9dsjez.jpg&h=4c3f844e&s={SIZE}\" /><img src=\"https://na.cx/i/rnkN3Gf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrnkN3Gf.jpg&h=58e711f8&s={SIZE}\" /><img src=\"https://na.cx/i/qtJcvmf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqtJcvmf.jpg&h=0b0e6541&s={SIZE}\" /><img src=\"https://na.cx/i/akg177V.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fakg177V.png&h=36d36824&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-08-21T16:34:56.000Z","msg":"樣JUST DO IT 掂啊<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"35f7d7101753783ed68e78c5f73e71448903d9f5","tid":1494093,"uid":26491,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d0815b487c65241a5ed3fe777840e12603d8f23","tid":1494093,"uid":293677,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T16:18:09.000Z","msg":"<span style=\"color: red;\"><strong>左膠</strong></span>先係鬼<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-21T17:37:39.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"a11d9844ccf5ec993c7dba0a1354b60da261ed16","tid":1494093,"uid":18465,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:41:58.000Z","msg":"唔好理，照做<br />\n阻手阻腳打埋佢"}]}