:0,"citedBy":0,"replyTime":"2020-02-02T11:43:09.000Z","msg":"Done 封關未呀屌<img src=\"/assets/faces/lny/clown4.gif\" class=\"hkgmoji\" />"},{"pid":"29bcae30bfc23ec1618a4d7fd79f8a02967bda08","tid":1857040,"uid":64092,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T19:03:18.000Z","msg":"<img src=\"/assets/faces/lny/smile2.gif\" class=\"hkgmoji\" />"},{"pid":"157eae337bae687d10b986537baff6a723008f2d","tid":1857040,"uid":143269,"like":0,"dislike":0,"score":0,"quote":{"pid":"cfb92fc34f58e82ece012ab60dd29d15dd88a138","tid":1857040,"uid":346958,"like":0,"dislike":0,"score":0,"quote":{"pid":"87d846823a6893a68500c6fb4615013bdfb46a19","tid":1857040,"uid":266635,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-02-02T08:29:39.000Z","msg":"盒救救計唔計數好<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-02-02T08:41:04.000Z","msg":"咩係救救<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-02T19:12:03.000Z","msg":"黑心口罩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2b77b79eb844e672f91f79cdca07f59d0827464c","tid":1857040,"uid":122275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T19:13:30.000Z","msg":"推"},{"pid":"b261cc363205f56c761db78f227afe586b278ee6","tid":1857040,"uid":16961,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T19:22:58.000Z","msg":"Done<img src=\"/assets/faces/lny/devil.gif\" class=\"hkgmoji\" />"},{"pid":"f69170a228cac1185e9dbadbdadddff95cb441c3","tid":1857040,"uid":346958,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T20:13:57.000Z","msg":"做咗個簡單分析<br />\n<br />\n截至2/2 23:59，有~300 responses<br />\n籂走啲extreme data，用剩餘~250個嚟估算<br />\n<br />\n成人口用罩<br />\n平均存量: 每人33.27個<br />\n平均消耗率: 每日每人0.8896個<br />\n平均耗盡時間: 55.55日 [1]<br />\n<br />\n小童口罩<br />\n平均存量: 每人26.13個 [2]<br />\n平均消耗率: 每日每人0.3576個<br />\n平均耗盡時間: 108.4日 [