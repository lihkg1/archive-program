=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFxgqSW3.jpg&h=2006eaa8&s={SIZE}\" /><img src=\"https://na.cx/i/sGaZXqr.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsGaZXqr.jpg&h=89c697b5&s={SIZE}\" />"},{"pid":"e3eb03593622b816e42583c79b7f6fa913bf9810","tid":1785654,"uid":56084,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:54:54.000Z","msg":"估唔到香港會變到咁<img src=\"/assets/faces/pigxm/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/knife.gif\" class=\"hkgmoji\" />"},{"pid":"bdf929e51c21116e4039056e55f79a2d45b95f92","tid":1785654,"uid":265731,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T23:42:38.000Z","msg":"譯完去 Twitter<img src=\"/assets/faces/pigxm/free.gif\" class=\"hkgmoji\" />"}]}