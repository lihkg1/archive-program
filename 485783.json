assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"fe5326c53c6984ffa91855712f6fe56c65e81ff1","tid":485783,"uid":129509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:43:17.000Z","msg":"樓豬你黎養啦 隻狗咁痴你"},{"pid":"db35786ed7d8b3a95cfbd09c09deafe233f7b9b9","tid":485783,"uid":49062,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-12-07T13:47:07.000Z","msg":"緣份黎咖樓主<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n主人唔拎番養左佢啦"},{"pid":"54524d8b2c3462f145406c8b9c0222441e6d15c1","tid":485783,"uid":4392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-08T04:04:34.000Z","msg":"樓主隻狗而家點? <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"10a8c35a70545ad52a2fbc5eecebf79ea6929468","tid":485783,"uid":143768,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2017-12-08T06:32:50.000Z","msg":"做乜個個都要樓主養<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n樓主好心post上嚟搵狗主，暫時幫手睇住先<br />\n一個二個就叫樓主養，又話養一世<br />\n樓主自己屋企情況係點都未知，可能佢自己都唔太方便<br />\n<br />\n一陣佢搵人領養，班人又問樓主自己做乜唔養咁<br />\n講到好似樓主個責任嚟咁樣<br />\n大佬，以後有人發現有失狗都廢事麻煩post上嚟啦"},{"pid":"c5efb63209c0003e22f7596dc3158fdf23d93439","tid":485783,"uid":85121,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2017-12-08T13:43:16.000Z","msg":"<blockquote>樓主隻狗而家點? <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /></blockquote><br />\n哈哈 而家我收養緊 <br />\n<br />\n睇下佢原主人會唔會搵番我啦<img src=\"/assets/faces/big/wink.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/12/08/214313_6d5b64fd4114392345bf0d37ab3faf20.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F08%2F214313_6d5b64fd4114392345bf0d37ab3faf20.jpg&h=8346e9e2&s={SIZE}\" />"},{"pid":"5bfa323b93f0447d9ce2c386544bcb1258de0271","tid":485783,"uid":85121,"like":11,"dislike":0,"score":11,"citedBy":0,"reply