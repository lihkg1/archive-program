c5d8dbdb961676a76ef3b067","tid":1182584,"uid":238801,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-02T11:53:09.000Z","msg":"<img src=\"https://na.cx/i/iVQuXNm.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiVQuXNm.gif&h=685eeec4&s={SIZE}\" />"},{"pid":"108491c41f44672b7366d64102bc9b489f67704d","tid":1182584,"uid":177338,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-02T11:55:15.000Z","msg":"Billie?"},{"pid":"98ef22402dfdc61386edab8c273265597886e08e","tid":1182584,"uid":218575,"like":0,"dislike":0,"score":0,"quote":{"pid":"233e8f336a321b07c5d8dbdb961676a76ef3b067","tid":1182584,"uid":238801,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-02T11:53:09.000Z","msg":"<img src=\"https://na.cx/i/iVQuXNm.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiVQuXNm.gif&h=685eeec4&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-06-02T12:49:40.000Z","msg":"唔好自貼"},{"pid":"88f5b329460df1a7e4183c0b33e49864dc04027f","tid":1182584,"uid":218575,"like":0,"dislike":0,"score":0,"quote":{"pid":"108491c41f44672b7366d64102bc9b489f67704d","tid":1182584,"uid":177338,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-02T11:55:15.000Z","msg":"Billie?"},"citedBy":0,"replyTime":"2019-06-02T12:49:57.000Z","msg":"<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"18c8835a25bcf92b64002f1aea2f620cd42eadbb","tid":1182584,"uid":431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-02T18:47:31.000Z","msg":"無圖勿屌，<br />\n<br />\n不過原來連登真係有靚女上架屌<br />\n無相，返緊工影唔到亦唔會影，<br />\n不過如果唔係自己親眼見到我都唔信。<br />\n人生真係充滿希望<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><br />\n當然女呢啲有就固然好，<br />\n無既都唔好強求，<br />\n脫貧比脫單重要，<br />\n<br />\n窮養仔，富養女。<br />\n<br />\n<br />\n今日我返返下工，<br />\n無啦啦見到條女都幾靚係度上連登。。。<br />\n<br />\n我忍唔住大叫：原來都有靚女上連登架！！！嗌到全場都聽到。<br />\n之後佢好尷尬咁係度傻笑，<br />\n佢個笑容真係好靚<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n個一刻，我覺得人生充滿希望！<br />\n當然充滿完希望之後又平靜返繼續做野，<br />\n之後我返去同個靚囡囡講：唔好上咁多連登，因為好多痴線佬（我當然係其中一個）<br />\n<br />\n各位巴打自己幻想下：<br />\n條女著黑色連身裙（唔知係唔係，類似真光個種但又無長叉），<br />\n出面重有件棗紅色既披住應該保暖個種野（女仔個啲衫唔識咩黎），<br />\n樣靚身材正<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><br />\n又白又滑（應該係除非唔係），笑容又靚<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />，<br />\n樣ＯＫ唔濃妝，<br />\n大波，無肚腩<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />又夠高，目測１６２－１６５<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><br />\n個屁股又大，<br />\n長直髮但好似金金地（唔記得）<br />\n<br />\n佢男朋友／老公應該會晚晚捉住佢黎啪啪啪<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><br />\n<br />\n好羨慕佢男朋友／老公<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />佢就好啦，<br />\n個絲打個樣心地應該唔差（就咁睇佢個樣都唔係惡相）<br />\n應該係中產級數以上既家庭黎，<br />\n個氣質絕對唔係我地呢啲低賤既人種<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n最後，<br />\n各位巴絲，<br />\n其實現實中都真係有好多靚仔靚女上連登，<br />\n無論係咩原因都好，<br />\n不過我覺得討論區係一個幾好既地方，<br />\n至少其實好似我地呢啲無乜朋友既人，<br />\n討論區係一個 心靈 可以尋找刺激／快樂／安慰／解答難題既 避風港，<br />\n<br />\n雖然大家都黎自５湖４海，<br />\n由好似我地呢種最低賤既人種，<br />\n至到<br />\n甚至坐擁ＡＥ鈦金屬百夫長細頭黑卡都可能有，<br />\n你都唔好話咁既討論區唔勁秋<br />\n（甚至呢度有網絡記者／記者添）<br />\n<br />\n雖然大家都黎自５湖４海，<br />\n唔同階層唔同背景，<br />\n但大家面對既問題應該都係大同小異，<br />\n唔係錢銀就係女人ＯＲ男人。<br />\n<br />\n最後，<br />\n<br />\n雖然人生有時間係咁：<br />\n「生命無希望，前路受重創」<br />\n<br />\n但你亦都可以揀：<br />\n「前路是地獄，希望在轉角。」<br />\n<br />\n轉一轉，就變了；<br />\n<span style=\"color: brown;\">「命」這一次拆解便是， 人 一 叩，<br />\n人 只要願意向前／向天 一 叩，命就改了，真誠的懺悔，<br />\n為自己一力承擔。</span><br />\n<br />\n常言道：<span style=\"color: blue;\">山不轉路轉、路不轉人轉、人不轉心轉、心不轉念轉、轉心轉念也；<br />\n或許你也曾因一時無法跳脫某件事而轉不出，<br />\n轉心轉念也不過是意識上的一個念頭，<br />\n放棄一些不必要的想法無非是件容易的事，何須執著。</span><br />\n<br />\n「芭蕉葉上無愁雨，只是聽時人斷腸！」<br />\n<br />\n不甘心不放心，受苦的不是對方，是你自己；<br />\n你願意放下時，放下的不是對方，是坦誠的放下自己。<br />\n旁觀者清，當局者迷正是如此，<br />\n希望一眾正在經歷情殤的巴絲，<br />\n<br />\n都會「最後冇事」，幸福快樂，身體健康。<br />\n<br />\n最最後，當然作為廢毒宅油頭毒撚的我們，<br />\n我也不會奢望可以擁有白滑大波妹<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />因為即使對方不嫌棄，<br />\n您我撫心自問也不太可能養得起對方，<br />\n<br />\n白滑大波妹對毒撚來說是這樣的：<br />\n「出淤泥而不染，濯清漣而不妖；中通外直，不蔓不枝；香遠益清，亭亭淨植；<br />\n<br />\n<span style=\"color: red;\">可遠觀而不可褻玩焉&hellip;&hellip;」</span><br />\n<br />\n最後，希望一眾與我差不多貧窮的巴打，<br />\n都會好好為自己的人生努力，<br />\n好好地脫貧，<br />\n好好地學習，<br />\n好好地為自己負責。<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><br />\n<br />\n最最最最最後，<br />\n樣靚身材正，笑容可掬，<br />\n又夠高，把聲又好聽既絲打真係好正<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><br />\n不過佢應該都唔會睇到呢篇廢腑之言<img src=\"/assets/faces/lm2/tongue.gif\" class=\"hkgmoji\" /><br />\n<br />\n希望一眾女絲打唔會再遇到渣男，<br />\n都會遇到一個極罕見既專一高富帥<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n祝大家好運<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><br />\n如要賭博，請支持香港唯一合法莊家ＨＫＪＣ。<br />\n（以前有個老前輩話過我：傻仔！你輸比馬會個啲錢馬會真係拎去做慈善，<br />\n但你係股票輸個啲，你係送錢比人地去洗，人地笑鳩緊你傻你都唔知咋！）<br />\n<br />\n其實想遇到真愛，<br />\n不如定時捐２０蚊去ＨＫＪＣ買張投胎卷算啦<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n點都好，<br />\n祝自己＆大家好運<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><br />\n<br />\nＳＯＲＲＹ ＦＯＲ １９９９<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><br />\n<br />\n白滑大波妹絲打真係好正<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><br />\n<br />\n各位窮巴記得好好一齊加油出頭人地<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n晚安<img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beg_connect.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/zzz.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"b5623cc97508fba40dffc1840a4b0e4