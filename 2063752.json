faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"494a29e8e9269b4e7985fda8b63c6ec41e282e20","tid":2063752,"uid":92448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-14T09:33:07.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"324fb656a076030b4dabe8e4e3e18dd46d763e0a","tid":2063752,"uid":308251,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-14T09:33:25.000Z","msg":"好撚煩呀<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"0f8f4bf26b379382ff4994262b241e936d236df2","tid":2063752,"uid":109923,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-06-14T09:33:32.000Z","msg":"<blockquote><img src=\"https://static.hkej.com/hkej/images/2020/06/14/2494044_60b435bc4a57bfdbe5d1ae874314e8f4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.hkej.com%2Fhkej%2Fimages%2F2020%2F06%2F14%2F2494044_60b435bc4a57bfdbe5d1ae874314e8f4.jpg&h=82645b8b&s={SIZE}\" /><br />\n<br />\n商務及經濟發展局局長邱騰華接受鳳凰衞視訪問時表示，美國與香港的貿易關係屬互惠互利，任何傷害將屬於雙向性，不會有贏家。<br />\n<br />\n他認為，個別國家無論是限制別人到當地提供服務，或限制自己的企業到其他國家或城市服務，定必令自身經濟條件轉差，美國與香港的貿易關係屬互惠互利，兩地在高端專業服務業更是「你中有我，我中有你」，任何風吹草動，包括傷害，均屬於雙向性，不會有贏家。<br />\n<br />\n他又相信，很多旅遊行為和方式在疫情過後均可能有所改變，屆時要先起動本地旅遊、消費較高的商貿旅遊，以及能豐富旅客某方面知識和經驗的「有增值」和「主題式」旅遊。在應付疫情的過程中，當局累積很多實際經驗，例如把會展服務變成網上展覽，香港可透過<strong><span style=\"font-size: xx-large;\">5G</span></strong>的低接觸、高效的連接方式，與全世界的貿易夥伴連成一體。<br />\n<br />\n他直言，「有危就有機」，香港要把握疫情帶來的商機，繼續朝智慧城市方向發展。<br />\n<br />\n邱騰華說，國家推出港區國安法是出於憲制要求及實際需要，填補因《基本法》第二十三條未立法而出現憲法上的空隙，由於投資者均重視社會是否穩定和安全，立法可以為所有投資者帶來信心和安穩。<br />\n<br />\n<a href=\"https://www2.hkej.com/landing/mobArticle2/id/2494044\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww2.hkej.com%2Flanding%2FmobArticle2%2Fid%2F2494044&d=8Hffn7AX%2B5q16JKWebZXJvMFbVPULjdiAdi6tpyrPMY%3D&h=c8eb046d\" target=\"_blank\">https://www2.hkej.com/landing/mobArticle2/id/2494044</a></blockquote><br />\n<br />\n成篇廢文都可以同5G有關<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"cb6f0111cb204dd32afdfd3994b15d7f6db0e317","tid":2063752,"uid":82640,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-14T09:33:39.000Z","msg":"真係好撚好笑"},{"pid":"5753a0b4e4dd1c5c61e461a2a2f43f48935a9879","tid":2063752,"uid":331739,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-06-14T09:33:45.000Z","msg":"咁要全力支持了<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> 愛國就要支持貿易戰 等美國砸自己隻腳"},{"pid":"0320e98c92e3e5cbf3b299f66637c6005a87dabd","tid":2063752,"uid":107950,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-14T09:33:59.000Z","msg":"好撚煩<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 美國掙住要做輸家咪由佢囉"},{"pid":"618d331a1076fe70ff00c7233664c007d40ea273","tid":2063752,"uid":135867,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-14T09:34:38.000Z","msg":"香港要把握疫情帶來的商機，繼續朝智慧城市方向發展。<br />\n忽上腦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"dae594cdd8b0f25596638d44a9e6ecbd27d2d1a6","tid":2063752,"uid":161726,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-06-14T09:35:14.000Z","msg":"傻尻<br />\n人地出少少錢要你仆街呀"},{"pid":"0bac010378877ffe8acffd0ed4c5e751346d87d0","tid":2063752,"uid":1560,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-06-14T09:35:18.000Z","msg":"美國想輸你咪由得佢囉 日日出黎提醒對手究竟有咩居心呢可<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"59bda6884e0044f0200eab619560b38cdba84cde","tid":2063752,"uid":402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-14T09:37:28.000Z","msg":"終於唔講石頭砸腳<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d63334bfc1df05caa174cc35b9561b0754bfac8f","tid":2063752,