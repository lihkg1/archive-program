pan><br />\n<a href=\"https://lih.kg/1604870\" data-auto-link target=\"_blank\">https://lih.kg/1604870</a><br />\n<br />\n勇武 和理非入<strong><span style=\"color: pink;\"> 依到有合集帶啲咩</span></strong><br />\n［整合］<span style=\"color: gold;\">十一執齊野</span><br />\n<a href=\"https://lih.kg/1603888\" data-auto-link target=\"_blank\">https://lih.kg/1603888</a></span><br />\n<br />\n<span style=\"font-size: x-small;\"><br />\n<span style=\"color: gold;\">無豬咀就帶定條濕毛巾cover 口同鼻 <br />\n會好啲</span><br />\n<br />\n同埋唔好行甘前</span><br />\n<br />\n<span style=\"font-size: small;\">仲有巴打目標post<br />\n十一國殤　六區開花<br />\n<a href=\"https://lih.kg/1600404\" data-auto-link target=\"_blank\">https://lih.kg/1600404</a></span>"},{"pid":"c94a54147884be7c2ad706c21ec053913ec687f0","tid":1606194,"uid":24390,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T13:50:23.000Z","msg":"大家畀啲意見，要多啲idea先可以成事"},{"pid":"a3d02ce26afb071f4bcf4791c83bedfd6d9a7e07","tid":1606194,"uid":276191,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-30T13:53:18.000Z","msg":"有冇保皇黨辦事處?"},{"pid":"3d7b535059880017aa19b5dbf401386f526c6820","tid":1606194,"uid":110119,"like":0,"dislike":0,"score":0,"quote":{"pid":"a3d02ce26afb071f4bcf4791c83bedfd6d9a7e07","tid":1606194,"uid":276191,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-30T13:53:18.000Z","msg":"有冇保皇黨辦事處?"},"citedBy":0,"replyTime":"2019-09-30T13:57:20.000Z","msg":"鳳德簡志豪"}]}