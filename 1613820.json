src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"8287f31fc08f09e68656ebec695d05e4e3f89a18","tid":1613820,"uid":5258,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2019-10-02T15:49:04.000Z","msg":"美國都講左割彈都唔就割啦"},{"pid":"1f4d8de47319d4b8dcd96759991c254c7e0fd81d","tid":1613820,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T15:49:51.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"fad472fb8d198de29a4b5a221a96d54a35013f41","tid":1613820,"uid":74155,"like":3,"dislike":0,"score":3,"quote":{"pid":"da946eed3581246d37886787ab6af9e95f0332aa","tid":1613820,"uid":134071,"like":4,"dislike":0,"score":4,"quote":{"pid":"ed10a063458cd6724d7a1e5567aee49d6d4f2342","tid":1613820,"uid":30476,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-10-02T15:44:59.000Z","msg":"<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">肥</span></span></strong>"},"citedBy":1,"replyTime":"2019-10-02T15:45:46.000Z","msg":"&nbsp; &nbsp; <span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>佬</strong></span></span>"},"citedBy":1,"replyTime":"2019-10-02T15:50:17.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>黎</strong></span></span>"},{"pid":"6e800413aea7ff8d5fbbbe0f01151c7ec37313c2","tid":1613820,"uid":134071,"like":35,"dislike":0,"score":35,"quote":{"pid":"3358ef38e679e26298672156e3fd16f711adbfb0","tid":1613820,"uid":43041,"like":3,"dislike":2,"score":1,"citedBy":3,"replyTime":"2019-10-02T15:45:50.000Z","msg":"割席英文系咩牙？"},"citedBy":1,"replyTime":"2019-10-02T15:52:30.000Z","msg":"毛孟靜: <br />\n<br />\n割席的英文可以是 to distance oneself from someone or something ，與一些人或物保持距離、與之切割。<br />\n<br />\n用於政治：<br />\n‧The leader has recently distanced himself from the extremists in the party. 領袖最近與黨內的極端分子割席。<br />\n<br />\n用於商業：<br />\n‧The company has been trying to pretend to be environmentally friendly and has been distancing itself from its past connections to the oil industry. 公司企圖裝作環保，與過去的石油業務聯繫切割。<br />\n<br />\n用於日常生活：<br />\n‧You have to stay in touch. You cannot distance yourself from reality. 你要保持聯繫，不可與現實切割。<br />\n<br />\n‧We should all live a simple life and distance ourselves from consumerism. 我們都應該生活簡約，與消費主義切割。<br />\n<br />\n上面的句子，若不用 distance，可以改作 dissociate，意思基本上一樣。<br />\n<br />\n割席亦可說 to sever ties，但多用於斷絕關係：<br />\n<br />\n‧The two countries sever ties after a huge diplomatic row. 兩國於一場外交大爭議後，斷絕邦交。<br />\n<br />\n另有 split up，就多指個人關係：<br />\n‧His parents have decided to split up. 他的父母決定分手了。<br />\n‧The group has refused to split up. 團體拒絕分散。<strong>這句的含意，不就是「不分化」。</strong><br />\n<br />\n<a href=\"http://news.mingpao.com/pns/%E8%8B%B1%E6%96%87/article/20190909/s00017/1567967872741\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.mingpao.com%2Fpns%2F%25E8%258B%25B1%25E6%2596%2587%2Farticle%2F20190909%2Fs00017%2F1567967872741&d=Bbcm6JBZsUbsJrWfDZmHX%2BxpY9ERoCMedVnvBBvIoB8%3D&h=89b18f7f\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fnews.mingpao.com%2Fpns%2F%25E8%258B%25B1%25E6%2596%2587%2Farticle%2F20190909%2Fs00017%2F1567967872741&h=a47cc877\" data-auto-link target=\"_blank\">http://news.mingpao.com/pns/%E8%8B%B1%E6%96%87/article/20190909/s00017/1567967872741</a>"},{"pid":"8dad5dac95e5225c1ff89b5aa3045b16107e5f17","tid":1613820,"uid":85425,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-02T15:53:30.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"00b5b80d11378ddf18763e54100a70c0ebfa81ad","tid":1613820,"uid":134071,"like":0,"dislike":0,"