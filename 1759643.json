itedBy":1,"replyTime":"2019-11-27T19:38:55.000Z","msg":"<a href=\"https://www.ukrant.nl/magazine/worlds-apart/?lang=en\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ukrant.nl%2Fmagazine%2Fworlds-apart%2F%3Flang%3Den&d=iBLSwy1tqwhlDNpwtuM9Der6kk4zB%2BnGw4DSdwpbM%2Bg%3D&h=ef48a6b9\" target=\"_blank\">https://www.ukrant.nl/magazine/worlds-apart/?lang=en</a><br />\n<br />\n巴打可以係篇文最下留言 多謝Ukrant 同Nora 為香港人發聲<br />\n同希望大學正視人權問題<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"92555d6b1604da8149f706dba5492624ca2a8e51","tid":1759643,"uid":212731,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-27T19:50:00.000Z","msg":"將個post開過去時事台 會多人關注好多"},{"pid":"9993ae0ee850f58249087dc6ad8ed8eb9b9aec00","tid":1759643,"uid":15677,"like":0,"dislike":0,"score":0,"quote":{"pid":"92555d6b1604da8149f706dba5492624ca2a8e51","tid":1759643,"uid":212731,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-27T19:50:00.000Z","msg":"將個post開過去時事台 會多人關注好多"},"citedBy":0,"replyTime":"2019-11-27T19:51:19.000Z","msg":"好 我再開<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"5077f7f3d2fab64bf13a4592eaa62052ada71d9f","tid":1759643,"uid":98271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-27T20:05:25.000Z","msg":"Push"},{"pid":"7c181eb14ee9175289ea86fda1636b09095a379b","tid":1759643,"uid":57221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-27T20:08:25.000Z","msg":"lpp"},{"pid":"c3edc935ead47a20a4770c275739d3ecc035c650","tid":1759643,"uid":49911,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-27T23:24:41.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"c006cb010b81eeb433abdbe5d8d3db3e0694b25c","t