/pig/free.gif\" class=\"hkgmoji\" />"},{"pid":"b10c4a030ca26e7515bfaafaa1a7b468f8206041","tid":1775624,"uid":241949,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-09T07:33:27.000Z","msg":"9upper嚟講<br />\n陳雲認第二<br />\n得郭文貴有資格做第一"},{"pid":"2b7ddb44333b6cf2751dbb6bb88d33033301dae4","tid":1775624,"uid":1886,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d44d42227e9a067c47e5452a5e53e9eaa9494f5","tid":1775624,"uid":30247,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-12-09T03:32:56.000Z","msg":"可唔可以唔好再貼呢條9upper出黎"},"citedBy":0,"replyTime":"2019-12-09T12:00:31.000Z","msg":"郭文貴：中共出年仲未收皮我就跳樓死！<br />\n<a href=\"http://news.ltn.com.tw/news/world/breakingnews/2661924\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F2661924&d=2Jo0d4zpMW7MEYOmRW2LdfYtrFBHe52Fn%2F6n3rMGN5k%3D&h=652d5263\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F2661924&h=4b21dc27\" target=\"_blank\">http://news.ltn.com.tw/news/world/breakingnews/2661924</a><br />\n<br />\n<div style=\"text-align: center;\"><img src=\"https://upload.cc/i1/2019/12/06/4kDjBt.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2019%2F12%2F06%2F4kDjBt.png&h=2d3a0463&s={SIZE}\" /><br />\n</div><br />\n<br />\n一直預告西方世界將與中國全面對抗的郭文貴還強調：「<span style=\"color: red;\"><strong>2020年是結束共產黨在中國的最後一年，否則文貴就從那18樓跳下去，大家要記住我的承諾。</strong></span>」"}]}