 src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"d329365125e1358f5719088f01025e8587d724e9","tid":393552,"uid":54373,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-09T15:08:53.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4896802162720202ad47825d66a4264d98847304","tid":393552,"uid":95617,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-10T07:51:21.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"419d276a9250e8d4a11fa17941ed849e757f561d","tid":393552,"uid":69971,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-17T07:57:52.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" />"},{"pid":"8b6e8d52cbf22ff9ad1d7bdac102407470aaa070","tid":393552,"uid":54373,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-17T11:29:19.000Z","msg":"<blockquote><img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ccfc1ecfa437aba52d711c21b4d3f3f19ae69379","tid":393552,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-02T09:15:05.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}