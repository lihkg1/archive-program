=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-08T07:54:15.000Z","msg":"有機會係，但朋友間安全屋係得熟人知，但唔知點解閪9拍上門<br />\n而閪9係有打到朋友迫佢認罪+篤灰，朋友選擇左認無篤到<br />\n閪9無性，講定出黎等大家有準備點保障自己<br />\n同埋集思廣益"},{"pid":"67dd68c1628155a467246d262e04c2506f0257b4","tid":1915350,"uid":235316,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T08:13:18.000Z","msg":"借位 大家幫手推一推<br />\n［行動post入黎推一推］ 明天1930將軍澳*準時到*<br />\n<a href=\"https://lih.kg/1914250\" data-auto-link target=\"_blank\">https://lih.kg/1914250</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"a89a0116d472229f55f0498842c856723de8d0c9","tid":1915350,"uid":112081,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T08:15:33.000Z","msg":"集思廣益<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"1307491a1e302cfec3503604d32bf233cfaec3b1","tid":1915350,"uid":331973,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T08:16:28.000Z","msg":"建議手足拍片，裝cam自保"},{"pid":"99286332201f7bb823fbf33547be3fd05c8190d2","tid":1915350,"uid":119864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T08:16:30.000Z","msg":"光復香港"},{"pid":"a5e90ece098e1e7b90bac5e6a29f7f90bd7a4a14","tid":1915350,"uid":84176,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T08:17:05.000Z","msg":"上熱門"},{"pid":"e4219228e58fef3611386bb5aecbde2a4efebe69","tid":1915350,"uid":230703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T08:18:19.000Z","msg":"點都拉左先"},{"pid":"f0db21114a19d1737bf8139dbe42de9cc5c96beb","tid":1915350,"uid":84176,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T08:18:32.000Z","msg":"保護自己先可以保護其他人"},{"pid":"e231ecab7915205dca45c7ea4c382d661c6888d4","tid":1915350,"uid":230703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T08:19:02.000Z","msg":"玩法律就係燒錢"},{"pid":"254da47ef04445290117f59633c6df55e08bbf87","tid":1915350,"uid":31215,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-08T0