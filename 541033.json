"},{"pid":"475f708d1b58640763e6a3a29c0706083311a710","tid":541033,"uid":51857,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-26T10:29:14.000Z","msg":"聯派灣"},{"pid":"19c4b5b67fdc1472ab6330b0622f6bfc49218fff","tid":541033,"uid":104294,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-01-26T10:31:56.000Z","msg":"限之日<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"58ba11a28b8b45740633e1d015792d86f2ae4072","tid":541033,"uid":44454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-26T10:38:33.000Z","msg":"肘川卞巴"},{"pid":"469ae90adf6654596f5cbaeed24d84737650d274","tid":541033,"uid":64847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-26T10:39:36.000Z","msg":"卷父"},{"pid":"7af67cd2c0c34278f94c4ba6cc2a011e0910a61b","tid":541033,"uid":24755,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-26T10:43:47.000Z","msg":"畈匠汴"},{"pid":"9a9d7622989bf30106cb2c99b660e160bc29c900","tid":541033,"uid":66546,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-26T10:44:59.000Z","msg":"分門 愜 刀門"},{"pid":"d383563c8af340af979b7d47374364b04c8c0e6e","tid":541033,"uid":143505,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-26T10:48:01.000Z","msg":"友了卜"},{"pid":"5b61eab3736413ebdba4a5636a530bccbad050e3","tid":541033,"uid":143686,"like":0,"dislike":0,"score":0,"quote":{"pid":"c2f9d78059f315f93c44ffa103e6069ccbc3e607","tid":541033,"uid":146917,"like":0,"dislike":0,"score":0,"quote":{"pid":"836f6281951a8af29db41b4bbf73104325151e7f","tid":541033,"uid":143686,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-26T09:04:19.000Z","msg":"樣了成"},"citedBy":1,"replyTime":"2018-01-26T09:16:05.000Z","msg":"dennis"},"citedBy":0,"replyTime":"2018-01-26T10:54:53.000Z","msg":"是"},{"pid":"1d77feb7fe7ee4dc713d48d3866414cb5afde915","tid":541033,"uid":112892,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-26T16:05:00.000Z","msg":"襯錯尸"},{"pid":"8ee288863d0265410be0030fbdc