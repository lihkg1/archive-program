,{"pid":"8c6ba7000eaad0d231fa3529cb88ae88951bb5af","tid":520683,"uid":24160,"like":3,"dislike":2,"score":1,"quote":{"pid":"5a56d66f1a5d3ad7a1b0ea842db047afad511234","tid":520683,"uid":5195,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-01-05T16:49:05.000Z","msg":"<img src=\"http://image.wenweipo.com/2017/07/08/a06b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimage.wenweipo.com%2F2017%2F07%2F08%2Fa06b.jpg&h=012e9cef&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-01-05T21:59:26.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/01/06/030458_3981c36d99ba269a8def64fc763f2dc8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F06%2F030458_3981c36d99ba269a8def64fc763f2dc8.jpg&h=3348aa08&s={SIZE}\" />"},{"pid":"3988df7c3ab30a8189da273171983d57c4a3c45f","tid":520683,"uid":90601,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2018-01-05T22:13:32.000Z","msg":"<a href=\"https://news.mingpao.com/pns/dailynews/web_tc/article/20180106/s00001/1515176527920\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2Fdailynews%2Fweb_tc%2Farticle%2F20180106%2Fs00001%2F1515176527920&d=47bLBQiuShvRDyQFUVKHy54f2li5K%2Fs6EGgmwhpeblA%3D&h=703a9f00\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2Fdailynews%2Fweb_tc%2Farticle%2F20180106%2Fs00001%2F1515176527920&h=6a128f3e\" target=\"_blank\">https://news.mingpao.com/pns/dailynews/web_tc/article/20180106/s00001/1515176527920</a><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n【明報專訊】國務院昨公布鄭若驊接替袁國強成為律政司長，並於今日履新。<strong>本報偵查發現</strong>，鄭若驊於2008年購入並一直報住的大欖海詩別墅獨立屋，地面層（ground floor）有一條原圖則所沒有的下行樓梯，建築師把圖片對比大宅原圖則，懷疑樓梯通向下層僭建地庫。本報昨就此向鄭若驊當面查詢，她未有回應。<br />\n<br />\n記者曾到鄭宅旁邊另一幢圖則一樣的獨立屋內，同樣在地面層見到類似的下行樓梯，通往逾400方呎的僭建地庫（見另稿）。本報10日前、即12月27日已就鄭宅的懷疑僭建地庫、露台、水池及天台屋向屋宇署查詢，但至截稿前未獲回應。律政司昨晚亦未有回覆。<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n依單野明報偵查有claim係佢地做 不過兩邊都無講獨家<br />\n又專登吼正佢上任第1日先爆<br />\n唔知係咪夾埋<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"a7e5d3ed88fdba27403849647525aeeb710356f7","tid":520683,"uid":35746,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-05T22:40:43.000Z","msg":"擺明玩野第一日就做佢"},{"pid":"32b193bb8875b8c80f12ec1d960e03363b8f8fc3","tid":520683,"uid":39838,"like":3,"dislike":0,"score":3,"quote":{"pid":"5f305ffd3f3ccf0b72bf129f40e0962001546a4e","tid":520683,"uid":29552,"like":11,"dislike":145,"score":-134,"citedBy":11,"replyTime":"2018-01-05T16:50:13.000Z","msg":"其實由唐英年果單已經覺得呢D捉僭建好小題大做<br />\n唔好講獨立屋就算新界村屋嚴格來講大部份都有僭建架啦<br />\n<br />\n天台加野, 起地庫, 係地面將花園伸延出去範圍外等等...<br />\n求其去幾間都會見到...<br />\n<br />\n你針住個咁大粒既新律政司竟然搵唔到其他料要執呢D細野出來真係得淡笑"},"citedBy":0,"replyTime":"2018-01-05T22:55:45.000Z","msg":"當年涼粉蟲偷步買車夠好少事啦屌"},{"pid":"572f27b95f9c9bb31b6e383faa4bc910f0aaf57e","tid":520683,"uid":24216,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-05T22:58:28.000Z","msg":"無人機全面進埸🚁🚁🚁"},{"pid":"a30427adc205b2522623ae144424e485a7b154a6","tid":520683,"uid":55913,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-05T23:22:07.000Z","msg":"我就係法律！"},{"pid":"bff21eb4afcd09fdd7b0ed2adc10b41f23c72fb0","tid":520683,"uid":7699,"like":4,"dislike":0,"score":4,"quote":{"pid":"5f305ffd3f3ccf0b72bf129f40e0962001546a4e","tid":520683,"uid":29552,"like":11,"dislike":145,"score":-134,"citedBy":11,"replyTime":"2018-01-05T16:50:13.000Z","msg":"其實由唐英年果單已經覺得呢D捉僭建好小題大做<br />\n唔好講獨立屋就算新界村屋嚴格來講大部份都有僭建架啦<br />\n<br />\n天台加野, 起地庫, 係地面將花園伸延出去範圍外等等...<br />\n求其去幾間都會見到...<br />\n<br />\n你針住個咁大粒既新律政司竟然搵唔到其他料要執呢D細野出來真係得淡笑"},"citedBy":1,"replyTime":"2018-01-05T23:28:59.000Z","msg":"文翠珊條𡃁返工睇咸片都要辭職啦"},{"pid":"110a124d148ec9c9946844a467aa395ab4dd989e","tid":520683,"uid":33908,"like":0,"dislike":0,"score":0,"quote":{"pid":"bff21eb4afcd09fdd7b0ed2adc10b41f23c72fb0","tid":520683,"uid":7699,"like":4,"dislike":0,"score":4,"quote":{"pid":"5f305ffd3f3ccf0b72bf129f40e0962001546a4e","tid":520683,"uid":29552,"like":11,"disl