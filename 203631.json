意<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <br />\n<br />\n你地唔係噓我呀？<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"1fd3e6e735db04c41be2b5a4d11e60783149df68","tid":203631,"uid":56377,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-18T07:50:42.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}