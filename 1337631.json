br />\n果個位置<br />\n<br />\n呢係係我小小睇法 天黑再出黎發夢 暫時現場既大家討論下先</blockquote>"},{"pid":"c7e6c2916a120a70a1b3a9ff8c7c9e23b2a3a888","tid":1337631,"uid":4493,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-21T10:17:05.000Z","msg":"IFC"},{"pid":"5a2608a7d98fa5dac6cb92888f111f2ab3dd519a","tid":1337631,"uid":263485,"like":0,"dislike":0,"score":0,"quote":{"pid":"c7e6c2916a120a70a1b3a9ff8c7c9e23b2a3a888","tid":1337631,"uid":4493,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-21T10:17:05.000Z","msg":"IFC"},"citedBy":0,"replyTime":"2019-07-21T10:19:13.000Z","msg":"IFC有咩可以做啊?"},{"pid":"2d99d7751ef5764dcba6e36cbda2e09e423bce63","tid":1337631,"uid":65790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T10:19:32.000Z","msg":"中環"}]}