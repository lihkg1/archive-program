ets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"fb817a351a8f610a1cec1e22a203c9b8a1e5ed9e","tid":1886090,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T15:54:03.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"d2e9ffe2ea43fc8bbba319a7e57b5e351ae041bc","tid":1886090,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T15:56:47.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"1e3d9dfea953a1b71e9ab8ae79db26694b00a41a","tid":1886090,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T16:04:46.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"2e6cbeaacd443761fbc45566d49e5c3b51568c8a","tid":1886090,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T16:12:10.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"be1a31797d880fbbb8e75abefcf104ab24da0fb8","tid":1886090,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T16:13:30.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"c16907ed0176554be3011ce845a91a8926f4be4a","tid":1886090,"uid":38795,"like":8,"dislike":0,"score":8,"citedBy":2,"replyTime":"2020-02-24T17:24:14.000Z","msg":"五毛最近轉左新招洗人腦唔好投票<br />\n<br />\n以前就話選舉無用所以大家應該要攬炒投白票廢票<br />\n而家識包裝左，話應該全面推翻選舉制度所以唔好投票<br />\n但個個都知無可能短時間內推翻選舉制度，其實依招係五毛想引你乜都唔做等補選慘敗重現<br />\n你信依d包裝過既白票五毛論既話香港就必輸，投票既話仲有一絲希望，條路係點連登仔自己擇<br />\n<br />\n似乎選舉就到，五毛大軍出動散播各式各樣歪理整輸選舉係每場選舉前必然發生，咁多屆都無例外，不過屆屆玩法唔同<br />\n經過區選之後希望連登仔唔好再俾五毛水到"},{"pid":"a272e52a06f8c477026b14ed5a7f1cd1421be6a3","tid":1886090,"uid":113183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T17:27:52.000Z","msg":"依幾日真係超多超多五毛<br />\n多到block唔切<br />\n好多P牌新account<br />\n波台、娛樂台"},{"pid":"6cfbec68b78a245ec089f12b93537b4639c9274f","tid":1886090,"uid":34641,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-24T17:31:49.000Z","msg":"連仔唔做嘢冇計。。。。"},{"pid":"bf954dc3020f824aa7b8e6de4414512193a586db","tid":1886090,"uid":38795,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-24T17:40:39.000Z","msg":"大家唔好再俾五毛水到唔投票香港就有翻身希望<br />\n<br />\n從最近幾個有五毛氣味既post見到，今年五毛既風向會主力推:<br />\n「功能組別係制度唔公平，所以應該要先推翻制度，現有選舉應該要杯葛」之類既包裝白票論<br />\n今年既五毛將會好識包裝，因為熱狗個種攬炒論已經穿左煲，所以而家d五毛會更著重隱藏身份等你唔覺佢係五毛<br />\n好似前幾日見到個post話咩應該等美國救香港，所以唔應該重視功能組別等奇怪既論點都出埋黎<br />\n另外由此可見功能組別係勝負既關鍵，因為從區議會選舉可以睇到直選議員一定係泛民多，所以今年d五毛都針著功能組別黎散播白票論<br />\n<br />\n只要連登仔同香港人俾d定力，唔好俾五毛各式奇招白票論洗到腦，區議會既大勝畫面唔一定無機會係立會出現，而且嬴立會更變相奪回香港一半控制權，就算最壞情況中共洗橫手都可以挫到中共係香港既統治"},{"pid":"b779812d37283f21b19959664eeb3325bfdac90b","tid":1886090,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T05:17:28.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"65cb35f308c3a489f956a5fa7dfd64643fe9af6f","tid":1886090,"uid":66221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T05:22:24.000Z","msg":"啲廢老都唔推翻點解我要去放水俾保皇狗<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f98128d686ebea8657bf3dbcd3ea6b0393f50848","tid":1886090,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T05:26:52.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"d6efb767b5388c27095f2553487342cc5d2fe5e4","tid":1886090,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T05:31:32.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"d50de731b2bb462b155ba91c3f96cd486fe464b5","tid":1886090,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T05:36:10.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"45f6375908c80ff465ee4bd853726a9765fdf46d","tid":1886090,"uid":14103,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-25T05:40:48.000Z","msg":"佢地好興講一大輪野 然後加句 留名等被