ass=\"hkgmoji\" />"},{"pid":"9899158c49bb7b5045840fe2f7d32dc5937ba674","tid":2215831,"uid":173207,"like":0,"dislike":0,"score":0,"quote":{"pid":"603fe0169c13b25aa47269c3dd167a797c5ed237","tid":2215831,"uid":53379,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-24T08:50:31.000Z","msg":"<strong><span class=\"xx-large\">彭博︰曾助警破解黃之鋒電話　瑞典科技公司撤出香港　停止為港警服務</span></strong><br />\n<br />\n據美國彭博新聞社報導，曾為香港警方提供手機資料提取服務的瑞典科技公司「Micro Systemation AB」將撤出香港，並停止為香港警方提供服務，包括提取涉案人士手機資料的科技。公司副行政總裁 Mike Dickinson 承認，撤出決定與美國早前取消香港特殊地位有關。<br />\n<br />\n總部位於瑞典斯德哥爾摩的科技公司 Micro Systemation AB（MSAB），其副行政總裁 Mike Dickinson 表示，撤出決定與美國今年 7 月取消香港特殊地位有關，該政策影響公司的在美業務和其他部署。撤出在港業務後，MSAB 將不再向香港任何政府機構，包括警方的網絡安全及科技罪案調查科「提供解決方案」（supply solutions），包括提取涉案人士手機資料的科技。<br />\n<br />\n......<br />\n<br />\n<a href=\"https://www.thestandnews.com/politics/%E5%BD%AD%E5%8D%9A-%E6%9B%BE%E5%8A%A9%E8%AD%A6%E7%A0%B4%E8%A7%A3%E9%BB%83%E4%B9%8B%E9%8B%92%E9%9B%BB%E8%A9%B1-%E7%91%9E%E5%85%B8%E7%A7%91%E6%8A%80%E5%85%AC%E5%8F%B8%E6%92%A4%E5%87%BA%E9%A6%99%E6%B8%AF-%E5%81%9C%E6%AD%A2%E7%82%BA%E6%B8%AF%E8%AD%A6%E6%9C%8D%E5%8B%99/?fbclid=IwAR04o9bYU1BucRRGsVr4-bNfoMaXq3dX9OG7RFWn0sKPazoDLUqP2q9iK3M\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E5%25BD%25AD%25E5%258D%259A-%25E6%259B%25BE%25E5%258A%25A9%25E8%25AD%25A6%25E7%25A0%25B4%25E8%25A7%25A3%25E9%25BB%2583%25E4%25B9%258B%25E9%258B%2592%25E9%259B%25BB%25E8%25A9%25B1-%25E7%2591%259E%25E5%2585%25B8%25E7%25A7%2591%25E6%258A%2580%25E5%2585%25AC%25E5%258F%25B8%25E6%2592%25A4%25E5%2587%25BA%25E9%25A6%2599%25E6%25B8%25AF-%25E5%2581%259C%25E6%25AD%25A2%25E7%2582%25BA%25E6%25B8%25AF%25E8%25AD%25A6%25E6%259C%258D%25E5%258B%2599%2F%3Ffbclid%3DIwAR04o9bYU1BucRRGsVr4-bNfoMaXq3dX9OG7RFWn0sKPazoDLUqP2q9iK3M&d=NOH35fHRfA96o6n45SGJFE6%2B9elrQwgXj79VqWXxFjk%3D&h=9b554125\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E5%25BD%25AD%25E5%258D%259A-%25E6%259B%25BE%25E5%258A%25A9%25E8%25