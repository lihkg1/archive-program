l/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"372cbf59e22bcfb5ef2f790ba656b5b219b9b25a","tid":2455591,"uid":30067,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-21T15:27:23.000Z","msg":"去7仔買十盒condom"},{"pid":"f4ccf616e38b62efede37620982065b8ad73619b","tid":2455591,"uid":38540,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2021-03-21T15:33:56.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" />"},{"pid":"cd564b1bcb593bf585a5addf7ab499cfc9a4f8b2","tid":2455591,"uid":1482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-21T15:35:50.000Z","msg":"牛黃丸"},{"pid":"bdae677f634f8c902972a9583e6944c6e1400159","tid":2455591,"uid":152500,"like":0,"dislike":0,"score":0,"quote":{"pid":"027722d9664119e6d3566b46d42bd34e188af12b","tid":2455591,"uid":41484,"like":0,"dislike":7,"score":-7,"citedBy":2,"replyTime":"2021-03-21T15:20:54.000Z","msg":"點樣先可以每月1000？求提示<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n同某隻好惡動物有關既apps有關定係咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-21T15:49:15.000Z","msg":"波仔派"},{"pid":"df2884ee3002c47bbedebe1d2b4be827dc30b944","tid":2455591,"uid":134993,"like":0,"dislike":0,"score":0,"quote":{"pid":"027722d9664119e6d3566b46d42bd34e188af12b","tid":2455591,"uid":41484,"like":0,"dislike":7,"score":-7,"citedBy":2,"replyTime":"2021-03-21T15:20:54.000Z","msg":"點樣先可以每月1000？求提示<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n同某隻好惡動物有關既apps有關定係咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-21T15:56:41.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"f1faab18962d95f32fb077d83fb00042e8a0b09e","tid":2455591,"uid":134993,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-10T09:15:20.000Z","msg":"政府向合資格市民派發5,000元電子消費券，當中最重要考量為商戶覆蓋面及消費設限功能。綜合業界人士指出，政府經過甄選及磋商，多間SVF脫穎而出，而WeChat Pay HK、AlipayHK、PayMe、八達通屬於名單之內。據講，由於項目籌備需時，難提前至第二季推出，甚至未必趕及暑假前推出。<br />\n現時本港有18個SVF持牌人，港人最常用的分別是WeChat Pay HK、AlipayHK及PayMe，據公開資料顯示，上述三間營運商註冊用戶分別有380萬、270萬、230萬。<br />\n政府屬意消費券只限本地消費，涵蓋零售、餐飲、服務行業等，而且不適用於繳稅、水電煤等賬單費用，業界人士指出，「本身SVF要具備區分合資格消費的功能，可能要設定一些規則才能使用」，故已排除一些技術未到位的營運商。<br />\n據悉商戶覆蓋面是另一重點考量，根據第三方研究機構Cimigo今年初數據顯示，AlipayHK、WeChat Pay HK及八達通目前分別有10萬、8萬以及4萬左右的商戶使用。<br />\n本港大部份SVF用途廣，但以大眾消費作為對象的則繆繆可數，當中PayPal、TNG、拍住賞（Tap &amp; Go）料爭奪餘下席位，惟有消息人士指TNG由於受金管局調查關係，未必能夠成為消費券核准營運商之一。<br />\n業界人士分析，WeChat Pay HK、AlipayHK、拍住賞（透過Mastercard進行）均有廣泛的零售商網絡，八達通、PayPal主攻網購；PayMe商戶覆蓋面沒有想像中高，而且部份商店僅以個人PayMe Code當為支付渠道。翻查資料，現時OK便利店、順豐速運、部份連鎖餐廳開始接納PayMe，短期內可能需要擴大零售網絡。<br />\n本報嘗試尋找上述公司回覆，當中八達通發言人回覆指「等政府公告」。<br />\n財政預算案今年2月宣佈向全港18歲或以上市民派5,000元電子消費券，擬分5期派，每月派發1,000元，不能累積並需於當月使用。當時政府指最快暑假起可登記領取，料720萬人受惠，涉公帑360億元。"},{"pid":"2b4768d324d441f66f8895f4d4ed44fcbd56e857","tid":2455591,"uid":45749,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04-10T09:23:11.000Z","msg":"去信和買1000蚊咸碟"},{"pid":"536d606477b41408204c66d82ddb50fe6ac43ebd","tid":2455591,"uid":47605,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-10T09:26:20.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"1f235b7ef7fc39059d52d8ee3e08dc763fbdf575","tid":2455591,"uid":134993,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b4768d324d441f66f8895f4d4ed44fcbd56e857","tid":2455591,"uid":45749,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04-10T09:23:11.000Z","msg":"去信和買1000蚊咸碟"},"citedBy":0,"replyTime":"2021-04-10T09:28:49.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"374e4e0fce9e851ce4b9eaf6fee5b1e5754caddc","tid":2455591,"uid":134993,"like":0,"dislike":0,"score":0,"quote":{"pid":"536d606477b41408204c66d82ddb50fe6ac43ebd","tid":2455591,"uid":47605,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-10T09:26:20.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-10T09:29:39.000