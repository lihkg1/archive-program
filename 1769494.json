{"tid":1769494,"cid":6,"subCid":0,"title":"會員何淦途做緊外判港鐵查飛狗","createTime":"2019-12-05T02:23:01.000Z","updateTime":"2019-12-05T09:36:25.000Z","uid":19552,"like":3,"dislike":1,"uniUserReply":28,"replies":[{"pid":"3c914bd3077bf1bc774cdfea635f37999176e419","tid":1769494,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T02:23:01.000Z","msg":"<img src=\"https://i.lih.kg/540/https://i.lih.kg/540/https://na.cx/i/d7MXEVR.png\" />"},{"pid":"a75224435b4c4c9aa9db70fb9f2b5b30866af717","tid":1769494,"uid":19552,"like":13,"dislike":1,"score":12,"citedBy":4,"replyTime":"2019-12-05T02:23:40.000Z","msg":"<img src=\"https://i.lih.kg/540/https://na.cx/i/d7MXEVR.png\" />"},{"pid":"a410071d188a3bfd3c394efe184bcfd71a599c22","tid":1769494,"uid":206382,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-12-05T02:25:03.000Z","msg":"副白色眼鏡<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"40704277d6dc8c53a635931daadf1149d6b84d0a","tid":1769494,"uid":8968,"like":0,"dislike":0,"score":0,"quote":{"pid":"a75224435b4c4c9aa9db70fb9f2b5b30866af717","tid":1769494,"uid":19552,"like":13,"dislike":1,"score":12,"citedBy":4,"replyTime":"2019-12-05T02:23:40.000Z","msg":"<img src=\"https://i.lih.kg/540/https://na.cx/i/d7MXEVR.png\" />"},"citedBy":0,"replyTime":"2019-12-05T02:25:19.000Z","msg":"好型<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"c92c111a8eb7b4e64b3712fcb7db54c26168f4e7","tid":1769494,"uid":270532,"like":0,"dislike":0,"score":0,"quote":{"pid":"a75224435b4c4c9aa9db70fb9f2b5b30866af717","tid":1769494,"uid":19552,"like":13,"dislike":1,"score":12,"citedBy":4,"replyTime":"2019-12-05T02:23:40.000Z","msg":"<img src=\"https://i.lih.kg/540/https://na.cx/i/d7MXEVR.png\" />"},"citedBy":1,"replyTime":"2019-12-05T02:27:16.000Z","msg":"你點知係佢<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><br />\n同埋佢捉過手足？"},{"pid":"a17aae63dfbc81d37e25d085e24dd65208