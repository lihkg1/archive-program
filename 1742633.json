faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"2d6eeaea8fdcdb9f7cd2dc803d0c054a8900a795","tid":1742633,"uid":216800,"like":0,"dislike":0,"score":0,"quote":{"pid":"84d8c996f3241f2e76bd56936f70cefc95d9baf8","tid":1742633,"uid":121580,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-11-21T04:24:08.000Z","msg":"夾硬迫上車轉個頭又迫返落車<br />\n識玩<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-21T04:45:40.000Z","msg":"唔好阻我返工呀！<br />\n企入啲啦！<br />\n推呀！關唔到門呀！<br />\n遲到啦！<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"}]}