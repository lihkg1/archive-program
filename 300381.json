inger_Mao.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.wikimedia.org%2Fwikipedia%2Fcommons%2F0%2F09%2FKissinger_Mao.jpg&h=bab8786b&s={SIZE}\" /><br />\n<img src=\"http://image.cache.storm.mg/styles/smg-800x533-fp/s3/media/image/2015/09/26/20150926-051528_U720_M90693_1631.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimage.cache.storm.mg%2Fstyles%2Fsmg-800x533-fp%2Fs3%2Fmedia%2Fimage%2F2015%2F09%2F26%2F20150926-051528_U720_M90693_1631.jpg&h=3b6149a3&s={SIZE}\" />"},{"pid":"d843bd9612e22d299892cbf372e3e96c63348587","tid":300381,"uid":35790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-28T00:47:10.000Z","msg":"身有_?"},{"pid":"351db4eed739e5514753b64fd344721eaf0e81b4","tid":300381,"uid":92301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-28T00:48:37.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"49ae516db09a9fab729f07f8cc95c5366d4440d7","tid":300381,"uid":44358,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-28T00:49:33.000Z","msg":"輕輕一推<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"4b2bb750bd071a71608c2e92bc370cd89c55c49f","tid":300381,"uid":997,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-06-28T00:50:28.000Z","msg":"捉基辛格條仆街去打靶就岩<br />\n比人用黑錢收買就當正自己係支那通"},{"pid":"0948b1b4102ce54ab598ea4c8535003c2bc842f9","tid":300381,"uid":62935,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-28T00:52:24.000Z","msg":"house of cards<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"893bbcfd178817146260ffe77fbbd263ac40fa06","tid":300381,"uid":100986,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-06-28T01:01:11.000Z","msg":"<blockquote>house of cards<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n查完俄羅斯，跟住就查中心之國<br />\n其實更應該查既唔係爛溶溶既俄佬，而係中心之國"},{"pid":"33981f9db3a9d94f775edd15848fe222b5a0fa83","tid":300381,"