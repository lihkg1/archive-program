2:13.000Z","msg":"推"},{"pid":"fb62cdb5191a3e30adca2359f5060dab869489fb","tid":1509172,"uid":36696,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-26T19:24:04.000Z","msg":"真。防彈少年團"},{"pid":"9237701b60a011a87ac2b9d517a75119539d8939","tid":1509172,"uid":27793,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T06:37:41.000Z","msg":"twt 推緊<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n#HongKongArmy"},{"pid":"fa956efd4d898f501c6fcf7471fcfad405258ee1","tid":1509172,"uid":128334,"like":1,"dislike":0,"score":1,"quote":{"pid":"0d3c4a62873663d9aa52deb0c5860138f2a3ecdd","tid":1509172,"uid":138296,"like":2,"dislike":0,"score":2,"quote":{"pid":"00fbebebd7a607caaa728b61600d8c2a248ae186","tid":1509172,"uid":172092,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-08-26T18:49:18.000Z","msg":"隻兔仔係代表某一個韓國團體嘅應援物？"},"citedBy":1,"replyTime":"2019-08-26T18:52:04.000Z","msg":"Bts"},"citedBy":0,"replyTime":"2019-08-27T06:44:24.000Z","msg":"介紹返：<br />\nBT21，是由韓國男子團體「防彈少年團」(BTS) 和LINE FRIENDS攜手合作所打造的卡通角色系列。 從最初的卡通角色草圖，到賦予其個性，商品開發計畫等，整個角色創造過程都由BTS成員們親自參與。 角色包括KOYA、TATA、CHIMMY、RJ、SHOOKY、MANG、COOKY和VAN。<br />\n<img src=\"https://na.cx/i/CBZcvJV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCBZcvJV.jpg&h=896f8641&s={SIZE}\" /> <br />\n<br />\nARMY<br />\n歌迷名稱<br />\n防彈少年團的官方歌迷名稱為「A.R.M.Y」（韓語：아미），這個名稱是在2013年7月9日通過官方網站首度亮相，由防彈少年團的成員們閱讀約1000個粉絲意見後親自選出。來自於英文「Adorable Representative M.C for Youth」的縮寫，意指「值得人們景仰的青年代表」，ARMY在英語裏的意思是軍隊，而防彈衣和軍隊總是在一起，所以也有粉絲們和防彈少年團一直在一起的意思[10]。官方應援物為炸彈造型的手燈「ARMY BOMB」。"},{"pid":"53c36f82d1820b90f2c3a515cec43e8f8199652b","tid":1509172,"uid":80396,"like":0,"dislike":0,"score":0,"quote":{"pid":"fb62cdb5191a3e30adca2359f5060dab869489fb","tid":1509172,"uid":36696,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-26T19:24:04.000Z","msg":"真。防彈少年團"},"citedBy":0,"replyTime":"2019-08-27T06:45:13.000Z","msg":"中彈少年團"},{"pid":"d663aa4c4de71a5de235cca95e839dae00664545","tid":