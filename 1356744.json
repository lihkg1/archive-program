3A%2F%2Fna.cx%2Fi%2FFm6wVj8.jpg&h=a278d3d6&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/AGeFOE8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAGeFOE8.jpg&h=6a66afb5&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/O4SgmZ9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FO4SgmZ9.jpg&h=eebe775f&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/6PWACyw.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6PWACyw.png&h=a280a0bd&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/m3cTpdw.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fm3cTpdw.png&h=6f4f1fb2&s={SIZE}\" />"},{"pid":"1002fc9fb1cd8db32f4177439a2e507d8c1a9888","tid":1356744,"uid":127929,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-07-23T15:11:46.000Z","msg":"再講多次，今次係和理非黎！<span style=\"color: gold;\"><strong>係和理非呀！和！理！非！呀！</strong></span>絕對<span style=\"color: red;\"><strong>唔</strong></span>可以做主動撩交打個個呀！<br />\n<br />\n反警黑勾結一定要優先講清楚！但<span style=\"color: gold;\"><strong>同時要提及其他4大訴求！唔好比機會林鄭建制淡化</strong></span> 612, 屯門, 九龍, 上水, 沙田, 上環 既事！<br />\n<br />\n<span style=\"color: gold;\"><strong>同埋夠鐘一定要拉隊走</strong></span>！拉！隊！走！班黑社會同黑警冇人性！冷血架佢地！可能又會好似上次咁，<span style=\"color: gold;\"><strong>一入黑就同我地黎多次江湖新秩序！</strong></span><img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><br />\n<br />\n今次和理非係元朗都要聚焦返<span style=\"font-size: xx-large;\"> 5 </span>大訴求<br />\n1. 全面撤回送中條例<br />\n2. 撤銷<span style=\"color: red;\">6.12</span>暴動定性<br />\n3. 釋放被捕義士並承諾永不追究<br />\n4. 5. 成立獨立調查委員會，追究黑警濫用暴力，徹查警黑勾結<span style=\"color: red;\">7.21</span>元朗恐襲<br />\n5. 全面實行雙普選"},{"pid":"c7b8f5b37b507df302f328165a15d96ab8e9fae7","tid":1356744,"uid":279269,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-23T15:12:27.000Z","msg":"<span style=\"font-size: xx-large;\">元朗真心危險, 晚上慎入....</span>"}]}