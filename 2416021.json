f8a0288671a3ee1c7c8ebda407f8b7152ca3","tid":2416021,"uid":30788,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-02-20T16:42:08.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />好想死"},"citedBy":1,"replyTime":"2021-02-21T01:08:53.000Z","msg":"去睇娜娜跳大媽舞開心d"},"citedBy":0,"replyTime":"2021-02-21T01:27:51.000Z","msg":"no"},{"pid":"64dd4dc571b095166d8727146ed3916ac7463f95","tid":2416021,"uid":122513,"like":0,"dislike":0,"score":0,"quote":{"pid":"8622f8a0288671a3ee1c7c8ebda407f8b7152ca3","tid":2416021,"uid":30788,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-02-20T16:42:08.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />好想死"},"citedBy":0,"replyTime":"2021-02-22T12:12:40.000Z","msg":"或許我不能完全了解你內心的痛苦，但我也曾置身於無助和絕望之中，明白身處痛苦是怎樣一回事。無論你的是否想放棄自己，也希望你不要將困擾藏在心裡，因鬱結和壓力積存得太多太久，到情緒爆發時可能已超出你所能控制的程度。<br />\n<br />\n你不如停一停，到我們的網站  <a href=\"http://www.help4suicide.com.hk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.help4suicide.com.hk&d=0FWZMlR46yIxX%2BJDTULvnbHKdwoo7KeUephkEgg9e70%3D&h=696aa71b\" data-auto-link target=\"_blank\">www.help4suicide.com.hk</a>  。 那裡有一些勵志故事、有趣短片，也有與自殺有關的人與事，你可以隨心看看。您更可以進入網站內的『Chat窿』（星期一至五：下午4時至凌晨1時；星期六、日及公眾假期：晚上８時至凌晨１時），即時與我們的義工在網上交談，或致電我們24小時電話熱線2389-2222，與我們的義工傾訴。<br />\n<br />\n我們願意聆聽你的心聲，伴你一起走過這段艱難的時候！只因『晴天雨天要樂天，難關難過總會過』！<br />\n<br />\n《自殺．自療．互助舍》"},{"pid":"80d588ee3e72cafeb678bada292da182ad32d458","tid":2416021,"uid":293937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-22T12:15:31.000Z","msg":"52歲又真係唔上唔落"}]}