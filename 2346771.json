faces/catxm/pussy1.gif\" class=\"hkgmoji\" />"},{"pid":"08ad49882a4aa27f4a8901961fd7965502e4d68e","tid":2346771,"uid":55177,"like":6,"dislike":0,"score":6,"citedBy":2,"replyTime":"2020-12-30T13:51:42.000Z","msg":"想問 chi na個讀音做支那其實係有咩問題？？？"},{"pid":"3ba75ec47fcffba1b37842caa89e8703ac731f3c","tid":2346771,"uid":181318,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-12-30T13:51:58.000Z","msg":"遲早中國兩個字都會叫到變辱華架喇 諗定叫第2個名啦死柒頭<img src=\"/assets/faces/dogxm/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"5be17882305cea5c2ec293672c07df7b8498ffca","tid":2346771,"uid":20903,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-30T13:51:58.000Z","msg":"支那<img src=\"/assets/faces/big/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"7397896c633298cadf632d6c52049f991928b901","tid":2346771,"uid":114360,"like":4,"dislike":0,"score":4,"quote":{"pid":"08ad49882a4aa27f4a8901961fd7965502e4d68e","tid":2346771,"uid":55177,"like":6,"dislike":0,"score":6,"citedBy":2,"replyTime":"2020-12-30T13:51:42.000Z","msg":"想問 chi na個讀音做支那其實係有咩問題？？？"},"citedBy":3,"replyTime":"2020-12-30T13:53:46.000Z","msg":"語源明明一樣，為何只有日本的「支那」會變成貶義呢？中國人對「支那」這個字詞由中性變成反感，明顯是後天的歷史因素造成，不能抽離忽視不看。<br />\n<br />\n<br />\n早在昭和5年（1930年）10月31日的內閣議決，提出議案「支那国号ノ呼称ニ関スル件」（約略中譯：關於支那國號的稱呼議案），內文說「然ルニ右支那ナル呼称ハ当初ヨリ同国側ノ好マサリシ所ニシテ殊ニ最近同国官民ノ之ニ対シ不満ヲ表示スルモノ多キヲ加ヘタル観アリ」（約略中譯：「支那」這稱呼在該國一開始已經不是首選的名稱。最近該國官民都表現對此名稱不滿，而且似乎越來越多。）<br />\n<br />\n<br />\n後來日本侵華，與中華民國交惡，日本不再稱呼對方作「中華民國」而是繼續使用「支那」一名。自侵略開始、侵華戰爭過程中日本一直以「支那」稱呼中國，這點連中國的平民都知道，所以「支那」一字由那時開始增添了「帝國主義」、「軍國主義」的色彩，令中國人對「支那」一字產生極厭惡的感覺。"},{"pid":"95099bcb275e7360ff487965c52e52feeb421e4f","tid":2346771,"uid":284432,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-12-30T13:57:10.000Z","msg":"此回覆已被刪除"},{"pid":"39b7fa27d7c9be217157cf9cd6a59d92c4e55933","tid":2346771,"uid":288688,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-30T13:57:19.000Z","msg":"咪住先呢個北一輝係咪以前嗰個北一輝先？ 係嘅話我覺得好正常啫～"},{"pid":"69f81fdc983d1ce273a8b28c75d77466fac2dff7","tid":2346771,"uid":114360,"like":3,"disli