一場逆權運動<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"a1870d6055a7c6ed0a4c5b443aa87c8ca95ed615","tid":1484400,"uid":100986,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-18T18:27:17.000Z","msg":"豬隊友<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" />"}]}