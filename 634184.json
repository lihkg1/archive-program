e4cefb93642d565b43390bbfa","tid":634184,"uid":900,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-19T05:31:54.000Z","msg":"張示意圖擺明畫緊疑犯一<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"cf6fd19add4b1e2491c7849c6c24344d12ebe1ca","tid":634184,"uid":900,"like":0,"dislike":0,"score":0,"quote":{"pid":"1dd1e1450ff5d94e4cefb93642d565b43390bbfa","tid":634184,"uid":900,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-19T05:31:54.000Z","msg":"張示意圖擺明畫緊疑犯一<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-19T05:32:44.000Z","msg":"無野了<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 無睇內文 自隊一打<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f0e349f0c3a28bf60a169bc15fc1dca37732aeb8","tid":634184,"uid":5499,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d86c1fa4853be5cdd70e62353b5e5fafe7f2599","tid":634184,"uid":117965,"like":0,"dislike":0,"score":0,"quote":{"pid":"50dbc95840bdfe2747