F%25E8%2596%25AF%25E4%25BB%2594%25E8%2581%259E%25E8%258C%25B1%25E8%258E%2589%2Fportfolio&d=BCqMRPjRs%2BrlYbPtDS4RDJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=008d9aa1\" data-auto-link target=\"_blank\">https://www.penana.com/user/27349/%E8%96%AF%E4%BB%94%E8%81%9E%E8%8C%B1%E8%8E%89/portfolio</a><br />\n<br />\n<br />\n有興趣接收科學資訊的話，歡迎follow IG: potatopigtongue。<br />\n<br />\n<a href=\"https://www.instagram.com/potatopigtongue/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fpotatopigtongue%2F&d=BCqMRPjRs%2BrlYbPtDS4RDJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=e2c6d48f\" data-auto-link target=\"_blank\">https://www.instagram.com/potatopigtongue/</a><br />\n<br />\n<br />\n<br />\nRef1:<a href=\"https://www.siemens-healthineers.com/en-us/news/mso-case-operated-thyroid-carcinoma.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.siemens-healthineers.com%2Fen-us%2Fnews%2Fmso-case-operated-thyroid-carcinoma.html&d=BCqMRPjRs%2BrlYbPtDS4RDJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=5c67faa7\" data-auto-link target=\"_blank\">https://www.siemens-healthineers.com/en-us/news/mso-case-operated-thyroid-carcinoma.html</a><br />\nRef2:<a href=\"https://www.sciencedirect.com/science/article/pii/S0167814020308094\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.sciencedirect.com%2Fscience%2Farticle%2Fpii%2FS0167814020308094&d=BCqMRPjRs%2BrlYbPtDS4RDJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=c4173ae4\" data-auto-link target=\"_blank\">https://www.sciencedirect.com/science/article/pii/S0167814020308094</a>"},"citedBy":1,"replyTime":"2020-10-27T23:21:20.000Z","msg":"係PSMA<img src=\"/assets/faces/dog/discover.gif\" class=\"hkgmoji\" />"},{"pid":"76b638e051bb936772634bfff82a8b761da33933","tid":2260750,"uid":38861,"like":0,"dislike":1,"score":-1,"quote":{"pid":"a7462af42d589f177a7d17ee7361257e1c0a893e","tid":2260750,"uid":54323,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-10-27T23:19:20.000Z","msg":"該器官知唔知有咩作用<img src=\"/assets/faces/lm2/wfc2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-27T23:31:01.000Z","msg":"暫時應該未知<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"710c0e4716508eb991c03669111c19691a3d7ce8","tid":2260750,"uid":38861,"like":1,"dislike":1,"score":0,"quote":{"pid":"6aeffc21eec893bf026a46f1c88e0bc13015265e","tid":2260750,"uid":115049,"like":0,"dislike":0,"score":0,"quote":{"pid":"875794cf81be00cc1eabd1bb785ccf9119e4be75","tid":2260750,"uid":38861,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-27T23:04:30.000Z","msg":"早前新聞亦有廣泛報導有新「器官」tubarial glands的發現，乃為研究人員在替前列腺病人作檢測的時候無意中尋覓出來。<br />\n<br />\n本文會將整個發現的過程深入淺出一番，順帶講及一下關於癌細胞的話題。<br />\n<br />\n<img src=\"https://na.cx/i/qFy2R9e.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqFy2R9e.png&h=2cb66718&s={SIZE}\" /><br />\n<br />\n部份癌細胞會傾向攝取葡萄糖提供能量及原料，以支撐其生長速度。<br />\n<br />\n18F-FDG-PET scans能夠檢查細胞的葡萄糖攝取量，因而被採取為一道癌細胞的檢測工具。<br />\n<br />\n但並不是所有癌細胞均會傾向攝取葡萄糖，以前列腺癌為例，他們傾向攝取Glutamine（氨基酸的一種）及Fatty acid，因此18F-FDG-PET scans並不太適用於前列腺癌檢測方面上。<br />\n<br />\n<br />\n（圖2）而在檢測前列腺癌方面， PMSA-PET scans是其中一種取代18F-FDG-PET scans的方法，原因是前列腺癌擁有較多的PMSA數量，因此在檢測中會被呈現出來。<br />\n<img src=\"https://na.cx/i/gAqHR9k.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgAqHR9k.jpg&h=bd23703f&s={SIZE}\" /><br />\n<br />\n而負責分泌唾液的唾腺(Salivary gland)，在正常運作狀態下，亦會被PMSA-PET scans檢測得到。<br />\n<br />\n<br />\n（圖3）而就在利用PMSA-PET scans檢驗前列腺病人的時候，研究人員發現了一道在書本上沒有記載的區域(藍色箭嘴所示)，與已知的唾腺位置並不吻合（Ref2)；<br />\n他們足足檢驗了100名病人樣本，所有人均擁有這區域。<br />\n<img src=\"https://na.cx/i/frLkDPp.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfrLkDPp.png&h=895b2da7&s={SIZE}\" /><br />\n<br />\n（圖4）從一男一女所捐贈的身體解剖中，肉眼亦可見到其結構的存在，而研究人員亦有做實驗證實其結構擁有大量PMSA，與PMSA-PET scans的結果相乎。<br />\n<img src=\"https://na.cx/i/Z63eJf7.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZ63eJf7.png&h=115e749f&s={SIZE}\" /><br />\n<br />\n基於其結構在Torus tubarius位置發現，研究人員提出命名這結構為tubarial glands的主張。<br />\n<br />\n而究竟應該定位tubarial glands為器官、組織、還是人體第四對唾腺，至今還需要尋求醫學界的共識。<br />\n<br />\n若然被證實其結構有著唾腺作用的話，那麼日後進行放射治療的人員便要加倍小心不可傷及其結構位置，以免傷害病人正常器官的運作。<br />\n<br />\n如果想我快啲出文的話，請入去<span class=\"blue\">Penana網站科普專欄&ndash;薯不揀單</span>俾一個<span class=\"green\">like</span>以及<span class=\"red\">Bookmark</span>，這對我非常之重要。<br />\n<br />\nLink: <a href=\"https://www.penana.com/story/66244/%E7%A7%91%E6%99%AE%E5%B0%88%E6%AC%84-%E8%96%AF%E4%B8%8D%E6%8F%80%E5%96%AE/toc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.penana.com%2Fstory%2F66244%2F%25E7%25A7%2591%25E6%2599%25AE%25E5%25B0%2588%25E6%25AC%2584-%25E8%2596%25AF%25E4%25B8%258D%25E6%258F%2580%25E5%2596%25AE%2Ftoc&d=BCqMRPjRs%2BrlYbPtDS4RDJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=4489dbd8\" data-auto-link target=\"_blank\">https://www.penana.com/story/66244/%E7%A7%91%E6%99%AE%E5%B0%88%E6%AC%84-%E8%96%AF%E4%B8%8D%E6%8F%80%E5%96%AE/toc</a><br />\n<br />\n同時亦可以在Penana網站裡按「<span class=\"gold\">買一嚿/半嚿薯仔</span>」，以課金的方式推動我繼續搜羅資料寫文，多謝。<br />\n<br />\nLink:<br />\n<a href=\"https://www.penana.com/user/27349/%E8%96%AF%E4%BB%94%E8%81%9E%E8%8C%B1%E8%8E%89/portfolio\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.penana.com%2Fuser%2F27349%2F%25E8%2596%25AF%25E4%25BB%2594%25E8%2581%259E%25E8%258C%25B1%25E8%258E%2589%2Fportfolio&d=BCqMRPjRs%2BrlYbPtDS4RDJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=008d9aa1\" data-auto-link target=\"_blank\">https://www.penana.com/user/27349/%E8%96%AF%E4%BB%94%E8%81%9E%E8%8C%B1%E8%8E%89/portfolio</a><br />\n<br />\n<br />\n有興趣接收科學資訊的話，歡迎follow IG: potatopigtongue。<br />\n<br />\n<a href=\"https://www.instagram.com/potatopigtongue/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fpotatopigtongue%2F&d=BCqMRPjRs%2BrlYbPtDS4RDJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=e2c6d48f\" data-auto-link target=\"_blank\">https://www.instagram.com/potatopigtongue/</a><br />\n<br />\n<br />\n<br />\nRef1:<a href=\"https://www.siemens-healthineers.com/en-us/news/mso-case-operated-thyroid-carcinoma.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.siemens-healthineers.com%2Fen-us%2Fnews%2Fmso-case-operated-thyroid-carcinoma.html&d=BCqMRPjRs%2BrlYbPtDS4RDJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=5c67faa7\" data-auto-link target=\"_blank\">https://www.siemens-healthineers.com/en-us/news/mso-case-operated-thyroid-carcinoma.html</a><br />\nRef2:<a href=\"https://www.sciencedirect.com/science/article/pii/S0167814020308094\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.sciencedirect.com%2Fscience%2Farticle%2Fpii%2FS0167814020308094&d=BCqMRPjRs%2BrlYbPtDS4RDJ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=c4173ae4\" data-auto-link target=\"_blank\">https://www.sciencedirect.com/science/article/pii/S0167814020308094</a>"},"citedBy":1,"replyTime":"2020-10-27T23:21:20.000Z","msg":"係PSMA<img src=\"/assets/faces/dog/discover.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-27T23:31:23.000Z","msg":"<img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" />......fk，7哂"},{"pid":"58ab94a635b8a7058a03baf173365b1404af723c","tid":2260750,"uid":57073,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-27T23:33:56.000Z","msg":"可能就係傳說中嘅笑臟"},{"pid":"d7cbb61ad25caeff8d3c7d6c8299299fa1af6749","tid":2260750,"uid":113250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-28T01:43:39.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"7fa972afbdbcdecf656db29e31058bc754b1a2b6","tid":2260750,"uid":36088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-28T01:57:12.000Z","msg":"<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"1149be417252e42bfc1fa1b373d6238896f37e5c","tid":2260750,"uid":88663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-28T02:05:58.000Z","msg":"口水？"},{"pid":"443f33f2f2725e4ef08a24b424b46112637e7694","tid":2260750,"uid":4780,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7462af42d589f177a7d17ee7361257e1c0a893e","tid":2260750,"uid":54323,"like":1,"dislike"