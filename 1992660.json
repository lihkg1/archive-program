src=\"https://na.cx/i/n0zSBzF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fn0zSBzF.jpg&h=2a900452&s={SIZE}\" /><br />\n<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"dd8cc053a817102c34fab342fc1f044fedf8f5df","tid":1992660,"uid":43062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T10:55:50.000Z","msg":"立場好波<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"221016cbdddf1fa7c136aa290602cae4f90fd18c","tid":1992660,"uid":242262,"like":0,"dislike":0,"score":0,"quote":{"pid":"5af452be5318d71d949dfa56afcb24a3fe796783","tid":1992660,"uid":22556,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-04-28T09:35:08.000Z","msg":"去年 11 月 4 日凌晨，有人於將軍澳一帶堵路示威及向警員投擲雜物，警方展開驅散行動並在多處發射催淚彈。其中拘捕一名 30 歲文員，控以一項《警隊條例》下的襲警罪。案件今（28日）於觀塘裁判法院提堂，被告不認罪。裁判官將案件定於 8 月 3 日進行審訊。<br />\n<br />\n辯方表示，由於被告的代表大律師將會在隨後數月在上級法院接受任命，故裁判官將案件押後至較後的 8 月初，暫定於面積較大的觀塘法院 8 號法庭，以中文進行審訊。<br />\n<br />\n控方則透露，本案沒有警誡供詞，傳召 3 名證人，以及將一段2 至 3 分鐘《立場新聞》網上發佈的片段呈堂。辯方表示未有機會閱覽相關片段。<br />\n<br />\n《立場新聞》總編輯鍾沛權表示，《立場》自去年七月至今年二月期間，共收到警務處十多次來信，針對多次衝突事件提出確認片段、提供網上片段母片、其他紀錄及拍攝人員資料等要求，《立場新聞》早已公開表示不會提供採訪材料、記者身份和聯絡方法予警方，新聞機構不應該配合警方調查案件和搜證，其後再無回應警務處來信，不確定上述案件中警方提及的片段來源及完整性。<br />\n<br />\n<br />\n<a href=\"https://www.thestandnews.com/politics/%E6%96%87%E5%93%A1%E5%90%A6%E8%AA%8D%E8%A5%B2%E8%AD%A6-8-%E6%9C%88%E9%96%8B%E5%AF%A9-%E6%8E%A7%E6%96%B9%E7%A8%B1%E5%B0%87%E5%91%88-%E7%AB%8B%E5%A0%B4-%E7%B6%B2%E4%B8%8A%E7%89%87%E6%AE%B5/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E6%2596%2587%25E5%2593%25A1%25E5%2590%25A6%25E8%25AA%258D%25E8%25A5%25B2%25E8%25AD%25A6-8-%25E6%259C%2588%25E9%2596%258B%25E5%25AF%25A9-%25E6%258E%25A7%25E6%2596%25B9%25E7%25A8%25B1%25E5%25B0%2587%25E5%2591%2588-%25E7%25AB%258B%25E5%25A0%25B4-%25E7%25B6%25B2%25E4%25B8%258A%25E7%2589%2587%25E6%25AE%25B5%2F&d=mbsn9%2Fi9gU9wZYjOUdyYPsg7Fotki3H%2BSmgHlFrgEoM%3D&h=4a0a74fc\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E6%2596%2587%25E5%2593%25A1%25E5%2590%25A6%25E8%25AA%258D%25E8%25A5%25B2%25E8%25AD%25A6-8-%25E6%259C%2588%25E9%2596%258B%25E5%25AF%25A9-%25E6%258E%25A7%25E6%2596%25B9%25E7%25A8%25B1%25E5%25B0%2587%25E5%2591%2588-%25E7%25AB%258B%25E5%25A0%25B4-%25E7%25B6%25B2%25E4%25B8%258A%25E7%2589%2587%25E6%25AE%25B5%2F&h=114186eb\" data-auto-link target=\"_blank\">https://www.thestandnews.com/politics/%E6%96%87%E5%93%A1%E5%90%A6%E8%AA%8D%E8%A5%B2%E8%AD%A6-8-%E6%9C%88%E9%96%8B%E5%AF%A9-%E6%8E%A7%E6%96%B9%E7%A8%B1%E5%B0%87%E5%91%88-%E7%AB%8B%E5%A0%B4-%E7%B6%B2%E4%B8%8A%E7%89%87%E6%AE%B5/</a>"},"citedBy":0,"replyTime":"2020-04-28T10:56:18.000Z","msg":"做得好"},{"pid":"46a3a5bdd0e604d30744debc5105a27d676b8cf5","tid":1992660,"uid":138064,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-28T10:56:47.000Z","msg":"推"},{"pid":"aeda4503be8f4646cd3a7751df083cc7ea653114","tid":1992660,"uid":124455,"like":0,"dislike":0,"score":0,"quote":{"pid":"400f9bff45a2874cbc4d0154ab7943863eb10445","tid":1992660,"uid":201605,"like":94,"dislike":1,"score":93,"citedBy":5,"replyTime":"2020-04-28T09:40:21.000Z","msg":"如果發現網上有唔同deep fake版本，代表片段被修改過?"},"citedBy":0,"replyTime":"2020-04-28T10:58:07.000Z","msg":"做好安全操施先<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"2daa7e691a49612afd37a345da4664b882a4c039","tid":1992660,"uid":259988,"like":8,"dislike":0,"score":8,"quote":{"pid":"92328e1850810fc7e1a78138de355ed51955e052","tid":1992660,"uid":78392,"like":36,"dislike":0,"score":36,"quote":{"pid":"7d7073010d90b54183f3a95c6fd2114341c1624b","tid":1992660,"uid":56115,"like":235,"dislike":1,"score":234,"citedBy":2,"replyTime":"2020-04-28T09:38:24.000Z","msg":"唔俾母片就有機會程堂質疑片段有冇被修改<img src=\"/assets/fa