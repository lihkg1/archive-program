000Z","msg":"貪得無厭的沙螺灣人<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"708baeb58952d767d3244009f8546b76a29fbade","tid":2232022,"uid":186,"like":1,"dislike":0,"score":1,"quote":{"pid":"22220d53b62c73c11d768a78160d5f1ea8032f92","tid":2232022,"uid":54800,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1f669e18153556fe83ea20d08e30c1ddfe6bb2a","tid":2232022,"uid":173326,"like":1,"dislike":0,"score":1,"quote":{"pid":"ee9edb87a3b004d577a889bcfe0915226af4db30","tid":2232022,"uid":186,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-10-06T05:54:39.000Z","msg":"沙螺人 站出來"},"citedBy":1,"replyTime":"2020-10-06T05:58:39.000Z","msg":"英雄名嚟？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-06T07:27:25.000Z","msg":"<a href=\"https://www.google.com/maps/uv?pb=!1s0x3403e380ee3de01d%3A0x350b15650580fac5!3m1!7e115!4shttps%3A%2F%2Flh5.googleusercontent.com%2Fp%2FAF1QipO2uI7df7kG_ow4eSGZvUzE__TChzl0Uba90_Ky%3Dw260-h175-n-k-no!5z5rKZ6J6654Gj5Lq6IC0gR29vZ2xlIOaQnOWwiw!15sCgIgAQ&amp;imagekey=!1e10!2sAF1QipO2uI7df7kG_ow4eSGZvUzE__TChzl0Uba90_Ky&amp;hl=zh-TW#\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.google.com%2Fmaps%2Fuv%3Fpb%3D%211s0x3403e380ee3de01d%253A0x350b15650580fac5%213m1%217e115%214shttps%253A%252F%252Flh5.googleusercontent.com%252Fp%252FAF1QipO2uI7df7kG_ow4eSGZvUzE__TChzl0Uba90_Ky%253Dw260-h175-n-k-no%215z5rKZ6J6654Gj5Lq6IC0gR29vZ2xlIOaQnOWwiw%2115sCgIgAQ%26imagekey%3D%211e10%212sAF1QipO2uI7df7kG_ow4eSGZvUzE__TChzl0Uba90_Ky%26hl%3Dzh-TW%23&d=zpUJ%2F0Jv8gnTBnB6SvMaKJUrr29XULmfQ5XcAAvzh4c%3D&h=b9100e87\" target=\"_blank\">https://www.google.com/maps/uv?pb=!1s0x3403e380ee3de01d%3A0x350b15650580fac5!3m1!7e115!4shttps%3A%2F%2Flh5.googleusercontent.com%2Fp%2FAF1QipO2uI7df7kG_ow4eSGZvUzE__TChzl0Uba90_Ky%3Dw260-h175-n-k-no!5z5rKZ6J6654Gj5Lq6IC0gR29vZ2xlIOaQnOWwiw!15sCgIgAQ&amp;imagekey=!1e10!2sAF1QipO2uI7df7kG_ow4eSGZvUzE__TChzl0Uba90_Ky&amp;hl=zh-TW#</a><br />\n<br />\n疑似沙螺人祖先~!!<img sr