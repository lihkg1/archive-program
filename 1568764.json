aces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"7cc23d9c323851d463e07a363d77dbce7a97232b","tid":1568764,"uid":202876,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-14T14:00:42.000Z","msg":"你點影的"},{"pid":"be19f390cfac5f190364e84a78f6de570a6ce5eb","tid":1568764,"uid":43785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-14T15:12:19.000Z","msg":"<img src=\"/assets/faces/mf/bye.gif\" class=\"hkgmoji\" />"},{"pid":"0dc4ff30448fd1ef240fc440603766f35d1f6d7a","tid":1568764,"uid":6723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-14T15:17:03.000Z","msg":"推"},{"pid":"14ad643c191e9961653c66bd81a2b8eefe406f79","tid":1568764,"uid":288154,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-14T15:26:48.000Z","msg":"唱《願榮光歸香港》國歌，<span style=\"font-size: xx-large;\"><span style=\"color: red;\">給中共最大壓力</span></span><br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1569108\" data-auto-link target=\"_blank\">https://lih.kg/1569108</a>"},{"pid":"7ae3c1096734153cca0ad33eb7379f747170d25d","tid":1568764,"uid":187272,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-14T16:36:36.000Z","msg":"Yes ,sir!"},{"pid":"b76e10e78d7edfee0ab971418d524387802f6c7c","tid":1568764,"uid":80560,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-14T16:41:31.000Z","msg":"日本南北朝時代的武將楠木正成將軍壯烈犧牲後，旗幟上留有「非、理、法、權、天」五個字。這五個字是什麼意思呢？<br />\n<br />\n非，就是不對的事情。所以，「非」不能勝過「理」，這是當然的。<br />\n<br />\n理，不能勝過「法」。例如，在法官之前，即使你講說多少道理，但是他也可能說：「我知道你有很多的理由，不過你做的這件事情不合法。」所以，在法律之前，道理也不算道理了。<br />\n<br />\n法，不能勝過「權」。例如，古代有權勢的人，他可以改變法令。就是今日，世界上也還有許多地方只講權力，沒有法制。<br />\n<br />\n權，不能勝過「天」。天，就是最高的真理，也就是因果的道理。一個人權力再大，就算是逃脫得了法律的制裁，但是在因果、天理之前，必定也要受報。<br />\n<br />\n<div style=\"text-align: center;\"><strong><span style=\"color: red;\"><span style=\"font-size: xx-large;\">汝欲和平，必先備戰<br />\n替天行道</span></span></strong></div>"},{"pid":"7dbdf14cdcbaeae80a4d5bd6795430398053ddea","tid":1568764,"uid":74155,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-14T16:43:38.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">你點影的</span></span>"},{"pid":"9d601aacef6d92573a2c01c3c93941cbeb6f3666","tid":1568764,"uid":43785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-14T17:24:05.000Z","msg":"<img src=\"/assets/faces/mf/frown.gif\" class=\"hkgmoji\" />"},{"pid":"0b27a456cdfa395eac00f7050137134ae20833ab","tid":1568764,"uid":264788,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-14T17:31:19.000Z","msg":"姐係唱願榮光歸香港你地好驚拉，會唱多啲架拉"},{"pid":"e03326d6f458eca441ba450903c91001afda7064","tid":1568764,"uid":222811,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-14T21:42:52.000Z","msg":"Good morning sir"},{"pid":"a29e7ac26507ed6beeac8cb332301c729b91cb1d","tid":1568764,"uid":309822,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-09-15T02:55:11.000Z","msg":"證明我地正確 連呀sir都出黎想轉風向分化和勇 我地真係做得好岩<img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/point2.gif\" class=\"hkgmoji\" />"},{"pid":"a5a7f5d183f20d1e0da70a2c6de66eac2e6b92a8","tid":1568764,"uid":43785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T04:09:26.000Z","msg":"<img src=\"/assets/faces/mf/bye.gif\" class=\"hkgmoji\" />"},{"pid":"b13ce0150cc85ead1e2536e16f5c26f94660532e","tid":1568764,"uid":53062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T04:10:39.000Z","msg":"你點影的"},{"pid":"481663343d532a4cee0268ad8d84ea8600f28da1","tid":1568764,"uid":51612,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-15T04:11:54.000Z","msg":"點解要將兩件事變成對立？"},{"pid":"bdd3d42a2cb2793c43ac4944bdbccf7ef3045df5","tid":1568764,"uid":43785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T07:46:22.000Z","msg":"推"},{"pid":"2b7fe671e3