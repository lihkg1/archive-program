mal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"4cbbbc077761533687bcecdca70930347b34c946","tid":2029851,"uid":300006,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-05-22T12:42:54.000Z","msg":"屌你老母，命仲掛住鬥黃<br />\n你老母個閪d汁最黃"},{"pid":"a42fe348965fa015209a241631e02f2342911026","tid":2029851,"uid":33508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-22T12:43:05.000Z","msg":"將來某一刻<br />\n守香港就會好似守poly咁<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"457004d71c5285fd1b459d6b70fef33cf9bd51c1","tid":2029851,"uid":306808,"like":0,"dislike":0,"score":0,"quote":{"pid":"e801eff289e748aade4ad998c165454f4fe0eb19","tid":2029851,"uid":47775,"like":28,"dislike":1,"score":27,"citedBy":1,"replyTime":"2020-05-22T12:32:22.000Z","msg":"呢個時候仲鬥乜撚野黃<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-22T12:43:19.000Z","msg":"咪係..."},{"pid":"91a5709f09a86a38ec86189e56fb0ab3609b03bf","tid":2029851,"uid":176282,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-05-22T12:43:40.000Z","msg":"講真，移民嘅一定唔係深藍"},{"pid":"97b0ad9027d246428ce30fed978dcf5f96322b4b","tid":2029851,"uid":255162,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-22T12:50:09.000Z","msg":"咁孫中山一定唔係愛國添"},{"pid":"ebd542a932451414539a203afeed9cd89fe29608","tid":2029851,"uid":206210,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-22T12:58:05.000Z","msg":"人地移民關你春事咩<br />\n你有無做好自己啊又<br />\n成日鬥黃<br />\n鬥你老母黃<br />\n見你個po就想升你幾巴<br />\n<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" />"},{"pid":"4b4dcfd2393f25c1b4b4af82a9909b358e1d6bfe","tid":2029851,"uid":304769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-22T13:01:41.000Z","msg":"<strong><span style=\"font-size: x-large;\">借個位：黑色五毛風向警告，大量五毛正在吹襲連登</span></strong><br />\n正視聽，<span style=\"color: red;\">國安法唔係攬炒，美國做野先係</span><br />\n<br />\n大家<span style=\"color: red;\">唔好比五毛帶風向去支持國安法，否則會比對家spin成香港人支持國安法</span>。只有<span style=\"color: red;\">香港人強烈反對下強行通過，美國才有做野的理由</span>。大家小心。<br />\n<br />\n借個位<br />\n連登一向錯曬風向，<span style=\"color: red;\">英國點日落都好，香港問題上都係重要持分者</span>，必須engage。<br />\n我地唔係要拉攏政府班奶共狗（例如Dominic Rabb），而係要<span style=\"color: red;\">拉攏英國民意</span>啊。英國係民主國家，民意最重要。英國民意決定stand with Hong Kong/Boycott China，BJ以至成個政府都無得唔跟。<span style=\"color: red;\">宜家武肺英國死左就三萬幾人，正是推動報仇民意好機會</span>。<br />\n<br />\n另外要借助美國向英國施壓，因為<span style=\"color: red;\">美國有動機（報武肺之仇）同拳頭，加英國有理由（聯合聲明），兩個加埋先容易嚮香港問題做野</span>"},{"pid":"35c1035eacd6c7d9eb3766fb26d3cc0fd92d7cae","tid":2029851,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T05:40:17.000Z","msg":"有得走好走"},{"pid":"1af1bba072ead75bba356edf23378f586e3ae3f9","tid":2029851,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T05:44:11.000Z","msg":"移咗民既香港人：<br />\n<br />\n<img src=\"https://i.postimg.cc/zfq232d3/CRYBABY-JPG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.postimg.cc%2Fzfq232d3%2FCRYBABY-JPG.jpg&h=1bfe6715&s={SIZE}\" />"},{"pid":"0aa2560dcc1f5c5ce83c917b3da7dfcada356ef2","tid":2029851,"uid":126382,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-23T05:47:41.000Z","msg":"成班垃圾，個個就想走就包裝移民依種卑微下流懦夫既行為<br />\n依家前線係香港，你退一步都係仆街，何況移民?<br />\n你地懦夫多所以評分一定多，<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">但道理上你地講唔通唔係懦夫同拋棄同胞</span></span></strong>"},{"pid":"b7f3aac7d4de0338166f06ee8fcbcd6fe4917f4e","tid":2029851,"uid":120123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T05:48:33.000Z","msg":"我走唔到，但有得走我都想走"},{"pid":"661f834c378b43e0cbe1389d173f4f4fdd1598ae","tid":2029851,"uid":1159,"like":0,"dislike":0,"score":0,"quote":{"pid":"91a5709f09a86a38ec86189e56fb0ab3609b03bf","ti