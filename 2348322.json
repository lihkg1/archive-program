4802757e4ad8dd5664f0f0437","tid":2348322,"uid":170395,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:17:32.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"ea69227a006fbc388e5bb4ef5e8659653271b8e2","tid":2348322,"uid":170395,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:17:43.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"c1f866033becea4d9dc724a7eb68670b12c81019","tid":2348322,"uid":35054,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:19:20.000Z","msg":"<img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/knife.gif\" class=\"hkgmoji\" />"},{"pid":"e369f6b4e10f4f139aef1a72e199512f9b4160bc","tid":2348322,"uid":284860,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:20:51.000Z","msg":"<img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" />"},{"pid":"09e7ac5a94c623d45030e45a4b38f811aa44f5c5","tid":2348322,"uid":51754,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-01-01T17:21:17.000Z","msg":"個地圖好唔user friendly<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />好多舊紅點搞到好難睇真係近期既個案<br />\n不過都好多謝樓主同其他手足咁用心整呢個網<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n因為呢個網都幫咗我好多<br />\n<br />\n[求推] 衞生署 強制檢測名單 又双叒叕有錯？<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/2349363\" data-auto-link target=\"_blank\">https://lih.kg/2349363</a>"},{"pid":"bb8be27c52da07df99abb524f70dbea1e017e899","tid":2348322,"uid":17430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T17:46:05.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"93068ba40369a43a0b438b35ee3ec56532121fe6","tid":2348322,"uid":34213,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T18:19:44.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"45f69aff47c04c183679a434973b406b207507f2","tid":2348322,"uid":78695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T18:23:34.000Z","msg":"push<br />\n個網真係好清楚易明<br />\n衷心多謝你哋咁多位付出<img src=\"/assets/faces/xm/adore.gif\" class=\"hkgmoji\" />"},{"pid":"667f7c3f5fd10037c1d7c372b14b34b69a7ae75b","tid":2348322,"uid":26752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T18:23:59.000Z","msg":"<img src=\"/assets/faces/xm/oh.gif\" class=\"hkgmoji\" />"},{"pid":"4e8b7afa9318405728a98617b1a6b9400f3d676f","tid":2348322,"uid":55658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-01T18:27:55.000Z","msg":"推"},{"pid":"2436397312c0926ff913dd0675e7bf3c2855923e","tid":2348322,"uid":329597,"like":0,"dislike":0,"score":0,"quote":{"pid":"09e7ac5a94c623d45030e45a4b38f811aa44f5c5","tid":2348322,"uid":51754,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-01-01T17:21:17.000Z","msg":"個地圖好唔user friendly<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />好多舊紅點搞到好難睇真係近期既個案<br />\n不過都好多謝樓主同其他手足咁用心整呢個網<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n因為呢個網都幫咗我好多<br />\n<br />\n[求推] 衞生署 強制檢測名單 又双叒叕有錯？<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/2349363\" data-auto-link target=\"_blank\">https://lih.kg/2349363</a>"},"citedBy":1,"replyTime":"2021-01-02T08:52:58.000Z","msg":"Hello 你好啊，<br />\n<br />\n可以的話，歡迎俾意見我地吖！因爲我地仲頭痛緊點 revamp 幅地圖，例如分成 18 區，每區 click 落去應該 show 咩資料；又如果我地用 2019 區議會選區黎劃分細區 (zoom in 先分區，zoom out 會 show 返 18 區)，大家