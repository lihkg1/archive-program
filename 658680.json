load/2018/05/09/143721_f3ec458dbaf3c1208a8832dd8e15bd44.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F09%2F143721_f3ec458dbaf3c1208a8832dd8e15bd44.png&h=b127aa64&s={SIZE}\" />"},{"pid":"7dc86844b737797c28f5c22e73d989cff8f1fcad","tid":658680,"uid":182499,"like":17,"dislike":1,"score":16,"citedBy":0,"replyTime":"2018-05-09T07:49:17.000Z","msg":"呢條咁嘅星之子 宜家進化到寄語青年<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"8ff7ce2cd5f6042dd9c116a51fb5a308fca989cd","tid":658680,"uid":90863,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-09T07:50:16.000Z","msg":"十二少<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"6e3bb564d324ae7836f9d80338b1be376e7f2fa2","tid":658680,"uid":124277,"like":5,"dislike":10,"score":-5,"citedBy":0,"replyTime":"2018-05-09T07:50:36.000Z","msg":"字字誅機<br />\n90 後00 後班垃圾學到3 份1 都偷笑<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"c7ffee8c17899d5a0a296975f01382f72e2aa837","tid":658680,"uid":133354,"like":40,"dislike":1,"score":39,"citedBy":0,"replyTime":"2018-05-09T07:52:13.000Z","msg":"自己死好命，會考英文唔合格碌入大學，同人分享心得，真係好嘔心<br />\n<br />\n事後都唔少中學生有得命名星星，只係佢食頭啖湯，死好命<br />\n<br />\nd所謂發明，咩盲人飲水杯，其實有其他人一早發明咗，但傳媒又吹奏<br />\n<br />\n佢其實只係夠運，咁啱嗰時社會上好似無乜科研出色的新聞，d 人先一齊吹捧，好心就低調d啦，學好英文，唔好自視過高。"},{"pid":"622d1201177d36d660849c3beaa00e1759136d0d","tid":658680,"uid":46911,"like":20,"dislike":0,"score":20,"citedBy":2,"replyTime":"2018-05-09T07:52:19.000Z","msg":"2006年8月9日，香港中學會考放榜，當時陳易希不在香港而未向外界揭曉成績。後來，網上不時傳出流言陳易希的成績僅為3分。直到8月21日，陳易希參與一個公開活動時證實自己會考有12分，中國語文科及英國語文科（課程甲）等第為U（即不予評級），電腦與資訊科技科E級，數學D級，化學D級，物理C級，圖像傳意B級。升讀中六必須在中國語文科及英國語文科（課程甲或乙）取得及格成績，故此在一般情況下，陳易希幾乎沒有可能升讀。<br />\n<br />\n<br />\n<br />\n你自己有幾勤力啊<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"372f1e