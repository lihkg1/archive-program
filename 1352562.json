"https://na.cx/i/67aycf2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F67aycf2.jpg&h=98790fe1&s={SIZE}\" />"},{"pid":"213e3586262496eddee59a356fa74b855d44fe75","tid":1352562,"uid":142904,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T17:55:05.000Z","msg":"推"},{"pid":"951e69cf16d6314b3637985a3f37634bb2a949c1","tid":1352562,"uid":12558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T18:11:20.000Z","msg":"Pish"},{"pid":"47c927dd86aaa5ef714035f984cd9e343ee45d05","tid":1352562,"uid":12558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T22:58:51.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"62f815183d78027d0bb4a8f614737fd5c3f351da","tid":1352562,"uid":43204,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T06:27:34.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"686c599be0ef4b8fafd030683a8521a66ad02a83","tid":1352562,"uid":43204,"like":0,"dislike":0,"score":0,"quote":{"pid":"47c927dd86aaa5ef714035f984cd9e343ee45d05","tid":1352562,"uid":12558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T22:58:51.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-25T06:32:10.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"7dea2d06ab428b48a6c55d62a5dc8bd084c8a65c","tid":1352562,"uid":108201,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T07:42:02.000Z","msg":"Push <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"a7a08698c066c1633137d510d7d8e1d08f731b13","tid":1352562,"uid":164043,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T10:55:51.000Z","msg":"大道至簡。"},{"pid":"c42871debf91d7e1ab1a06472cbe9b7f885b7c44","tid":1352562,"uid":43204,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T14:59:58.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f0b395786a85e8c1d21798d0d4badf25bfa795f9","tid":1352562,"uid":32204,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T15:03:31.000Z","msg":"點樣做到 <br />\n<a href=\"https://www.youtube.com/watch?v=zfNKZRPQHZk&amp;feature=youtu.be\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DzfNKZRPQHZk%26feature%3Dyoutu.be&d=4HHrVRRB2qdXUamIokVXjSrXKCTJ71YGEIw5q99tfRY%3D&h=79b92181\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=zfNKZRPQHZk&amp;feature=youtu.be</a><br />\n721 宣言英文版個位義士咁<br />\n個眼罩唔透又睇到野<br />\n同埋佢下巴點包"}]}