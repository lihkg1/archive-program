ages.arcpublishing.com%2Fappledaily%2FKZ743U3RGJA7VHK5Z4SBMBGR4Q.jpg&h=10d16a21&s={SIZE}\" />"},{"pid":"642523dd9aba3f0c34d9c5c38afef8f772d5bb08","tid":2257523,"uid":1886,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-10-25T08:30:50.000Z","msg":"目前要分清山寨機不難，先達店主阿然估計，未必有不法之徒會在香港賣山寨 iPhone 12，但擁有這些技術的人，日後會怎樣做就不得而知了，可能會再改良，推出更像真的假機也說不定。除了整台電話都是假的明顯騙案，阿然也教大家一些買二手機也有要留意的地方。<br />\n<br />\n例如 iPhone 8 以後的型號有一個原色調（True Tone）功能，平時只要從右上角拉下叫出「控制中心」，再長按「亮度調整」就能在右下角開關「原色調」。原來這功能需要接上原廠 iPhone 顯示屏幕才用到，非原廠的第三方屏幕仍未破解到。如果見到「原色調」不翼而飛，就代表這部 iPhone 已換上非原廠芒，或者更換過原廠屏幕但維修師傅在接駁上做漏了工夫。<br />\n<br />\n<p class=\"center\"><img src=\"https://cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/KQL2FGYL25BVBKKUNU3ZX5AAQY.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FKQL2FGYL25BVBKKUNU3ZX5AAQY.jpg&h=7d83f31e&s={SIZE}\" /><br />\n<span class=\"small\">iPhone 8 以後的型號如果用了非原廠屏幕，這裏的「原色調」會不見了。</span></p><br />\n<br />\n<a href=\"https://hk.appledaily.com/lifestyle/20201022/NJEWPTKRBBABTMVYHRK7E3EAEU/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flifestyle%2F20201022%2FNJEWPTKRBBABTMVYHRK7E3EAEU%2F&d=FHegwWfkEdb3mv0CWz72PSKjAP3shAOQj%2BHHIi00eAs%3D&h=058646f6\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flifestyle%2F20201022%2FNJEWPTKRBBABTMVYHRK7E3EAEU%2F&h=3f1daf40\" target=\"_blank\">https://hk.appledaily.com/lifestyle/20201022/NJEWPTKRBBABTMVYHRK7E3EAEU/</a>"},{"pid":"64bed9de5bd77a8f77b1954d799576cac6db4de2","tid":2257523,"uid":48286,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2020-10-25T08:33:30.000Z","msg":"簡寫傷眼<br />\n<br />\n<br />\n<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"52ec2d0bc155b2c47a106ddd2ce3cc3b63745d56","tid":2257523,"uid":120499,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-10-25T08:35:41.000Z","msg":"咁樣以後先達更加冇人會去<img src=\"/assets/faces/normal/sos