rc=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fdyy8wqz.jpg&h=18391795&s={SIZE}\" />"},{"pid":"f5f8bd480ee02dede538ee3dca7e7a58592d7ff4","tid":1269642,"uid":215715,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-30T15:42:03.000Z","msg":"你唔撚升旗都係當你搞革命架啦<br />\n咪撚咁天真<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ca155e15da0877bc152fc3f79b1576aa00f4104d","tid":1269642,"uid":28459,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-30T15:43:20.000Z","msg":"收皮啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"eabc6e6a078475c8ba0b87d60887452cae764921","tid":1269642,"uid":9214,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-06-30T15:47:42.000Z","msg":"游蕙禎 Yau Wai Ching<br />\n2小時 &middot;<br />\n<br />\n據聞有組織欲於明日行升黑旗禮。<br />\n黑旗代表無政府主義，而無政府主義必須是全面推翻政府，亦將廢除所有現行制度、貨幣等，等同發動政變。部份國家會視之為恐怖主義，亦為部份伊斯蘭組織所採用，並將之為發動聖戰的標誌。<br />\n這是political symbolism。在此勸告各位若要參與，務必三思，及明白黑旗的意義，才決定是否參加。"}]}