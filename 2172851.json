ke":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-08-25T01:48:21.000Z","msg":"<img src=\"https://na.cx/i/maCU5xq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmaCU5xq.jpg&h=56b3e5a8&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-08-25T07:02:40.000Z","msg":"即係7000000做哂會有350000被中招<br />\n好危險呀，封關呀，香港人唔俾走呀<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"20569460f874f829c92df9c183ce82d143fb0644","tid":2172851,"uid":57073,"like":0,"dislike":0,"score":0,"quote":{"pid":"d00649783678c227c842f339b559c71d12116af6","tid":2172851,"uid":61577,"like":0,"dislike":0,"score":0,"quote":{"pid":"244946f6396c85f3a0594417e32b11f26efdbc2f","tid":2172851,"uid":57073,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-08-25T01:48:21.000Z","msg":"<img src=\"https://na.cx/i/maCU5xq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmaCU5xq.jpg&h=56b3e5a8&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-08-25T07:02:40.000Z","msg":"即係7000000做哂會有350000被中招<br />\n好危險呀，封關呀，香港人唔俾走呀<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-25T11:29:00.000Z","msg":"250000個肝<br />\n500000個腎"},{"pid":"9e66c351c51f9ca24595df6caa849e6d8c5a4c98","tid":2172851,"uid":254183,"like":0,"dislike":0,"score":0,"quote":{"pid":"9f82d9e8843558670912f7484af4dd41b6704fe4","tid":2172851,"uid":293921,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-25T01:54:01.000Z","msg":"假陽性既全部都捉入去隔離？"},"citedBy":0,"replyTime":"2020-08-25T11:39:33.000Z","msg":"做第二次檢測確定係假陽性前，你只能當佢係陽性處理<br />\n唔隔離要點做?"}]}