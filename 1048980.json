下降至約18度，預料未來數天間中有驟雨及雷暴，明日及星期五天氣稍涼，風勢頗大。<br />\n<br />\n無啦啦勁大雨"},{"pid":"6058c08d4e7e1a4837e79687e4b642289eb3c4f3","tid":1048980,"uid":196924,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-06T03:33:27.000Z","msg":"早上10時45分發出特別天氣警告<br />\n...即係佢發出嗰陣已經落緊雨"},{"pid":"4f68dfe21e8881e56a3b61314d3e275285f39b64","tid":1048980,"uid":108756,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-06T03:34:19.000Z","msg":"係keep 住落先好呀"},{"pid":"5002bbfdf5a1a33fcf3c06e47b87607e54ba4aa7","tid":1048980,"uid":90089,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-06T03:34:41.000Z","msg":"冇咩雨啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"550125d3360f7ca88e095a31447b446737d6133b","tid":1048980,"uid":120427,"like":0,"dislike":0,"score":0,"quote":{"pid":"5002bbfdf5a1a33fcf3c06e47b87607e54ba4aa7","tid":1048980,"uid":90089,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-06T03:34:41.000Z","msg":"冇咩雨啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-06T03:37:02.000Z","msg":"好撚大雨"},{"pid":"1cc35e5524eedb89ebd1c872eb8b72c0a1cb31f3","tid":1048980,"uid":71748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-06T03:37:10.000Z","msg":"濕撚晒<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"deac0805611d13c4c471931df1f78d089a606f9a","tid":1048980,"uid":25952,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-06T03:41:36.000Z","msg":"唔好再遲啲先講<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5b6819ba9b9f6d7de72dd82f3f4bfa91ce66699c","tid":1048980,"uid":145408,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-03-06T03:43:33.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2019/03/06/114329_09ca491c26a89770374d06dc98eb185d.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F03%2F06%2F114329_09ca491c26a89770374d06dc98eb