":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-10T13:11:55.000Z","msg":"Push"},{"pid":"c7ee80e5b73f07c039c47259db1a81eb3251018f","tid":2236950,"uid":52946,"like":0,"dislike":0,"score":0,"quote":{"pid":"8de4d7ed9ed9a485b3244db7d414a500ff823c15","tid":2236950,"uid":19847,"like":1,"dislike":1,"score":0,"quote":{"pid":"00fac65e0ffc5ecc741aeb15e2597895a9d52e7b","tid":2236950,"uid":284432,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2020-10-10T02:51:56.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2020-10-10T03:04:01.000Z","msg":"得東網有直網"},"citedBy":0,"replyTime":"2020-10-10T13:17:31.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"06346eff0e5a771687a5381e406be3bd3f000b76","tid":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-10T17:45:25.000Z","msg":"Push"},{"pid":"c2f70751893dcfce3c5ce14c8d902eae05a96d22","tid":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T00:17:32.000Z","msg":"Push"},{"pid":"9988a3176adf4387630c70f4a1793eb4b1c5241f","tid":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T02:27:04.000Z","msg":"<img src=\"https://media.giphy.com/media/Y4sMzxmIYLT82YFlsk/giphy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2FY4sMzxmIYLT82YFlsk%2Fgiphy.gif&h=49a5bc6e&s={SIZE}\" /><br />\n<img src=\"https://media.giphy.com/media/AEO5EH9WJI8RAxwul0/giphy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2FAEO5EH9WJI8RAxwul0%2Fgiphy.gif&h=d73a04cf&s={SIZE}\" /><br />\n<img src=\"https://media.giphy.com/media/dJ44Az6j758ooXlvId/giphy-downsized-large.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2FdJ44Az6j758ooXlvId%2Fgiphy-downsized-large.gif&h=9b5cb767&s={SIZE}\" /><br />\n<img src=\"https://media.giphy.com/media/LoNSOSUeOgtihiVr2o/giphy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2FLoNSOSUeOgtihiVr2o%2Fgiphy.gif&h=33f3a6e6&s={SIZE}\" />"},{"pid":"d8f9fbe9ef9e9c93136dfcf52c16544ab04c28b7","tid":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T03:01:57.000Z","msg":"<strong>修例風波疫情「夾擊」 港超幾近腰斬</strong><br />\n<br />\n今季港超可謂多災多難，上半季先因反修例風波，令部分賽事延期，踏入2020年再受疫情打擊，<span class=\"red\">由閉門比賽到封場，球季有接近半年「真空期」，賽程連番押後甚至面臨腰斬，10支港超隊最終只餘6隊復賽。</span><br />\n<br />\n僅6隊踢復賽 社區盃復戰無期<br />\n今季港超以「Breakthrough」為主題，寓意積極面對新挑戰，更多球迷見證香港足球突破，<span class=\"red\">但這「新挑戰」來得甚艱巨。去年9月底至11月，香港社會事件影響球場附近交通，多輪各級聯賽均延期，季初的社區盃更復賽無期。</span><br />\n<br />\n新冠病毒疫情其後全球大流行，港超在今年2及3月只能閉門舉行菁英盃及足總盃等，<span class=\"red\">但第三波疫情爆發下再次封場，令球季自3月底起停擺半年。飛馬、流浪、元朗及大埔4隊棄戰復賽，大埔更陷欠薪風波及退出亞協盃。</span><br />\n<br />\n港超直至9月中復賽，<span class=\"red\">新球員能否註冊參賽惹爭議，兩名富力教練團成員又被揭違反家居隔離指引</span>，但23天內閉門舉行的17仗，今天總算走到終點。<br />\nFrom: 明報"},{"pid":"97749c6a28816b04e8f3f11a63c216837ddcf670","tid":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T04:04:48.000Z","msg":"#港超煞科 | 三場同步 | 下午三點<br />\n<img src=\"https://na.cx/i/cd6ETpu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fcd6ETpu.jpg&h=93aff2b8&s={SIZE}\" /><br />\nFrom: 港超聯fb"},{"pid":"3f45888d9fd1d992f2a92afb756347a9a9b81d3e","tid":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T04:41:21.000Z","msg":"<img src=\"https://na.cx/i/VXGNbzs.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVXGNbzs.jpg&h=8b7bb70c&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/QD1pxsg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQD1pxsg.jpg&h=15bede48&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/RV3jTBz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRV3jTBz.jpg&h=9673f9e7&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/CiR8ZeC.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCiR8ZeC.jpg&h=bc39cfea&s={SIZE}\" />"},{"pid":"885812d77f35cf14598f77683019c11a81b4bd3d","tid":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T05:13:41.000Z","msg":"Push"},{"pid":"0997908cc4a0bec6f82030b8c20fc72cf4909e07","tid":2236950,"uid":7439,"like":0,"dislike":0,"score":0,"quote":{"pid":"1e2b30d15550f8cc9f057622f26374f81e900ab8","tid":2236950,"uid":133873,"like":0,"dislike":0,"score":0,"quote":{"pid":"d172e0c13afff0923e72fc516b821713bfc1c83e","tid":2236950,"uid":7439,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-10-10T03:06:06.000Z","msg":"藍絲搞波不了<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-10T04:17:00.000Z","msg":"香港有邊隊波唔係藍/紅老細<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-11T05:44:04.000Z","msg":"入cc台隨俗"},{"pid":"7b00226eb219e3a5186233bc6972100c3b340e09","tid":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"quote":{"pid":"0997908cc4a0bec6f82030b8c20fc72cf4909e07","tid":2236950,"uid":7439,"like":0,"dislike":0,"score":0,"quote":{"pid":"1e2b30d15550f8cc9f057622f26374f81e900ab8","tid":2236950,"uid":133873,"like":0,"dislike":0,"score":0,"quote":{"pid":"d172e0c13afff0923e72fc516b821713bfc1c83e","tid":2236950,"uid":7439,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-10-10T03:06:06.000Z","msg":"藍絲搞波不了<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-10T04:17:00.000Z","msg":"香港有邊隊波唔係藍/紅老細<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-11T05:44:04.000Z","msg":"入cc台隨俗"},"citedBy":0,"replyTime":"2020-10-11T05:46:14.000Z","msg":"<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"ccf891773639555fa29c07209c7858348e7838e8","tid":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T06:36:16.000Z","msg":"Push"}],"pinned":{"pid":"a7ebf084c64aa4aa7c71bec3c749e654fed3a53f","tid":2236950,"uid":19847,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T14:53:44.000Z","msg":"歷時13個幾月嘅2019至2010年度「中銀人壽香港超級聯賽」，終於喺10月11日(日)圓滿結朿，恭喜傑志同東方龍獅各捧兩盃，齊齊榮膺「雙冠王」！<br />\n<br />\n今個球季經過唔少賽事取消同延期，先後3次「閉門作賽」，聯賽最終由10隊爭變成得番6隊踢<span class=\"red\">，兩支區隊停擺期間順勢退出埋，有球員面對欠薪同失業，亦有個別為咗生計，喺無波練、無比賽期間去做各式各樣嘅兼職</span>，突然之間成個球圈，出現咗一個又一個嘅未知數。<br />\n<br />\n足球，喺好多朋友眼中，可能只係一門消閒娛樂：「人命關天呀！仲踢波！」但對於咁多隊波嘅職、球員嚟講，<span class=\"red\">足球係佢哋嘅工作，靠份收入嚟養家、供車供樓、對子女供書教學。感謝為復賽付出過，流過唔少血汗同眼淚嘅每一位</span>，特別係足總競賽部同宣傳部嘅手足、6隊嘅班主、管理層同職、球員、傳媒行家同埋直播嘅團隊；仲有喺電腦、手機面前嘅觀眾，<span class=\"red\">同埋爬晒山喺樹叢或者高束公路旁邊離完為愛隊打氣嘅球迷（仲有喺天國嘅你）</span>，多謝妳、你同您哋，等復賽可以順利舉行同完成。<br />\n<br />\n好快新一個球季又會開始喇，希望大家可以多啲關注呢個屬於我哋香港人嘅聯賽，多啲支持你認為值得支持嘅球隊同球員，感謝。<br />\nFrom: 我撐本地波"}}