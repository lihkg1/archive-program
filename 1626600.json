uote":{"pid":"6a167c84258a6ec0ace13c8503f1d3d8cabdf29f","tid":1626600,"uid":138609,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-05T13:30:43.000Z","msg":"港共封鐵關商場更好<br />\n幫手罷工<br />\n歷史證明<br />\n經濟越差反政府既人只會越多"},"citedBy":0,"replyTime":"2019-10-05T13:34:34.000Z","msg":"係，其實我覺得佢又形勢錯判<br />\n不過我地呢邊都要做好D"},{"pid":"58af891a74611b4e4aa1bcd3bc18d0f303e36e8c","tid":1626600,"uid":277702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:35:28.000Z","msg":"聽日call行和理非出嚟"},{"pid":"4d47203fe60464786aa231f64b3d5b4933471ba4","tid":1626600,"uid":222323,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:36:55.000Z","msg":"見到另一個po講類似野 比人屌到仆街<br />\n<br />\nBtw 支持"},{"pid":"5a5940ab00e684d6495c9f75fdec3f5ae5d3d7c9","tid":1626600,"uid":258522,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:49:44.000Z","msg":"推"},{"pid":"dad94820fb9a94e11a7187b94342ac3466da40c8","tid":1626600,"uid":289252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:50:00.000Z","msg":"推<br />\n光復香港<br />\n時代革命"},{"pid":"5b0e6b7dcccb016401a950f8b75247dc58ea68dc","tid":1626600,"uid":289156,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:57:11.000Z","msg":"612 ，721 831 101<br />\n光復香港<br />\n時代革命<br />\nPish"},{"pid":"fa46c2417f3ca315f8f443b886fe4c86ba2f4b44","tid":1626600,"uid":258522,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T14:00:07.000Z","msg":"<img src=\"https://scontent-hkg3-1.xx.fbcdn.net/v/t1.0-9/72693210_134152917929156_3922139176652242944_o.jpg?_nc_cat=105&amp;_nc_oc=AQl5KoozKctdaoGtK-Me7h1uXy7TMnDYYMAAA5Lpnf5HbjZzxsyVfxUZoN-XrKHi1es&amp;_nc_ht=scontent-hkg3-1.xx&amp;oh=8dc73360e2cca05aa05169a8e5cba643&amp;oe=5E1FE8FA\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkg3-1.xx.fbcdn.net%2Fv%2Ft1.0-9%2F72693210_134152917929156_3922139176652242944_o.jpg%3F_nc_cat%3D105%26_nc_oc%3DAQl5KoozKctdaoGtK-Me7h1uXy7TMnDYYMAAA5Lpnf5HbjZzxsyVfxUZoN-XrKHi