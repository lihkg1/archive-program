在本年6月至8月期間，共接獲37宗空調溫度投訴，其中除了冷氣巴及商場外，法庭、酒店會議廳、私家醫院等，而港鐵東涌線更是接獲最多投訴的地方之一。據了解，某些地方的空調溫度較低，是因為該處的通風系統並不完善，為避免遭人投訴悶熱，有關方面只好把空調調低，以減少空氣不流通而做成悶焗，亦有商場因員工的制服過厚，需要調低氣溫以作配合。<br />\n<br />\n環保撚<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"6a8dc171bfd07c58365c24464e6083b7f83f0472","tid":973751,"uid":130698,"like":1,"dislike":0,"score":1,"quote":{"pid":"0e8c6a42e1225ba885912411f71906e89aa430e6","tid":973751,"uid":35014,"like":179,"dislike":2,"score":177,"citedBy":2,"replyTime":"2019-01-08T11:54:29.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-01-08T15:21:30.000Z","msg":"唔係通風問題<br />\n係太多人啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f325b20836e074f222cec96d1da2523e739ba461","tid":973751,"uid":24210,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-08T15:22:22.000Z","msg":"此回覆已被刪除"},{"pid":"a2b511eda05e4017a5c243a453c9e8638f7c6989","tid":973751,"uid":75072,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-08T15:24:42.000Z","msg":"環保撚落地獄"},{"pid":"f92d3b6aaf1a6ae6c7f822a06bd647fe89256f61","tid":973751,"uid":63154,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-08T15:25:19.000Z","msg":"成個站冇氧氣咁滯，自己帶氧氣筒啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"56b0088851caaca8ea15e9758dc98938ec3b0d4d","tid":973751,"uid":16404,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-01-08T15:27:10.000Z","msg":"點解港鐵真係唔撚理<br />\n金鍾真係焗到仆街"},{"pid":"dbc8a5125493b1f56f0837baf7da71a2c7ccfd51","tid":973751,"uid":75072,"like":0,"dislike":0,"score":0,"quote":{"pid":"f92d3b6aaf1a6ae6c7f822a06bd647fe89256f61","tid":973751,"uid":63154,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-08T15:25:19.000Z","msg":"成個站冇氧氣咁滯，自己帶氧氣筒啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-08T15:27:27.000Z","msg":"氧氣樽係危險品<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"962fb10cdd0da6abd11a1448e39168a9