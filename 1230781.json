ets/faces/lomoji/23.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},{"pid":"357497337931a671c62c572192e8da85c62e03e2","tid":1230781,"uid":259321,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2019-06-16T10:22:46.000Z","msg":"我地要返去多謝佢地! &rarr;&rarr;&rarr;&rarr;&rarr;<br />\n<br />\n【大阪G20峰會】有志文宣嘅宜家即刻同我買6月28日機票!!!<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1229803\" data-auto-link target=\"_blank\">https://lih.kg/1229803</a>"},{"pid":"dc07496cca011e31fc53dd1b3940e0fc198da5a6","tid":1230781,"uid":208239,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-16T10:23:11.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"3369cb06e012065537c3853cbae5d8ca8534d637","tid":1230781,"uid":201374,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-16T10:23:32.000Z","msg":"今日嘅速度，行晒嘅話未必趕到夜晚機<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"124010f69d39c5f51d43d1c73a36c69578fad32f","tid":1230781,"uid":256952,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-16T10:24:04.000Z","msg":"Push"},{"pid":"fc7623dfec4867792cf48a8940acaea71e15097e","tid":1230781,"uid":259321,"like":44,"dislike":1,"score":43,"citedBy":0,"replyTime":"2019-06-16T10:24:04.000Z","msg":"<img src=\"https://na.cx/i/EfmPAXx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEfmPAXx.jpg&h=37b69dd0&s={SIZE}\" /><br />\n<br />\n<br />\n<a href=\"https://mainichi.jp/articles/20190615/k00/00m/030/302000c\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmainichi.jp%2Farticles%2F20190615%2Fk00%2F00m%2F030%2F302000c&d=p84ZIGfbRlzA5dgw%2Bb26WEYnXQRGGZgEWtwyrMN1cgk%3D&h=9350369b\" target=\"_blank\">https://mainichi.jp/articles/20190615/k00/00m/030/302000c</a><br />\n<br />\n日本自6月12日<br />\n每日媒體都十分關注香港情況<br />\n當日嘅NHK晚上9點鐘新聞就以頭條播出香港政府血腥鎮壓遊行示威<br />\n<br />\n宜家暫緩<br />\n下一個觀望點就係大阪G20峰會<br />\n中美deal唔deal, 用乜嚟deal<br />\n好有可能<br />\n香港嘅未來就係被人用左嚟做交易<br />\n我地香港人係必須去到大阪G20峰會現場<br />\n申示香港人寧死不屈<br />\n都要保衛香港憲法嘅決心!!!<br />\n<br />\n【大阪G20峰會】有志文宣嘅宜家即刻同我買6月28日機票!!!<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1229803\" data-auto-link target=\"_blank\">https://lih.kg/1229803</a>"},{"pid":"032de81317e9db47725570aa84961208ebd5d2fe","tid":1230781,"uid":68220,"like":2,"dislike":2,"score":0,"citedBy":0,"replyTime":"2019-06-16T10:24:27.000Z","msg":"如果啲狗打佢 我一定衝出黎擋"},{"pid":"efcaca480eb17a98a1b7c795c06eb80103ba59da","tid":1230781,"uid":31285,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-16T10:24:40.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"3fe407b0fb3d582c6a83c911a2098c80c157a710","tid":1230781,"uid":259321,"like":18,"dislike":1,"score":17,"citedBy":0,"replyTime":"2019-06-16T10:24:59.000Z","msg":"<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><br />\n<br />\n的而亦確<br />\n今次香港憲法保衛戰呢壇野<br />\n國際輿論支持嘅規模係空前絕後<br />\n雖然香港好唔好彩成為左貿易戰籌碼<br />\n無奈地已經俾人擺左上台<br />\n正正都因為咁<br />\n宜家開始所有同香港存亡有關嘅國際場合<br />\n『吓？俾中共同美帝傾香港嘅嘢？』<br />\n我地香港人絕對有份!<br />\n『宜家兩條謀利傾我地屋企嘢喎。』<br />\n香港人絕不能任人宰割!<br />\n<br />\n6月28日大阪G20峰會<br />\n貿易戰兩大對家同各國元首都會在場<br />\n之前亦有在日港人出post<br />\n聚集香港人6月28大阪G20峰會 do something<br />\ndo 乜野我一條友唔係好知<br />\n但香港絕對會係今次G20一個亮點中嘅亮點<br />\n去到大阪俾全球記者取材<br />\n俾全世界睇到香港人係幾咁團結保衞香港憲法<br />\n一定make 到noise<br />\n你張機票一定值回票價!<br />\n<br />\n經濟鬆動而且攞到假嘅<br />\n宜家同我立即買6月28日大阪機票!!!<br />\nWE WILL DO SOMETHING IN OSAKA,<br />\nTHE PEOPLE OF HONG KONG!!!<br />\n<br />\n【大阪G20峰會】有志文宣嘅宜家即刻同我買6月28日機票!!!<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1229803\" data-auto-link target=\"_blank\">https://lih.kg/1229803</a>"},{"pid":"3435656d04838eb179942bc29511356deaaa4ad9","tid":1230781,"uid":174566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T10:25:35.000Z","msg":"<img src=\"/assets/faces/fs/angel