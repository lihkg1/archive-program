gmoji\" />"},{"pid":"384947b2ac6801bbaa4db47d37650a1e25b1f4fb","tid":1890082,"uid":3149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-21T03:52:20.000Z","msg":"Push <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ed3c6cb35658ed6c654d6df6fc2afb6febbea2e2","tid":1890082,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-21T03:54:09.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"ad553a34f5130e06fcda263b5682a70c4d00250d","tid":1890082,"uid":284450,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-21T03:56:00.000Z","msg":"爽哥又要不爽了"},{"pid":"4916a5d5f028daad5a389e2a37f0ac17c150c8dd","tid":1890082,"uid":14494,"like":0,"dislike":0,"score":0,"quote":{"pid":"3abf890a5eb236de88d1361794d8c667fd6a5a09","tid":1890082,"uid":39258,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-02-21T03:32:46.000Z","msg":"口交部去咗邊"},"citedBy":0,"replyTime":"2020-02-21T04:05:52.000Z","msg":"病毒是「生化武器」？ 耿爽不爽：居心不良、荒謬無知<br />\n<a href=\"https://lih.kg/1888538\" data-auto-link target=\"_blank\">https://lih.kg/1888538</a><br />\n- 分享自 LIHKG 討論區"}]}