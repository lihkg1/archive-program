\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"084f6bb13685bad93eeb59e779eccd0889c067ca","tid":2318933,"uid":305767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-09T18:12:59.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"b011ef98c08f9ac0985227147d3b153f70e58bbc","tid":2318933,"uid":281418,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-09T18:13:42.000Z","msg":"<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" />"}]}