normal/biggrin.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-06T10:46:33.000Z","msg":"啲朋友成日話我無鬼聊，終於搵到同道中人"},"citedBy":0,"replyTime":"2018-05-06T12:52:39.000Z","msg":"因為我通常Backpack多，買唔到大件野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"133a296632eac25d4f2ea7d8b685c74c72fdbb4d","tid":654962,"uid":40849,"like":0,"dislike":0,"score":0,"quote":{"pid":"e1bef610da8e7fddc167c296944ae2362411b79f","tid":654962,"uid":47470,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-05-06T12:25:07.000Z","msg":"好難紀念每一次<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\npostcard比自己但目前已經有3個國家寄失<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n有諗過Starbucks杯但唔係每個國家都有<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n有d後悔既係冇買磁石，下次先開始買又好似唔統一咁<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-05-06T13:39:19.000Z","msg":"I know that feel<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n試過住間hostel話幫手代寄postcard 點知佢哋好似冇咗件事咁 (因為嗰疊postcard冇人收到) <br />\n唯有希望將來有一日會收到<br />\n<br />\n有啲國家嘅磁石唔靚...買唔落手<br />\n<br />\n所以都係儲下機票/入場券嗰啲就算<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"93c2215010b26fba09ae0f273e53c36555714869","tid":654962,"uid":47470,"like":0,"dislike":0,"score":0,"quote":{"pid":"133a296632eac25d4f2ea7d8b685c74c72fdbb4d","tid":654962,"uid":40849,"like":0,"dislike":0,"score":0,"quote":{"pid":"e1bef610da8e7fddc167c296944ae2362411b79f","tid":654962,"uid":47470,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-05-06T12:25:07.000Z","msg":"好難紀念每一次<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\npostcard比自己但目前已經有3個國家寄失<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n有諗過Starbucks杯但唔係每個國家都有<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n有d後悔既係冇買磁石，下次先開始買又好似唔統一咁<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" 