d6d400312ccc0d8277b17cf53ad7f310be","tid":821320,"uid":19990,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-16T08:11:29.000Z","msg":"放假全日在家玩電腦"},{"pid":"a83640bfd503e26a38499054ff562f45348b9528","tid":821320,"uid":8644,"like":0,"dislike":0,"score":0,"quote":{"pid":"49026ccec402fe7bfadd47202c34e4f7885685db","tid":821320,"uid":132587,"like":2,"dislike":0,"score":2,"quote":{"pid":"938502e752e5f3eedfb33198925e45209c04b15b","tid":821320,"uid":103237,"like":0,"dislike":0,"score":0,"quote":{"pid":"e91c8d091d5e261f2875b92ff75ba672def90322","tid":821320,"uid":191919,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-16T06:58:26.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-09-16T07:22:54.000Z","msg":"12點落波好多人唔駛番工"},"citedBy":2,"replyTime":"2018-09-16T07:23:44.000Z","msg":"大把垃圾公司2點前落都要番<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-16T12:13:35.000Z","msg":"仲有好多都係放工前兩個鐘<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"c57298a8bdc02b2320431885c13101783131d3f9","tid":821320,"uid":132587,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-16T12:14:38.000Z","msg":"聽日香港因為番工有任何一單意外發生 <br />\n無啦啦成個棚跌落去人群<br />\n搭鐵斷鋼纜 成車人燒死曬<br />\n搭巴士因為撞到未清理好既樹幹反車<br />\n避雜物十車相撞既話<br />\n個垃圾政府咩唔咩得起?<br />\n<br />\n點解政府咁有信心一晚可以搞掂好市面清況 <br />\n可以比香港近一半人口 差唔多同一時間出門口番工?<br />\n今日少人出街就話少意外<br />\n聽日條街咁多人 真係確保到打工仔100%安全?<br />\n中學生大學生係人 打工仔唔係人?<br />\n<br />\n果d跌吊臂 棚架 都未fix好就要我地番工? 痴撚左線?<br />\n我知今日都有人要番 <br />\n但當咁多人同一時間出門口 發生意外既機會率又高左<br />\n<br />\n睇新聞連杏花村都停水停電 <br />\n大把地方水浸到門口都出唔到<br />\n有無諗過果班人感受?<br />\n<br />\n希望政府明白我地打工仔唔係想r一日假 要r我射波都得<br />\n係安全問題<br />\n我地唔想打完10號波 落完波先見到有人命傷亡<br />\n希望政府明白<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},{"pid":"3da489b585788d5f9e569a2134ccd8c63dc6e7b1","tid":821320,"uid":111325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-16T12:21:40.000Z","msg":"唔改講咁多<br />\n香港地欠嘅就係一個叫我郁人唔返工嘅官方機構<br />\n<br />\n大交合掛波都係睇佢d儀器架咋<br />\n至於點解你唔駛返工<br />\n某程度上我覺得因為保險嘅問題多過8唔畀8號嘅原因<br />\n<br />\n你可以話好冷血<br />\n<br />\n係呀本身香港睇天氣呢套system就好冷血<br />\n有風有風，有雨就有雨<br />\n一停唔該你班hihi同我即刻返工<br />\n<br />\n再講<br />\n細風左，大交合冇得唔落波，d數據又公開嘅，唔落你又俾人鬧<br />\n<br />\n落左波，特首有冇得宣佈今日停工？用咩藉口？"},{"pid":"8928606be784b1de514f225735c737f27078a9a1","tid":821320,"uid":106363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-16T12:25:12.000Z","msg":"廣東省都停工停課<br />\n<br />\n<a href=\"https://www.inmediahk.net/node/1059485\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1059485&d=5wuWbje2rmQuCRe4DOkwdm6tz0R9Svbxs0EcWe5CwMI%3D&h=51911e32\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1059485&h=a591926c\" data-auto-link target=\"_blank\">https://www.inmediahk.net/node/1059485</a>"},{"pid":"dcf70b8b100cd65837a576d138aa2610632e145b","tid":821320,"uid":43594,"like":0,"dislike":0,"score":0,"quote":{"pid":"a83640bfd503e26a38499054ff562f45348b9528","tid":821320,"uid":8644,"like":0,"dislike":0,"score":0,"quote":{"pid":"49026ccec402fe7bfadd47202c34e4f7885685db","tid":821320,"uid":132587,"like":2,"dislike":0,"score":2,"quote":{"pid":"938502e752e5f3eedfb33198925e45209c04b15b","tid":821320,"uid":103237,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-16T07:22:54.000Z","msg":"12點落波好多人唔駛番工"},"citedBy":2,"replyTime":"2018-09-16T07:23:44.000Z","msg":"大把垃圾公司2點前落都要番<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-16T12:13:35.000Z","msg":"仲有好多都係放工前兩個鐘<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-16T12:25:58.000Z","msg":"咁撚on9 <br />\n勞工處好似預打工仔落波後兩個鐘內返到公司<br />\n咁咪一返到又夠鐘放工<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n雖然準時放工只係傳說<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\