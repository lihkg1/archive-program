=\"hkgmoji\" />"},{"pid":"50168db449fa596356825fe9b0716de413605da4","tid":530574,"uid":63272,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-19T09:11:00.000Z","msg":"3月培正JJ留名"},{"pid":"066757dd4bc1fb0340728dc7c6173ce7fb781ee3","tid":530574,"uid":33866,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-19T23:36:35.000Z","msg":"係，除左斜佬停車開車，其他都唔使轉波<br />\n<br />\n普通停踩brake拉手制就得，少做少錯，咪聽上面邊友老點<br />\n<br />\n三條線就應該睇佢心情，無得講"},{"pid":"8164177398d0821823ec5644af8eae7b94d0aa97","tid":530574,"uid":9115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-21T04:38:57.000Z","msg":"自動波嚟講,係可以全部唔轉n嘅<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"33561c46f68714eaf6ec24d62c13c68a50c22380","tid":530574,"uid":41387,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-21T04:49:55.000Z","msg":"剩係上斜先N波就夠<br />\n<br />\n利申:培正1take pass"}]}