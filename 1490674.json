ike":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T07:43:48.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"855edcd1008cfcb3e099577c3532d079b19072aa","tid":1490674,"uid":110832,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T07:48:03.000Z","msg":"好"},{"pid":"9a2ddd27e7652de31a1d9fbb0e15583498642285","tid":1490674,"uid":45477,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T07:52:51.000Z","msg":"喂大佬呀 班藍絲真係弱智架 <br />\n一陣真係周街斬人就唔好啦<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"6b531a62f3f30679328d0e4960cc3cee7765d00f","tid":1490674,"uid":52230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T07:56:25.000Z","msg":"不要忘記<br />\n<br />\n<img src=\"https://na.cx/i/Pd7TOsP.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPd7TOsP.jpg&h=e790ee5b&s={SIZE}\" />"},{"pid":"d4aaa8a8f9a5156bf57c34d6aad03e834b567c25","tid":1490674,"uid":35081,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T07:57:39.000Z","msg":"推"}]}