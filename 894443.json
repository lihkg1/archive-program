ormal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"36aef563c4ddc0da8e2a9cb17f21549ece2d7dbc","tid":894443,"uid":180281,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-09T16:06:54.000Z","msg":"當前參加人數:<br />\n[6/10]<br />\n<br />\n差4個"},{"pid":"2887bbb8a1d909a18026733da288d87772329862","tid":894443,"uid":55375,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-09T16:11:57.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"404cc6e62f5fd7d65a3a8fa66def0f30daf1f645","tid":894443,"uid":180281,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-09T16:17:18.000Z","msg":"3個！ 差3個<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3ff9db61e22f5c5afd1d04b2923b980bc12692f8","tid":894443,"uid":55375,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-09T16:22:31.000Z","msg":"-2"},{"pid":"590dae3a535ee8d3270fc8550e69a886887bc4ab","tid":894443,"uid":180281,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-09T16:27:50.000Z","msg":"推呀<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"92048ab62e8facc23c097ca940439cede1def2dd","tid":894443,"uid":180281,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-09T16:34:50.000Z","msg":"差你一個就開波啦 快入<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4a08df71cff224e4359526d40461db4e2165d0d6","tid":894443,"uid":55375,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-09T16:36:06.000Z","msg":"-1"},{"pid":"b6aa827e1a242d41fe05ab184cb8898978cea919","tid":894443,"uid":180281,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-09T18:27:43.000Z","msg":"今晚呢場好精彩<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n被兩個臥底玩到氹氹轉... 最後3人 簡單票殺埋個囚犯就贏都唔做...話要推理殺型D<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n另外多謝幾位完左場都留係到比意見既ching...<br />\n放心v3.0好快有<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\n目前排名：<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/11/10/022723_f6a4e3d1081b8c4b3aae5292453d5283.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F11%2F10%2F022723_f6a4e3d1081b8c4b3aae5292453d5283.png&h=84af5f4b&s={SIZE}\" />"},{"pid":"2cfff14b057d97ef5f8be4adc05b8e233da8a1fe","tid":894443,"uid":180281,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-09T18:29:18.000Z","msg":"無錯啦喵...自己寫既驚竟然輸到自己上唔到榜<br />\n負緊200分<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"0a8500b4a596e625c8ce0775eae7519a3d61b928","tid":894443,"uid":180281,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-10T10:33:15.000Z","msg":"有人走場要等夠鐘 &gt; 等太耐 &gt; 無耐性既人又會走場 &gt; ...<br />\n係惡性循環...<br />\n<br />\n所以更新左以下<br />\nV2.1<br />\n<br />\n時限更新：<br />\n-投票捉臥底限時 5分鐘 改 2分鐘<br />\n-囚犯發問限時 5分鐘 改 3分鐘<br />\n-推理時間限時 5分鐘 改 3分鐘<br />\n<br />\n規則更新：<br />\n-在推理與問問題中必須進行操作(就算按放棄鍵都可), 如果累積 <del>3次</del> 2次 沒有任何操作將被系統賜死"},{"pid":"096f82436cdf032267e00d59b41edcb06cd32d8c","tid":894443,"uid":180281,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-10T14:00:55.000Z","msg":"今晚有無人一戰？<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"7f043a6d2a191172cd35fe9cc9d8f7f5d3deed42","tid":894443,"uid":180281,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-10T14:05:56.000Z","msg":"開始有人入啦 位有限 要入請快手<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}