\" />"},{"pid":"d850675ca745a399960da4e323dff48e41113b6d","tid":345770,"uid":55511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-03T22:55:20.000Z","msg":"出街"},{"pid":"f9c5514110f4ff862c898008afd904e4d5a78907","tid":345770,"uid":116000,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-08-03T23:47:59.000Z","msg":"恐懼症唔係咁解"},{"pid":"dd774ad51cd1ded36dde246714d5a5175ed5d5d4","tid":345770,"uid":22104,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-08-03T23:50:13.000Z","msg":"我明樓主<br />\n勁驚買到假西瓜<br />\n$10 個真係平到唔敢食 <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"9b32e80e304fda78e52f073cd53c3bc7cc297a22","tid":345770,"uid":57693,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-08-03T23:53:11.000Z","msg":"嗌交恐懼症"},{"pid":"842376c4cee8a3a28d094511be8dca853a1fc9ac","tid":345770,"uid":130118,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-03T23:53:22.000Z","msg":"水喉扭唔實"},{"pid":"6a4184dc70de5187b971f574c5b7ba80df64363b","tid":345770,"uid":38017,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-03T23:55:56.000Z","msg":"<blockquote>赤腳行啲公共地方<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /></blockquote><br />\n好唔舒服<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"5fe3b128caa150370d53ce1b82120d6eaf9ae902","tid":345770,"uid":79471,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-03T23:58:39.000Z","msg":"<blockquote>恐懼症唔係咁解</blockquote><br />\n醒<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"1e635249a4d8d2035c64dcd879dfd5039d88e4e9","tid":345770,"uid":49162,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-08-04T00:24:54.000Z","msg":"蝴蝶 飛蛾"},{"pid":"49c5cbf826193c6cb43e97a51beab79142cdfa0d","tid":345770,"uid":99025,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-04T08:07:58.000Z","msg":"密集<br />\n刮玻璃"},{"pid":"985b