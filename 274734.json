:"2017-06-08T04:43:17.000Z","msg":"此回覆已被刪除"},{"pid":"52fd628baed7b80a380d4fa48773a3b2587fa12b","tid":274734,"uid":997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-08T04:45:20.000Z","msg":"支那報仇 十年未晚<br />\n<br />\n當初雲南比緬甸炸<br />\n用呢種方法報復 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"60eb97fdbd34936af69aca6e6c3af800202e292b","tid":274734,"uid":35430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-08T05:25:15.000Z","msg":"<img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" />"},{"pid":"e43023a1fb0f8f10dc40486567e7924276613af3","tid":274734,"uid":8048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-08T05:26:37.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"}]}