:"50fe4913fd0d3aab57d7ae9f760cc8b4fac1b637","tid":1389503,"uid":35699,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-31T02:18:13.000Z","msg":"罷工"},{"pid":"166c9a4daa66041019ed14faea18c7e05755edcb","tid":1389503,"uid":35699,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-31T02:18:23.000Z","msg":"罷工"},{"pid":"f0afdf561bb9e6d67e21ea751f01cc5137a2ce63","tid":1389503,"uid":35699,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-31T02:18:33.000Z","msg":"罷工"},{"pid":"8e93aca75e733b505f28db5e251321692a5274a2","tid":1389503,"uid":161274,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-31T02:25:04.000Z","msg":"罷工，不了<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n我連份工都辭埋 冇得罷工<br />\n8月5號 大家識做"},{"pid":"df7080162e234711c7fbdd558dbb4ac5b6ce0ac3","tid":1389503,"uid":35699,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-31T02:30:33.000Z","msg":"<img src=\"https://na.cx/i/veJEffn.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FveJEffn.png&h=62f8f9d4&s={SIZE}\" />"},{"pid":"1d0b71582314b0b3c1f7ed1ec612cc04d3fa8cf3","tid":1389503,"uid":294906,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T02:34:04.000Z","msg":"罷工團結強心針方案<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/dtvcxS\" data-auto-link target=\"_blank\">https://lih.kg/dtvcxS</a>"},{"pid":"39922c6f64ec9703b54bd08fdb5423cd03132230","tid":1389503,"uid":70888,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-31T02:35:28.000Z","msg":"罷工"},{"pid":"6a888f97ae21d5a05e0def9f9973310f66761323","tid":1389503,"uid":35699,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-31T04:08:40.000Z","msg":"罷工"},{"pid":"f73f299d0e795e8ebcd951c77435ad42caad1d7e","tid":1389503,"uid":65858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T04:10:47.000Z","msg":"推"},{"pid":"911854111c0da303169b8e992eb38d2ecbdab097","tid":1389503,"uid":234339,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T04:11:24.000Z","msg":"罷工"},{"pid":"1a4fab4afed3bb4561f85823d820fa4534c3f8ad","tid":1389503,"uid":6528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T04:11:35.000Z","msg":"全民8月5日大罷工！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n五大訴求，缺一不可！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n雙普選應要排最頭！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n全民黑衫、口罩同頭盔，返工返學行街，唔擺工既日子一齊做，將抗爭帶入生活，保護示威者<br />\n<a href=\"https://lih.kg/1379839\" data-auto-link target=\"_blank\">https://lih.kg/1379839</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n光復香港，時代革命！<br />\n－－－－－－－－－－－－－－－－－－－－－－－－－－－－－<br />\n想比更多人知道其實而家呢一刻基本上得番香港獨立呢條路，<br />\n我知好多人未準備好，我知而家急唔黎。<br />\n但係想大家思考下，種下一個思想，唔好屌我住。<br />\n<br />\n而家就算有真普選其實都係under中共！！<br />\n咁唔通去到2047再抗爭過咩，西方國家都出唔到手幫你地。<br />\n因為白紙黑字寫明50年，西方國家唔好話出手，連發聲既正當性都冇啊<br />\n<br />\n可能好多前人都係到諗點解英國當時唔寫999年！<br />\n可能好多我地呢代既諗點解上一代冇去抗爭！<br />\n可能好多下一代係2047係到諗點解我地唔直接爭取獨立！！！<br />\n<br />\n所有既問題，所有既恩怨，係我地呢代到解決哂啦，好嗎？<br />\n我地唔可以好似上一代咁，計好哂數50年後都死左啦，唔好理啦。<br />\n我地唔可以再咁自私咁，過埋2047都死左啦。<br />\n我想我地既下一代唔需要再為呢啲事再受苦啦，我只係希望下一代可以係呼吸住自由既空氣出世係呢個地球上。<br />\n<br />\n所有問題去到最後只會追究到主權問題，希望大家思考下。<br />\n今次搞到咁大真係最後一次反擊同最大力量。<br />\n<br />\nBTW，五大訴求，缺一不可！<br />\n雙普選應要排最頭"},{"pid":"80ab0cf84fcf07ceb9973e0bbc8e7227c0be0f77","tid":1389503,"uid":35699,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T04:47:23.000Z","msg":"要令義士無罪釋放，係要贏！ 唔好將責任外判俾陪審團！！！！！！！！"},{"pid":"544d40c07d6a723f14fcfcf5ebeea878f5f0262b","tid":1389503,"uid":51814,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T04:52:09.000Z","msg":"向家暴說不，8.5我會罷工"}]}