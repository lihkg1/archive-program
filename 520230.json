assets/faces/xm/oh.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/oh.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/oh.gif\" class=\"hkgmoji\" />"},{"pid":"dcea79329657381cf10da43d54cf1ef867686ef4","tid":520230,"uid":33982,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-01-05T09:19:18.000Z","msg":"<blockquote>以前高登啲痴線故同潮文係咪就係呢啲人寫<img src=\"/assets/faces/xm/oh.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/oh.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/oh.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"2e836b54d1bcfa0ec76f46018cf70e7c06a29388","tid":520230,"uid":33868,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-01-05T09:19:35.000Z","msg":"d戲over左"},{"pid":"4b39bd901e779a7d75dd00aaa881a4bc29568423","tid":520230,"uid":11331,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2018-01-05T09:22:25.000Z","msg":"We are SPARTA!!!!"},{"pid":"cc4ae77ec792c13de000bf024c5e5779fa6ff802","tid":520230,"uid":75448,"like":17,"dislike":2,"score":15,"citedBy":0,"replyTime":"2018-01-05T09:25:23.000Z","msg":"痴膠線都結到婚，你地班單身狗好好檢討下"},{"pid":"ac6b4676182c84acedb20cf5111fbfe484a766ca","tid":520230,"uid":54486,"like":6,"dislike":3,"score":3,"citedBy":0,"replyTime":"2018-01-05T09:31:57.000Z","msg":"睇到個標題嚇到叫左出黎，老細問咩事，我照讀比佢聽，讀左標題內文都未開始讀，佢成塊面白哂，自言自語，猛咁話「共慘黨殺到黎，香港九龍新界無得避，要化身玉皇大帝打救蒼生；共慘黨殺到黎，香港九龍新界無得避，要化身玉皇大帝打救蒼生&hellip;&hellip;」<br />\n<br />\n跟住衝左上天台，叫左一聲「鳴呀，點解係我」就跳左落去，成班同事追上去都追唔切，有兩個女同事嚇到暈左，仲有個男同事當場嚇到變左弱智，不停問人要唔要食腸仔蛋。<br />\n<br />\n我就好好彩無咩事，但同班同事五十幾個人即時變左失業，你條仆街真係害人害物&hellip;&hellip;"},{"pid":"3ed3a8ab28d5cb62c2ce91717232c7feffb2822b","tid":520230,"uid":90820,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-05T09:35:38.000Z","msg":"影帝<img src=\"/assets/faces/xm/adore.gif\" class=\"hkgmoji\" />"},{"pid":"762e00056b746ddb3c9a6dfedbfb788978da3536","tid":520230,"uid":73935,"like":6,"dislike":0,"score":6,"quote":{"pid":"93ca801915d67a5388fa0398b41d2ddc23adcd35","tid":520230,"uid":39539,"like":57,"dislike":1,"score":56