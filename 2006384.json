/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />好驚啊<br />\n希望巴絲打可以幫下我"},"citedBy":1,"replyTime":"2020-05-07T18:01:09.000Z","msg":"同埋正常黎講肌肉都好吸糖，如果你好大隻，平時又唔係暴飲暴食，應該都唔會有野Ge,除非你本身啲Gene 有野"},{"pid":"801cdcd42660228283c85a31618c1ef8397e2629","tid":2006384,"uid":27203,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-07T18:02:36.000Z","msg":"如果你有做開運動又後生其實唔洗咁驚<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e11f93816a0fd694ba8f5bab8c79e903fb3e64b7","tid":2006384,"uid":256464,"like":0,"dislike":0,"score":0,"quote":{"pid":"3fcce0372cc669851587394d8667bda5f24b79e1","tid":2006384,"uid":27203,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-07T18:00:57.000Z","msg":"食得比較多係咩意思先 特登食去增肌 定其實對你都係正常份量<br />\n如果係前者你咪試下減啲量到正常量先度<br />\n<br />\n同埋你幾多歲個啲都好影響洗唔洗檢查/ 你檢查既方法/壓力呀個啲其實都好有影響<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n仲有你講HbA1c係check緊3個月之既野 如果係近期先有呢個問題咁未必有用<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-07T18:03:39.000Z","msg":"我得29咋<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />BMI 22.7"},{"pid":"9d173d100d41bd70dc42cf5e99581db27dd40c86","tid":2006384,"uid":25468,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec76564434084f0fc86babad1451e50ae1acf1e2","tid":2006384,"uid":158857,"like":0,"dislike":0,"score":0,"quote":{"pid":"b0d403056bfb2bc31d8339d4d672c42ce447f730","tid":2006384,"uid":256464,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-07T17:30:14.000Z","msg":"小弟平時玩開健身，每次操練兩到三小時左右，每星期五日。因爲平時做嘢無辦法小食多餐，所以午餐and晚餐（睡前5小時食）會食得比較多，希望可以食夠。其中白飯每餐約350-400g。最近無意中想起測下自己餐後2小時血糖，測得餐後2小時為8.2-8.4，餐後3小時為6.8-6.9<br />\n<br />\n係網上見到理想值為餐後兩小時&lt;7.8 ，餐後3小時&lt;6.1<br />\n<br />\n我想問下我依家應該點做，去做糖耐量測試？定係驗HbA1c？<br />\n<br />\n好煩惱<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />冇諗過自己做開運動，今日度出來會高左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />好驚啊<br />\n希望巴絲打可以幫下我"},"citedBy":1,"replyTime":"2020-05-07T18:01:09.000Z","msg":"同埋正常黎講肌肉都好吸糖，如果你好大隻，平時又唔係暴飲暴食，應該都唔會有野Ge,除非你本身啲Gene 有野"},"citedBy":1,"replyTime":"2020-05-07T18:05:15.000Z","msg":"但佢做三個鐘gym 會唔會過長？有睇過啲report 講運動時間過長反而會引起血糖標升，唔記得係咩原理"},{"pid":"d89a2c4d92b70a5400ed2076905f17e4f0fa90d6","tid":2006384,"uid":27203,"like":0,"dislike":0,"score":0,"quote":{"pid":"e11f93816a0fd694ba8f5bab8c79e903fb3e64b7","tid":2006384,"uid":256464,"like":0,"dislike":0,"score":0,"quote":{"pid":"3fcce0372cc669851587394d8667bda5f24b79e1","tid":2006384,"uid":27203,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-07T18:00:57.000Z","msg":"食得比較多係咩意思先 特登食去增肌 定其實對你都係正常份量<br />\n如果係前者你咪試下減啲量到正常量先度<br />\n<br />\n同埋你幾多歲個啲都好影響洗唔洗檢查/ 你檢查既方法/壓力呀個啲其實都好有影響<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n仲有你講HbA1c係check緊3個月之既野 如果係近期先有呢個問題咁未必有用<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-07T18:03:39.000Z","msg":"我得29咋<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />BMI 22.7"},"citedBy":0,"replyTime":"2020-05-07T18:16:04.000Z","msg":"BMI 對有健身既人更唔準 因為本係肌肉就重 BMi係冇consider 到你係肌肉定脂肪 你可以用體脂比做參考<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 當然去醫院做檢查係好 但係你個數字咁marginal 同埋又後生 其實都會唔會比藥你食 咪又係lifestyle modification先<br />\n<br />\n所以有錢去check清楚冇話 冇錢先下轉飲食同其他習慣先再睇下個數字點<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1d4f84e5419b2bfb7fc8db0272868fe33fdb0544","tid":2006384,"uid":275698,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-05-07T19:35:43.000Z","msg":"糖尿病二型係因為胰島素阻抗異常，令血糖走唔到，積聚係血入面形成高血糖<br />\n但血糖高並不等同胰島素阻抗異常，可以係腸胃消化、自律神經失調、個人精神緊張都會令血糖升高<br />\n所以最後都係要抽血驗糖化血紅蛋白為準<br />\n<br />\nbtw研究話以糖尿病前期黎講，間歇性斷食即係多食少餐會幫助血糖正常化，其實少食多餐已經係old news"},{"pid":"6a771e4b8a9112b4b06602045ade7e2deaad12e2","tid":2006384,"uid":158857,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d173d100d41bd70dc42cf5e99581db27dd40c86","tid":2006384,"uid":25468,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec76564434084f0fc86babad1451e50ae1acf1e2","tid":2006384,"uid":158857,"like":0,"dislike":0,"score":0,"quote":{"pid":"b0d403056bfb2bc31d8339d4d672c42ce447f730","tid":2006384,"uid":256464,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-07T17:30:14.000Z","msg":"小弟平時玩開健身，每次操練兩到三小時左右，每星期五日。因爲平時做嘢無辦法小食多餐，所以午餐and晚餐（睡前5小時食）會食得比較多，希望可以食夠。其中白飯每餐約350-400g。最近無意中想起測下自己餐後2小時血糖，測得餐後2小時為8.2-8.4，餐後3小時為6.8-6.9<br />\n<br />\n係網上見到理想值為餐後兩小時&lt;7.8 ，餐後3小時&lt;6.1<br />\n<br />\n我想問下我依家應該點做，去做糖耐量測試？定係驗HbA1c？<br />\n<br />\n好煩惱<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />冇諗過自己做開運動，今日度出來會高左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />好驚啊<br />\n希望巴絲打可以幫下我"},"citedBy":1,"replyTime":"2020-05-07T18:01:09.000Z","msg":"同埋正常黎講肌肉都好吸糖，如果你好大隻，平時又唔係暴飲暴食，應該都唔會有野Ge,除非你本身啲Gene 有野"},"citedBy":1,"replyTime":"2020-05-07T18:05:15.000Z","msg":"但佢做三個鐘gym 會唔會過長？有睇過啲report 講運動時間過長反而會引起血糖標升，唔記得係咩原理"},"citedBy":0,"replyTime":"2020-05-07T20:17:14.000Z","msg":"運動太激烈或太長時間的確有機會令糖糖上升，但都係短時間之內係咁。如果樓主check過幾次飯後血糖都係咁，咁似本身有問題多，可能係impair fasting glucose 或者impair glucose tolerance"},{"pid":"2ab400c88d932e4883423c5f153540493770b8d9","tid":2006384,"uid":35581,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-07T21:18:30.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d4748b7d3515b15d43fb638d9ecdd60121c8da94","tid":2006384,"uid":35581,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-07T21:26:07.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"86b3fe9d52fbc8c62c642c23c806c29feb2899fd","tid":2006384,"uid":35581,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-07T21:37:31.000Z","msg":"<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" />"}]}