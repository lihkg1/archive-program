moji\" />"},{"pid":"780422d7e6066f3e6be3178e77ddaaae052f5ead","tid":2345940,"uid":123961,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-30T06:18:40.000Z","msg":"冇興趣真係唔好<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"01c5577528082d7f7370f021e99aa544033b9b90","tid":2345940,"uid":115281,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-12-30T06:20:38.000Z","msg":"未讀過IT就疊埋心水做教蓄啦，薪高糧準。做code狗開頭人工一定低，仲要唔知幾時被人炒，或者公司執笠，到時實後悔"},{"pid":"41607d37389f2e3695b56c58064e41c10218cf63","tid":2345940,"uid":64694,"like":0,"dislike":7,"score":-7,"quote":{"pid":"d740e7cbc24bfb71407ec3caea054c4087f22694","tid":2345940,"uid":122134,"like":61,"dislike":0,"score":61,"citedBy":1,"replyTime":"2020-12-30T02:36:43.000Z","msg":"教人打code既老師"},"citedBy":0,"replyTime":"2020-12-30T07:33:03.000Z","msg":"睇錯咗<br />\n教人打交嘅老師<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /><br />\n教人打J嘅老師<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /><br />\n教人打飛機嘅老師<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"044c7e785d09f534b388ec47d222afdd6c645a65","tid":2345940,"uid":64694,"like":0,"dislike":0,"score":0,"quote":{"pid":"62ce64ee67b8a0499f7f1034f84438d40b1b6c4f","tid":2345940,"uid":116960,"like":7,"dislike":1,"score":6,"quote":{"pid":"f4ec23931e85098a1d9337850ad032a35f8bb67f","tid":2345940,"uid":55954,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-12-30T03:12:53.000Z","msg":"做programmer可以好好搵<br />\n亦都可以做好多年都係咁沉<br />\n原因係programming唔係一件你學完就可以做到好好既一回事<br />\n由零開始既勸你早d返轉頭<br />\n成個IT業真係高人工既比例其實唔係咁多<br />\n何況由一個新人開始做起？"},"citedBy":1,"replyTime":"2020-12-30T04:07:48.000Z","msg":"由零開始其實唔係問題,但IT呢行想做得耐同高人工其實好興趣,自己主動學野PICK UP新野,成件事本身係無窮無盡唔會有完既一日(除左退休)。但見樓主30歲先黎諗IT,原因就係見呢兩年IT好似好好景<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />咁都係收收皮先"},"citedBy":0,"replyTime":"2020-12-30T07:38:14.000Z","msg":"起碼都要讀個文憑先啦，但樓主似係想自學完直接轉行，雖然冇話唔得嘅，但係HR可能一嘢已經screen走佢<img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" />"},{"pid":"6637089977ff536f183440aa21f52276fd181db8","tid":2345940,"uid":80153,"like":1,"dislike":0,"score":1,"quote":{"pid":"cc5b183df1d9ac934f764d4240dd779a6fa54924","tid":2345940,"uid":365801,"like":2,"dislike":7,"score":-5,"citedBy":3,"replyTime":"2020-12-30T03:28:21.000Z","msg":"想轉行都關自己性格事既，自己性格係坐係度靜靜地做就會做得好既人，而不停互動反而無咁易handle。<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-30T07:43:59.000Z","msg":"IT人嘅互動好多㗎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n係就係坐係電腦前面，但一日可能有幾個zoom/con-call，間唔中又有啲人IM彈出嚟問嘢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"83eb6daa7021c6733e985e455dd15197be4218e3","tid":2345940,"uid":232442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-30T08:06:17.000Z","msg":"識人有類似經歷，但佢本身係工程出身但走咗去教書，佢條路係好漫長，兩年進修，第一份工跌到落得返萬幾蚊，四五年後都仲未攞得返教書個人工"},{"pid":"491b0b0b224e9b2cad8dded578405b2e7eafdf6b","tid":2345940,"uid":38030,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-30T08:09:40.000Z","msg":"認真答，It係一個好睇個人興趣嘅行業，冇興趣夾硬做，包你慘過狗，所以最簡單嘅起步點就係得閒學下coding先，冇興趣就及早回頭是岸"},{"pid":"3bfb05e2d7e06183f5501c813ebbe1eb47d0239c","tid":2345940,"uid":116960,"like":3,"dislike":0,"score":3,"quote":{"pid":"491b0b0b224e9b2cad8dded578405b2e7eafdf6b","tid":2345940,"uid":38030,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-30T08:09:40.000Z","msg":"認真答，It係一個好睇個人興趣嘅行業，冇興趣夾硬做，包你慘過狗，所以最簡單嘅起步點就係得閒學下coding先，冇興趣就及早回頭是岸"},"citedBy":0,"replyTime":"2020-12-30T08:13:37.000Z","msg":"老老實實返工日日對九個鍾code難實好少人可以放工繼續對住。<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n都已經唔係話興趣問題,做多兩年你對眼會開始FEEL到乾到仆街<img src=\"/assets/faces/pigxm/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/smile.gif\" class=\"hkgmoji\" />已經係頂唔頂得順既問題。<img src=\"/assets/faces/pigxm/wine.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/wine.gif\" class=\"hkgmoji\" />我建議IT狗自學新野係返