yle=\"color: red;\"><strong><strong><strong>大家要小心，係FACEBOOK的片要盡快BACKUP，放上YOUTUBE再放上來，噚晚有好多片被FACEBOOK下架!!!</strong></strong></strong></span></span>"},{"pid":"7117894a53bd321e3973c570eb83d700767860f2","tid":1203983,"uid":256937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T01:56:35.000Z","msg":"冇片唔緊要，請幫手推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b4b230f67919239176d7cd2e9e34e963e12560c7","tid":1203983,"uid":256937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T02:03:46.000Z","msg":"警方於金鐘站用胡椒噴霧射向示威者 <br />\n<a href=\"https://www.facebook.com/watch/?v=508913512981322\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fwatch%2F%3Fv%3D508913512981322&d=%2FodnS2mEGvHoUZPzyf%2FmNWzUwbN2nhMFbUYjFdDHJd4%3D&h=ab3fa7e1\" data-auto-link target=\"_blank\">https://www.facebook.com/watch/?v=508913512981322</a>"},{"pid":"9db282e016614cd11fa471eaa45c03e1a96ceeaf","tid":1203983,"uid":163663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T02:05:51.000Z","msg":"韓國青瓦台聯署<br />\n<a href=\"https://lih.kg/1213446\" data-auto-link target=\"_blank\">https://lih.kg/1213446</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"f7bce0af230e6295a4f60b2c84872a80ee68a595","tid":1203983,"uid":256937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T02:45:23.000Z","msg":"推"},{"pid":"f47f84e751c8bd934b837db335ef287b31a25790","tid":1203983,"uid":256937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T03:45:14.000Z","msg":"推"},{"pid":"df94b9cbcd8b2cd1978eb54a37562c25dd25d988","tid":1203983,"uid":210011,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T04:09:13.000Z","msg":"唔夠抽就取智做9佢哋啦"}]}