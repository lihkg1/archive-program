9:56.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"9293f8948be3a8c9ad70d364c6faa416db5ec9d7","tid":1638291,"uid":146737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T09:24:22.000Z","msg":"［第八期牆紙］抗爭之餘，還請好好活著<br />\n<a href=\"https://lihkg.com/thread/1631856/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1631856/page/1</a><br />\nTG CHANNEL :<a href=\"https://t.me/WallPaperENews\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FWallPaperENews&d=NaStGCRJdOSKaO4BfYueNuDT5CHOggjCyLUuLmpgHOg%3D&h=87551dea\" data-auto-link target=\"_blank\">https://t.me/WallPaperENews</a><br />\n歡迎投稿 : <a href=\"https://padlet.com/lennonnewshk/6g5yp3tllkxx\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpadlet.com%2Flennonnewshk%2F6g5yp3tllkxx&d=NaStGCRJdOSKaO4BfYueNuDT5CHOggjCyLUuLmpgHOg%3D&h=0be23feb\" data-auto-link target=\"_blank\">https://padlet.com/lennonnewshk/6g5yp3tllkxx</a>"},{"pid":"0c4236ce3561a9ecc92f96ef78d9ff885aabbc90","tid":1638291,"uid":134141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T09:33:45.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"0f5080ec15f11121f1f225e5f73fb9da954bf809","tid":1638291,"uid":134141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T09:34:01.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"9e054546a3f06814e0084a17f9ab8f81a0f064f8","tid":1638291,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-08T09:34:01.000Z","msg":"問題係連和理非都好難成功遊行<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我係擔心和理非安危<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"860a6e74ddcd791dca15f16c586c3d4236c1c358","tid":1638291,"uid":134141,"like":0,"dislike":0,"score":0,"quote":{"pid":"9e054546a3f06814e0084a17f9ab8f81a0f064f8","tid":1638291,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-08T09:34:01.000Z","msg":"問題係連和理非都好難成功遊行<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我係擔心和理非安危<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-08T09:34:38.000Z","msg":"和理非都要帶豬嘴眼罩"},{"pid":"e8f652302d37a086cf4380ce49f0d0650e76c0bf","tid":1638291,"uid":134141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T09:34:49.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"47989c29daa69128f3f1e7a756b13e06881a7a70","tid":1638291,"uid":134141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T09:35:00.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"760bc9148e0a7e39751a102ae7b92b80fda68da8","tid":1638291,"uid":134141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T09:35:11.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"db3b8bac0bc41657527c003748dca87f0027660d","tid":1638291,"uid":134141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T09:35:22.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"bf95c3900889433df8807922c720ecb353773a3e","tid":1638291,"uid":44461,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-08T09:39:01.000Z","msg":"其實不嬲都好岩聽 但一言既之曰都係難<br />\n其實係裝修師父都知道 裝修真係唔磨得幾耐 可以裝修嘅鋪種類又唔多 佢地整得又慢 真係唔裝修得幾多次<br />\n<br />\n裝修得最勁嘅 都係十月呢段時間 每晚八點聚人個轉<br />\n之所以點解裝修美心/mtr 因為易搵 多 唔會搵好多popo守<br />\n好多人問點解唔打中聯辦/政總/狗局狗總 因為難 重防 唔好話裝修 狗屋個啲你多人少少行過去 都tg放題<br />\n<br />\n打休班狗/狗家屬我唔肯定係咪一個好方法 因為雖然理念係好 但堅難捉 唔通我係休班popo/狗家屬仲大搖大擺咁係手足面前行過咩 通常佢地唔出聲 你根本identify唔到佢地係 變相每次行動 都可能係食西北風嘅開始 如果一食西北風 就好似變路障/遊擊陣地嘅節奏<br />\n<br />\n我最近係度諗緊方向去裝修建制議員嘅屋企 但問題係佢地屋企多數都係普通私樓樓上 你一大班人 大搖大擺咁上去真係天方夜譚<br />\n<br />\n我諗緊將裝修普及到普通建制議員(區議會級)會唔會係出路?<br />\n<br />\n不過真心 搵野裝修係堅難 又要俾人鬧 可以裝修嘅對像又少 連裝修黨鐵都俾人話係鬼 唉"}]}