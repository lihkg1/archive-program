=\"hkgmoji\" />"},{"pid":"a3484e04d4719a890ed664fb3483b08433a4b9f0","tid":1875150,"uid":310324,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-12T05:27:11.000Z","msg":"手足<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n雖然已經有人提過<br />\n我地真係要專注返戰線<br />\n唔可以辜負手足<br />\n<br />\n題外話<br />\n信入面講可能會忘記自己之後做既野<br />\n我覺得好似d廢老做緊既野<br />\n其實會唔會d廢老都經歷過呢啲問題<br />\n所以先磨滅人性同智商<br />\n<br />\n利申：成日屌屋企兩件廢老"},{"pid":"cb0bfdcd1540dc9e7fdfc055a692e7f6dc5afab3","tid":1875150,"uid":44955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-12T07:04:00.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"2c977ea67ac4d297e77499eb706006be27ddae61","tid":1875150,"uid":61886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-12T07:37:00.000Z","msg":"手足加油<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"11c54f962c86c491fdb1c2ca2f371a6e9f7a75db","tid":1875150,"uid":253978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-12T07:38:00.000Z","msg":"condom<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"27d8fc275b5d162c013a0d874d73a13e4f965b52","tid":1875150,"uid":12186,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-02-12T07:39:06.000Z","msg":"手足加油<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n<br />\n回完post轉個撚頭去打機，d傻仔就白白浪費自己既青春去俾人利用<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6a8f1f21eae6828697cb5937abc76b7f2d96b4dd","tid":1875150,"uid":307011,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-12T07:41:49.000Z","msg":"推"},{"pid":"2c80b9c59