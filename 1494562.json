14d86e8b3aa0025","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:28:28.000Z","msg":"9"},{"pid":"70e184f15ad327aabf03409039770bc8285c7215","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:28:38.000Z","msg":"8"},{"pid":"7f190d236454f181757090ed87eb681f1abd4508","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:28:48.000Z","msg":"7"},{"pid":"4a94d7c0695806a05eae122b424a2d40d16c4cf6","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:28:58.000Z","msg":"6"},{"pid":"f8c8ad6007e22b4efc9b59ec8283e63793f16cb7","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:29:08.000Z","msg":"5"},{"pid":"1be1b6954399ec138c4567a193c2c5e83b55b0f8","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:29:18.000Z","msg":"4"},{"pid":"e2c0b3d11b009881f1db7ac863d895773adb4532","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:29:28.000Z","msg":"3"},{"pid":"f8c6f94939cc5ddefaaff5fac95a8b0ed869d8a8","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:29:38.000Z","msg":"2"},{"pid":"fa7fe72dce23857477e354cb36acec966e8c8893","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:29:48.000Z","msg":"1"},{"pid":"4a0f02c63639fcb71f89dda98ca22992a4756db0","tid":1494562,"uid":288786,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:35:55.000Z","msg":"評論白兵的一點短視<br />\nYouTube嘅白兵及其朋友白兵頭係我非常佩服的分析能力極高的青年KOL，各位如果未聽過他們的video就一定要聽聽：<a href=\"https://youtu.be/eif-Fe6_UAw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Feif-Fe6_UAw&d=qWTZpUodHfCf2bB0mbfn0yrXKCTJ71YGEIw5q99tfRY%3D&h=208330cf\" target=\"_blank\">https://youtu.be/eif-Fe6_UAw</a>  <br />\n<br />\n香港有白兵這樣的青年才俊，香港的前途無可限量。但是白兵有時候刻意與和理非及泛民割席，這雖然有其可接受的理據：<a href=\"https://youtu.be/wS0PDYcWh8U\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FwS0PDYcWh8U&d=qWTZpUodHfCf2bB0mbfn0yrXKCTJ71YGEIw5q99tfRY%3D&h=cd095ddb\" target=\"_blank\">https://youtu.be/wS0PDYcWh8U</a><br />\n就顯示了年輕人一些短視。因為後來有網友問白兵這場運動最後如何勝出呢？白兵沒能提供一個好的答覆。請恕我淺薄提供一些觀點給白兵及其聽眾參考：<br />\n<br />\n1.年輕人急於求成往往忽略了要長期地全方位地對抗。八十年代九十年代的香港年輕人也曾為香港前途激烈抗爭（其激烈程度由前港督尤德在北京心臟病亡可証），當年的年輕人現在的中年人一直都有通過議會選舉、71遊行、64集會等抗爭，<span style=\"color: red;\"><span style=\"font-size: large;\">請傘後一代不要放棄這些戰場</span></span>。<br />\n<br />\n2.年輕人可能會對中共的惡魔本質瞭解不深，雖然爭取真普選是<span style=\"color: blue;\"><span style=\"font-size: large;\">與虎謀皮</span></span>，但是只要全方位錙銖必較（請參考以下幾點），一定可以玩殘十幾億人的老虎加跳蚤的。<br />\n<br />\n3.中共計劃用深圳取代香港，這是<span style=\"color: red;\"><span style=\"font-size: x-large;\">一個好機會趕走香港的親中財團，他們放棄香港自然就不會為其利益而介意香港人自主</span></span>。香港人要趁機說服歐美如果中共不給予香港真普選，歐美要制裁香港的親中財團的產品，同時培植和不制裁香港的<span style=\"color: purple;\"><span style=\"font-size: x-large;\">反共經濟</span></span>。<br />\n<br />\n4.香港的反共經濟可以在各行各業包括金融及新經濟同歐美同行建立緊密聯繫，要建立全球網絡，可借助全球各地的香港移民。<br />\n<br />\n5.香港的反共經濟要有百萬人或更多人參與，要有自己的產業規劃，要有市場文宣，要更多更快地使用人工智能等等新科技，要利用與深圳的就近地理位置借鑒深圳的成功經驗。<br />\n<br />\n6.香港人要為反共經濟作出長期的抗爭，因為會被中共及親中財團打壓，因此要在區議會、立法會、選委會中爭取每一票。不要過於依賴某些歐美政治人物，要依賴歐美市場及在歐美經濟轉型中的各種需要。<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: large;\">光復香港時代革命</span></span>心"},{"pid":"7b4698994d5b69c0e152b5c936416aa768b99fe4","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:57:31.000Z","msg":"推"},{"pid":"93b0f140c9a0c560ced98a3f2e2ced92ffdf4cc3","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:57:41.000Z","msg":"推"},{"pid":"255d9109e3494cec2ce3678468649bf5213488b6","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T17:57:51.000Z","msg":"推"},{"pid":"7c21f7f31304551a75cfb9e905a61f670c0943dc","tid":1494562,"uid":44312,"like":0,"dislike":0,"score":0,