e3d71f06861339d9","tid":1625312,"uid":87511,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-05T13:39:35.000Z","msg":"林鄭出入總有至少5部豬籠/衝鋒護送<br />\n你諗到嘅嘢，POPO點會諗唔到"},"citedBy":2,"replyTime":"2019-10-05T13:40:31.000Z","msg":"建制派有好多議員"},{"pid":"3d6479fe1836c4151886156d7ea5074ee5ebb366","tid":1625312,"uid":87511,"like":0,"dislike":0,"score":0,"quote":{"pid":"eddc489adf2bbfc832358d97d4feeb3d6b4860ce","tid":1625312,"uid":116526,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c76f7941a602d5afcd5f3bae3d71f06861339d9","tid":1625312,"uid":87511,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-05T13:39:35.000Z","msg":"林鄭出入總有至少5部豬籠/衝鋒護送<br />\n你諗到嘅嘢，POPO點會諗唔到"},"citedBy":2,"replyTime":"2019-10-05T13:40:31.000Z","msg":"建制派有好多議員"},"citedBy":0,"replyTime":"2019-10-05T13:40:57.000Z","msg":"呢個就認同 <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"4777f44987257d47a1507dc848a1e8544fc01743","tid":1625312,"uid":169195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:41:58.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7bb0d7dcddc48f7730d4851e1b8a17edc8b10504","tid":1625312,"uid":312125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:43:51.000Z","msg":"全民核彈！全部軍師立即響應美國，草擬制裁港共企業名單！<br />\n<a href=\"https://lih.kg/1599761\" data-auto-link target=\"_blank\">https://lih.kg/1599761</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n制裁名單草稿（英文版）長文<br />\n<a href=\"https://lih.kg/1607415\" data-auto-link target=\"_blank\">https://lih.kg/1607415</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<br />\n<span style=\"font-size: large;\">美國已經批准審核香港人權及民主法案2019，<span style=\"color: red;\">國會議員可以制定制裁名單。</span><br />\n請各位軍師善用呢個機會，<span style=\"color: gold;\">依家大家應搜集一切過往新聞片段、照片、新聞報導、政府新聞公告等一切資料，羅列所有協助侵犯香港人權嘅個人、企業嘅罪證</span>，<span style=\"color: red;\">整理好一份名單，寄俾美國嘅國會議員</span>。<br />\n<span style=\"color: red;\">只要佢哋落入《全球馬格尼茨基人權問責法案》嘅制裁名單，咁個人或公司經濟即刻受到重創。咁呢班商人到時就會調轉槍頭，向政府施壓要求政府讓步及妥協。</span><br />\n我在此拋磚引玉，請大家接力發掘：<br />\n<strong><span style=\"color: red;\">香港警察</span></strong>：非法鎮壓、濫捕和平示威者，無顯示警員編號及無出示委任證，應全體受到制裁。所以請大家依家要整理好現役警員清單。<br />\n<strong><span style=\"color: red;\">律政司</span></strong>：無理監控<br />\n<strong><span style=\"color: red;\">政府新聞處</span></strong>：惡意抹黑示威者，為港共政權掩飾罪證。<br />\n<span style=\"color: red;\"><strong>黨鐵</strong></span>：多次協助警察鎮壓示威者，721車務控制中心落order迫停列車，任由黑幫恐怖襲擊。<br />\n<span style=\"color: red;\"><strong>新雄雞</strong></span>：縱容警察在其屬下商場毆打、濫捕示威者<br />\n<strong><span style=\"color: red;\">狗巴、八達通</span></strong>：將示威者八達通資料交與警察抓捕<br />\n<strong><span style=\"color: red;\">中國國務院港澳辦、中國外交部、中聯辦、人民日報、中央電視台、環球時報、太公文匯報、賣過百份報、黨媒01、巫線、腥賭日報</span></strong>：惡意抹黑示威者，散播仇恨言論，為港共政權掩飾罪證。<br />\n<span style=\"color: red;\"><strong>富臨</strong></span>：主動為參與鎮壓和平示威者嘅黑幫提供膳食。<br />\n<span style=\"color: red;\"><strong>國家民航局、國泰、拮野家</strong></span>：打壓參與示威嘅員工、或以政治原因炒員工<br />\n<span style=\"color: red;\"><strong>中國政法委</strong></span>：打壓及恐嚇李嘉誠同情年輕人的言論<br />\n等等。<br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: gold;\">我地要做嘅係，向美國參眾議員建議制裁名單及佢地罪證。一旦制裁名單上嘅人士、企業受到美國制裁，以後就無人及公司可以同佢做生意。否則同受制裁。</span></strong></span>例子如下：</span><br />\n<br />\n<strong>中國企業違反伊朗制裁令 美國務卿：將進行懲罰</strong><br />\n<pre><code data-type=\"\">美國國務卿龐皮歐（Mike Pompeo）周三（9/25）表示，部分中國公司及個人因違反伊朗制裁禁令，而正接受美國的相關制裁。\n \n美國之音報導，美國財政部周三在其官網上公佈了這次最新制裁的對象，包括5名中國公民和6家中國實體。龐皮歐在紐約聯大會議期間參加一次會議時說：「正如我們對中國和所有國家所說的那樣：要知道我們將對每一次違反禁令進行制裁。」\n \n龐皮歐還說，華府正努力讓各國了解跟伊朗革命衛隊做生意的風險，美國將懲罰那些違反制裁並且繼續跟伊朗接觸的實體和個人。\n \n據悉，這6家被制裁的中國實體是中遠海運（大連）有限公司、大連中遠海運油運船員船舶管理有限公司、中和石油有限公司、昆侖航運有限公司，昆侖控股有限公司和飛馬88有限公司。\nhttps://tw.news.appledaily.com/international/realtime/20190926/1639203</code></pre>"},{"pid":"4c45f0824fe9a3c57fff015cd151eb10908e1817","tid":1625312,"uid":261478,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:57:02.000Z","msg":"聽曰港島記住係和平遊行<br />\n盡量吸多D和理非出黎<br />\n和理非唔好怕無不反對通知書<br />\n香港已經唔講法律<br />\n有不反對通知書都照拉鳩你架啦<br />\n所以聽日為香港全世界出黎港島<br />\n勇和一家目標300萬人和平遊行<br />\n畀人知道香港人係和平嘅<br />\n暴力嘅係政府<br />\n要吸多D國際支持<br />\n<br />\n同時我唔反對衝衝子去衝<br />\n但記住要散水返左屋企先<br />\n避免畀狗圍無路走唔到<br />\n返左屋企之後再係屋企步行範圍內快閃游擊<br />\n拆鐵拆政府建築幫中資國企裝修<br />\n裝修到星期二開唔到門就變相三罷<br />\n唔好等有狗出現就要散水轉場<br />\n記住我地優勢係人多機動性高<br />\n攰同餓就返屋企食飯休息回滿升先再第日出過<br />\n有唔對路就返屋企訓覺唔好送頭<br />\n<br />\n幫手推POST<br />\n<a href=\"https://lihkg.com/thread/1626523/page/1\" target=\"_blank\">https://lihkg.com/thread/1626523/page/1</a>"},{"pid":"cec0fbafe0514dd02b0d68698871422f50d6c143","tid":1625312,"uid":264806,"like":0,"dislike":0,"score":0,"quote":{"pid":"eddc489adf2bbfc832358d97d4feeb3d6b4860ce","tid":1625312,"uid":116526,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c76f7941a602d5afcd5f3bae3d71f06861339d9","tid":1625312,"uid":87511,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-05T13:39:35.000Z","msg":"林鄭出入總有至少5部豬籠/衝鋒護送<br />\n你諗到嘅嘢，POPO點會諗唔到"},"citedBy":2,"replyTime":"2019-10-05T13:40:31.000Z","msg":"建制派有好多議員"},"citedBy":0,"replyTime":"2019-10-06T22:52:36.000Z","msg":"其實，咁耐以黎都無人搞CCTVB袁志偉呢件人型畜牲，就可以知道，大家係幾咁斯文"}]}