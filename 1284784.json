biggrin.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-07-04T22:20:59.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-07-04T22:56:57.000Z","msg":"On79佢先唔撚會理你。你估無啦啦幫港共捉人佢有so?"},{"pid":"997acb10d959d804b27325ddd5fa5ba7fd85d19e","tid":1284784,"uid":201828,"like":1,"dislike":0,"score":1,"quote":{"pid":"630184858a373d4befc8530cf925f01abc1c3742","tid":1284784,"uid":43964,"like":1,"dislike":0,"score":1,"quote":{"pid":"60ead52427fc97dcd142450031f19291a7d89317","tid":1284784,"uid":100423,"like":4,"dislike":0,"score":4,"quote":{"pid":"36c34bb7129d829c9ad1e6926a2311355af9f4fb","tid":1284784,"uid":225798,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2019-07-04T14:27:54.000Z","msg":"轉機地點唔好北京 上海 曼谷 新加坡 <br />\n<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-07-04T22:20:59.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-07-04T22:56:57.000Z","msg":"On79佢先唔撚會理你。你估無啦啦幫港共捉人佢有so?"},"citedBy":0,"replyTime":"2019-07-04T23:08:09.000Z","msg":"表面上係港共，枱底會係中共出聲要人。<br />\n你諗下呢幾個國家會唔賣賬？<br />\n好似之前去德國果兩位，你估真係港共開聲要人咩，咪又係中共枱底要德國交人，呢啲算係外交嘅嘢，港共係無權力咁做。"},{"pid":"0c24c92902379d23b8f3cbb16f0f917792647e5b","tid":1284784,"uid":201828,"like":1,"dislike":0,"score":1,"quote":{"pid":"36c34bb7129d829c9ad1e6926a2311355af9f4fb","tid":1284784,"uid":225798,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2019-07-04T14:27:54.000Z","msg":"轉機地點唔好北京 上海 曼谷 新加坡 <br />\n<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-04T23:12:40.000Z","msg":"琴日有個 post, 好似係鄭立講嘅，唔好喺香港直飛，要轉機。<br />\n因為如果申請唔批或者任何原因唔可以俾你入境，佢會遺返你去上機去德國嘅出發點，所以要考慮清楚點樣轉機，去邊到轉機。可以嘅話，盡量去民主國家，唔會賣賬俾中共嘅國家轉機，會多一重保障。"},{"pid":"ace5e7439e6ed8e50444abb9014dd778fe633252","tid":1284784,"uid":225798,"like":0,"dislike":0,"score":0,"quote":{"pid":"630184858a373d4befc8530cf925f01abc1c3742","tid":1284784,"uid":43964,"