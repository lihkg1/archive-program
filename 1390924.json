blank\">https://lih.kg/1390913</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"454f26f85c7bc07e649354b1ffd2fb9a19ce1fa3","tid":1390924,"uid":156632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T09:52:08.000Z","msg":"<img src=\"https://na.cx/i/oJD8VMC.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FoJD8VMC.png&h=e8b18113&s={SIZE}\" />"},{"pid":"3d5fca17be4ac2095835c93b42708b4f67930b94","tid":1390924,"uid":156632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T09:53:30.000Z","msg":"<img src=\"https://na.cx/i/nkzzRkO.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnkzzRkO.png&h=c7c5f93d&s={SIZE}\" />"},{"pid":"6f73ad010944b999585756f6f3c846c7a3218c8b","tid":1390924,"uid":156632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T09:53:43.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3cf6b84b24eeb5f3d7d713d3b445ce47a9d2bca0","tid":1390924,"uid":240522,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T09:53:45.000Z","msg":"推"},{"pid":"3d120fe2a18efc5d4430ba49472e6febeabf1527","tid":1390924,"uid":156632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T09:54:06.000Z","msg":"<img src=\"https://na.cx/i/W4Wiyzk.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FW4Wiyzk.png&h=2c0f1ae8&s={SIZE}\" />"},{"pid":"5e6977e14f8daab8b334fc8c5fb3dca9b24eb803","tid":1390924,"uid":268725,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T09:56:07.000Z","msg":"我會罷工<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n<img src=\"https://na.cx/i/ZTgB36g.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZTgB36g.png&h=c203fc4f&s={SIZE}\" /><img src=\"https://na.cx/i/ZX9PEEB.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZX9PEEB.png&h=f886d751&s={SIZE}\" /><br />\n<br />\n堅持五大訴求 拒絕警黑勾結<br />\n<br />\n1. 徹底撤回逃犯修訂條例<br />\n2. 釋放所有因反送中被捕人士並承諾永不追究<br />\n3. 撤回暴動定性<br />\n4. 追究警察濫權濫暴(包括721元朗官警黑勾結事件)，成立獨立調查委員會<br />\n5. 立即實行雙普選"},{"pid":"68d53a8e2da9115875e8905c882f3118781b492d","tid":1390924,"uid":265064,"like":0,"dislike":0,"score":0,"quote":{"pid":"8adf6c00ffa45c390206f845e2b88bf9a78263e2","tid":1390924,"uid":156632,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-31T09:21:23.000Z","msg":"31/7/19 東區法院有過千市民響8號風球、西灣河海傍聚集，聲援45位被捕人士。在場一個男人極度虛弱，混身顫抖，好似一推就會跌咁。就算眾人勸籲、抬佢、迫佢坐低佢都掙扎唔願意休息。即使佢雙眼通紅、氣弱游絲，目光仍然非常非常堅定，堅持企住為被捕人士打氣。<br />\n<br />\n響呢個荒謬、不公不義嘅香港，或者嗰<span style=\"color: green;\">45個真香港人一輩子，甚或一百年後都翻唔到案，永遠背負污名。</span>佢地可能一世都得唔到公義，一世都會因為案底而失去人生好多好多機會，而當中年紀最細嘅只有16歲。16歲，假如你響呢個年紀就入獄、有案底，你嘅人生會係點呢？<br />\n<br />\n我問自己，<span style=\"font-size: x-large;\"><span style=\"color: red;\">到底係死亡可怕，定還是坐政治監、等待被釋放到警察國度可怕？<br />\n<br />\n到底係捱子彈捱棍可怕，定還是漫目無的咁做個無靈魂嘅豬可怕？</span></span><br />\n<br />\n政府對人民嘅訴求充耳不聞，對於警察嘅惡行視而不見，口就話會修補裂痕，但，由69到而家，佢地做過咩實事呢？我諗黎諗去都諗唔到。或者係派黑社會打自己嘅人民？鼓吹執法部門不擇手段？默許警方自立皇法濫暴、濫捕、濫射、濫殺？<br />\n<br />\n仲記唔記得傘運時警方用催淚彈激起社會幾大迴響？點解到左而家，催淚彈已經係基本消費，連警員持槍瞄準市民、棍打記者、盾撞細路，政府都可以繼續匿埋，「有佢啦過幾日冇事」？<br />\n<br />\n我地而家面對嘅係無賴嘅政權、無能嘅高官。而呢個政權呢班高官都唔係民選嘅。既然你地唔係佢老細，佢點解要理我地呢班賤民呢？有人話抗爭者阻人返工，但點解唔諗下，<span style=\"font-size: x-large;\"><span style=\"color: green;\">你努力打工其實係貢獻緊比一個連你死撚左都唔在乎嘅政府呢？</span></span>響政府眼中，我地連一粒螺絲都唔係。<br />\n<br />\n我同好多人一樣都好絕望，好想放棄。但每當我諗到咁做會令一眾視我如手足嘅「陌生人」傷心時、聽到「齊上齊落」時、見到memo紙上嘅打氣字句時，我都會堅持下去，特別係我知道我<span style=\"font-size: xx-large;\"><span style=\"color: red;\">要為嗰45個手足爭取下去，讓等待佢地釋放嘅唔係一個警察國度，而係一個公義廉明嘅香港。</span></span><br />\n<br />\n<br />\n平時要天文台打8號波難過登天，但今日佢就千依百順。有人懷疑政府係想籍此淡化昨晚葵芳白衫警渣槍，同埋天水圍黑社會煙花射市民兩件事。點都好，我地應該好好利用今日做該做嘅事<span style=\"color: teal;\"><br />\n-宣傳同參與85罷工<br />\n-支持遊行<br />\n-連一啲重要嘅po，遇到水軍要馬上回帖警告其他人出返上一頁唔好幫手推；參與一啲重要嘅討論；幫手推重要po<br />\n-連儂牆遍地開花<br />\n-等等等等，勿以善小而不為</span><br />\n<br />\n我知有好多人因為工作、家庭等等因素唔方便參與運動，但你都可以做好多嘢支持抗爭者<br />\n<span style=\"color: pink;\">-一聲「加油、支持」<br />\n-捐款到612人道支援基金 <a href=\"https://www.facebook.com/612Fund/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F612Fund%2F&d=0Ti31m2ePiHoIE7ADo8qnc3u7Zzj2Sx3DhCMrptFZ9w%3D&h=a121e334\" target=\"_blank\">https://www.facebook.com/612Fund/</a><br />\n-捐贈物資（你可以到現場，將物資交比後方嘅物資站，完全唔洗冒險走到前線；亦可以搵物資組，我不便響度公開tg ）<br />\n-見到不實資訊時，幫手糾正，避免更多人受騙</span><br />\n<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: green;\">我期待有一日，香港人出街唔再需要諗著咩色衫，遊客集會言論自由受保護，每個週末唔洗再到街上抗爭，擔港鐵時唔洗提心吊膽，遇到意外時唔洗猶豫打唔打999好，入醫院時唔洗擔心醫生會唔會加害於你，見到警察時唔洗擔心佢會叫黑社會打你，同埋<span style=\"color: red;\">期待我地大家對呢個屋企重拾希望嘅一日。</span></span></span><br />\n<br />\n<img src=\"https://na.cx/i/9bNqdkA.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F9bNqdkA.png&h=46fff8fa&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/b681v7h.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fb681v7h.png&h=abc4f25c&s={SIZE}\" /><img src=\"https://na.cx/i/gBy8VBw.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgBy8VBw.png&h=d553e9f4&s={SIZE}\" /><img src=\"https://na.cx/i/boqy6Jd.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fboqy6Jd.png&h=2c638c63&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-07-31T09:57:12.000Z","msg":"謝謝。大家都為那44個義士默默祈禱。"},{"pid":"d90557bc3a76a5fbc71dde788e28093c70110434","tid":1390924,"uid":156632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T10:03:09.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3b9f447b127cc4da66b3758589d3e13bcdb45384","tid":1390924,"uid":117968,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T10:03:40.000Z","msg":"推"},{"pid":"9e60f24ccf659ffe9b6fa9840dd53a70455ee6be","tid":1390924,"uid":156632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T10:06:05.000Z","msg":"<img src=\"https://na.cx/i/fAKsrYk.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2F