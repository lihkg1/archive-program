d632882ca35fc6b748eee5.png&h=9e9d8b59&s={SIZE}\" />"},{"pid":"ab8f61939122127b43038298ccaab76042efd6b5","tid":714010,"uid":51129,"like":0,"dislike":0,"score":0,"quote":{"pid":"c8d8456133a6cd1546c5a4bc72d5fa0832c4a616","tid":714010,"uid":187216,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2018-06-24T07:31:24.000Z","msg":"咁大家鳩計呢題:<br />\n<br />\nQ6.<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/24/153045_5712e31c0dd632882ca35fc6b748eee5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F24%2F153045_5712e31c0dd632882ca35fc6b748eee5.png&h=9e9d8b59&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-06-24T08:04:11.000Z","msg":"13?"},{"pid":"fa20cf16a45510e03297880f594ab5ad56454308","tid":714010,"uid":169445,"like":0,"dislike":0,"score":0,"quote":{"pid":"c8d8456133a6cd1546c5a4bc72d5fa0832c4a616","tid":714010,"uid":187216,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2018-06-24T07:31:24.000Z","msg":"咁大家鳩計呢題:<br />\n<br />\nQ6.<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/24/153045_5712e31c0dd632882ca35fc6b748eee5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F24%2F153045_5712e31c0dd632882ca35fc6b748eee5.png&h=9e9d8b59&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-06-24T08:07:23.000Z","msg":"the degree of this polynomial is 210.  hence, in order to get x^{203} while expanding the product we only need consider in which factors we don't take the x^k but instead we take the -k.  the cases are as follows:<br />\n7<br />\n6+1<br />\n5+2<br />\n4+3<br />\n4+2+1.<br />\n<br />\nfor each of the above case, we get the corresponding coefficient for the x^{203} as follows:<br />\n-7<br />\n6<br />\n10<br />\n12<br />\n-8<br />\n<br />\ntherefore by summing all these we get the coefficient for the x^{203} in the final expression as 13."},{"pid":"76d8cd2f823fd0a1e50f27d0ea3440fd2d77be4e","tid":7140