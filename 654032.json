{"tid":654032,"cid":23,"subCid":0,"title":"高下立見","createTime":"2018-05-05T09:26:36.000Z","updateTime":"2018-05-29T08:44:35.000Z","uid":11779,"like":4,"dislike":11,"uniUserReply":15,"replies":[{"pid":"b9e05ba00668d1f5222f54c2ae4deb67680a38f2","tid":654032,"uid":11779,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-05T09:26:36.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/05/05/172154_253be56a060dc1fade0154f075ba781e.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F05%2F172154_253be56a060dc1fade0154f075ba781e.jpeg&h=dc980187&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/05/05/172155_ad3282b0c5214290736c31cdd34562ee.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F05%2F172155_ad3282b0c5214290736c31cdd34562ee.jpeg&h=87551458&s={SIZE}\" /><br />\n<br />\n第一幅同第二幅係強烈對比，第一用成個白川鄉黎襯果對新人，無論新人定個背景都好靚。<br />\n但第二幅就.......哈哈哈，唔睇介紹仲以為去左台灣合歡山，仲要紫鳩晒......如果我係對新人 山長水遠去到白川鄉，但結果影埋啲咁嘅相我一定開個攝影師齋，全世界最靚嘅景都可以影到咁，個攝影師實力絕對超勁。"},{"pid":"1a0ebae3658d8a6b5d9c8186c7a1a32f8a0c48b0","tid":654032,"uid":185376,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-05-05T09:29:48.000Z","msg":"做乜鳩"},{"pid":"90bfff5f1b1bcf0ed6f33643443a97c3dd99beeb","tid":654032,"uid":19932,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2018-05-05T09:30:10.000Z","msg":"第一張係幾𡃁<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"97c9f1e06a761bbb7fc7ef8b1df2609ac552f2b7","tid":654032,"uid":11779,"like":0,"dislike":2,"score":-2,"quote":{"pid":"90bfff5f1b1bcf0ed6f33643443a97c3dd99beeb","tid":654032,"uid":19932,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2018-05-05T09:30:10.000Z","msg":"第一張係幾𡃁<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-05T09:34:10.000Z","msg":"我都覺"},{"pid":"9ed96579b73a633150e12bfba762daf72fff8181","tid":654032,"uid":1177