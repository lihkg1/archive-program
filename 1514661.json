i\" />"},{"pid":"9d7a07dafdd3c467990c5dea7ad2564596a1ade5","tid":1514661,"uid":219590,"like":0,"dislike":0,"score":0,"quote":{"pid":"455c4131415e00301df02166c15f5767baddfaed","tid":1514661,"uid":35818,"like":0,"dislike":0,"score":0,"quote":{"pid":"7978483378098ea903220a9b9f9ae411267ddb7a","tid":1514661,"uid":3775,"like":7,"dislike":0,"score":7,"citedBy":3,"replyTime":"2019-08-28T23:18:27.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n中國真係神奇國度黎<br />\n日日有天災人禍都唔會冧"},"citedBy":1,"replyTime":"2019-08-28T23:26:55.000Z","msg":"13億死極都仲有13億<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-28T23:34:50.000Z","msg":"其實我懷疑落後少少既地方仍然有人生幾十個，所以點死都唔會底過13億<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"d2092af92bbc4184b60f2570f04b8d52ebfb6569","tid":1514661,"uid":3161,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-28T23:54:59.000Z","msg":"有毒放射性廢料無毒"},{"pid":"a105ef3ae9e780d8c2d852af5484d623bcd1d1c2","tid":1514661,"uid":13343,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T23:58:59.000Z","msg":"畀核技術 北泡畀得咁爽吖喇"},{"pid":"661285172454cf5333fc548976113d763bb3f4c8","tid":1514661,"uid":219590,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2092af92bbc4184b60f2570f04b8d52ebfb6569","tid":1514661,"uid":3161,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-28T23:54:59.000Z","msg":"有毒放射性廢料無毒"},"citedBy":0,"replyTime":"2019-08-28T23:59:04.000Z","msg":"潛台詞：正負得負，點都有毒<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"3c262fb90f149ad670cee718cc0d4dbadadf2f19","tid":1514661,"uid":51701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T00:05:08.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">吉x家東北大米</span></span>"},{"pid":"bdd375c44358ca67d772f5b3269283e2b7c7167f","tid":1514661,"uid":236646,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T00:07:05.000Z","msg":"可能養到幅射都有抗體"},{"pid":"74ec79f99b07bb93121012d03a885dc990a97d76","tid":1514661,"uid":183228,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T00:11:11.000Z","msg":"我們中國的人民喝有毒放射性廢料能生存一年<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"ddad9dcef60f0d73fd1fcf736a594f637e301942","tid":1514661,"uid":77968,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T00:14:04.000Z","msg":"The Host"},{"pid":"fd0e04656cd3665b4424a05bb567e750299679d3","tid":1514661,"uid":202466,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T00:57:35.000Z","msg":"一直都係生化人，幅射都唔驚"},{"pid":"169817de89288c7de15c9a1fc961166128a4aafb","tid":1514661,"uid":253016,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T01:13:52.000Z","msg":"有毒放射性廢料遭到支那污染"},{"pid":"294e2d1cbfc6decf59efd1e011dd00efa1f6b49f","tid":1514661,"uid":141508,"like":1,"dislike":0,"score":1,"quote":{"pid":"39fd035b46f1a799e11baad24ee0d19c1de26ee8","tid":1514661,"uid":219590,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-28T23:07:14.000Z","msg":"皇天擊殺！支爆日子不遠！<br />\n<br />\n<br />\n殘體字慎入<br />\n<br />\n<img src=\"https://na.cx/i/e3j4Aid.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fe3j4Aid.jpg&h=68bc9daa&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-08-29T01:15:22.000Z","msg":"<a href=\"https://www.thesun.co.uk/news/9766215/north-korea-nuclear-leak-uranium-mines/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thesun.co.uk%2Fnews%2F9766215%2Fnorth-korea-nuclear-leak-uranium-mines%2F&d=BKn7HUA2FwSq4MnMa2nFTLM5QgR%2FpIHXQ%2BfAgFWVWJ0%3D&h=093ccdce\" target=\"_blank\">https://www.thesun.co.uk/news/9766215/north-korea-nuclear-leak-uranium-mines/</a><br />\n幫你補個太陽報Source<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"fb43ad8ed3876c81f9d3f15376ae083eba2f7e35","tid":1514661,"uid":192043,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T01:21:52.000Z","msg":"3.6 roentgen <br />\nNot great. Not terrible"}]}