/lm2/clown.gif\" class=\"hkgmoji\" />"},{"pid":"94be2835889c129ce0edc5b324338594dd64e6b7","tid":2114592,"uid":245813,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-07-19T03:41:10.000Z","msg":"用字同結構簡單時<br />\n「講呢啲低B英文有冇小學程度？字都唔識多隻好意思扮勁學人講英文」<br />\n<br />\n用字同結構複雜時<br />\n「喺香港讀死書以為啲字難就代表勁，事實人哋英國美國人講英文唔會咁」<br />\n<br />\n其實講咩都會有人笑有人屌<br />\n就好似父子賣驢嘅故事咁<br />\n唔好理呢啲人就得"},{"pid":"35f93a325ffda6c90615ece3301ee2715ac04fe3","tid":2114592,"uid":60321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-19T03:41:42.000Z","msg":"i agree"},{"pid":"cfd1e2e7beeedb4f872ed33eda7aa64010e708fd","tid":2114592,"uid":325421,"like":1,"dislike":1,"score":0,"quote":{"pid":"e0f43a2003909ae6f8333ffdcab1d88a12fd0434","tid":2114592,"uid":194120,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-19T03:37:58.000Z","msg":"英文最正宗口音好似係Oxford,中學時教英文個呀Sir佢後生喺嗰邊讀書,佢講嘅英文發音同一般聽嘅真係唔同."},"citedBy":0,"replyTime":"2020-07-19T03:43:39.000Z","msg":"語言又好難分正宗唔正宗既，將oxford口音既人放係其他英文母語社區，當地人都會覺得佢講既英文唔正宗，但係雙方都唔會因此而自卑。"},{"pid":"2ee5040399158bdfc3dde22a1d1c0c0a60751f11","tid":2114592,"uid":294648,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-19T03:44:17.000Z","msg":"國安法唔知幾時禁英文"},{"pid":"6daf68498c4580ca6fd665bae4f2036ed08cc23a","tid":2114592,"uid":63400,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-19T03:46:13.000Z","msg":"正宗港式口音才是王道<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"becd6dcb2bb8741db2980041167564c7d4531339","tid":2114592,"uid":174339,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-07-19T03:46:47.000Z","msg":"想講咪講<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n其實你講到似模似樣啲人都唔會care<br />\n唯一care嘅係嗰班chock到口音嘅人<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> 因為自己裝模作樣 over咗 所以要以一副高人一等嘅姿態說服自己先係standard 其他人唔係黎掩飾嗰份尷尬<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> but wfc <br />\n個人覺得講英文最重要係流暢 同埋聽得明 令人覺得舒服就已經meet到個standard<br />\n身邊總有幾個會chock口音出黎嘅 咁佢地練到