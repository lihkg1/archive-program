5985e21f24f42f5733d153a2ab49e72bef9e27","tid":1131364,"uid":134071,"like":0,"dislike":0,"score":0,"quote":{"pid":"e407dcfc5560d304ae6c117ecd9a8ed4260adab8","tid":1131364,"uid":98386,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-30T03:39:55.000Z","msg":"商界班仆街自己驚落鑊 但推大粒墨去死"},"citedBy":0,"replyTime":"2019-04-30T03:43:45.000Z","msg":"東方唔驚<br />\n<br />\n<img src=\"http://na.cx/i/4eYzpf9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fna.cx%2Fi%2F4eYzpf9.jpg&h=84cd7d35&s={SIZE}\" />"},{"pid":"2b4691fe5c83f053fd4963c87babb01f2c236727","tid":1131364,"uid":46033,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-30T04:01:50.000Z","msg":"正, 撞岩我無產,  <br />\n有錢佬睇路呀"},{"pid":"38a548939ed2726c3858ba171432f828d8364081","tid":1131364,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-30T04:28:46.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"75bfacf621a6939a01ec7033436c2b8cd775451e","tid":1131364,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-30T04:32:57.000Z","msg":"班權貴有錢佬商家先醒<br />\n叫你地班窮人 傻閪出手<br />\n你話窮人無影響？ 有，隨時比人砌生豬肉<br />\n講抄家既功效一定權貴有錢佬商家大好多<br />\n但班權貴商家有錢佬日日做班窮閪去反，自己乜都唔做<br />\n<br />\n反到就繼續奴役壓榨你班窮閪<br />\n反唔到就輕輕鬆鬆快快樂樂移民去外國"},{"pid":"3b5e5979a7fd6a3b5499fb5d09acb9bc1840450d","tid":1131364,"uid":76310,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b4691fe5c83f053fd4963c87babb01f2c236727","tid":1131364,"uid":46033,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-30T04:01:50.000Z","msg":"正, 撞岩我無產,  <br />\n有錢佬睇路呀"},"citedBy":0,"replyTime":"2019-04-30T04:34:19.000Z","msg":"有錢佬：<br />\n慫恿班窮閪去反咪得<br />\n<br />\n反到繼續留港壓榨港豬<br />\n反唔到就移民去外國嘆世界<br />\n<br />\n有錢佬永遠都係贏家"},{"pid":"e62fa9517f67731e41f8bed1add719adefb4d558","tid":1131364,"uid":41394,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-30T04:34:41.000Z","msg":"正  好想有生之年見到"},{"pid":"e7b40a5ad5b95b3449e2e7389b6382b738183c48","tid":1131364,"uid":76310,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-04-30T04:36:37.000Z","msg":"所以我先一早話因為想為香港爭取民主既人而坐監唔值得<br />\n成班都係仆街<br />\n為左呢班自私自利撚樣值得咩"},{"pid":"986f6cf2e8a06df47392446d52eaf382fe9b0ae3","tid":1131364,"uid":47259,"like":0,"dislike":0,"score":0,"quote":{"pid":"fd838f4cdee4ad440454defb5456d440fbb39fc8","tid":1131364,"uid":79563,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2019-04-29T16:01:51.000Z","msg":"<blockquote>華人置業（127）前主席劉鑾雄早前就修訂逃犯條例申請司法覆核許可，入稟狀表明，一旦通過修例，他或流亡海外；而在本年3月，劉鑾雄辭去至少8家私人公司、包括BVI及香港公司的董事或授權代表的職務，涉及資產市值數以百億元計，有會計師指劉或憂慮修例後資產可能遭凍結而作出有關安排</blockquote><br />\n<br />\n會唔會當係洗黑錢, 拉埋甘比?"},"citedBy":0,"replyTime":"2019-04-30T04:39:55.000Z","msg":"呢個時候就大大力示範乜叫雖遠必誅喇<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"2a395f8065a9a2f467d00d95ddf15961d4a00196","tid":1131364,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"3240d98d085062761a0e669211a7fa69094f0164","tid":1131364,"uid":55913,"like":15,"dislike":0,"score":15,"citedBy":1,"replyTime":"2019-04-29T16:04:50.000Z","msg":"好呀 黨而家缺水 大家應該捐身家<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-04-30T04:51:38.000Z","msg":"共你產<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"267d49a48351070aa1281eabe4aba2372741964c","tid":1131364,"uid":51937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-30T05:10:08.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"dfe9d1995ea9e49681d3c2c5e68414d9604f8093","tid":1131364,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-30T05:29:50.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"}]}