http://hk.on.cc/hk/bkn/cnt/news/20180528/mobile/bkn-20180528173651495-0528_00822_001.html</a>"},"citedBy":0,"replyTime":"2018-05-28T12:31:22.000Z","msg":"&gt; &quot;30乘客海上漂流&quot; <br />\n百份報 <img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"85eeb20843dce7df48031514a58ceddd926bac7d","tid":681774,"uid":85819,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-05-28T12:32:48.000Z","msg":"此回覆已被刪除"},{"pid":"30daea7024422318c032365cf9860c50714f5ecd","tid":681774,"uid":48334,"like":4,"dislike":0,"score":4,"quote":{"pid":"85eeb20843dce7df48031514a58ceddd926bac7d","tid":681774,"uid":85819,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-05-28T12:32:48.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-05-28T12:36:24.000Z","msg":"本能反應"},{"pid":"5de691c36c68060bb4ce65854620a70cb89aaeb5","tid":681774,"uid":123082,"like":10,"dislike":0,"score":10,"quote":{"pid":"180ae8099649ae6d5da96749a5f33a3aa606de63","tid":681774,"uid":17510,"like":20,"dislike":0,"score":20,"quote":{"pid":"3d53ce512b6fcc8c7a4b45ed96d25ea1cff1d8df","tid":681774,"uid":26332,"like":19,"dislike":1,"score":18,"quote":{"pid":"fe73cdd92197b87a2e448e7aeeb02e241afedb20","tid":681774,"uid":1082,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2018-05-28T10:28:35.000Z","msg":"唔實淨點行咁多年<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-28T10:33:15.000Z","msg":"如果比着鄰國啲船，會唔會一撞即散<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-28T12:23:56.000Z","msg":"新渡輪果啲一撞即刻入