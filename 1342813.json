},{"pid":"2e1328dc4bda779116b8f41a122d1090b6e2d903","tid":1342813,"uid":272773,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T18:21:55.000Z","msg":"個頭未撚set好<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d5c5230273a014bec6af76b2dd4a1ea6482ecc6a","tid":1342813,"uid":16676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T18:23:57.000Z","msg":"凌晨4點先出現 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"18fa2024b9ff8b95f078a3565ae5dcc8026a0e16","tid":1342813,"uid":150121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T01:28:28.000Z","msg":"你期待佢講d咩"}]}