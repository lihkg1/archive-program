564ba397e4a4e944d3e4a154346bbd6","tid":1631110,"uid":264314,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T15:07:17.000Z","msg":"p"},{"pid":"d64d91f50c5d35ccf1c53aa93fa40279b5ccdd27","tid":1631110,"uid":143570,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T15:12:12.000Z","msg":"push"},{"pid":"998d12c24346a50f532b543268da34d040f1f116","tid":1631110,"uid":7179,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T15:13:47.000Z","msg":"推<br />\n<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" />"},{"pid":"f270d7b51735ed48de2eecac03de33c0cf001e2f","tid":1631110,"uid":320078,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-06T15:14:26.000Z","msg":"一定要<br />\n白送頭唔係辦法"},{"pid":"37e16708f467f524a234e74e5c3f9c0a2e79ca40","tid":1631110,"uid":153015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T15:15:37.000Z","msg":"定死線<br />\n<br />\n雙十賀台慶<br />\n<br />\n有冇得諗？<br />\n<br />\n之前開過post問，集思廣益"},{"pid":"169bc3a0d49fa9435b6cbf7041f211e2c96d91ac","tid":1631110,"uid":99686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T15:17:12.000Z","msg":"pish"},{"pid":"0f5efce4f67604aa4fc73d057d4b10d70779bd08","tid":1631110,"uid":64743,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T15:20:55.000Z","msg":"過去幾個月好多人煽同狗對抗<br />\n要贏佢地<br />\n其實根本就係贏唔到，我地根本冇槍<br />\n目標達到就應該走<br />\n仲有命先可以打落去<br />\n死人係乜都做唔到"},{"pid":"157cf7a28f48d8113663bd73c519f6bbd5975418","tid":1631110,"uid":53610,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T15:23:54.000Z","msg":"戰略一定係快閃<br />\n但係每次出嚟目的就要再討論下，唔好次次都剩係出嚟裝修"},{"pid":"556d81225c9aaf2785323b8ecfdfe1350a156848","tid":1631110,"uid":320902,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T15:24:11.000Z","msg":"推<br />\n<a href=\"https://www.facebook.com/100004388460997/posts/1424716221017980?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F100004388460997%2Fposts%2F1