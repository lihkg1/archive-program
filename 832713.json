5%A5%B9-080500852.html&d=3MLEuntUU0VPnla4ey6UyJ4%2BuNhYgvPKbWZYs3KJomg%3D&h=67ff1875\" target=\"_blank\">https://hk.mobi.yahoo.com/celebrity/劉愷威否認有新歡britney-根本不認識她-080500852.html</a><br />\n<br />\n<img src=\"https://cdn.hk01.com/di/media/images/1893794/org/5b2ed8ec784cb684863cc7da32de20b7.jpg/I-muF4gcB1WjAqr2qcfY9iI_vALdCotd9CVwIfQlcCE?v=w1120\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F1893794%2Forg%2F5b2ed8ec784cb684863cc7da32de20b7.jpg%2FI-muF4gcB1WjAqr2qcfY9iI_vALdCotd9CVwIfQlcCE%3Fv%3Dw1120&h=c0fb1222&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-09-28T23:34:19.000Z","msg":"兩個膠面人合照<img src=\"/assets/faces/mf/clown.gif\" class=\"hkgmoji\" />"},{"pid":"2f50075c309f6c73dd0d09791326476d07f64a3d","tid":832713,"uid":71496,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-29T01:28:23.000Z","msg":"<img src=\"/assets/faces/mf/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"a38eebf958f20ec52fba392bba844c9f02149d84","tid":832713,"uid":21279,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-29T03:08:41.000Z","msg":"點忍"},{"pid":"e69602ea594dbcdf35fa0b28079513eb3a2597f7","tid":832713,"uid":101657,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-29T04:10:28.000Z","msg":"成班大造人<img src=\"/assets/faces/mf/dead.png\" class=\"hkgmoji\" />"},{"pid":"1655b4106063290af3d0de2e4a0478b2c7b920f4","tid":832713,"uid":14055,"like":0,"dislike":0,"score":0,"quote":{"pid":"e69602ea594dbcdf35fa0b28079513eb3a2597f7","tid":832713,"uid":101657,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-29T04:10:28.000Z","msg":"成班大造人<img src=\"/assets/faces/mf/dead.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-29T10:37:05.000Z","msg":"照完鏡再返黎留言<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"}]}