:0,"quote":{"pid":"db9addf5d0534316b80ef330e1f8928250409ca4","tid":2489821,"uid":90282,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2021-04-15T07:49:51.000Z","msg":"<span class=\"x-large\">區院高院唔夠人啊</span>"},"citedBy":1,"replyTime":"2021-04-15T08:43:50.000Z","msg":"邊個庭要人多啲"},"citedBy":1,"replyTime":"2021-04-15T08:48:18.000Z","msg":"高院送車"},{"pid":"5dc315d3152b537d3526218ac78b913265a054c3","tid":2489821,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-15T09:06:34.000Z","msg":"12 港人之一的越南籍男學生黃臨福去年底被遣返回港後，一直還押至今。他在港涉及的縱火和管有汽油彈案今（15日）在區域法院提訊，辯方透露黃臨福打算認企圖縱火、管有物品意圖摧毀財產兩罪。案件押後至 7 月 6 日正式聽取答辯及求情，黃臨福今日無保釋申請，須繼續還押。<br />\n<br />\n現年 17 歲的黃臨福（案發時 16 歲，中二學生）原被控有意圖而企圖縱火、管有攻擊性武器及不依期歸押。控方今修訂控罪，改為只控告有意圖而企圖縱火和管有物品意圖摧毀或損壞財產罪。<br />\n<br />\n控罪指，他於 2019 年 10 月 14 日在旺角警署外企圖用火損壞旺角警署；於同日在住所內管有用啤酒瓶製成的三個汽油彈。<br />\n<br />\n<a href=\"https://www.thestandnews.com/court/12-%E6%B8%AF%E4%BA%BA-%E9%BB%83%E8%87%A8%E7%A6%8F%E6%93%AC%E8%AA%8D%E4%BC%81%E5%9C%96%E7%B8%B1%E7%81%AB-%E7%AE%A1%E6%B1%BD%E6%B2%B9%E5%BD%88-%E6%B2%92%E7%94%B3%E4%BF%9D%E9%87%8B%E6%8A%BC%E8%87%B3-7-%E6%9C%88-6-%E6%97%A5%E7%AD%94%E8%BE%AF/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F12-%25E6%25B8%25AF%25E4%25BA%25BA-%25E9%25BB%2583%25E8%2587%25A8%25E7%25A6%258F%25E6%2593%25AC%25E8%25AA%258D%25E4%25BC%2581%25E5%259C%2596%25E7%25B8%25B1%25E7%2581%25AB-%25E7%25AE%25A1%25E6%25B1%25BD%25E6%25B2%25B9%25E5%25BD%2588-%25E6%25B2%2592%25E7%2594%25B3%25E4%25BF%259D%25E9%2587%258B%25E6%258A%25BC%25E8%2587%25B3-7-%25E6%259C%2588-6-%25E6%2597%25A5%25E7%25AD%2594%25E8%25BE%25AF%2F&d=RjdfG9uxtkM%2FelS3aO62sIleFUCahE4vUWSiCYLfmAs%3D&h=14eb7a9d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F12-%25E6%25B8%25AF%25E4%25BA%25BA-%25E9%25BB%2583%25E8%2587%25A8%25E7%25A6%258F%25E6%2593%25AC%25E8%25AA%258D%25E4%25BC%2581%25E5%259C%2596%25E7%25B8%25B1%25E7%2581%25AB-%25E7%25AE%25A1%25E6%25B1%25BD%25E6%25B2%25B9%25E5%25BD%2588-%25E6%25B2%2592%25E7%2594%25B3%25E4%25BF%259D%25E9%2587%258B%25E6%258A%25BC%25E8%2587%25B3-7-%25E6%259C%2588-6-%25E6%2597%25A5%25E7%25AD%2594%25E8%25BE%25AF%2F&h=dbb623b6\" data-auto-link target=\"_blank\">https://www.thestandnews.com/court/12-%E6%B8%AF%E4%BA%BA-%E9%BB%83%E8%87%A8%E7%A6%8F%E6%93%AC%E8%AA%8D%E4%BC%81%E5%9C%96%E7%B8%B1%E7%81%AB-%E7%AE%A1%E6%B1%BD%E6%B2%B9%E5%BD%88-%E6%B2%92%E7%94%B3%E4%BF%9D%E9%87%8B%E6%8A%BC%E8%87%B3-7-%E6%9C%88-6-%E6%97%A5%E7%AD%94%E8%BE%AF/</a>"},{"pid":"43fb808cff9e9a5b84a2518247ed5e83254f559f","tid":2489821,"uid":87985,"like":0,"dislike":0,"score":0,"quote":{"pid":"b60f59905398420c53de39688764d930220a0193","tid":2489821,"uid":90282,"like":0,"dislike":0,"score":0,"quote":{"pid":"7f6c590bbdc995d29e40df29737238da4e9073d8","tid":2489821,"uid":87985,"like":0,"dislike":0,"score":0,"quote":{"pid":"db9addf5d0534316b80ef330e1f8928250409ca4","tid":2489821,"uid":90282,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2021-04-15T07:49:51.000Z","msg":"<span class=\"x-large\">區院高院唔夠人啊</span>"},"citedBy":1,"replyTime":"2021-04-15T08:43:50.000Z","msg":"邊個庭要人多啲"},"citedBy":1,"replyTime":"2021-04-15T08:48:18.000Z","msg":"高院送車"},"citedBy":0,"replyTime":"2021-04-15T09:36:52.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"8748560cd0762a0686b88ba69535870b2e30daef","tid":2489821,"uid":53498,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-15T09:37:18.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d6f606ef53fbb9783fe84037186c01f0e09f1256","tid":2489821,"uid":511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-15T09:37:53.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"