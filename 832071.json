d":832071,"uid":103362,"like":16,"dislike":1,"score":15,"citedBy":1,"replyTime":"2018-09-22T14:29:33.000Z","msg":"回歸後的香港<br />\n<br />\n由高峰到低谷，市民個種無力感，一定好有戲味"},{"pid":"fb19d8d9d687d7e5cc1f840b9889b43dfc1c8ad1","tid":832071,"uid":99642,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-22T14:30:36.000Z","msg":"史記<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5742ca854b872bd80812d13dd111f9bc1ba65907","tid":832071,"uid":92230,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-09-22T14:30:49.000Z","msg":"<blockquote>回歸後的香港<br />\n<br />\n由高峰到低谷，市民個種無力感，一定好有戲味</blockquote><br />\nTruman Show..."},{"pid":"070a86c323556120f7086e30b09cd93afab13dca","tid":832071,"uid":67500,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-22T14:38:30.000Z","msg":"高歡  宇文泰"},{"pid":"f233650dc277bcbee47a7c44e103828f1b726c08","tid":832071,"uid":155883,"like":1,"dislike":0,"score":1,"quote":{"pid":"e0cd41355f9a229a410aa74cf22982b3c7171b80","tid":832071,"uid":41375,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-09-22T14:28:41.000Z","msg":"<a href=\"https://zh.m.wikipedia.org/zh-hk/萬曆朝鮮之役\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wikipedia.org%2Fzh-hk%2F%E8%90%AC%E6%9B%86%E6%9C%9D%E9%AE%AE%E4%B9%8B%E5%BD%B9&d=wK0BA4HHJ9AIvyreE2hJBXIou9iuErJt32EjuWI86Zw%3D&h=16606351\" target=\"_blank\">https://zh.m.wikipedia.org/zh-hk/萬曆朝鮮之役</a>"},"citedBy":1,"replyTime":"2018-09-22T14:52:44.000Z","msg":"<img src=\"/assets/faces/lomoji/03.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/03.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/03.png\" class=\"hkgmoji\" />"},{"pid":"b2493e079f5102dd5461ba07d7571b089a5d4351","tid":832071,"uid":175560,"like":14,"dislike":1,"score":13,"citedBy":0,"replyTime":"2018-09-22T14:53:34.000Z","msg":"商末：有妲己<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n春秋：齊桓公同管仲，其實管仲個人幾仆街<br />\n戰國：孫臏vs龐涓、吳起、信陵君合縱<br />\n秦同西漢拍得太濫，連光武中興都有人拍埋，東漢就一直戚宦戚宦悶咗百幾年最後到三國<br />\n西晉大把嘢拍，賈南風、八王之亂、永嘉之亂，然後東晉王敦之亂，北方可以拍羯人石勒、符堅王猛、淝水<br />\n南北朝大陸都拍過，但冇人拍劉裕篡位<br />\n隋就超多靚女，張麗華、孔貴嬪、宣華夫人<br />\n唐又係拍到悶，初唐盛唐中唐晚唐都拍過<br />\n五代我覺得拍馮道傳會好正，歷事五朝超級打工皇帝<br />\n兩宋我最想睇宋末英烈傳，尤其睇完田中芳樹本《海嘯》覺得南宋好慘<br />\n元朝收皮，唯一有興趣反元起義<br />\n明朝又係前中後都拍過晒，清朝一樣<br />\n民國就拍吓北伐+共產黨喺後方搞屎棍啦"},{"pid":"5048ba5496deb902614eb0c02e59e1f56019d395","tid":832071,"uid":124268,"like":1,"dislike":0,"score":1,"quote":{"pid":"f233650dc277bcbee47a7c44e103828f1b726c08","tid":832071,"uid":155883,"like":1,"dislike":0,"score":1,"quote":{"pid":"e0cd41355f9a229a410aa74cf22982b3c7171b80","tid":832071,"uid":41375,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-09-22T14:28:41.000Z","msg":"<a href=\"https://zh.m.wikipedia.org/zh-hk/萬曆朝鮮之役\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wikipedia.org%2Fzh-hk%2F%E8%90%AC%E6%9B%86%E6%9C%9D%E9%AE%AE%E4%B9%8B%E5%BD%B9&d=wK0BA4HHJ9AIvyreE2hJBXIou9iuErJt32EjuWI86Zw%3D&h=16606351\" target=\"_blank\">https://zh.m.wikipedia.org/zh-hk/萬曆朝鮮之役</a>"},"citedBy":1,"replyTime":"2018-09-22T14:52:44.000Z","msg":"<img src=\"/assets/faces/lomoji/03.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/03.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/03.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-22T14:56:28.000Z","msg":"中日唔敢拍，南韓係咁拍，但只敢拍海戰<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"1cefaf88b1b0d1d2a3c3a7ea5d6f0723432e0d95","tid":832071,"uid":4826,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-22T14:57:39.000Z","msg":"淝水"},{"pid":"5d806593fd12bb651cc04101e519457e26e9367c","tid":832071,"uid":77257,"like":0,"dislike":0,"score":0,"quote":{"pid":"b0ac779d55f87ba84f05a70807e2d785b87fb741","tid":832071,"uid":13653,"like":2,"dislike":0,"score":2,"quote":{"pid":"faa0da195857a5fb64d48e810057d6e219f6a40e","tid":832071,"uid":66195,"like":46,"dislike":2,"score":44,"citedBy":2,"replyTime":"2018-09-22T14:17:07.000Z","