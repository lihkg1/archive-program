eplyTime":"2019-12-05T15:36:42.000Z","msg":"Dq左個民選校董又咁對記者同學，睇黎佢好撚想申請裝修<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"c691172e3ebddca355c07abd6b743957c2d83969","tid":1771134,"uid":63734,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T15:37:34.000Z","msg":"佢個女經歷完 我係街開香檳慶祝完再同佢講sorry囉<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"8ff96c9df972c69d89f27b6aba91f00072104246","tid":1771134,"uid":314947,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T15:38:15.000Z","msg":"順便幫推一下隔離po<br />\n<br />\n突發：科大宣布學生校董選舉結果無效！<br />\n<a href=\"https://lih.kg/1769423\" target=\"_blank\">https://lih.kg/1769423</a>"},{"pid":"bd46c8b203d49e67eff30429267e5e957f27b97e","tid":1771134,"uid":212843,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T15:39:05.000Z","msg":"光復科大<br />\n刻不容緩"},{"pid":"6019525a679544887cfe70b8b694cd5648c57fd6","tid":1771134,"uid":172596,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T15:39:57.000Z","msg":"推呀"},{"pid":"597f31228d5881ba0409347dc24e4e8c50ef6a42","tid":1771134,"uid":314947,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T15:40:13.000Z","msg":"推"},{"pid":"ada0d46522488c48b2a74a6bc9790b390100349b","tid":1771134,"uid":227153,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T15:40:17.000Z","msg":"科大高層都係垃圾"},{"pid":"2785cb4cadd1b98af941ed48c4ce197a42b64f21","tid":1771134,"uid":314947,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-05T15:41:34.000Z","msg":"幫推隔離<br />\n<br />\n［科大人必入］科大學生校董要重選，期間三個候選人都可以列席校董會議<br />\n<a href=\"https://lih.kg/1768737\" target=\"_blank\">https://lih.kg/1768737</a>"}]}