/faces/normal/kiss.gif\" class=\"hkgmoji\" /> ：你諗諗佢啦<br />\n<br />\n我馬上衝出門口，出到去見到女友老豆，佢仲問我做乜面都紅埋，係咪好熱。<br />\n<br />\n我落到樓下，充滿無限疑問<br />\n<br />\n心諗：我夠唔夠套係身呢？搞幾次慳一半，好似真係 何樂而不為。但係屌左既話，第日佢仲係咪我岳母呢？！ <br />\n<br />\n求解！<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"89efb1d1dd6cd507c48c0e1ed25a1ac60fd02cf7","tid":595633,"uid":23833,"like":679,"dislike":2,"score":677,"citedBy":0,"replyTime":"2018-03-16T23:30:33.000Z","msg":"0 分重作"},{"pid":"1e02b912a95a4423ba7c273dad63f43607b6b93e","tid":595633,"uid":127177,"like":182,"dislike":1,"score":181,"citedBy":1,"replyTime":"2018-03-16T23:33:03.000Z","msg":"出岳母相<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> 幫你分析"},{"pid":"b813eaed46e97c25dbfdd9c0a855fa52560d1915","tid":595633,"uid":87646,"like":9,"dislike":32,"score":-23,"citedBy":0,"replyTime":"2018-03-16T23:36:58.000Z","msg":"痴<br />\n撚<br />\n線<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"00be544b8091989cd95cb6232b263a7a38fce2cc","tid":595633,"uid":174733,"like":59,"dislike":2,"score":57,"citedBy":0,"replyTime":"2018-03-16T23:41:49.000Z","msg":"無是咁的，重作"},{"pid":"cf68f7f74070864e8bd54371210cf6c07e572090","tid":595633,"uid":166768,"like":44,"dislike":7,"score":37,"citedBy":0,"replyTime":"2018-03-16T23:43:10.000Z","msg":"真係唔知信唔信好"},{"pid":"36be8051ddbb50382134a1ad43327cc4914bdc63","tid":595633,"uid":23973,"like":305,"dislike":1,"score":304,"citedBy":1,"replyTime":"2018-03-17T00:01:32.000Z","msg":"伯母幫緊個女試你啫"},{"pid":"019ec37b778ae2a5bd6b32d7d659e798c7c303e8","tid":595633,"uid":153778,"like":59,"dislike":2,"score":57,"citedBy":1,"replyTime":"2018-03-17T00:04:13.000Z","msg":"母女丼<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 老母係咪成個