i\" />"},{"pid":"d38843eb0e2b214e6a7009a6e2d227742b546617","tid":1845661,"uid":151534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T14:18:36.000Z","msg":"唔撚係掛<img src=\"/assets/faces/lny/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/@.gif\" class=\"hkgmoji\" />"},{"pid":"57a188b4f7a47b73d7b2195d89c9a73912afd054","tid":1845661,"uid":344033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T14:18:50.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">請廣傳</span></span><br />\n<br />\n手足裝備抗沙士：防毒面具/濾罐 (型號/分析/用法/清潔全齊）<br />\n<br />\n<a href=\"https://lih.kg/1848447\" data-auto-link target=\"_blank\">https://lih.kg/1848447</a><br />\n<br />\n<br />\n整體分析圖：<a href=\"https://www.facebook.com/112357283631796/posts/116690396531818/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F116690396531818%2F%3Fd%3Dn&d=FyFnEhDp3tEmtF3AT420RrM5QgR%2FpIHXQ%2BfAgFWVWJ0%3D&h=f7c4220f\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/116690396531818/?d=n</a><br />\n個別仔細分析：<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\"><span style=\"font-size: xx-large;\">護目鏡</span>：<a href=\"https://lih.kg/1845419\" data-auto-link target=\"_blank\">https://lih.kg/1845419</a></span></span> / <a href=\"https://m.facebook.com/112357283631796/posts/117867026414155/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2F112357283631796%2Fposts%2F117867026414155%2F%3Fd%3Dn&d=FyFnEhDp3tEmtF3AT420RrM5QgR%2FpIHXQ%2BfAgFWVWJ0%3D&h=cd5c88bd\" data-auto-link target=\"_blank\">https://m.facebook.com/112357283631796/posts/117867026414155/?d=n</a><br />\n<br />\nVPN 大踢爆：<a href=\"https://m.facebook.com/story.php?story_fbid=112386483628876&amp;id=112357283631796&amp;__tn__=%2As-R\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2Fstory.php%3Fstory_fbid%3D112386483628876%26id%3D112357283631796%26__tn__%3D%252As-R&d=FyFnEhDp3tEmtF3AT420RrM5QgR%2FpIHXQ%2BfAgFWVWJ0%3D&h=35bb3902\" data-auto-link target=\"_blank\">https://m.facebook.com/story.php?story_fbid=112386483628876&amp;id=112357283631796&amp;__tn__=%2As-R</a><br />\n<br />\n請大家廣傳，避免沉底<br />\n<br />\n最近口罩同N95 都賣曬，部分手足屋企口罩已經就黎用盡，今日同大家介紹下可以防沙士+TG嘅濾罐同濾棉。第一，係for 用曬/買唔到口罩嘅手足，第二係希望方便大家一次過買齊發夢+出街嘅裝備，就算沙士完左，自用送禮都可以繼續名貴大方。<br />\n<br />\nN95/R95/P95 口罩基本上係particulate respirator, 外科口罩防嘅係飛沫粒子，即係我地用防毒面具代替，就要裝particulate filter，換言之，就係濾棉！<br />\n<br />\n濾棉最高級別就係P100，防油性+非油性粒子，即係TG（油性）同埋病毒都可以防，型號包括2091, 2097, 2297, 6035（只有英國製）,7093 等等，而60926等等嘅6092X 系列濾罐，因為內置P100 濾棉，所以一樣ok <br />\n其中，6053 同 7093 棉係防水的，清潔消毒會較方便，而60926表面亦有膠盒。<br />\n<br />\n有強國人做過測試，係北京霧霾毒氣之下，3M 2091 用左十一日過濾能力都係跌左1%，手足請自行考慮幾耐換一次。<br />\n<br />\nAmazon 大log買亦有便，大家可以組團買。<br />\n<br />\n<a href=\"https://www.3m.com.au/3M/en_AU/company-au/all-3m-products/~/3M-Particulate-Filter-6035-P2-P3/?N=5002385+8711017+3294471754&amp;rt=rud\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.3m.com.au%2F3M%2Fen_AU%2Fcompany-au%2Fall-3m-products%2F~%2F3M-Particulate-Filter-6035-P2-P3%2F%3FN%3D5002385%2B8711017%2B3294471754%26rt%3Drud&d=FyFnEhDp3tEmtF3AT420RrM5QgR%2FpIHXQ%2BfAgFWVWJ0%3D&h=6820ffe1\" data-auto-link target=\"_blank\">https://www.3m.com.au/3M/en_AU/company-au/all-3m-products/~/3M-Particulate-Filter-6035-P2-P3/?N=5002385+8711017+3294471754&amp;rt=rud</a><br />\n<a href=\"https://www.3m.com/3M/en_US/company-us/all-3m-products/~/3M-Particulate-Filter-7093-P100-60-EA-Case/?N=5002385+3294776429&amp;rt=rud\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.3m.com%2F3M%2Fen_US%2Fcompany-us%2Fall-3m-products%2F~%2F3M-Particulate-Filter-7093-P100-60-EA-Case%2F%3FN%3D5002385%2B3294776429%26rt%3Drud&d=FyFnEhDp3tEmtF3AT420RrM5QgR%2FpIHXQ%2BfAgFWVWJ0%3D&h=77176768\" data-auto-link target=\"_blank\">https://www.3m.com/3M/en_US/company-us/all-3m-products/~/3M-Particulate-Filter-7093-P100-60-EA-Case/?N=5002385+3294776429&amp;rt=rud</a><br />\n<br />\n2003 年沙士，淘大嘅清理人員就係用2091棉+600X 罐（罐理論上唔洗，應該係防佢地嘅清潔同消毒藥水）。<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: green;\">如何清潔防毒面具可參考依段片，有教disinfection，主要都係漂白水同消毒劑<br />\n<a href=\"https://youtu.be/dE5IweYn3T4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FdE5IweYn3T4&d=FyFnEhDp3tEmtF3AT420RrM5QgR%2FpIHXQ%2BfAgFWVWJ0%3D&h=f5cac1a7\" data-auto-link target=\"_blank\">https://youtu.be/dE5IweYn3T4</a></span></span><br />\n<br />\n清潔步驟：<br />\n入到屋企唔好除裝備住，用酒精紙巾抹左面具同濾棉/罐表面先，跟住抹埋手再洗手（點解又要酒精又要洗手係有原因的），跟住就除面罩，再跟番片入面嘅教學清潔<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n防毒面具方面，建議大家買/用6800 或者其他包曬成塊面嘅款式，咁樣就唔洗帶眼罩，一舊野保護曬成塊面，最安全。因為你戴半面+眼罩，咁就多舊野清潔，同埋部分眼罩封唔曬，冇咁安全。<br />\n<br />\n型號方面，全面嘅建議大家買6800，順便擋埋橡膠子彈，半面嘅就買7502/ 6500，兩款手足都表示舒適度幾高。<br />\n<br />\n<span style=\"color: red;\"><a href=\"https://www.facebook.com/112044766987392/posts/119490526242816/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112044766987392%2Fposts%2F119490526242816%2F%3Fd%3Dn&d=FyFnEhDp3tEmtF3AT420RrM5QgR%2FpIHXQ%2BfAgFWVWJ0%3D&h=b0523b04\" data-auto-link target=\"_blank\">https://www.facebook.com/112044766987392/posts/119490526242816/?d=n</a><br />\n酒精搓手液 vs 洗手梘液</span>"},{"pid":"a3b6ce54eeb1f6f72311c65465153189bbd7609e","tid":1845661,"uid":135011,"like":3,"dislike":0,"score":3,"quote":{"pid":"5d1f4a754adde994198843bc35805e74184417b4","tid":1845661,"uid":335716,"like":0,"dislike":0,"score":0,"quote":{"pid":"b8b46c225c8e9bfed62fe13cccfb7319eacf34c2","tid":1845661,"uid":135011,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa3e736d17cdb429f3bf55ab97a4fcf5b170d22b","tid":1845661,"uid":335716,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-28T14:16:26.000Z","msg":"仲係青衣？"},"citedBy":1,"replyTime":"2020-01-28T14:17:32.000Z","msg":"係<img src=