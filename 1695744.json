ss=\"hkgmoji\" />"},{"pid":"ca87b102268d19a96f606b81370b68331fbf1356","tid":1695744,"uid":93141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T23:22:21.000Z","msg":"太早出post好少人<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"8596740e5c54dea4570480a06121a38f54844e42","tid":1695744,"uid":37954,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T23:23:27.000Z","msg":"幫推"},{"pid":"28835bf1925b1f5c8a4dbcb0bc8f9c1edfdadee2","tid":1695744,"uid":93141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T23:23:57.000Z","msg":"推到8點<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3c95c6186358567d089ece7b6edf64f8c7725153","tid":1695744,"uid":93141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T23:25:19.000Z","msg":"推到8點<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"8df67bcac638737d5c217ba1c0ababa6d216cc54","tid":1695744,"uid":130385,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T23:26:12.000Z","msg":"<img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" />"},{"pid":"ca886e5bb581e6fef747a1c0d73d85d90370afcc","tid":1695744,"uid":33621,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T23:30:20.000Z","msg":"推"},{"pid":"403d975d00e3520f0c2ce3158381f80b93f8228f","tid":1695744,"uid":81640,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T23:32:15.000Z","msg":"ok<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"15e6a8fc884d3a8526e91c6c7d613ddf6a3b80a1","tid":1695744,"uid":292151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T23:32:33.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"31688dd8711fb8c0eb8028fbebeb4c99a0a2966e","tid":1695744,"uid":244818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T23:34:55.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"84fa1669090d63324e4f5925b845796a5cc10c80","tid":1695744,"uid":169845,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-05T23:54:32.000Z","msg":"推"},{"pid":"065116e34e594118d274e8f5e3f4b60ba99e0c09","tid":1695744,"uid":9028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T00:15:50.000Z","msg":"高汁<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f053a253b1d809247b80bdaab242131aa5256a2a","tid":1695744,"uid":113141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T00:16:25.000Z","msg":"推"},{"pid":"32bb45bbebcc7872da0ca8cc3fe85b205fb72a98","tid":1695744,"uid":24345,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T00:22:12.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"a8026e7e1b13b8ee25cd6734f3566ee978d323c9","tid":1695744,"uid":134033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T00:23:45.000Z","msg":"推"},{"pid":"50c236655051c1c7d66087fe0f6504404f191a20","tid":1695744,"uid":212119,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T02:04:11.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"e0f7669bbfba41314afe570b0f23dcd4d21830af","tid":1695744,"uid":2383,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T10:54:57.000Z","msg":"唔係冇野做架<br />\n大家準備好自己"},{"pid":"0af2aa0de6b1f9a8123a71ecd02557aa0986e9aa","tid":1695744,"uid":93141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T10:59:15.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b0457b4bcef1c2d916843d7c24ee7a322f1a6cc2","tid":1695744,"uid":333360,"like":0,"dislike":0,"score":0,"quote":{"pid":"7597def3e162887c953a5945a5e1de0caaed5e22","tid":1695744,"uid":93141,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-05T23:07:55.000Z","msg":"多謝大家入左黎，今次我會用簡短既文字同大家講下點樣響戰場以外幫自己升呢。每一刻都為下一次抗爭做好十二分準備，先有機會迎接最終既勝利。如果岩駛既話，希望睇完可以幫手推一推。<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><strong>現場環境不安全</strong></span><br />\n<br />\n要知道抗爭時，唔係無時無刻都有個急救響左近。有好多你以為自己知既野，其實未必係常識，例如著火要碌地，唔好亂郁傷者，洗眼要向邊個方向等等。一旦現場有咩事，你都可以自救甚至幫手出一分力。就算你考試柒到肥佬都冇所謂，目的唔係為個牌，而係希望大家有基本既急救概念，上過堂聽過書總好過道聽塗說。<br />\n<br />\n<img src=\"https://na.cx/i/u44940R.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fu44940R.jpg&h=e0908080&s={SIZE}\" /><br />\n <br />\n<span style=\"font-size: x-large;\"><strong><strong>四海皆兄弟</strong></strong></span><br />\n<br />\n抗爭時無論你係前線定後援，勇氣都係至關緊要。所以我鼓勵大家不如平時努力嘗試識多少少朋友，知道有信得過既人係深黃既，見到前線有人信得過既，咪一齊組隊，當然你都要努力獲得彼此信任。我地大家之前都係金鐘毒撚，但係戰場無毒撚，出得黎既都係勇士，要救手足就大聲嗌出黎，見到邊到有咩事就大聲嗌出黎，確保資訊流通，互相支援。<br />\n<br />\n<img src=\"https://na.cx/i/Nd8ZHPj.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNd8ZHPj.png&h=5a6bd174&s={SIZE}\" /><br />\n<span style=\"font-size: x-large;\"><br />\n<strong><strong>苦其心志，勞其筋骨</strong><br />\n</strong></span><br />\n相信好多手足同我一樣，響呢場運動前都係條肥/排骨毒撚。但抗爭時無論進攻，搬野，救人，逃走，無處不戰場，最需要既就係體力。所以無論你係咩位，練好個身體都係當務之急。屋企body weight又好，公園跑步又好，gym舉鐵又好，甚至武術都好，總之由今日開始，搵一樣你鍾意既運動，持之以恆落去，強化自己肌力同心肺，慢慢感受自己既成長，戰場上先可以保護自己甚至拯救手足。<br />\n <br />\n<img src=\"https://na.cx/i/TGSS2ND.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTGSS2ND.jpg&h=d6df12f3&s={SIZE}\" /><br />\n<br />\n<br />\n<span style=\"font-size: x-large;\"><strong>知識就是力量</strong></span><br />\n<br />\n如果對方既力量只得武力，我地既力量就係武力加上知識。各位無論係書本上既知識定實際上既技能，對抗爭都係缺一不可，絕對唔可以有勇無謀。所以我建議大家學返符合自己定位既知識。做開文宣既學下國際關係，做開火元素師既學下基礎化學，做開軍師既學下歷史等等。最最最緊要既係學好英文，獲得資訊既來源會多好多，有能力自己確定消息真確性，甚至主動對外輸出。<br />\n<br />\n<img src=\"https://na.cx/i/ybh0seq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fybh0seq.jpg&h=126cad5c&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><strong>橫眉冷對千夫指</strong></span><br />\n<br />\n我地好多時戰場上會遇到敵人既挑釁，影響你既冷靜，甚至激到主動送頭。另一方面係會有五毛同間諜混入你既同溫層分化，影響你對手足既信心，動搖大家士氣。所以我建議大家會嘗試用漸進式暴露療法，每日去敵陣例如香討，港人講地，人民日報等等，特登睇一兩篇令自己反胃既論點，一邊深呼吸一邊思考如何反駁對方。既可以克服憤怒，更可以令自己更理直氣壯，唔怕被挑戰。<br />\n<br />\n<img src=\"https://na.cx/i/aSPmV7Z.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaSPmV7Z.png&h=1036bc0f&s={SIZE}\" /> <br />\n<br />\n<span style=\"font-size: x-large;\"><strong>機會係留比有準備既人</strong></span><br />\n<br />\n既然我地冇大台，又決定打游擊，戰術準備會顯得更加重要。所以每次出黎之前，一定要睇熟地圖，帶齊裝備。計劃好自己既行動定位，目標，時機，逃生路線，被捕後準備等等。如果有組隊既請做好分工同埋至少要有後備計劃，達到目的/受威脅時可以儘快執生。最好係自己寫低一次會更入腦（寫完當然記得銷毀）。最後出發前訓個靚教。<br />\n<br />\n <img src=\"https://na.cx/i/edy67ff.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fedy67ff.png&h=24f91f23&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: x-large;\"><strong>香港人永不妥協</strong></span><br />\n<br />\n最後，所謂全民勇武，唔單止係行動，心態都好重要。見到好多人雖然有反對通知書，有蒙面法都仍然會去，但個諗法係借自稱行街經過，自稱病黎鑽漏洞。呢種諗法只係斬腳趾避沙蟲，要知道政府從一開始就已經侵犯緊我地既自由，唔好搵藉口，唔好呃自己，更唔好自我審查，我地要絕不妥協。不要說：香港人，加油。試著說：香港人，反抗。<br />\n<br />\n<img src=\"https://na.cx/i/pOY67fm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpOY67fm.jpg&h=aa9976c4&s={SIZE}\" /> <br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: xx-large;\"><strong>光復香港，時代革命！</strong></span></span><br />\n<br />\n延伸閱讀:<br />\n<br />\n讀緊書既朋友，唔好因為港共放棄知識<br />\n<a href=\"https://lih.kg/1683250\" data-auto-link target=\"_blank\">https://lih.kg/1683250</a><br />\n<br />\n不要說：我要1020去行街睇戲食飯<br />\n<a href=\"https://lih.kg/1661480\" data-auto-link target=\"_blank\">https://lih.kg/1661480</a><br />\n<br />\n真全民健身 - 為抗爭者而設既屋企健身全攻略影片 (觀念+熱身+正式訓練)<br />\n<a href=\"https://lih.kg/1644871\" data-auto-link target=\"_blank\">https://lih.kg/1644871</a><br />\n<br />\n\b[內附抗爭手冊] 本土民主前線 ： FREEDOM IS NOT FREE<br />\n<a href=\"https://lih.kg/1204152\" data-auto-link target=\"_blank\">https://lih.kg/1204152</a>"},"citedBy":0,"replyTime":"2019-11-06T11:03:58.000Z","msg":"有用post可惜推唔郁，我都岀過個post講反擊訊號，我地夢中相見<br />\n反抗第一步，建立反擊訊號<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1691213\" data-auto-link target=\"_blank\">https://lih.kg/1691213</a>"},{"pid":"7bc98234796b325001f431c7ebd2568954046514","tid":1695744,"uid":33970,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T11:06:09.000Z","msg":"推"},{"pid":"e44cacb3c87b077f87662036859bff853a0923bf","tid":1695744,"uid":93141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T11:06:58.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1186696505cd417b4ea4e7ab7eee284117d7ec0f","tid":1695744,"uid":39710,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T11:17:33.000Z","msg":"甴近平！"},{"pid":"ef1a5bcc24a2322fd36ab44a27a345037084b233","tid":1695744,"uid":93141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T11:22:18.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ff2a6812897eaf5d722940a59535c8457af53644","tid":1695744,"uid":229886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T11:24:36.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"055f295debed0368fb582a7072f3c705dd3595ee","tid":1695744,"uid":229886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T11:25:39.000Z","msg":"<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},{"pid":"d9d63d431ce794ba6f7d3b9ca809db1a848c40d9","tid":1695744,"uid":229886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-06T11:25:59.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"fbd80933a51794270cda05a0dc5d6e13fc8ed6d4","tid":