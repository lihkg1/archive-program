e":-1,"quote":{"pid":"3803ab1a83aace5f328f247475ff77533ed4b9c8","tid":866270,"uid":168415,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2018-10-17T17:45:02.000Z","msg":"次次睇完樂觀蛇嘅POST 都好負面<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-17T23:59:04.000Z","msg":"自稱樂觀的人，但行文充滿負能量。<br />\n<br />\n當我睇到 &ldquo;但時間總要過, 要生活, 要活下去&rdquo;，我覺得好矛盾，心情好複雜。<br />\n<br />\n樂觀sir，你兩個高手點睇個市？"},{"pid":"3fde05b096b3243c331d1f3fbaebe83866e234a9","tid":866270,"uid":126609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-18T00:02:21.000Z","msg":"此回覆已被刪除"},{"pid":"9087db94ae1c0218ab30578061f83927d8b378e1","tid":866270,"uid":41524,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-10-18T01:28:23.000Z","msg":"人往往失敗最主要原因係欠缺思考"},{"pid":"3936bee34b2a2dcdafb454c0859d6494b5b2b8cf","tid":866270,"uid":31907,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-18T02:48:57.000Z","msg":"all is crap"},{"pid":"240c716275006bae61d4e7bf6b1c75f1eeb1258f","tid":866270,"uid":31907,"like":0,"dislike":0,"score":0,"quote":{"pid":"9087db94ae1c0218ab30578061f83927d8b378e1","tid":866270,"uid":41524,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-10-18T01:28:23.000Z","msg":"人往往失敗最主要原因係欠缺思考"},"citedBy":0,"replyTime":"2018-10-18T02:50:05.000Z","msg":"亦有人思考太多痴左線"},{"pid":"6baee069c2fb587116b47fbd9612b224b35560ef","tid":866270,"uid":171866,"like":0,"dislike":0,"score":0,"quote":{"pid":"9087db94ae1c0218ab30578061f83927d8b378e1","tid":866270,"uid":41524,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-10-18T01:28:23.000Z","msg":"人往往失敗最主要原因係欠缺思考"},"citedBy":0,"replyTime":"2018-10-18T03:35:26.000Z","msg":"班師奶又思考過乜"}]}