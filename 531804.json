滋擾，兼夾座駕俾人損毀，即係陳志遠先係受害嗰一個。<br />\n<br />\n<a href=\"http://nextplus.nextmedia.com/news/latest/20180116/568159\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnextplus.nextmedia.com%2Fnews%2Flatest%2F20180116%2F568159&d=iyvf8w05XlyTyEHPDCLKZF0Hwm5JNK6yt%2FgZtp%2B4HOw%3D&h=e68406cb\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fnextplus.nextmedia.com%2Fnews%2Flatest%2F20180116%2F568159&h=7061f44b\" target=\"_blank\">http://nextplus.nextmedia.com/news/latest/20180116/568159</a>"},{"pid":"e3c9bd70bcf5e983044b672c3216f4cb39420093","tid":531804,"uid":56212,"like":0,"dislike":0,"score":0,"quote":{"pid":"b0c4d97b828574d154404e4584ee68e0d111020f","tid":531804,"uid":48350,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-17T08:09:18.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/01/17/160409_e733337db464c2bba9dcf4ff229281a6.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F17%2F160409_e733337db464c2bba9dcf4ff229281a6.png&h=afb7da3a&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/01/17/160410_e733337db464c2bba9dcf4ff229281a6.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F17%2F160410_e733337db464c2bba9dcf4ff229281a6.png&h=cbe15279&s={SIZE}\" /><br />\n陳嘉倩<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/17/160436_2f18fd2db416529338308781c6f2d546.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F17%2F160436_2f18fd2db416529338308781c6f2d546.png&h=1c8dc5f0&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/01/17/160437_41f4e7261139c213268101fc9f03e940.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F17%2F160437_41f4e7261139c213268101fc9f03e940.png&h=8d854bec&s={SIZE}\" /