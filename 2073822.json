:2073822,"uid":3063,"like":0,"dislike":0,"score":0,"quote":{"pid":"5443bf0800c6432e240a2670bb7bd4ffb417c5ba","tid":2073822,"uid":58880,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-06-21T15:17:17.000Z","msg":"原來仲係拳腳交<br />\n做咩唔用水炮車<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-21T15:18:16.000Z","msg":"我以為又刀又乜"},"citedBy":0,"replyTime":"2020-06-21T15:19:09.000Z","msg":"流浮山刀手都冇<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5d611b26e157725f45639c1f7829becb47fd5cf7","tid":2073822,"uid":25019,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-06-21T15:20:47.000Z","msg":"黑驚話最低武力係橡膠子彈喎 仲拳頭波？"},{"pid":"ca659fcedd577f819fdbf45aa91e062cb3b306a1","tid":2073822,"uid":304769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-21T15:21:09.000Z","msg":"停止拳頭交<br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">要拳交</span></span></strong><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><br />\n<br />\n幫我推到印度佬睇到<br />\n<br />\n<br />\n借個位<br />\n正視聽：若抗爭方向不隨局勢改變，只會無謂地損兵折將<br />\n香港街頭抗爭目標，亦都係街頭抗爭最大效果；&ldquo;攬炒&rdquo;已經達到，今次搞蟈安法其實仲攬炒過上年出老解。<br />\n宜家<strong><span style=\"color: red;\">跟著落黎就係引渡全球政府同議會（尤其美國）對付支那以及滅共</span></strong>，所以大家重點應該著眼帶出清晰民意授權比各國政府做野，畫面靚+全球廣泛報導（類似反蟈安法銅鑼灣自由行）係最理想，用選票帶出民意亦十分重要。<br />\n<br />\n<strong><span style=\"color: red;\">大家要小心五毛、熱狗放負風向：美國唔會幫我地（舊年年尾）-》英國係廢國無用架（今年年頭）-》歐盟奶共唔會幫我地（宜家）</span></strong><br />\n<br />\n大家要記住，香港生路只有一條：救香港人+攬炒促進支爆+重建香港。<strong><span style=\"color: red;\">沒有支爆，香港獨立或者歸英等重建方案全部都係痴人說夢。</span></strong><br />\n<br />\n未來幾個月至支共瓦解期間大家要做嘅事：1.<strong><span style=\"color: red;\">走資</span></strong>2.全球救生艇<strong><span style=\"color: red;\">救手足加有細路既黃絲家庭</span></strong>（細路是重點，香港未來棟樑，正如今時今日d前線義士，咪比佢地洗腦變小糞紅，否則香港係真正玩完）3.比足夠<strong><span style=\"color: red;\">民意授權，敦促美國以至各國凌遲式消除香港作為支那獲得外資渠道</span></strong>，包括但不限於：禁止美國個人或公司投資港股，暫停接受香港用美元結算等等4.最後就真係等<span style=\"color: red;\"><strong>支那自己爆</strong></span>"},{"pid":"4868c6e51c8efcabaa798a7329f8d9052f92a48b","tid":2073822,"uid":228143,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2020-06-21T15:22:14.000Z","msg":"都冇戴口罩  舊片？"},{"pid":"6d8272e0df1fb2dd7cd0543d77d29bcb86b99ae8","tid":2073822,"uid":87123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-21T15:22:21.000Z","msg":"邊隊分邊隊 矇到分唔到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4235b55ea0a7801b96726df28ed4c190f3540915","tid":2073822,"uid":269465,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-06-21T15:22:31.000Z","msg":"段片舊唔舊左d.....<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"48bc9ca80fc212a76fdefe13d19aaaf2a5a54016","tid":2073822,"uid":36702,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-21T15:22:36.000Z","msg":"支持印度軍方嚴正執法<br />\n<br />\n同我充公曬解放軍所有床舖    摺得你咁撚開心"},{"pid":"c63f2a4c8dde95596ed4ddd401eb8071f4a2f147","tid":2073822,"uid":269465,"like":0,"dislike":0,"score":0,"quote":{"pid":"4868c6e51c8efcabaa798a7329f8d9052f92a48b","tid":2073822,"uid":228143,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2020-06-21T15:22:14.000Z","msg":"都冇戴口罩  舊片？"},"citedBy":0,"replyTime":"2020-06-21T15:23:31.000Z","msg":"印象中起碼一兩年前.... <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"84cc072301fcbd686634f2756119b7e9b6bb3e9a","tid":2073822,"uid":277186,"like":0,"dislike":0,"score":0,"quote":{"pid":"4868c6e51c8efcabaa798a7329f8d9052f92a48b","tid":2073822,"uid":228143,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2020-06-21T15:22:14.000Z","msg":"都冇戴口罩  舊片？"},"citedBy":0,"replyTime":"2020-06-21T15:24:26.000Z","msg":"守邊境 口罩要黎把撚<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 印度同支那喎"},{"pid":"4592894c288e6cf0d82a85e8c7ebf82054db61b9","tid":2073822,"uid":120955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-21T15:26:25.000Z","msg":"2020年連360p都無"},{"pid":"35f41e71704aad756169933571b7cbe3916f172a","t