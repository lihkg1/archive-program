ae%2598%25e7%259d%2580%25e6%259f%25a5%25e6%25bf%25ab%25e6%259a%25b4&h=d17badcd\" data-auto-link target=\"_blank\">https://news.mingpao.com/pns/%e6%b8%af%e8%81%9e/article/20200703/s00002/1593715168047/%e3%80%8c%e5%b7%b2%e8%b6%85%e6%87%89%e5%be%97%e6%87%b2%e7%bd%b0%e3%80%8d-%e9%aa%a8%e6%8a%98%e4%b8%ad%e6%b8%af%e5%8f%b8%e6%a9%9f%e9%98%bb%e5%b7%ae%e7%bd%b05000-%e6%89%b9%e8%ad%a6%e7%84%a1%e6%95%85%e6%91%94%e5%82%b7%e8%a2%ab%e5%91%8a-%e5%ae%98%e7%9d%80%e6%9f%a5%e6%bf%ab%e6%9a%b4</a><br />\n<br />\n<span style=\"color: red;\">徐官形容涉案防暴警23385「無故在被告無反抗或挑釁下，突然將被告猛力向前摔低」</span>，使他左手落地，對被告造成「嚴重傷勢」，坦言「被告已付上沉重代價，超越應得懲罰」，終判他罰款5000元。徐官表示，片段中有警員行為明顯不合理及不必要，着控方索取法律意見，調查案中有否警員濫暴。"},{"pid":"bd8fc2ff315c3c50d28f91fa64d4bb424ec8f8df","tid":2091763,"uid":36494,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-07-03T00:19:04.000Z","msg":"庭上播放辯方呈遞的案發片段，顯示被告遭防暴警按地制服後，遭拖行至牆角，數秒後再次遭箍頸摔在地上。主任裁判官徐綺薇稱被告在「似乎已被控制」下仍被摔地，要求控方解釋。控方回應警員需「隔開」被告，徐官隨即說「箍頸撻低落地下都叫隔開？」又說「無𠵱段片，好多嘢我都睇唔到」。"},{"pid":"9bdc04458fb18e1c70bf9076bcd9dd7bf0266cb2","tid":2091763,"uid":36494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-03T00:19:15.000Z","msg":"Push"},{"pid":"842b193d1ecf0029136f800ce7bcc013f4a3ba2e","tid":2091763,"uid":51701,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2020-07-03T00:19:27.000Z","msg":"賭場模式啟動<br />\n<br />\n10 場賭局<br />\n比你贏 3 場<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"965c0897f6c8fa30efa2a401245496045ba55324","tid":2091763,"uid":1654,"like":2,"dislike":0,"score":2,"quote":{"pid":"842b193d1ecf0029136f800ce7bcc013f4a3ba2e","tid":2091763,"uid":51701,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2020-07-03T00:19:27.000Z","msg":"賭場模式啟動<br />\n<br />\n10 場賭局<br />\n比你贏 3 場<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-03T00:19:52.000Z","msg":"等你以為有得贏"},{"pid":"011079ddc1359cc8a7dabdf170dacdd78b8a2342","tid":2091763,"uid":36494,"like":0,"dislike":0,"score":0,"citedBy":0,"reply