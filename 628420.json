.php?field=1&amp;q=舓&amp;</a><br />\n<br />\n<a href=\"https://zh.m.wiktionary.org/zh-hant/舓\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wiktionary.org%2Fzh-hant%2F%E8%88%93&d=W7b%2BWNj1u%2BV7aCy48ljdW26tz0R9Svbxs0EcWe5CwMI%3D&h=1e1e1598\" target=\"_blank\">https://zh.m.wiktionary.org/zh-hant/舓</a>"},{"pid":"202dcbaf07688ba9284d128496395f17b42d958a","tid":628420,"uid":21423,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-04-14T02:05:18.000Z","msg":"此回覆已被刪除"},{"pid":"ff40b57ac5a592c589758a2cbe13727e9db80f26","tid":628420,"uid":74339,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-14T02:06:07.000Z","msg":"舐<br />\n舔音近添"},{"pid":"2862de501f453f453f22be6223bf91dea7c3316e","tid":628420,"uid":102475,"like":0,"dislike":0,"score":0,"quote":{"pid":"202dcbaf07688ba9284d128496395f17b42d958a","tid":628420,"uid":21423,"like":5,"dislike":0,"score":5,"quote":{"pid":"3f26884346412853b96123f751dbfd5d8d85590d","tid":628420,"uid":48083,"like":1,"dislike":0,"score":1,"quote":{"pid":"7d6f48f9e01d8004f672128e46439332f27cac6f","tid":628420,"uid":21423,"like":20,"dislike":2,"score":18,"citedBy":2,"replyTime":"2018-04-14T01:21:02.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-04-14T02:03:25.000Z","msg":"似係'錫'既古字，唔係奶？<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /> <br />\n<br />\n舓\t以舌取食也。从舌，易聲。〔神旨切〕𦧇，舓或从也。 (《說文》 : 49 / 44)\t舌\t𦧇<br />\n<br />\n<a href=\"http://humanum.arts.cuhk.edu.hk/Lexis/lexi-mf/searchShuowen.php?field=1&amp;q=舓&amp;\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhumanum.arts.cuhk.edu.hk%2FLexis%2Flexi-mf%2FsearchShuowen.php%3Ffield%3D1%26q%3D%E8%88%93%26&d=W7b%2BWNj1u%2BV7aCy48ljdW26tz0R9Svbxs0EcWe5CwMI%3D&h=abe278c5\" target=\"_blank\">http://humanum.arts.cuhk.edu.hk/Lexis/lexi-mf/searchShuowen.php?field=1&amp;q=舓&amp;</a><br />\n<br />\n<a href=\"https://zh.m.wiktionary.org/zh-hant/舓\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wiktionary.org%2Fzh-hant%2F%E8%88%93&d=W7b%2BWNj1u%2BV7aCy48ljdW26tz0R9Svbxs0EcWe5CwMI%3D&h=1e1e1598\" target=\"_blank\">https://zh.m.wiktionary.org/zh-hant/舓</a>"},"citedBy":1,"replyTime":"2018-04-14T02:05:18.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-04-14T02:09:02.000Z","msg":"咁點解唔係舐係舓"},{"pid":"0c5a1940b6367594a69d48b4fac9794808c51248","tid":628420,"uid":21423,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-04-14T02:09:44.000Z","msg":"此回覆已被刪除"},{"pid":"7fcd6ce98fea9635fd1c40956cac86c221cd0d59","tid":628420,"uid":61882,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-14T02:30:13.000Z","msg":"<a href=\"https://is.gd/makelovewithfatc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fis.gd%2Fmakelovewithfatc&d=W7b%2BWNj1u%2BV7aCy48ljdW26tz0R9Svbxs0EcWe5CwMI%3D&h=a12f47b2\" target=\"_blank\">https://is.gd/makelovewithfatc</a><br />\n巴打點睇<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n廣州話正音字典 states that all the three characters 𦧺, 舔, 舐 mean &ldquo;to lick/lap&rdquo; but that 𦧺 [laai2] is Cantonese, 舔 [tim2] is Mandarin, and 舐 [saai2] is literary (used mainly in classical Chinese idiom such as 舐犢情深).<br />\n粵語拼音字表 has no 𦧺 entry. It also has 舔 pronounced as &ldquo;tim2&rdquo;, but it has 舐 pronounced as &ldquo;laai2&rdquo; and &ldquo;lem2&rdquo; as well as &ldquo;saai2&rdquo;."},{"pid":"1e13b215b9e44090df0a6f696121616cd3eac0e8","tid":628420,"uid":102475,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c5a1940b6367594a69d48b4fac9794808c51248","tid":628420,"uid":21423,"like":1,"dislike":0,"score":1,"quote":{"pid":"2862de501f453f453f22be6223bf91dea7c3316e","tid":628420,"uid":102475,"like":0,"dislike":0,"score":0,"quote":{"pid":"202dcbaf07688ba9284d128496395f17b42d958a","tid":628420,"uid":21423,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-04-14T02:05:18.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-04-14T02:09:02.000Z","msg":"咁點解唔係舐係舓"},"citedBy":1,"replyTime":"2018-04-14T02:09:44.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-04-14T08:59:50.000Z","msg":"知道左異體字之後我點分邊個係正字邊個係異體字？"},{"pid":"26e470b52e5b02784e23bae5df053e1291b859ed","tid":628420,"uid":21423,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-04-14T09:07:38.000Z","msg":"此回覆已被刪除"},{"pid":"3ebcc63fdf759a61ae326e3c081a2546bd149b3a","tid":628420,"uid":102475,"like":0,"dislike":0,"score":0,"quote":{"pid":"26e470b52e5b02784e23bae5df053e1291b859ed","tid":628420,"uid":21423,"like":1,"dislike":0,"score":1,"quote":{"pid":"1e13b215b9e44090df0a6f696121616cd3eac0e8","tid":628420,"uid":102475,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c5a1940b6367594a69d48b4fac9794808c51248","tid":628420,"uid":21423,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-04-14T02:09:44.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-04-14T08:59:50.000Z","msg":"知道左異體字之後我點分邊個係正字邊個係異體字？"},"citedBy":1,"replyTime":"2018-04-14T09:07:38.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-04-14T14:55:50.000Z","msg":"你直接解釋會快過就咁話人未知"},{"pid":"1738025c8d0f845de160cb8d041fac8ec9750eca","tid":628420,"uid":61882,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-14T15:27:53.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>似係'錫'既古字，唔係奶？<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /> <br />\n<br />\n舓\t以舌取食也。从舌，易聲。〔神旨切〕𦧇，舓或从也。 (《說文》 : 49 / 44)\t舌\t𦧇<br />\n<br />\n<a href=\"http://humanum.arts.cuhk.edu.hk/Lexis/lexi-mf/searchShuowen.php?field=1&amp;q=舓&amp;\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhumanum.arts.cuhk.edu.hk%2FLexis%2Flexi-mf%2FsearchShuowen.php%3Ffield%3D1%26q%3D%E8%88%93%26&d=W7b%2BWNj1u%2BV7aCy48ljdW26tz0R9Svbxs0EcWe5CwMI%3D&h=abe278c5\" target=\"_blank\">http://humanum.arts.cuhk.edu.hk/Lexis/lexi-mf/searchShuowen.php?field=1&amp;q=舓&amp;</a><br />\n<br />\n<a href=\"https://zh.m.wiktionary.org/zh-hant/舓\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wiktionary.org%2Fzh-hant%2F%E8%88%93&d=W7b%2BWNj1u%2BV7aCy48ljdW26tz0R9Svbxs0EcWe5CwMI%3D&h=1e1e1598\" target=\"_blank\">https://zh.m.wiktionary.org/zh-hant/舓</a></blockquote>查舐就會發現寫住「同舓」<br />\n<a href=\"http://humanum.arts.cuhk.edu.hk/Lexis/lexi-mf/search.php?word=舐\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhumanum.arts.cuhk.edu.hk%2FLexis%2Flexi-mf%2Fsearch.php%3Fword%3D%E8%88%90&d=W7b%2BWNj1u%2BV7aCy48ljdW26tz0R9Svbxs0EcWe5CwMI%3D&h=8c1940a7\" target=\"_blank\">http://humanum.arts.cuhk.edu.hk/Lexis/lexi-mf/search.php?word=舐</a></blockquote>咁點解唔係舐係舓</blockquote>查下咩叫異體字先啦</blockquote><br />\n<a href=\"https://is.gd/laaifatchai\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fis.gd%2Flaaifatchai&d=W7b%2BWNj1u%2BV7aCy48ljdW26tz0R9Svbxs0EcWe5CwMI%3D&h=4ac557ca\" target=\"_blank\">https://is.gd/laaifatchai</a><br />\n...問題是，「舐」字既然早已約定俗成，本字的「舓」和「舌也」字則變成了文字化石。況且「舐」字本身就是形聲字，現在的「舐」聲符从氏更能反映其讀音，我們又何苦要盲目法古用回這個「舌也」字呢﹖用回「舐嘢」又有何問題呢﹖"},{"pid":"9b6865805bb95fda4ddf15b4f87ad3c1c7f64f14","tid":628420,"uid":2419,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-04-14T15:30:32.000Z","msg":"條肥鳩撚識咩"},{"pid":"8944f128d1864ccb09b1a6625499340950eabe16","tid":628420,"uid":21423,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-04-14T15:50:01.000Z","msg":"此回覆已被刪除"}]}