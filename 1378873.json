yTime":"2019-07-28T17:05:22.000Z","msg":"Push"},{"pid":"b93c1271f96adeca1469a029bcbdc73b23ac4ee0","tid":1378873,"uid":98477,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T17:09:56.000Z","msg":"推爆佢<br />\n我要罷工"},{"pid":"c486a273da4be5dc0991305b4d161ca7ca17c527","tid":1378873,"uid":164127,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T19:29:07.000Z","msg":"我無嘢講"},{"pid":"eb7c337a8cbb8d1f49a8869c5117771987067b36","tid":1378873,"uid":98477,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T01:59:50.000Z","msg":"我要罷工"},{"pid":"d84c274d0bad08c8476c22cc0ed6f1e60c4ec37e","tid":1378873,"uid":98477,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T04:12:53.000Z","msg":"推"}]}