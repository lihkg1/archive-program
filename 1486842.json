ount level<br />\n字眼要twist"},{"pid":"8054f527dd098f56d73fab38bfdc3579fe1b0c67","tid":1486842,"uid":229886,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-19T04:35:38.000Z","msg":"可信?"},{"pid":"bf8ae4d0d808f35429055effee9bb815b0a894c4","tid":1486842,"uid":271234,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T04:45:15.000Z","msg":"推上熱門 <img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"}]}