l/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8878b427b21bfff54d51e26ee8c0886876b9b251","tid":863860,"uid":13534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-16T04:36:35.000Z","msg":"無啦無啦"},{"pid":"9af872334ff063547f56367b196c89294bdbb36d","tid":863860,"uid":36609,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-16T04:44:49.000Z","msg":"排隊CALL先"},{"pid":"597135e9e9501c28e8a6d8d8f86216a6b0d79618","tid":863860,"uid":13644,"like":0,"dislike":0,"score":0,"quote":{"pid":"9af872334ff063547f56367b196c89294bdbb36d","tid":863860,"uid":36609,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-16T04:44:49.000Z","msg":"排隊CALL先"},"citedBy":0,"replyTime":"2018-10-16T05:17:35.000Z","msg":"Yau win <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"7c0efc0c05c08997d6831f89fea8ec1715bf9823","tid":863860,"uid":43469,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-16T05:17:48.000Z","msg":"有冇蝗..."},{"pid":"642d85efe3cbddcc541e1617c2d2fdae7d021465","tid":863860,"uid":43469,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-16T05:19:49.000Z","msg":"大家有發現嗎? 最近新角色(不論有無登上正式服) 強的越來越誇張<br />\n<br />\n戰士位移越來越多(包含觸發條件刷新技能所增加之位移) 真傷 無敵  回血 技能越來越氾濫<br />\n<br />\n狗角用技能位移後甚至還能強化普攻<br />\n<br />\n坦克技能同時有位移 控場  擊飛, 機體最大血量相比舊角越來越高 , 甚至還能被動自帶復活甲<br />\n<br />\n射手 有視距外攻擊能力  有位移 能在固定位置開視野  基礎攻擊力又高 <br />\n<br />\n法師有無敵 有回血 有控制 有位移 有高傷害<br />\n<br />\n而且不論職業新角的被動越來越多效果<br />\n<br />\n如果說以前是位移對決 <br />\n<br />\n現在是位移 + 真傷 無敵 秒殺 回血 對決<br />\n<br />\n現在的趨勢是<br />\n<br />\n新角出來後, 官方怕舊角不能生存, 所以改強舊角的傷害量<br />\n<br />\n但這改強的傷害量不足以彌補那些新角&quot;飛來飛去&quot;的瞬間爆發傷害<br />\n<br />\n因為你在打出傷害之前被英雄飛來飛去的傷害給打爆了<br />\n<br />\n先前受到隔壁棚的刺激 改強舊角一波<br />\n<br />\n現在隔壁棚威脅沒那麼大<br />\n<br />\n又故態復萌了<br />\n<br />\n現在各英雄在被動跟技能上的差距真的越拉越大<br />\n<br />\n不知道大家喜歡這種秒殺 無敵 真傷 回血 位移對決嗎?<br />\n<br />\n<br />\n<img src=\"/assets/faces/lomoji/27.png\" class=\"hkgmoji\" />"},{"pid":"9b6bbc2fc234f7c1487a2c58afe8c96802ccbd82","tid":863860,"uid":97,"l