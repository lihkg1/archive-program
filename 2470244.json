moji\" /><br />\n<br />\n其實好易搞 我以前都試過夾到包皮 倒啲煮食油落嗰位到等一陣就佢自己跣返出嚟"},{"pid":"3038f5cb6ddff945d57060bfafa6b2fe3e6c7cd3","tid":2470244,"uid":250308,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2021-03-31T23:42:55.000Z","msg":"杭州iq稱得上十分之低b 創造力量同幻想會嚇你一跳"},{"pid":"e43895b519f66f521b89908d6415036f71e71f5e","tid":2470244,"uid":130626,"like":0,"dislike":0,"score":0,"quote":{"pid":"b2bd3439e1703c35d2edd84051ad1b52e6966827","tid":2470244,"uid":17359,"like":21,"dislike":3,"score":18,"citedBy":1,"replyTime":"2021-03-31T20:22:22.000Z","msg":"地獄鬼國真係乜戇鳩野都有<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-01T01:06:10.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"6d9376d5d9fe30095c4a8adf8a7d7850131acb42","tid":2470244,"uid":275570,"like":0,"dislike":0,"score":0,"quote":{"pid":"044f8eb80e9c1266eb60a2a55c041355fa150597","tid":2470244,"uid":208713,"like":6,"dislike":1,"score":5,"citedBy":1,"replyTime":"2021-03-31T20:21:30.000Z","msg":"你包埋個頭出街？"},"citedBy":0,"replyTime":"2021-04-01T01:11:52.000Z","msg":"笑甚麼<br />\n<br />\n<br />\n問過陶傑未?"},{"pid":"ef32ee101a0edc839330d443c05687ef277bca6a","tid":2470244,"uid":289115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-01T01:20:22.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"bc753ae18af692ecede73544a2fb91ac975520f1","tid":2470244,"uid":130626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-01T03:17:51.000Z","msg":"Push"},{"pid":"7566028fd0a5e79a609db4a2a6a4d25d15a88676","tid":2470244,"uid":364767,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-01T03:23:30.000Z","msg":"支那人絕對不能接觸西方科技 又一例證<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"a009e3b9dcec6310f049e8839943132f96c