/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"775fb93cc48693514118659d2f71c692fafc231f","tid":1812111,"uid":79563,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2020-01-05T10:53:39.000Z","msg":"<img src=\"https://i.postimg.cc/BvT0bB02/image.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.postimg.cc%2FBvT0bB02%2Fimage.jpg&h=fb15f2b8&s={SIZE}\" />"},{"pid":"8d18d0152d5cfc7767ddc0254ae473803cbaee11","tid":1812111,"uid":139700,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-05T11:09:26.000Z","msg":"推上去畀人睇"},{"pid":"6c0bd1ade21e20d1357ad92e73799a0b074b34c7","tid":1812111,"uid":11055,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-01-05T11:48:45.000Z","msg":"沒有兩國，哪有兩制，<br />\n香港獨立，唯一出路！"},{"pid":"49023550a89769ceb0fdcaee671181491f8fd4ca","tid":1812111,"uid":329551,"like":2,"dislike":1,"score":1,"quote":{"pid":"775fb93cc48693514118659d2f71c692fafc231f","tid":1812111,"uid":79563,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2020-01-05T10:53:39.000Z","msg":"<img src=\"https://i.postimg.cc/BvT0bB02/image.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.postimg.cc%2FBvT0bB02%2Fimage.jpg&h=fb15f2b8&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-01-05T11:53:33.000Z","msg":"沒有支爆，那有獨立<br />\n沒有獨立，那有普選<br />\n<br />\n支爆-&gt;獨立-&gt;普選<br />\n<br />\n大家係同一條船上，政見唔同只差在對出路要求嘅高低。<br />\n<br />\n對出路要求嘅較低嘅政黨/圈麻煩詳細解釋一下點樣可以唔使打死個大佬(共產黨)就得到你哋追求嘅出路？淨係嗌口號但唔講你哋嘅理念點實踐嘅話好難信服人。用腦諗嘢嘅人當晒你哋係邪教。成日淨係嗌冤枉又唔澄清真係想open-minded都唔知點幫你哋。<br />\n<br />\n冇實質嘅辦法嘅話就唔該唔好喺度扭計R信徒，大家默默耕耘，一齊打大佬好唔好？暫時放低私人利益，私人恩怨，點分餅仔嘅事等差唔多成功時先討論好唔好？<br />\n<br />\n講到咁到淨係試用得粗口人身攻擊(又唔正面反駁論點)嗰啲，大家睇得出係網軍，知道點做。"},{"pid":"a48d430cc33ea5f4999a042a7e588b6004e70e76","tid":1812111,"uid":174174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-05T13:12:04.000Z","msg":"推"},{"pid":"19513306eddc9e2e6a2a2f804ee4dc60751e1cab","tid":1812111,"uid":238275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-05T14:36:45.000Z","msg":"推"},{"