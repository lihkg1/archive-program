e9f4e744430c736828a1658c772b89f0e62f","tid":635184,"uid":34010,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-04-20T05:49:25.000Z","msg":"將減少他們對中國<span style=\"color: red;\">仿製品</span>和俄羅斯裝備系統的依賴<br />\n<br />\n<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"70e6738dfebdc8077fc0d1be094e18dcc81008a1","tid":635184,"uid":11962,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-20T05:56:57.000Z","msg":"買定軍工股"},{"pid":"a07fac3592ab3c71e1d9837ed23a164a6b020e64","tid":635184,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-24T00:54:22.000Z","msg":"<img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/kill2.gif\" class=\"hkgmoji\" />"}]}