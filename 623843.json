55a74c70139db6053.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F204818_6bb63f53b7ca40b55a74c70139db6053.jpeg&h=b3c61761&s={SIZE}\" />"},{"pid":"d7415e59342b425b21b0e3127d758c99cc1356a2","tid":623843,"uid":179810,"like":1,"dislike":0,"score":1,"quote":{"pid":"ca7b88cd173b8f549628a42d262e88723e7dfd7f","tid":623843,"uid":48334,"like":0,"dislike":1,"score":-1,"quote":{"pid":"231025c7b9f1578ff6098aef7b8137f1b56dc501","tid":623843,"uid":89145,"like":449,"dislike":2,"score":447,"citedBy":5,"replyTime":"2018-04-10T10:18:36.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-04-10T11:53:43.000Z","msg":"炸彈"},"citedBy":0,"replyTime":"2018-04-10T12:59:14.000Z","msg":"早排喺印度有條友想用炸彈殺人，點知唔爆查出原來中國製。<br />\n揾唔返段新聞<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n用手榴彈造成大量死傷，是不少電影常見的橋段，不過大家有否想過，平常在電影所見，當主角一拔出撞針、拋出手榴彈即爆出強勁火藥的情況，在現實生活中發生，竟會「無內容」？引述外媒報道，最近一次發生於印度喀什米爾的恐怖襲擊，就出現了一個不懂爆發的手榴彈，及後調查發現，這個手榴彈，原來是中國製造的！哦，師父，明白了！<br />\n<br />\n中國製造的貨品，憑甚麼最為知名？就是世人單看表面，是不會知道當中孰真敦假，直到貨品真正到手及使用之時，才驚覺這是假到不能的假貨，正如這個不炸手榴彈一樣，看像跟真正手榴彈無異，但實際卻空空如也，恐怖份子想用來傷人都傷不了。說來中國製的不炸炸彈，已不是首次曝光，早在兩年前有一宗「緬甸第 4 次誤投炸彈入雲南」的新聞，裡面所用的不炸炸彈，都是中國製造的，幸好那次因為炸彈不懂炸，而沒有造成傷亡，否則就會有「自己打自己」的嫌疑了。"},{"pid":"73dda003dc9cc5e9ce355005e5762e8d6d176f09","tid":623843,"uid":46933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-10T13:11:11.000Z","msg":"肯定係叮完拎出黎<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"22ca9fc1a4a030651e0bbd733ea148b016594190","tid":623843,"uid":3764,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-10T13:19:33.000Z","msg":"支那係咪得炸彈唔會爆<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8f253b564a88e628963e7bf0f83e8318cc30cd03","tid":623843,"uid":33643,"like":0,"dislike":0,"score":0,"quote":{"pid":"96869ab6f0679ed7f5b12ee10e2cd1ab6d323de5","tid":623843,"uid":41509,"like":4,"dislike":77,"score":-73,"quote":{"pid":"260c8430a871d9dd8323314a0d41f7e9d4886000