b834e66b79cb4a5210c329e0196547be7c","tid":1386223,"uid":39752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T10:32:21.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"063549c60a1433b4f9face8be99920a1a673b746","tid":1386223,"uid":39752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T10:54:15.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"70d99fb430355d691fb0cabbfa60751badddaed8","tid":1386223,"uid":39752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T10:59:26.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"5a5052311b6464920f10bf9c85154396f7e6c9b7","tid":1386223,"uid":39752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T11:07:25.000Z","msg":"推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"bd8cfee500c287377b2a90036ad0e7385b2d09f0","tid":1386223,"uid":39752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T11:20:23.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>首先梗係屈咗人哋唔派飯唔助養山區兒童先</strong></span></span><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://thestandnews.com/politics/612%E4%BA%BA%E9%81%93%E6%94%AF%E6%8F%B4%E5%9F%BA%E9%87%91-%E6%AD%A3%E5%BC%8F%E6%88%90%E7%AB%8B-%E6%8E%A5%E5%8F%97%E6%8D%90%E6%AC%BE-%E6%94%AF%E6%8F%B4%E5%8F%8D%E9%80%81%E4%B8%AD%E9%81%8B%E5%8B%95%E4%B8%AD%E5%8F%97%E5%82%B7%E8%A2%AB%E6%8D%95%E7%AD%89%E4%BA%BA%E5%A3%AB/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F612%25E4%25BA%25BA%25E9%2581%2593%25E6%2594%25AF%25E6%258F%25B4%25E5%259F%25BA%25E9%2587%2591-%25E6%25AD%25A3%25E5%25BC%258F%25E6%2588%2590%25E7%25AB%258B-%25E6%258E%25A5%25E5%258F%2597%25E6%258D%2590%25E6%25AC%25BE-%25E6%2594%25AF%25E6%258F%25B4%25E5%258F%258D%25E9%2580%2581%25E4%25B8%25AD%25E9%2581%258B%25E5%258B%2595%25E4%25B8%25AD%25E5%258F%2597%25E5%2582%25B7%25E8%25A2%25AB%25E6%258D%2595%25E7%25AD%2589%25E4%25BA%25BA%25E5%25A3%25AB%2F&d=R3EG5gZ7WKeJnJLyvNLCufcTfOzAwtSP2zPdisjLlXU%3D&h=3cae7837\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F612%25E4%25BA%25BA%25E9%2581%2593%25E6%2594%25AF%25E6%258F%25B4%25E5%259F%25BA%25E9%2587%2591-%25E6%25AD%25A3%25E5%25BC%258F%25E6%2588%2590%25E7%25AB%258B-%25E6%258E%25A5%25E5%258F%2597%25E6%258D%2590%25E6%25AC%25BE-%25E6%2594%25AF%25E6%258F%25B4%25E5%258F%258D%25E9%2580%2581%25E4%25B8%25AD%25E9%2581%258B%25E5%258B%2595%25E4%25B8%25AD%25E5%258F%2597%25E5%2582%25B7%25E8%25A2%25AB%25E6%258D%2595%25E7%25AD%2589%25E4%25BA%25BA%25E5%25A3%25AB%2F&h=9e067030\" data-auto-link target=\"_blank\">https://thestandnews.com/politics/612%E4%BA%BA%E9%81%93%E6%94%AF%E6%8F%B4%E5%9F%BA%E9%87%91-%E6%AD%A3%E5%BC%8F%E6%88%90%E7%AB%8B-%E6%8E%A5%E5%8F%97%E6%8D%90%E6%AC%BE-%E6%94%AF%E6%8F%B4%E5%8F%8D%E9%80%81%E4%B8%AD%E9%81%8B%E5%8B%95%E4%B8%AD%E5%8F%97%E5%82%B7%E8%A2%AB%E6%8D%95%E7%AD%89%E4%BA%BA%E5%A3%AB/</a><br />\n<br />\n<span style=\"color: orange;\">基金首要為在反送中運動中受傷、已遭受拘捕或很可能被拘捕的人士提供人道支援，例如上述人士接受醫療服務、心理輔導或法律諮詢的費用。如將來涉及刑事或民事法律程序，基金亦會考慮支援有關訴訟而引致我方的法律開支或法援分擔費。但對於民事訴訟方面有較大的限制，因為基金無法承擔對方的訟費。如因受傷或被捕而引致的經濟困難，基金亦會按個別情況考慮支援；不幸身故死者的直屬家人如需援助，基金亦會酌情提供資助。<br />\n資助有關反送中運動的各種投訴及調查項目，資助範圍包括相關的法律費用、調查研究、舉辦活動開支或出席國際會議等。<br />\n除了上述支援之外，基金在接受查詢的過程中如發現有其他支援需要，信託人將會於基金宗旨許可的範圍內靈活處理，讓基金能發揮最大的作用。<br />\n基金日常運作的必要開支，如核數費用、負責行政及跟進個案職員的薪金等。</span>"},{"pid":"11f35b3953e55c05d75a10ff6d3c49ae59d319bf","tid":1386223,"uid":105511,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-30T11:30:06.000Z","msg":"同屈勇武一入村就燒村屠村一撚樣<br />\n最後個日連村口都掂唔到"},{"pid":"9655871daa4c951b5871579d83c33f0effe913c2","tid":1386223,"uid":39752,"like":0,"dislike":0,"score":0,"quote":{"pid":"11f35b3953e55c05d75a10ff6d3c49ae59d319bf","tid":1386223,"uid":105511,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-30T11:30:06.000Z","msg":"同屈勇武一入村就燒村屠村一撚樣<br />\n最後個日連村口都掂唔到"},"citedBy":0,"replyTime":"2019-07-30T12:17:19.000Z","msg":"exactly<br />\n高級玩法就喺公海講完 cap 圖嚟屌<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"68959fc4cd0deb47b29b41d1fd1d97bdcb30af3f","tid":1386223,"uid":62032,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:20:23.000Z","msg":"係要小心"},{"pid":"257f18e2e828802a1407a6d529940d4c3e06fd89","tid":1386223,"uid":50457,"like":0,"dislike":0,"score":0,"quote":{"pid":"98f1b825f7ac607d5eb071ed0075cec35241bf57","tid":1386223,"uid":39752,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-30T09:40:56.000Z","msg":"舉個遠少少嘅例子<br />\n大家記唔記得七月十號呢段新聞呢？<br />\n<br />\n<a href=\"https://m.mingpao.com/pns/%E8%A6%81%E8%81%9E/article/20190710/s00001/1562696095126/10%E5%AD%B8%E7%94%9F%E6%9C%83-%E7%84%A1%E5%89%8D%E8%A8%AD%E8%A6%81%E6%B1%82%E5%B0%8D%E8%A9%B1%E6%98%AF%E7%99%A1%E5%BF%83%E5%A6%84%E6%83%B3\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.mingpao.com%2Fpns%2F%25E8%25A6%2581%25E8%2581%259E%2Farticle%2F20190710%2Fs00001%2F1562696095126%2F10%25E5%25AD%25B8%25E7%2594%259F%25E6%259C%2583-%25E7%2584%25A1%25E5%2589%258D%25E8%25A8%25AD%25E8%25A6%2581%25E6%25B1%2582%25E5%25B0%258D%25E8%25A9%25B1%25E6%2598%25AF%25E7%2599%25A1%25E5%25BF%2583%25E5%25A6%2584%25E6%2583%25B3&d=R3EG5gZ7WKeJnJLyvNLCufcTfOzAwtSP2zPdisjLlXU%3D&h=796855cd\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fm.mingpao.com%2Fpns%2F%25E8%25A6%2581%25E8%2581%259E%2Farticle%2F20190710%2Fs00001%2F1562696095126%2F10%25E5%25AD%25B8%25E7%2594%259F%25E6%259C%2583-%25E7%2584%25A1%25E5%2589%258D%25E8%25A8%25AD%25E8%25A6%2581%25E6%25B1%2582%25E5%25B0%258D%25E8%25A9%25B1%25E6%2598%25AF%25E7%2599%25A1%25E5%25BF%2583%25E5%25A6%2584%25E6%2583%25B3&h=27b923d6\" data-auto-link target=\"_blank\">https://m.mingpao.com/pns/%E8%A6%81%E8%81%9E/article/20190710/s00001/1562696095126/10%E5%AD%B8%E7%94%9F%E6%9C%83-%E7%84%A1%E5%89%8D%E8%A8%AD%E8%A6%81%E6%B1%82%E5%B0%8D%E8%A9%B1%E6%98%AF%E7%99%A1%E5%BF%83%E5%A6%84%E6%83%B3</a><br />\n<span style=\"color: gold;\">【明報專訊】特首林鄭月娥昨日出席行政會議前表示，願意與大專學界「公開對話」，而非原先提出的閉門會面，但希望是於互相沒有前設下進行。10間大專院校的學生會聯合發聲明稱，學界多次指出考慮見面的兩大前設，包括永不追究6月9日及之後的「反送中」示威者，以及會面須公開邀請市民、各界別代表及傳媒出席，若政府要求學界放棄這兩大前設，是「癡心妄想」，亦無可能會面。</span><br />\n<br />\n學生會喺七月十號之前直至而家嘅立場都無變過<br />\n以上嗰段聲明都一樣，用人話翻譯就係<br />\n「你幫我含，我咪考慮吓談判囉」<br />\n<strong><span style=\"color: red;\">開出港共絕對唔會接受嘅條件作為前設<br />\n實際上等同羞辱緊港共<br />\n亦根本無任何要談判嘅意思</span></strong><br />\n<br />\n唔知大家記唔記得，當時有<span style=\"color: red;\">某批人</span>瘋狂咁屌<br />\n<span style=\"color: red;\"><span style=\"font-size: x-large;\"><strong>「學生會試圖談判！扮大台！騎劫！搞散運動！鬼！」</strong></span></span><br />\n<br />\n香港一日咁多新聞，件事當然好快不了了之<br />\n<strong><span style=\"color: red;\">但喺某啲跟車無咁貼、邏輯思考弱嘅人眼中<br />\n幾大學生會就忽然間變成試圖談判嘅鬼<br />\n「只係大家阻止得快」</span></strong><br />\n<br />\n所謂打稻草人，就係<br />\n「明明你無做過，屈你有做，搏你唔回應」<br />\n「件事不了了之，壞印象流傳一世」<br />\n「針對意圖呢一種無法驗證、捕風捉影嘅點去打」<br />\n「對方有做就係斷正，無做就係好在我喝住佢」<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">而家係咪又有「同一批人」開始打緊稻草人呢？</span></span></strong>"},"citedBy":0,"replyTime":"2019-07-30T13:22:51.000Z","msg":"今日一堆就係打泛民主派無出聲，612基金無用兩個稻草人"},{"pid":"98fc89fd5080fdbbc1e69734e9bee382a1d46d4e","tid":1386223,"uid":105995,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:25:08.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />好多隱性三毛做緊呢樣野<br />\n<br />\n大家睇路"},{"pid":"edc56be738f040ee70120932f3f3c3bca5b907e0","tid":1386223,"uid":172345,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:26:45.000Z","msg":"哩班仆街趷起條尾就知佢地想做乜<br />\n係水深火熱之際仲要抽水真係冚家鏟"},{"pid":"02394edbd529acb6e454a33cc077a8357172a505","tid":1386223,"uid":39752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T13:37:22.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"e50205e5c5b69083253d6a921ea0b74df4137833","tid":1386223,"uid":38482,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-30T13:38:11.000Z","msg":"咪熱狗囉<br />\n成功左要清算佢地"}]}