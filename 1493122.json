51ebaf810842074a8824ae63719e8444f58","tid":1493122,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T06:55:02.000Z","msg":"今晚元朗西鐵站默坐<br />\n<br />\n<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-21T07:02:38.000Z","msg":"1900-2300"},{"pid":"41f6845e04f4d97169af59ba3263e7048dcdeb31","tid":1493122,"uid":278765,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T07:04:13.000Z","msg":"其實我覺得利君雅，已經非常克制。換轉喺任何另外一個香港人，可能已經爆粗問候林鄭老母！雅雅好波，加油"},{"pid":"b2c19a459f7b92d112f0d291c9bbb1f2c386be43","tid":1493122,"uid":166117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T07:07:02.000Z","msg":"<img src=\"https://na.cx/i/W8NQdHU.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FW8NQdHU.png&h=f77d7d64&s={SIZE}\" />"},{"pid":"434cb92987ac317ae98e0db6f6b699e95b75807e","tid":1493122,"uid":52341,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T07:22:41.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}