好想玩玩了。"},{"pid":"b0c153720585bb897ae568b3fa42773e9296b73b","tid":1299951,"uid":150100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-09T12:58:02.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a9c9f2cb0c2a50f18477dc289763b991754db2cf","tid":1299951,"uid":150100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-09T13:38:50.000Z","msg":"<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"},{"pid":"41afeec7114c0e3f1fcd670fc367a4efb1a31df4","tid":1299951,"uid":150100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-09T13:55:28.000Z","msg":"<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1730977927a0c23ac4a8295987d6e1a4c945e89d","tid":1299951,"uid":150100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-09T15:14:19.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"b202d2b33c28ee3060ba0cb6302586c47fe2ac94","tid":1299951,"uid":59832,"like":0,"dislike":0,"score":0,"quote":{"pid":"99f6ccefb5c25b96a4cf179d6e1733c4e2bbf28c","tid":1299951,"uid":214690,"like":1,"dislike":0,"score":1,"quote":{"pid":"4f703b2e3833d77d8a2eb30b4d2002bbae8e6c06","tid":1299951,"uid":150100,"like":19,"dislike":0,"score":19,"quote":{"pid":"40392c4db9ae012a6b8242a51fdf4193896220e9","tid":1299951,"uid":214690,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-07-09T08:22:13.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2019-07-09T08:24:04.000Z","msg":"恆大難入過港大醫學院"},"citedBy":1,"replyTime":"2019-07-09T08:29:16.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-07-09T15:23:37.000Z","msg":"BSex"},{"pid":"f7546c219e9f3b52aefb2e0f8fd53ace123faf99","tid":1299951,"uid":83251,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-07-09T15:24:27.000Z","msg":"OU Nursing &amp; Computer science <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"