aces/lny/pig2.gif\" class=\"hkgmoji\" />"},{"pid":"50e9ca98c96ba37d1d3f9ed976121b6fcb3d8cf3","tid":1006824,"uid":26602,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-03T10:40:45.000Z","msg":"睇左咁多年張床褥圖都仲係笑到停唔到<img src=\"/assets/faces/lny/chicken1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken3.gif\" class=\"hkgmoji\" />"},{"pid":"86992bae3d18c5c2fbc15d1791f6a18fe9c211ce","tid":1006824,"uid":182933,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-03T10:41:18.000Z","msg":"此回覆已被刪除"},{"pid":"1b66373d2da92bb5846eaa020b39129ca36959e2","tid":1006824,"uid":4161,"like":1,"dislike":5,"score":-4,"quote":{"pid":"87fb146cdf87624134d8dd33ea6ab53cce079923","tid":1006824,"uid":215207,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-03T09:31:46.000Z","msg":"電視機　電腦　枱櫈　廚具　衣物&hellip;&hellip;<br />\n失戀青年全屋物件掟落街<br />\n<br />\n【本報訊】天水圍天悅出現高空擲物狂徒，一名青年疑受失戀打擊精神大受刺激，昨日瘋狂地將屋內的家具、電器及雜物等掟落街中，警方接報封鎖現場，與擲物狂徒對峙期間，他仍不停拋下大小物件，最後屋內除重型電器及床外，幾乎全被他拋清光，幸而未有傷及途人。事件擾攘兩個多小時後，警方破門入屋將狂徒制服送院，他涉嫌高空擲物被扣查。　<br />\n<br />\n<img src=\"http://static.apple.nextmedia.com/images/apple-photos/640pix/20050328/Article_news/28la2p3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fapple-photos%2F640pix%2F20050328%2FArticle_news%2F28la2p3.jpg&h=4dc2e11b&s={SIZE}\" /><br />\n<br />\n<img src=\"http://static.apple.nextmedia.com/images/apple-photos/640pix/20050327/Article_news/27la2p11.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fapple-photos%2F640pix%2F20050327%2FArticle_news%2F27la2p11.jpg&h=05aa471e&s={SIZE}\" /><br />\n青年疑失戀，不停將屋內電器及雜物擲落街上，警方將現場封鎖，地上滿布被擲下的家具及雜物。 <br />\n<br />\n<img src=\"http://static.apple.nextmedia.com/images/apple-photos/640pix/20050327/Article_news/27la2p133.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fapple-photos%2F640pix%2F20050327%2FArticle_news%2F27la2p133.jpg&h=ec6ddf85&s={SIZE}\" /><br />\n青年所住單位事發後空空如也，只剩下幾件大型家具及電器。<br />\n<br />\n<img src=\"http://static.apple.nextmedia.com/images/apple-photos/640pix/20050327/Article_news/27la2p16.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fapple-photos%2F640pix%2F20050327%2FArticle_news%2F27la2p16.jpg&h=0f6f4e07&s={SIZE}\" /><br />\n被男事主擲下的一張床褥，從三十六樓飛下街中。 <br />\n<br />\n<img src=\"http://static.apple.nextmedia.com/images/apple-photos/640pix/20050327/Article_news/27la2p14.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fapple-photos%2F640pix%2F20050327%2FArticle_news%2F27la2p14.jpg&h=4d4a497a&s={SIZE}\" /><br />\n發狂擲物落街的男事主，不時在屋內大聲呼叫。<br />\n<br />\n<img src=\"https://static.appledaily.hk/images/apple-photos/640pix/20050327/Article_news/newx111.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fapple-photos%2F640pix%2F20050327%2FArticle_news%2Fnewx111.gif&h=ce088699&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-02-03T10:56:49.000Z","msg":"Old news is so exciting"},{"pid":"a065a3d0d42e058d8fd6881d6a2748b08ffbfcbe","tid":1006824,"uid":16783,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-02-03T11:17:48.000Z","msg":"佢屋企人放工返到屋企會點？<br />\n一路經過樓下一路諗點解地下啲垃圾咁似屋企啲野<img src=\"/assets/faces/lny/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"c99c4919a18da802ce3aeaa4f9684828c839198d","tid":1006824,"uid":215207,"like":11,"dislike":0,"score":11,"quote":{"pid":"a065a3d0d42e058d8fd6881d6a2748b08ffbfcbe","tid":1006824,"uid":16783,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-02-03T11:17:48.000Z","msg":"佢屋企人放工返到屋企會點？<br />\n一路經過樓下一路諗點解地下啲垃圾咁似屋企啲野<img src