f4c8","tid":474444,"uid":108740,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-20T07:16:34.000Z","msg":"淨係同差唔多年紀既傾計 其他人除咗公事乜柒都唔講 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"32b35689a9405f01cd1b2f30ad8ee0962f84a7de","tid":474444,"uid":157977,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-20T07:18:59.000Z","msg":"<blockquote>淨係同差唔多年紀既傾計 其他人除咗公事乜柒都唔講 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n我冇分年紀, 啱傾就咩年紀都得, 不過基本上都好少出聲, 成日諗自己嘅嘢<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"dfb6628b5c8628a6cb55aa227a3cee28a198ecb5","tid":474444,"uid":57835,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-20T07:37:41.000Z","msg":"個個都啊姐黎喎<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"aeb1f54638346ffb013d44afcc0b33e46bb40370","tid":474444,"uid":115323,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-11-20T07:39:40.000Z","msg":"成日比人話唔出聲黑面<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />  明明就唔係"},{"pid":"2d0f974314872fb6778cf5c2ecd7f61e670755c6","tid":474444,"uid":56533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-20T07:42:24.000Z","msg":"每次開工都係孤身隻影<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"0ed8ed9bbc28659693287139240dc2cfb3c535eb","tid":474444,"uid":44916,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-20T07:43:16.000Z","msg":"剩係同兩三個講嘢，其他會自動自閉mode"},{"pid":"1add01a1d9b96c0faa418f9446535c7c03838e1a","tid":474444,"uid":157977,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-20T07:58:06.000Z","msg":"<blockquote>成日比人話唔出聲黑面<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />  明明就唔係</blockquote><br />\n<br />\n最煩就係呢樣嘢, 其實我冇惡意, 只係唔想煩啫"},{"pid":"82c4736867d7b9f12dbf1c62bdde125cf221d891","tid":474444,"uid":3186,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-20T08:12:04.000Z","msg":"<blockquote><blockquote>成日比人話唔出聲黑面<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />  明明就唔係</blockquote><br />\n<br />\n最煩就係呢樣嘢, 其實我冇惡意, 只係唔想煩啫</blockquote><br />\n<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <br />\n同同事年紀唔同<br />\n佢地又好鍾意講車<br />\n連打機都係講車<br />\n但自己又在得遠又對車無咩興趣<br />\n<br />\n平時個樣又目無表情<br />\n好似好惡咁<br />\n我諗同層啲人見到都驚左我<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a2209e9400d5ede971c547eae0c28f9bf6967e74","tid":474444,"uid":143241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-20T11:57:29.000Z","msg":"番工o者,又唔係去識朋友.<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"51878164631ec25a169bfc228de4d957d7f81bac","tid":474444,"uid":24570,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-20T13:27:37.000Z","msg":"冇個啱傾<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"201430f1d88df42cf766ace77cf4c9d6ae784750","tid":474444,"uid":1060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-20T13:30:05.000Z","msg":"會同人鳩嗡<br />\n但永遠都自己帶飯食"},{"pid":"8e41d9c75a2add000c2326cebb4ebff41a5e2edf","tid":474444,"uid":111929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-21T00:58:18.000Z","msg":"比老細話太cool，唔笑但樣好惡<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"9ba34d133e807b56b1e75c39b054e66eb0416be3","tid":474444,"uid":30694,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-21T01:14:03.000Z","msg":"唔講野比人話毒<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"6610a930861883c49b1213400c57f002cebfb708","tid":474444,"uid":54593,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-21T11:34:22.000Z","msg":"留名 返工每日可以唔講多過十句野<br />\n主要用Skype 打字交流"},{"pid":"bf1beb88116ef866131eeccfb5476838f7ae3f9f","tid":474444,"uid":35882,"like":0,"dis