4035939039753345/</a>"},{"pid":"99eb7698a77d9548f1d257a28a3a0a3a220f1c8b","tid":1922111,"uid":99642,"like":2,"dislike":0,"score":2,"quote":{"pid":"1bcee736e4e2422e7d86daac77e8f4e486cf5bb1","tid":1922111,"uid":200465,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-12T11:29:57.000Z","msg":"兩輪咋<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n咁樂觀<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-12T11:56:10.000Z","msg":"14日差不多"},{"pid":"394a1e6053249679d6d1b81fc0480637b440021b","tid":1922111,"uid":9104,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-03-12T11:57:51.000Z","msg":"點解出亞洲後咁多出名明星球員官員奶野"},{"pid":"af1cf8ac8f7ae4ee6030c65c686fb4a85bd0117f","tid":1922111,"uid":13343,"like":3,"dislike":0,"score":3,"quote":{"pid":"394a1e6053249679d6d1b81fc0480637b440021b","tid":1922111,"uid":9104,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-03-12T11:57:51.000Z","msg":"點解出亞洲後咁多出名明星球員官員奶野"},"citedBy":0,"replyTime":"2020-03-12T12:00:36.000Z","msg":"亞洲明星高官唔信強國世衛<br />\n一早買定晒口罩洗手液<br />\n<br />\n歐美人真心信世衛同強國<br />\n一直都唔信係大鑊嘢<br />\n你睇個nba球星咁on9就知"}]}