款落到有需要人士又真係有幾多?"},{"pid":"6223e85f141613f9fefaa4d1f4d55cc9fbdc83d2","tid":1733663,"uid":117737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T09:57:46.000Z","msg":"push"},{"pid":"b8a3a8dbf26ca828b1f04e9346829bd334afcf41","tid":1733663,"uid":117737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T10:13:27.000Z","msg":"<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"3dc5138edffaec7405f7b984016bfaffdca64767","tid":1733663,"uid":117737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T11:07:36.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"3c3148c3210e4a84b43716e0ed7ef1a6565f75ca","tid":1733663,"uid":117737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T11:43:56.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"bad6747aa46b6c19233a0bab21adeaab09ce584f","tid":1733663,"uid":117737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T13:07:23.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"48f53ff08aa80fc2719471a15ebea1984ce8685c","tid":1733663,"uid":117737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T15:21:17.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"}]}