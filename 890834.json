更正，我已經表示願意承擔所有責任，主管都拒絕更正，心存僥倖下個月有男人加入條數可以啱番，點知一直加入嘅都係女人，所以條數一直錯"},{"pid":"d7c2cfe28c3ba7b48615669324da8d16dc82d0a7","tid":890834,"uid":20816,"like":1,"dislike":0,"score":1,"quote":{"pid":"6c748b450aa1458ffc170d287da11c3bbaad6ecc","tid":890834,"uid":210071,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2018-11-05T15:36:54.000Z","msg":"將見終<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-05T15:47:33.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6b354ba9f9a971cdde1667ad13391bda923422e2","tid":890834,"uid":20816,"like":0,"dislike":1,"score":-1,"quote":{"pid":"31d2bad5f2bdddc4274d96cc08cc600e36439b05","tid":890834,"uid":29080,"like":3,"dislike":0,"score":3,"quote":{"pid":"b84f9a660a4c9c7e070344169f9498f4cfa3ace9","tid":890834,"uid":20816,"like":0,"dislike":1,"score":-1,"quote":{"pid":"2979dc8fb6d5e0b16ef504b6cf7d94e73a5e28b6","tid":890834,"uid":3122,"like":11,"dislike":1,"score":10,"citedBy":1,"replyTime":"2018-11-05T15:31:49.000Z","msg":"縱容下屬包庇偽造文件<br />\n好嚴重WO??"},"citedBy":1,"replyTime":"2018-11-05T15:36:45.000Z","msg":"係"},"citedBy":1,"replyTime":"2018-11-05T15:37:27.000Z","msg":"證據<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-05T15:47:53.000Z","msg":"無帶走任何文件<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"049d450622ad0bee68c93cd164a6a50b34e31184","tid":890834,"uid":20816,"like":0,"dislike":0,"score":0,"quote":{"pid":"4e5b1729e6e7dfabd867cdd63eaaed7977a7f513","tid":890834,"uid":48286,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-05T15:42:25.000Z","msg":"咁撚屌波吳？"},"citedBy":0,"replyTime":"2018-11-05T15:48:09.000Z","msg":"<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"70c378144c4b7133726cd93986ebdcd8a7cb7e3f","tid":890834,"uid":20816,"like":0,"dislike":1,"score":-1,"quote":{"pid":"308