一定嘅話題性嘅，呢個都係一個好嘅活動嚟，而唔係亂咁絕食"},{"pid":"7ad8b9de1774562e028868f71b2cc920c9bf5368","tid":2339114,"uid":138144,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-24T12:35:32.000Z","msg":"bump"},{"pid":"f3ce45934e25a8b8aa8122495749871d00054a0d","tid":2339114,"uid":91721,"like":0,"dislike":0,"score":0,"quote":{"pid":"632d79aa1f976c389e47e707f83b696fab03a7ce","tid":2339114,"uid":14494,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-24T11:49:43.000Z","msg":"twitter都越黎越少人<img src=\"/assets/faces/xm/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-24T12:37:47.000Z","msg":"入去幫手支持下<br />\n<br />\n佢長期俾五毛圍攻"},{"pid":"27b01ebb2fec74dd73963f9a74af06d46594a580","tid":2339114,"uid":91721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-24T12:51:08.000Z","msg":"up"},{"pid":"dd604cb122737de7494891dff9b5005883814041","tid":2339114,"uid":91721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-24T13:00:27.000Z","msg":"up"},{"pid":"b83a1f0e040b94ff6e605b7dfea274d414367cf0","tid":2339114,"uid":53498,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-24T13:01:38.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"cdc034d9915815875ff99fab51a02af62afddcf3","tid":2339114,"uid":91721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-24T13:12:14.000Z","msg":"up"},{"pid":"c90503c8eeec524b5a749cf6cd0f6a14a89d3953","tid":2339114,"uid":91721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-24T13:31:46.000Z","msg":"up"},{"pid":"b33e517dcf2067e78c0f7502ed6f74adab86d696","tid":2339114,"uid":91721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-24T16:44:50.000Z","msg":"up"},{"pid":"58fc384b2e29901ce45b6c511bfbf799cc333867","tid":2339114,"uid":60259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-24T16:47:31.000Z","msg":"Pushhhhh"},{"pid":"bd33033fd5f32e78e773d83d66dc66e62b243464","tid":2339114,"uid":40,"like":0,"dislike":0