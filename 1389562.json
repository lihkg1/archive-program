/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f461bc1bdcab89fa212a496e6ed0d9b85bdf6b80","tid":1389562,"uid":79589,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2019-07-31T02:56:58.000Z","msg":"如果有任何公務員、地鐵車長因爲支持罷工、集會而受到上司、政府壓力，甚至被致<br />\n<br />\n香港人一定會幫你討回公道<br />\n<br />\n所以，求下你地一定要行出黎<br />\n已經有一班人付出佢地嘅生命為香港爭取民主<br />\n佢哋大可以選擇做港豬，打份工過一世，點解會頻犧牲？就係因為佢地愛香港，想每一個香港人都得到自由同民主<br />\n<br />\n8月2、8月5一定要有你地支持"},{"pid":"65f9972afa3db48db23717c1aa467bbb4ef947cd","tid":1389562,"uid":220601,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T03:03:52.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a72e7716552e02a5c7874324b7898b0388a7c069","tid":1389562,"uid":41411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T03:20:18.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"cc064944661c9b3955a87dc87c8fe0bcf15418cc","tid":1389562,"uid":41411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T04:27:28.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"d6aafe0439a6b4118ebf25a14e1e4e36f1550d98","tid":1389562,"uid":258465,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T04:37:30.000Z","msg":"8.2遮打集會<br />\n8.5全民罷工"},{"pid":"b36751c88c15c4f06d1868d106bc0d8a0583d527","tid":1389562,"uid":282875,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T04:41:29.000Z","msg":"[文宣長文] 全城罷工，反對送中，五大訴求，竭力追究<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1389934\" data-auto-link target=\"_blank\">https://lih.kg/1389934</a>"},{"pid":"116611ebd9b90d6a22a0e0cc1ab8f945c4aca64c","tid":1389562,"uid":63927,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-31T05:02:46.000Z","msg":"8.2遮打集會<br />\n8.5全民罷工"},{"pid":"d87b31858526b243713e707c35abc9aa531e697b",