\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1475856-20190821.htm&h=d20f61ef\" target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1475856-20190821.htm</a>"},"citedBy":0,"replyTime":"2019-08-21T03:46:32.000Z","msg":"明明廣大港人都支持民主派<br />\n支持反民主派先係少數<br />\n而呢個少數不包括嗰堆<br />\n支持獨栽政權嘅中国人"},{"pid":"d90b270e0163c3c5c6a684effb55283a1da2874a","tid":1492683,"uid":208484,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T03:47:14.000Z","msg":"<img src=\"https://na.cx/i/6M6UEwC.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6M6UEwC.png&h=38280765&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/wPLRGKY.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwPLRGKY.jpg&h=ace56d56&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/3SJWSRD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3SJWSRD.jpg&h=1ec88192&s={SIZE}\" />"},{"pid":"b498273f05197a2fdd42fbcba844037e525485ff","tid":1492683,"uid":40415,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T03:47:48.000Z","msg":"堅決鬥爭"},{"pid":"f97472c032b7bc9ffa84e011f5bf4ea53c015e60","tid":1492683,"uid":210895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T03:48:13.000Z","msg":"此回覆已被刪除"},{"pid":"4ac131e29c1e4282409f44c1fd5922e268cb362a","tid":1492683,"uid":158889,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T03:48:46.000Z","msg":"聽到未 和理非比邊個睇"},{"pid":"9877e9947f262130990bf4de3c732e2e16829f92","tid":1492683,"uid":265443,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T03:49:01.000Z","msg":"老解"},{"pid":"4951b93c77c9f876cd713c37e3775269b8c5a11e","tid":1492683,"uid":253016,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T03:49:28.000Z","msg":"咁攬炒囉屌你老母支那"},{"pid":"b7593b5e1a9e33eb51e0b820e27afc45634dd024","tid":1492683,"uid":189260,"like":0,"dislike":0,"score":0,"citedBy":0,"reply