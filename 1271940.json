:31:16.000Z","msg":"push"},{"pid":"e34b2ae16183f54b58e6ecf460125406db353d05","tid":1271940,"uid":2373,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T09:32:38.000Z","msg":"好同意"},{"pid":"588d261530eec4889ed046911296aec707fb43d0","tid":1271940,"uid":104499,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-07-01T09:32:42.000Z","msg":"老實講 跟本去到而家個階段，民唔民意已經完全唔重要，要醒既人神早醒左，政治從來無中立呢樣野，就算今日某位巴絲去殺晒d速龍殺埋d建制派，唔通我地就會轉軚撐警撐政府?<br />\n<br />\n驚民意輿論? 如果因為咁樣改變左你既政治立場，姐係個d咩中間派，我會稱之為垃圾<br />\n你地要記住香港人企出黎既原因到底係乜 ，搞社運從來唔係睇表面個層<br />\n<br />\n手足們be water 大家加油"},{"pid":"f3a83cd1083946500a87827b70e8bc1d2dd1ddf4","tid":1271940,"uid":80386,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T09:37:17.000Z","msg":"不嬲都覺得唔使要民意, 因為香港政府唔會理民意, 只要做到目標就得, 真香港人加油!"},{"pid":"15b3134851ead2cbabbdd789f6b705fc4ec8a94d","tid":1271940,"uid":91616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T09:45:03.000Z","msg":"一碰就碎的玻璃民意是沒有用的"},{"pid":"ef77d9d44048675e5f618bb89703fb8c60bb3a57","tid":1271940,"uid":191366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T09:45:40.000Z","msg":"冇錯"},{"pid":"9938a38f58c4d32a7c86e9b1aeb3ff3d0f9da8b1","tid":1271940,"uid":191366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T09:45:58.000Z","msg":"Push"},{"pid":"835b8c2b34c163b6ac9da591df50dc454fdbe77d","tid":1271940,"uid":91616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T09:46:07.000Z","msg":"香港不是民選政府，民意對政府是沒有約束力的<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"87b1048a40d2821fad759d425633857f7f0e3997","tid":1271940,"uid":109647,"like":0,"dislike":0,"score":0,"quote":{"pid":"48ceaaf3d50283bcf5e974b8493100c856771bce","tid":1271940,"uid":251119,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-01T08:17:31.000Z","msg":"<span style=\"font-size: large;\">因為佢地根本唔係支持緊你既</span><span style=\"font-size: x-large;\"><span style=\"color: gold;\">理念同信念</span></span><br />\n對住一班根本唔係支持你既人<br />\n呢啲所謂既<span style=\"font-size: x-large;\"><span style=\"color: gold;\">民意</span></span> 已經唔再值得我地去爭取<br />\n依家成個運動根本上已經比呢啲<span style=\"font-size: x-large;\"><span style=\"color: gold;\">假民意</span></span><span style=\"font-size: x-large;\"><span style=\"color: red;\">勒索左</span></span><br />\n真正為左香港好而去抗爭既人<br />\n唔再需要咩住<span style=\"font-size: x-large;\"><span style=\"color: gold;\">民意</span></span>呢個包袱<br />\n冇左呢個包袱 話唔定成個運動會更加有效<br />\n而唔似得69至到今日咁<br />\n做左咁多日 <span style=\"font-size: x-large;\"><span style=\"color: red;\">一樣訴求都冇回應</span></span><br />\n<br />\n<img src=\"https://na.cx/i/sVr6o8E.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsVr6o8E.png&h=cb94ad7e&s={SIZE}\" /><img src=\"https://na.cx/i/h7KLEG0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fh7KLEG0.png&h=37a3af2f&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-07-01T09:48:46.000Z","msg":"雞蛋與高牆，很明顯是以卵擊石，結果是石不會毀，雞蛋卻會亡。<br />\n<br />\n為何要站在雞蛋那邊？因為雞蛋是弱勢啊。<br />\n<br />\n陣營選擇，往往不是正義與邪惡的問題，政治是很複雜的東西，不單止政治，其實任何事情都不會有絕對正義或絕對邪惡。「誰是誰非，自有他人、時間、歷史來定論。 」<br />\n<br />\n弱勢的雞蛋，不論有沒有使用暴力，只要他們犯了法，法律會制裁他們，執法者也很樂意送他們上法庭，這些就是雞蛋想反抗時必會遇到的情況。<br />\n<br />\n強勢的高牆，不論幹了甚麼違規行為，執法者都不會把他們送上法庭，法律不會制裁到他們。<br />\n<br />\n高牆不需要其他人來支持，雞蛋卻很需要我們支持。<br />\n<br />\n雞蛋被別人破開是死亡，他從內在破開卻是生命。<br />\n<br />\n我喜歡生命，不喜歡以暴力解決事件，不過，無論雞蛋有多錯，我永遠站在雞蛋這邊。"},{"pid":"bc06ea1b921460bfd9a763189fc0cdc0fbec3c74","tid":1271940,"uid":4618,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-01T09:52:47.000Z","msg":"人民重奪議會 香港民主運動歷史性時刻"},{"pid":"f007d39138d8e979d6d8c90681e10a7dc3f5a477","tid":1271940,"uid":251119,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc06ea1b921460bfd9a763189fc0cdc0fbec3c74","tid":1271940,"uid":4618,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-01T09:52:47.000Z","msg":"人民重奪議會 香港民主運動歷史性時刻"},"citedBy":0,"replyTime":"2019-07-01T09:53:42.000Z","msg":"呢個先係衝立法會既意義"},{"pid":"f93796d11a04b4733db614a8bb4e8cbc777a6692","tid":1271940,"uid":2