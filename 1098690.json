lyTime":"2019-04-10T04:02:52.000Z","msg":"lm"},{"pid":"e2f75a97a6eb8826b23ceaa76aae3985bc85e254","tid":1098690,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-10T04:39:11.000Z","msg":"99年嘅嘢<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"06f04ad4f64e23302c6470884f1e452dcb3c010d","tid":1098690,"uid":19454,"like":0,"dislike":0,"score":0,"quote":{"pid":"e2f75a97a6eb8826b23ceaa76aae3985bc85e254","tid":1098690,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-10T04:39:11.000Z","msg":"99年嘅嘢<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-04-10T04:43:58.000Z","msg":"500億創科<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"258545cbd0b55526c78e33a24554545cb39186b8","tid":1098690,"uid":130105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-10T04:56:44.000Z","msg":"其實好多地方現在唔係預測，基本上係計算到喎<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"d34371116e6c608240108457f8188b0e0abbe215","tid":1098690,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-11T14:18:55.000Z","msg":"lm"},{"pid":"20b979fc81feba19109324fb82ecc23078b20d3e","tid":1098690,"uid":9193,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-11T14:20:29.000Z","msg":"預測到暴雨有鬼用咩 死都唔掛紅雨<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n人治真係戇鳩"},{"pid":"4118c4c8097ffedab6eb980dde21077701501fad","tid":1098690,"uid":159870,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-11T14:21:42.000Z","msg":"99年ge嘢黎2019年攞獎<br />\n會唔會過分左小小"}]}