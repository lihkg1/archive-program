{"tid":1485232,"cid":33,"subCid":0,"title":"北戴河會議共識 定性香港顏色革命","createTime":"2019-08-18T15:42:17.000Z","updateTime":"2019-08-18T16:08:28.000Z","uid":33267,"like":4,"dislike":0,"uniUserReply":1,"replies":[{"pid":"be752e8acd8bcd2d0eeb3caeef135d312448f81b","tid":1485232,"uid":33267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T15:42:17.000Z","msg":"<a href=\"https://m.mingpao.com/pns/%E4%B8%AD%E5%9C%8B/article/20190817/s00013/1565979208130/%E4%BA%AC%E5%9F%8E%E5%AF%86%E8%AA%9E-%E5%8C%97%E6%88%B4%E6%B2%B3%E6%9C%83%E8%AD%B0%E5%85%B1%E8%AD%98-%E5%AE%9A%E6%80%A7%E9%A6%99%E6%B8%AF%E9%A1%8F%E8%89%B2%E9%9D%A9%E5%91%BD-%E6%96%87-%E9%8D%BE%E4%BB%95\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.mingpao.com%2Fpns%2F%25E4%25B8%25AD%25E5%259C%258B%2Farticle%2F20190817%2Fs00013%2F1565979208130%2F%25E4%25BA%25AC%25E5%259F%258E%25E5%25AF%2586%25E8%25AA%259E-%25E5%258C%2597%25E6%2588%25B4%25E6%25B2%25B3%25E6%259C%2583%25E8%25AD%25B0%25E5%2585%25B1%25E8%25AD%2598-%25E5%25AE%259A%25E6%2580%25A7%25E9%25A6%2599%25E6%25B8%25AF%25E9%25A1%258F%25E8%2589%25B2%25E9%259D%25A9%25E5%2591%25BD-%25E6%2596%2587-%25E9%258D%25BE%25E4%25BB%2595&d=T%2BmtXVGNOTzTHFJD9Tq3cYuQyocENDzUuJTHoiHzCac%3D&h=a49e1aa9\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fm.mingpao.com%2Fpns%2F%25E4%25B8%25AD%25E5%259C%258B%2Farticle%2F20190817%2Fs00013%2F1565979208130%2F%25E4%25BA%25AC%25E5%259F%258E%25E5%25AF%2586%25E8%25AA%259E-%25E5%258C%2597%25E6%2588%25B4%25E6%25B2%25B3%25E6%259C%2583%25E8%25AD%25B0%25E5%2585%25B1%25E8%25AD%2598-%25E5%25AE%259A%25E6%2580%25A7%25E9%25A6%2599%25E6%25B8%25AF%25E9%25A1%258F%25E8%2589%25B2%25E9%259D%25A9%25E5%2591%25BD-%25E6%2596%2587-%25E9%258D%25BE%25E4%25BB%2595&h=a4516d16\" target=\"_blank\">https://m.mingpao.com/pns/%E4%B8%AD%E5%9C%8B/article/20190817/s00013/1565979208130/%E4%BA%AC%E5%9F%8E%E5%AF%86%E8%AA%9E-%E5%8C%97%E6%88%B4%E6%B2%B3%E6%9C%83%E8%AD%B0%E5%85%B1%E8%AD%98-%E5%AE%9A%E6%80%A7%E9%A6%99%E6%B8%AF%E9%A1%8F%E8%89%B2%E9%9D%A9%E5%91%BD-%E6%96%87-%E9%8D%BE%E4%BB%95</a><br />\n<br />\n消息稱，中共高層仍希望港府能憑藉自身能力，在有限時間、法律框架下平息內亂，但若港府力有不逮，中央亦可提供一切法律框架下的「援助」。<br />\n<br />\n民陣已宣布831去中聯辦<br />\n有12日俾港共回應五大訴求<br />\n<br />\n港共亦啱啱已放風，「發言人重申，目前最重要的是要盡快回復社會秩序；當一切平靜之後，政府會與市民展開真誠對話，致力修補撕裂，重建社會和諧。」<br />\n我估，即係有機會有限度回應，尤其時時間必須在十一鄰國國慶前。<br />\n<br />\n<span style=\"font-size: large;\"><span style=\"font-size: medium;\"><span style=\"font-size: large;\"><span style=\"color: red;\">今晚留力，一次咁多，就一次。</span></span></span></span><br />\n<br />\n呢12日傾唔掂數，咁大家合理升級，而831舞台更大，目標更明確，你懂的。"},{"pid":"4a240e25ad785e2f5dbc250ccdad7732c9b70f1d","tid":1485232,"uid":33267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T15:42:52.000Z","msg":"自推"},{"pid":"f7878025ea4495e35e3fa9c21c5cca951b538b74","tid":1485232,"uid":33267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T15:43:23.000Z","msg":"1"},{"pid":"84cb5f93d587f13efade4990366539ae2871f04d","tid":1485232,"uid":33267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T15:43:33.000Z","msg":"2"},{"pid":"55ed0c981e23b8d62649bf350b947f9d919ce029","tid":1485232,"uid":33267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T15:43:47.000Z","msg":"3"},{"pid":"2886e5ebf260744cb6274660241a470947e6237f","tid":1485232,"uid":33267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T15:44:01.000Z","msg":"4"},{"pid":"4ac179af9e61e94806efd56622ffe95e3e8ae6b1","tid":1485232,"uid":33267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:08:28.000Z","msg":"自推5"}]}