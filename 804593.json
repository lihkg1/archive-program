id":128369,"like":0,"dislike":0,"score":0,"quote":{"pid":"c165ecf5f5fb351ce418f3124140e2020b35be24","tid":804593,"uid":177047,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-03T09:12:26.000Z","msg":"證明呢d地方政府莫財，無錢搞免費教育。<br />\n<br />\n<br />\n各位親中愛共大愛支人士快d課金比支共抗美+賑濟地方政府"},"citedBy":1,"replyTime":"2018-09-03T09:36:36.000Z","msg":"俾官員一層層咁貪姐<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-03T09:41:52.000Z","msg":"都唔明點解佢地可以負到幾千億債<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n只係地方政府"},{"pid":"cfce489df7df5ca6bc72aeeb064a8ed1bf6d4629","tid":804593,"uid":12021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-03T09:42:34.000Z","msg":"此回覆已被刪除"},{"pid":"dc2d5a8d18b0de7482bec1e67bde6f81c836ae0d","tid":804593,"uid":4574,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-09-03T09:43:53.000Z","msg":"前世恩 今世果<br />\n<br />\n你啲賤種祖先<br />\n揀咗土共<br />\n預咗後代被人勞役"},{"pid":"6982e75110bca2a384407d68ec47e10dcc66c728","tid":804593,"uid":16676,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-09-03T09:47:00.000Z","msg":"<a href=\"https://youtu.be/kirfo-cuBLM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fkirfo-cuBLM&d=B77mozuHgSHAw5Nhb0exGmi1w7%2FDyS2Kz%2BsYtkalU0Y%3D&h=8e5b7c0f\" target=\"_blank\">https://youtu.be/kirfo-cuBLM</a><br />\n湖南幫前排先賺埋咁多香港人錢<br />\n唔使怕<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"11d679bd21f71d62cbd024c100c1647e8190ab51","tid":804593,"uid":53666,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-03T09:58:30.000Z","msg":"好睇"},{"pid":"810191cc36542e69235a8a6fd18f04e096efce9f","tid":804593,"uid":130575,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-03T10:13:34.000Z","msg":"到底間私校係邊位高幹開架呢<em></em>"}]}