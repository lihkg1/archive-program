/smile.gif\" class=\"hkgmoji\" />"},{"pid":"20cd76fb077db408c78aba58b80b383326b043da","tid":705202,"uid":28366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-17T04:06:34.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a60a6ce144bad209fe45c76584aaadcc2ea96076","tid":705202,"uid":52132,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-06-17T04:32:06.000Z","msg":"無人關心 無人理"},{"pid":"9e2cc011aa12019b821fb2becc71fc70dc60f4a0","tid":705202,"uid":28366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-17T04:56:24.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"216a6546b1875b24bdca0ed5e3e92d547d652416","tid":705202,"uid":12367,"like":3,"dislike":7,"score":-4,"citedBy":1,"replyTime":"2018-06-17T05:15:13.000Z","msg":"又搞埋d on9野真係無眼睇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"4ab7d7aea8f3e37d131e405e50dc8a4fa1b3fe91","tid":705202,"uid":28366,"like":5,"dislike":1,"score":4,"quote":{"pid":"216a6546b1875b24bdca0ed5e3e92d547d652416","tid":705202,"uid":12367,"like":3,"dislike":7,"score":-4,"citedBy":1,"replyTime":"2018-06-17T05:15:13.000Z","msg":"又搞埋d on9野真係無眼睇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-17T05:16:59.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"90849cda070ad3a8924b383b17583255152e9178","tid":705202,"uid":20227,"like":1,"dislike":3,"score":-2,"citedBy":0,"replyTime":"2018-06-17T06:00:35.000Z","msg":"此回覆已被刪除"},{"pid":"19e6af079857267646990f39a553d4db72240051","tid":705202,"uid":28366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-17T06:01:26.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6c77fe5f5140e8857e3b925650c70df549a6df48","tid":705202