:642784,"uid":842,"like":0,"dislike":0,"score":0,"quote":{"pid":"0537b97ac68a8fa76180ad077f8cdd66131ce66c","tid":642784,"uid":20943,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-26T07:08:03.000Z","msg":"<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> 景子"},"citedBy":1,"replyTime":"2018-04-26T08:34:22.000Z","msg":"技術了得<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-26T10:09:38.000Z","msg":"咩技術<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"e4f1d2962dc05f108ff237c7c19bc38002c3bb2a","tid":642784,"uid":842,"like":0,"dislike":0,"score":0,"quote":{"pid":"d604838f30953831d96e320f5ea307d7f55a2002","tid":642784,"uid":20943,"like":1,"dislike":0,"score":1,"quote":{"pid":"b5a037320e08aa1dd6790f7bac4b61ef772ba4d4","tid":642784,"uid":842,"like":0,"dislike":0,"score":0,"quote":{"pid":"0537b97ac68a8fa76180ad077f8cdd66131ce66c","tid":642784,"uid":20943,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-26T07:08:03.000Z","msg":"<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> 景子"},"citedBy":1,"replyTime":"2018-04-26T08:34:22.000Z","msg":"技術了得<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-26T10:09:38.000Z","msg":"咩技術<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-26T10:37:04.000Z","msg":"山下智久被爆難忘北川床技，不時回味床上功夫。<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"25f4c8aca880397948677e659d2302f6916a5d2b","tid":642784,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-26T11:58:42.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> 景子</blockquote><br />\n技術了得<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /></blockquote><br />\n咩技術<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /></blockquote><br />\n山下智久被爆難忘北川床技，不時回味床上功夫。<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /></blockquote><br />\n有冇同daigo分享😂"},{"pid":"fd80a566cafb0c76b5b7dedf9f418056a42d4994","tid":642784,"uid":44730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-26T14:46:22.000Z","msg":"於今年開播的NHK大河劇《西鄉殿》中飾演「篤姬（天璋院）」的北川景子，近日接受日媒「eltha」專訪，她除了透露自己在學習薩摩方言時遇到的困難，也談及自己與篤姬的共通點，是「直率」與「該說的就直說」。<br />\n<br />\n篤姬（天璋院）是江戶時代後期至明治初期的歷史人物，出身於薩摩藩島津家，被島津本家收為養女，為了嫁進德川家而成為近衛家的養女，後來成為江戶幕府第13代將軍德川家定的御台所（將軍夫人）。在大政奉還後的「無血開城」一事上是重要的關鍵人物之一。<br />\n<br />\n由於篤姬的故事曾於2008年拍攝成同名NHK大河劇《篤姬》，平均收視率達24.5%，不僅創下史上首次播出中由第一集同時重播的紀錄，至今仍是21世紀以來收視率最高的大河劇，因此今年的大河劇《西鄉殿》中再次出現篤姬一角，也引起高度關注。<br />\n<br />\n於《西鄉殿》中飾演這個知名角色的北川景子，於訪談中談到自己與篤姬的共通點。她談及，篤姬的話語沒有表裡之分，而且能感受到篤姬自始至終都懷抱著強烈的責任感，直率的貫徹自己的理念。北川景子表示：「如果我判斷這個事情這個時間點應該要說，我也會直率的表達意見。所以我覺得『直率』這點，似乎跟篤姬很像。」<br />\n<br />\n北川景子也透露，篤姬尊敬父母、非常珍惜「家」、以及貫徹信念的這些方面，都讓她非常尊敬。她也談及，由於自己的成長經歷，幾乎都與許多女生一起相處，所以自己一直以來都不太在意異性怎麼看她，也不會去討好異性。<br />\n<br />\n關於自己不在意異性眼光、也不特別討好異性這一點，有些粉絲表示就是因為這樣才喜歡她，因此北川景子表示：「今後也不打算矯飾，想什麼就確實地傳達給對方，想珍惜自己的想法與信念。」她也談及，自己在遇到苦惱時都會盡快轉換心情，希望自己盡力做一個「自然的笑容美人」。<br />\n<br />\n大河劇咁悶點解都可以拍咁多集🤔"},{"pid":"339a65df043940d6fa348877b65337168bf3df1c","tid":642784,"uid":119379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-26T20:56:37.000Z","msg":"lm"}]}