By":0,"replyTime":"2020-11-30T06:53:03.000Z","msg":"冇人?"},{"pid":"7bebf2335fbf1c63023070304771e629b68e9316","tid":2305891,"uid":51753,"like":0,"dislike":0,"score":0,"quote":{"pid":"66bef497bfda3732ea4e9ce8a68502b82f5cfd2c","tid":2305891,"uid":79351,"like":0,"dislike":0,"score":0,"quote":{"pid":"b5175c278bfac48bc9b288c267178ea681daf848","tid":2305891,"uid":48026,"like":7,"dislike":1,"score":6,"citedBy":1,"replyTime":"2020-11-30T05:20:12.000Z","msg":"諗住入黎睇偽娘裝假狗 <img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-11-30T05:26:49.000Z","msg":"+1<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-30T08:34:39.000Z","msg":"+1"},{"pid":"7f4b1f5ad8db14818ca32262a7b2acd559db86a4","tid":2305891,"uid":45498,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-12T19:59:59.000Z","msg":"Cos G<img src=\"/assets/faces/pig/dance3.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"}]}