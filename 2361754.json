d8d2e","tid":2361754,"uid":248054,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2021-01-11T03:35:48.000Z","msg":"<img src=\"https://na.cx/i/9RxRpNu.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F9RxRpNu.png&h=4248d41e&s={SIZE}\" /><img src=\"https://na.cx/i/Ov39bsu.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOv39bsu.png&h=ed03795c&s={SIZE}\" /><br />\n<br />\n而家得抽到300呎已經好似中六合彩咁<br />\n抽完都要比錢買<br />\n<br />\n600呎更係長者家庭先有機會買<br />\n加入紀律部隊 就算junior都有免費拿到600呎單位"},{"pid":"9869ee8b7365e41b374840ff19f95d3844ecbb5b","tid":2361754,"uid":168250,"like":1,"dislike":7,"score":-6,"quote":{"pid":"c79c0ab0005af26988db5a88f9b794023143ba63","tid":2361754,"uid":117689,"like":11,"dislike":0,"score":11,"citedBy":3,"replyTime":"2021-01-11T03:25:39.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-01-11T03:38:20.000Z","msg":"政府覺得佢地職務多 工作時間長 但係人工比文職職系 專業職系低 所以福利比其他公務員好"},{"pid":"f23b68fc92c21ef5788dce54fb9db934d694f989","tid":2361754,"uid":248054,"like":8,"dislike":0,"score":8,"quote":{"pid":"9869ee8b7365e41b374840ff19f95d3844ecbb5b","tid":2361754,"uid":168250,"like":1,"dislike":7,"score":-6,"quote":{"pid":"c79c0ab0005af26988db5a88f9b794023143ba63","tid":2361754,"uid":117689,"like":11,"dislike":0,"score":11,"citedBy":3,"replyTime":"2021-01-11T03:25:39.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-01-11T03:38:20.000Z","msg":"政府覺得佢地職務多 工作時間長 但係人工比文職職系 專業職系低 所以福利比其他公務員好"},"citedBy":2,"replyTime":"2021-01-11T03:39:20.000Z","msg":"醫護都好辛苦<br />\n又唔見有醫護宿舍<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7c9f3dae2498737a4a83cb16a72dddb1758ded8a","tid":2361754,"uid":117689,"like":1,"dislike":0,"score":1,"quote":{"pid":"9869ee8b7365e41b374840ff19f95d3844ecbb5b","tid":2361754,"uid":168250,"like":1,"dislike":7,"score":-6,"quote":{"pid":"c79c0ab0005af26988db5a88f9b794023143ba63"