{"tid":2013672,"cid":9,"subCid":0,"title":"[IOS/AN/PC] 御城プロジェクト：RE～囡囡守城養生Game [55]","createTime":"2020-05-12T12:32:37.000Z","updateTime":"2020-05-13T09:25:06.000Z","uid":35487,"like":1,"dislike":0,"uniUserReply":12,"replies":[{"pid":"c6c986cff1224ca2eabb947cf4cb30f57c5a6b21","tid":2013672,"uid":35487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-12T12:32:37.000Z","msg":"<img src=\"https://na.cx/i/HSHtrhA.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHSHtrhA.png&h=66275aab&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/Bj5t7a9.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBj5t7a9.png&h=259c1777&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/NtFOkJM.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNtFOkJM.png&h=928156be&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/16nQy4s.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F16nQy4s.png&h=9a6b3ffb&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/SUhQy5Q.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSUhQy5Q.png&h=07f41667&s={SIZE}\" /><br />\n<br />\n官方網頁：<br />\n<a href=\"http://oshirore-dmmgames.com/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Foshirore-dmmgames.com%2F&d=EvsgW2mpOVZdTd1tTx%2BWmE2FGjryiJR74P7%2B0uEOyUg%3D&h=89ee0990\" target=\"_blank\">http://oshirore-dmmgames.com/</a><br />\n<br />\n官方Twitter：<br />\n<a href=\"https://twitter.com/ShiroPro_STAFF\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2FShiroPro_STAFF&d=EvsgW2mpOVZdTd1tTx%2BWmE2FGjryiJR74P7%2B0uEOyUg%3D&h=68745f46\" target=\"_blank\">https://twitter.com/ShiroPro_STAFF</a><br />\n<br />\nIOS：<br />\n<a href=\"https://itunes.apple.com/jp/app/id1303315539\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fitunes.apple.com%2Fjp%2Fapp%2Fid1303315539&d=EvsgW2mpOVZdTd1tTx%2BWmE2FGjryiJR74P7%2B0uEOyUg%3D&h=4c16803e\" target=\"