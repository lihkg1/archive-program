6:36.000Z","msg":"買得都預左自己有車"},{"pid":"ecd67eaa6d9fe12c422a9a8fd12c7679943b55cf","tid":1142854,"uid":227275,"like":2,"dislike":0,"score":2,"quote":{"pid":"5d3bcb27d40d1f20f56a26363f751bff0f7ae91f","tid":1142854,"uid":81586,"like":0,"dislike":0,"score":0,"quote":{"pid":"ccda13eb74f6dcc19742be21602b1f538fb174cd","tid":1142854,"uid":227275,"like":5,"dislike":0,"score":5,"citedBy":6,"replyTime":"2019-05-07T14:01:24.000Z","msg":"啟德有咩咁好<br />\n乜撚都冇 又唔近車站"},"citedBy":1,"replyTime":"2019-05-07T14:56:36.000Z","msg":"買得都預左自己有車"},"citedBy":0,"replyTime":"2019-05-07T14:56:59.000Z","msg":"咁洗撚買啟德"},{"pid":"cda87b91f82d0567029bb2f1088fb51d1cea6618","tid":1142854,"uid":93986,"like":9,"dislike":2,"score":7,"quote":{"pid":"ccda13eb74f6dcc19742be21602b1f538fb174cd","tid":1142854,"uid":227275,"like":5,"dislike":0,"score":5,"citedBy":6,"replyTime":"2019-05-07T14:01:24.000Z","msg":"啟德有咩咁好<br />\n乜撚都冇 又唔近車站"},"citedBy":1,"replyTime":"2019-05-07T14:57:33.000Z","msg":"100年前，廣州人講香港有咩好？乜撚都冇，又多魚腥味"},{"pid":"627b5a33d583d143356ab7005cbc14f1d1eeef36","tid":1142854,"uid":61105,"like":0,"dislike":1,"score":-1,"quote":{"pid":"ccda13eb74f6dcc19742be21602b1f538fb174cd","tid":1142854,"uid":227275,"like":5,"dislike":0,"score":5,"citedBy":6,"replyTime":"2019-05-07T14:01:24.000Z","msg":"啟德有咩咁好<br />\n乜撚都冇 又唔近車站"},"citedBy":0,"replyTime":"2019-05-07T16:13:20.000Z","msg":"淺水灣、渣甸山夠乜都無啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f535a17047eccb9e97280aad113540e641a68eb7","tid":1142854,"uid":113373,"like":12,"dislike":0,"score":12,"citedBy":0,"replyTime":"2019-05-07T16:13:47.000Z","msg":"<strong><span style=\"font-size: x-large;\">反對修訂逃犯條例 香港的終局之戰</span><br />\n<br />\n<span style=\"font-size: large;\">5月11日 星期六 早上8點半<br />\n立法會將會開會討論有關修訂 暫未知會否表決 <br />\n由於秘書處政變 原本由涂謹申主持會議改為石禮謙主持<br />\n<br />\n事態危急<br />\n一定要阻止立法<br />\n否則香港直送中國受審<br />\n到時中國話你犯咗中國法律 無需證據 無需理由<br />\n就可以光明正大係香港夾你返中國 <br />\n坐黑獄 洗你腦<br />\n<br />\n<br />\n<span style=\"color: red;\">此修例禍害大於23條立法<br />\n23條&gt;&gt;&gt;(需危害國家安全，香港審判，香港監禁)<br />\n<br />\n修訂逃犯條例 &gt;&gt;&gt;(莫需有，中國政府可任意控告香港人任何罪行，香港會配合執法將你拘捕，移交中國審判及監禁，無需證據 無需理由)</span></span></strong>"},{"pid":"93d208e7ee077774131aa9bbb4dddf906d467b13","tid":1142854,"uid":72399,"like":1,"dislike":0,"score":1,"quote":{"pid":"ccda13eb74f6dcc19742be21602b1f538fb174cd","tid":1142854,"uid":227275,"like":5,"dislike":0,"score":5,"citedBy":6,"replyTime":"2019-05-07T14:01:24.000Z","msg":"啟德有咩咁好<br />\n乜撚都冇 又唔近車站"},"citedBy":0,"replyTime":"2019-05-07T16:16:42.000Z","msg":"依家咩都未起好緊係百無<br />\n望下啟德發展藍圖先講<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"b80edecc390a78f015550066ded52d33549364de","tid":1142854,"uid":124107,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-07T16:26:41.000Z","msg":"此回覆已被刪除"},{"pid":"422f1d069ed1c2733b810a910d60703164760a0c","tid":1142854,"uid":124107,"like":2,"dislike":3,"score":-1,"citedBy":0,"replyTime":"2019-05-07T16:28:16.000Z","msg":"此回覆已被刪除"},{"pid":"1539bb6f60e7404dd897d1e1817f635e43b38e88","tid":1142854,"uid":122318,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-07T17:10:05.000Z","msg":"地王效應<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"18921e0d5539234cf19aec95b9e070ad83f15d32","tid":1142854,"uid":100256,"like":1,"dislike":0,"score":1,"quote":{"pid":"f26c592c78c12cc814c18bd9242b112ddae97d3a","tid":1142854,"uid":93986,"like":17,"dislike":1,"score":16,"citedBy":1,"replyTime":"2019-05-07T10:56:56.000Z","msg":"$30000呎指日可待"},"citedBy":0,"replyTime":"2019-05-08T00:18:33.000Z","msg":"啟德一號都過3萬好耐啦ching<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n地價兩皮 起樓人工最平都8千一呎<br />\n賣出去居然只值3皮<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 發下夢好啦<br />\n起碼都35k樓上嫁啦<br />\n<br />\n利申：想買"},{"pid":"71df5755143f0ee0848f287f7350539a35de22bf","tid":1142854,"uid":187544,"like":4,"dislike":4,"score":0,"quote":{"pid":"00bce511687112d637c15883a6592bdd185210fd","tid":1142854,"uid":227275,"like":5,"dislike":5,"score":0,"quote":{"pid":"33742d1c4534d670e2695945b520c3b461883ad7","tid":1142854,"uid":216780,"like":21,"dislike":1,"score":20,"quote":{"pid":"ccda13eb74f6dcc19742be21602b1f538fb174cd","tid":1142854,"uid":227275,"like":5,"dislike":0,"score":5,"citedBy":6,"replyTime":"2019-05-07T14:01:24.000Z","msg":"啟德有咩咁好<br />\n乜撚都冇 又唔近車站"},"citedBy":1,"replyTime":"2019-05-07T14:54:00.000Z","msg":"你識條撚咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-05-07T14:56:31.000Z","msg":"講黎聽下喇撚樣"},"citedBy":1,"replyTime":"2019-05-08T01:19:14.000Z","msg":"市區最後一個地區而且臨海有維港景，跟據荃西愛炫美咁垃圾都賣咁貴，假設樓價不升不跌情況下，呢塊地起完一定大賺。發展藍圖已計劃好，雖然而家好似咩都無，但照藍圖去起，將來應該好旺，環境好好，啟德未來有香港第一個環保覽車，有一個站係果度，又有地下街，大型商場，體育館等等，你睇2019，梗係話垃圾啦，當去到2029，2039，你就唔係咁講，買樓睇長遠，唔係睇短期"},{"pid":"75174d843392322f66856442e2d43b9e53df2903","tid":1142854,"uid":178317,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-08T09:51:50.000Z","msg":"個景咁靚實過3皮<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"65bcea5af657bd80a03a2848b8836a50ffaac5a1","tid":1142854,"uid":125261,"like":0,"dislike":0,"score":0,"quote":{"pid":"75174d843392322f66856442e2d43b9e53df2903","tid":1142854,"uid":178317,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-08T09:51:50.000Z","msg":"個景咁靚實過3皮<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-08T09:58:30.000Z","msg":"海璇個海景唔靚，都五六萬一呎"},{"pid":"96f877968b269cee4623866211de26e5e664280c","tid":1142854,"uid":76261,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-05-08T11:36:57.000Z","msg":"六個財團夾<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />每個財團夾廿億頂住個價，一人推番一個盤出黎賣都回本有凸啦<br />\n<br />\n誠哥唔玩又執輸喇 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5150292ecb40cae35a1c017cfc3986602187d9a8","tid":1142854,"uid":93986,"like":0,"dislike":0,"score":0,"quote":{"pid":"96f877968b269cee4623866211de26e5e664280c","tid":1142854,"uid":76261,"like":1,"dislike":0,"score":1,