d":2409334,"uid":375325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-15T17:31:58.000Z","msg":"<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />"},{"pid":"baebc5a963cc73adece6bc7bcc1c058e27d99ee4","tid":2409334,"uid":375325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-15T17:32:37.000Z","msg":"<img src=\"/assets/faces/dog/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />"},{"pid":"290a2a038ffb7f012d9ef4c6186f8195967b60f2","tid":2409334,"uid":375325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-15T17:33:38.000Z","msg":"<img src=\"/assets/faces/lny/no.gif\" class=\"hkgmoji\" />"},{"pid":"e4aa60117377b74a9f6fc928b2ebfc9c8b420ab4","tid":2409334,"uid":274123,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2021-02-15T17:38:53.000Z","msg":"樹仁中文出名架嘛<br />\n係自資入面最好<br />\n恒大真心唔知<br />\n公大就有朋友讀，<br />\n佢話入面啲人好廢，<br />\n不過老師係有心教既<br />\n你諗你啦<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"bdeea7948f0ff7dc16c7fb89804bd3b5102bf692","tid":2409334,"uid":306565,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-15T17:43:52.000Z","msg":"禾含<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8a175520a0713394c120cf598d3d76d12863a487","tid":2409334,"uid":12086,"like":7,"dislike":1,"score":6,"citedBy":0,"replyTime":"2021-02-15T17:44:01.000Z","msg":"認真 考好啲去台灣入國立<br />\n台清政交中文絕對好過呢3間<br />\n有心既係果面讀上去會易啲<br />\n尤其依家咁既環境 你到時想留係台灣 憑你國立出身點都搵到下食<br />\n趁細個 出去見識下囉<br />\n<br />\nbtw點解你會覺得有駢文係優點<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /> 基本上每間有詩選既都會掂到下 獨立成科只係講多啲<br />\n如果你care學野多唔多你係要睇多唔多人讀 多人先多科揀 佢門面寫幾多科都係搵你笨<br />\n<br />\n利申中文系"},{"pid":"9735cd19fd6c0fc77c811b4c97810715a42a6328","tid":2409334,"uid":258815,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-02-15T17:45:18.000Z","msg":"中大入唔到香港八大<br />\n但解唔試吓台灣大<br />\n台灣中文好過香港"},{"pid":"51775dd65536de439b207e281c6a1dca08fffdbb","tid":2409334,"uid":258815,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2021-02-15T17:47:43.000Z","msg":"聯合分發（學士班）<br />\n<br />\n第二梯次<br />\n<br />\n。持海外學歷_SAT、海外A Level、IBDP、中學最後三年成績<br />\n<span class=\"red\">報名系統開放：2021年2月8日~3月20日</span><br />\n繳交報名表件和費用：2021年3月8~20日           <br />\n報名費：港幣500元<br />\n<br />\n仲未dead，不如買多個機會"},{"pid":"7ff468d5441a5a65a9c9c5d419e090bba887611c","tid":2409334,"uid":376895,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2021-02-15T17:58:11.000Z","msg":"如果best5都有16-20分而又有決心會勤力讀嘅話建議考慮吓讀hkcc/space嘅文科asso<img src=\"/assets/faces/lm2lny/think.gif\" class=\"hkgmoji\" /><br />\n搏一搏單車變摩托隨時入得返cu/bu/ling u中文<br />\n就算變唔到摩托基本上正正常常咁讀都可以穩陣入返樹大中文<img src=\"/assets/faces/lm2lny/yo.gif\" class=\"hkgmoji\" />"},{"pid":"4ee8621b34a2f5ac541628fd17894a855f7cb358","tid":2409334,"uid":274858,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-15T18:15:04.000Z","msg":"去臺灣讀啦 你獲得嘅會更多"}]}