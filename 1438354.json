%2Fna.cx%2Fi%2FExJBC9C.png&h=09b37a28&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/Codx3B5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCodx3B5.jpg&h=90ddc2fb&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2019/08/09/120301_b905b9b5650f3b34258a66f2e8b8fc2e.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F08%2F09%2F120301_b905b9b5650f3b34258a66f2e8b8fc2e.png&h=3d914307&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/Y7SSn1t.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FY7SSn1t.jpg&h=d22e2793&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/uQhCy7L.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuQhCy7L.jpg&h=b0a436f7&s={SIZE}\" />"},{"pid":"1ac493a612b674cc586c4be7c0b9c773de59f0e9","tid":1438354,"uid":66023,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T18:02:52.000Z","msg":"【811港島東大遊行】 10號下晝4點半將進行上訴聆訊<br />\n<a href=\"https://lihkg.com/thread/1438318/page/1\" target=\"_blank\">https://lihkg.com/thread/1438318/page/1</a><br />\n<br />\n【811港島東大遊行】當日維園會照有集會<br />\n<a href=\"https://lihkg.com/thread/1438329/page/1\" target=\"_blank\">https://lihkg.com/thread/1438329/page/1</a><br />\n<br />\n<img src=\"https://na.cx/i/FrmcoLA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFrmcoLA.jpg&h=b4db3112&s={SIZE}\" /><br />\n港島東集會<br />\n日期：2019年8月11日(星期日)<br />\n時間：下午1時正<br />\n地點：維多利亞公園4至6號足球場<br />\n<br />\n集會詳情有待通知<br />\n<br />\n集會以和平理性方式進行，要求政府正面回應五大訴求，唯警方選擇以種種理由拒絕遊行申請，無疑令人有感政府嘗試打壓市民的遊行權利和自由，因此我們呼籲市民更加要站出來，繼續遍地開花，堅守五大訴求。"},{"pid":"7c8197c3d8f9fbd73a42511bde7ff45dd9948ed6","tid":1438354,"uid":6826,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T18:05:45.000Z","msg":"我知大家會好攰！<br />\n但一定要堅持<br />\n諗下當初為左咩出黎？<br />\n當初一齊講過咩？<br />\n71既時候大家都講過話齊上齊落<br />\n要走一齊走 要留一齊留<br />\n呢句野我一直記住<br />\n行得出黎就一定要堅持原則<br />\n對準政權 目標五大訴求"},{"pid":"5aa2d6822af19783eb026d0afe49421e6d08cd3e","tid":1438354,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T18:06:08.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"598e78ae4aef3ddf069df126e72dfb2a5a6e21a2","tid":1438354,"uid":6826,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-09T18:14:36.000Z","msg":"當初行出黎就預左支持到最後一日<br />\n宜家中途走既同出賣義士、出賣香港人無分別<br />\n大家諗下點解要不斷升級<br />\n係乜野令到我地要冒住俾狗打<br />\n俾黑社會打都要堅持落去既原因？<br />\n就係呢個政權既獨裁<br />\n就係知道如果輸就會乜都無<br />\n<br />\n如果大家了解既就會明白<br />\n其實大家已經無離場分化脫隊既理由<br />\n已經無野可以再輸"},{"pid":"d7a321ea2a1f48fa73a72c0e2999e374a5ee8211","tid":1438354,"uid":6826,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T18:20:54.000Z","msg":"自推<img src=\"/assets/faces/dog/bark.gif\" class=\"hkgmoji\" />"},{"pid":"db98959934be1e7f7624b1a153c09b0e4ec93297","tid":1438354,"uid":55130,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T18:21:31.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"3ea6924e6f008a7ca7741636365aad5c2ee43aa5","tid":1438354,"uid":6826,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T18:22:12.000Z","msg":"自推<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"0a7b70631e689614524ced31d62dc0aaed132b81","tid":1438354,"uid":257422,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T18:22:54.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: x-large;\">林鄭拒五大訴求，望社會</span><span style=\"font-size: xx-large;\">「move on」</span><span style=\"font-size: x-large;\">搞經濟</span