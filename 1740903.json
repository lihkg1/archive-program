aces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />大陸係咁架啦"},{"pid":"7649ee10d0b5f8e5abd97996dbcee2929cdfbc5c","tid":1740903,"uid":169079,"like":21,"dislike":0,"score":21,"citedBy":1,"replyTime":"2019-11-20T06:18:35.000Z","msg":"升級到了 16nm 工藝<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />老人家"},{"pid":"fb7520b84a73059edb44b60a8cca0bdc4d4bf263","tid":1740903,"uid":256234,"like":0,"dislike":0,"score":0,"quote":{"pid":"f2e6216881fb75bacceab063213187983a93abd5","tid":1740903,"uid":15406,"like":173,"dislike":2,"score":171,"quote":{"pid":"d316b56f974feb8f24b6f426c22463a917eb5eda","tid":1740903,"uid":104804,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-20T06:07:26.000Z","msg":"【性能達 Zen2 水平?!】支援 DDR5、 PCIe 4.0<br />\n國產兆芯 KX-7000 要追上 AMD、Intel 了!!<br />\n<br />\n儘管 X86 處理器是 Intel 的私有指令集，不過國內依然通過各種方式獲得了合法 X86 授權，其中上海兆芯通過 VIA 合資獲得了 X86 授權，並且從 KX-5000 系列開始走上了自研架構的道路，<span style=\"color: red;\">日前新一代的 KX-6000 處理器正式發佈了，最多 8 核心、時脈 3.0GHz，官方表示性能比 Intel 的七代 Core i5-7400 處理器更強</span>。<br />\n<br />\n上海兆芯是 VIA 威盛與上海政府基金成立的合資公司，獲得了 X86 授權，在 2017 到 2018 年間展示的處理器主要是 KX-5000 系列，代號&ldquo;wudaokou&rdquo;（五道口），採用 28nm 工藝，時脈 2.2GHz，I/O 方面支援 PCIe 3.0/USB 3.1 Gen2（Type-C ）等，號稱代碼 100% 自有，設計絕無第三方參與。<br />\n<img src=\"https://na.cx/i/zYqvvvp.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzYqvvvp.png&h=e3a263ba&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/iDKDEoK.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiDKDEoK.png&h=df42122b&s={SIZE}\" /><br />\n<br />\n在今年 6 月份，兆芯正式發佈了接替 KX-5000 系列的全新 KX-6000 處理器，升級到了 16nm 工藝，時脈提升到 3GHz，有 4 核心及 8 核心兩種規格，還支援 PCIe 4.0、雙通道 DDR4-3200 記憶體，搭配的晶片組升級到了 KH-3000 系列。<br />\n<br />\n<span style=\"color: red;\">兆芯 KX-6000 系列處理器此前已經多次展示過，官方曾表示 KX-6000 系列產品在性能跑分方面已經和 Intel 的第七代桌面 i5 處理器相當。至於規劃中的 KX-7000 則基於完全煥然一新的微架構，採用 7nm 工藝，不僅支援 DDR5，還將演進到 PCIe 4.0 總線，而兆芯總工王惟林稱 KX-7000 的性能目標是「<span style=\"color: limegreen;\">將達到同期 AMD 的水平</span>」，對標的 CPU 至少是 Zen2 級別</span>。<br />\n<img src=\"https://na.cx/i/oZBbeYi.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FoZBbeYi.png&h=33c45351&s={SIZE}\" />"},"citedBy":7,"replyTime":"2019-11-20T06:16:52.000Z","msg":"圖二用緊老翻windows<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-20T06:19:20.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8fee261d0161fb8c191d67c59f9af92deaf14e61","tid":1740903,"uid":16465,"like":7,"dislike":0,"score":7,"quote":{"pid":"7649ee10d0b5f8e5abd97996dbcee2929cdfbc5c","tid":1740903,"uid":169079,"like":21,"dislike":0,"score":21,"citedBy":1,"replyTime":"2019-11-20T06:18:35.000Z","msg":"升級到了 16nm 工藝<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />老人家"},"citedBy":2,"replyTime":"2019-11-20T06:19:56.000Z","msg":"Intel 都係 14+++++ AMD YES"},{"pid":"f67273a9a9d7214bca418d20ad84dbe0c0618b3e","tid":1740903,"uid":284592,"like":0,"dislike":0,"score":0,"quote":{"pid":"f2e6216881fb75bacceab063213187983a93abd5","tid":1740903,"uid":15406,"like":173,"dislike":2,"score":171,"quote":{"pid":"d316b56f974feb8f24b6f426c22463a917eb5eda","tid":1740903,"uid":104804,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-20T06:07:26.000Z","msg":"【性能達 Zen2 水平?!】支援 DDR5、 PCIe 4.0<br />\n國產兆芯 KX-7000 要追上 AMD、Intel 了!!<br />\n<br />\n儘管 X86 處理器是 Intel 的私有指令集，不過國內依然通過各種方式獲得了合法 X86 授權，其中上海兆芯通過 VIA 合資獲得了 X86 授權，並且從 KX-5000 系列開始走上了自研架構的道路，<span style=\"color: red;\">日前新一代的 