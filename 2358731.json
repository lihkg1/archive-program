gmoji\" />"},{"pid":"39962f54327a3c7e8565e8f5b00a7fab22fde71e","tid":2358731,"uid":280648,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-09T03:38:20.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1958fd66b912a4d14501d89b77da9101db06dfce","tid":2358731,"uid":106,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-09T03:38:56.000Z","msg":"made in italy by chinese <img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"ffe87c80dbb36f4015907678624339187021e0cd","tid":2358731,"uid":374796,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-10T06:30:06.000Z","msg":"用過candy洗衣機， 粗用左6~7年真係未試過有壞機漏水，但係部機洗完d衫係過唔清洗衣粉，機門膠邊位會有好多污糟野清極都清唔哂，用耐左洗衫會好唔乾淨一陣味，好果唔係洗太多衫可以諗下，但係如果每次洗一機好多衫既就唔好諗佢<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><br />\n啱啱換咗LG機暫時都無問題<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"51d26fddd65a6ef4840d95b70afa1fa9321efbe1","tid":2358731,"uid":66189,"like":0,"dislike":0,"score":0,"quote":{"pid":"ffe87c80dbb36f4015907678624339187021e0cd","tid":2358731,"uid":374796,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-10T06:30:06.000Z","msg":"用過candy洗衣機， 粗用左6~7年真係未試過有壞機漏水，但係部機洗完d衫係過唔清洗衣粉，機門膠邊位會有好多污糟野清極都清唔哂，用耐左洗衫會好唔乾淨一陣味，好果唔係洗太多衫可以諗下，但係如果每次洗一機好多衫既就唔好諗佢<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><br />\n啱啱換咗LG機暫時都無問題<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-08T03:21:25.000Z","msg":"間屋唔夠大<br />\n得Candy 部洗衣同乾衣夠細可以放雜物房<br />\n<br />\n準備中伏買Candy"}]}