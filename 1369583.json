3,"uid":25973,"like":0,"dislike":0,"score":0,"quote":{"pid":"d8546e3a4c9c4815caff55e9649996a88bf6af92","tid":1369583,"uid":237133,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-26T17:57:04.000Z","msg":"<span style=\"font-size: xx-large;\">裝備篇：</span><br />\n<br />\n話明自由行，當然同平時遊行有d唔同啦！<br />\n<br />\n基本裝束：<br />\n1. 替換嘅衣物(保持衞生)<br />\n2. 大量清水(當然係解渴)<br />\n3. 雨遮(當然係遮太陽同擋雨)，長柄好過縮骨(大把d，可以遮到大d範圍)<br />\n4. 雨褸(小朋友適用，大人亦無不可)<br />\n5. 乾糧(因為未必有補給站)<br />\n<br />\n今次係和理非自由行，但個別巴打需要多少少防禦裝備亦無不可，而呢班巴打需要喺自由行路程嘅<span style=\"font-size: xx-large;\">前、中、後</span>都要出現，詳情之後再講。"},"citedBy":0,"replyTime":"2019-07-27T01:04:31.000Z","msg":"頭盔<br />\n<br />\n津路 <br />\n<br />\n索帶"},{"pid":"bed1a5605f26396c5756149ad3439205bbb5bb7b","tid":1369583,"uid":237133,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T01:19:59.000Z","msg":"推"},{"pid":"c3c001041c4d1eea7f1269f45ed2f16355954947","tid":1369583,"uid":237133,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T01:27:47.000Z","msg":"push"},{"pid":"38a672043cd0d948dd0cd8b2febc136083ff36f7","tid":1369583,"uid":115977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T01:29:47.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: x-large;\"><strong>各位手足<br />\n萬事小心<br />\n<br />\n#一個都不能少<br />\n#727</strong></span></span>"},{"pid":"c9eb0689bc281e3dc31f3bdfc35a87b3b134e64e","tid":1369583,"uid":1495,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T01:34:16.000Z","msg":"整合得好好<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"aeec6249f41cde06fabcfa64c8be71356a3871e9","tid":1369583,"uid":115977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T01:34:48.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: x-large;\"><strong>各位手足<br />\n萬事小心<br />\n<br />\n#一個都不能少<br />\n#727</strong></span></span>"},{"pid":"3467811d599cf990077d1feeaa1b26d905b6b42d","tid":1369583,"uid":36592,"like":0,"dislike":0,"score":0,