rc=\"https://na.cx/i/RNawcvU.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRNawcvU.png&h=696cb174&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-04-12T09:46:44.000Z","msg":"又要人課金?<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d37f411965a5bd428b356018a773999a10a0dc9e","tid":1969183,"uid":51271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-12T09:48:17.000Z","msg":"完全未聽過"},{"pid":"922267c87aaf7ad9eaac6ba7c3a017eb3870575a","tid":1969183,"uid":201464,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-04-12T10:04:10.000Z","msg":"<a href=\"https://www.facebook.com/109087273779959/posts/234155771273108/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F109087273779959%2Fposts%2F234155771273108%2F&d=6Nb1RK4hIZDTz%2Fb962Zoj8%2BxtiM4uRDursPVmWLIdz4%3D&h=f1804d8a\" data-auto-link target=\"_blank\">https://www.facebook.com/109087273779959/posts/234155771273108/</a><br />\n白兵都開過<br />\n不過刪咗po"},{"pid":"8b466e0da3870e9194b76e1c96a179c0205edc07","tid":1969183,"uid":92188,"like":7,"dislike":1,"score":6,"quote":{"pid":"1fcf2b50cb4902c75c05d1f3a76a8f017f648cbb","tid":1969183,"uid":51701,"like":25,"dislike":2,"score":23,"quote":{"pid":"2016a3d3a929a80482a07461479e97350cfc9295","tid":1969183,"uid":49643,"like":4,"dislike":2,"score":2,"citedBy":1,"replyTime":"2020-04-12T09:04:51.000Z","msg":"又開多咁多個衛星page"},"citedBy":2,"replyTime":"2020-04-12T09:06:10.000Z","msg":"懷疑仲有<br />\n北歐心科學"},"citedBy":1,"replyTime":"2020-04-12T10:06:16.000Z","msg":"唔洗懷疑，根本就係"},{"pid":"bcbba62a2ad3aed1cff7a8f10b1d8f99eec53607","tid":1969183,"uid":34572,"like":4,"dislike":3,"score":1,"citedBy":1,"replyTime":"2020-04-12T10:28:09.000Z","msg":"雖然熱狗page係班壞腦嘅人開，但你格硬將page屌泛民同反對進攻功能組別嘅嘢放大，又係咪將所有屌泛民嘅人打成講成熱狗啊<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n至於政治娛樂化嘅問題，嗰啲pag