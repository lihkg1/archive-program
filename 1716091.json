ets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"224a2bce90a6067e49ba36a9aee9873a1a684aaa","tid":1716091,"uid":96871,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-13T13:34:42.000Z","msg":"我建議整返個水POST <br />\n教下市民買飲用水<br />\n文宣埋香港政府無視市民生命安全"},{"pid":"b0f7e4f02cd5e88d404d13d98cdd08d440ac244b","tid":1716091,"uid":34241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T20:59:34.000Z","msg":"<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"586f8e3f9a4c81b6f9d94503b4642173925e01b2","tid":1716091,"uid":324356,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T21:13:38.000Z","msg":"黑狗真係冇腦 狂射tg<br />\n害人終害己"},{"pid":"e1ec67a41ef608af26107ab6c1e07e5e3e10fc2d","tid":1716091,"uid":31185,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T21:28:57.000Z","msg":"Push"},{"pid":"6edabbb5aaa13ba48664b1ca8113f08eef3d218a","tid":1716091,"uid":268516,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T21:30:43.000Z","msg":"中共話你哋咁驚<br />\n咁佢哋唯有送多啲支拿人黎香港<br />\n吸哂啲毒氣<br />\n飲哂啲毒水啦<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"4a348787f0ecbc820c864fd701ccaf9210a8a340","tid":1716091,"uid":34241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T09:49:25.000Z","msg":"<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"ffaee8f03e07293dca1efaeb3d911dd4adb68dbc","tid":1716091,"uid":34241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T11:34:44.000Z","msg":"中大已經有雀死亡<br />\n成為第一批生態災難既祭品<br />\n水中生物會係第二批<br />\n<br />\n好快成個吐露港、馬料水、馬鞍山、大埔，甚至沙田城門河<br />\n岸邊會有大量死魚浮上水面"},{"pid":"8fcc7832f1df939cbfce3bde37f155886c4c528c","tid":1716091,"uid":16087,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T11:36:14.000Z","msg":"避無可避..唉"},{"pid":"c63ab7c6672fff6e5463f997cf55a5778db1be12","tid":1716091,"uid":295563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T11:41:29.000Z","msg":"push ar雖然P牌"},{"pid":"00bc4af37745883630847e4fab5a2ad39cf7dd35","tid":1716091,"uid":34241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T00:08:55.000Z","msg":"焦土"},{"pid":"4de0792658bf40e2b3d7748e559cc742b2fecc7c","tid":1716091,"uid":80396,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T00:22:03.000Z","msg":"<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" />"},{"pid":"16d9c4706f0a8d8cc34be471e3a9fe6717423c6a","tid":1716091,"uid":80396,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T00:24:02.000Z","msg":"關於中大FA話水喉水有TG味<br />\n<a href=\"https://lih.kg/1712684\" data-auto-link target=\"_blank\">https://lih.kg/1712684</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"11ac4e2e3d9de239c4dc3a3986fcf06713f3b51b","tid":1716091,"uid":237465,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T00:34:56.000Z","msg":"咁咪好囉. 要死一齊死.  尤其係膠官 &amp; 權貴 &amp; 恐怖分子"},{"pid":"3288088227294cf32e0340d0006970a7758781b2","tid":1716091,"uid":76705,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T01:02:11.000Z","msg":"Push"}]}