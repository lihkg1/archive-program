kgmoji\" />"},{"pid":"a005290692d95fc906c08ffa4235197cbb43e793","tid":736292,"uid":116471,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-07-10T09:48:06.000Z","msg":"做得很正確，我嘉許！<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<a href=\"https://youtu.be/XsRXPe8OzTA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FXsRXPe8OzTA&d=G3HZ6pmG21M7rxM7%2BVX0Bdr9upuAghWR75VkZoMWgf8%3D&h=838a4c7a\" target=\"_blank\">https://youtu.be/XsRXPe8OzTA</a>"},{"pid":"e96784d8f8b7ad5f78d25dfdf1afe9291314834e","tid":736292,"uid":116471,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-10T09:48:47.000Z","msg":"<a href=\"https://youtu.be/m9pIPZYkB7w\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fm9pIPZYkB7w&d=G3HZ6pmG21M7rxM7%2BVX0Bdr9upuAghWR75VkZoMWgf8%3D&h=9cce02ad\" target=\"_blank\">https://youtu.be/m9pIPZYkB7w</a>"},{"pid":"780f947c6103679161fb683b4d0c62a4a0d5b0ef","tid":736292,"uid":116471,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-10T09:53:31.000Z","msg":"我們對於螞蟻、蚊蟲、蒼蠅、蟑螂，我們跟牠溝通都是誠誠懇懇像對佛菩薩一樣，合掌禮敬，稱牠菩薩，蟑螂菩薩，螞蟻菩薩，聽話，不能用輕慢心。我們跟牠溝通之後，然後回避，一、兩個小時牠一定都走了，都散掉了。所以跟對人一樣，要尊重，不能夠輕慢，不能夠無禮，也不能夠威脅、要脅，都不可以，要很尊重。牠們到這邊來，當然有很多都是找食物的，我們把食物放在院子裡，放在戶外，供養牠們，會合作的。一切眾生都有靈性，佛說一切眾生都有佛性，一定要用真誠懇切你才能感動這些小動物。在過去我們不懂這個道理，傷害了牠們，我們常常忏悔，我們自己誦經、念佛給牠回向。我們這個佛堂裡面都供養著小畜生的牌位，你們仔細去看看，你就曉得，我們天天不忘記牠們，我們天天感謝牠跟我們的合作。"},{"pid":"306def18edf91ef592ba34e5901d494e59d8365e","tid":736292,"uid":116471,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-10T09:55:07.000Z","msg":"應該跟隨我，吃素，愛護所有動物。<br />\n<br />\n<img src=\"http://www.renegadetribune.com/wp-content/uploads/2016/12/hitler-deer.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.renegadetribune.com%2Fwp-content%2Fuploads%2F2016%2F12%2Fhitler-deer.jpg&h=c87a432f&s={SIZE}\" />"},{"pid":"7bbb2b36407250a4c8f43aac8330ce82f05db351","tid":736292,"uid":80311,"like":0,"dislike":0,"score":0,"quote":{"pid":"ce07e3550f13a2624df3f151a59