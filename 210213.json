ass=\"hkgmoji\" />"},{"pid":"6a453891a02942b3bd22ae0c1f8d3d78df95e5ed","tid":210213,"uid":14090,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-04-20T21:37:12.000Z","msg":"好撚心啦 咩對社會有貢獻 睇過？<br />\n根本就細個冇理財 冇儲錢 大個去食二手飯 抵撚死啦 唔好係到怪社會 比左咁多年你儲錢都儲唔到退休金既話 咪變廢老囉<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n快撚啲死左佢啦 依家根本對社會負貢獻 死左佢都叫做止蝕<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n利申：積開口德<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"1543be856caed20967ac82128d0e46360edfafae","tid":210213,"uid":28279,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-04-20T23:14:49.000Z","msg":"人口老化，老人家多咗，社會唔需要再咁容讓老人<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" />"},{"pid":"2e714cfd1b79c410c91122aac52d5140f2aead28","tid":210213,"uid":266,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-20T23:24:33.000Z","msg":"咁有尊嚴唔搵社工幫手 反而走去偷野<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"23e4d8a39d5e72d316636298715ea0f99ab39cf8","tid":210213,"uid":35507,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-20T23:40:13.000Z","msg":"<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"8ae1b89f8a1629e4331800fcb8a464d3c9b2057c","tid":210213,"uid":53466,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-04-20T23:40:42.000Z","msg":"此回覆已被刪除"},{"pid":"59d899d46448ffe968b7436f6f06f34564f0236c","tid":210213,"uid":46042,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-04-20T23:46:45.000Z","msg":"食二手飯 真係社會有責任"},{"pid":"653cce3a7682013f17d20f644cfae7ab9608d62b","tid":210213,"uid":14090,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-04-20T23:55:29.000Z","msg":"<blockquote>食二手飯 真係社會有責任</blockquote><br />\n