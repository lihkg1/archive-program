"hkgmoji\" />"},{"pid":"2406b1b433838d8302be1d65c2d6712f6a3c59d2","tid":939542,"uid":60635,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2018-12-15T03:17:59.000Z","msg":"咪撚玩啦，拉麵D 咁既下欄野，拎簽證好難嫁。<br />\n你話Johnny 唔聽身邊D 姨媽姑姐講，堅持讀IT 做狗。<br />\n係香港捱左幾年年年比人炒既打工生涯，最後去左日本就可信D<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"18eacd5ba1f4584d21e0583e193e8ab6f6957f18","tid":939542,"uid":103617,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-15T03:25:12.000Z","msg":"樓主十幾萬一個月呀仲呻咩丫<br />\n好快退得休啦"},{"pid":"fca3e0cac1c9fc6cb1785da6e97b752262adf28c","tid":939542,"uid":12792,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T03:26:50.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"bf44f3bc3357dd1a60ab3b96a33bfe05afbe18c2","tid":939542,"uid":1915,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-15T04:21:04.000Z","msg":"因為蠢果個唔係Johnny仔而係你<br />\n蠢在只識得盲目相信上一級既人講既野"},{"pid":"1f7e309d4e1f1cf7242bf7ad88e47f317d7c030b","tid":939542,"uid":16070,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T05:06:17.000Z","msg":"其實佢地無呃你 不過只係講緊理想情況<br />\n實際係10個都有1個既<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"bcdf11938ac6c120336f223ffca4feecafb2cfa3","tid":939542,"uid":136233,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T05:50:15.000Z","msg":"此回覆已被刪除"},{"pid":"ef0e7eae57ffd17390bf70f5e5b01146df0ca15f","tid":939542,"uid":54930,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T09:17:48.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"fc461f41df1b936e217ac99ef37871f3b006ae0f","tid":939542,"uid":27210,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T09:22:43.000Z","msg":"好岩<br />\n不過我大學時已經無再信<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" />"},{"pid":"ba8b17bcf32a59610274f77c42811c1716150075","tid":939542,"uid":225828,"like":1,"dislike":0,"score":1,"quote":{"pid":"b6cbb0ad9011d6edce7548ca50377ff6116b62c6","tid":939542,"uid":206224,"like":6,"dislike":1,"score":5,"quote":{"pid":"72cd72525788edff6e992e888adb5e85402721ab","tid":939542,"uid":48743,"like":61,"dislike":3,"score":58,"citedBy":2,"replyTime":"2018-12-13T13:53:59.000Z","msg":"其實你朋友開post曬命都係一種謊言，梗係post好野，唔通日日做到死死下又話你聽咩<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <br />\n<br />\n根本你無家底人生就辛苦好多，依個就係事實<img src=\"/assets/faces/lm2/point2.gif\" class=\"hkgmoji\" /> <br />\n<br />\n唔通細細個就同細路講你無架喇，你做到仆街一生人都搵唔到人地一日賺既錢咩<img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-12-14T01:48:13.000Z","msg":"一層層謊言就係為左保持到奴隸嘅supply<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-12-15T10:11:49.000Z","msg":"如果所有奴𡝯突然間冇哂班富商會唔會仆街<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" />"},{"pid":"9492d7c10bbf5d7192e820189884ac01fd512d3a","tid":939542,"uid":225828,"like":0,"dislike":0,"score":0,"quote":{"pid":"07d450ab3b3e960942a3c2299217b2669c1a87ce","tid":939542,"uid":113626,"like":4,"dislike":1,"score":3,"citedBy":1,"replyTime":"2018-12-14T02:41:25.000Z","msg":"呢個社會就係搵班懵仔入場<br />\n等班資本家可以食人血饅頭唔駛做咁去靠下一代動力維持自己 <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-15T10:12:09.000Z","msg":"*香港"},{"pid":"2811fe564d8404a3adda371e6de7fcc6e708cd8d","tid":939542,"uid":225828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-15T10:19:11.000Z","msg":"<blockquote>睇完死返去溫書先<img src=\"/assets/faces/xm/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/xm/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1a5e093cf6e0b5609e8d7248c1e480cc0958da97","tid":939542,"uid":225828,"like":0,"dislike":1,"score":-1,"quo