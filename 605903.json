rvice-hk.net/upload/2018/03/26/142222_b81d3ab27ee60ba0b58aa7f9c5664f67.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F26%2F142222_b81d3ab27ee60ba0b58aa7f9c5664f67.png&h=305d9277&s={SIZE}\" />"},{"pid":"eb378104be36a2d2efba553e9ba10c8892ecb2c6","tid":605903,"uid":15745,"like":6,"dislike":3,"score":3,"citedBy":3,"replyTime":"2018-03-26T06:23:40.000Z","msg":"26度叫高溫？？"},{"pid":"7273ee657854b747cf1da7302f14255240072f79","tid":605903,"uid":74778,"like":12,"dislike":0,"score":12,"quote":{"pid":"d7dbdc9ae67ce29cb4ea9018e1eb9df2d505f99c","tid":605903,"uid":40470,"like":2,"dislike":34,"score":-32,"citedBy":4,"replyTime":"2018-03-26T06:11:25.000Z","msg":"<blockquote><blockquote>塊地係你地連登毒撚買左咩？<br />\n<br />\n點發展關你撚事？</blockquote>我心平氣和同你傾<br />\n<br />\n你覺得放火啱唔啱</blockquote><br />\n你見到有人放火？"},"citedBy":0,"replyTime":"2018-03-26T06:26:26.000Z","msg":"公道自在人心<br />\n<br />\n如果你一個人利欲熏心，都仲可以用社會壓力令你收皮<br />\n<br />\n好可惜宜家成個社會都係咁<br />\n<br />\n你既無恥係社會既大多數，如果你成功，唔係因為你啱，係因為你無恥而好多人都好似你咁無恥"},{"pid":"64d84fb159e0b4df4f2a9dea6a2fcc8b6e26e161","tid":605903,"uid":74778,"like":30,"dislike":1,"score":29,"quote":{"pid":"d7dbdc9ae67ce29cb4ea9018e1eb9df2d505f99c","tid":605903,"uid":40470,"like":2,"dislike":34,"score":-32,"citedBy":4,"replyTime":"2018-03-26T06:11:25.000Z","msg":"<blockquote><blockquote>塊地係你地連登毒撚買左咩？<br />\n<br />\n點發展關你撚事？</blockquote>我心平氣和同你傾<br />\n<br />\n你覺得放火啱唔啱</blockquote><br />\n你見到有人放火？"},"citedBy":0,"replyTime":"2018-03-26T06:29:22.000Z","msg":"宜家有人做出放火既行為，我地譴責暴行，<br />\n<br />\n你為暴行辯護，你既行為比放火更羞恥<br />\n<br />\n放火即人都會偷偷地放，怕比人知，知恥<br />\n你光明正大行出黎護航，唔掩飾自己身分，無恥"},{"pid":"0707431cd4783a65e2b1d9136d3ca119222bdabe","tid":605903,"uid":74778,"like":4,"dislike":0,"score":4,"quote":{"pid":"d7dbdc9ae67ce29cb4ea9018e1eb9df2d505f99c","tid":605903,"uid":40470,"like":2,"dislike":34,"score":-32,"citedBy":4,"replyTime":"2018-03-26T06:11:25.000Z","msg":"<blockquote><blockquote>塊地係你地連登毒撚買左咩？<br />\n<br />\n點發展關你撚事？</blockquote