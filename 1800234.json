15cbbc48bce127e6","tid":1800234,"uid":256957,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2a51ae120df83c95cc1e2fb2c15c1ca6a5b882e","tid":1800234,"uid":330204,"like":0,"dislike":0,"score":0,"quote":{"pid":"fd5d1cde687fa43a003114492e6985d227e7a8c1","tid":1800234,"uid":256957,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-28T06:38:31.000Z","msg":"用web server就唔會有error問題<br />\n最大路係apache<br />\n你想方便啲可以vscode + live server, 會有hot reload"},"citedBy":1,"replyTime":"2019-12-28T06:40:27.000Z","msg":"Notepad++ 天下無敵。<img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/snowhat.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-12-28T06:45:55.000Z","msg":"咁你可以用apache個方法去解決個error問題另你用到jquery解決你include個問題<br />\n你document.write寫耐咗你唔會想maintain落去"},"citedBy":0,"replyTime":"2019-12-28T06:53:50.000Z","msg":"OK啦 <img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" /><br />\n又唔係啲咩大型複雜需求嘅網站。<br />\n<br />\nKeep It Simple <br />\n<br />\n<img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" /> 其實我懶得學嗻，仲有 FYP 要做。"},{"pid":"982baa075c7a3964cc0e1daac9a21fa5bb97cde8","tid":1800234,"uid":66242,"like":0,"dislike":0,"score":0,"quote":{"pid":"73b656f00ccd3f0bb2d494620b19ffc376ae5d80","tid":1800234,"uid":48796,"like":0,"dislike":0,"score":0,"quote":{"pid":"06efa829d0bd30392dab0e7ad61f786075b0d530","tid":1800234,"uid":330204,"like":0,"dislike":0,"score":0,"quote":{"pid":"347ba1e781cf9761f2fce4bfdb2ac603b8a998e0","tid":1800234,"uid":48796,"like":3,"dislike":2,"score":1,"citedBy":1,"replyTime":"2019-12-27T17:58:19.000Z","msg":"有呀, 20年前有種科技叫 Server Side Includes (SSI)<br />\n俾啲 唔識寫CGI/冇CGI/冇PHP 嘅情況下用<br />\n唔屬於HTML, 而檔名要改成 .shtml<br />\n而家啲hosting重sup唔support就唔知了<br />\n至於點解呢種古老嘅秘法被遺忘就要自己諗下...<img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/41xjcGk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F41xjcGk.jpg&h=a0b41f3b&s={SIZE}\" /><br />\n<a href=\"https://www.st-andrews.ac.uk/itsnew/web/ssi/index.shtml\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.st-andrews.ac.uk%2Fitsnew%2Fweb%2Fssi%2Findex.shtml&d=CRZj9ITMXIzKHLmvffUzPC%2B7EDXmwg1SXj7S5MqlT1o%3D&h=3046cdd4\" target=\"_blank\">https://www.st-andrews.ac.uk/itsnew/web/ssi/index.shtml</a>"},"citedBy":1,"replyTime":"2019-12-27T18:05:08.000Z","msg":"<img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" /> 我諗都係注入問題啩。"},"citedBy":1,"replyTime":"2019-12-27T20:36:03.000Z","msg":"<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><br />\n因為後來開始流行server side program, 例如PHP、ASP, 已經built-in有呢種基本功能, 而且更方便同強大, 所以大家直接用程式產生HTML, 而SSI就被淘汰.<br />\n講到尾HTML只係文件格式, 唔係俾你咁用. 你要file call file就用PHP / <a href=\"http://ASP.NET\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2FASP.NET&d=CRZj9ITMXIzKHLmvffUzPC%2B7EDXmwg1SXj7S5MqlT1o%3D&h=c8c7569d\" data-auto-link target=\"_blank\">ASP.NET</a> / NodeJS / ... 等程式做."},"citedBy":0,"replyTime":"2019-12-28T22:35:23.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n無 deprecated<br />\n仲可以用的<br />\n以前 web1.0 年代 static pages 為主<br />\n但 web2.0 年代當你個網站需要 SSI<br />\n上面有人提出用 jQuery.load 亦做到<br />\n以前無 Ajax 呀<br />\n（呢個年代已經好難唔用 js 唔做 user interaction）<br />\n而且 business requirements 好快就會見到需要更 rich 嘅 server side programming<br />\n即係 php/nodejs etc<br />\n所以一開始就會直接 setup server 跳過 SSI 無考慮<br />\n<a href=\"https://www.whoishostingthis.com/resources/ssi/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.whoishostingthis.com%2Fresources%2Fssi%2F&d=CRZj9ITMXIzKHLmvffUzPC%2B7EDXmwg1SXj7S5MqlT1o%3D&h=fedc366f\" data-auto-link target=\"_blank\">https://www.whoishostingthis.com/resources/ssi/</a>"},{"pid":"79fd31c3b6da93663dbf5026eda6c603c3f70992","tid":1800234,"uid":328061,"like":3,"dislike":2,"score":1,"citedBy":2,"replyTime":"20