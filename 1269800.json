ore":0,"citedBy":0,"replyTime":"2019-06-30T17:55:08.000Z","msg":"推 <br />\n多謝瑪瑪"},{"pid":"75d1a9637586ac57c2e2cb0e6241a3f0d59846fd","tid":1269800,"uid":44455,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T17:55:16.000Z","msg":"推"},{"pid":"8e5134e754066e93a9f29d0c84bf4c952e80edc7","tid":1269800,"uid":99871,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T17:57:34.000Z","msg":"推"},{"pid":"45c3af9bb9c3259015d1ec1f7455283ead3d6ae4","tid":1269800,"uid":257887,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T17:59:12.000Z","msg":"推"},{"pid":"6fc570f1d31761215353edcccf475b98dcdb5f7d","tid":1269800,"uid":270642,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-06-30T18:00:41.000Z","msg":"多謝你既資訊<br />\n真係要好好守護身邊既人<br />\n我本身有焦慮，呢兩個月有朋友話我似有埋抑鬱...仲惡化得好快...<br />\n不斷睇新聞，好無力，對其它事情失去興趣...<br />\n番工日日靠飲咖啡... 頂唔順就晚晚安眠藥<br />\n行唔安 坐唔樂 食唔落 不斷睇 不斷諗<br />\n我可以做到d 咩... 點解會搞到咁<br />\n點解仲有咁多人沈默，當冇事發生...<br />\n如果好好地做隻港豬，傻傻地過一世又會點...<br />\nAnyway, 壓力係好可怕咁拉扯住內心，<br />\n而有些道理你明，但無辦法自己控制到壓力對身心既影響，<br />\n身邊既人既支持係好重要，<br />\n多些陪伴，聽聽煩惱，<br />\n記得有時真係要放過自己，<br />\n不用勉強，已經做得好好。<br />\n長期處於臨界點會令自己更焦燥不安，<br />\n累了就好好休息，活著就有希望。"},{"pid":"939293d4002417b9d4672872091656e5f6f66689","tid":1269800,"uid":266367,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T18:03:18.000Z","msg":"推 各位保重呀"},{"pid":"20b2e57ca153d782945caf793dff74410c771f56","tid":1269800,"uid":12583,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T18:11:04.000Z","msg":"推，好有用"},{"pid":"e12ecef874f098ce6428870ff6e0beeb47a78e8b","tid":1269800,"uid":7427,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T18:13:09.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"5029ae4857e64fc760fe2d9f57ee18ecbb6fd0b8","tid":1269800,"uid":127807,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-30T18:14:53.000Z","msg":"GOOD"},{"pid":"649a6fe2f99d0b52759d67195b0baea64aa71cd8","tid":1269800,"u