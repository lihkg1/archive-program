":0,"score":0,"quote":{"pid":"021763a27c677fec4f66460e6ea3fb68877746bb","tid":1780641,"uid":155818,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-12-12T13:58:51.000Z","msg":"反習會<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-13T02:42:53.000Z","msg":"<a href=\"https://youtu.be/nNmUVwD7hhc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FnNmUVwD7hhc&d=Vh0AUGqI%2BhuKY3uG7C8Fc2a%2FpyP0knsd4enDGc0qzPM%3D&h=b7f92319\" target=\"_blank\">https://youtu.be/nNmUVwD7hhc</a>"}]}