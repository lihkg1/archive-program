民<br />\n<br />\nbtw祝 <span style=\"font-size: xx-large;\"><span style=\"color: red;\">林鄭早日落台</span></span><br />\n<img src=\"/assets/faces/big/kill2.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" />認同請分享+正皮<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n<span style=\"color: pink;\"><span style=\"font-size: x-small;\">Sorry講嘢1999<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /></span></span>"},"citedBy":1,"replyTime":"2019-06-18T14:06:02.000Z","msg":"留負皮者求解<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-18T14:47:23.000Z","msg":"下一頁quote完再推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"7a2c8fc041b861e85457348ac2108da67f236a62","tid":1236230,"uid":221105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-20T05:17:41.000Z","msg":"係咪應該自推<img src=\"/assets/faces/lm2/adore.gif\" class=\"hkgmoji\" />"},{"pid":"6d330aad30873ff355469feef5f9d43ecaebd3e1","tid":1236230,"uid":91659,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-20T06:59:09.000Z","msg":"林鄭似典型繼母所為"},{"pid":"0252c6a05a6dc67623d346f7c227cb7fb9e2f9af","tid":1236230,"uid":221105,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d330aad30873ff355469feef5f9d43ecaebd3e1","tid":1236230,"uid":91659,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-20T06:59:09.000Z","msg":"林鄭似典型繼母所為"},"citedBy":0,"replyTime":"2019-06-20T07:01:57.000Z","msg":"灰姑娘<img src=\"/assets/faces/lm2/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/frown.gif\" class=\"hkgmoji\" />"},{"pid":"06b748e641951ffb21988d4e5ca6840a4ec17eef","tid":1236230,"uid":221105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-20T08:48:29.000Z","msg":"推<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"dab714bebc059c94cc62ee62e01