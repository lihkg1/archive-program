sets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f18c3cae1f0af2aba0c9f21d325313d4a2da92c3","tid":1924984,"uid":228143,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-03-14T05:17:38.000Z","msg":"用番藍屍理論啦<br />\n<br />\n之前美國咁少人中 <br />\n<br />\n中國多人中就話美國放<br />\n<br />\n而家美國多人中  點會美國放<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><br />\n<br />\n佢點解釋即係推番之前結論？"},{"pid":"8a5054b3411a7f17ae5777b7070b7988812a28f4","tid":1924984,"uid":164751,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-03-14T05:17:42.000Z","msg":"當佢地堅信一件事<br />\n只會不斷接納支持佢立場嘅資訊<br />\n<br />\n其他動搖佢地嘅證據, 都會視為捏造,<br />\n因為佢地唔想面對, 落唔倒台,<br />\n亦唔想認錯<br />\n<br />\n好多錯誤都係依種態度造成"},{"pid":"3662cc9de77490c5756149b156bcd8f4c856584a","tid":1924984,"uid":28227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-14T05:18:41.000Z","msg":"你同佢哋講：聽講撐邊度的人下世會喺返果度投胎"},{"pid":"ca597e406243557c82f6018036d4c1267fea4b20","tid":1924984,"uid":147198,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-14T05:20:44.000Z","msg":"香港仲有一百幾萬藍 你理得佢咁多<br />\n反正冇教化可能 直接用實力去講"},{"pid":"f0b653504a47287117a1d6606d8704b032653f8f","tid":1924984,"uid":272202,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-14T05:22:08.000Z","msg":"廢老就算鳩數啦 只會信佢想信嘅嘢<br />\n嚟Twitter幫手仲實際<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\nTwitter真係多咗好撚多5毛<img src=\"/assets/faces/cat/stare.gif\" class=\"hkgmoji\" /><br />\n以呢個post做例子<br />\n<blockquote><a href=\"https://twitter.com/yannnnnn111/status/1238675168446185474?s=19\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Fyannnnnn111%2Fstatus%2F1238675168446185474%3Fs%3D19&d=B95HL5QQ1MLE%2FldfuzA7j09C3ZeEg%2BAMpIxt97RLrpY%3D&h=4152a9a4\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftwitter.com%2Fyannnnnn111%2Fstatus%2F1238675168446185474%3Fs%3D19&h=92f9f5ba\" data-auto-link target=\"_blank\">https://twitter.com/yannnnnn111/status/1238675168446185474?s=19</a></blockquote><br />\n拉落去大部分都係話支那唔係肺炎發原地/美國先係發原地 + 無腦人身攻擊<br />\n仲有啲睇落似係外國人講嘢正常咁仲有好多like但其實係高級5毛<br />\n大家幫幫手撳個掣retweet同like手足嘅tweets<br />\n最好comment下幫自己人 like埋手足comment推上去<br />\n唔洗同5毛嘈 直接report佢地虛假帳號/仇恨內容"},{"pid":"a609428f8d23c1a41f5bc08c18d8fce42e73d044","tid":1924984,"uid":213877,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-14T05:22:12.000Z","msg":"即場開佢波啦"},{"pid":"566472763f0733fb42399381e61b2d721225bdaa","tid":1924984,"uid":107927,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-14T05:22:21.000Z","msg":"直接笑佢無腦咪得"},{"pid":"e449fc19872a2f04a1a82bdb737c22d6551c1b1c","tid":1924984,"uid":70888,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-03-14T05:23:00.000Z","msg":"我屋企嗰兩個藍絲廢老都係<br />\n但依家我已經決定無視<br />\n要講已經講左，嘈又嘈左<br />\n同佢地嘈係因為對佢地上心，唔想佢地咁無知<br />\n但到今日我已經放棄，因為最終難受既係自己<br />\n我會令佢地承受返自己講過既野<br />\n有咩搵政府，唔好搵我"},{"pid":"295b8a6b316893e5d9528e1878ad5152ef4e9e69","tid":1924984,"uid":174502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-14T05:25:39.000Z","msg":"樓豬同藍絲講邏輯？傻撚左？"},{"pid":"19514e37a5a6e9b329e77430b52db639a7107c0c","tid":1924984,"uid":35658,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-14T05:26:04.000Z","msg":"hea mode <br />\n<br />\n<br />\n&quot;係呀 出解放軍攻美啦屌 等咩? 武漢死咁多人都唔報仇點仲叫強國&quot;"},{"pid":"1e143e3b1a4438992be16af82568fe6ec4fad965","tid":1924984,"uid":287422,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-14T05:27:11.000Z","msg":"[交宣做嘢啦]藍絲開始抹黑 用篇文屈美國喺武肺源頭<br />\n<a href=\"https://lih.kg/1924900\" data-auto-link target=\"_blank\">https://lih.kg/1924900</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n已駁了"},{"pid":"46d35a430319ac23cf6a9b024803388a8c2dc010","tid":1924984,"uid":174502,"like":0,"dislike":0,"score":0,"quote":{"pid":"f18c3cae1f0af2aba0c9f21d325313d4a2da92c3","tid":1924984,"uid":228143,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-03-14T05:17:38.000Z","msg":"用番藍屍理論啦<br />\n<br />\