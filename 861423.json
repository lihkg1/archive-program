/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /> <br />\n大腸就普普通通<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},{"pid":"dfc2f44999cf2a9935b3cb039beaa2d14e61d94f","tid":861423,"uid":38030,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-10-14T06:35:15.000Z","msg":"where"},{"pid":"f01d897e94df42fbd20f392f89c35d768000c076","tid":861423,"uid":96704,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-10-14T06:37:37.000Z","msg":"25<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e24b25616225522080924ccd2aaaede50a213471","tid":861423,"uid":38030,"like":16,"dislike":0,"score":16,"quote":{"pid":"f46b0d861a7f070b2ab345ad926457d1a0e18dfd","tid":861423,"uid":33694,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-14T06:29:11.000Z","msg":"中非打<img src=\"/assets/faces/dog/lihkg.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-14T06:38:31.000Z","msg":"作為一個虔誠嘅百里香信徒，應該尋日買定隻燒雞今日丁熱嚟食<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},{"pid":"93492bf9e7db84dc105b62e161fd504ecb567b92","tid":861423,"uid":174432,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-10-14T06:38:46.000Z","msg":"食落去喉嚨舒唔舒服<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"9d457ead9e0581156e85d930f84eff67517d413e","tid":861423,"uid":33359,"like":0,"dislike":7,"score":-7,"quote":{"pid":"93492bf9e7db84dc105b62e161fd504ecb567b92","tid":861423,"uid":174432,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-10-14T06:38:46.000Z","msg":"食落去喉嚨舒唔舒服<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-14T06:39:18.000Z","msg":"好c服<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"c92af2e5c0d8085e746bc4698887ca4d4fad7dc5","tid":861423,"uid":33359,"like":0,"dislike":0,"score":0,"quote":{"pid":"dfc2f44999cf2a9935b3cb039beaa2d14e61d94f","tid":861423,"uid":38030,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":