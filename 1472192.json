F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F08%2F14%2F141106_a064336a869290c4a85c50e2c5342faf.jpeg&h=42d70b2e&s={SIZE}\" />"},{"pid":"f0168af2fe7f3b8945d969915f4dc57f55753b81","tid":1472192,"uid":104793,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T19:18:54.000Z","msg":"屌晒黑警老豆老母<br />\n有冇搞撚錯 畀廁所水人地飲"}]}