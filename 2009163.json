m/link?u=https%3A%2F%2Fwww.facebook.com%2F960526577368640%2Fposts%2F3164024883685454%2F%3Fd%3Dn&d=EEWyN02WlTtsLATURr%2Ffpf7c%2B9HD3JYLAdxAiSxEDXo%3D&h=4b4ca7b9\" data-auto-link target=\"_blank\">https://www.facebook.com/960526577368640/posts/3164024883685454/?d=n</a><br />\n<br />\n<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-09T15:46:42.000Z","msg":"今日派口罩果班拉咗未？"},{"pid":"f5f67cce8c986f8586a7b07ed9f8c115d3f7c18b","tid":2009163,"uid":258106,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T15:48:54.000Z","msg":"23公斤<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b85e0b279312d07f8b9ed09733cd9f1dde5e0dea","tid":2009163,"uid":270733,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T15:49:02.000Z","msg":"其實佢地怕武肺"},{"pid":"41d017d26bfe2fdcf37a5ac94c399f0acdee4ea6","tid":2009163,"uid":102110,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T15:54:40.000Z","msg":"入來吧，入商埸清埸攬抄"},{"pid":"805655c60fd510e16ac311ca209622904d842dc4","tid":2009163,"uid":271516,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T15:55:00.000Z","msg":"<img src=\"https://na.cx/i/XpejGvY.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXpejGvY.png&h=31b98e26&s={SIZE}\" />"},{"pid":"7e8e894ad7f28f852c7f22ef509e5c91bc2b08c1","tid":2009163,"uid":92467,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T15:58:09.000Z","msg":"預估聽日<br />\n黃：唱歌&gt;be water<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><br />\n港豬：驚驚&gt;閃人<img src=\"/assets/faces/dog/escape.gif\" class=\"hkgmoji\" /><br />\n中立撚：唔怕&gt;2000蚊<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><