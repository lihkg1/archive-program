EN/HRBodies/CAT/pages/catindex.aspx</a><br />\n<br />\nCommittee Against Torture"},{"pid":"05c13f8ac6632877059bc279a575a5dd92c27c92","tid":1501512,"uid":279840,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-24T16:01:54.000Z","msg":"<a href=\"https://www.ohchr.org/EN/Issues/Torture/SRTorture/Pages/SRTortureIndex.aspx\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ohchr.org%2FEN%2FIssues%2FTorture%2FSRTorture%2FPages%2FSRTortureIndex.aspx&d=mYJIHVlKms%2F2btm24%2BMsOsFcVrLE0QCYyCuC44%2F36M0%3D&h=3cd53ba9\" data-auto-link target=\"_blank\">https://www.ohchr.org/EN/Issues/Torture/SRTorture/Pages/SRTortureIndex.aspx</a><br />\n<br />\n幫推。 <br />\n<br />\n搵有法律底既巴絲將新屋嶺推上聯合國"},{"pid":"a306e125208274f62336e7f3e424efc7b4204a8f","tid":1501512,"uid":230,"like":0,"dislike":0,"score":0,"quote":{"pid":"05c13f8ac6632877059bc279a575a5dd92c27c92","tid":1501512,"uid":279840,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-24T16:01:54.000Z","msg":"<a href=\"https://www.ohchr.org/EN/Issues/Torture/SRTorture/Pages/SRTortureIndex.aspx\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ohchr.org%2FEN%2FIssues%2FTorture%2FSRTorture%2FPages%2FSRTortureIndex.aspx&d=mYJIHVlKms%2F2btm24%2BMsOsFcVrLE0QCYyCuC44%2F36M0%3D&h=3cd53ba9\" data-auto-link target=\"_blank\">https://www.ohchr.org/EN/Issues/Torture/SRTorture/Pages/SRTortureIndex.aspx</a><br />\n<br />\n幫推。 <br />\n<br />\n搵有法律底既巴絲將新屋嶺推上聯合國"},"citedBy":0,"replyTime":"2019-08-24T16:59:08.000Z","msg":"感謝巴打<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"7f767e231a7e8f2d1ab1c12b5f0959a0530e59f5","tid":1501512,"uid":230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:59:24.000Z","msg":"推"},{"pid":"3a34312af11f89044123df9754e6d30806a64255","tid":1501512,"uid":192754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime