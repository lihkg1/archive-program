e48385ad","tid":535283,"uid":24160,"like":25,"dislike":1,"score":24,"quote":{"pid":"96f6f3f909d699c6dcb98efea0388410bfd458a3","tid":535283,"uid":151836,"like":0,"dislike":0,"score":0,"quote":{"pid":"171cfad2d07d848c61a0e1110a550988cdd6d5b4","tid":535283,"uid":82829,"like":82,"dislike":2,"score":80,"citedBy":1,"replyTime":"2018-01-20T16:47:21.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>&uarr;&rarr;&darr;&rarr;&darr;&uarr;&darr;&rarr;&darr;&uarr;&darr;&rarr;&darr;&rarr;&darr;&rarr;&uarr;&uarr;&rarr;&darr;&rarr;&uarr;&rarr;&darr;&darr;&rarr;&darr;&uarr;&rarr;&darr;&rarr;&darr;&rarr;&uarr;&rarr;&darr;&darr;&rarr;&uarr;&rarr;&darr;&darr;&rarr;&uarr;&rarr;&darr;&rarr;</strong></span></span>"},"citedBy":2,"replyTime":"2018-01-21T17:01:56.000Z","msg":"唔係好明"},"citedBy":0,"replyTime":"2018-01-21T17:25:19.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">【猙獰演出】汪明荃 9級震音 唱出 愛你變成害你</span></strong><br />\n汪明荃 愛你變成害你 @Sunday 靚聲王<br />\n<a href=\"http://youtu.be/VsanYsbvBjk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fyoutu.be%2FVsanYsbvBjk&d=VTVUaDvxTuXSvhzJp1u6B54f2li5K%2Fs6EGgmwhpeblA%3D&h=71049d92\" target=\"_blank\">http://youtu.be/VsanYsbvBjk</a>(yt:直接影電視)</span><br />\n2:05 為什<span style=\"font-size: xx-large;\"><span style=\"color: red;\">麼&darr;&uarr;(爛聲)</span></span>偏會把<span style=\"font-size: xx-large;\"><span style=\"color: red;\">&amp;quot;你&uarr;&darr;&uarr;害&amp;quot;(爛聲)</span></span><br />\n2:12 <span style=\"font-size: xx-large;\"><span style=\"color: red;\">我&darr;&darr;喔&uarr;&uarr;&uarr; 愛&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;你&uarr;&uarr;....變&uarr;&uarr;&uarr;&darr;&uarr;&darr;(爛聲) 了害(爛聲)你(爛聲)</span></span><br />\n2:24 <span style=\"font-size: xx-large;\"><span style=\"color: red;\">我~(爛聲) 不~(爛聲)</span></span> 愛&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;<br />\n2:31 <span style=\"font-size: xx-large;\"><span style=\"color: red;\">難&darr;&darr;道&darr;&darr;世間(爛聲, 走音)...真(爛, 走)&uarr;&darr;&uarr;&darr; 孽~~(原:苦)海&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr; (爛聲)</span></span><br />\n2:36 神仙也是<span style=\"font-size: xx-large;\"><span style=\"color: red;\">跳&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;不&uarr;&uarr;&uarr;&uarr;&uarr;出&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;來~~~</span></span><br />\n2:45 <span style=\"font-size: xx-large;\"><span style=\"color: red;\">難道人生(全句爛聲) <span style=\"font-size: large;\">只&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;</span><span style=\"font-size: x-large;\">有&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;</span><span style=\"font-size: xx-large;\">黑&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;暗&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;</span></span></span><br />\n<img src=\"http://i66.tinypic.com/o9g5mc.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi66.tinypic.com%2Fo9g5mc.gif&h=be9033b3&s={SIZE}\" /><br />\n2:50 <span style=\"font-size: xx-large;\"><span style=\"color: red;\">光&uarr;&uarr;&uarr;明&uarr;&uarr;&uarr; 都不全在&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr; (爛聲, 走音)</span></span><br />\n<img src=\"https://media.giphy.com/media/26ybwGkN4ZHLxL3B6/giphy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2F26ybwGkN4ZHLxL3B6%2Fgiphy.gif&h=e921e93f&s={SIZE}\" /><br />\n3:10 來愛&uarr;&uarr;不&uarr;&darr;&uarr;來&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;<br />\n3:15 <span style=\"font-size: xx-large;\"><span style=\"color: red;\">(發功) <span style=\"font-size: large;\">我↘↘</span><span style=\"font-size: x-large;\">↘↘</span><span style=\"font-size: xx-large;\">屙↗↗↗↗↗</span>愛&uarr;&darr;&uarr;你&uarr;&darr;&uarr;<br />\n變了hai你 (全句爛聲)</span></span><br />\n3:22 <span style=\"font-size: xx-large;\"><span style=\"color: red;\">早&darr;&darr;&darr;&darr;&darr;&darr;hou&uarr;&uarr;&uarr;&uarr;知hai你~~</span></span><br />\n3:35 <span style=\"font-size: xx-large;\"><span style=\"color: red;\">我不~~~愛&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr;&uarr;&darr; (爛聲)</span></span><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">同場加映<br />\n汪明荃 愛你變成害你 (荃加福祿壽)&amp;#160;<br />\n<a href=\"http://youtu.be/B2CGc0bkCpM\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fyoutu.be%2FB2CGc0bkCpM&d=VTVUaDvxTuXSvhzJp1u6B54f2li5K%2Fs6EGgmwhpeblA%3D&h=41b88c46\" target=\"_blank\">http://youtu.be/B2CGc0bkCpM</a></span></span>"},{"pid":"fa065b105929e8a2d494f9598cc9ff8e903f94fb","tid":535283,"uid":10329,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-21T17:25:19.000Z","msg":"二月先開未遲"},{"pid":"0ac056de64fa9e8730a30bce249abb56200de62e","tid":535283,"uid":29001,"like":0,"dislike":0,"score":0,"quote":{"pid":"0aad5d631f61f19e2f2bf381ab16f897a0d2f023","tid":535283,"uid":17008,"like":25,"dislike":1,"score":24,"citedBy":1,"replyTime":"2018-01-20T16:37:02.000Z","msg":"家英哥，用投擲地球！"},"citedBy":0,"replyTime":"2018-01-21T18:24:10.000Z","msg":"屌你<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8190158289cd162b9056472d0e66fea04fb3f327","tid":535283,"uid":24160,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa065b105929e8a2d494f9598cc9ff8e903f94fb","tid":535283,"uid":10329,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-21T17:25:19.000Z","msg":"二月先開未遲"},"citedBy":0,"replyTime":"2018-01-21T18:28:36.000Z","msg":"到時幫手推<br />\n<br />\n但蘋果個網啱啱好寫住3650 日前<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"89b5d524588551753f8441eb33331c1b0a314dda","tid":535283,"uid":24160,"like":0,"dislike":0,"score":0,"citedBy"