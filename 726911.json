=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f6fc1a63e661c55b710ac368ee2991104ddc51c9","tid":726911,"uid":171151,"like":0,"dislike":0,"score":0,"quote":{"pid":"53b6649e557505b4dfc2096d8948ad9606b997cb","tid":726911,"uid":105888,"like":1,"dislike":0,"score":1,"quote":{"pid":"aa07b5530f847cc5c74553e6896f17762d10b27d","tid":726911,"uid":171151,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-07-03T04:45:46.000Z","msg":"食過晚市，加錢食a5和牛，好好食<br />\n其他嘢就好撚普通<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n仲有抽風好差，勁大煙"},"citedBy":1,"replyTime":"2018-07-03T07:46:29.000Z","msg":"和牛有咩部份食？<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-03T08:44:25.000Z","msg":"唔記得喇"},{"pid":"b4ba9fea43e04ae0502ff02846c1ede04638f539","tid":726911,"uid":140726,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-03T08:45:22.000Z","msg":"狗也不屌<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"4de41db285c12d7a2f9860d08dbe93e7de9de903","tid":726911,"uid":15906,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-03T08:47:36.000Z","msg":"垃圾<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"90b9b253559a9dfdfc399dfa7237927328de3d39","tid":726911,"uid":33154,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-07-03T23:45:14.000Z","msg":"琴晚食完<br />\n又冇想像中咁差<br />\n不過都唔係好架啦<br />\n呢間野網上d評語差到貼地<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n食物方面一般般<br />\n佢一開始上既海鮮拼盤幾好<br />\n兩隻大蝦同蠔都有驚喜<br />\n飽魚同帶子唔錯<br />\n兩隻大扇貝就有少少強差人意<br />\n<br />\n第一盤上既和牛係真係好食既<br />\n但之後叫果d冇味<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n早知就唔加<br />\n叫佢普通menu個特級胸腹肉同牛仔骨仲好食<br />\n<br />\n最多人屌既漏單同員工質素都冇咩問題<br />\n佢而家用部ipad落單<br />\n好少漏單仲要上得勁快<br />\n落完幾分鐘就上<br />\n<br />\n不過有一點好奇怪既係<br />\n佢地唔知係唔係好唔夠碟用<br />\n如果你慢慢燒慢慢吹水嘆既話<br />\n佢有個男員工會走埋黎<br />\n一鳩野將你所有肉放晒上去燒<br />\n然後收走你個碟<br />\n呢點唔係幾好<br />\n<br />\n仲有<br />\n果到個冷氣係好撚大<br />\n唔係好大 係好撚大 異常地大<br />\n凍到我同女朋友震晒<br />\n如果去食一定要帶件薄嬲<br />\n<br />\n同埋入面冇咩油煙味<br />\n呢點我覺得幾好<br />\n<br />\n結論：<br />\n不過不失啦<br />\n刺身油甘魚同馬刀貝幾好食<br />\n可以一試但冇翻食既意欲<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <br />\n下次試下伊呂波先"},{"pid":"2eb928701930ea8773a1823e71478b70287a67e6","tid":726911,"uid":179232,"like":0,"dislike":0,"score":0,"quote":{"pid":"90b9b253559a9dfdfc399dfa7237927328de3d39","tid":726911,"uid":33154,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-07-03T23:45:14.000Z","msg":"琴晚食完<br />\n又冇想像中咁差<br />\n不過都唔係好架啦<br />\n呢間野網上d評語差到貼地<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n食物方面一般般<br />\n佢一開始上既海鮮拼盤幾好<br />\n兩隻大蝦同蠔都有驚喜<br />\n飽魚同帶子唔錯<br />\n兩隻大扇貝就有少少強差人意<br />\n<br />\n第一盤上既和牛係真係好食既<br />\n但之後叫果d冇味<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n早知就唔加<br />\n叫佢普通menu個特級胸腹肉同牛仔骨仲好食<br />\n<br />\n最多人屌既漏單同員工質素都冇咩問題<br />\n佢而家用部ipad落單<br />\n好少漏單仲要上得勁快<br />\n落完幾分鐘就上<br />\n<br />\n不過有一點好奇怪既係<br />\n佢地唔知係唔係好唔夠碟用<br />\n如果你慢慢燒慢慢吹水嘆既話<br />\n佢有個男員工會走埋黎<br />\n一鳩野將你所有肉放晒上去燒<br />\n然後收走你個碟<br />\n呢點唔係幾好<br />\n<br />\n仲有<br />\n果到個冷氣係好撚大<br />\n唔係好大 係好撚大 異常地大<br />\n凍到我同女朋友震晒<br />\n如果去食一定要帶件薄嬲<br />\n<br />\n同埋入面冇咩油煙味<br />\n呢點我覺得幾好<br />\n<br />\n結論：<br />\n不過不失啦<br />\n刺身油甘魚同馬刀貝幾好食<br />\n可以一試但冇翻食既意欲<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <br />\n下次試下伊呂波先"},"citedBy":0,"replyTime":"2018-07-05T06:57:47.000Z","msg":"我睇open rice, 伊呂波執哂啦"}]}