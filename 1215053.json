-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FP0qwjsM.png&h=ddd4ac0a&s={SIZE}\" /> <br />\n<br />\n<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/90M7Cew.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F90M7Cew.png&h=40abe25d&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/sBp5oUx.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsBp5oUx.png&h=7917b9f3&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/H1PMSNN.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FH1PMSNN.png&h=d9ef5a4e&s={SIZE}\" />"},{"pid":"9c5993ffdf78017161867812ef51e01c1105ed71","tid":1215053,"uid":86509,"like":1,"dislike":0,"score":1,"quote":{"pid":"5b46c9cccc6c9e14245036a4f852b2b355775c6e","tid":1215053,"uid":203983,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-06-13T06:09:37.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-06-13T06:16:23.000Z","msg":"日日都遇到㗎喎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n啲燥火癈中癈老<br />\n成日死都逼上車<br />\n最後一秒衝上車<br />\n狂開閂一千次㗎啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n到時睇啲中坑互片<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"105c8e4d344aa639942f2230b6fecff1b4ac8fa6","tid":1215053,"uid":86509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T06:22:07.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"c5de9d438ca835b2496c5c52026a03bdf196d8f5","tid":1215053,"uid":14065,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T06:23:07.000Z","msg":"<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"9baf18224