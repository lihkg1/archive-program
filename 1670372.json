呢2.5小時嘅辯論，係好多人用咗好多年先有嘅成果。我哋永遠唔會知今日做嘅事會帶嚟聽日咩成果！"},{"pid":"bdaf01c1c3340096467cb83063d260a9e90f8e55","tid":1670372,"uid":12558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-23T04:52:21.000Z","msg":"<img src=\"https://na.cx/i/ymQGz0q.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FymQGz0q.gif&h=c6879d37&s={SIZE}\" />"},{"pid":"4206816cf4d83f08fe5178d7ad4ff1e2849dce06","tid":1670372,"uid":20272,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-23T04:52:59.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"e5b07fc04c4730ccf51ec0b62395d293c5ce5282","tid":1670372,"uid":52727,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-23T05:16:26.000Z","msg":"推"},{"pid":"3dd68818a6b3f745e327b5f822adf1a46d61e147","tid":1670372,"uid":138144,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-23T08:03:08.000Z","msg":"Bump"},{"pid":"c92dade92fd80e89140828695cbb69d933fdf11a","tid":1670372,"uid":12824,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-23T08:41:31.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}