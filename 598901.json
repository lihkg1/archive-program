sets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"117dc7df99924d90727d45f008fe53656601c7d9","tid":598901,"uid":169468,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-20T04:12:49.000Z","msg":"其實就算掂到都冇問題，唔會咁易有事，只係心理上接受唔到姐"},{"pid":"999bfcabf7514e98bd7c99fca8466b464c8fb835","tid":598901,"uid":101917,"like":0,"dislike":0,"score":0,"quote":{"pid":"59814ddb27265e2d791d4f9d92e9061ead1ca639","tid":598901,"uid":1060,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-20T03:11:42.000Z","msg":"如果好污衊我會扎馬痾（旺角公廁）<br />\n如果睇落企企理理既充坐（大商場）"},"citedBy":1,"replyTime":"2018-03-20T04:18:46.000Z","msg":"扎馬屙易生痣瘡<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e67cec6d1e880b30089f708cd958f7a59b671dea","tid":598901,"uid":162539,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-03-20T04:22:42.000Z","msg":"去公廁就係為左果個一雙玉臂千人枕既廁所板，痾屎都只係次要，如果唔狠狠咁坐落塊板度再出盡力咁甩佢，我做乜要去公廁？"},{"pid":"26d1f5a59d671c11a7a34377ff39ccb3db23d418","tid":598901,"uid":38514,"like":0,"dislike":0,"score":0,"quote":{"pid":"999bfcabf7514e98bd7c99fca8466b464c8fb835","tid":598901,"uid":101917,"like":0,"dislike":0,"score":0,"quote":{"pid":"59814ddb27265e2d791d4f9d92e9061ead1ca639","tid":598901,"uid":1060,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-20T03:11:42.000Z","msg":"如果好污衊我會扎馬痾（旺角公廁）<br />\n如果睇落企企理理既充坐（大商場）"},"citedBy":1,"replyTime":"2018-03-20T04:18:46.000Z","msg":"扎馬屙易生痣瘡<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-20T04:25:52.000Z","msg":"蹲便比坐便更利於排便<br />\n首先，當直腸里充滿糞便時，它會自動收縮，使肛管表面的肌肉放鬆。之後，環繞在直腸周圍的恥骨直腸肌會拉動直腸，形成一個直腸肛管角。排便時，恥骨直腸肌會放鬆，同時直肛管角將變大。實踐證明，蹲便的方式會讓肛管角進一步擴大，從而為糞便提供一條更直、更順暢的通道，輕鬆排便。<br />\n<br />\n<br />\n原文網址：<a href=\"https://kknews.cc/health/9olx4q.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fkknews.cc%2Fhealth%2F9olx4q.html&d=D%2BverwI54%2FCFhfeffaWAvgRJEaK469wi7EMLOMkgk88%3D&h=e661b403\" data-auto-link target=\"_blank\">https://kknews.cc/health/9olx4q.html</a>"},{"pid":"f3625756346a2d6f9b0384dac56edd8aac13d4fc","tid":598901,"uid":177376,"like":0,"dislike":0,"score":0,"quote":{"pid":"78d363bfb278e854091c584218d80348cdf65f2a","tid":598901,"uid":169892,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-20T03:09:53.000Z","msg":"唔會 無論大小都無影櫈<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-20T04:27:33.000Z","msg":"大腿肌耐力要幾勁痾屎先可以無影櫈<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"d1d14833cf346200e7970550ca4c4d1a5800c2df","tid":598901,"uid":169892,"like":0,"dislike":1,"score":-1,"quote":{"pid":"f3625756346a2d6f9b0384dac56edd8aac13d4fc","tid":598901,"uid":177376,"like":0,"dislike":0,"score":0,"quote":{"pid":"78d363bfb278e854091c584218d80348cdf65f2a","tid":598901,"uid":169892,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-20T03:09:53.000Z","msg":"唔會 無論大小都無影櫈<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-20T04:27:33.000Z","msg":"大腿肌耐力要幾勁痾屎先可以無影櫈<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-20T04:46:14.000Z","msg":"頂唔順㗎 但一諗到成個馬桶都佈滿細菌唯有頂硬上<img src=\"/assets/faces/lomoji/20.png\" class=\"hkgmoji\" />"},{"pid":"d7af228d96fb5e1812fe7459a9009f682c9b8dae","tid":598901,"uid":92401,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-20T04:49:24.000Z","msg":"唔會， 多數痾屎會圍著個厠板一個圈咁痾落去"}]}