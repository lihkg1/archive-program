lass=\"hkgmoji\" />"},{"pid":"6484ad61c2b72185bf7bdf3a77fbaae1d4cd4be2","tid":936164,"uid":34489,"like":0,"dislike":0,"score":0,"quote":{"pid":"14b1fa0199b61bbb11190ae07e8f0c478a352499","tid":936164,"uid":93358,"like":1,"dislike":2,"score":-1,"quote":{"pid":"a67eca7e538e7774acfe4a8cadc168e32cb2f796","tid":936164,"uid":34489,"like":0,"dislike":1,"score":-1,"quote":{"pid":"9a016dbbd95b7b84c4e4aa978e34052ce1bfc8b4","tid":936164,"uid":82243,"like":3,"dislike":5,"score":-2,"citedBy":2,"replyTime":"2018-12-10T14:22:56.000Z","msg":"D5500"},"citedBy":2,"replyTime":"2018-12-10T14:35:11.000Z","msg":"呢部有咩特別呀<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-12-10T15:10:30.000Z","msg":"即食 平 輕 正<br />\n$3000 /二手更平<br />\n400幾g<br />\n冇Anti-aliasing filter , 相片影像更sharp<br />\n<br />\n配af-p鏡對焦快準靜"},"citedBy":0,"replyTime":"2018-12-10T15:30:04.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"33f405d4f9f71f2cdcc9fe19c4ec5fcdb96f1a1a","tid":936164,"uid":163332,"like":1,"dislike":2,"score":-1,"quote":{"pid":"cba75702d9e484d82a5cb2d81512f544df7cd084","tid":936164,"uid":34489,"like":0,"dislike":1,"score":-1,"quote":{"pid":"00e40b710088dc98dc48af6dc75964421f938618","tid":936164,"uid":163332,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2018-12-10T15:09:26.000Z","msg":"想學攝影定要造型？有無話想影咩類型提材？"},"citedBy":1,"replyTime":"2018-12-10T15:22:25.000Z","msg":"想學 咩都影<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-10T15:41:55.000Z","msg":"買部單反加支kit鏡玩住先啦，有個光學取景器實在睇到鏡頭望出去嘅景物。片幅呢，apsc輕便啲，咁先會成日帶住係身影相；full frame 重好多，但就容易獲得更淺景深。"},{"pid":"54b4cf24a6bc90f5edb8ca58a7f66ccec1c703f0","tid":936164,"uid":226209,"like":1,"dislike":1,"score":0,"quote":{"pid":"a67eca7e538e7774acfe4a8cadc168e32cb2f796","tid":936164,"uid":34489,"like":0,"dislike":1,"score":-1,"quote":{"pid":"9a016dbbd95b7b84c4e4aa978e34052ce1bfc8b4","tid":936164,"uid":82243,"like":3,"dislike":5,"score":-2,"citedBy":2,"replyTime":"2018-12-10T14:22:56.000Z","msg":"D5500"},"citedBy":2,"replyTime":"2018-12-10T14:35:11.000Z","msg":"呢部有咩特別呀<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-12T03:16:34.000Z","msg":"無咩特別， <br />\n1， 吾算重，我搭支18-50， 2.8，鏡重過機。機身420g， 輕過部份無反。<br />\n2， 電量， nikon一向本色，影一日吾使換電。<br />\n3， 手感不錯。<br />\n4，同同期canon比DR較高。<br />\n5， 支50mm， 1.8，都係千幾，窮人必備。我係窮人， 我有。<br />\n<br />\n其他中規中矩。<br />\n價錢好的話， 入門不錯。"},{"pid":"5bff4a4e07ac2248a397e4c262459e0a610ee1c0","tid":936164,"uid":17531,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-13T05:49:43.000Z","msg":"此回覆已被刪除"},{"pid":"6195c51f3937fde559c82440c10925a7f7dcc945","tid":936164,"uid":217277,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-13T06:14:03.000Z","msg":"sony的話&hellip;<br />\n<br />\na6000 + sigma 30mm f1.4 + SEL55210 或者<br />\na6000 + sigma 三寶 (16mm f1.4 + 30mm f1.4 + 56mm f1.4)<br />\n<br />\na6000輕便同普通攝影幾唔錯，而且幾平<br />\n然後光圈快門ISO依類關係可以拎起部機慢慢試不同<br />\n<br />\n鏡頭黎講，方案一<br />\nsigma 30.4等效焦佢 ~45mm，接近標準單眼視角方便學習構圖<br />\nsel55210平價變焦遠攝鏡，雖然日光鏡要光源充足先發揮得好但成像唔差，而且可以體驗遠攝構圖/壓縮景深滋味<br />\n但會冇左廣角端，可能長遠需要入多支sigma 16mm f1.4或者19 f2.8黎影大景/SNAP SHOT <br />\n<br />\n方案二<br />\nsigma三寶包括曬廣角、標準、遠攝，方便練習大景或者特寫構圖<br />\n三支定焦雖然要按需要換鏡，但成像質素比變焦鏡好，同埋會令你放心機諗構圖<br />\n唯一考慮係帶曬三支鏡出街時你會唔會嫌麻煩<br />\n如果想輕便D會有f2.8既組合 (19mm / 30mm / 60mm)<br />\n<br />\n不論NIKON CANON定SONY<br />\n收夠料後去SHOWROOM試一試啦，記住設定想試既主題 (例如定焦VS變焦 / 相機易上手程度 / 鏡頭特性)，避色上到剩係拎上手CHOP幾下用過當試左"},{"pid":"47f1538d4dcfca38c3bd897fa878dbbcdaf91f7b","tid":936164,"uid":217277,"like":0,"dislike":0,"score":0,"quote":{"pid":"6195c51f3937fde559c82440c10925a7f7dcc945","tid":936164,"uid":217277,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-13T06:14:03.000Z","msg":"sony的話&hellip;<br />\n<br />\na6000 + sigma 30mm f1.4 + SEL55210 或者<br />\na6000 + sigma 三寶 (16mm f1.4 + 30mm f1.4 + 56mm f1.4)<br />\n<br />\na6000輕便同普通攝影幾唔錯，而且幾平<br />\n然後光圈快門ISO依類關係可以拎起部機慢慢試不同<br />\n<br />\n鏡頭黎講，方案一<br />\nsigma 30.4等效焦佢 ~45mm，接近標準單眼視角方便學習構圖<br />\nsel55210平價變焦遠攝鏡，雖然日光鏡要光源充足先發揮得好但成像唔差，而且可以體驗遠攝構圖/壓縮景深滋味<br />\n但會冇左廣角端，可能長遠需要入多支sigma 16mm f1.4或者19 f2.8黎影大景/SNAP SHOT <br />\n<br />\n方案二<br />\nsigma三寶包括曬廣角、標準、遠攝，方便練習大景或者特寫構圖<br />\n三支定焦雖然要按需要換鏡，但成像質素比變焦鏡好，同埋會令你放心機諗構圖<br />\n唯一考慮係帶曬三支鏡出街時你會唔會嫌麻煩<br />\n如果想輕便D會有f2.8既組合 (19mm / 30mm / 60mm)<br />\n<br />\n不論NIKON CANON定SONY<br />\n收夠料後去SHOWROOM試一試啦，記住設定想試既主題 (例如定焦VS變焦 / 相機易上手程度 / 鏡頭特性)，避色上到剩係拎上手CHOP幾下用過當試左"},"citedBy":0,"replyTime":"2018-12-13T06:20:47.000Z","msg":"btw a6000係屬於apsc機，即係塊感光元件既面積相比專業FF機細塊D<br />\n要記住依件事會影響實際焦距，所以剛才提及有<strong>特效</strong>焦距依回事<br />\n<br />\nSONY同NIKON既APSC機要將鏡頭焦段x1.5，CANON既要x1.6<br />\n所以例如30mm既鏡用係SONY部APSC機時，實際焦距係30x1.5 = 45mm<br />\n因此唔好起初以為30mm就以為係廣角，其實換算後更接近標準鏡<br />\n<br />\n同埋巴打你冇講預算又冇限定想優先學既主題，其實難俾更具體可操作既建議<br />\n<br />\n利申︰唔熟悉NIKON Caono 其他品牌機鏡，等依方面用家巴打補充其他可能性 / 要點"},{"pid":"bfa51902dc5b7b2a9c12d4cd5b830a8a8ced21e1","tid":936164,"uid":40272,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-12-13T06:24:45.000Z","msg":"我都係新手 買左架a7r3<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"62e491ad21b7be126271a508f7ef2b7573f1107c","tid":936164,"uid":197863,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-13T09:06:10.000Z","msg":"其實個個新手諗住買部入門機學影相，依個概念係好錯<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n唔係叫你一定要買部好貴相機<br />\n但最小部機係有一定規格令你影到靚相，手動學習到攝影光圈/快門/ISO 三角關係，從而有滿足感去學落去。<br />\n個人推薦 Fujifilm XT3 <br />\n預算唔多就Fujifilm XT20 <br />\n<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"}]}