"ef85fd96a944d684dcc6164825858095c68545a4","tid":2320504,"uid":124690,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T05:05:49.000Z","msg":"2012 + 8 = 2020<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"3a0cb74bca39d8d4128bdab0d1fac7624cc27fb4","tid":2320504,"uid":118983,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T05:12:07.000Z","msg":"天球交滙"},{"pid":"852a7a74cd2fbae63f6a43e4ac19400a682f0fe6","tid":2320504,"uid":121125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T05:12:23.000Z","msg":"咪又係要返工<img src=\"/assets/faces/pig/dance3.gif\" class=\"hkgmoji\" />"},{"pid":"37a767e0078b4a6f34bad5b7c1c8c6325a764d5d","tid":2320504,"uid":3172,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-11T05:12:40.000Z","msg":"究竟印度有幾多個神童"},{"pid":"7170080c13110a93ff5d9fb7b7d2cd64ad5afa27","tid":2320504,"uid":128179,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-11T05:17:03.000Z","msg":"1.對神的信仰<br />\n2.增強免疫力<br />\n3.停止錯誤治療<br />\n4.理財和投資黃金、土地<br />\n5.傳播正面情緒<br />\n6.注意心理健康<br />\n7.走入大自然<br />\n<br />\n<br />\n1. 依樣野見人見致<br />\n其他鬼唔知咩<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"}]}