43da9ea9954fc4e5","tid":659413,"uid":135160,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-10T06:46:23.000Z","msg":"文筆<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-10T07:04:42.000Z","msg":"咩文筆<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"2af2526d12edac3edae71a6db039df89419b8dfa","tid":659413,"uid":28371,"like":1,"dislike":0,"score":1,"quote":{"pid":"1d79403ce57f782781dac777105b3961bbdcc029","tid":659413,"uid":87648,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2018-05-10T05:24:15.000Z","msg":"我女友就有抑鬱，我好多時都被佢搞到自己都鬱鬱地。 起初以為香港同台灣個環境令到佢提唔起勁搵生活/生存嘅意義，就決定拋低一切移民，希望換一個生活節奏慢d嘅地方，可以慢慢再重拾生活嘅樂趣。奈何佢始終會將生活上好細微嘅錯折放大，一路鑽牛角尖。<br />\n係我眼中，抑鬱嘅人好多時係將自己個標準定得好高，好難會滿足得到。當個人需求一直滿足唔到果陣，久而久之就會對身邊嘅一切失去興趣。<br />\n<br />\n我依家都係好似照顧小朋友咁，每日陪住佢，同佢一齊學下西班牙文，一齊諗下煮咩菜咁。暗地裏就不斷嘗試去幫佢完成佢想要嘅人生。<br />\n<br />\n所以，你可以聽下其他人意見，試下去學下寫program 或者做其他事，可能開始果陣無興趣，但你嘗試下堅持多陣，或者會幫你點燃到心入面堆柴。"},"citedBy":0,"replyTime":"2018-05-10T14:51:18.000Z","msg":"巴打女朋友有你真係好幸福"},{"pid":"be17664506b13183ec17ce9706549f39dc20e5a9","tid":659413,"uid":28371,"like":0,"dislike":0,"score":0,"quote":{"pid":"176007a56e16f261419890b3f7af5841efa3e500","tid":659413,"uid":37912,"like":0,"dislike":0,"score":0,"quote":{"pid":"14d7810621c36bebdede740235be3e8c1f8d1c2a","tid":659413,"uid":28371,"like":1,"dislike":0,"score":1,"quote":{"pid":"457fdb324cb2f2b3ba0bc8af21fcb9803b6a0aba","tid":659413,"uid":37912,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-05-09T21:03:12.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-05-10T02:48:12.000Z","msg":"呢種好似架車冇晒油嘅感覺好難受<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-10T04:17:29.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-05-10T14:53:11.000Z","msg":"全中 係好無助的感覺"},{"pid":"840a659c258d39023e1c314cffde46bd51