b010cdb6c9ba.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F03%2F202845_da65c06b4622fb9dafd3b010cdb6c9ba.png&h=3d72fabb&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/07/03/202854_d3eb21fe4c4487fd1d8a63fb2c4ecab4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F03%2F202854_d3eb21fe4c4487fd1d8a63fb2c4ecab4.png&h=7c6200f2&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/07/03/204852_0829705895cb601eb146a9fdc10f4d6b.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F03%2F204852_0829705895cb601eb146a9fdc10f4d6b.gif&h=0ef0f4ae&s={SIZE}\" /><br />\n<br />\n感謝KFCCoffee巴高質cap圖<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"c19a01965849e712c678ec8d65d904ada73eccfb","tid":728351,"uid":145037,"like":30,"dislike":1,"score":29,"citedBy":0,"replyTime":"2018-07-03T17:34:21.000Z","msg":"我覺得佢先係女主角<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"02a75a31fb9091cf8356472909c256d31c5ede47","tid":728351,"uid":63588,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2018-07-03T17:40:58.000Z","msg":"靈活雲芝"},{"pid":"602e08534cdbaf818e531b9bafb1721e9e303ba3","tid":728351,"uid":137470,"like":2,"dislike":2,"score":0,"citedBy":0,"replyTime":"2018-07-04T11:24:38.000Z","msg":"【開心速遞】大小姐同送水輝終成為戀人　將有強勁情敵出現硬撬<br />\n<br />\n<img src=\"https://cdn.hk01.com/di/media/images/1610203/org/ba5a0c0da5ec3fc0473bff0e293487fb.JPG/fKOtXX2xNAX6nawxN3718CwiTrFQ8BWBDuRd0Q7kXdE?v=w1920\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F1610203%2Forg%2Fba5a0c0da5ec3fc0473bff0e293487fb.JPG%2FfKOtXX2xNAX6nawxN3718CwiTrFQ8BWBDuRd0Q7kXdE%3Fv%3Dw1920&h=6bdb4887&s={SIZE}\" /><br />\n<br />\n無綫處境劇《愛&middot;回家之開心速遞》今日(4日)舉行活動宣布會再添食180集，全劇幾乎總動員出席造勢，還有珍姐 (曾勵珍)、該劇監製林建祥、編審李綺華及袁寶慧等，場面熱鬧。劇中多對CP均大受觀眾同網民歡迎，其中就以大小姐 (林淑敏飾) 與送水輝 (許家傑飾) 最有人氣，兩人的感情線發展令大家都睇得好肉緊。昨晚播出的一集更引起網民熱烈的討論，話睇到好感動，又大讚兩人演得好。而大家最關心的當然是兩人到底會否成為情侶啦。<br />\n<br />\n林淑敏 (Mandy) 同許家傑就預告大小姐同送水輝確是會發展成為情侶的，Mandy說：「至於係點樣開始呢？由咩關係開始就要賣個關子，會開始得幾得意嘅，出人意表咁好睇。」家傑亦不肯透露半句。提到昨晚那集有不少網民表示感動到喊，大小姐表示：「我當初睇劇本時都有喊，寫得好好，真係好感動，令人好動容，導演好畀心機拍。」家傑又指該劇投放了好多資源去製作。<br />\n<br />\n對於有網民讚家傑的演技有進步，大小姐即說：「佢不嬲演得幾好，唔係咩進步咗，係好之外可以更加好。有好對手好重要，佢帶到我入戲，我哋大家互相幫助，演技無頂，希望可以衝破。」家傑就大讚Mandy說：「大小姐真係演得好好，喜怒哀樂，起承轉接都無得彈。」原來兩人就算不用開工，都會私底下相約出來對劇本，非常認真同專業。問到稍後黎振燁是否加入做第三者同送水輝爭大小姐，他們就話暫時收到的劇本未寫到，不過編審同監製就劇透了黎振燁的第三者角色，笑言：「唔可以畀大小姐同送水輝咁順利嘅。」"},{"pid":"17341e81d1911ba65eb499620ea45173d5ea46a8","tid":728351,"uid":41508,"like":8,"dislike":35,"score":-27,"citedBy":0,"replyTime":"2018-07-04T11:27:13.000Z","msg":"此回覆已被刪除"},{"pid":"c126b49e509666787b4ad3ea177cf1cad784e31c","tid":728351,"uid":155818,"like":0,"dislike":5,"score":-5,"citedBy":0,"replyTime":"2018-07-04T11:27:45.000Z","msg":"思思"},{"pid":"fe4ebb195e7693c483e469fb6b519994ed596c62","tid":728351,"uid":170896,"like":3,"dislike":18,"score":-15,"citedBy":0,"replyTime":"2018-07-04T11:28:35.000Z","msg":"女人喊下就好戲嫁啦<br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b7af2c8af7f0fa4a899626b35297e4039ca996ef","tid":728351,"uid":66825,"like":1,"dislike":15,"score":-14,"citedBy":0,"replyTime":"2018-07-04T11:29:17.000Z","msg":"屌你睇錯徐淑敏<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" /> 無野睇返出去先"},{"pid":"d6b11b7916c65342fbb3bdf3e7630c75fd1854f7","tid":728351,"uid":79355,"like":2,"dislike":31,"score":-29,"citedBy":0,"replyTime":"2018-07-04T12:33:28.000Z","msg":"佢d戲作狀到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"bee63ce944ba4e74475efe1ac5cf1152dd71aa8c","tid":728351,"uid":62815,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-04T17:54:07.000Z","msg":"小蓮<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"fc93590c08279dd7282acbb92e2cf4985f986b59","tid":728351,"uid":37666,"like":37,"dislike":0,"score":37,"citedBy":0,"replyTime":"2018-07-04T19:00:18.000Z","msg":"佢由潑婦變番淑女轉變得勁快<br />\nTVB都痴線既 咁好既演員留到依家先重用"},{"pid":"1fe0a598529500a570f2f926468168089cd6236a","tid":728351,"uid":4431,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-07-04T19:08:59.000Z","msg":"先黎三角戀，之後bbq嗰陣法國初戀情人返左黎仲要無女，如果係咁就真係攞硬獎啦。可以將傳統嘅劇情演得活靈活現<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"da77bccbbbfdcaa488b731e7106d5bd35bbd94ee","tid":728351,"uid":65429,"like":19,"dislike":0,"score":19,"citedBy":2,"replyTime":"2018-07-05T00:26:46.000Z","msg":"佢值得轉正拍正劇<br />\n演技同外表擺去大陸韓國日本同齡女演員都唔失禮"},{"pid":"051455a5d2c338be63e249564be18197d9704cb4","tid":728351,"uid":51895,"like":11,"dislike":0,"score":11,"quote":{"pid":"da77bccbbbfdcaa488b731e7106d5bd35bbd94ee","tid":728351,"uid":65429,"like":19,"dislike":0,"score":19,"citedBy":2,"replyTime":"2018-07-05T00:26:46.000Z","msg":"佢值得轉正拍正劇<br />\n演技同外表擺去大陸韓國日本同齡女演員都唔失禮"},"citedBy":0,"replyTime":"2018-07-05T01:08:40.000Z","msg":"有天海祐希既氣勢<br />\n但又不失可愛<br />\n大小姐真係好正<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"fedf4442bf5e55187e02ad9047cab5719da4a230","tid":728351,"uid":7907,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-05T01:29:22.000Z","msg":"為左睇大小姐先開電視<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"11fc6cb017ec4e7db3e5ba19026daf115a2d479b","tid":728351,"uid":81569,"like":15,"dislike":0,"score":15,"citedBy":0,"replyTime":"2018-07-13T12:59:59.000Z","msg":"唔係馬後炮<br />\n以前已經覺得佢做戲好睇過唐姨，胡定欣呢啲"},{"pid":"be07f5227cfd0e7f978fb5131d05c345ad4b7a21","tid":728351,"uid":154684,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-13T15:00:08.000Z","msg":"直頭要拎我最喜愛女角色<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"60bf7e34e9a1bd6e29627ffad9b5168fdcc1c378","tid":728351,"uid":137470,"like":1,"dislike":0,"score":1,"citedBy":0,"