pan style=\"color: gold;\">那就證明我們不但同敵人劃清了界線，而且證明我們的工作是很有成績的了。</span></strong><br />\n<br />\n我地要打贏班五毛小粉紅，要人啊！😡"},{"pid":"a8edebcf32da387644ad8a61f81db2d600ffa01c","tid":1956892,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:28:20.000Z","msg":"推"},{"pid":"b91cd7fc61886956a5e2d6aa943e940a9e7d7987","tid":1956892,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:28:31.000Z","msg":"推"},{"pid":"fb06c7c2972c2d24f35f94560879cba1ac9c3054","tid":1956892,"uid":307203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:28:36.000Z","msg":"push"},{"pid":"6314320ed75ef93ac49eacca99e1d1aae87e39e1","tid":1956892,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:28:41.000Z","msg":"推"},{"pid":"299cc43ded9e581a42889df2d9377e9ab133424c","tid":1956892,"uid":75759,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:28:43.000Z","msg":"推"},{"pid":"d24ac92e4c4bbe2c594a77ccf4bb5392d7836b11","tid":1956892,"uid":307203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:28:48.000Z","msg":"push"},{"pid":"134525078f37e57f8c202c78a88bfdefb1052967","tid":1956892,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:28:51.000Z","msg":"推"},{"pid":"e1811cfb9a75bc12e991006ee48d9f17643e2d24","tid":1956892,"uid":75759,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:28:56.000Z","msg":"推"},{"pid":"41fcabb2220156885fd84cfd41db87e06ac0cbf3","tid":1956892,"uid":307203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:28:58.000Z","msg":"push"},{"pid":"8bf73b2315407903b5d08fe33f1e9939c2d75cde","tid":1956892,"uid":235501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:29:02.000Z","msg":"推"},{"pid":"6eb7569fb0e82d32ab5a9a75a5fe54e26954a476","tid":1956892,"uid":75759,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T13:29:07.000Z","msg":"推"},{"pid":"fd3