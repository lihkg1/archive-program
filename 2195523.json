,"uid":301989,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-09-09T08:48:31.000Z","msg":"黑人&gt;支那人"},{"pid":"b5cb4c5c042873447cb6cf1a6e3bf779bd1ab7f8","tid":2195523,"uid":221132,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-09T08:49:45.000Z","msg":"黃種人先係"},{"pid":"eb02480db6acb7fe216fa21c17002f31682507da","tid":2195523,"uid":273791,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-09-09T08:49:48.000Z","msg":"&ldquo;白種人黃種人黑種人&rdquo; 中東地方嗰啲係咩?南美嗰啲又係咩? 東歐嗰啲又係咩?"},{"pid":"be8b09667013b7fd4f1e630ef649f4f09172645d","tid":2195523,"uid":2772,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-09-09T08:49:56.000Z","msg":"支那人先係最低"},{"pid":"f9b0b5fb159062c35ecb11adbede0d2d0d8e74f8","tid":2195523,"uid":2772,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-09-09T08:51:28.000Z","msg":"黑人就算點衰 都係攪衰自己地方<br />\n<br />\n支那人自己衰不特止<br />\n仲去攪衰人地地方"},{"pid":"6dc051314ec822c2a6cc426a1ffa16415b5c1d9c","tid":2195523,"uid":208702,"like":1,"dislike":0,"score":1,"quote":{"pid":"f9b0b5fb159062c35ecb11adbede0d2d0d8e74f8","tid":2195523,"uid":2772,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-09-09T08:51:28.000Z","msg":"黑人就算點衰 都係攪衰自己地方<br />\n<br />\n支那人自己衰不特止<br />\n仲去攪衰人地地方"},"citedBy":0,"replyTime":"2020-09-09T08:51:50.000Z","msg":"博唔到<img src=\"/assets/faces/big/good.gif\" class=\"hkgmoji\" />"},{"pid":"a2a12b601ebc697941e45d8cbd56d76f9ec9243e","tid":2195523,"uid":208702,"like":0,"dislike":1,"score":-1,"quote":{"pid":"be8b09667013b7fd4f1e630ef649f4f09172645d","tid":2195523,"uid":2772,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-09-09T08:49:56.000Z","msg":"支那人先係最低"},"citedBy":0,"replyTime":"2020-09-09T08:52:54.000Z","msg":"但係而家嘅討論係講緊人種，黃黑白啡，支那人=動物&ne;人，所以可以退出討論"},{"pid":"030f93bb22df00111a8b38234d5b0e241100e5a6","tid":2195523,"uid":279511,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-09-09T08:54:21.000Z","msg":"唔認同   <br />\n藍屍先係"},{"pid":"b1470fefbcee7dece3835b7dd3607b01ef849e08","tid":2195523,"uid":278219,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-09-09T08:54:34.000Z","msg":"支那人衰cheap，同樣死力架都係賤 廢 臭。<br />\n兩者無衝突"},{"pid":"2a94add78cfa2c6242c6623ea02c77bca8600790","tid":2195523,"uid":60648,"like":0,"dislike":0,"score":0,"quote":{"pid":"3fb0cc72a2b8b03caff2ce9a46213b94e8e6411a","tid":2195523,"uid":343268,"like":14,"dislike":0,"score":14,"citedBy":2,"replyTime":"2020-09-09T08:43:54.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-09-09T08:55:34.000Z","msg":"一樣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e9dbc7ad37cf56944f9166dec40b10cc7c383469","tid":2195523,"uid":81505,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-09-09T08:56:10.000Z","msg":"好想將中國人同黑人擺晒係同一個國家<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"211bd3318ca9f78d7ae57eaf0d5a406815a1d170","tid":2195523,"uid":204929,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-09-09T08:56:19.000Z","msg":"講嚟講去,其實都係有暗中貶低鬼佬<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />!<br />\n<br />\n然後再推行中國極端民族主義<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />!"},{"pid":"6205e309291c2fff081d78c81edde8ee600ad504","tid":2195523,"uid":208702,"like":0,"dislike":1,"score":-1,"quote":{"pid":"3fb0cc72a2b8b03caff2ce9a46213b94e8e6411a","tid":2195523,"uid":343268,"like":14,"dislike":0,"score":14,"citedBy":2,"replyTime":"2020-09-09T08:43:54.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2020-09-09T08:56:50.000Z","msg":"黃種人，日本，韓國，台灣<br />\n<br />\n唔可以用支那人騎劫全部黃種人，thx"},{"pid":"2a585ce9c6ba73815958cd93ccd92a5b4064e68c","tid":2195523,"uid":238415,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-09T08:58:44.000Z","msg":"一定係支那人囉<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"26aff3c0d4e68b030c5ae143147fe7ebadf44ae9","tid":2195523,"uid":208702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-09T08:59:35.000Z","msg":"其實根本就要喺非洲開塊地，用欄杆困住啲支那人同埋黑人<img src=\"/assets/faces/big/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"a693b26443bb1830b32ec2b21cc3f1f6e2fb2dde","tid":2195523,"uid":81424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-09T09:01:05.000Z","msg":"東非黑人同西非黑人喺基因/文化上都係兩回事<br />\n凡係唔區分兩者嘅都文都係垃圾"}]}