,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T16:07:00.000Z","msg":"PUSH"},{"pid":"2b94103a3ad8d4d99c9d32cb15e686fa1c772274","tid":1345951,"uid":43098,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T02:12:22.000Z","msg":"PUSH"},{"pid":"b61b6de9a0d44e614e14cd7323f59d7c1bbc096c","tid":1345951,"uid":43098,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T03:52:53.000Z","msg":"Push"},{"pid":"4831f4580cb3101ab8f21d32acb79c5e319736a1","tid":1345951,"uid":54785,"like":0,"dislike":0,"score":0,"quote":{"pid":"02815e2806cfcb90cb2e8960e60da9df54563a44","tid":1345951,"uid":43098,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-22T03:28:54.000Z","msg":"社會契約破壞左，我地都可以唔遵守我果部分"},"citedBy":1,"replyTime":"2019-07-24T01:45:14.000Z","msg":"多謝樓主<br />\n<br />\n呢個term 好細個就聽個, 但香港人普遍都係唔識, 而家睇完你篇文就明白了<br />\n<br />\n其實就好似簽約咁, 大家有mutual agreement, 如果有一分破壞左, 就係毀約, 張約毀左, 亦無所謂遵守約定上嘅規則<br />\n<br />\n只不過係我地社會發展到一定程度, 大家都忘記左, 而中共更加行返以往君權神授果套"},{"pid":"5fce18a134cd10dc5a55835d6737de832caa76de","tid":1345951,"uid":43098,"like":1,"dislike":0,"score":1,"quote":{"pid":"4831f4580cb3101ab8f21d32acb79c5e319736a1","tid":1345951,"uid":54785,"like":0,"dislike":0,"score":0,"quote":{"pid":"02815e2806cfcb90cb2e8960e60da9df54563a44","tid":1345951,"uid":43098,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-22T03:28:54.000Z","msg":"社會契約破壞左，我地都可以唔遵守我果部分"},"citedBy":1,"replyTime":"2019-07-24T01:45:14.000Z","msg":"多謝樓主<br />\n<br />\n呢個term 好細個就聽個, 但香港人普遍都係唔識, 而家睇完你篇文就明白了<br />\n<br />\n其實就好似簽約咁, 大家有mutual agreement, 如果有一分破壞左, 就係毀約, 張約毀左, 亦無所謂遵守約定上嘅規則<br />\n<br />\n只不過係我地社會發展到一定程度, 大家都忘記左, 而中共更加行返以往君權神授果套"},"citedBy":0,"replyTime":"2019-07-24T03:39:38.000Z","msg":"唔洗多謝 本來唔係讀會科學既朋友都唔會突登去了解<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"175382c9800004d00db15b82e2832c897247dc82","tid":1345951,"uid":43098,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T04:17:00.000Z","msg":"Push"},{"pid":"c0ef5c