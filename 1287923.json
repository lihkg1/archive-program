tps%3A%2F%2Fwww.anyidea.hk%2Fen%2Fjob%2F1135%2Fwork%2F17985%2Fview%2F1467956348.jpg&h=57c9e307&s={SIZE}\" /><br />\n<img src=\"https://cdn.shopify.com/s/files/1/0016/8535/6621/products/d035df4fe79b06c75e08792e4494e23f_1000x1000.png?v=1536332363\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.shopify.com%2Fs%2Ffiles%2F1%2F0016%2F8535%2F6621%2Fproducts%2Fd035df4fe79b06c75e08792e4494e23f_1000x1000.png%3Fv%3D1536332363&h=f0af8e9e&s={SIZE}\" />"},{"pid":"78f72932b93fcc16c8a189e3826b40cd5901fe27","tid":1287923,"uid":5523,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-07-05T12:20:27.000Z","msg":"定依隻好?<br />\n<br />\n<img src=\"https://i1.wp.com/pic4.zhimg.com/50/9665ca286ed0a338f8fc53f7d9ac9653_hd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi1.wp.com%2Fpic4.zhimg.com%2F50%2F9665ca286ed0a338f8fc53f7d9ac9653_hd.jpg&h=a9db7227&s={SIZE}\" />"},{"pid":"b3d4572a9e8c1c2001a603dacc3555f370649e84","tid":1287923,"uid":39752,"like":0,"dislike":0,"score":0,"quote":{"pid":"aa0c6b266ad08bbee92a94746e7a765813a49a03","tid":1287923,"uid":5523,"like":0,"dislike":1,"score":-1,"quote":{"pid":"2cd3139ac3f3b408a7078ce834b558a85f0a74a8","tid":1287923,"uid":39752,"like":0,"dislike":0,"score":0,"quote":{"pid":"ee0db395d0dbd2bda88350ed1bef6ff559598df3","tid":1287923,"uid":5523,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-07-05T12:07:46.000Z","msg":"<img src=\"https://na.cx/i/KrrZxYL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKrrZxYL.jpg&h=96aace23&s={SIZE}\" /><br />\n<br />\n定D黎..<br />\n用呢隻紅, 唔用共產血紅<br />\n好唔好?<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-05T12:12:24.000Z","msg":"兩個字：色差"},"citedBy":1,"replyTime":"2019-07-05T12:19:13.000Z","msg":"唔識design呀..<br />\n依隻紅呢?<br />\nd圖網上搵的..<br />\n<br />\n<img src=\"https://www.anyidea.hk/en/job/1135/work/17985/view/1467956348.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.anyidea.hk%2Fen%2Fjob%2F1135%2Fwork%2F17985%2Fview%2F1467956348.jpg&h=57c9e307&s={SIZE}\" /><br />\n<img src=\"https://cdn.shopify.com/s/files/1/0016/8535/6621/products/d035df4fe79b06c75e08792e4494e23f_1000x1000.png?v=1536332363\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.shopify.com%2Fs%2Ffiles%2F1%2F0016%2F8535%2F6621%2Fproducts%2Fd035df4fe79b06c75e08792e4494e23f_1000x1000.png%3Fv%3D1536332363&h=f0af8e9e&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-07-05T12:27:25.000Z","msg":"就係因為呢個世界太少人識 design，太多情況下重製旗幟、重用旗幟色都唔專業，所以旗幟設計用嘅顏色通常都好大路，就算有色差，問題都唔嚴重<br />\n你呢隻紅藍色先唔講無標準（其實係紅/藍線溝白線溝出嚟），就算有標準，普通無知識嘅人憑印象唔會整得返出嚟<br />\n到拎去印（非專業情況，例如唔識轉CMYK）又有多一重色差，咁如果印咗出嚟變成好似咁<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />，我重承唔承認係同一支旗好？<br />\n<br />\n點解咁少旗用紫色都係類似原理<br />\n吉百利嘅紫色同<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />都可以話係紫色，但睇落完全唔同"},{"pid":"90e085d03da663f72a7a8a8e9d9fe2e56ec19d5e","tid":1287923,"uid":218,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-05T12:29:43.000Z","msg":"笑撚咗<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b16e22bf72ebc5ca486c580f249e5a42da8bfbfa","tid":1287923,"uid":5523,"like":0,"dislike":1,"score":-1,"quote":{"pid":"b3d4572a9e8c1c2001a603dacc3555f370649e84","tid":1287923,"uid":39752,"like":0,"dislike":0,"score":0,"quote":{"pid":"aa0c6b266ad08bbee92a94746e7a765813a49a03","tid":1287923,"uid":5523,"like":0,"dislike":1,"score":-1,"quote":{"pid":"2cd3139ac3f3b408a7078ce834b558a85f0a74a8","tid":1287923,"uid":39752,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-05T12:12:24.000Z","msg":"兩個字：色差"},"citedBy":1,"replyTime":"2019-07-05T12:19:13.000Z","msg":"唔識design呀..<br />\n依隻紅呢?<br />\nd圖網上搵的..<br />\n<br />\n<img src=\"https://www.anyidea.hk/en/job/1135/work/17985/view/1467956348.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.anyidea.hk%2Fen%2Fjob%