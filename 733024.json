{"tid":733024,"cid":5,"subCid":0,"title":"【國際突發】千葉縣東部發生 黎克特制6級地震","createTime":"2018-07-07T12:05:06.000Z","updateTime":"2018-07-07T12:05:06.000Z","uid":65346,"like":0,"dislike":0,"uniUserReply":1,"replies":[{"pid":"c25fed30ae65df63c1148d80e06dd0b76fb22e0e","tid":733024,"uid":65346,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-07T12:05:06.000Z","msg":"<a href=\"https://hk.news.appledaily.com/international/realtime/article/20180707/58414064\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Finternational%2Frealtime%2Farticle%2F20180707%2F58414064&d=WDp8gKrEpb2cwY35X3V8FZZgE6vMW1KEzMhkvokIvkY%3D&h=38ed07d0\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Finternational%2Frealtime%2Farticle%2F20180707%2F58414064&h=87e37523\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/international/realtime/article/20180707/58414064</a><br />\n<br />\n<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /> <br />\n<br />\n又水又地震<br />\n日本危險啦.....<br />\n<br />\n日本氣象廳公佈，鄰近東京的千葉縣東部在當地時間7時許發生黎克特制6級地震，震源深度50公里，東京市內建築物都受影響搖晃。當局未有發出海嘯警告，暫時未有傷亡報告。"}]}