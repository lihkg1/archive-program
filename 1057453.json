d":"388414b20d783a97be19fafb5b75962aa1d07659","tid":1057453,"uid":29929,"like":0,"dislike":3,"score":-3,"quote":{"pid":"3b1c3fae77285eebb51b777eb6880f8a8e7e67f8","tid":1057453,"uid":65984,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-12T04:22:51.000Z","msg":"蒜蓉牛油雜菇超好食喎"},"citedBy":0,"replyTime":"2019-03-12T04:29:47.000Z","msg":"你將鮑魚、魚換做菇一樣好好食<br />\n好食在調味"},{"pid":"86287e1329073f232cf744281919ecc3942fa400","tid":1057453,"uid":51698,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-12T04:32:27.000Z","msg":"好鍾意食菇<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n之前係英國煮嘢食日日都一定食菇 仲要係清蒸唔落嘢<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"8396a4bb194451adab17d326d8c7c741eaf589dc","tid":1057453,"uid":160031,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-12T04:34:44.000Z","msg":"聞到陣菇味就頭暈"},{"pid":"17bcf982dbde0719e55c37f94750c4a7be22c0a2","tid":1057453,"uid":200286,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-12T04:34:47.000Z","msg":"好撚正呀蘑菇冬菇杏鮑菇金針菇<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"eb6d3b65cbe572515d4482471fcb8427d1cdf35f","tid":1057453,"uid":46965,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-03-12T04:35:57.000Z","msg":"最撚憎草菇<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<br />\n其他都ok"},{"pid":"916cc5b3233dbbc25883e405fb920fce340647e1","tid":1057453,"uid":177924,"like":1,"dislike":5,"score":-4,"citedBy":0,"replyTime":"2019-03-12T04:42:14.000Z","msg":"最撚憎食菇<img src=\"/assets/faces/lm2/dead.gif\" class=\"hkgmoji\" /><br />\n聞到就想嘔<br />\n有時唔知食左落口個口感又核特<br />\n之前試過食碗仔翅訓練食菇<br />\n結果成日個身都唔舒服<br />\n啲胃氣有陣菇味差啲臭死自己<br />\n次次去酒樓食飯都會有碟野係勁多香菇<br />\n見到佢上果陣我就想走"},{"pid":"bcd299bf3197a1cb21638a32aaf2a41a2fb17177","tid":1057453,"uid":124169,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-03-12T04:44:12.000Z","msg":"好鐘意食菇 冬菇 蘑菇 大啡菇<img src=\"/assets/faces/lm2/tongue.gif\" class=\"hkgmoji\" /><br />\n但食左濕疹會發<br />\n已經好耐無食<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},{"pid":"5300899fd55676cc840c2ed76c0194cf72a8ce3a","tid":1057453,"uid":76098,"like":1,"dislike":0,"score":1,"quote":{"pid":"86287e1329073f232cf744281919ecc3942fa400","tid":1057453,"uid":51698,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-12T04:32:27.000Z","msg":"好鍾意食菇<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n之前係英國煮嘢食日日都一定食菇 仲要係清蒸唔落嘢<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-12T05:12:17.000Z","msg":"煲飯直接掉d啡菇落去<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"4328144f4a9a39f3882530c56aa4f847da7ec333","tid":1057453,"uid":49062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-12T05:37:31.000Z","msg":"覺得口感同味道都好怪<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"db7cef9d65b696dacf7f27edf63b6a9dfa3e60fd","tid":1057453,"uid":17566,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-03-12T06:40:32.000Z","msg":"好鐘意食菇<br />\n草菇滾湯同炒牛肉都正，最緊要係唔好切開，入面濃裂嘅菇味爆漿出黎<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />，但一定要加薑辟走泥味<br />\n磨菇就配牛扒，煎完牛再用剩低嘅油煎，好撚好食<br />\n雞脾菇打邊爐一流<br />\n好多人食金針菇就好一般，純食口感又難消化<br />\n最易伏就係d 咩海鮮菇蟹味菇，間唔中都會苦 <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"}]}