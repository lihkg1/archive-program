8:21.000Z","msg":"中國特色社會現象"},{"pid":"9506f3c7eb99f13c9131b9e0c221070248df6fe4","tid":726300,"uid":174601,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-03T00:59:07.000Z","msg":"1959-1961<br />\n係毛澤東管治時期既大飢荒。官方人口少左過三千萬<br />\n<br />\n1965 佢地18歲。可以生存仲會講乜自由 人權<br />\n有既只係合作、妥協"},{"pid":"0becbed842732c5b20c6fe57d50d68d0769522d6","tid":726300,"uid":130901,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-03T01:06:06.000Z","msg":"無姦屍算係咁啦"},{"pid":"fd08ada7eff0f7face77c1987031ae308214e43f","tid":726300,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-03T02:13:55.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 根本唔可以叫做人<br />\n唔好再叫做中國&quot;人&quot;啦<br />\n畜牲們"},{"pid":"18c6d58ab46727d8c62c8a683a97230b955bdc4c","tid":726300,"uid":15823,"like":0,"dislike":0,"score":0,"quote":{"pid":"48424d4b8acbffba3d9dc8f5152d39695010b5fc","tid":726300,"uid":2419,"like":0,"dislike":0,"score":0,"quote":{"pid":"f0a46e242e84aa09b48299c638733226622d8ca0","tid":726300,"uid":41974,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2018-07-02T10:46:36.000Z","msg":"冇人急救On9<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-03T00:53:23.000Z","msg":"驚屈錢 不了"},"citedBy":0,"replyTime":"2018-07-03T02:22:53.000Z","msg":"贏國邏輯：你急救救唔返＝你殺人<img src=\"/assets/faces/fifa/red.gif\" class=\"hkgmoji\" /> <br />\n不過報個驚都得掛<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"187f0dc363c3e5d1880e1d75a818acf0dde3f405","tid":726300,"uid":2521,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-07-03T02:42:54.000Z","msg":"沒事兒沒事兒<br />\n大伙繼續吃<