SIZE}\" />"},"citedBy":0,"replyTime":"2019-07-24T05:47:00.000Z","msg":"推"},{"pid":"5d868784372e9592d696214eeb960ce7e84b6462","tid":1359234,"uid":190505,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:47:32.000Z","msg":"727 光復元朗，重新聚焦五大訴求<br />\n<a href=\"https://lih.kg/1359166\" data-auto-link target=\"_blank\">https://lih.kg/1359166</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"b6859a9afcf61573664543f01ae9787aec366889","tid":1359234,"uid":285330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:48:28.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1cad592aed02dfe4f5a53623b8760eddc59d296a","tid":1359234,"uid":208429,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:48:33.000Z","msg":"<img src=\"https://na.cx/i/dWjV7iP.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FdWjV7iP.png&h=b40c43ab&s={SIZE}\" />"},{"pid":"5666db7eff4c4da4a536a84c43932a274af30cef","tid":1359234,"uid":173058,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-24T05:48:34.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: large;\">[重要] 聽日癱瘓港鐵同時要做好文宣工作!!</span></span><br />\n<span style=\"color: gold;\">我地唔能夠成日以連登睇嘢角度做事</span>，出面返工個堆係有大量港豬依然唔知元朗咩事，點解我地要癱瘓。<br />\n<br />\n我地唔可以又比人覺得係反送中示威者搞屎棍，要清楚同在場乘客表明721港鐵失職，屢次漠視乘客安危，長開車門及沒有危機應變，任由黑社會衝入港鐵站內對乘客進行無差別肆施虐。<span style=\"color: red;\">事隔兩日，港鐵依然擺出高姿態不作出回應，我地先會進行不合作運動。</span><br />\n<br />\n<span style=\"color: red;\">主題係港鐵一日唔回應唔改革，大眾就會一直堅持不合作運動，矛頭要清晰指向港鐵！</span><br />\n<br />\n實際做法：<br />\n一，提早傳開呢件事等人知道嚟緊會繼續進行港鐵不合作運動<br />\n一，攞大聲公向在場乘客宣傳(假如狗鐵附例唔比用，大家諗諗可以點)<br />\n二，print定大量721元朗傷者圖派比乘客<br />\n三，舉牌（傷者圖+指控港鐵失職導致大量乘客受傷）<br />\n四，大力講721女車長罔顧乘客安危，強行要求乘客落車（要比港鐵職員知，佢地錯判形勢係有後果，殺雞敬候，令內部職員向港鐵施加壓力）"},{"pid":"95a9ac8eade648b90bd436ac2758f850cf265065","tid":1359234,"uid":39752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:48:46.000Z","msg":"你哋搞嘅港鐵不合作運動根本錯撚晒<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1359219\" data-auto-link target=\"_blank\">https://lih.kg/1359219</a>"},{"pid":"5c471c4b45e717371bb7ebe8b4f0d004185f7b16","tid":1359234,"uid":77761,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2019-07-24T05:50:30.000Z","msg":"阻車門阻果一陣根本迫唔到港鐵回應，不如考慮下全民免費搭車，藍絲有著數都會支持埋，少左車票收入港鐵都要迫住回應"},{"pid":"5e01810a7e2801dfe6467271568f73c86333ea5d","tid":1359234,"uid":8738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:53:40.000Z","msg":"推爆佢"},{"pid":"56c1b6db68ef37b6943d41dce390580dfb79864d","tid":1359234,"uid":203499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:55:03.000Z","msg":"推"},{"pid":"dfb71bd363c4acd4add63e4575906dcaa3cbcd4b","tid":1359234,"uid":143079,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:55:36.000Z","msg":"推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"af617e9533760dbd9934a5a300377605f2a81d3f","tid":1359234,"uid":102356,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T05:58:50.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"9a36ae76521c4b7bdd364748bb380aa0234dbf3d","tid":1359234,"uid":281533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:02:34.000Z","msg":"Pish"},{"pid":"3b1191e5d0dcb68b435e2a3822a0643825858e70","tid":1359234,"uid":285330,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-24T06:02:44.000Z","msg":"目的係全港大罷工<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"9265be577e9b15d9e0162de3a7b7d4dbd3e96e4e","tid":1359234,"uid":90306,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:04:13.000Z","msg":"gooooooooooo"},{"pid":"3e0231a42a084c70ff10d9a5d9d46d9f15fc5eba","tid":1359234,"uid":94972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:04:39.000Z","msg":"Pish"},{"pid":"7c1c0531e944222e183bb9f812675ac58d05c107","tid":1359234,"uid":142803,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:07:29.000Z","msg":"push"},{"pid":"c6eff54156f9a1e99f7ba67bac4cc577d321c126","tid":1359234,"uid":231102,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:10:48.000Z","msg":"2019.07.21【元朗恐襲事件】西鐵車長迫人元朗落車送死<br />\n<a href=\"https://youtu.be/iHrpr2HdSAU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FiHrpr2HdSAU&d=WWcUXgYU4baXfieBSZbTey%2B7EDXmwg1SXj7S5MqlT1o%3D&h=6d160690\" data-auto-link target=\"_blank\">https://youtu.be/iHrpr2HdSAU</a><br />\n<img src=\"https://na.cx/i/Uc7D5c7.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUc7D5c7.png&h=5aaeb439&s={SIZE}\" />"},{"pid":"00e859fbe866d9eb76cccbeced2fa8f3f6bac6de","tid":1359234,"uid":117076,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:13:18.000Z","msg":"推"},{"pid":"6c629653007a0f894480f5e9fdf09929a80434d6","tid":1359234,"uid":263660,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:40:01.000Z","msg":"PUSH"},{"pid":"52d3cc56037dc25b418f72066a57e9a1a0e12cf6","tid":1359234,"uid":93908,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:40:45.000Z","msg":"重申我地5大訴求：<br />\n1. 徹底撤回送中條例<br />\n2. 收回612暴動定義<br />\n3. 撒銷所有義士既控罪<br />\n4. 成立獨立調查委員會（調查警隊濫權以及721事件）<br />\n5. 以行政命令解散立法會，並實行雙普選（治本）"},{"pid":"06c3cc36a0861b974715292ccf2a5792b1ba37f2","tid":1359234,"uid":254594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:42:00.000Z","msg":"政府拒絕回應五大訴求 加上元朗恐襲 足證港共已經無法保護市民<br />\n恐襲陰霾令好多人開始連和平遊行都唔敢出<br />\n香港人連遊行自由、免於恐懼既自由都無埋<br />\n現在自發不合作運動 希望透過和平手法逼政府回應<br />\n避免每星期遊行流血衝突收場<br />\n<br />\n不合作運動係透過合法增加政府管治成本、商界營運成本<br />\n從而令佢地對政府施壓<br />\n<br />\n每一次不合作其實都只係阻左大家一陣<br />\n相比港鐵一次延誤實在係小巫見大巫<br />\n雖然有好多人會受牽連<br />\n但市民都會明白 如果黑社會問題不被正視，遺禍更大<br />\n<br />\n我地和理非無辦法同黑社會正面衝突，只有透過非常手段去逼政府 逼警察正常執法<br />\n只要政治問題解決 不合作運動自然無以為繼<br />\n黑社會威脅大定失業威脅大 我諗大眾市民會識得判斷<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: xx-large;\"><strong>最後想講 7/25 7:30 九龍塘 <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<a href=\"http://t.me/mtr723\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ft.me%2Fmtr723&d=WWcUXgYU4baXfieBSZbTey%2B7EDXmwg1SXj7S5MqlT1o%3D&h=c07046af\" data-auto-link target=\"_blank\">http://t.me/mtr723</a></strong></span><br />\n<img src=\"https://na.cx/i/cdQeDqE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcdQeDqE.jpg&h=fce13e3e&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/Jv1p0D0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJv1p0D0.jpg&h=c3cf913d&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/LWY7YqF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLWY7YqF.jpg&h=a7a36c51&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/pSQm2Sm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpSQm2Sm.jpg&h=5b380ba2&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/VJ2TS2R.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVJ2TS2R.png&h=05aaecf9&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/DyzbD2D.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDyzbD2D.png&h=b1d377b5&s={SIZE}\" /><br />\n<span style=\"font-size: xx-large;\"><strong><a href=\"http://t.me/mtr723\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ft.me%2Fmtr723&d=WWcUXgYU4baXfieBSZbTey%2B7EDXmwg1SXj7S5MqlT1o%3D&h=c07046af\" data-auto-link target=\"_blank\">http://t.me/mtr723</a></strong></span>"},{"pid":"acf3d4b584a534fe87fadc46b011f57b2e2e7401","tid":1359234,"uid":18245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-24T06:42:20.000Z","msg":"<div style=\"text-align: center;\"><code>（瞄準政權）上環黑警36槍企圖殺害抗爭者 中共策劃元朗恐襲</code></div><br />\n<br />\n<br />\n<div style=\"text-align: center;\">所有嘢都係中共係背後策劃<br />\n如果呢個政權係仆街係十惡不赦<br />\n咁擁護佢嘅黑警 黑社會都一樣咁仆街<br />\n咁十惡不赦 但唔好浪費咁多時間係呢<br />\n班卒仔到 <br />\n主力打大佬 瞄準返中共 唔好out focus唔係就真係對唔住咁多位被呢個政權殺害嘅戰友</div><br />\n<br />\n<span style=\"font-size: xx-large;\"><div style=\"text-align: center;\">義士宣言：不排除成立臨時立法會</div></span><br />\n<span style=\"font-size: small;\"><a href=\"https://lih.kg/1350879\" data-auto-link target=\"_blank\">https://lih.kg/1350879</a><br />\n- 分享自 LIHKG 討論區</span><br />\n<br />\n<span style=\"font-size: xx-large;\"><div style=\"text-align: center;\">[長文] 時代周刊直指港府失去管治香港能力嘅分析</div></span><br />\n<span style=\"font-size: small;\"><a href=\"https://lih.kg/1356861\" data-auto-link target=\"_blank\">https://lih.kg/1356861</a><br />\n- 分享自 LIHKG 討論區</span><br />\n<br />\n<br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\"><strong>支持前線所有決定</strong></span></div><br />\n<br />\n民情，輿論，選票，呢啲唔洗我哋去諗，點去收拾所謂嘅殘局，就交比啲政治人物去煩啦<br />\n<br />\n<br />\n<div style=\"text-align: center;\"><strong><span style=\"font-size: xx-large;\">我哋要做嘅係我哋認為啱嘅事</span></strong></div><br />\n<br />\n<img src=\"https://na.cx/i/4LYjFvR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4LYjFvR.jpg&h=d444c005&s={SIZE}\" /><br />\n<br />\n<code>「人民不應該害怕他們的政府，政府應該害怕它的人民。」（People should not be afraid of their governments. Governments should be afraid of their people.）</code><br />\n<div style=\"text-align: center;\"><br />\n<pre><code data-type=\"\">五大訴求，勿忘初衷\n遍地開花，不撤不散\n打倒軍權，反對國家恐怖主義\n光復香港，時代革命</code></pre><br />\n<pre><code data-type=\"\">&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash; 八大訴求 &mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;\n一、徹底撤回修例\n二、收回暴動定義\n三、撤銷對今為所有反送中抗爭者控罪\n四、徹底追究警隊濫權情況\n五、以行政命令解散立法會，立即實行雙真普選\n六、要求永不落實「社會信用評分系統」\n七、要求移除全港「多功能智慧燈柱」\n八、追究元朗鄉黑暴徒及警察失蹤</code></pre></div><br />\n<br />\n定性721黑警上環血腥鎮壓，元朗黑社會恐怖襲擊，警黑合作散播中國國家恐怖主義:<br />\n<div style=\"text-align: center;\"><br />\n<strong><span style=\"font-size: xx-large;\">警察戰線:</span></strong></div><br />\n<img src=\"https://na.cx/i/7gq6kYx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7gq6kYx.jpg&h=1f5648e1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/hY7P3bT.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhY7P3bT.jpg&h=5c1777d4&s={SIZE}\" /><br />\n警察冇預警下開槍射36發橡膠彈，有人爆頭，警察已無視通例，已失去合法性<br />\n警察放任黑社會打市民，完全冇制止，並假指無發現武器收隊，傳媒發現雙方實有公開溝通<br />\n警察公然無視電話求助，元朗警署落閘，違反警隊職責<br />\n<div style=\"text-align: center;\"><br />\n<span style=\"font-size: xx-large;\">黑社會戰線:</span></div><br />\n<img src=\"https://na.cx/i/d7DWJcw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fd7DWJcw.jpg&h=92c6a934&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/idEKR5S.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FidEKR5S.jpg&h=e6380dff&s={SIZE}\" /><br />\n拉攏任何政治冷感市民，有錢人，元朗問題非個別事件，收錢恐襲任何區都會發生，任何人都有機會中招<br />\n俾藍絲睇到佢地支持何君堯即係支持黑社會打人斬人，令藍絲同何君堯反面<br />\n<br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\">國際戰線:</span></div><br />\n<br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\">攬炒巴團隊</span></div><br />\n<img src=\"https://media.giphy.com/media/RhkvtuUcntXSuoVzay/giphy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2FRhkvtuUcntXSuoVzay%2Fgiphy.gif&h=254e8117&s={SIZE}\" /><br />\nLink:<br />\nFacebook:<br />\n<a href=\"https://www.facebook.com/standwithhk/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fstandwithhk%2F&d=WWcUXgYU4baXfieBSZbTey%2B7EDXmwg1SXj7S5MqlT1o%3D&h=ef00b2d4\" target=\"_blank\">https://www.facebook.com/standwithhk/</a><br />\n<br />\nTwitter:<br />\n<a href=\"https://twitter.com/Stand_with_HK\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2FStand_with_HK&d=WWcUXgYU4baXfieBSZbTey%2B7EDXmwg1SXj7S5MqlT1o%3D&h=7f49366b\" target=\"_blank\">https://twitter.com/Stand_with_HK</a><br />\n<br />\nInstagram:<br />\n<a href=\"https://www.instagram.com/standwithhk_/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fstandwithhk_%2F&d=WWcUXgYU4baXfieBSZbTey%2B7EDXmwg1SXj7S5MqlT1o%3D&h=5c7c0042\" target=\"_blank\">https://www.instagram.com/standwithhk_/</a><br />\n<br />\nYouTube:<br />\n<a href=\"https://www.youtube.com/channel/UCyi42Y5o1ksO_yFItyHW7Jw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fchannel%2FUCyi42Y5o1ksO_yFItyHW7Jw&d=WWcUXgYU4baXfieBSZbTey%2B7EDXmwg1SXj7S5MqlT1o%3D&h=89ca3ced\" target=\"_blank\">https://www.youtube.com/channel/UCyi42Y5o1ksO_yFItyHW7Jw</a>[/quote]<br />\n<br />\n<blockquote><br />\n[我都要攬炒][時事台]一齊上twitter將黑警濫權揚威國際，警告遊客不要來港旅遊！！！<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1325723\" data-auto-link target=\"_blank\">https://lih.kg/1325723</a><br />\n</blockquote><br />\n<br />\n向外國抗議中國政府散播國家恐怖主義<br />\n向外媒及各國投訴香港警察包庇黑社會合作各自無差別打人，違反通例無預警開槍，已失去合法性<br />\n港鐵作為國際地鐵聯盟之一公然妄顧市民安危強逼市民離開車廂被打<br />\n黑社會涉嫌在元朗發動恐襲襲擊，主腦直指中共政府<br />\n<br />\n<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\">自發治安戰線:</span></div><br />\n<img src=\"https://na.cx/i/sf52DMn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fsf52DMn.jpg&h=ecc7650f&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/OejSgx3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOejSgx3.jpg&h=01748b84&s={SIZE}\" /><br />\n<br />\n<blockquote><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<img src=\"https://na.cx/i/uYfY5nD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuYfY5nD.jpg&h=c65da17d&s={SIZE}\" /><br />\n<br />\n<blockquote><strong><span style=\"font-size: large;\">香港防衛隊  正式成立<br />\n<a href=\"https://lih.kg/1342844\" data-auto-link target=\"_blank\">https://lih.kg/1342844</a><br />\n<br />\n【HKSDF】香港自衛隊<br />\n<a href=\"https://lih.kg/1352390\" data-auto-link target=\"_blank\">https://lih.kg/1352390</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n[請長期置頂] 民間保衛隊初形 公民團結行公義 任何抗命運動適用<br />\n<a href=\"https://lih.kg/1351343\" data-auto-link target=\"_blank\">https://lih.kg/1351343</a><br />\n<br />\n<br />\n【元朗恐襲】真心，如果眾籌，成立「香港自衛隊保安公司」優先過登報<br />\n<a href=\"https://lih.kg/1346745\" data-auto-link target=\"_blank\">https://lih.kg/1346745</a><br />\n</span></strong></blockquote><br />\n<br />\n<div style=\"text-align: center;\"><br />\n<span style=\"font-size: xx-large;\">思想革命戰線:</span></div><br />\n<br />\n平民遊戲工作室出條政治片十分值得思考<br />\n<a href=\"https://lih.kg/1357566\" data-auto-link target=\"_blank\">https://lih.kg/1357566</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n劉細良 香港內戰<br />\n<a href=\"https://youtu.be/QbJTdHbdGIU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FQbJTdHbdGIU&d=WWcUXgYU4baXfieBSZbTey%2B7EDXmwg1SXj7S5MqlT1o%3D&h=2ddd1b6c\" data-auto-link target=\"_blank\">https://youtu.be/QbJTdHbdGIU</a><br />\n<br />\n梁天琦 本土自治勇武抗爭嘅理由<br />\n<a href=\"https://youtu.be/36olyar0wHE\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F36olyar0wHE&d=WWcUXgYU4baXfieBSZbTey%2B7EDXmwg1SXj7S5MqlT1o%3D&h=c9e07cfa\" data-auto-link target=\"_blank\">https://youtu.be/36olyar0wHE</a><br />\n<br />\n梁天琦 革命<br />\n<a href=\"https://youtu.be/VEUhAVki0DA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FVEUhAVki0DA&d=WWcUXgYU4baXfieBSZbTey%2B7EDXmwg1SXj7S5MqlT1o%3D&h=23e307be\" data-auto-link target=\"_blank\">https://youtu.be/VEUhAVki0DA</a><br />\n<br />\n<br />\n<div style=\"text-align: center;\"><br />\n<span style=\"font-size: xx-large;\">港鐵戰線:</span></div><br />\n<img src=\"https://na.cx/i/F4hpgc9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FF4hpgc9.jpg&h=372e2d1d&s={SIZE}\" /><br />\n<br />\n全面係所有車站招貼: 元朗站逼市民落車被打，妄顧安危<br />\n一定要令每個站每個角