b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F07%2F192704_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=be756aaa&s={SIZE}\" /><br />\n連登都看不到屎 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"144f17b812b731aff41b71ea4db5a96c6572fba9","tid":490590,"uid":159333,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T11:31:06.000Z","msg":"要食大量奇異種籽同西柚加火龍果先去到<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"933150e603c5201f92a6252b1b9a65d246c6add2","tid":490590,"uid":44916,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T11:32:34.000Z","msg":"日日返公司一定痾返個屎，可能兩次<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"3e8e9295185a491f79219a732126ebb2c5e54924","tid":490590,"uid":9136,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T11:38:45.000Z","msg":"一日兩次 時間都差唔多"},{"pid":"19c13e4274aee8909bd9d68554c23f5be0155a96","tid":490590,"uid":42759,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T11:44:01.000Z","msg":"一日至少兩次<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n講起又急屎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6be9d9eeb7ed5f8e5ed7980561539a8266c3ad6f","tid":490590,"uid":63154,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-12-07T11:50:12.000Z","msg":"其實好多人個煩惱係反而太易柯屎，腸胃比較敏感，對食物挑剔，出街食啲嘢一少少唔乾淨就要搵厠所<br />\n<br />\n食麥皮又係好易柯爛屎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n小弟就係呢種"},{"pid":"1eae1abd963e1fbd4a38f15aad3239e7a6c4ca65","tid":490590,"uid":33095,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T12:28:36.000Z","msg":"下世食多d菜"},{"pid":"74edd3bc8a59fb41633a930df722b50f0fa9352c","tid":490590,"uid":21262,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T12:30:53.000Z","msg":"今日全日零生產力睇戲+訓晏覺都痾撚左兩次大大篤<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> <br />\n日日都有屎痾 一日一次基本 平時好中意食菜同乳酪 得閒就切橙食 腸胃健康都仆街<img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" />"},{"pid":"22c5a35bd2aab750833a139c106827216f7bcfc2","tid":490590,"uid":75100,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-12-07T12:55:10.000Z","msg":"如果無肚漲，胃口各方面無事，2-4日柯一次其實無問題<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n有人180cm, 有人160cm，唔通160cm就係傷殘咩，你成日入廁所硬谷，硬逼自己1日去1次，反而唔好<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"8b80274fbdf56a6079836156dc51bf8c4b72c257","tid":490590,"uid":99144,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:03:21.000Z","msg":"由細到大都係三四日先屙一次，細個睇醫生試過比醫生問身體有冇咩唔正常<br />\n我答日日都有屎屙好唔正常<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />  <br />\n到依家都覺得自己係因為腸長先幾日屙一次"},{"pid":"6be4c51de7e5609e2c23c89aee27226e9d92204a","tid":490590,"uid":90000,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-12-07T13:05:12.000Z","msg":"細個試過甲型肝炎又痾又嘔，入醫院打完止瀉針之後住左成個星期醫院都冇屎痾。<br />\n出院番到屋企痾第一次痾屎，痾左半個鐘先痾出黎，好記得舊屎係四方形"},{"pid":"3c8a530b8fb37f7b6dbb922099bf445a7be86614","tid":490590,"uid":20820,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:06:14.000Z","msg":"以前係，最近食多左菜，日日準時返工柯屎<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"052253f06ecf79ded559d0f9453c53c73f783124","tid":490590,"uid":6058,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:06:48.000Z","msg":"最健康嘅人係一日兩次"},{"pid":"440c2b24de5af3167395efc23bb37a4d3f260a31","tid":490590,"uid":72608,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:10:01.000Z","msg":"<blockquote>其實好多人個煩惱係反而太易柯屎，腸胃比較敏感，對食物挑剔，出街食啲嘢一少少唔乾淨就要搵厠所<br />\n<br />\n食麥皮又係好易柯爛屎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n小弟就係呢種</blockquote><br />\n<br />\n真正既健康係每日1~2次痾屎<br />\n<br />\n同埋D屎要健康屎"},{"pid":"a2eb6f804a03422b3863e1469dcee8da9f92c2bd","tid":490590,"uid":71257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:14:26.000Z","msg":"得罪講句<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n樓主應該好重口氣<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"a1af44d4cc0d5875ced4a4ece7dd1d39f6eb1811","tid":490590,"uid":138375,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:15:50.000Z","msg":"耐唔屙人會好易攰<br />\n一日一屙啦最好就"},{"pid":"244c438abe86ad8d8caedd69470654055f57f87a","tid":490590,"uid":63154,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:23:11.000Z","msg":"<blockquote><blockquote>講開又講，有冇人做過腸鏡檢查？</blockquote><br />\n做過</blockquote><br />\n<br />\n<br />\n其實辛唔辛苦？"},{"pid":"8ceeb893a4ff3ba51d7db541efd03b76238b6f16","tid":490590,"uid":94842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:24:10.000Z","msg":"痾得少可能肚有蟲"},{"pid":"5f401b065e6c74bd12809462ddd22df41e24ebde","tid":490590,"uid":13283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:36:50.000Z","msg":"<blockquote>日日返公司一定痾返個屎，可能兩次<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /></blockquote><br />\n返公司痾一次，臨收工痾一次，返到屋企痾一次，沖涼前痾多次<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> 抆屎都抆到屎眼出血"},{"pid":"8a0f20e8c5a6b0de9eae036671b3bf21a2f1dedc","tid":490590,"uid":9732,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:46:45.000Z","msg":"我成日都急屎<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"bec9babe5735768a0fc00e0735e351a286d3d23d","tid":490590,"uid":23897,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:47:24.000Z","msg":"去到商場特別想痾屎<br />\n唔知係咪因為冷氣凍"},{"pid":"4427aa91032901d279e8db9e9d28112ad90aba59","tid":490590,"uid":65813,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-12-07T13:48:21.000Z","msg":"我都係<br />\n可以一個禮拜都唔屙....<br />\n但真係唔急..."},{"pid":"190699fb910eb9f9b359615fb919ee439a1f2459","tid":490590,"uid":21331,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:48:36.000Z","msg":"一日兩次<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n唔食加工食品同食多啲菜同生果"},{"pid":"eef86b055634ff6c655cd43714e0939167ac85ab","tid":490590,"uid":104725,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:49:04.000Z","msg":"一日一次"},{"pid":"abb682c641c93a055f5c022ac23a80d7a9303abe","tid":490590,"uid":274,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:52:02.000Z","msg":"至少一日兩次<br />\n朝早食完麥皮 夜晚沖涼都有"},{"pid":"f85333989a2afb7b5f4b6c1e5294f6a109d391c0","tid":490590,"uid":58165,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:52:16.000Z","msg":"急屎先屙"},{"pid":"028bd63928f4cfe61f19dd2a478eb548e45fe23d","tid":490590,"uid":27190,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T13:58:06.000Z","msg":"有冇人去旅行會減少個密度"},{"pid":"5cfde9fce6a39552d9558faf40250e1acaf1d029","tid":490590,"uid":121450,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T14:05:52.000Z","msg":"一日一次<br />\n否則肚谷谷咁<br />\n用開甘油pump幫手<br />\n加埋食日本d健康藥品，軟便的乳酸菌，軟到便便會易痾好多<br />\n仲有要飲多d水"},{"pid":"1da3ebc8b9e7ebd7a9280a2ede30b022caf42bd5","tid":490590,"uid":3189,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T14:07:55.000Z","msg":"我每日一枝益力多<br />\n日日有得屙<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b2742ad0482bca04158435cf95c1bf982a7a88fa","tid":490590,"uid":143747,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-12-07T14:09:27.000Z","msg":"輕則3日 重則 7天<br />\n日日飲益力多<br />\n但都冇乜屎要屙<br />\n<br />\n屙出黎個下好撚臭"},{"pid":"967b30b79e2c949517ac51ea82809e023f043311","tid":490590,"uid":10623,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-12-07T14:22:09.000Z","msg":"通常2-3日先有得屙 試過成個禮拜都無<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"053da248204e5cd6a4bd51a0aeb44f5c960ba472","tid":490590,"uid":69354,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T14:40:33.000Z","msg":"我都係"},{"pid":"50ecc2c8286887d90e41763610bfaa9d40fbf826","tid":490590,"uid":85819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T14:50:18.000Z","msg":"此回覆已被刪除"},{"pid":"45cc751f574208d9de0ef9dc1c3cd22018575f2c","tid":490590,"uid":14103,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T14:51:02.000Z","msg":"日日都一個月一次"},{"pid":"581156cd490627319b4b1828d584c9f73e596d82","tid":490590,"uid":25641,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T15:02:12.000Z","msg":"此回覆已被刪除"},{"pid":"8d0518d8c04ff6410b77596f33a541325d9e07a4","tid":490590,"uid":2719,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-12-07T15:06:42.000Z","msg":"有無人每日早上返工車程都會急屎<br />\n我10日有9日都係咁<br />\n有無得調整柯屎時間 日日返緊公司急屎好難受<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0482e0d7c74b6ee1d91466194ffc7a151e3d80ce","tid":490590,"uid":55198,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T15:13:59.000Z","msg":"食多D菜啦"},{"pid":"8728c1c771be62f87a5b748722b870d4ab64d8bb","tid":490590,"uid":90128,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T15:22:32.000Z","msg":"<blockquote><blockquote><blockquote>由細到大都未試過有一日係冇屎屙<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n我都係<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n唔明點做到兩日一次 d野食去左邊</blockquote><br />\n我都唔明身體出現咩問題<br />\n<br />\n我平均最多2日一次，最長試過4日<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n強行坐係廁所都無用，成日食乳酪<br />\n<br />\n我飲食都係偏多菜少肉</blockquote><br />\n我都係咁 食生果食菜食得多過肉<br />\n水又一日1.5L<br />\n唔知邊到出錯<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"f2e988801993101a0eb7289436e1cc3859e0f560","tid":490590,"uid":105888,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-12-07T15:24:27.000Z","msg":"記得唔知邊度講過一日三次最健康<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"56c796abff1622e9cd32d031e341b9447e46487c","tid":490590,"uid":15730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T15:36:35.000Z","msg":"<blockquote>我 明明餐餐食菜 冇/少肉</blockquote><br />\n食菜唔會屙到屎 食生果啦<br />\n日日食一個橙包有得屙"},{"pid":"d55efe0f0bd86f6e6bf08364ee2471d6ed98fa3b","tid":490590,"uid":15730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T15:39:09.000Z","msg":"<blockquote>去到商場特別想痾屎<br />\n唔知係咪因為冷氣凍</blockquote><br />\n我行埋惠康啲凍櫃度又係咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0fe0a6be074979912d2f34cb7783d018729a7d94","tid":490590,"uid":74002,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2017-12-07T16:11:26.000Z","msg":"返工啦 包你一至五都有屎屙"},{"pid":"1f17d4a8b513440279d1e48a68bff070cba394d6","tid":490590,"uid":24160,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-12-07T17:44:12.000Z","msg":"<blockquote>我每日一次，你每日堅持有菜或生果落肚就好好多，毒素積太耐唔清有健康隱憂</blockquote><br />\n菜同生果都要<br />\n普遍生果嘅纖維都多過菜<br />\n不過要上網查下食咩種類嘅菜同生果先多纖維<br />\n最多嘅蔬菜係蓮藕同西蘭花<br />\n生果呢就番石榴, 牛油果, 熱情果<br />\n成年人每日最要攝取25g 膳食纖維<br />\n另外就係要多飲水<br />\n因為纖維會吸水"},{"pid":"385bcf54c3fc3e2dcd67f231c4e34782e638a318","tid":490590,"uid":24160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T17:44:26.000Z","msg":"所以要多飲水"},{"pid":"809ae3ddabeda94f97d51a8e75859d3417e12fdf","tid":490590,"uid":24160,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-12-07T17:46:24.000Z","msg":"<blockquote><blockquote>我 明明餐餐食菜 冇/少肉</blockquote><br />\n食菜唔會屙到屎 食生果啦<br />\n日日食一個橙包有得屙</blockquote><br />\n橙<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n橙嘅纖維好少<br />\n每100克先2.4克<br />\n每日都夠25克先足夠<br />\n<br />\n唔係要有冇食咁簡單<br />\n係啲屎要夠靚<br />\n先唔會難抆"},{"pid":"a34ce746ddc77b92f1d571a0721d032116f32432","tid":490590,"uid":133977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T17:51:55.000Z","msg":"我唔急都去係冇野屙到<br />\n我自己都想一日一次<img src=\"/assets/faces/lomoji/19.png\" class=\"hkgmoji\" />"},{"pid":"93d386bc2094d5f53ce157f29fa8a759093a55f5","tid":490590,"uid":37413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T17:54:35.000Z","msg":"你個口應該惡臭"},{"pid":"3794c91d32091d5b5a6122c5ed2c50f21b2e7ac2","tid":490590,"uid":37413,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-07T18:04:08.000Z","msg":"我每日最少一次有時兩次，習慣咗每晚返到屋企就會去，好多年都係咁<br />\n已經好多年未試過肚痛了"}]}