b1f93b","tid":1487483,"uid":37897,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T10:24:11.000Z","msg":"正經post推 打擊香引以為傲既經濟體系先最入肉"},{"pid":"6f92d2c2141bd8ac47692497b76ef2e576ebab05","tid":1487483,"uid":262674,"like":0,"dislike":0,"score":0,"quote":{"pid":"ba0394eafed68c117ec0d9de7094d6aa9cf8d0fc","tid":1487483,"uid":128117,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-19T09:58:14.000Z","msg":"19號隔夜又跌返落1.02 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-19T11:05:37.000Z","msg":"咁快 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e4cf0e30fba7e1d7381464ad5193aae413a026a2","tid":1487483,"uid":264806,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c4d8b8036c055a79eaf2cd8124656cb0fd8e1d5","tid":1487483,"uid":34334,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-19T09:44:22.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-08-20T14:06:47.000Z","msg":"就正如出黎遊行，都係要人多至有效。<br />\n但如果個個諗住，我一個人小小出黎行無乜影響，咁結果個遊行就係因為人少而無乜影響。"}]}