914,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-18T14:42:00.000Z","msg":"721見"},{"pid":"949b07568ddd4f76add321194ffc9226f2c8a8a8","tid":1326603,"uid":158235,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-18T14:45:23.000Z","msg":"721 見"},{"pid":"44bb68ce7dcad4b8ff9dd1a1b8521fa5dec587bd","tid":1326603,"uid":102378,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-18T14:45:35.000Z","msg":"721主線任務<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n唔理衝唔衝 一齊去金鐘<img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /><br />\n兄弟各自趴山 <img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><br />\n不分化<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />不篤灰<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />不割蓆<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /><br />\n我冇野講<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><br />\n<br />\n1。推行真雙普選<br />\n2。成立獨立調查委員會<br />\n3。停止搜捕示威者<br />\n4。白紙黑字除消612暴動定義<br />\n5。撤回送中條例"},{"pid":"353acd5fd247f0470665a7f983b5329059640a9e","tid":1326603,"uid":74598,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-18T14:50:04.000Z","msg":"十八真係好好聽好應景<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"35e8e6b9b7894f59d6fbf6dd3f445ba289154a06","tid":1326603,"uid":256914,"like":0,"dislike":0,"score":0,"quote":{"pid":"353acd5fd247f0470665a7f983b5329059640a9e","tid":1326603,"uid":74598,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-18T14:50:04.000Z","msg":"十八真係好好聽好應景<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-18T15:41:02.000Z","msg":"好掛住天琦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"8c3b28d635533ce696b241165824b9e764cc6906","tid":1326603,"uid":280547,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-18T15:53:30.000Z","msg":"Push"},{"pid":"290a8f4ff899c86b10af993dc139ae1e93885325","tid":