%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F15%2F190420_90a500b496ceba09e3e63741f604e44f.png&h=db232621&s={SIZE}\" />"},{"pid":"50d826d330a5610708ca5f1a614db85de3ec160b","tid":593694,"uid":140831,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-15T11:07:39.000Z","msg":"仲記得美國有單係排緊隊買gta個時有條友攞支槍出黎開"},{"pid":"47306c01fd2b83fc681c4fd1d21bc2e71e02f408","tid":593694,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-15T11:09:22.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"3dd6aa488f12ee98375061b3be8a51219a12f4cb","tid":593694,"uid":166528,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-15T15:41:14.000Z","msg":"其實個研究既 argument都有d問題<br />\n<br />\n「因為有暴力行為既人玩暴力遊戲既比例比正常人玩暴力遊戲既比例低，所以玩暴力遊戲唔會令人有暴力行為。」<br />\n<br />\n假設<br />\nX=有暴力行為既人<br />\nY=正常人<br />\nZ=玩暴力遊戲既人<br />\n<br />\n如果X既總人數係1000，而X入面Z既比例係20%，姐係200人;<br />\n而Y既總人數係100，而Y入面Z既比例係70%，姐係70人。<br />\n<br />\n咁Z入面X同Y既比例就會係200：70，姐係74%：26%<br />\n<br />\n由此可以得出個結論「係Z既人有74%機會係X」，亦即係「玩暴力遊戲既人有74%機會係有暴力行為既人」<br />\n<br />\n咁睇就好難可以再推論出「玩暴力遊戲唔會令人有暴力行為。」<br />\n<br />\n當然，現實中Y既人數係比X既人數多好多(好似係)，加上文中既數據，確實可以推斷出「玩暴力遊戲既人有較大機會係有暴力行為既人」。但如果係咁點解一開始唔研究玩暴力遊戲既人入面正常人同有暴力行為既人既比例？唔係會更直接？而且「玩暴力遊戲既人有較大機會係有暴力行為既人」係咪就可以證實「玩暴力遊戲會令人有暴力行為」呢？又似乎爭d"},{"pid":"e4662f2182641dfc95382dd570383ecc768a2d40","tid":593694,"uid":2507,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-15T15:44:12.000Z","msg":"掛住打機邊有時間計劃殺人<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}