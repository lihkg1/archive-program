r />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n雖然最後佢打到我仆街, 牙都甩埋<br />\n但完全同腹肌冇關"},{"pid":"c3d1b379f41561cc5b7c337496a2bb5d8d124182","tid":726484,"uid":129660,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-07-02T13:13:28.000Z","msg":"個咀仔好得意<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},{"pid":"41720f804340d41c48ca096dfe570f86fb331088","tid":726484,"uid":16676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-02T14:50:06.000Z","msg":"好似黎明咁憂鬱既眼袋<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"94f2577a14998c02e702dcc9f9e1628b532094d4","tid":726484,"uid":84282,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-05T06:15:53.000Z","msg":"此回覆已被刪除"},{"pid":"51c7a10b7499a26841c96b4365fffd3f49228712","tid":726484,"uid":70972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-05T07:15:25.000Z","msg":"此回覆已被刪除"},{"pid":"272bb7b216ef416bf34358cb539683ca0b5e44af","tid":726484,"uid":35301,"like":1,"dislike":0,"score":1,"quote":{"pid":"153199da2d19a4046333987a77ac2e17efc2ce02","tid":726484,"uid":49664,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-02T12:49:05.000Z","msg":"有冇ig"},"citedBy":0,"replyTime":"2018-07-10T17:45:37.000Z","msg":"黃景"},{"pid":"e563290d6d871005e8c3f246b5e35673005cafbb","tid":726484,"uid":128741,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-11T04:34:36.000Z","msg":"做GYM9成基<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8c07646ec8116396862892c9ca09cac970f69c4b","tid":726484,"uid":65530,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-11T06:07:20.000Z","msg":"此回覆已被刪除"},{"pid":"f3d25ca23be7d4ae4c6e8cf3ef0ba88a6cf34515","tid":726484,"uid":56610,"like":5,"dislike":4,"score":1,"citedBy":0,"replyTime