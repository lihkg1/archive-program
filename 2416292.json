4f737c40c0af9b3309764edb6737f0eb513","tid":2416292,"uid":156321,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2021-02-22T00:32:08.000Z","msg":"咪話仲有-6場，做乜野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-22T03:51:34.000Z","msg":"Ching識波<img src=\"/assets/faces/lny/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"05a8d38adf7c95791ab92756bc903c39c172a288","tid":2416292,"uid":209773,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-22T04:20:11.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"2bb7e059aec883c3626ddbb59e296ff0ea8929bb","tid":2416292,"uid":67225,"like":0,"dislike":0,"score":0,"quote":{"pid":"301bd4f737c40c0af9b3309764edb6737f0eb513","tid":2416292,"uid":156321,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2021-02-22T00:32:08.000Z","msg":"咪話仲有-6場，做乜野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-22T04:46:22.000Z","msg":"佢地未學負數<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4061cdd4c25cd302dfd441398de087c1485877a1","tid":2416292,"uid":192409,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-22T12:40:19.000Z","msg":"<img src=\"/assets/faces/cow/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"75dd2b776d7d7a8f0402ddc51dc8fdf14cb56e39","tid":2416292,"uid":191926,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-22T12:45:27.000Z","msg":"係度買曼後上<br />\n<br />\n一年回報高過比特幣<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1c5a91dd25338136e19f96ed939bdaac6a0420c8","tid":2416292,"uid":192409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-05T03:32:16.000Z","msg":"仲有機會後上<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3452cf2395254cfb2ad2efe7a972718dee4b947b","tid":2416292,"uid":50385,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-03-05T04:21:33.000Z","msg":"個人覺得今屆係好有機會拿冠軍的一年~比去年更大機會~<br />\n簡單分析幾個主要對手~<br />\n曼聯~~今年走了lkk其實佢地實力削弱了好多~<br />\n先講後防~jones傷了~maguire開始老了同輕敵~後場開洌到現在失了好多波~<br />\n中前場無了Lkk的曼聯已經無以前咁大殺傷力~我吾信福狗同馬狗可以頂得著咁密賽程~<br />\n單單依賴一個般奴係吾足夠~個人認為綠木同卡雲尼幫助不大~<br />\n車仔~~今屆開始佢地係開得好好~但吾好忘記佢D對手係好平凡~<br />\n只有一仗對熱(次)叫做強D~另外就係佢D主將開始老了~<br />\n無記錯m朗~azp~基佬~t施華~等等都過了三十了~<br />\n可不可以頂住呢D賽程係一個大問題~<br />\n同個人覺得杜曹吾係一個咁有料的人~有幾多個好似魔佬咁勁~<br />\n阿仙奴~大年輕了的球員~個人覺得佢地穩定性比利記仲差~<br />\n曼城~~雖然佢地大把錢買人~但係都要磨合的~同埋哥狗都係一般般~暫時沒有冠軍相~<br />\n至於利物浦今年雖然走了lallana~但一支球隊吾會話走左一個人就會差成咁~<br />\n個人覺得Thiago攻擊力比lallana更好~(不喜物插)~有待時間証明~<br />\n今屆無可否認開季比以往差左~但我寧願開季差D~之後慢慢追上來~<br />\n無記錯~都已連勝了幾仗~今屆好明顯高daddy比過去更重視聯賽~<br />\n希望今晚可以殺低車仔~一鼓作氣過埋曼聯呢關~<br />\n保持氣勢到季尾<br />\n各位巴打一條心支持利記今屆奪第2個英超~~"},{"pid":"f7da3f355c41f86c5a29caacbd7edc88675b772e","tid":2416292,"uid":266467,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-05T04:39:50.000Z","msg":"<img src=\"/assets/faces/big/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"d86359ed1baf9914ab87a5fda1c80e1e6fd37d39","tid":2416292,"uid":262480,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-05T13:00:29.000Z","msg":"後上奪冠仲好睇"}]}