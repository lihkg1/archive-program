8B%E8%B3%BD-1%E9%87%911%E9%8A%801%E9%8A%85%E5%89%B5%E6%B5%B7%E5%A4%96%E8%B3%BD%E4%BA%8B%E6%9C%80%E4%BD%B3%E6%88%90%E7%B8%BE?utm_medium=Social&amp;utm_source=fbpost_link&amp;utm_campaign=martialabhk</a>"},{"pid":"8e67c699b29a93941866378adc576ea0f9db3bea","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T15:40:03.000Z","msg":"自推"},{"pid":"aa0e33e4671747f88195bb54e592ebd478312f04","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T15:40:18.000Z","msg":"自推"},{"pid":"c5ca16773b5884c5194d5d7b642cb55bb3fb9b6b","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T15:40:37.000Z","msg":"自推"},{"pid":"a0524bb30e7ca48cf0b12fa8b54f3ad900b70a93","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T15:40:53.000Z","msg":"自推"},{"pid":"ddbd07df82777863093b3c841daa9b349fdd8227","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T15:41:05.000Z","msg":"自推"},{"pid":"23e8c8d9c900250e6519691b7dac027c87e9324b","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T15:41:18.000Z","msg":"自推"},{"pid":"d958a805ac40cab0f5119831dea9590b1ff7dc6f","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T15:42:44.000Z","msg":"自推"},{"pid":"a151b051aa828396d2cead7fa68261639858331e","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T15:44:50.000Z","msg":"自推"},{"pid":"af946bccf765d2fe3e9c071b1dbfca5ff42db510","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T15:58:25.000Z","msg":"自推"},{"pid":"b09d37152a8ba46970a53b93150360417e970a25","tid":1808850,"uid":17321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T16:19:33.000Z","msg":"非常非常需要的一場勝利。這是香港久違了10多年的海外賽金牌。<br />\n亞洲拳擊聯合會（ASBC）在12月26-31日舉行馬來西亞檳城國際邀請賽，吸引數以百計來自馬來西亞、台北、新加坡、泰國、印度尼西亞、尼泊爾、東帝汶等地的拳擊好手參加，爭奪各量級獎牌。<br />\n <br />\n<br />\n香港國際拳擊聯會（HKIBF）派出4名運動員： 譚梓鋒（左一）,袁文俊（左二） , 鄧創文 （左三） 及林敬皓（左四）出戰檳城盃。（圖片由受訪者提供）<br />\n香港隊勇奪1金1銀1銅。近期流行的勝利手勢。（圖片由受訪者提供）<br />\n香港國際拳擊聯會（HKIBF）派出的隊伍。（圖片由受訪者提供）<br />\n出發前在拳館合照。（圖片由受訪者提供）<br />\n在機場合照。（圖片由受訪者提供）<br />\n<br />\n香港國際拳擊聯會（HKIBF）派出4名運動員：袁文俊（64kg） , 譚梓鋒（60kg）, 鄧創文 （56kg） 及林敬皓（56kg 青少年）出戰檳城盃。經過數日賽事，最終香港隊勇奪1金1銀1銅，為歷來出戰海外賽事最佳成績。<br />\n <br />\n<br />\n在頒獎台上，香港運動員做出抗爭手勢。（圖片由受訪者提供）<br />\n手勢代表運動中的訴求。（圖片由受訪者提供）<br />\n非常非常需要的一場勝利。這是香港久違了10多年的海外賽金牌。<br />\n金牌得主袁文俊<br />\n其中曾五度羸得香港冠軍頭銜的袁文俊，在是次比賽中保持穩定發揮，在量級組別中脫穎而出，一一以RSC勝過對手，以全勝姿態為香港奪得久違多年的海外賽金牌，這是繼他在2002年亞青杯奪得銀牌後又一海外賽事獎牌。<br />\n<br />\n另一香港代表林敬皓雖然年僅17歲，並只有短短兩年拳齡，但他首次代表香港出外比賽，便即獲得不俗成績。他不單在準決賽第二回合RSC馬六甲選手，更在決賽跟勁旅台北選手打得難分難解，甚至在第三回合令對方被裁判讀秒。可惜最終還是不敵台北選手，獲得一面青少年56公斤组別銀牌。<br />\n<br />\n早前在香港奧運資格賽跟曹星如交手的香港代表鄧創文則在56公斤組別獲得一面銅牌。出賽60公斤級別的譚梓鋒不幸於初賽落敗，無緣獎牌。<br />\n<br />\n幫推 <img src=\"/assets/faces/pigxm/snowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/snowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n「為歷來出戰海外賽事最佳成績」<img src=\"/assets/faces/pigxm/cook.gif\" class=\"hkgmoji\" />"},{"pid":"f92860db15bf627efcc4be199f03d9610c023d25","tid":1808850,"uid":213607,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-01-02T16:22:12.000Z","msg":"on9和理非 : 鬼"},{"pid":"933bf58fa8849b7b31110d537babac7f67857e17","tid":1808850,"uid":30836,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T16:23:50.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"b0f974ca2cb4a5d73b1abe0a98a9c2b4b13e9869","tid":1808850,"uid":58841,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T16:24:35.000Z","msg":"香港之光<img src=\"/assets/faces/xm/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/cry.gif\" class=\"hkgmoji\" />"},{"pid":"8ebe324fe56c63ae8d3033902b95ae76cecb98cd","tid":1808850,"uid":228868,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T16:26:24.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"0a4415492e7dcd37683a5922ffee9ed396968254","tid":1808850,"uid":130105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T16:59:15.000Z","msg":"咁勇<img src=\"/assets/faces/lm2xm/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2xm/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2xm/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2xm/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"84f248a1d42b143e077842fd115e372cd8322488","tid":1808850,"uid":311867,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T17:09:17.000Z","msg":"支持"},{"pid":"5ec5b521ece76fafa5d524eeac1cec1c62d5125d","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-02T17:51:57.000Z","msg":"國際體壇都係重要戰線。嚟緊奧運唔知有幾多香港運動員表態呢？<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"9c4bc7f54448f3cfe907d706c67d4b4a3f2ce991","tid":1808850,"uid":278180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-03T06:28:30.000Z","msg":"自推"}]}