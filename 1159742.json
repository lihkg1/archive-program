ps://r.lihkg.com/link?u=https%3A%2F%2Fsimonshen.blog%2F2019%2F05%2F06%2F%25E4%25BD%25A0%25E7%259A%2584%25E5%258F%2597%25E7%259C%25BE%25E6%2598%25AF%25E8%25AA%25B0%25E4%25BA%25BA%25EF%25BC%259F-%25E2%2594%2580%25E2%2594%2580%25E4%25BA%2592%25E8%2581%25AF%25E7%25B6%25B23-0%25E5%25A6%2582%25E4%25BD%2595%25E9%25A1%259B%25E8%25A6%2586%25E3%2580%258C%25E5%2585%25B1%25E8%25AD%2598%25E6%25B0%2591%2F&d=LRk9npnliL4HefRMP%2BWOkLnp9gp%2BSvHPFRLSSJzTNPo%3D&h=10a33b2c\" data-auto-link target=\"_blank\">https://simonshen.blog/2019/05/06/%E4%BD%A0%E7%9A%84%E5%8F%97%E7%9C%BE%E6%98%AF%E8%AA%B0%E4%BA%BA%EF%BC%9F-%E2%94%80%E2%94%80%E4%BA%92%E8%81%AF%E7%B6%B23-0%E5%A6%82%E4%BD%95%E9%A1%9B%E8%A6%86%E3%80%8C%E5%85%B1%E8%AD%98%E6%B0%91/</a><br />\n<br />\n一個香港既國際關係學者"},{"pid":"67ea39095395ef0db057be7e50a8b7ea4f25016e","tid":1159742,"uid":41355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-19T08:11:08.000Z","msg":"push"},{"pid":"c0c9d6381f827baccabe3e1b02c1a9b0599432c5","tid":1159742,"uid":41355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-19T13:25:08.000Z","msg":"push"},{"pid":"fde0d1eaf9ca43c076ff5a5476c74a95f124f692","tid":1159742,"uid":224323,"like":0,"dislike":0,"score":0,"quote":{"pid":"b87e7634fc4ddff1b770ff54dc5e01420323fc02","tid":1159742,"uid":41355,"like":0,"dislike":0,"score":0,"quote":{"pid":"05df5146cc43c19a77186187a746ccc0a1ada4ab","tid":1159742,"uid":221490,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-05-18T12:33:00.000Z","msg":"得益者就係想要衣種局面<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-18T13:30:53.000Z","msg":"點解咁講?"},"citedBy":1,"replyTime":"2019-05-19T15:50:58.000Z","msg":"方便新式獨裁，收偏、分化、假民主。"}]}