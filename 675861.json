oad/2018/05/24/103013_b6b314ceab5425a1ccc92e2e37daafba.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F24%2F103013_b6b314ceab5425a1ccc92e2e37daafba.png&h=ea538f19&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/05/24/103015_1db0d3e71e0c04d1634538f15853f29a.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F24%2F103015_1db0d3e71e0c04d1634538f15853f29a.png&h=853f0a4c&s={SIZE}\" />"},{"pid":"eddab9c0399106d53f68a56a461931b9ab7b1382","tid":675861,"uid":79563,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2018-05-24T02:37:09.000Z","msg":"其實我真係唔撚想理"},{"pid":"9eb152f6bb7a033681b2296c6be3b3c1a2e6a46e","tid":675861,"uid":79563,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-05-24T02:38:12.000Z","msg":"<blockquote>兩邊共狗都係仆街<br />\n但啲學生係想要民主，部分開名要李x矮仔落台（而唔係趙），所以矮仔出兵鎮壓<br />\n哩篇文顛倒是非<br />\n喺NYT出，有人想鞭矮仔條屍？</blockquote><br />\n<br />\n其實三邊共狗都係仆街黎<br />\n<br />\n柴玲、王丹呢D, 唔係仆街係乜?"},{"pid":"43cc9793e292bd7c459f7eb89778328d61f21fd9","tid":675861,"uid":107405,"like":6,"dislike":1,"score":5,"quote":{"pid":"62f52c89f9db0f17069e75e3fe6c1d7fb6a9edf9","tid":675861,"uid":48631,"like":5,"dislike":3,"score":2,"citedBy":2,"replyTime":"2018-05-24T02:07:09.000Z","msg":"唯一一個有良心嘅中共人俾個閪佬鄧小平迫害<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-24T03:04:14.000Z","msg":"如果係指趙紫陽 咁佢唔算有良心 胡耀邦在位個陣係打擊太子黨呢件事上面佢係有份屌鳩胡<br />\n不過話晒佢都同胡一樣算係改革派 加上六四自然更加比鄧針對<br />\n<br />\n同趙相比 胡耀邦先叫有少少良心 雖然講到底都唔係支持西方式民主 但佢既改革主張係多少會放權比平民 <br />\n所以胡既民望先會高 睇下乜揀野溫爺爺習維尼 成班人爭住提胡耀邦 口講就係讚揚 實則跟本係消費胡既聲望<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b54b0249efe24cf5d7f98d199937951119e77f16","tid":675861,"uid":48083,"like":0,"dislike":0,"score":0,"quote":{"pid":"9eb152f6bb7a033681b2296c6be3b3c1a2e6a46e","tid":675861,"uid":79563,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-05-24T02:38:12.