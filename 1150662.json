2Fbini-the-bunny-newsletter&d=0a%2BBnfQRLGMOm4peNIjNW0yCzF7GSvQxQofikz39bzk%3D&h=166a19ba\" data-auto-link target=\"_blank\">https://binithebunny.com/pages/bini-the-bunny-newsletter</a> <br />\n<img src=\"https://na.cx/i/5tETNm2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F5tETNm2.png&h=f70bebab&s={SIZE}\" /><img src=\"https://na.cx/i/RvPP48J.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRvPP48J.png&h=fc3e092a&s={SIZE}\" />"},{"pid":"e45037778dde9e4aef0e7fd57c0507c95d74231f","tid":1150662,"uid":197098,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-05-12T05:21:13.000Z","msg":"<strong><ins><span style=\"font-size: large;\">好多人以為兔子冇感情無視主人, 其實完全相反....</span></ins></strong><br />\n<br />\n兔子🐰是親人的群體性動物，但身體語言與其他動物不同，要做些研究才理解。(推介最底的3個網站)<br />\n<br />\n無視主人的誤會而被棄養：其實兔子側面看某東西就代表正面看某東西。兔子也有遠視。牠們正前方和下方是盲點，除了這兩個盲點外，牠們幾乎可以看到360度。(所以有時食物在牠下巴下面睇唔到)兔子只有向著前方大約30度範圍，才可以有立體影像。所以佢地唔係無視你，你是在他們視線範圍之內。<br />\n<br />\n以下2個videos可看到：<br />\n<a href=\"https://youtu.be/pyL0yEs-ka8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FpyL0yEs-ka8&d=0a%2BBnfQRLGMOm4peNIjNW0yCzF7GSvQxQofikz39bzk%3D&h=4e3f3d69\" data-auto-link target=\"_blank\">https://youtu.be/pyL0yEs-ka8</a><br />\n<a href=\"https://youtu.be/Maovq8Vz1LM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FMaovq8Vz1LM&d=0a%2BBnfQRLGMOm4peNIjNW0yCzF7GSvQxQofikz39bzk%3D&h=11b3c8ee\" data-auto-link target=\"_blank\">https://youtu.be/Maovq8Vz1LM</a><br />\n<br />\n<span style=\"color: red;\">兔子的行為解釋網站：</span><br />\n<br />\n香港兔協: <a href=\"http://www.hkrabbit.org/knowledge8_ch.php\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.hkrabbit.org%2Fknowledge8_ch.php&d=0a%2BBnfQRLGMOm4peNIjNW0yCzF7GSvQxQofikz39bzk%3D&h=c4e825ca\" data-auto-link target=\"_blank\">http://www.hkrabbit.org/knowledge8_ch.php</a><br />\n<br />\n美國兔協 House Rabbit Society (教育網站): <a href=\"http://rabbit.org\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Frabbit.org&d=0a%2BBnfQRLGMOm4peNIjNW0yCzF7GSvQxQofikz39bzk%3D&h=c946a1be\" data-auto-link target=\"_blank\">http://rabbit.org</a><br />\n<br />\n詳盡身體語言解釋(喜怒哀樂): <a href=\"http://rabbitspeak.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Frabbitspeak.com&d=0a%2BBnfQRLGMOm4peNIjNW0yCzF7GSvQxQofikz39bzk%3D&h=11151f07\" data-auto-link target=\"_blank\">http://rabbitspeak.com</a>"},{"pid":"5ba97e37257c2779f5f1749d2991a2436596b50f","tid":1150662,"uid":197098,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-05-12T07:31:32.000Z","msg":"兔子是其中一種最心境平靜的動物，很多人覺得牠們尤其是咀嚼食物的聲音很治癒。如果你家的兔子有攻擊性，這不是兔子的本性，而是後天環境和飼養方式影響的。兔子亦被作為情緒和心靈支持動物(emotional support animal)，即是主人有醫生的證明，帶着小動物作伴，心靈才得到慰藉。<br />\n<br />\n以下video可看到兔子拚命地拯救一隻被困住的貓! 真感人！☺<br />\n<a href=\"https://youtu.be/ydwwZtQyuiU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FydwwZtQyuiU&d=0a%2BBnfQRLGMOm4peNIjNW0yCzF7GSvQxQofikz39bzk%3D&h=22b043ff\" data-auto-link target=\"_blank\">https://youtu.be/ydwwZtQyuiU</a>"},{"pid":"214f4f3652c3415863949995707454013f666a96","tid":1150662,"uid":197098,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-12T14:19:44.000Z","msg":"<span style=\"font-size: x-large;\"><ins>領養了兔子,係咁跳兔子舞!</ins></span><br />\n<br />\n跳兔子舞(Binky)是兔子最開心的狀態。這是告訴你是一個好主人，代表牠很喜歡現時的環境和生活:<br />\n<a href=\"https://youtu.be/Mu27kYckovg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FMu27kYckovg&d=0a%2BBnfQRLGMOm4peNIjNW0yCzF7GSvQxQofikz39bzk%3D&h=88e01d08\" data-auto-link target=\"_blank\">https://youtu.be/Mu27kYckovg</a>"}]}