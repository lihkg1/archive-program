6:20.000Z","msg":"<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"e346c28bbb669c6c267d7a6cfee96fb2c1013b09","tid":1502194,"uid":2300,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:37:29.000Z","msg":"有五毛開始推post<br />\n講多次啦屌<br />\n禁係for 軍隊<br />\n唔好炒車同轉視線<br />\n依隻彈用左好耐"},{"pid":"5f62eab1d2f08f6da07925b0796ceaab56a8e882","tid":1502194,"uid":179598,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:37:52.000Z","msg":"推"},{"pid":"92d94c5010c5a66d99ad83fcae320ffd95790b3c","tid":1502194,"uid":81996,"like":1,"dislike":0,"score":1,"quote":{"pid":"9ba5f2aae56eeeb2a1c142d89e99abe048bd6964","tid":1502194,"uid":81996,"like":0,"dislike":0,"score":0,"quote":{"pid":"2039b5d2f1a8d7ec4521fcebb359f41638524240","tid":1502194,"uid":92376,"like":0,"dislike":1,"score":-1,"quote":{"pid":"00311e17209bfce3df038458272ca38bbf77415c","tid":1502194,"uid":81996,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-08-24T16:33:20.000Z","msg":"唔好推啦 玩開槍既都知不嬲都係咁"},"citedBy":2,"replyTime":"2019-08-24T16:34:04.000Z","msg":"講啲無人證實到既野想帶風向？"},"citedBy":1,"replyTime":"2019-08-24T16:36:07.000Z","msg":"<a href=\"https://orientaldaily.on.cc/cnt/news/20161003/mobile/odn-20161003-1003_00176_011.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Forientaldaily.on.cc%2Fcnt%2Fnews%2F20161003%2Fmobile%2Fodn-20161003-1003_00176_011.html&d=BZKFieMwLRuYRu3HtqC84s4e4tfxBia5339duguOAPM%3D&h=574c9d8b\" data-auto-link target=\"_blank\">https://orientaldaily.on.cc/cnt/news/20161003/mobile/odn-20161003-1003_00176_011.html</a><br />\n<br />\n求其google下都有啦<br />\n咪亂屈<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n我懷疑你想帶風向就真 煲d無鬼用既野<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-24T16:38:38.000Z","msg":"穿透力低 免流彈傷無辜<br />\n<br />\n消息指，九十年代初，香港發生多宗匪徒持重型軍火劫案，當時警方被指火力不足，故在九三年開始，改用由美國生產的史密夫威爾遜十型左輪手槍，並引入特製的中空子彈取代舊有鉛頭子彈。昨日警員開槍制服尼籍疑兇所使用的子彈，正是殺傷力強大的中空子彈。中空子彈彈頭包含兩層不同金屬，射進人體後會產生旋轉動力，破壞人體組織，令中槍者大量出血，雖然傷害較大，但穿透力低，彈頭不易穿過人體成為流彈誤傷無辜。<br />\n<br />\n此post已完 集中精力推其他post"},{"pid":"ecb2cba9b9b9c00c4330263f13dc7dc7298383a5","tid":1502194,"uid":28159,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:38:56.000Z","msg":"要國際組織求助<br />\n將港共同阿薩德畫上等號<br />\n想幫美軍帶路嘅就快啲幫手<br />\n<br />\n[敘利亞翻版 山埃毒氣襲擊]一人一信向禁止化學武器組織求助<br />\n<a href=\"https://lih.kg/1502347\" data-auto-link target=\"_blank\">https://lih.kg/1502347</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"ea910c20b16328377a5ea09f253a01bdbe34eedd","tid":1502194,"uid":250951,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:39:24.000Z","msg":"可唔可以發twitter比美國部門知道<br />\n比人知道佢地暗地開始軍事行動"},{"pid":"dc6efd1355528329eafb3d1b636eb034a72bf4e8","tid":1502194,"uid":1562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:40:06.000Z","msg":"推"},{"pid":"2ee227a097ec6c5518919eeddc10f440239676bd","tid":1502194,"uid":212238,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:40:38.000Z","msg":"警察不嬲用依種"},{"pid":"a1a58564575b5489648ffd0e57a7a719369bb5cc","tid":1502194,"uid":68258,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:42:55.000Z","msg":"<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"0d4b8ba11f35c167a715790b055611695c849c90","tid":1502194,"uid":119610,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T16:43:19.000Z","msg":"推"},{"pid":"abba44817dab3e8c4563b876720cfefb56047a1f","tid":1502194,"uid":280593,"like":