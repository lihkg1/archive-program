kgmoji\" />"},{"pid":"ff168398bf95480dc817eeac226ebaca202d41a3","tid":2094194,"uid":306664,"like":8,"dislike":1,"score":7,"quote":{"pid":"d613619b5f4b502b62425eda9ed6b2970ddaacee","tid":2094194,"uid":282637,"like":19,"dislike":1,"score":18,"citedBy":4,"replyTime":"2020-07-04T12:14:42.000Z","msg":"羅家聰講過"},"citedBy":1,"replyTime":"2020-07-04T12:23:52.000Z","msg":"yes, 香港D分析員都係中國人<br />\n<br />\n做假數"},{"pid":"0b5bb9f2328cde7d9cb95e5bd067f0e001b9867b","tid":2094194,"uid":345502,"like":1,"dislike":0,"score":1,"quote":{"pid":"0b3b7b4c68b7297573e4d551539df92da4faa6ca","tid":2094194,"uid":63154,"like":8,"dislike":4,"score":4,"citedBy":1,"replyTime":"2020-07-04T12:17:48.000Z","msg":"<span style=\"color: red;\">呢樣野真係要公諸於世，以免國際投資者受誤導。</span><br />\n<br />\n<br />\n我對呢個講法有保留，叫得國際投資者，唔係買得一兩球望退休保障嘅C9，如果能夠被所謂分析師誤導，呢種國際投資者都好失敗<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-04T12:23:56.000Z","msg":"大N陸有版你睇"},{"pid":"46bb9390b49734adcec890859b4d1b9417d669f1","tid":2094194,"uid":345502,"like":1,"dislike":1,"score":0,"quote":{"pid":"ff168398bf95480dc817eeac226ebaca202d41a3","tid":2094194,"uid":306664,"like":8,"dislike":1,"score":7,"quote":{"pid":"d613619b5f4b502b62425eda9ed6b2970ddaacee","tid":2094194,"uid":282637,"like":19,"dislike":1,"score":18,"citedBy":4,"replyTime":"2020-07-04T12:14:42.000Z","msg":"羅家聰講過"},"citedBy":1,"replyTime":"2020-07-04T12:23:52.000Z","msg":"yes, 香港D分析員都係中國人<br />\n<br />\n做假數"},"citedBy":1,"replyTime":"2020-07-04T12:25:16.000Z","msg":"唔駛做數，只係主觀分析有咁好講咁好，差果d野唔講"},{"pid":"570e3966c9030f55970ed9e723dbbcc16e7d932e","tid":2094194,"uid":54721,"like":4,"dislike":1,"score":3,"quote":{"pid":"d613619b5f4b502b62425eda9ed6b2970ddaacee","tid":2094194,"uid":282637,"like":19,"dislike":1,"score":18,"citedBy":4,"replyTime":"2020-07-04T12:14:42.000Z","msg":"羅家聰講過"},"citedBy":0,"replyTime":"2020-07-04T12:26:28.000Z","msg":"所以佢被炒<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"53586afe93f17716584d9ccef85