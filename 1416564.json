地係咪要港獨？目標要一致！！<br />\n</span><br />\n如果唔係爭取港獨，請立即澄清<br />\n<a href=\"https://lih.kg/1416445\" data-auto-link target=\"_blank\">https://lih.kg/1416445</a>"},"citedBy":0,"replyTime":"2019-08-05T15:19:13.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"52fb5c529fa091cad74a0dae463a6867074184fb","tid":1416564,"uid":229880,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T15:19:24.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"f78b9b72a8ed0464742e1c9d893a7fa17ff01d2e","tid":1416564,"uid":229880,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T15:19:35.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b4da232f0ef5db40b1f46235694abf3f7ff84c37","tid":1416564,"uid":229880,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T15:19:51.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"0ee24baef62e7712369754482cf24e22b3f62efa","tid":1416564,"uid":229880,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T15:20:06.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"deff1902f528579afb303216e6fb186d24143b9c","tid":1416564,"uid":238275,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-05T15:21:14.000Z","msg":"pushhhhhh"},{"pid":"e3efb882471c402ef069516403b923be92186096","tid":1416564,"uid":229880,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T15:28:10.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"df18e4b2cdb67b6ade9abb1e6c7703fee310a9c0","tid":1416