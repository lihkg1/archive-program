 src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n總有一日，朗朗乾坤，一片清明！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"1537222b9d81aefa9dc40a64debb2162c3da80ef","tid":1225002,"uid":1303,"like":0,"dislike":0,"score":0,"quote":{"pid":"9e74f1919ddd95b8f6fc70dd7499b0756dc4dd4d","tid":1225002,"uid":53515,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-06-15T06:00:17.000Z","msg":"想收集一下連登風向<br />\n<br />\n正皮 出<br />\n負皮 唔出"},"citedBy":0,"replyTime":"2019-06-15T06:55:43.000Z","msg":"收咩集呀屌<br />\n<br />\n有無出不讚成通知書呀依家<br />\n<br />\n屌你老母"},{"pid":"45a87e5ac1e646b7c98981f29f9fe08e1162287a","tid":1225002,"uid":15646,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T06:56:02.000Z","msg":"冇咁點 遊咩行？<br />\n唔俾人岀港島行街？"},{"pid":"ef638f241435cff8c663cefaa85e9e20087c9d78","tid":1225002,"uid":239295,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T06:57:50.000Z","msg":"訓覺而，發緊夢，係夢入面既話<br />\n反唔反對關我撚事，要出就一定出"},{"pid":"7f1932713564dc8b3a43d88107e7a6cc44ea05ff","tid":1225002,"uid":83934,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T06:58:23.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"3d25376d22396a0d985d2b500b1fcc441c697381","tid":1225002,"uid":36048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T06:59:18.000Z","msg":"咪撚再出啲咁隱晦既標題，企硬啲個立場，一撚定會出"},{"pid":"1b40b7d10115860243992800c2ef8a4e25fec940","tid":1225002,"uid":158317,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T07:00:08.000Z","msg":"老閪都出"},{"pid":"3eafeb4eb1a1107369e80db2d3f50f0a5ce72626","tid":1225002,"uid":19978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T07:04:54.000Z","msg":"想去銅鑼灣行街"},{"pid":"2ccf667a339c1f17d933f57552e871a19cd1c446","tid":1225002,"uid":191290,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T07:06:11.000Z","msg":"如果612後，你有情緒低落問題，請入嚟睇睇。<br />\n<br />\n612戰後情緒舒緩，請幫推。<br />\n<a href=\"https://lih.kg/1225094\" data-auto-link target=\"_blank\">https://lih.kg/1225094</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"311bbaf4b55b6cad2d0772ae05b81bafddfc89eb","tid":1225002,"uid":242851,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T07:06:17.000Z","msg":"從來出黎行都唔會理咩反唔反對通知書<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"17b5eae5f0f53f0b3351721cd3041975d71d3b9c","tid":1225002,"uid":59407,"like":0,"dislike":0,"score":0,"quote":{"pid":"8a939fcae960546f5df2a1ec7b1755f174562df4","tid":1225002,"uid":18948,"like":275,"dislike":0,"score":275,"citedBy":6,"replyTime":"2019-06-15T06:06:38.000Z","msg":"<a href=\"https://www.doj.gov.hk/chi/archive/doc/201200c.doc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.doj.gov.hk%2Fchi%2Farchive%2Fdoc%2F201200c.doc&d=NKClBOrNcUwYLVyzdKWJdegMmE0tIaoAQI%2BAeX1JER4%3D&h=a34b00de\" target=\"_blank\">https://www.doj.gov.hk/chi/archive/doc/201200c.doc</a><br />\n<br />\n3.​最普遍的誤解，是公眾遊行必須得到警方批准。我希望所有議員現在明白，事實並非如此。《公安條例》只是就大部分超過30人的公眾遊行，訂立了一項通知警方的規定。<br />\n<br />\n4.​警務處處長在接到舉行公眾遊行的意向通知後，除非反對舉行遊行，否則必須發出不反對通知書。如果處長在指定期限內沒有發出不反對通知書，也沒有發出反對遊行的通知，他便會被當作已發出不反對通知書。<br />\n<br />\n5.​換言之，如果警方不發出反對通知，遊行便可進行，顯而易見，法例並無規定遊行必須得到警方批准。<br />\n<br />\n<br />\n<br />\n究竟要講幾多次"},"citedBy":0,"replyTime":"2019-06-15T07:06:59.000Z","msg":"推！！！！！"},{"pid":"b6542e8abbf638d8715a2d0f94aaf96657e7069a","tid":1225002,"uid":241026,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T07:07:26.000Z","msg":"依家法例規定唔俾出街？<br />\n出佢老母<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a8c5e1ff880c5f6e81aba0acfd3a46838b88735b","tid":1225002,"uid":7790,"like":0,"dislike":0,"score