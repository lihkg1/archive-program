1e3f7","tid":776542,"uid":31744,"like":0,"dislike":0,"score":0,"quote":{"pid":"2abe9f0f66bcfc3c0819efbb7c036fc302c9348c","tid":776542,"uid":59583,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-08-13T17:52:39.000Z","msg":"新疆暑假好多人<br />\n北疆景點多人到<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n南疆唔錯"},"citedBy":0,"replyTime":"2018-08-27T17:08:27.000Z","msg":"想問啲女係咪鬼鬼哋 成個熱巴咁"},{"pid":"f24ce9c510388f5d5d133592597eb4e1a7d9a085","tid":776542,"uid":181015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-27T17:10:34.000Z","msg":"揾我<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"9af70ff0e9a710af5767cac734c94ef6a275d9c5","tid":776542,"uid":37661,"like":2,"dislike":0,"score":2,"quote":{"pid":"ff40389a539cf1760cbb5cd43a9202733fcbb2ed","tid":776542,"uid":31744,"like":0,"dislike":0,"score":0,"quote":{"pid":"9408a636d14321e8529a0ad0b3565f61a9456a96","tid":776542,"uid":37661,"like":0,"dislike":0,"score":0,"quote":{"pid":"2abe9f0f66bcfc3c0819efbb7c036fc302c9348c","tid":776542,"uid":59583,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-08-13T17:52:39.000Z","msg":"新疆暑假好多人<br />\n北疆景點多人到<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n南疆唔錯"},"citedBy":1,"replyTime":"2018-08-14T02:10:11.000Z","msg":"北疆九月至十月都好多人<br />\n<br />\n試過無 Plan 下去，幾乎要瞓街<br />\n<br />\n要住到當地人屋企，喺街問人搵住宿，人哋搵到有家人肯收留先有得住。"},"citedBy":1,"replyTime":"2018-08-27T16:59:37.000Z","msg":"隨便去人屋企瞓<br />\n唔驚㗎咩<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-27T23:15:46.000Z","msg":"驚得過冇地方住？<br />\n<br />\n上網狂掃人哋啲遊記，睇下有冇介紹住宿又有電話，打去搵住宿。<br />\n<br />\n住3個地方都係去到搵。<br />\n<br />\n幾日都冇涼沖，沖涼要搵當地俄式澡房。<br />\n<br />\n一間鐵皮屋，裡面燒着一大桶熱水，自己裝啲熱水去溝凍水沖。<br />\n<br />\n由構思話想去到出發，得一個禮拜，除咗來回烏魯木齊機票，其他乜都 book 唔到。<br />\n<br />\n屈蛇坐人哋啲區間車入景區。<br />\n<br />\n不過呢種經歷先最值得回味。"},{"pid":"7bc7df7c760ea95a1e7a984c0e6402a03ff03523","tid":776542,"uid":163350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-28T06:40:31.000Z","msg":"此回覆已被刪除"},{"pid":"6998755b0cc4c03305c2f68d61b0e3f04ac48d9a","tid":776542,"uid":52946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-28T06:41:40.000Z","msg":"記得話係外國人唔好話係中國/漢人"},{"pid":"e0963b88e85b162a645c0b3fefbefc0bc9bf0f93","tid":776542,"uid":174159,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-28T10:55:52.000Z","msg":"5-6年前去過南疆，基本上都安全，入烏魯木齊同吐魯番d商場同超市，個袋要過安檢機，然後鎖locker，驚恐襲同偷嘢。冇記錯d武警係揸住刺刀巡邏<br />\n<br />\n住宿好平，正常乾淨酒店都係百幾蚊人仔一晚（當年），瞓火車都唔算太污糟，睇實財物就得<br />\n去食飯同搭車，d人一定問你喺邊度黎，我會答廣州福建嗰d地方，總之唔好認係香港人<br />\n不過已經好多年前啦，而家真係唔知咩環境"},{"pid":"735ef32730d4914bc38f7050fc77db07b72db11d","tid":776542,"uid":31744,"like":0,"dislike":0,"score":0,"quote":{"pid":"e0963b88e85b162a645c0b3fefbefc0bc9bf0f93","tid":776542,"uid":174159,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-28T10:55:52.000Z","msg":"5-6年前去過南疆，基本上都安全，入烏魯木齊同吐魯番d商場同超市，個袋要過安檢機，然後鎖locker，驚恐襲同偷嘢。冇記錯d武警係揸住刺刀巡邏<br />\n<br />\n住宿好平，正常乾淨酒店都係百幾蚊人仔一晚（當年），瞓火車都唔算太污糟，睇實財物就得<br />\n去食飯同搭車，d人一定問你喺邊度黎，我會答廣州福建嗰d地方，總之唔好認係香港人<br />\n不過已經好多年前啦，而家真係唔知咩環境"},"citedBy":2,"replyTime":"2018-08-28T12:49:36.000Z","msg":"點解唔好認係香港人<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> 認係東南亞遊客會唔會更好<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"8285f21c28930bffc8c6d4fd2043a9fb3d0cd103","tid":776542,"uid":48222,"like":0,"dislike":0,"score":0,"quote":{"pid":"735ef32730d4914bc38f7050fc77db07b72db11d","tid":776542,"uid":31744,"like":0,"dislike":0,"score":0,"quote":{"pid":"e0963b88e85b162a645c0b3fefbefc0bc9bf0f93","tid":776542,"uid":174159,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-28T10:55:52.000Z","msg":"5-6年前去過南疆，基本上都安全，入烏魯木齊同吐魯番d商場同超市，個袋要過安檢機，然後鎖locker，驚恐襲同偷嘢。冇記錯d武警係揸住刺刀巡邏<br />\n<br />\n住宿好平，正常乾淨酒店都係百幾蚊人仔一晚（當年），瞓火車都唔算太污糟，睇實財物就得<br />\n去食飯同搭車，d人一定問你喺邊度黎，我會答廣州福建嗰d地方，總之唔好認係香港人<br />\n不過已經好多年前啦，而家真係唔知咩環境"},"citedBy":2,"replyTime":"2018-08-2