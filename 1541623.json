umbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2019%2F09%2F02%2F9dojRG.png&h=baf47345&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/JXMrzU3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJXMrzU3.jpg&h=4fd76574&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/uZFWW8o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuZFWW8o.jpg&h=4196affc&s={SIZE}\" />"},{"pid":"971ed699c471579275816e44243be115e0ae49ae","tid":1541623,"uid":39021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T15:25:26.000Z","msg":"加油<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"8ac2ed8bac2ec165e42f0171897b04945aee4181","tid":1541623,"uid":184746,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T15:26:58.000Z","msg":"push"},{"pid":"8070479f7c897b403a7019cb0ccec3193a4d6bd2","tid":1541623,"uid":46534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T23:30:00.000Z","msg":"推"},{"pid":"db6da8028cc6d4d740c81b5f7ca5a498242cac5a","tid":1541623,"uid":5822,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T03:29:41.000Z","msg":"首先啦 佢講得無錯<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 好多中1/2/3岩岩上黎唔會知咩事 的確係會嚇到 <br />\n<br />\n只係佢處理手法on9姐 不過一定係藍絲黎"}]}