cce43440","tid":640173,"uid":113626,"like":11,"dislike":1,"score":10,"citedBy":2,"replyTime":"2018-04-24T06:24:57.000Z","msg":"好快教科書將會寫成中國領導美國打贏二戰, 成最大羸家 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7cef3ff6bf5da126abf153fdffbb0041a71803c0","tid":640173,"uid":112416,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-04-24T06:25:34.000Z","msg":"不應將歷史科政治化"},{"pid":"3fc52ecbbe90617b7e32e5e741674ff1b048b9a3","tid":640173,"uid":93784,"like":1,"dislike":1,"score":0,"quote":{"pid":"2587052cee80b938e5fa5176f1894d1b748eb1ca","tid":640173,"uid":182475,"like":0,"dislike":1,"score":-1,"quote":{"pid":"843739d2b9b0a590abe8db199c66ffe4c0ab44b8","tid":640173,"uid":113626,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-04-24T06:15:17.000Z","msg":"<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /> 打敗仗割地賠償同將主權交比人有咩分別"},"citedBy":1,"replyTime":"2018-04-24T06:23:14.000Z","msg":"某甲住在某單位，有日佢衰咗，賠100蚊俾你。然某甲搬走，換咗乙，再搬走，今次係某丙住。然後某丙話，你並唔擁有之前果100蚊，行駛完果100蚊之後要10年要俾返佢，因為果100蚊從來都係佢嘅"},"citedBy":0,"replyTime":"2018-04-24T06:25:38.000Z","msg":"中共=賊, 黑社會"},{"pid":"11560ddd08abf8b8c0120b593698a6abe3b0b9b8","tid":640173,"uid":35790,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-04-24T06:27:54.000Z","msg":"北方大媽好野"},{"pid":"d065b5812d53f9a36c950a95e7d2284e33464eb9","tid":640173,"uid":22692,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-04-24T06:29:15.000Z","msg":"哈哈"},{"pid":"bdab98fb358d0fd425412b69db2eb907cbb656e4","tid":640173,"uid":22692,"like":0,"dislike":1,"score":-1,"quote":{"pid":"911ef2d849aea6eaec665209f80468b400af4de8","tid":640173,"uid":48083,"like":118,"dislike":2,"score":116,"citedBy":1,"replyTime":"2018-04-24T05:52:40.000Z","msg":"即係以下機構/人仕唔精準啦<br />\n<br />\n中國人民政治協商會議全國委員會(全國政協):<br />\n<br />\n(一國兩制)即&ldquo;一個國家，兩種制度&rdquo;的簡稱。中國共產黨和中國政府<span style=\"color: red;\"><strong><span style=\"font-size: xx-large;\">為了收回香港、澳門主權</span></strong></span>，實現台灣與祖國大陸統一而提出的一項重要戰略方針。<br />\n<br />\n<a href=\"http://www.cppcc.gov.cn/2011/09/26/ARTI1317001118812175.shtml\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.cppcc.gov.cn%2F2011%2F09%2F26%2FARTI1317001118812175.shtml&d=vHuKfvF7bamx%2B%2BckcQho87IOlR6kLHi1VdsYCD5DrTY%3D&h=d0aed6eb\" target=\"_blank\">http://www.cppcc.gov.cn/2011/09/26/ARTI1317001118812175.shtml</a><br />\n<br />\n1983年國務院政府工作報告<br />\n...我們還將在適當的時候<span style=\"color: red;\"><span style=\"font-size: x-large;\"><strong>收回香港主權</strong></span></span>，並且採取適當措施維持香港繁榮。<br />\n<a href=\"http://www.gov.cn/test/2006-02/16/content_200823.htm\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.gov.cn%2Ftest%2F2006-02%2F16%2Fcontent_200823.htm&d=vHuKfvF7bamx%2B%2BckcQho87IOlR6kLHi1VdsYCD5DrTY%3D&h=0851655b\" target=\"_blank\">http://www.gov.cn/test/2006-02/16/content_200823.htm</a><br />\n<br />\n中國幹部學習網:<br />\n自從香港淪陷並被割讓以來，祖國人民眷念香港同胞，從未放棄過<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>收回香港主權</strong></span></span>的努力。<br />\n<a href=\"http://www.ccln.gov.cn/xxzgyc/253653-1.shtml\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.ccln.gov.cn%2Fxxzgyc%2F253653-1.shtml&d=vHuKfvF7bamx%2B%2BckcQho87IOlR6kLHi1VdsYCD5DrTY%3D&h=703a4c6a\" target=\"_blank\">http://www.ccln.gov.cn/xxzgyc/253653-1.shtml</a><br />\n<br />\n中國國防部<br />\n&ldquo;一國&rdquo;體現了中國要<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>收回香港主權</strong></span></span>的堅定決心，&ldquo;兩制&rdquo;則充分考慮了香港歷史的特殊性，充分調動了香港民眾的積極性，&ldquo;一國兩制&rdquo;的成功有其必然性。<br />\n<a href=\"http://www.mod.gov.cn/big5/jmsd/2017-07/01/content_4784333.htm\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.mod.gov.cn%2Fbig5%2Fjmsd%2F2017-07%2F01%2Fcontent_4784333.htm&d=vHuKfvF7bamx%2B%2BckcQho87IOlR6kLHi1VdsYCD5DrTY%3D&h=eb4c21dd\" target=\"_blank\">http://www.mod.gov.cn/big5/jmsd/2017-07/01/content_4784333.htm</a><br />\n<br />\n在後來出版的《鄧小平》文選中，清晰記錄下了這次談話的內容，&ldquo;我先把中央已決定的原則與大家講一講，到1997年必須<span style=\"color: red;\"><strong><span style=\"font-size: x-large;\">收回香港主權</span></strong></span>，這是原則問題，不可討論的，但對香港仍要繼續維持自由港，貿易金融中心不變，即根據憲法草案第三十條原對台灣的也可用之香港，使其繼續留在資本主義制度。&rdquo;<br />\n<br />\n<a href=\"http://phtv.ifeng.com/a/20170627/44643763_0.shtml\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fphtv.ifeng.com%2Fa%2F20170627%2F44643763_0.shtml&d=vHuKfvF7bamx%2B%2BckcQho87IOlR6kLHi1VdsYCD5DrTY%3D&h=887b4c96\" target=\"_blank\">http://phtv.ifeng.com/a/20170627/44643763_0.shtml</a>"},"citedBy":0,"replyTime":"2018-04-24T06:29:46.000Z","msg":"高質"},{"pid":"7bf1afb2d40e8a84b17fb369963707fdcabef560","tid":640173,"uid":60297,"like":2,"dislike":1,"score":1,"quote":{"pid":"7cef3ff6bf5da126abf153fdffbb0041a71803c0","tid":640173,"uid":112416,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-04-24T06:25:34.000Z","msg":"不應將歷史科政治化"},"citedBy":0,"replyTime":"2018-04-24T06:31:17.000Z","msg":"洗腦要由歷史入手"},{"pid":"f6c3ff2f21f67979825af89babbc0bb4d5f57627","tid":640173,"uid":62599,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-04-24T06:35:09.000Z","msg":"現代趙高？"},{"pid":"db5ac2ba3a388a56fca048a00615194bdba87880","tid":640173,"uid":13257,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-04-24T06:37:37.000Z","msg":"咁割讓香港島即係點，無割主權呀？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"893813f26fb9ec21597e97c4dcbc3a5475017a07","tid":640173,"uid":182475,"like":2,"dislike":1,"score":1,"quote":{"pid":"e2824c70559866b997307839c482cf81cce43440","tid":640173,"uid":113626,"like":11,"dislike":1,"score":10,"citedBy":2,"replyTime":"2018-04-24T06:24:57.000Z","msg":"好快教科書將會寫成中國領導美國打贏二戰, 成最大羸家 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-24T06:39:00.000Z","msg":"二次大戰時，由於國共達成共識，國民黨停止騷擾共軍的對日作戰，故共軍能重新以游擊戰及堅壁清野戰術令日軍泥足深陷，侵略速度嚴重受阻。這美蘇偷來難得的空間，得以全力夾擊納粹德軍。於歐洲戰場大局已定之後，美軍在東亞反攻，並在共軍支援下，輕鬆擊潰日軍在東南亞在中華地區的部隊。在中華地區被共軍收服後，共軍亦順勢退出戰場，美軍對日的反擊立時陷於苦戰，死傷人數暴增，最後不得不向日本本土投下原子彈，以此結束整場二戰。"},{"pid":"2e3a476046f5053098bd6e0c6c71ac6505453514","tid":640173,"uid":60100,"