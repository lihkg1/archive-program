ke":0,"dislike":0,"score":0,"quote":{"pid":"86511a2b124a814248d4ba8350a366bbb546383b","tid":715044,"uid":124983,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-06-25T11:50:00.000Z","msg":"情緒輔導指南"},"citedBy":1,"replyTime":"2018-06-25T12:32:19.000Z","msg":"行行都有壓力架啦<br />\n保持正面<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-25T12:50:07.000Z","msg":"有無It 狗正面思考輔導書推介"},{"pid":"641122255f53d801ab68a72e63780d60ed59ef7f","tid":715044,"uid":125976,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2018-06-25T12:59:35.000Z","msg":"當你揼返三五七年發覺人生好抑鬱好冇希望，依個時候你需要嘅係抗抑鬱<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/25/205012_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F25%2F205012_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=a6efcaa0&s={SIZE}\" /><br />\n<br />\n再揼落去發覺香港揼一世 code 都搵唔得多錢，依個時候你需要學炒股，學估值模型同基本分析<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/25/205259_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F25%2F205259_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=0f8c1583&s={SIZE}\" /><br />\n<br />\n再揼多一兩年，你發覺做 IT 根本好難溝到女，依個時候你需要嘅係學 NLP (唔係 Natural Language Processing 呀柒頭)<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/25/205507_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F25%2F205507_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=7950bbbf&s={SIZE}\" /><br />\n<br />\n最後，你發覺喺香港做一世 code 狗係冇運行，學吹水同管理先係升Lv之道，依個時候你需要睇 business books<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/06/25/205844_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F25%2F205844_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=a64d832b&s={SIZE}\" />"},{"pid":"30b02f651013941c4cb2a46324506c53f3aa9823","tid":715044,"uid":64457,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-25T12:59:43.000Z","msg":"<img src=\"https://cdn.waterstones.com/bookjackets/large/9780/1987/9780198788607.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.waterstones.com%2Fbookjackets%2Flarge%2F9780%2F1987%2F9780198788607.jpg&h=1aa60d2b&s={SIZE}\" />"},{"pid":"dcb5db533de385f224c1571872a9b818e110004d","tid":715044,"uid":12599,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T13:10:29.000Z","msg":"c++ primer"},{"pid":"30a5cb217128fb3f1c2c26c558482e09af5bcdf6","tid":715044,"uid":41887,"like":1,"dislike":0,"score":1,"quote":{"pid":"94b4fea2c881f884f463647fcc98457a03009840","tid":715044,"uid":61249,"like":0,"dislike":0,"score":0,"quote":{"pid":"9bba9f18db76807dbe12b65ba1bc7c0d49a3ca73","tid":715044,"uid":41887,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-25T05:08:23.000Z","msg":"software foundation"},"citedBy":1,"replyTime":"2018-06-25T05:39:51.000Z","msg":"details pls<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-25T15:24:14.000Z","msg":"<a href=\"https://softwarefoundations.cis.upenn.edu/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fsoftwarefoundations.cis.upenn.edu%2F&d=8qpNhUi%2BzyL8RemxCRsfKp7TfgnX9jywtYe9GXZmhCU%3D&h=dae05f02\" target=\"_blank\">https://softwarefoundations.cis.upenn.edu/</a>"},{"pid":"c683ae15d070ff9a151a6c37062c092307f0c4be","tid":715044,"uid":127292,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-25T16:06:02.000Z","msg":"此回覆已被刪除"},{"pid":"20da61dd296dd36809a25f273e929d5bda1ba21c","tid":715044,"uid":70176,"l