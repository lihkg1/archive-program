f\" class=\"hkgmoji\" />"},{"pid":"1db64cd1a971a78c45de7510c418377f1514ea03","tid":921051,"uid":207867,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-06T10:10:26.000Z","msg":"推 <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"fd2a7fb2e2e9ebb9261ddcd41bb2211d631f94b0","tid":921051,"uid":144751,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-07T02:44:21.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"e4465337a3dcc9ba341821e45638b1fe2392d468","tid":921051,"uid":3522,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-11T12:44:40.000Z","msg":"仲收唔收學生?"},{"pid":"b9c892fbb7c993bf56cb74ff154fb4baabda5985","tid":921051,"uid":161644,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-12T16:20:35.000Z","msg":"師兄可唔可以講解下點樣jazz improvisation"},{"pid":"f64614facb1021ad26b2f983d35defd92091cd5b","tid":921051,"uid":4660,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-12T16:34:58.000Z","msg":"巴打會係邊到教？ 學過幾年，手指傷左放低左幾年<br />\n而家有啲興趣想執返起枝bass"},{"pid":"82803da545b261b012b3ab399623d1e78e32aa76","tid":921051,"uid":144751,"like":0,"dislike":0,"score":0,"quote":{"pid":"e4465337a3dcc9ba341821e45638b1fe2392d468","tid":921051,"uid":3522,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-11T12:44:40.000Z","msg":"仲收唔收學生?"},"citedBy":0,"replyTime":"2018-12-17T06:19:52.000Z","msg":"可以啊  詳細tg傾"},{"pid":"125d7c6f496f25e5214fb8754020366b26ccf360","tid":921051,"uid":144751,"like":0,"dislike":0,"score":0,"quote":{"pid":"b9c892fbb7c993bf56cb74ff154fb4baabda5985","tid":921051,"uid":161644,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-12T16:20:35.000Z","msg":"師兄可唔可以講解下點樣jazz improvisation"},"citedBy":0,"replyTime":"2018-12-17T06:27:47.000Z","msg":"即興jazz 初步最緊要捉到鼓既拍子 之後要熟樂理 熟指版  之後點樣係呢堆野入面玩 就好多元化 好難用幾句文字去講一種style點即興   主要可以youtube聽下啲大師彈了解下bass既jazz係點先"},{"pid":"9322b0a5052140807c3d5a040ab802efda58355a","tid":921051,"uid":144751,"like":0,"dislike":0,"score":0,"quote":{"pid":"f64614facb1021ad26b2f983d35defd92091cd5b","tid":921051,"uid":4660,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-12T16:34:58.000Z","msg":"巴打會係邊到教？ 學過幾年，手指傷左放低左幾年<br />\n而家有啲興趣想執返起枝bass"},"citedBy":0,"replyTime":"2018-12-17T06:28:27.000Z","msg":"主要係觀塘教  <br />\n 詳細可以tg傾"},{"pid":"f77428308b1fd3ee6f993e5d42b7cdb87cebedef","tid":921051,"uid":144751,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-06T01:50:30.000Z","msg":"推"},{"pid":"89325a5f8f0682ddd967a1d5b302f855d09d802d","tid":921051,"uid":83339,"like":0,"dislike":0,"score":0,"quote":{"pid":"a0ce6ea4ddb81c3fec37915c4399d22a4e3051bd","tid":921051,"uid":144751,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-29T09:18:04.000Z","msg":"第一次出post<br />\n有咩講錯或者1999希望各位巴絲體諒<br />\n <br />\n我自己就彈左9年bass左右<br />\n年紀唔算好大  但都叫做彈過下演唱會 <br />\n幫人support下<br />\n例如做過小肥小胖等等藝人既session bassist<br />\n<br />\n幾年前開始搵學生<br />\n果時有啲免費或者收幾十蚊一個鐘都有<br />\n果時都唔係為收幾錢   <br />\n而係覺得當學生慢慢進步 就好有成功感<br />\n <br />\n除左教bass之外   <br />\n我都會寫下歌 編下曲 錄音 混音咁 <br />\n但最熟既都一定係bass <br />\n而自己都有挾band都有出左幾首歌<br />\nYouTube 同各大平台都有得聽<br />\n想聽既可以tg我<br />\n<br />\n呢排就抽到多啲時間出黎<br />\n想再收下學生  <br />\n都見有巴絲開po話想學但係又冇乜前輩開po <br />\n<br />\n價錢方面 <br />\n始終唔係跟琴行 唔洗比琴行定死價錢 有意可傾傾<br />\n同埋時間都可以自由啲控制<br />\n<br />\n至於教學方面<br />\n主要我會分3類學生<br />\n1.唔識    2.有concept  3.熟悉<br />\n<br />\n1. 對於bass毫無基礎既朋友仔<br />\n我會比較重點講手指練習 拍子練習 同埋記指板既音 同埋基本樂理<br />\n<br />\n2. 對於有 concept 知道bass已經大致做緊乜  <br />\n但又會比較多甩漏 或者 <br />\n需要多一啲練習既朋友仔<br />\n我就會係著重汁譜練習多啲 <br />\n一開始就比啲譜你彈下<br />\n慢慢開始要你自己汁譜<br />\n<br />\n3. 對於想成為職業bass手 <br />\n或者自己有挾開band 已經彈到好多歌<br />\n但到自己度bass line又好似差啲咁<br />\n我就會係不同風格 不同scale 上去做練習<br />\n因應同學仔想要 想學 中意啲咩風格<br />\n而去做番一啲專業練習 <br />\n而可以自己創作bass line<br />\n<br />\n同埋如果同學仔由唔識比我教到熟 <br />\n就會少啲touching 既問題<br />\n如果唔係由0開始既學生 <br />\n我都會比較著重touching<br />\n<br />\n如果大家有關於bass上既問題<br />\n可以留言或者tg我   我會儘量解答<br />\n如果對我既教學有興趣嘅話<br />\n亦歡迎tg詳談<br />\n<br />\n<a href=\"https://t.me/rcihcokw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Frcihcokw&d=oW2ZKT0grFf0NVj5EkmC2P7vEz4FU%2Bq4m%2F6ZFrWLoTs%3D&h=3d106672\" data-auto-link target=\"_blank\">https://t.me/rcihcokw</a>"},"citedBy":1,"replyTime":"2019-02-07T14:18:40.000Z","msg":"唔中意bass 結他既搖滾音樂，但中意較soft音樂，好似冷雨夜既bass 結他，有咩結他野選擇？"},{"pid":"088402c13fcb945a07f8021080884fd2ee061231","tid":921051,"uid":83339,"like":0,"dislike":0,"score":0,"quote":{"pid":"89325a5f8f0682ddd967a1d5b302f855d09d802d","tid":921051,"uid":83339,"like":0,"dislike":0,"score":0,"quote":{"pid":"a0ce6ea4ddb81c3fec37915c4399d22a4e3051bd","tid":921051,"uid":144751,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-29T09:18:04.000Z","msg":"第一次出post<br />\n有咩講錯或者1999希望各位巴絲體諒<br />\n <br />\n我自己就彈左9年bass左右<br />\n年紀唔算好大  但都叫做彈過下演唱會 <br />\n幫人support下<br />\n例如做過小肥小胖等等藝人既session bassist<br />\n<br />\n幾年前開始搵學生<br />\n果時有啲免費或者收幾十蚊一個鐘都有<br />\n果時都唔係為收幾錢   <br />\n而係覺得當學生慢慢進步 就好有成功感<br />\n <br />\n除左教bass之外   <br />\n我都會寫下歌 編下曲 錄音 混音咁 <br />\n但最熟既都一定係bass <br />\n而自己都有挾band都有出左幾首歌<br />\nYouTube 同各大平台都有得聽<br />\n想聽既可以tg我<br />\n<br />\n呢排就抽到多啲時間出黎<br />\n想再收下學生  <br />\n都見有巴絲開po話想學但係又冇乜前輩開po <br />\n<br />\n價錢方面 <br />\n始終唔係跟琴行 唔洗比琴行定死價錢 有意可傾傾<br />\n同埋時間都可以自由啲控制<br />\n<br />\n至於教學方面<br />\n主要我會分3類學生<br />\n1.唔識    2.有concept  3.熟悉<br />\n<br />\n1. 對於bass毫無基礎既朋友仔<br />\n我會比較重點講手指練習 拍子練習 同埋記指板既音 同埋基本樂理<br />\n<br />\n2. 對於有 concept 知道bass已經大致做緊乜  <br />\n但又會比較多甩漏 或者 <br />\n需要多一啲練習既朋友仔<br />\n我就會係著重汁譜練習多啲 <br />\n一開始就比啲譜你彈下<br />\n慢慢開始要你自己汁譜<br />\n<br />\n3. 對於想成為職業bass手 <br />\n或者自己有挾開band 已經彈到好多歌<br />\n但到自己度bass line又好似差啲咁<br />\n我就會係不同風格 不同scale 上去做練習<br />\n因應同學仔想要 想學 中意啲咩風格<br />\n而去做番一啲專業練習 <br />\n而可以自己創作bass line<br />\n<br />\n同埋如果同學仔由唔識比我教到熟 <br />\n就會少啲touching 既問題<br />\n如果唔係由0開始既學生 <br />\n我都會比較著重touching<br />\n<br />\n如果大家有關於bass上既問題<br />\n可以留言或者tg我   我會儘量解答<br />\n如果對我既教學有興趣嘅話<br />\n亦歡迎tg詳談<br />\n<br />\n<a href=\"https://t.me/rcihcokw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2