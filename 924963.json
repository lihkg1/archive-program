r.lihkg.com/link?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fsport%2F20181201%2Fmobile%2Fbkn-20181201130028915-1201_00882_001.html&d=rTRvicHDFQga4If2T3r4LxOFz4pMHIf1Ti9x7C0XgVU%3D&h=108f637f\" target=\"_blank\">https://hk.on.cc/hk/bkn/cnt/sport/20181201/mobile/bkn-20181201130028915-1201_00882_001.html</a></blockquote>"},{"pid":"604f198dec4097f6b0b98c465a2a4091fd458a85","tid":924963,"uid":88862,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-12-03T08:42:50.000Z","msg":"此回覆已被刪除"},{"pid":"fde911061ef26731027cf3578117ce6741d27eb9","tid":924963,"uid":28028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-03T08:46:09.000Z","msg":"條女肯收幾十萬保密<br />\n依家都係想拎多筆和解金姐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n坐就實唔洗坐既"},{"pid":"0aa1c184ee1b7a25cf4fcb7bc9d9d776b14c8d98","tid":924963,"uid":92088,"like":1,"dislike":0,"score":1,"quote":{"pid":"e02655bf4e74a45ea81ca3e4e0851e88c82eea2d","tid":924963,"uid":22535,"like":9,"dislike":0,"score":9,"quote":{"pid":"945f64e98b342232e6a366d1f0a1ba5a4989f6b1","tid":924963,"uid":191391,"like":0,"dislike":0,"score":0,"quote":{"pid":"cc3001934a5d61ff3685edfbd48854fd7a44aa27","tid":924963,"uid":36044,"like":24,"dislike":0,"score":24,"citedBy":1,"replyTime":"2018-12-03T07:23:07.000Z","msg":"<img src=\"https://na.cx/i/06zdXaC.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F06zdXaC.gif&h=589f59ac&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-12-03T07:58:45.000Z","msg":"<img src=\"/assets/faces/big/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-12-03T08:20:55.000Z","msg":"廣東話，入呀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-12-03T08:47:26.000Z","msg":"似講，搞咩呀。多啲喎"},{"pid":"3d8cdcc66052afa408880d0ffeabdb7b2230aea5","tid":924963,"uid":202254,"like":0,"dislike":0,"score":0,"c