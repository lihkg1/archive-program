.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203634_176ff1340bdc35294716554a5e977fcd.jpg&h=13e7e0c7&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203634_94108d60486b2180e853e2b727b7e320.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203634_94108d60486b2180e853e2b727b7e320.jpg&h=189c4e44&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203635_94108d60486b2180e853e2b727b7e320.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203635_94108d60486b2180e853e2b727b7e320.jpg&h=f08bdee5&s={SIZE}\" /></blockquote><br />\n其實地鐵站個啲墨水字都好靚</blockquote><br />\n香港邊敢攪咁多野<br />\n到時又俾人屌做多餘野<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"}]}