hk.net/upload/2017/10/17/203635_94108d60486b2180e853e2b727b7e320.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203635_94108d60486b2180e853e2b727b7e320.jpg&h=f08bdee5&s={SIZE}\" />"},{"pid":"cc214533bdffa861303ace792819e17cd20b2b98","tid":420453,"uid":26506,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-17T12:38:30.000Z","msg":"<blockquote>班次/轉車系統咪好<br />\n成班港奴趕返工 當然話好</blockquote><br />\n&gt; 香港地理成功"},{"pid":"41a3d1d406b862d1f972733ce46a2bad5e3c9a13","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T12:39:22.000Z","msg":"<blockquote><blockquote>班次/轉車系統咪好<br />\n成班港奴趕返工 當然話好</blockquote><br />\n&gt; 香港地理成功</blockquote><br />\n[edit] 屌邊個推上嚟, 已經comment過"},{"pid":"ba44f6c0019c9416faa70d30e5cc2792a2b7fe95","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T12:44:12.000Z","msg":"<blockquote>我見韓國都有地下街，行到去下一站，香港唔可行？</blockquote><br />\n橫向平行線隔離個站定縱向條線下個站? <br />\n後者金鐘站-中環站遮打道月台同啟德站-宋王臺站做到 (一個理論上一個實際上)"},{"pid":"daa8372f315b4b35ca76302961afd933a06d28d6","tid":420453,"uid":43189,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2017-10-17T12:45:57.000Z","msg":"香港啲鐵路全部係有晒人先發展，咁緊係包賺"},{"pid":"aef64d03d0b0192265a5cebfc6561b8b60753e8c","tid":420453,"uid":80736,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-10-17T12:47:14.000Z","msg":"<blockquote><blockquote>我見韓國都有地下街，行到去下一站，香港唔可行？</blockquote><br />\n橫向平行線隔離個站定縱向條線下個站? <br />\n後者金鐘站-中環站遮打道月台同啟德站-宋王臺站做到 (一個理論上一個實際上)</blockquote><br />\n但宋王台站嗰個真係做到？<br />\n你好熟地鐵喎，你有研究開？"},{"pid":"3952433b88548362a8c39926854371a2ae7e5dd6","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T12:47:59.000Z","msg":"<blockquote>香港啲鐵路全部係有晒人先發展，咁緊係包賺</blockquote><br />\n錯啦, 兩個次序模式都咁成功"},{"pid":"7ce3b2574989aa041b3a4e1a178c5fd21aafab70","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T12:50:53.000Z","msg":"<blockquote><blockquote><blockquote>我見韓國都有地下街，行到去下一站，香港唔可行？</blockquote><br />\n橫向平行線隔離個站定縱向條線下個站? <br />\n後者金鐘站-中環站遮打道月台同啟德站-宋王臺站做到 (一個理論上一個實際上)</blockquote><br />\n但宋王台站嗰個真係做到？<br />\n你好熟地鐵喎，你有研究開？</blockquote><br />\n唔使問我, 港共政府個計劃已經提出咗, 想益地慘商"},{"pid":"1675d21c797981c4fb3703dc65349b047be8efac","tid":420453,"uid":38795,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T12:52:03.000Z","msg":"<blockquote><blockquote>香港啲鐵路全部係有晒人先發展，咁緊係包賺</blockquote><br />\n錯啦, 兩個次序模式都咁成功</blockquote><br />\n以前九龍灣德福嗰d算係先起地鐵再發展？"},{"pid":"8e02ed7fa5fcde6ae35c8e65423851f72677a822","tid":420453,"uid":80736,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T12:52:39.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>我見韓國都有地下街，行到去下一站，香港唔可行？</blockquote><br />\n橫向平行線隔離個站定縱向條線下個站? <br />\n後者金鐘站-中環站遮打道月台同啟德站-宋王臺站做到 (一個理論上一個實際上)</blockquote><br />\n但宋王台站嗰個真係做到？<br />\n你好熟地鐵喎，你有研究開？</blockquote><br />\n唔使問我, 港共政府個計劃已經提出咗, 想益地慘商</blockquote><br />\n地下城？唔係得尖沙咀彎仔同羅灣？"},{"pid":"441dd3d7d46c0f72bbadb6734ef49d886405b666","tid":420453,"uid":99642,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-10-17T13:03:03.000Z","msg":"<blockquote><blockquote>睇你覺得咩先叫成功<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <br />\n如果講營運同盈利呢方面又的確係幾成功</blockquote><br />\n好似完全冇人為設計喺入面，全商業活動<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 明明其實都算係公共空間嚟，又乜都唔畀做<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n其實中環香港站中間 以前間唔中有申請左既人仕表演音樂"},{"pid":"034685fb9f5f180c1b48223fd3304862cdb24a28","tid":420453,"uid":99642,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-10-17T13:05:21.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203634_176ff1340bdc35294716554a5e977fcd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203634_176ff1340bdc35294716554a5e977fcd.jpg&h=13e7e0c7&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203634_94108d60486b2180e853e2b727b7e320.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203634_94108d60486b2180e853e2b727b7e320.jpg&h=189c4e44&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203635_94108d60486b2180e853e2b727b7e320.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203635_94108d60486b2180e853e2b727b7e320.jpg&h=f08bdee5&s={SIZE}\" /></blockquote><br />\n其實地鐵站個啲墨水字都好靚"},{"pid":"d707fa489f286444e88f6f97b2dd6bdc2212ae55","tid":420453,"uid":52595,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T13:07:00.000Z","msg":"此回覆已被刪除"},{"pid":"ae79bf83b35c7a734a4e0c5c627882325bb372b3","tid":420453,"uid":80736,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-10-17T13:08:45.000Z","msg":"<blockquote><blockquote><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203634_176ff1340bdc35294716554a5e977fcd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203634_176ff1340bdc35294716554a5e977fcd.jpg&h=13e7e0c7&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203634_94108d60486b2180e853e2b727b7e320.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203634_94108d60486b2180e853e2b727b7e320.jpg&h=189c4e44&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203635_94108d60486b2180e853e2b727b7e320.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203635_94108d60486b2180e853e2b727b7e320.jpg&h=f08bdee5&s={SIZE}\" /></blockquote><br />\n其實地鐵站個啲墨水字都好靚</blockquote><br />\n<img src=\"/assets/faces/lomoji/29.png\" class=\"hkgmoji\" />"},{"pid":"ebe9bb632447d109afd74e20730f1874821f692d","tid":420453,"uid":52595,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-10-17T13:11:12.000Z","msg":"此回覆已被刪除"},{"pid":"8359bb138077da111964560114f9b6dc421f05af","tid":420453,"uid":55732,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2017-10-17T13:29:19.000Z","msg":"商業角度嚟睇超成功，佢呢種發展模式可以幫佢支配著一部分人嘅生活，食佢嘅住佢嘅搭車都係搵佢嘅<br />\n<br />\n社會角度嚟睇就見仁見智，我就覺得麻麻地<br />\n<br />\n佢的確係帶到較為舒適，快捷及有效率嘅服務，甚至可以話係一個集體運輸系統嘅典範<br />\n<br />\n佢嘅發展模式慢慢令班無車階級依賴地鐵公司嘅服務。變成佢嘅競爭越來越弱，尤其是交通選擇方面（雖然未至於話無競爭），最後佢話加價大家唯有焗食<br />\n<br />\n而且佢用住宅項目支持鐵路發展呢樣嘢，亦令到鐵路沿線嘅地方開始被佢嘅住宅項目侵蝕，街道文化被佢嘅商場取代。將軍澳已經係經典，家下西鐵沿線亦開始嚟料，元朗荃灣西南昌已經死起爛起<br />\n<br />\n所以政府/投資者角度嚟講，nothing can be better than MTR<br />\n但社會/市民角度嚟講，ok就ok嘅，不過有隱憂"},{"pid":"95321cc09332729d8b335119d58edfd0a9a93a71","tid":420453,"uid":53396,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-10-17T13:51:33.000Z","msg":"如果只計班次嘅話、香港應該完勝<br />\n你地睇下有邊一個國家做鐵路可以在繁忙時間2分鐘一班<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n<br />\n同埋每一個國家做鐵路都係蝕錢、唯獨狗鐵可以瘋狂賺錢"},{"pid":"dc730ec7f3b65c56af2422d7344560cb9178e289","tid":420453,"uid":149978,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-10-17T13:57:12.000Z","msg":"<blockquote>好似成日經過啲站，但毫無生活可言，全商業活動，我見人地外國地鐵站好多姿多彩，但我fd又話香港鐵路已經係全世界算好，得我覺得有問題？</blockquote><br />\n<br />\n香港有晒月台幕門，有升降機。<br />\n外國好多冇幕門。<br />\n所以香港好左呢度。"},{"pid":"2589b3eb29ef610d2e3f6773760e70f47ce70b1e","tid":420453,"uid":47674,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-10-17T14:00:12.000Z","msg":"<blockquote>商業角度嚟睇超成功，佢呢種發展模式可以幫佢支配著一部分人嘅生活，食佢嘅住佢嘅搭車都係搵佢嘅<br />\n<br />\n社會角度嚟睇就見仁見智，我就覺得麻麻地<br />\n<br />\n佢的確係帶到較為舒適，快捷及有效率嘅服務，甚至可以話係一個集體運輸系統嘅典範<br />\n<br />\n佢嘅發展模式慢慢令班無車階級依賴地鐵公司嘅服務。變成佢嘅競爭越來越弱，尤其是交通選擇方面（雖然未至於話無競爭），最後佢話加價大家唯有焗食<br />\n<br />\n而且佢用住宅項目支持鐵路發展呢樣嘢，亦令到鐵路沿線嘅地方開始被佢嘅住宅項目侵蝕，街道文化被佢嘅商場取代。將軍澳已經係經典，家下西鐵沿線亦開始嚟料，元朗荃灣西南昌已經死起爛起<br />\n<br />\n所以政府/投資者角度嚟講，nothing can be better than MTR<br />\n但社會/市民角度嚟講，ok就ok嘅，不過有隱憂</blockquote><br />\ngentrification，其實好難免<br />\n交通方便咗，租金自然上升，連鎖店取代街坊小店<br />\n但你冇方便交通，珍貴土地又未能地盡其用"},{"pid":"b9e2703db636c5a1f453f7c8b047aa6fcd773321","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T15:34:56.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203634_176ff1340bdc35294716554a5e977fcd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203634_176ff1340bdc35294716554a5e977fcd.jpg&h=13e7e0c7&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203634_94108d60486b2180e853e2b727b7e320.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203634_94108d60486b2180e853e2b727b7e320.jpg&h=189c4e44&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/10/17/203635_94108d60486b2180e853e2b727b7e320.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F17%2F203635_94108d60486b2180e853e2b727b7e320.jpg&h=f08bdee5&s={SIZE}\" /></blockquote><br />\n莫斯科地鐵大深度做埋防空洞, 舒緩侷促感同有位咪做得, 畢竟有可能要住人住成世"},{"pid":"64313ea06da8b63c3b18b37781faf1421f483d18","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T15:41:28.000Z","msg":"<blockquote>如果只計班次嘅話、香港應該完勝<br />\n你地睇下有邊一個國家做鐵路可以在繁忙時間2分鐘一班<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n<br />\n同埋每一個國家做鐵路都係蝕錢、唯獨狗鐵可以瘋狂賺錢</blockquote> <br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n1. 好多國家理論上同實際上都做到 <br />\n2. 地理同密度問題, 啫係香港先天同鐵路上exogenously完勝 <br />\n3. 公營機構好多唔志在賺錢要嚟提供社會福利同服務, 履行社會責任 <br />\n班次香港勝咗非繁延續到頻密服務"},{"pid":"a6fb9930d69239a8dfc3fe979202e350e986dc15","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T15:42:25.000Z","msg":"<blockquote><blockquote>好似成日經過啲站，但毫無生活可言，全商業活動，我見人地外國地鐵站好多姿多彩，但我fd又話香港鐵路已經係全世界算好，得我覺得有問題？</blockquote><br />\n<br />\n香港有晒月台幕門，有升降機。<br />\n外國好多冇幕門。<br />\n所以香港好左呢度。</blockquote> <br />\n1. 閘門都得㗎  <br />\n2. 歷史同結構限制, 有時再加通風"},{"pid":"15b26e9c4bbaa0ff5a0d4748d518d0e6e798f6f4","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T15:46:19.000Z","msg":"<blockquote>台北捷運已經好過港鐵！多數有位坐！<br />\nd位又舒服！<br />\n而且張悠遊卡又可以用碎銀增值！<br />\n香港八達通淨係收銀紙咋！</blockquote><br />\n1. 載客率問題, 啫係地理同密度問題 <br />\n2. 台北會有多過香港嘅中型鐵路線, 重鐵車組都短過香港"},{"pid":"681946aa56979a35ef6a17ff8cfea586dff2e042","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T15:55:16.000Z","msg":"<blockquote><blockquote><blockquote>香港啲鐵路全部係有晒人先發展，咁緊係包賺</blockquote><br />\n錯啦, 兩個次序模式都咁成功</blockquote><br />\n以前九龍灣德福嗰d算係先起地鐵再發展？</blockquote><br />\n九龍灣車廠有佐敦谷牛頭角同九龍灣商貿區算個混合例子, 其他都係 textbook example <br />\n西九填海區,將軍澳市中心,東涌明顯啲"},{"pid":"83998148e5de8d12835ddda089e44092f3acae57","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T15:56:44.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote>我見韓國都有地下街，行到去下一站，香港唔可行？</blockquote><br />\n橫向平行線隔離個站定縱向條線下個站? <br />\n後者金鐘站-中環站遮打道月台同啟德站-宋王臺站做到 (一個理論上一個實際上)</blockquote><br />\n但宋王台站嗰個真係做到？<br />\n你好熟地鐵喎，你有研究開？</blockquote><br />\n唔使問我, 港共政府個計劃已經提出咗, 想益地慘商</blockquote><br />\n地下城？唔係得尖沙咀彎仔同羅灣？</blockquote><br />\n你都識講地下城,呢幾個係多層地下發展做商場"},{"pid":"1ecb42b6d56f169e0ce69ffc663d2ecd300b2e70","tid":420453,"uid":47674,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-17T16:35:13.000Z","msg":"成功改變香港地名<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> <br />\n油麻地、尖沙咀之間改咗叫佐敦<br />\n中環同灣仔之間改咗叫金鐘<br />\n長沙灣變咗荔枝角<br />\n東角變咗銅鑼灣<br />\n維園變埋銅鑼灣北<br />\n土瓜灣差啲變咗馬頭圍"},{"pid":"7afbeb9e381dfd376c14eae73314a7c0ac080c92","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T16:40:30.000Z","msg":"<blockquote>成功改變香港地名<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> <br />\n油麻地、尖沙咀之間改咗叫佐敦<br />\n中環同灣仔之間改咗叫金鐘<br />\n長沙灣變咗荔枝角<br />\n東角變咗銅鑼灣<br />\n維園變埋銅鑼灣北<br />\n土瓜灣差啲變咗馬頭圍</blockquote><br />\n又嚟 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n地名上銅鑼灣北同維園有咩關係都重未講到"},{"pid":"4d9d4c088cad7477306e3741cec16dc2fae5b857","tid":420453,"uid":47674,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-10-17T16:48:13.000Z","msg":"<blockquote><blockquote>成功改變香港地名<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> <br />\n油麻地、尖沙咀之間改咗叫佐敦<br />\n中環同灣仔之間改咗叫金鐘<br />\n長沙灣變咗荔枝角<br />\n東角變咗銅鑼灣<br />\n維園變埋銅鑼灣北<br />\n土瓜灣差啲變咗馬頭圍</blockquote><br />\n又嚟 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n地名上銅鑼灣北同維園有咩關係都重未講到</blockquote><br />\n<img src=\"http://4.bp.blogspot.com/-Pm9AU7xQViw/USofly4Dc1I/AAAAAAAACxw/IsShqr-QnJk/s1600/X0nb.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2F4.bp.blogspot.com%2F-Pm9AU7xQViw%2FUSofly4Dc1I%2FAAAAAAAACxw%2FIsShqr-QnJk%2Fs1600%2FX0nb.jpeg&h=792e0174&s={SIZE}\" /><br />\n踩到一半入維園都唔叫維園站<br />\n咁會展站完全掂唔到會展又點解釋<br />\n我覺得應該叫灣仔北站同維園站囉<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"50b94eb362cfb8cc83ce31ecb1c07482e3905cc1","tid":420453,"uid":43189,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-17T16:59:09.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>香港啲鐵路全部係有晒人先發展，咁緊係包賺</blockquote><br />\n錯啦, 兩個次序模式都咁成功</blockquote><br />\n以前九龍灣德福嗰d算係先起地鐵再發展？</blockquote><br />\n九龍灣車廠有佐敦谷牛頭角同九龍灣商貿區算個混合例子, 其他都係 textbook example <br />\n西九填海區,將軍澳市中心,東涌明顯啲</blockquote><br />\n以香港人口密度根本點起都係包賺["},{"pid":"00229537e7bc34c395ab19072b4f4ad22ca08610","tid":420453,"uid":89857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T17:02:06.000Z","msg":"咁多人話港鐵車費貴<br />\n<br />\n其實買佢d股票做返對沖吧啦<br />\nif you can't beat them join them"},{"pid":"4863a85aa730390c5de43f31496815de472be295","tid":420453,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-17T17:03:08.000Z","msg":"<blockquote><blockquote><blockquote>成功改變香港地名<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /> <br />\n