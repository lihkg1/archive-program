rc=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"cd95c25bbce57043153dd61e8ed18fa049ccc254","tid":764341,"uid":48083,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d215592aa2c82e5d869534d722f50e8148222c9","tid":764341,"uid":156363,"like":16,"dislike":0,"score":16,"quote":{"pid":"067087d77fc3418e78ac82bb10441018e06bd2df","tid":764341,"uid":54876,"like":0,"dislike":1,"score":-1,"quote":{"pid":"88c49c3cadd64f6fbaea8d5c794be60a04f41ca4","tid":764341,"uid":4917,"like":1,"dislike":3,"score":-2,"citedBy":5,"replyTime":"2018-08-02T02:57:30.000Z","msg":"60年代打呢D疫苗嘅人又唔見出事？"},"citedBy":1,"replyTime":"2018-08-02T04:25:46.000Z","msg":"俾細路打嘅疫苗，出事嗰班死哂啦"},"citedBy":2,"replyTime":"2018-08-02T04:34:06.000Z","msg":"以前大陸既疫苗全部由日本作為戰後補償提供架，到2008年見你咁有米搞京奧先取消人道援助。"},"citedBy":1,"replyTime":"2018-08-02T04:51:03.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"6e02f843beb4c0acfd36159daba95f1766ad15f0","tid":764341,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-02T04:51:14.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"1b94ee242a364b51ec15209abce005b8bbb8e98c","tid":764341,"uid":21028,"like":1,"dislike":1,"score":0,"quote":{"pid":"8cbaf20550baac97a03a0fbdd23caee5d7844ee8","tid":764341,"uid":66943,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2018-08-02T04:41:50.000Z","msg":"大陸人早要嚴正聲明愛國不愛黨啦"},"citedBy":0,"replyTime":"2018-08-02T04:53:15.000Z","msg":"一早就黨等於國家 佢地每個人既思想"}]}