d2584d094d821621e217952","tid":2083561,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-29T00:30:02.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"f766eb1df18c9ba284ed8a38592a5d768cf088c8","tid":2083561,"uid":3357,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-29T00:32:40.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"a8e183290418603b77f118aebbe5c3f8e4f81828","tid":2083561,"uid":12824,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-29T01:05:13.000Z","msg":"<img src=\"/assets/faces/dog/fight_connect2.gif\" class=\"hkgmoji\" />"},{"pid":"54db193d0a5a943f3e88fd76fda624ccc406be06","tid":2083561,"uid":51937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-29T01:09:05.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"03e24e6f01a495822823f8b6e4724e9ad209bbf7","tid":2083561,"uid":343798,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-29T01:15:31.000Z","msg":"啱呀 唔好淨係喺連登吹雞 <br />\nFb ig airdrop都要做"},{"pid":"c5ed1c407bf69501a58a0fd748d846310a799011","tid":2083561,"uid":343798,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-29T01:15:43.000Z","msg":"<img src=\"https://na.cx/i/wHXBjiU.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwHXBjiU.gif&h=cbd0bceb&s={SIZE}\" />"},{"pid":"a80131bc4af48458508eb094a32f807f6bbe4eb3","tid":2083561,"uid":217089,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-29T01:19:12.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"d315d2cad82bdc7d338c867884bc4debe2b9d2e7","tid":2083561,"uid":304769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-29T01:19:45.000Z","msg":"七一見<br />\n<br />\n今年七一要加主題：<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\"><br />\n寧願最後不得善終<br />\n也不考慮含淚折衷<br />\n<br />\n我要美國制裁，無懼與支共同歸於盡，寧死捍衛自由民主</span></span></strong><br />\n<br />\n認同就拎張紙舉比美國睇，咪比條廢老Martin Lee騎劫我地，搞到美國以為我地驚攬炒而唔做野<br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">黃世澤出左香港自治法篤灰指南，好有用，大家入去睇</span></span></strong><br />\n<br />\n\t<br />\n\t<a href=\"https://youtu.be/s6o2r5DkT-w\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fs6o2r5DkT-w&d=wLbnxcWodPR608ZqId7G8Wo8q5%2FbnpuKyKF%2Fs7IAglk%3D&h=341f0540\" target=\"_blank\">https://youtu.be/s6o2r5DkT-w</a><br />\n<br />\n<br />\n借個位<br />\n正視聽：若抗爭方向不隨局勢改變，只會無謂地損兵折將<br />\n香港街頭抗爭目標，亦都係街頭抗爭最大效果；&ldquo;攬炒&rdquo;已經達到，今次搞蟈安法其實仲攬炒過上年出老解。<br />\n宜家<strong><span style=\"color: red;\">跟著落黎就係引導全球政府同議會（尤其美國）對付支那以及滅共</span></strong>，所以大家重點應該著眼帶出清晰民意授權比各國政府做野，畫面靚+全球廣泛報導（類似反蟈安法銅鑼灣自由行）係最理想，用選票帶出民意亦十分重要。<br />\n<br />\n<strong><span style=\"color: red;\">大家要小心五毛、熱狗放負風向：美國唔會幫我地（舊年年尾）-》英國係廢國無用架（今年年頭）-》歐盟奶共唔會幫我地（宜家）</span></strong><br />\n<br />\n大家要記住，香港生路只有一條：救香港人+攬炒促進支爆+重建香港。<strong><span style=\"color: red;\">沒有支爆，香港獨立或者歸英等重建方案全部都係痴人說夢。</span></strong><br />\n<br />\n未來幾個月至支共瓦解期間大家要做嘅事：1.<strong><span style=\"color: red;\">走資</span></strong>2.全球救生艇<strong><span style=\"color: red;\">救手足加有細路既黃絲家庭</span></strong>（細路是重點，香港未來棟樑，正如今時今日d前線義士，咪比佢地洗腦變小糞紅，否則香港係真正玩完）3.比足夠<strong><span style=\"color: red;\">民意授權，敦促美國以至各國凌遲式消除香港作為支那獲得外資渠道</span></strong>，包括但不限於：禁止美國個人或公司投資港股，暫停接受香港用美元結算等等4.最後就真係等<span style=\"color: red;\"><strong>支那自己爆</strong></span>"},{"pid":"c643ed5bd04d1d05b316bf5382ba4f93adbf69b3","tid":2083561,"uid":14494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-29T01:32:11.000Z","msg":"次次都一支公去 點解冇fd撩我<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1e0abe178126e9ef393d09f071bb6b1638fd8418","tid":2083561,"uid":180499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-29T01:41:37.000Z","msg":"推"}]}