{"tid":2372850,"cid":5,"subCid":11,"title":"區諾軒以大聲公襲警案上訴至高等法院被駁回 維持兩項襲警罪罪成","createTime":"2021-01-20T04:35:58.000Z","updateTime":"2021-01-20T10:34:36.000Z","uid":240362,"like":1,"dislike":22,"uniUserReply":23,"replies":[{"pid":"871c82fa9049e440b468ce1d1289bcdcfbad3a9f","tid":2372850,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-20T04:35:58.000Z","msg":"<a href=\"https://t.me/nowtv_news/55635\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fnowtv_news%2F55635&d=CthjHxCXz%2Bl0vOF3eBkmemWjTds15DFTxBM9bbMqy3g%3D&h=f8c18752\" data-auto-link target=\"_blank\">https://t.me/nowtv_news/55635</a><br />\n<br />\n#ALERT 區諾軒以大聲公襲警案上訴至高等法院被駁回，維持兩項襲警罪罪成 (1/20/12:34)"},{"pid":"39b816cf2eaf7cb80ccb0e8a7b3231400990e38d","tid":2372850,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-20T04:36:09.000Z","msg":"<img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" />"},{"pid":"30ae65dfa7f3f7d5f9195d5837e3bf2b634d6677","tid":2372850,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-20T04:37:29.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"22d8634e97aafb683dea2ebea39645f9d3d57372","tid":2372850,"uid":51752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-20T04:37:51.000Z","msg":"<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"c94b16e6dfa9edaef155c4379648f1a0701c4475",