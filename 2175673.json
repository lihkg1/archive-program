46億元，但是廣收入則按年減少46%至5300萬元，因此該部門整體收入按年跌11%至2.02億元，獲利只100萬元，按年大減96%。<br />\n<br />\n<a href=\"https://www.mpfinance.com/fin/instantf2.php?node=1598448763833&amp;issue=20200826\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.mpfinance.com%2Ffin%2Finstantf2.php%3Fnode%3D1598448763833%26issue%3D20200826&d=hjP0Q4X6c9sJGZoCRXhatiPhHSzXeBMEaaQhzK3ZYsY%3D&h=9d715c5f\" target=\"_blank\">https://www.mpfinance.com/fin/instantf2.php?node=1598448763833&amp;issue=20200826</a></blockquote>"},{"pid":"ff0544afd72262da585d1657e39ea9b2cc26b69c","tid":2175673,"uid":221894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-26T18:07:14.000Z","msg":"push"},{"pid":"cbd6c69ba305ae38cb1cc8fc6227138cd1b3e517","tid":2175673,"uid":221894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-26T18:07:24.000Z","msg":"push"},{"pid":"d359b06bb0e58c05c45d84132cea2b6bc38e38ec","tid":2175673,"uid":14244,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-26T18:17:51.000Z","msg":"三個字抵撚死呀<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"}]}