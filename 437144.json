bd1.gif&h=ae56e6b0&s={SIZE}\" />"},{"pid":"ff4ad7854780b64f661e20d368dcc66b0810e1c6","tid":437144,"uid":131526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-15T17:36:15.000Z","msg":"執柒左佢啦"},{"pid":"a5596e3b85888b37c7f77278b4b1225547241036","tid":437144,"uid":45788,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-15T17:36:48.000Z","msg":"走進水世界"},{"pid":"63dce5674b97b6ad9c355bced65a8c4aa41f7f99","tid":437144,"uid":19454,"like":16,"dislike":1,"score":15,"citedBy":0,"replyTime":"2017-10-15T17:36:50.000Z","msg":"<img src=\"https://www.cool-gif.com/media/gif/ea/0c/ea0c373679a29b74b163fe4527244e79/cool.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.cool-gif.com%2Fmedia%2Fgif%2Fea%2F0c%2Fea0c373679a29b74b163fe4527244e79%2Fcool.gif&h=b880cc34&s={SIZE}\" />"},{"pid":"150639d83505aadfd4b882ae49d4251a17685097","tid":437144,"uid":87511,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-15T17:39:54.000Z","msg":"<blockquote><span style=\"color: red;\">關注團體擔心同類事故陸續有來，阻礙連接路的完工日期。</span><br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> 淨係驚影響完工 唔係驚條橋既質素唔合格<br />\n通車後再有咩事就關人命事 係咪唔影響到完工就唔洗理條橋既品質？</blockquote><br />\n<br />\n完工我仲撚驚<br />\n老閪都唔會搭啲行經呢段路嘅車"},{"pid":"33858e976f008a1cf7e6ae532cfa4aa53c1b2e02","tid":437144,"uid":6347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-15T17:45:42.000Z","msg":"<blockquote><blockquote><span style=\"color: red;\">關注團體擔心同類事故陸續有來，阻礙連接路的完工日期。</span><br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> 淨係驚影響完工 唔係驚條橋既質素唔合格<br />\n通車後再有咩事就關人命事 係咪唔影響到完工就唔洗理條橋既品質？</blockquote><br />\n<br />\n完工我仲撚驚<br />\n老閪都唔會搭啲行經呢段路嘅車</blockquote><br />\n香港版龍出生天"},{"pid":"ef4bfd120d74987015c45386e85159b645096f41","tid":437144,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-15T17:49:21.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"9887eeb7dd756fa7b64ae32ba2f9930c897e0915","tid":437144,"uid":13503,"like":3,"dislike":22,"score":-19,"citedBy":0,"replyTime":"2017-10-15T17:49:29.000Z","msg":"港珠澳大橋島隧工程總工程師林鳴<br />\n卻在一檔節目中告訴我們<br />\n在建造大橋最引人矚目的<br />\n海底隧道部分的時候<br />\n我們曾經想引進荷蘭人的一個專利<br />\n而他們竟然漫天開價<br />\n一個專利張口就是15億<br />\n<br />\n於是，雙方鬧崩<br />\n我們決定自己攻關<br />\n最後的結果是，我們不但後來居上<br />\n解決了這個技術難題<br />\n實現了世界級的技術突破<br />\n還完成了港珠澳大橋<br />\n這個全世界難度最高的跨海大橋<br />\n還被西方人稱為<br />\n「新世界七大奇跡」之一！"},{"pid":"3b83f826d487a19173199db4d5388082f2e70cc0","tid":437144,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-15T17:53:08.000Z","msg":"<blockquote>其實「屯門至赤鱲角連接路」真係好無美感，應該叫赤龍隧道，一邊係赤鱲角、一邊係屯門龍門路，成件事即刻型咗<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" /></blockquote><br />\n1. Link應該譯幹線 (Ct Lantau Link, Lantau Fixed Crossing) <br />\n2. 個人一直叫屯赤龍鼓隧道(南段引道唔使名掛), 將藍照鏡環山隧道"},{"pid":"9c8c7bfe5b92b4156c9e6f99a66909eee72e3906","tid":437144,"uid":49955,"like":2,"dislike":45,"score":-43,"citedBy":0,"replyTime":"2017-10-15T17:59:06.000Z","msg":"水为财<br />\n没事儿没事儿"},{"pid":"c8b5ebe64004916a5c92066502c0f0ebddc49e59","tid":437144,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-15T17:59:14.000Z","msg":"地盤佬<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"a26ea81872b632a4469b314bef9452994b614785","tid":437144,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-15T17:59:40.000Z","msg":"<blockquote><blockquote><blockquote>其實「屯門至赤鱲角連接路」真係好無美感，應該叫赤龍隧道，一邊係赤鱲角、一邊係屯門龍門路，成件事即刻型咗<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" /></blockquote><br />\n雖然好中二病，但都好過原名先</blockquote></blockquote><br />\n唔關事, 最基本工程規劃名反映唔到個地位(當然呢個涉及&quot;link&quot;同&quot;連接路點解&quot;), CTS-3定以前命名好都唔太同意, 對比對岸10號幹線掃管笏連接路同中灣繞道東區走廊連接路唔consistent"},{"pid":"238cee30a6e42dda67f3338e961b0f395dff8d59","tid":437144,"uid":47674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-15T18:00:13.000Z","msg":"<blockquote><blockquote>其實「屯門至赤鱲角連接路」真係好無美感，應該叫赤龍隧道，一邊係赤鱲角、一邊係屯門龍門路，成件事即刻型咗<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" /></blockquote><br />\n1. Link應該譯幹線 (Ct Lantau Link, Lantau Fixed Crossing) <br />\n2. 個人一直叫屯赤龍鼓隧道(南段引道唔使名掛), 將藍照鏡環山隧道</blockquote><br />\n應該叫赤鱲角北隧道"},{"pid":"2bed04ba812289ea20c8370b512d57367d78fef4","tid":437144,"uid":70135,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-15T18:02:57.000Z","msg":"<blockquote>港珠澳大橋島隧工程總工程師林鳴<br />\n卻在一檔節目中告訴我們<br />\n在建造大橋最引人矚目的<br />\n海底隧道部分的時候<br />\n我們曾經想引進荷蘭人的一個專利<br />\n而他們竟然漫天開價<br />\n一個專利張口就是15億<br />\n<br />\n於是，雙方鬧崩<br />\n我們決定自己攻關<br />\n最後的結果是，我們不但後來居上<br />\n解決了這個技術難題<br />\n實現了世界級的技術突破<br />\n還完成了港珠澳大橋<br />\n這個全世界難度最高的跨海大橋<br />\n還被西方人稱為<br />\n「新世界七大奇跡」之一！</blockquote><br />\n<br />\n但造價係500億<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e247b1bc4099e5bf4cf10cfe15a069ab872db5c6","tid":437144,"uid":5220,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-15T18:03:26.000Z","msg":"<blockquote><blockquote><span style=\"color: red;\">關注團體擔心同類事故陸續有來，阻礙連接路的完工日期。</span><br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> 淨係驚影響完工 唔係驚條橋既質素唔合格<br />\n通車後再有咩事就關人命事 係咪唔影響到完工就唔洗理條橋既品質？</blockquote><br />\n<br />\n完工我仲撚驚<br />\n老閪都唔會搭啲行經呢段路嘅車</blockquote><br />\n希望到時噴射飛航仲做得住啦<img src=\"/assets/faces/lomoji/25.png\" class=\"hkgmoji\" />"},{"pid":"73b4cc3987732d2826a3d4a9a65711dc77647ae8","tid":437144,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-15T18:05:18.000Z","msg":"<blockquote><blockquote>其實「屯門至赤鱲角連接路」真係好無美感，應該叫赤龍隧道，一邊係赤鱲角、一邊係屯門龍門路，成件事即刻型咗<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" /></blockquote><br />\n1. Link應該譯幹線 (Ct Lantau Link, Lantau Fixed Crossing) <br />\n2. 個人一直叫屯赤龍鼓隧道(南段引道唔使名掛), 將藍照鏡環山隧道</blockquote><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/10/16/020517_dc49c619c30afcb4eac92b612f0a4e72.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F16%2F020517_dc49c619c30afcb4eac