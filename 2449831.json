aces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-17T03:58:00.000Z","msg":"做咁多嘢賺2K仲要俾人拉咗<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ce45c5337d521438b6f2b09d1717ef7ba0ce4a79","tid":2449831,"uid":238920,"like":0,"dislike":2,"score":-2,"quote":{"pid":"fac801414a85fea91788ba55a434820e5267aa77","tid":2449831,"uid":117584,"like":0,"dislike":3,"score":-3,"quote":{"pid":"a3c51ca3411e93823b2a7d58204d7eac83cd2fa2","tid":2449831,"uid":238920,"like":20,"dislike":1,"score":19,"citedBy":1,"replyTime":"2021-03-17T03:30:15.000Z","msg":"重點係房入面有CCTV"},"citedBy":1,"replyTime":"2021-03-17T03:48:53.000Z","msg":"邊到有寫房入邊有cctv<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-17T04:00:04.000Z","msg":"支那興帶個犯去現場影相<br />\n你望張相條友上左手扣,即係犯,指住部電腦<br />\n即係果度就係佢偷野既地方<br />\n你睇下個背景係咪房囉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"fecc8610235ad8f9ae4adf59be4f0f00918796bd","tid":2449831,"uid":253829,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2021-03-17T03:49:18.000Z","msg":"發現畫面的亮度與房間的另一電腦不同<br />\n<br />\n錯就錯在佢無偷埋某一部張卡<img src=\"/assets/faces/pig/nope.gif\" class=\"hkgmoji\" />"}}