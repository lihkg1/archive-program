25be%25bf%25e8%25a1%25a3%25e8%25ad%25a6%25e6%258b%25984%25e5%25ad%25b8%25e7%2594%259f-%25e5%25a5%25b3%25e7%2594%259f%25e8%25a2%25ab%25e5%259d%2590%25e9%25a0%25b8%25e9%2583%25a8%25e5%2588%25b6%25e6%259c%258d%25e8%25ad%25a6%25e7%25a8%25b1%25e6%259c%2580%25e4%25bd%258e%25e6%25ad%25a6%25e5%258a%259b-%25e5%2585%25a9%25e6%25a0%25a1%25e8%25ad%2589%25e5%25af%25a6%25e6%259c%2589%25e5%25ad%25b8%25e7%2594%259f%25e8%25a2%25ab%25e6%258d%2595&d=sHvBfS5bCv0nfD6zjI7mDdey%2FoW3U1ZMpR7BmJTbZh4%3D&h=8cb811ea\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%25e6%25b8%25af%25e8%2581%259e%2Farticle%2F20191204%2Fs00001%2F1575427317046%2F%25e5%259c%259f%25e7%2593%259c%25e7%2581%25a3%25e4%25be%25bf%25e8%25a1%25a3%25e8%25ad%25a6%25e6%258b%25984%25e5%25ad%25b8%25e7%2594%259f-%25e5%25a5%25b3%25e7%2594%259f%25e8%25a2%25ab%25e5%259d%2590%25e9%25a0%25b8%25e9%2583%25a8%25e5%2588%25b6%25e6%259c%258d%25e8%25ad%25a6%25e7%25a8%25b1%25e6%259c%2580%25e4%25bd%258e%25e6%25ad%25a6%25e5%258a%259b-%25e5%2585%25a9%25e6%25a0%25a1%25e8%25ad%2589%25e5%25af%25a6%25e6%259c%2589%25e5%25ad%25b8%25e7%2594%259f%25e8%25a2%25ab%25e6%258d%2595&h=6f5c26c6\" data-auto-link target=\"_blank\">https://m.mingpao.com/ins/%e6%b8%af%e8%81%9e/article/20191204/s00001/1575427317046/%e5%9c%9f%e7%93%9c%e7%81%a3%e4%be%bf%e8%a1%a3%e8%ad%a6%e6%8b%984%e5%ad%b8%e7%94%9f-%e5%a5%b3%e7%94%9f%e8%a2%ab%e5%9d%90%e9%a0%b8%e9%83%a8%e5%88%b6%e6%9c%8d%e8%ad%a6%e7%a8%b1%e6%9c%80%e4%bd%8e%e6%ad%a6%e5%8a%9b-%e5%85%a9%e6%a0%a1%e8%ad%89%e5%af%a6%e6%9c%89%e5%ad%b8%e7%94%9f%e8%a2%ab%e6%8d%95</a><br />\n<span style=\"font-size: x-large;\">部分行動失敗原因：</span><br />\n係因為係<strong>同一班人</strong>係學校附近地點或返學時間搞。你<strong>昨日搞完，今日又搞</strong>，人哋一定早有預防，<strong>返學時間、學校附近</strong>，要防有幾難？<br />\n新聞：&darr;<br />\n昨早（3日）7時許，約10名身穿校服的示威者，於<strong>馬頭圍道與譚公道交界</strong>以雪糕筒堵路，並毁壞途經巴士，導致附近一帶交通擠塞，影響市民上學上班。<strong>針對上述行為</strong>，警方今早（4日）7時15分展開部署行動，於<strong>馬頭圍道與譚公道一燈位</strong>，發現7至8名身穿校服、戴口罩及手套的示威者，以同一手法堵路，並以噴漆塗鴉途經巴士。"}]}