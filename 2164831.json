f1b3214e83510a75a","tid":2164831,"uid":50672,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-08-21T04:13:36.000Z","msg":"其樓主有冇揾CS跟過？ <br />\n我屌完CS。佢第二日就解左我鎖。<br />\n<br />\nANYWAY, 都多謝你，剩係知自己電話有時上網好慢，完全冇諗過係俾人限咗速。"},"citedBy":1,"replyTime":"2020-08-21T16:04:08.000Z","msg":"咁好 佢死撐話係我接收問題"},{"pid":"a8ddb64494b585c84480e2deab09e0069e252b7b","tid":2164831,"uid":50672,"like":0,"dislike":0,"score":0,"quote":{"pid":"d239a0a99b6341dcfdc2e5d4bbd58ca7e997cb04","tid":2164831,"uid":9193,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0e2a91ac8dfaf238b9c0229f1b3214e83510a75a","tid":2164831,"uid":50672,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-08-21T04:13:36.000Z","msg":"其樓主有冇揾CS跟過？ <br />\n我屌完CS。佢第二日就解左我鎖。<br />\n<br />\nANYWAY, 都多謝你，剩係知自己電話有時上網好慢，完全冇諗過係俾人限咗速。"},"citedBy":1,"replyTime":"2020-08-21T16:04:08.000Z","msg":"咁好 佢死撐話係我接收問題"},"citedBy":0,"replyTime":"2020-08-21T18:32:44.000Z","msg":"上兩個星期有條友whatsapp 我，話係 3 嘅CS，為提升服務質素，有個一對一服務，以後有咩問題可以直接whatsapp佢。<br />\n<br />\n咁岩又睇到你一連串嘅post。我就連續3日，每日test 兩次，屋企/公司一次，搭車返工/放工一次。random 時間，試過半夜3點試，都係4mb幾。<br />\n<br />\n仲要明明睇住佢衝緊上幾廿mb，然後跌返落幾mb。咁我咪cap晒圖，mark晒時間，諗住揾返whatsapp條CS 屌佢。<br />\n<br />\n點知我第一句問佢做乜限我速，佢就話幫我pass俾工程部幫我跟，7日內睇下有冇改善。<br />\n<br />\n我每個月23號止數，同CS Whatsapp 係17號，18號用落唔覺有問題，做野又忙，冇左件事，19號test 已經有返9x MB。<br />\n<br />\n最後我啲CAP圖都係冇出動到。"},{"pid":"5947dee9048e67e32e4dec4106067cca6f09f90f","tid":2164831,"uid":340623,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-22T04:28:50.000Z","msg":"其實間間都限速，點解咁多人屌3？<br />\n<a href=\"https://lih.kg/2168781\" data-auto-link target=\"_blank\">https://lih.kg/2168781</a>"},{"pid":"a0010098bf7cf2a53cf65a00e2de08cc2609c4ed","tid":2164831,"uid":340623,"like":0,"dislike":0,"score":0,"quote":{"pid":"5947dee9048e67e32e4dec4106067cca6f09f90f","tid":2164831,"uid":340623,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-22T04:28:50.000Z","msg":"其實間間都限速，點解咁多人屌3？<br />\n<a href=\"https://lih.kg/2168781\" data-auto-link target=\"_blank\">https://lih