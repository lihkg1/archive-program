{"tid":1193120,"cid":5,"subCid":0,"title":"美國再次關注港府修訂逃犯條例 稱一國兩制框架遭侵蝕 影響香港特殊地位","createTime":"2019-06-08T18:11:49.000Z","updateTime":"2019-06-09T06:01:20.000Z","uid":13663,"like":16,"dislike":0,"uniUserReply":3,"replies":[{"pid":"f54ca7ea08cd272dfd2075e36f2565b2b11991f2","tid":1193120,"uid":13663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-08T18:11:49.000Z","msg":"香港電台-國際2019年6月8日 下午4:55 [UTC]<br />\n美國再就特區政府修訂逃犯條例表達關注。<br />\n<br />\n美國國務院發言人表示，美國政府正密切監察及關注特區政府建議修訂的逃犯條例，發言人重申，一國兩制的框架正在持續地遭到侵蝕，並且威脅到香港長期在國際事務上建立的特珠地位。"},{"pid":"5275df5259f47d23d6353f95294ddb95a6c38139","tid":1193120,"uid":13663,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-08T18:15:34.000Z","msg":"<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1461626-20190609.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1461626-20190609.htm&d=%2BD6XGwqev%2FlZKpArKwvoHQp4YzggAwntK9UjHSQ2u7w%3D&h=57055b8f\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1461626-20190609.htm&h=95b1165a\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1461626-20190609.htm</a>"},{"pid":"b9e1c24f6da88d746790872fcc04b76d81f6270f","tid":1193120,"uid":13663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-08T18:29:40.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"e09c77fa794548637dc1e032c9fabf13f971750f","tid":1193120,"uid":8935,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-08T18:29:59.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"8fb3111ee89c7d65d12a20996b8439e76e0b22a1","tid":1193120,"uid":58609,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-08T18:31:16.000Z","msg":"得把口"},{"pid":"3cfe2a2153dc671c8e14a2ca44d41e57725e5e34","tid":1193120,"uid":13663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-09T05:37:00.000Z","m