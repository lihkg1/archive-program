l/frown.gif\" class=\"hkgmoji\" />"},{"pid":"6e8f24214eaeeb8c85a0ab3f5b3f5e4519fc736a","tid":751011,"uid":148021,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-21T16:42:57.000Z","msg":"差唔多三個月，仲係放唔低，但唔敢搵返佢，因為知道佢只會再一次拒絕復合"},{"pid":"08816fdec40349a0f164c4c2416a41acbb095a41","tid":751011,"uid":11260,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-07-21T16:49:27.000Z","msg":"分左手兩年，因為異地戀4年後覺得無將來所以和平分手。<br />\n<br />\n無再聯絡，但雙方都各自有另一半，各自發展事業。（最近睇完後來的我們，忍唔住stalk左一下）<br />\n<br />\n點先算放低？接受現實，接受遺憾，算唔算放低左？"},{"pid":"352bb89b29ce3e8f2076fbadf4f615d195131a3d","tid":751011,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-21T16:55:25.000Z","msg":"分手再做朋友只係多此一舉，要真正放低就要自己學習忘記<br />\n學習中<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2b7816deb1be1f948b82b85fafb0a823526d5795","tid":751011,"uid":185421,"like":1,"dislike":0,"score":1,"quote":{"pid":"6e8f24214eaeeb8c85a0ab3f5b3f5e4519fc736a","tid":751011,"uid":148021,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-21T16:42:57.000Z","msg":"差唔多三個月，仲係放唔低，但唔敢搵返佢，因為知道佢只會再一次拒絕復合"},"citedBy":2,"replyTime":"2018-07-21T17:13:59.000Z","msg":"唔好搵翻佢啦，致少唔好令佢討厭自己，呢個係我一直忍住唔搵嘅原因<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"b9d8075a1c7ed70fc3b9fa2d3d582a43e974af7d","tid":751011,"uid":60825,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-21T17:39:41.000Z","msg":"我都想知<br />\n網友黎 一分手就變成兩個世界<br />\n好掛住佢 <br />\n唔知點搵佢好<br />\n迫緊自己做好多野<br />\n<br />\n利申 分手一星期"},{"pid":"8c4b345b09df6e4d6c633077bd1e1941fc5745e9","tid":751011,"uid":148021,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b7816deb1be1f948b82b85fafb0a823526d5795","tid":751011,"uid":185421,"like":1,"dislike":0,"score":1,"quote":{"pid":"6e8f24214eaeeb8c85a0ab3f5b3f5e4519fc736a","tid":751011,"uid":148021,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-21T16:42:57.000Z","msg":"差唔多三個月，仲係放唔低，但唔敢搵返佢，因為知道佢只會再一次拒絕復合"},"citedBy":2,"replyTime":"2018-07-21T17