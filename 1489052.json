assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3b2a1c765f46143e34fc3c26653af23d15680c65","tid":1489052,"uid":209526,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-08-19T19:03:24.000Z","msg":"推上去呀<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"07e8798f00b6af2de6d0b687319f1c751463caec","tid":1489052,"uid":47659,"like":5,"dislike":1,"score":4,"citedBy":0,"replyTime":"2019-08-19T19:04:23.000Z","msg":"另外，癱瘓運輸係醞釀緊全港大罷工既催化劑，唔好再話要民意覺醒全港所有人自願唔返工，係無可能"},{"pid":"512fba65831f07525b97523a6c2c7d08e57d45e0","tid":1489052,"uid":47659,"like":3,"dislike":4,"score":-1,"citedBy":0,"replyTime":"2019-08-19T19:05:58.000Z","msg":"我預視到就算文宣做得再好<br />\n都會有班私怨撚分化撚黎破壞你地<br />\n<br />\n只希望大家沉著氣應對做自己應該做的事"},{"pid":"58c13ddce6274a869c811d1acf83f4162aacb4fc","tid":1489052,"uid":209526,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-08-19T19:06:06.000Z","msg":"<img src=\"https://na.cx/i/wSsTKbA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwSsTKbA.jpg&h=04179c46&s={SIZE}\" />"},{"pid":"9bbcfc715f262749bcfb72277e5512b91503c26e","tid":1489052,"uid":209526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T19:07:38.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e65c411ed5357a670af5989c758c169ef717c7d0","tid":1489052,"uid":209526,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-19T19:10:02.000Z","msg":"勿忘721<br />\n勿忘五大訴求<br />\n你地攰，抖夠就再出嚟啦<br />\n香港仲需要你<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"27b44c0df6fbb96f7c753b4b7a7c36390e4be0ed","tid":1489052,"uid":258474,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-19T19:10:30.000Z","msg":"幫推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ba2634eab6db1bfe2ea54ae1a4a6e2576ed69b33","tid":1489052,"uid":11698,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2019-08-19T19:12:59.000Z","msg":"要塞去塞機場啦"},{"pid":"8