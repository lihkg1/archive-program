:0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:45:40.000Z","msg":"實用post 推"},{"pid":"8082c4e99b992a6277932535a7c95802f5027e3c","tid":1843442,"uid":88140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:45:50.000Z","msg":"推"},{"pid":"7d160f65ce77d8ac9602929ab0ee0c40358207df","tid":1843442,"uid":88140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:46:13.000Z","msg":"推"},{"pid":"a5c397874d18d25303144364b049346ca37b8ca4","tid":1843442,"uid":88140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:46:25.000Z","msg":"推"},{"pid":"2ad6c94f15f878c0605938177434e4547ff1c07f","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:47:43.000Z","msg":"推下先"},{"pid":"e486577f882a76bc5bc6067609cccdbf271e64de","tid":1843442,"uid":65074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:49:14.000Z","msg":"一齊罷"},{"pid":"1d2a09bd529281ac1d8187b45d16bda1cfbb709e","tid":1843442,"uid":88140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:49:19.000Z","msg":"推"},{"pid":"3e90743e0a5306de6511afcca154d2343fc1274d","tid":1843442,"uid":88140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:49:32.000Z","msg":"推"},{"pid":"ff1b789b010bffb42c7ad6179727ea40b1127f94","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:49:56.000Z","msg":"推呀"},{"pid":"300e1c967444ce06873f36954380b487c83eb689","tid":1843442,"uid":88140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:50:20.000Z","msg":"推上熱門"},{"pid":"4f706a6f1173ee67db4d3ca0a111cd084126c3e4","tid":1843442,"uid":164476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:50:24.000Z","msg":"Pish"},{"pid":"061c8961106071825e05674d1567019d68509bb8","tid":1843442,"uid":88140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:50:33.000Z","msg":"推"},{"pid":"d8b8b80565da3085baee2f5622bd4edb0916fc5e","tid":1843442,"uid":164476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:50:40.000Z","msg":"推"},{"pid":"2b90d0b64bf890d27fdd4b61cbca81eaa12cb91c","tid":1843442,"uid":59297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:50:56.000Z","msg":"一齊罷"},{"pid":"9af82997716cac5fcead3eef1ab4fd2fcf170e91","tid":1843442,"uid":164476,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:51:32.000Z","msg":"推"},{"pid":"9ee0e1f3f1b91ec2a0beb8ee64495ac433cc8a91","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:52:11.000Z","msg":"推唔郁<img src=\"/assets/faces/big/dead.gif\" class=\"hkgmoji\" />"},{"pid":"b2d075b33a2235a64a85302454dee1dbe775af07","tid":1843442,"uid":88140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:53:08.000Z","msg":"推"},{"pid":"248ccabf5150838513e166dc951355f166d7c8cc","tid":1843442,"uid":75153,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:53:27.000Z","msg":"pish"},{"pid":"ae519c71dfaa8bb3a5a6dab8fbe7c815a4a7956b","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:53:59.000Z","msg":"推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"77236cc4903fdfe55ee88ca6600c6a9d4756c9f9","tid":1843442,"uid":234058,"like":0,"dislike":0,"score":0,"quote":{"pid":"bb995520bf36a8d4a84e2dd565499d65bd5bbb75","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2020-01-26T08:12:43.000Z","msg":"<span style=\"font-size: x-large;\"><ins>醫管局員工</ins></span><br />\n<br />\n<strong>1. 請參加罷工</strong><br />\n<br />\n我知道有好多同事仲係十五十六，諗緊罷唔罷。<br />\n<br />\n簡單啲講罷工人數愈多，效果愈大，醫管局以至政府先會回應訴求，達至<span style=\"color: red;\">封關救港</span>。<br />\n<br />\n唔罷工嘅同事工作量一定大增，<span style=\"color: red;\">呢個係工會最唔想有嘅罷工副作用</span>。不過換個角度睇，你唔罷工就要做砲灰，<strong><span style=\"color: gold;\">與其做餐死，為港共執手尾賣命，不如一齊罷工，迫佢封關。</span></strong><br />\n<br />\n好多人都叫工會提早罷工，但因為工會罷工前要盡量收集會員、教育會員罷工安排同埋舉行會員大會通過罷工動議，所以迫於無奈要去到2月3號先開始罷。<span style=\"color: orange;\">Dirty team 或其他同事有需要可自行考慮會否提早罷工</span>，我知道工會對此都感到十分慚愧。<br />\n<br />\n<br />\n<strong>2. 加入工會</strong><br />\n<br />\n仲未加入工會嘅 請即加入<a href=\"http://bit.ly/36LfYF4\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2F36LfYF4&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=cc0a0c64\" target=\"_blank\">http://bit.ly/36LfYF4</a>  ，<br />\n如果日後不幸被醫管局清算，工會可以代為採取法律行動。<br />\n<br />\n不過罷工人數多 先係最佳避免清算嘅方法，FF如果有四萬人罷工，醫管局一定唔夠薑炒晒，<span style=\"color: gold;\">風險最大嘅從來都唔係參加者，而係一班工會理事，要炒都係炒佢地先</span>。難得有一班同事肯出嚟做出頭鳥，幫你地做靶，請各位把握機會向政府表態。<br />\n<br />\n<strong>3. 幫手宣傳罷工</strong><br />\n<br />\n參考反送中運動，建立<span style=\"color: orange;\">連儂更衣室/連儂廁所</span>。<br />\n<br />\n我相信有好同事都未入新工會，唔會知道罷工運動去向。所以有人曾經提議喺廁所、更衣室呢啲冇Cam 嘅地方貼文宣，向同事推擴運動目的同埋內容。<br />\n<br />\n無論如何，你想罷工，唔應該淨係罷，<span style=\"color: orange;\">要幫手增加罷工人數，保護自己之餘，又可以提高成效</span>。<br />\n<br />\n<span style=\"font-size: x-large;\"><ins>非醫局管員工</ins></span><br />\n<br />\n<strong>1. 幫手宣傳</strong><br />\n<br />\n我地最驚嘅唔係被人清算，而係罷工力度唔夠，被政府<span style=\"color: blue;\">冷處理</span>，所以我地希望大家<strong><span style=\"color: red;\">長推罷工</span></strong>，幫手向外界解釋罷工原因，醫管局員工陣線facebook page有文宣，可以幫手傳出去。<a href=\"https://m.facebook.com/HA.EmployAlliance/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2FHA.EmployAlliance%2F&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=d99e46c2\" target=\"_blank\">https://m.facebook.com/HA.EmployAlliance/</a><br />\n<br />\n<strong>2. 加入相屬工會，響應罷工</strong><br />\n<br />\n工會應該想第二階段<span style=\"color: gold;\">（2月4號起）</span>最多人出嚟罷工，其他工會可以考慮於當日響應，合力迫使政府封關防疫。但其他工會有權<span style=\"color: gold;\">自行提早發起工業行動</span>，醫護工會絕非大台。<br />\n<br />\n醫管局員工陣線係一個新工會，有做得不足嘅地方唔出奇，但我知道佢地一班理事真係好辛苦，返完工又要開會，又要整文宣，又要搞入會手續，真係好佩服佢地。希望各位繼續支持佢地。<br />\n<br />\n光復香港，時代革命"},"citedBy":0,"replyTime":"2020-01-26T08:55:03.000Z","msg":"推"},{"pid":"9264f74f7129ff59d4e8affc11d31e33d5c85fbf","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:55:29.000Z","msg":"<img src=\"/assets/faces/big/cry.gif\" class=\"hkgmoji\" />"},{"pid":"57014f7b901c36ae02bdb6f0d0cc5f54c0cbc825","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:56:18.000Z","msg":"連登幫政府冷處理罷工"},{"pid":"13e92bc8e195111b9de8af5cc2581615879b5fe7","tid":1843442,"uid":306591,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:56:41.000Z","msg":"<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"741dc43150f94b7d9287416ef3e5578238ca7ae7","tid":1843442,"uid":266469,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:57:01.000Z","msg":"推"},{"pid":"1b3d41b31c60a7d6dd0116726bba6d490af6b892","tid":1843442,"uid":88140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:58:37.000Z","msg":"推"},{"pid":"e7ef328c66c88f0a37c419a97cf8ce221b29b993","tid":1843442,"uid":88140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:58:57.000Z","msg":"推"},{"pid":"bf3ef9628efae6a04c5fb3ec23c781f2ab57a777","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:59:06.000Z","msg":"推唔起呀"},{"pid":"06622ce9b0c6c0c857d0f40b9b54831195c09688","tid":1843442,"uid":340178,"like":0,"dislike":0,"score":0,"quote":{"pid":"bb995520bf36a8d4a84e2dd565499d65bd5bbb75","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2020-01-26T08:12:43.000Z","msg":"<span style=\"font-size: x-large;\"><ins>醫管局員工</ins></span><br />\n<br />\n<strong>1. 請參加罷工</strong><br />\n<br />\n我知道有好多同事仲係十五十六，諗緊罷唔罷。<br />\n<br />\n簡單啲講罷工人數愈多，效果愈大，醫管局以至政府先會回應訴求，達至<span style=\"color: red;\">封關救港</span>。<br />\n<br />\n唔罷工嘅同事工作量一定大增，<span style=\"color: red;\">呢個係工會最唔想有嘅罷工副作用</span>。不過換個角度睇，你唔罷工就要做砲灰，<strong><span style=\"color: gold;\">與其做餐死，為港共執手尾賣命，不如一齊罷工，迫佢封關。</span></strong><br />\n<br />\n好多人都叫工會提早罷工，但因為工會罷工前要盡量收集會員、教育會員罷工安排同埋舉行會員大會通過罷工動議，所以迫於無奈要去到2月3號先開始罷。<span style=\"color: orange;\">Dirty team 或其他同事有需要可自行考慮會否提早罷工</span>，我知道工會對此都感到十分慚愧。<br />\n<br />\n<br />\n<strong>2. 加入工會</strong><br />\n<br />\n仲未加入工會嘅 請即加入<a href=\"http://bit.ly/36LfYF4\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2F36LfYF4&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=cc0a0c64\" target=\"_blank\">http://bit.ly/36LfYF4</a>  ，<br />\n如果日後不幸被醫管局清算，工會可以代為採取法律行動。<br />\n<br />\n不過罷工人數多 先係最佳避免清算嘅方法，FF如果有四萬人罷工，醫管局一定唔夠薑炒晒，<span style=\"color: gold;\">風險最大嘅從來都唔係參加者，而係一班工會理事，要炒都係炒佢地先</span>。難得有一班同事肯出嚟做出頭鳥，幫你地做靶，請各位把握機會向政府表態。<br />\n<br />\n<strong>3. 幫手宣傳罷工</strong><br />\n<br />\n參考反送中運動，建立<span style=\"color: orange;\">連儂更衣室/連儂廁所</span>。<br />\n<br />\n我相信有好同事都未入新工會，唔會知道罷工運動去向。所以有人曾經提議喺廁所、更衣室呢啲冇Cam 嘅地方貼文宣，向同事推擴運動目的同埋內容。<br />\n<br />\n無論如何，你想罷工，唔應該淨係罷，<span style=\"color: orange;\">要幫手增加罷工人數，保護自己之餘，又可以提高成效</span>。<br />\n<br />\n<span style=\"font-size: x-large;\"><ins>非醫局管員工</ins></span><br />\n<br />\n<strong>1. 幫手宣傳</strong><br />\n<br />\n我地最驚嘅唔係被人清算，而係罷工力度唔夠，被政府<span style=\"color: blue;\">冷處理</span>，所以我地希望大家<strong><span style=\"color: red;\">長推罷工</span></strong>，幫手向外界解釋罷工原因，醫管局員工陣線facebook page有文宣，可以幫手傳出去。<a href=\"https://m.facebook.com/HA.EmployAlliance/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2FHA.EmployAlliance%2F&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=d99e46c2\" target=\"_blank\">https://m.facebook.com/HA.EmployAlliance/</a><br />\n<br />\n<strong>2. 加入相屬工會，響應罷工</strong><br />\n<br />\n工會應該想第二階段<span style=\"color: gold;\">（2月4號起）</span>最多人出嚟罷工，其他工會可以考慮於當日響應，合力迫使政府封關防疫。但其他工會有權<span style=\"color: gold;\">自行提早發起工業行動</span>，醫護工會絕非大台。<br />\n<br />\n醫管局員工陣線係一個新工會，有做得不足嘅地方唔出奇，但我知道佢地一班理事真係好辛苦，返完工又要開會，又要整文宣，又要搞入會手續，真係好佩服佢地。希望各位繼續支持佢地。<br />\n<br />\n光復香港，時代革命"},"citedBy":0,"replyTime":"2020-01-26T08:59:12.000Z","msg":"其實攬炒之母跟本就係想攬炒 無論消占佢都唔會理"},{"pid":"2b37d5fa6d4df64137a8d28e0129fa6cc530cd5d","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:02:58.000Z","msg":"長推罷工"},{"pid":"743d77fbafd744fa56e702f6bbb1f4d2945e379c","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:03:11.000Z","msg":"長推罷工"},{"pid":"a311f5fc704e3f4e27cdabe4637d701fea1ed587","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:03:24.000Z","msg":"長推罷工"},{"pid":"7645964126d4996641b65ae163af94e7904f9d14","tid":1843442,"uid":340178,"like":0,"dislike":0,"score":0,"quote":{"pid":"bb995520bf36a8d4a84e2dd565499d65bd5bbb75","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2020-01-26T08:12:43.000Z","msg":"<span style=\"font-size: x-large;\"><ins>醫管局員工</ins></span><br />\n<br />\n<strong>1. 請參加罷工</strong><br />\n<br />\n我知道有好多同事仲係十五十六，諗緊罷唔罷。<br />\n<br />\n簡單啲講罷工人數愈多，效果愈大，醫管局以至政府先會回應訴求，達至<span style=\"color: red;\">封關救港</span>。<br />\n<br />\n唔罷工嘅同事工作量一定大增，<span style=\"color: red;\">呢個係工會最唔想有嘅罷工副作用</span>。不過換個角度睇，你唔罷工就要做砲灰，<strong><span style=\"color: gold;\">與其做餐死，為港共執手尾賣命，不如一齊罷工，迫佢封關。</span></strong><br />\n<br />\n好多人都叫工會提早罷工，但因為工會罷工前要盡量收集會員、教育會員罷工安排同埋舉行會員大會通過罷工動議，所以迫於無奈要去到2月3號先開始罷。<span style=\"color: orange;\">Dirty team 或其他同事有需要可自行考慮會否提早罷工</span>，我知道工會對此都感到十分慚愧。<br />\n<br />\n<br />\n<strong>2. 加入工會</strong><br />\n<br />\n仲未加入工會嘅 請即加入<a href=\"http://bit.ly/36LfYF4\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2F36LfYF4&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=cc0a0c64\" target=\"_blank\">http://bit.ly/36LfYF4</a>  ，<br />\n如果日後不幸被醫管局清算，工會可以代為採取法律行動。<br />\n<br />\n不過罷工人數多 先係最佳避免清算嘅方法，FF如果有四萬人罷工，醫管局一定唔夠薑炒晒，<span style=\"color: gold;\">風險最大嘅從來都唔係參加者，而係一班工會理事，要炒都係炒佢地先</span>。難得有一班同事肯出嚟做出頭鳥，幫你地做靶，請各位把握機會向政府表態。<br />\n<br />\n<strong>3. 幫手宣傳罷工</strong><br />\n<br />\n參考反送中運動，建立<span style=\"color: orange;\">連儂更衣室/連儂廁所</span>。<br />\n<br />\n我相信有好同事都未入新工會，唔會知道罷工運動去向。所以有人曾經提議喺廁所、更衣室呢啲冇Cam 嘅地方貼文宣，向同事推擴運動目的同埋內容。<br />\n<br />\n無論如何，你想罷工，唔應該淨係罷，<span style=\"color: orange;\">要幫手增加罷工人數，保護自己之餘，又可以提高成效</span>。<br />\n<br />\n<span style=\"font-size: x-large;\"><ins>非醫局管員工</ins></span><br />\n<br />\n<strong>1. 幫手宣傳</strong><br />\n<br />\n我地最驚嘅唔係被人清算，而係罷工力度唔夠，被政府<span style=\"color: blue;\">冷處理</span>，所以我地希望大家<strong><span style=\"color: red;\">長推罷工</span></strong>，幫手向外界解釋罷工原因，醫管局員工陣線facebook page有文宣，可以幫手傳出去。<a href=\"https://m.facebook.com/HA.EmployAlliance/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2FHA.EmployAlliance%2F&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=d99e46c2\" target=\"_blank\">https://m.facebook.com/HA.EmployAlliance/</a><br />\n<br />\n<strong>2. 加入相屬工會，響應罷工</strong><br />\n<br />\n工會應該想第二階段<span style=\"color: gold;\">（2月4號起）</span>最多人出嚟罷工，其他工會可以考慮於當日響應，合力迫使政府封關防疫。但其他工會有權<span style=\"color: gold;\">自行提早發起工業行動</span>，醫護工會絕非大台。<br />\n<br />\n醫管局員工陣線係一個新工會，有做得不足嘅地方唔出奇，但我知道佢地一班理事真係好辛苦，返完工又要開會，又要整文宣，又要搞入會手續，真係好佩服佢地。希望各位繼續支持佢地。<br />\n<br />\n光復香港，時代革命"},"citedBy":1,"replyTime":"2020-01-26T09:04:08.000Z","msg":"擇胐炒之母由始至卛冬都想攬炒 無論點佢都唔會理"},{"pid":"0ef9f6083b2615457c3d9e0db7b09540b33b866f","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:04:53.000Z","msg":"長推罷工"},{"pid":"48878c21fcef014eb3a2633fc9b5e12e17c09de1","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"quote":{"pid":"7645964126d4996641b65ae163af94e7904f9d14","tid":1843442,"uid":340178,"like":0,"dislike":0,"score":0,"quote":{"pid":"bb995520bf36a8d4a84e2dd565499d65bd5bbb75","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2020-01-26T08:12:43.000Z","msg":"<span style=\"font-size: x-large;\"><ins>醫管局員工</ins></span><br />\n<br />\n<strong>1. 請參加罷工</strong><br />\n<br />\n我知道有好多同事仲係十五十六，諗緊罷唔罷。<br />\n<br />\n簡單啲講罷工人數愈多，效果愈大，醫管局以至政府先會回應訴求，達至<span style=\"color: red;\">封關救港</span>。<br />\n<br />\n唔罷工嘅同事工作量一定大增，<span style=\"color: red;\">呢個係工會最唔想有嘅罷工副作用</span>。不過換個角度睇，你唔罷工就要做砲灰，<strong><span style=\"color: gold;\">與其做餐死，為港共執手尾賣命，不如一齊罷工，迫佢封關。</span></strong><br />\n<br />\n好多人都叫工會提早罷工，但因為工會罷工前要盡量收集會員、教育會員罷工安排同埋舉行會員大會通過罷工動議，所以迫於無奈要去到2月3號先開始罷。<span style=\"color: orange;\">Dirty team 或其他同事有需要可自行考慮會否提早罷工</span>，我知道工會對此都感到十分慚愧。<br />\n<br />\n<br />\n<strong>2. 加入工會</strong><br />\n<br />\n仲未加入工會嘅 請即加入<a href=\"http://bit.ly/36LfYF4\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2F36LfYF4&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=cc0a0c64\" target=\"_blank\">http://bit.ly/36LfYF4</a>  ，<br />\n如果日後不幸被醫管局清算，工會可以代為採取法律行動。<br />\n<br />\n不過罷工人數多 先係最佳避免清算嘅方法，FF如果有四萬人罷工，醫管局一定唔夠薑炒晒，<span style=\"color: gold;\">風險最大嘅從來都唔係參加者，而係一班工會理事，要炒都係炒佢地先</span>。難得有一班同事肯出嚟做出頭鳥，幫你地做靶，請各位把握機會向政府表態。<br />\n<br />\n<strong>3. 幫手宣傳罷工</strong><br />\n<br />\n參考反送中運動，建立<span style=\"color: orange;\">連儂更衣室/連儂廁所</span>。<br />\n<br />\n我相信有好同事都未入新工會，唔會知道罷工運動去向。所以有人曾經提議喺廁所、更衣室呢啲冇Cam 嘅地方貼文宣，向同事推擴運動目的同埋內容。<br />\n<br />\n無論如何，你想罷工，唔應該淨係罷，<span style=\"color: orange;\">要幫手增加罷工人數，保護自己之餘，又可以提高成效</span>。<br />\n<br />\n<span style=\"font-size: x-large;\"><ins>非醫局管員工</ins></span><br />\n<br />\n<strong>1. 幫手宣傳</strong><br />\n<br />\n我地最驚嘅唔係被人清算，而係罷工力度唔夠，被政府<span style=\"color: blue;\">冷處理</span>，所以我地希望大家<strong><span style=\"color: red;\">長推罷工</span></strong>，幫手向外界解釋罷工原因，醫管局員工陣線facebook page有文宣，可以幫手傳出去。<a href=\"https://m.facebook.com/HA.EmployAlliance/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2FHA.EmployAlliance%2F&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=d99e46c2\" target=\"_blank\">https://m.facebook.com/HA.EmployAlliance/</a><br />\n<br />\n<strong>2. 加入相屬工會，響應罷工</strong><br />\n<br />\n工會應該想第二階段<span style=\"color: gold;\">（2月4號起）</span>最多人出嚟罷工，其他工會可以考慮於當日響應，合力迫使政府封關防疫。但其他工會有權<span style=\"color: gold;\">自行提早發起工業行動</span>，醫護工會絕非大台。<br />\n<br />\n醫管局員工陣線係一個新工會，有做得不足嘅地方唔出奇，但我知道佢地一班理事真係好辛苦，返完工又要開會，又要整文宣，又要搞入會手續，真係好佩服佢地。希望各位繼續支持佢地。<br />\n<br />\n光復香港，時代革命"},"citedBy":1,"replyTime":"2020-01-26T09:04:08.000Z","msg":"擇胐炒之母由始至卛冬都想攬炒 無論點佢都唔會理"},"citedBy":1,"replyTime":"2020-01-26T09:05:24.000Z","msg":"藍tick 不回"},{"pid":"e0a95b2f8aaee46bb0868effb3df17ca271b5844","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:05:36.000Z","msg":"推"},{"pid":"86ad654607d03d5658458a8840a02eafb9baf1ae","tid":1843442,"uid":340178,"like":0,"dislike":0,"score":0,"quote":{"pid":"bb995520bf36a8d4a84e2dd565499d65bd5bbb75","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2020-01-26T08:12:43.000Z","msg":"<span style=\"font-size: x-large;\"><ins>醫管局員工</ins></span><br />\n<br />\n<strong>1. 請參加罷工</strong><br />\n<br />\n我知道有好多同事仲係十五十六，諗緊罷唔罷。<br />\n<br />\n簡單啲講罷工人數愈多，效果愈大，醫管局以至政府先會回應訴求，達至<span style=\"color: red;\">封關救港</span>。<br />\n<br />\n唔罷工嘅同事工作量一定大增，<span style=\"color: red;\">呢個係工會最唔想有嘅罷工副作用</span>。不過換個角度睇，你唔罷工就要做砲灰，<strong><span style=\"color: gold;\">與其做餐死，為港共執手尾賣命，不如一齊罷工，迫佢封關。</span></strong><br />\n<br />\n好多人都叫工會提早罷工，但因為工會罷工前要盡量收集會員、教育會員罷工安排同埋舉行會員大會通過罷工動議，所以迫於無奈要去到2月3號先開始罷。<span style=\"color: orange;\">Dirty team 或其他同事有需要可自行考慮會否提早罷工</span>，我知道工會對此都感到十分慚愧。<br />\n<br />\n<br />\n<strong>2. 加入工會</strong><br />\n<br />\n仲未加入工會嘅 請即加入<a href=\"http://bit.ly/36LfYF4\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2F36LfYF4&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=cc0a0c64\" target=\"_blank\">http://bit.ly/36LfYF4</a>  ，<br />\n如果日後不幸被醫管局清算，工會可以代為採取法律行動。<br />\n<br />\n不過罷工人數多 先係最佳避免清算嘅方法，FF如果有四萬人罷工，醫管局一定唔夠薑炒晒，<span style=\"color: gold;\">風險最大嘅從來都唔係參加者，而係一班工會理事，要炒都係炒佢地先</span>。難得有一班同事肯出嚟做出頭鳥，幫你地做靶，請各位把握機會向政府表態。<br />\n<br />\n<strong>3. 幫手宣傳罷工</strong><br />\n<br />\n參考反送中運動，建立<span style=\"color: orange;\">連儂更衣室/連儂廁所</span>。<br />\n<br />\n我相信有好同事都未入新工會，唔會知道罷工運動去向。所以有人曾經提議喺廁所、更衣室呢啲冇Cam 嘅地方貼文宣，向同事推擴運動目的同埋內容。<br />\n<br />\n無論如何，你想罷工，唔應該淨係罷，<span style=\"color: orange;\">要幫手增加罷工人數，保護自己之餘，又可以提高成效</span>。<br />\n<br />\n<span style=\"font-size: x-large;\"><ins>非醫局管員工</ins></span><br />\n<br />\n<strong>1. 幫手宣傳</strong><br />\n<br />\n我地最驚嘅唔係被人清算，而係罷工力度唔夠，被政府<span style=\"color: blue;\">冷處理</span>，所以我地希望大家<strong><span style=\"color: red;\">長推罷工</span></strong>，幫手向外界解釋罷工原因，醫管局員工陣線facebook page有文宣，可以幫手傳出去。<a href=\"https://m.facebook.com/HA.EmployAlliance/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2FHA.EmployAlliance%2F&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=d99e46c2\" target=\"_blank\">https://m.facebook.com/HA.EmployAlliance/</a><br />\n<br />\n<strong>2. 加入相屬工會，響應罷工</strong><br />\n<br />\n工會應該想第二階段<span style=\"color: gold;\">（2月4號起）</span>最多人出嚟罷工，其他工會可以考慮於當日響應，合力迫使政府封關防疫。但其他工會有權<span style=\"color: gold;\">自行提早發起工業行動</span>，醫護工會絕非大台。<br />\n<br />\n醫管局員工陣線係一個新工會，有做得不足嘅地方唔出奇，但我知道佢地一班理事真係好辛苦，返完工又要開會，又要整文宣，又要搞入會手續，真係好佩服佢地。希望各位繼續支持佢地。<br />\n<br />\n光復香港，時代革命"},"citedBy":0,"replyTime":"2020-01-26T09:05:57.000Z","msg":"擇屇山炒之母根本就係想同香港港人攬炒"},{"pid":"f41a7522caf36a241284f4512cbb5656bd6bb984","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:06:21.000Z","msg":"長推罷工"},{"pid":"672940d19e6bf2ac29629a032a57b5da12259e48","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:06:35.000Z","msg":"長推罷工"},{"pid":"f689c702aac3a9e80e23b9ee2d34aade28ff7c71","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:06:45.000Z","msg":"長推罷工"},{"pid":"f700f06510ee333ce1551c8b83d485258961ef74","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:07:06.000Z","msg":"長推罷工"},{"pid":"9f3f66ab9faae8a4f456b8f8f84f2c321a8a6d20","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:07:21.000Z","msg":"長推罷工"},{"pid":"3cc7d2aadf8adeb75c08dafd94110b66b598a4be","tid":1843442,"uid":340178,"like":0,"dislike":0,"score":0,"quote":{"pid":"48878c21fcef014eb3a2633fc9b5e12e17c09de1","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"quote":{"pid":"7645964126d4996641b65ae163af94e7904f9d14","tid":1843442,"uid":340178,"like":0,"dislike":0,"score":0,"quote":{"pid":"bb995520bf36a8d4a84e2dd565499d65bd5bbb75","tid":1843442,"uid":240256,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2020-01-26T08:12:43.000Z","msg":"<span style=\"font-size: x-large;\"><ins>醫管局員工</ins></span><br />\n<br />\n<strong>1. 請參加罷工</strong><br />\n<br />\n我知道有好多同事仲係十五十六，諗緊罷唔罷。<br />\n<br />\n簡單啲講罷工人數愈多，效果愈大，醫管局以至政府先會回應訴求，達至<span style=\"color: red;\">封關救港</span>。<br />\n<br />\n唔罷工嘅同事工作量一定大增，<span style=\"color: red;\">呢個係工會最唔想有嘅罷工副作用</span>。不過換個角度睇，你唔罷工就要做砲灰，<strong><span style=\"color: gold;\">與其做餐死，為港共執手尾賣命，不如一齊罷工，迫佢封關。</span></strong><br />\n<br />\n好多人都叫工會提早罷工，但因為工會罷工前要盡量收集會員、教育會員罷工安排同埋舉行會員大會通過罷工動議，所以迫於無奈要去到2月3號先開始罷。<span style=\"color: orange;\">Dirty team 或其他同事有需要可自行考慮會否提早罷工</span>，我知道工會對此都感到十分慚愧。<br />\n<br />\n<br />\n<strong>2. 加入工會</strong><br />\n<br />\n仲未加入工會嘅 請即加入<a href=\"http://bit.ly/36LfYF4\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2F36LfYF4&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=cc0a0c64\" target=\"_blank\">http://bit.ly/36LfYF4</a>  ，<br />\n如果日後不幸被醫管局清算，工會可以代為採取法律行動。<br />\n<br />\n不過罷工人數多 先係最佳避免清算嘅方法，FF如果有四萬人罷工，醫管局一定唔夠薑炒晒，<span style=\"color: gold;\">風險最大嘅從來都唔係參加者，而係一班工會理事，要炒都係炒佢地先</span>。難得有一班同事肯出嚟做出頭鳥，幫你地做靶，請各位把握機會向政府表態。<br />\n<br />\n<strong>3. 幫手宣傳罷工</strong><br />\n<br />\n參考反送中運動，建立<span style=\"color: orange;\">連儂更衣室/連儂廁所</span>。<br />\n<br />\n我相信有好同事都未入新工會，唔會知道罷工運動去向。所以有人曾經提議喺廁所、更衣室呢啲冇Cam 嘅地方貼文宣，向同事推擴運動目的同埋內容。<br />\n<br />\n無論如何，你想罷工，唔應該淨係罷，<span style=\"color: orange;\">要幫手增加罷工人數，保護自己之餘，又可以提高成效</span>。<br />\n<br />\n<span style=\"font-size: x-large;\"><ins>非醫局管員工</ins></span><br />\n<br />\n<strong>1. 幫手宣傳</strong><br />\n<br />\n我地最驚嘅唔係被人清算，而係罷工力度唔夠，被政府<span style=\"color: blue;\">冷處理</span>，所以我地希望大家<strong><span style=\"color: red;\">長推罷工</span></strong>，幫手向外界解釋罷工原因，醫管局員工陣線facebook page有文宣，可以幫手傳出去。<a href=\"https://m.facebook.com/HA.EmployAlliance/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2FHA.EmployAlliance%2F&d=1bJdDSIrk6tBa%2BBM68SGehZhTFX1FVJLw6RhI%2FCRHR8%3D&h=d99e46c2\" target=\"_blank\">https://m.facebook.com/HA.EmployAlliance/</a><br />\n<br />\n<strong>2. 加入相屬工會，響應罷工</strong><br />\n<br />\n工會應該想第二階段<span style=\"color: gold;\">（2月4號起）</span>最多人出嚟罷工，其他工會可以考慮於當日響應，合力迫使政府封關防疫。但其他工會有權<span style=\"color: gold;\">自行提早發起工業行動</span>，醫護工會絕非大台。<br />\n<br />\n醫管局員工陣線係一個新工會，有做得不足嘅地方唔出奇，但我知道佢地一班理事真係好辛苦，返完工又要開會，又要整文宣，又要搞入會手續，真係好佩服佢地。希望各位繼續支持佢地。<br />\n<br />\n光復香港，時代革命"},"citedBy":1,"replyTime":"2020-01-26T09:04:08.000Z","msg":"擇胐炒之母由始至卛冬都想攬炒 無論點佢都唔會理"},"citedBy":1,"replyTime":"2020-01-26T09:05:24.000Z","msg":"藍tick 不回"},"citedBy":0,"replyTime":"2020-01-26T09:09:24.000Z","msg":"就算藍tick都係睇唔到"},{"pid":"328e317650fe84e27ba28416306bfb94575c111b","tid":1843442,"uid":165894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:10:52.000Z","msg":"Push"},{"pid":"5bbc9b0601ccf52945e3abe99133fb6f3e1482d7","tid":1843442,"uid":2584,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:10:59.000Z","msg":"我準備好同醫護界一齊罷工！"},{"pid":"5865c9c0d905447d9b03e1b533b95b1cfec3895f","tid":1843442,"uid":165894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:11:14.000Z","msg":"Push"},{"pid":"ebbf2ff38a3bce0141170896a464712cb4c9e6a5","tid":1843442,"uid":67049,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:12:58.000Z","msg":"支持醫護 一齊罷工！"},{"pid":"50d2fadf060e7fedafd997044b66ae6ef8b2ea55","tid":1843442,"uid":2584,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T09:13:00.000Z","msg":"一撚定要封關！"}]}