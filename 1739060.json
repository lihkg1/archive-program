 src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d7f73579ac7c2cccc1e9cabae50d55ca7b76bf76","tid":1739060,"uid":42762,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-11-19T14:02:10.000Z","msg":"沈旭暉之前都話應該要建立一支屬於香港人嘅游說團，真係要做"},{"pid":"1684c5592d1d8309d9f6f0b9d402264e762e475f","tid":1739060,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T14:05:59.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"352794fd5e54311fd88e8b6163a450b4964772f0","tid":1739060,"uid":205927,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T14:08:34.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}