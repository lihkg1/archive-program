citedBy":0,"replyTime":"2020-04-08T11:29:04.000Z","msg":"呼喚妹妹<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"a73433cb7f1ce3794f3176c65af6859aa255575a","tid":1963820,"uid":272840,"like":0,"dislike":0,"score":0,"quote":{"pid":"711d9e82c0a1514a9e7b0ef284f86e9564a059d6","tid":1963820,"uid":167286,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-08T11:28:30.000Z","msg":"之前係咪話著衫可以趕人走,隻雞唔鍾意舊的衫,咁即係咩衫,舊時代既衫?"},"citedBy":1,"replyTime":"2020-04-08T11:29:05.000Z","msg":"回收箱發霉個啲"},{"pid":"2353ecba18ac6f3e3f2c18627ba9f6749a7ea0f0","tid":1963820,"uid":353380,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-08T11:29:09.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ad530138c4eb755551d83ca148e7bcd422000e7c","tid":1963820,"uid":221478,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-08T11:29:17.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />哇同時3個POST"},{"pid":"6ba3dfae022d14fcd1fc49a5e2c796ca6697003f","tid":1963820,"uid":272840,"like":0,"dislike":0,"score":0,"quote":{"pid":"84f38fa127c4239410918b3daa23c314da163ccc","tid":1963820,"uid":73055,"like":0,"dislike":0,"score":0,"quote":{"pid":"ad8004632ff99e38f5acb0bb2f9d5f6dba7a9a96","tid":1963820,"uid":272840,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-04-08T11:27:21.000Z","msg":"西施惠係_係__<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-08T11:27:45.000Z","msg":"痴線 做咩咁講<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-08T11:29:31.000Z","msg":"不務正業<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8e32c10c6e64616e0f5031063400419cdb6b6f34","tid":1963820,"uid":353380,"like":0,"dislike":0,"score":0,"quote":{"pid":"ad530138c4eb755551d83ca148e7bcd422000e7c","tid":1963820,"uid":221478,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-08T11:29:17.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />哇同時3個POST"},"citedBy":0,"replyTime":"2020-04-08T11:29:48.000Z","msg":"推邊個<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3b67db5f5bca0fd3feb9528fef0dccac24994a60","tid":1963820,"uid":167286,"like":0,"dislike":0,"score":0,"quote":{"pid":"a73433cb7f1ce3794f3176c65af6859aa255575a","tid":1963820,"uid":272840,"like":0,"dislike":0,"score":0,"quote":{"pid":"711d9e82c0a1514a9e7b0ef284f86e9564a059d6","tid":1963820,"uid":167286,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-08T11:28:30.000Z","msg":"之前係咪話著衫可以趕人走,隻雞唔鍾意舊的衫,咁即係咩衫,舊時代既衫?"},"citedBy":1,"replyTime":"2020-04-08T11:29:05.000Z","msg":"回收箱發霉個啲"},"citedBy":0,"replyTime":"2020-04-08T11:30:01.000Z","msg":"試下先<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"452e5ceff337d0ab7b4bcb0ede90ea5756231a4b","tid":1963820,"uid":106964,"like":0,"dislike":0,"score":0,"quote":{"pid":"2353ecba18ac6f3e3f2c18627ba9f6749a7ea0f0","tid":1963820,"uid":353380,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-08T11:29:09.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-08T11:31:23.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />開幾耐我8點幾先得閒"},{"pid":"f813fa2bdd2709a7243e9741bd2f73a8f598280e","tid":1963820,"uid":7232,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T11:42:51.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"c6a0cd3d456ae3cf0c84dec53fadd3454f03b5b7","tid":1963820,"uid":7232,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-08T11:44:39.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" />"},{"pid":"057430453563a263d1b7566eb785a080705ad784","tid":1963820,"uid":4780,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T12:26:40.000Z","msg":"有妹妹， 是咪可以開比人黎摸<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"bd8dd9e8aa1a509a8da2b11b49da3b03da8b9fc0","tid":1963820,"uid":4780,"like":0,"dislike":0,"score":0,"quote":{"pid":"c6a0cd3d456ae3cf0c84dec53fadd3454f03b5b7","tid":1963820,"uid":7232,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-08T11:44:39.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-08T12:27:09.000Z","msg":"南半無蛛 好似係<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"0776ed2d5d7b6ed11bfb45ea17885fc466fecf27","tid":1963820,"uid":29299,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T14:32:34.000Z","msg":"想問下係咪唔可以同一日係外島搵兩隻動物黎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n邀完一隻再劃地再去外島，但無火"}],"pinned":{"pid":"48957bcc947b7eb1c4c441c163c96f031a584e96","tid":1963820,"uid":221478,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T11:27:54.000Z","msg":"遊戲初期常見問題 // 實用online tools // <img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" /><br />\n<br />\n＞Android/iOS 「Nintendo Switch Online」app可以scan設計QR code，<strong><span style=\"color: gold;\">連機時可以快速打字傾計</span></strong><br />\n<br />\n股價計算<br />\n<a href=\"https://mikebryant.github.io/ac-nh-turnip-prices/index.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmikebryant.github.io%2Fac-nh-turnip-prices%2Findex.html&d=LgTIxyFtuo0acoW68XVTBexpY9ERoCMedVnvBBvIoB8%3D&h=6264db38\" target=\"_blank\">https://mikebryant.github.io/ac-nh-turnip-prices/index.html</a><br />\n排隊賣股<br />\n<a href=\"https://turnip.exchange/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fturnip.exchange%2F&d=LgTIxyFtuo0acoW68XVTBexpY9ERoCMedVnvBBvIoB8%3D&h=172a44a5\" target=\"_blank\">https://turnip.exchange/</a><br />\n外島攻略<br />\n<a href=\"https://wuffs.org/acnh/mysterytour.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwuffs.org%2Facnh%2Fmysterytour.html&d=LgTIxyFtuo0acoW68XVTBexpY9ERoCMedVnvBBvIoB8%3D&h=e75e1907\" target=\"_blank\">https://wuffs.org/acnh/mysterytour.html</a><br />\n設計任意pattern, 可生成qr code scan落遊戲度, 可以匯入任意圖片<br />\n<a href=\"https://acpatterns.com/editor\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Facpatterns.com%2Feditor&d=LgTIxyFtuo0acoW68XVTBexpY9ERoCMedVnvBBvIoB8%3D&h=d8ec9e45\" target=\"_blank\">https://acpatterns.com/editor</a><br />\n分割圖片做幾個正方形，搭上面一齊用效果更佳<br />\n<a href=\"https://pinetools.com/split-image\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpinetools.com%2Fsplit-image&d=LgTIxyFtuo0acoW68XVTBexpY9ERoCMedVnvBBvIoB8%3D&h=88b271ae\" target=\"_blank\">https://pinetools.com/split-image</a><br />\n設計主題曲<br />\n<a href=\"https://tunes.nooknet.net/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftunes.nooknet.net%2F&d=LgTIxyFtuo0acoW68XVTBexpY9ERoCMedVnvBBvIoB8%3D&h=d5966362\" target=\"_blank\">https://tunes.nooknet.net/</a><br />\n<br />\nＱ：我見人地玩得好快？<br />\nＡ：隻game精綷係由零開始慢慢認識你啲島民(<span style=\"color: orange;\"><strong>記得留意島民同NPC啲對話</strong></span>)，發展同裝飾你座島，睇住座島點樣進化。最緊要啱自己play style，預左你玩幾年架啦<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<br />\nQ：露營地第一隻動物係咪要硬食？<br />\nA：係<br />\n<br />\nQ：風水？<br />\nA：主人房擺唔同顏色家具增加運氣，綠 整體，紅 物品，黃 金錢。<br />\n<img src=\"https://i.postimg.cc/FRbfJgYp/fengshui.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.postimg.cc%2FFRbfJgYp%2Ffengshui.jpg&h=dc333a39&s={SIZE}\" /> <br />\n<a href=\"https://www.thonky.com/animal-crossing-new-leaf/feng-shui-guide\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thonky.com%2Fanimal-crossing-new-leaf%2Ffeng-shui-guide&d=LgTIxyFtuo0acoW68XVTBexpY9ERoCMedVnvBBvIoB8%3D&h=09b2f833\" target=\"_blank\">https://www.thonky.com/animal-crossing-new-leaf/feng-shui-guide</a><br />\n<br />\nQ：摸呀妹？<br />\nA：同館長個妹傾計有星星DIY<br />\n<br />\nQ：鐵斧頭同石斧頭有咩分別？<br />\nA：鐵會劈斷棵樹，石唔會<br />\n<br />\nQ：整爆左啲石會唔會生返？<br />\nA：第二日隨機位置生<br />\n<br />\nＱ：幾時先有得 買大頭菜(蘿蔔)，用ATM買摸過嘅野？<br />\nＡ：起商店後<br />\n<br />\nＱ：ATM有啲係非賣品？<br />\nＡ：合成物品摸完都買唔到<br />\n<br />\nＱ：點為之「摸」？<br />\nＡ：去人個島擺人地啲道具入袋之後物品圖鑑會有record，之後去返自己村部ATM可以訂嗰件貨。「摸」即係擺入袋之後再還返俾人<br />\n<br />\nＱ：點樣加速對話？<br />\nＡ：按B/長按R<br />\n<br />\nＱ：去外島請左啲新動物過我個島要幾時先會搬過來／幾時先有新島民？<br />\nＡ：keep住玩落去，有一日去揾狸吉(Tom Nook)會叫你幫新島民起屋，做好要求就會有新人搬過來<br />\n<br />\nＱ：用遊戲內design app整嘅圖案可唔可以分享？<br />\nＡ：開左時裝鋪就可以upload上網分享俾人<br />\n<br />\nＱ：點俾禮物動物島友？<br />\nＡ：間唔中對話會有得俾你揀，而機場心意卡都可以連禮物寄俾動物，佢地會回信<br />\n<br />\nＱ：點做遊戲內好友？<br />\nＡ：首先去機場揀同好友連機，會多左個好友app，之後去加左Switch好友嘅島玩一次就可以加<br />\n<br />\nＱ：點寄家俱，衫俾其他玩家？<br />\nＡ：加左遊戲內好友起狸貓ATM網購可以直寄俾好友<br />\n<br />\nＱ：見到流星可以點？<br />\nＡ：空手㩒A(好似仲要用右菇轉視角見到個天)第二日會有星星碎片執<br />\n<br />\nＱ：掘完窿種唔到樹／發光窿唔俾我種錢袋？<br />\nＡ：要揸住個鏟先得<br />\n<br />\nＱ：花係咪可以配種？<br />\nＡ：同類花種埋一齊，淋水，側邊有機會出新色花<br />\n<img src=\"https://na.cx/i/0GL7F8T.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0GL7F8T.png&h=a012237e&s={SIZE}\" /><br />\n<br />\nＱ：點同人online連線？<br />\nＡ：請人來嗰位要去機場（遊戲第二日後解放）開放你個島，同時會俾個代碼你。去人個島嗰位去機楊入代碼就得。如果加左Switch主機好友可以唔駛代碼咁開放俾好友入。要有Nintendo Switch Online會員<br />\n<br />\nＱ：去人地個島時個過場動畫有無得skip？<br />\nＡ：無<br />\n<br />\nＱ：點炒蘿蔔(大頭菜)？<br />\nＡ：星期日早上入股，平日每日留意價格，啱心水價格時賣去，去朋友島賣都得架<br />\n<br />\nQ：咁多巴絲分享作曲/畫畫QR Code係有咩用架？<br />\nA：遊戲起左office之後可以揀一段仔自製音樂做小島鈴聲。而QR Code scan返來嘅Pattern可以著落衫度，又可以鋪落地度，亦可以用作家俱設計等<br />\n<br />\nQ：無人島個地型係隨機定固定？<br />\nA：一開始會隨機gen四個俾你揀，開office後會解鎖整理地型功能<br />\n<br />\nQ：一個島可以有幾多個動物村民？<br />\nA：十<br />\n<br />\nＱ：合成好慢？<br />\nＡ：兩下A可加速合成<br />\n<br />\nＱ：生果點種？<br />\nＡ：掘個窿，再掉個生果落去，等幾日就有收成<br />\n<br />\nＱ：地下有啲金色嘅光？<br />\nＡ：掘開佢會有錢，掉袋錢落去會種到錢樹<br />\n<br />\nＱ：幾點轉第二日？<br />\nＡ：早上五點<br />\n<br />\nＱ：點樣跑同靜靜雞行(唔想嚇親昆蟲)？<br />\nＡ：跑 &gt; B，靜靜雞行 &gt; 細力推磨菇，捉昆蟲時持網可以長按A預備<br />\n<br />\nＱ：鋪左啲畫落地下點del走佢？<br />\nＡ：Y<br />\n<br />\nＱ：點掛自製畫去牆／著畫...?<br />\nＡ：去設計app度揀幅畫<br />\n<br />\nＱ：唔夠樹枝<br />\nＡ：搖樹，同一棵樹可以多搖幾次<br />\n<br />\nＱ：石頭/礦石無晒點算？<br />\nＡ：用鏟／斧頭鋤石頭，下面有張圖係秘技<br />\n<br />\nＱ：點樣成棵樹移植去其他地方？<br />\nＡ：食完生果可以成棵樹掘起，再去第度掘個窿種<br />\n<br />\nＱ：點解石頭一劈就爆？<br />\nＡ：食左生果特效係會劈爆石頭<br />\n<br />\nＱ：點一機多人玩？<br />\nＡ：Switch要先開多個profile先，再用嗰啲profile入game做教學。之後隨時用遊戲電話app「召集村民」<br />\n<br />\nＱ：有啲氣球飄下飄下點射落來？<br />\nＡ：丫叉<br />\n<br />\nＱ：點樣擴大個背包？<br />\nＡ：用哩數可去狸貓ATM換「口袋整理技巧」<br />\n<br />\nＱ：點拎丫叉/鏟/杆/梯...？<br />\nＡ：多啲捐野俾狸貓/貓頭鷹，多啲同NPC傾計，睇下細狸有無賣<br />\n<br />\nＱ：點去「外島」／「下西洋」？<br />\nＡ：去狸貓ATM買機票之後去機場<br />\n<br />\nＱ：「外島」有咩特別？<br />\nＡ：有機會有稀有花 蟲 魚 礦石，有巴絲話毎個外島都有一個蜂巢同一件家俱(可能要搖多幾次樹)，間中會有漂流瓶<br />\n<br />\nＱ：一開始點拎多啲鐵礦石／其他素材？<br />\nＡ：外島<br />\n<br />\nＱ：點釣魚？<br />\nＡ：瞄準魚頭，咬實左魚竿先拉佢上來<br />\n<br />\nＱ：有無私人儲物空間？<br />\nＡ：有樓住之後就有<br />\n<br />\nＱ：點叫醒海邊隻海鷗？點揾佢要嘅野？<br />\nＡ：同佢講多幾次野；留意沙地有野識噴水，掘開佢<br />\n<br />\nＱ：無位擺野！<br />\nＡ：擺住出面先<br />\n<br />\nＱ：啲屋/設施可唔可以調位？<br />\nＡ：有office後可以<br />\n<br />\nＱ：點拎多啲礦石？<br />\nＡ：好似幅圖咁整三個窿先<br />\n<img src=\"https://na.cx/i/rvjEZrt.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrvjEZrt.jpg&h=79ad3315&s={SIZE}\" /><br />\n<br />\nＱ：巴絲分享，外島捉狼蛛攻略<br />\nＡ：<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" /><br />\n<br />\nQ：點解跟哂方法整狼蛛島都係失敗/咁少/咁慢<br />\nA：4月開始蟲類會多左田鱉 田鱉會係河到生 但佢又計係蟲類 所以大大打擊左狼蛛刷新既機率 (解決方法係去冇河既外島)<br />\n<br />\n設計無人島<br />\n<a href=\"https://planimalcrossing.com/nh/start/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fplanimalcrossing.com%2Fnh%2Fstart%2F&d=LgTIxyFtuo0acoW68XVTBexpY9ERoCMedVnvBBvIoB8%3D&h=254b0a39\" target=\"_blank\">https://planimalcrossing.com/nh/start/</a><br />\n<br />\n<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}}