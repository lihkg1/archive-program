n.cc/hk/bkn/cnt/entertainment/20160510/photo/bkn-20160510210922448-0510_00862_001_07p.jpg?20160511012831\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fentertainment%2F20160510%2Fphoto%2Fbkn-20160510210922448-0510_00862_001_07p.jpg%3F20160511012831&h=67348ae3&s={SIZE}\" />"},{"pid":"e516c94f4c84434307c55a52426957fa003a70f6","tid":1017931,"uid":38189,"like":1,"dislike":0,"score":1,"quote":{"pid":"54b66d14cfc224f7ee3a11aaf7c832c63a420fad","tid":1017931,"uid":31314,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-02-12T04:42:00.000Z","msg":"<img src=\"https://cdn.picoodle.com/i343bm/dlmm_63971ae.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.picoodle.com%2Fi343bm%2Fdlmm_63971ae.jpg&h=49c52072&s={SIZE}\" /><br />\n<img src=\"https://hk.on.cc/hk/bkn/cnt/entertainment/20160510/photo/bkn-20160510210922448-0510_00862_001_07p.jpg?20160511012831\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fentertainment%2F20160510%2Fphoto%2Fbkn-20160510210922448-0510_00862_001_07p.jpg%3F20160511012831&h=67348ae3&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-02-12T04:43:10.000Z","msg":"最大影響力會員"}]}