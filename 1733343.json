{"tid":1733343,"cid":5,"subCid":10,"title":"教育局宣布周二停課　幼稚園停課至下周日‬ (13:34)","createTime":"2019-11-18T05:39:37.000Z","updateTime":"2019-11-18T05:47:41.000Z","uid":124722,"like":0,"dislike":0,"uniUserReply":1,"replies":[{"pid":"3bef6d4bb61ee69a8c858fca9488e25dd4816d60","tid":1733343,"uid":124722,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T05:39:37.000Z","msg":"<a href=\"https://m.mingpao.com/ins/%e6%b8%af%e8%81%9e/article/20191118/s00001/1574055130286/%e6%95%99%e8%82%b2%e5%b1%80%e5%ae%a3%e5%b8%83%e5%91%a8%e4%ba%8c%e5%81%9c%e8%aa%b2-%e5%b9%bc%e7%a8%9a%e5%9c%92%e5%81%9c%e8%aa%b2%e8%87%b3%e4%b8%8b%e5%91%a8%e6%97%a5%e2%80%ac\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%25e6%25b8%25af%25e8%2581%259e%2Farticle%2F20191118%2Fs00001%2F1574055130286%2F%25e6%2595%2599%25e8%2582%25b2%25e5%25b1%2580%25e5%25ae%25a3%25e5%25b8%2583%25e5%2591%25a8%25e4%25ba%258c%25e5%2581%259c%25e8%25aa%25b2-%25e5%25b9%25bc%25e7%25a8%259a%25e5%259c%2592%25e5%2581%259c%25e8%25aa%25b2%25e8%2587%25b3%25e4%25b8%258b%25e5%2591%25a8%25e6%2597%25a5%25e2%2580%25ac&d=uhXF1s3LJRzyxl6IDZpy2fsUKqL2I5G2E%2FT5UXudKlU%3D&h=4895b04d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%25e6%25b8%25af%25e8%2581%259e%2Farticle%2F20191118%2Fs00001%2F1574055130286%2F%25e6%2595%2599%25e8%2582%25b2%25e5%25b1%2580%25e5%25ae%25a3%25e5%25b8%2583%25e5%2591%25a8%25e4%25ba%258c%25e5%2581%259c%25e8%25aa%25b2-%25e5%25b9%25bc%25e7%25a8%259a%25e5%259c%2592%25e5%2581%259c%25e8%25aa%25b2%25e8%2587%25b3%25e4%25b8%258b%25e5%2591%25a8%25e6%2597%25a5%25e2%2580%25ac&h=a7ae89a3\" target=\"_blank\">https://m.mingpao.com/ins/%e6%b8%af%e8%81%9e/article/20191118/s00001/1574055130286/%e6%95%99%e8%82%b2%e5%b1%80%e5%ae%a3%e5%b8%83%e5%91%a8%e4%ba%8c%e5%81%9c%e8%aa%b2-%e5%b9%bc%e7%a8%9a%e5%9c%92%e5%81%9c%e8%aa%b2%e8%87%b3%e4%b8%8b%e5%91%a8%e6%97%a5%e2%80%ac</a><br />\n<br />\n教育局宣布，鑑於路面及交通仍有不穩定因素，以及給予學校充分時間為復課做好準備，全港學校（包括幼稚園、小學、中學及特殊學校）明日周二（‪19日‬）繼續停課。<br />\n<br />\n按現時情況，中小學及部分特殊學校計劃於周三（20日‬）恢復上課；幼稚園、肢體傷殘兒童學校及智障兒童學校將停課‪至下周日‬（24日‬）。<br />\n<br />\n停課期間，學校必須保持校舍開放，家長如有需要可將子女送返學校。學校應安排教職員在安全可行的情況下返回學校照顧學生，與家長保持溝通，並在安全的情況下方可安排學生返家。"},{"pid":"20601a5b064309f801de17b8b058032d198f7566","tid":1733343,"uid":124722,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T05:47:41.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}