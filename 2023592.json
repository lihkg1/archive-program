al/agree.gif\" class=\"hkgmoji\" />"},{"pid":"294210b8e2bac21b57617dda6fbf9887c3581410","tid":2023592,"uid":37912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T06:20:56.000Z","msg":"此回覆已被刪除"},{"pid":"8b89393eb402f608f6f8524fb86ae2823a4c7d33","tid":2023592,"uid":264426,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-19T06:22:45.000Z","msg":"睇翻以前啲戲都有講，報紙佬揭發某區探長貪污，佢都可以原告到被告...<br />\n<br />\n但都係需要一段時間令班港豬醒，所以最好佢出多啲醜聞。<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1b91b0729615e243bda55678716f8f5faae5cf24","tid":2023592,"uid":72457,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-19T06:23:11.000Z","msg":"黎智英就黎坐監<br />\n鄧就黎做保安局長"},{"pid":"04f19a4e04ce84ccca93bae69f3890f69d95deab","tid":2023592,"uid":264426,"like":0,"dislike":1,"score":-1,"quote":{"pid":"ac9d58ee8a11063efad490a701aaebaccf024e0e","tid":2023592,"uid":27882,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-05-19T06:12:12.000Z","msg":"諗太多喇你<br />\n<br />\n潛建呢啲野,你爆多一百幾十單都唔會扣到佢地血<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-19T06:24:44.000Z","msg":"你咁講其實都錯唔哂，連梁震英5000萬ugl都無事，仲可以做埋政協副主席<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1db7fbb35fb9390ba1031ac78c89399309e98835","tid":2023592,"uid":38668,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-19T06:25:57.000Z","msg":"任你報又點 官官相衛 怕你D咩?"},{"pid":"08bbff53807242b52d3c78e618a76c00cd8c448d","tid":2023592,"uid":264426,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-19T06:26:09.000Z","msg":"時間唔知幾時先可以結束呢一切<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"da00ae412efe7bda86a41fd9f3a57d02f736531b","tid":2023592,"uid":264426,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-19T06:27:54.000Z","msg":"港豬未燒到自己真係咩都唔理<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"ffdf648d04a137785e4281349cb0d01dd7b8eb64","t