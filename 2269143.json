core":0,"citedBy":0,"replyTime":"2020-11-03T09:51:43.000Z","msg":"<img src=\"/assets/faces/pig/read.gif\" class=\"hkgmoji\" />睇足全日開票"},{"pid":"f1fd736a7bb215f8a888520cbcc518d358ed17ed","tid":2269143,"uid":22553,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-11-03T09:52:25.000Z","msg":"即係要10號先有最終結果<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5603432c1d47636abcb2d18ed055b0d0fa640a1b","tid":2269143,"uid":295230,"like":0,"dislike":0,"score":0,"quote":{"pid":"f1fd736a7bb215f8a888520cbcc518d358ed17ed","tid":2269143,"uid":22553,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-11-03T09:52:25.000Z","msg":"即係要10號先有最終結果<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-03T09:53:19.000Z","msg":"如果勢均力敵就係<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"459a9dc6b1449f913e7aa2efd4448d300dd51820","tid":2269143,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-03T09:53:40.000Z","msg":"民主黨兩大票倉12點"},{"pid":"5b1917b636d5d85a423d23f110a182610d091b74","tid":2269143,"uid":8257,"like":0,"dislike":0,"score":0,"quote":{"pid":"f1fd736a7bb215f8a888520cbcc518d358ed17ed","tid":2269143,"uid":22553,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-11-03T09:52:25.000Z","msg":"即係要10號先有最終結果<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-03T09:54:16.000Z","msg":"拎到270就得啦"},{"pid":"f8db76b69b58e2f289ace99e0e5adfffd369f48b","tid":2269143,"uid":8257,"like":0,"dislike":0,"score":0,"quote":{"pid":"459a9dc6b1449f913e7aa2efd4448d300dd51820","tid":2269143,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-03T09:53:40.000Z","msg":"民主黨兩大票倉12點"},"citedBy":0,"replyTime":"2020-11-03T09:55:44.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />CA, NY, IL 3大票倉都唔係同時完"}]}