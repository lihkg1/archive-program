{"tid":2171733,"cid":5,"subCid":10,"title":"侵侵用武漢肺炎平價藥物HCQ打選戰，開始越來越多人聽","createTime":"2020-08-24T07:06:08.000Z","updateTime":"2020-08-26T04:04:24.000Z","uid":273218,"like":123,"dislike":16,"uniUserReply":35,"replies":[{"pid":"18695d2bf6a70fb4e10da5f47ac6bda23252c2d8","tid":2171733,"uid":273218,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-24T07:06:08.000Z","msg":"<a href=\"https://mobile.twitter.com/realDonaldTrump/status/1297715098795094017\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmobile.twitter.com%2FrealDonaldTrump%2Fstatus%2F1297715098795094017&d=aCvg504CNSeS5FxaNurzsjYSMhv%2BBpubH8pt7agTF2U%3D&h=a04278f7\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fmobile.twitter.com%2FrealDonaldTrump%2Fstatus%2F1297715098795094017&h=7a4025d6\" data-auto-link target=\"_blank\">https://mobile.twitter.com/realDonaldTrump/status/1297715098795094017</a><br />\n<br />\n有追開閻博士報導既一定知<br />\n武肺於病發初期階段，根本有平價藥可醫<br />\n但就因為WHO 同背後一D藥廠及中共勢力<br />\n一直制止人討論呢隻藥<br />\n如果病毒無料到又有藥醫<br />\n中共/世衛/藥廠靠疫苗發財<br />\n及靠病毒控制香港及世界既陰謀就會失敗<br />\n其實香港人都完全對呢隻藥蒙在鼓裡<br />\n而就算無藥或用舊藥<br />\n隻病毒依家係香港都算係不成氣候<br />\n明顯中共港共風向係唔想武肺被消滅<br />\n講真千言萬語都難書對邪魔既憤慨<br />\n希望中共奸計唔會成功"},{"pid":"e75f062d54ad234b344cbba118dd27e92b25462d","tid":2171733,"uid":273218,"like":53,"dislike":0,"score":53,"citedBy":0,"replyTime":"2020-08-24T07:09:15.000Z","msg":"美國人終於開始相信侵侵<br />\n武肺平價藥HCQ <br />\n被美國反侵政客及中共在背後政治化<br />\n以美國CDC為首的福奇博士多次用港式官腔妖魔化呢隻藥"},{"pid":"ddd360cbf65e571ff604d3c55a2cbdf20ca4f1c1","tid":2171733,"uid":273218,"like":3,"dislike":2,"score":1,"citedBy":0,"replyTime":"2020-08-24T07:11:09.000Z","msg":"要話比多D 香港人知，武肺係有藥醫"},{"pid":"acf0a4dda99da95de0cea08aabf2bd7d439a1a72","tid":2171733,"uid":92385,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-24T07:19:07.000Z","msg":"Push"},{"pid":"2f5d7cc1590e84934c1377165feed16f20209c89","tid":2171733,"uid":273218,"like":17,"dislike":0,"score":17,"citedBy":0,"replyTime":"2020-08-24T07:19:24.000Z","msg":"<img src=\"https://na.