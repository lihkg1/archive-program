%28%E9%A6%99%E6%B8%AF&d=BjPUJoueJJBj8huYKMWPWnlPKE5%2BvOhv5kPCmhOEeDs%3D&h=de251951\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/zh-hk/公安條例_(香港</a>)"},{"pid":"faba5a9100d3417c6b3fe519b14621cadb3920f6","tid":1979130,"uid":322195,"like":2,"dislike":0,"score":2,"quote":{"pid":"72b21e4ee58ab4e18fbe6ea98fc861f0caa3edad","tid":1979130,"uid":63934,"like":6,"dislike":0,"score":6,"citedBy":4,"replyTime":"2020-04-19T08:13:29.000Z","msg":"次次睇佢地發D所謂聲明就覺得好嘈<br />\n完全係謾罵,毫無道理<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-19T08:20:31.000Z","msg":"其實佢地係咪心裡面都想狠狠地爆美國一句NMSL<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"784a96dbd22aea5e260cccfb539b3e385eed12cf","tid":1979130,"uid":151924,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-04-19T08:21:02.000Z","msg":"咁咪取消香港關係法囉<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"4ebbc3c6c8e8358c3516e34071bf7afc7fef22b7","tid":1979130,"uid":87780,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T08:21:22.000Z","msg":"就嚟checkmate<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"e65e58808bf6485bbdad0df6a8b71a1db4938662","tid":1979130,"uid":7369,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-04-19T08:22:54.000Z","msg":"美國國務卿係代表美國, 唔係政客囉!"},{"pid":"7640cf6b3a4edc751cebc583ca002a621cf3b850","tid":1979130,"uid":7369,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-19T08:23:39.000Z","msg":"其實打咁大段嘢把鬼咩, 打NMSL咪算囉!"},{"pid":"9e42c2c964028331e87390f0ca439f6347987b07","tid":1979130,"uid":281189,"like":1,"dislike":0,"score":1,"quote":{"pid":"1297925b4ea8e81e8c5e078bad539107acd72168","tid":1979130,"uid":21470,"like":2,"dislike":0,"score":2,"quote":{"pid":"d631129e78dc1fdbbef0fa6787b6c32e2113a21d","tid":1979130,"uid":281189,"like":20,"dislik