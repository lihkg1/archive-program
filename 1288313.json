eea57edb25b62c0eeb1bfb9bc","tid":1288313,"uid":6448,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-05T16:22:36.000Z","msg":"24未追過人,太怕醜<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-05T16:38:20.000Z","msg":"你個名"},{"pid":"b4e12b5c11592495fac5f157a075c3c29df62cc5","tid":1288313,"uid":270548,"like":0,"dislike":1,"score":-1,"quote":{"pid":"cff1fa47148708f15d0da2037dc551d63254ef4f","tid":1288313,"uid":84172,"like":1,"dislike":0,"score":1,"quote":{"pid":"1d5afcdd114311c8c7b92ac0cdcb903c482aebfc","tid":1288313,"uid":270548,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e2edda6c4724de0f0e6b614022250c6de633eccb","tid":1288313,"uid":207336,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-05T15:38:57.000Z","msg":"對方冇反應<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-07-05T15:44:52.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-05T16:08:35.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-05T16:52:38.000Z","msg":"<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />我諗住試多一兩次都唔得就放棄<br />\n<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />好人永遠比人欺負欺騙<br />\n<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />就算放幾多心機去關心對方都係空氣<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />睇黎我註定永遠單身<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />好羨慕啲賤男，佢哋對女仔咁衰反而有女仔鍾意有女仔關心<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />自己本身對異性比較被動。因為怕醜，二來又唔識追女仔。<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />難得遇到個對自己好主動又溫柔，我初頭唔敢主動，但係見佢肯我同我傾計又一齊去玩，而且同佢一齊真係幾開心，佢又咁主動。<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />我先諗住試下主動再搵佢傾計，試下再約佢出街，點知佢態度同之前大翻轉<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />我拎個心出黎真係想試下做主動既時候就咁樣對我<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />連個天都要欺負我<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />當初諗住主動出擊嘅時候就已經打算放啲心機手整份禮物比佢<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />但見到佢態度忽然間咁冷淡，真心覺得好失望<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />點解當自己願意交個心出黎去看待對方就咁樣比人傷害<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />好恨自己心太軟，我依然相信佢同我解釋既理由<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />等到而家，佢終於得閒<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />我諗住試下搵佢傾計佢就直接唔睇<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />心好累，一直等佢既同時仲一邊傻傻咁整份禮物<br />\n<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />份禮物就嚟做好，但見到佢對我反應忽冷忽熱<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />其實我有諗過不如死左去算<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />以前成日都比女仔利用，而家嘗試拎個真心出嚟待人又遇到類似情況<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />點解係要揀我呢種好人去欺負⋯⋯<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />唔識追女仔，唔識玩女仔<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />偏偏就要受到咁既懲罰<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />我只係想搵個女仔比我鍚，又會互相關心，又可以一齊傾計，一齊去玩。"},{"pid":"5a1bc3394e523be13adff2c38a3d71451af632fc","tid":1288313,"uid":270548,"like":0,"dislike":0,"score":0,"quote":{"pid":"906a8260791995730a6ee5b7d0a220c10258ef6d","tid":1288313,"uid":207336,"like":0,"dislike":0,"score":0,"quote":{"pid":"1d5afcdd114311c8c7b92ac0cdcb903c482aebfc","tid":1288313,"uid":270548,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e2edda6c4724de0f0e6b614022250c6de633eccb","tid":1288313,"uid":207336,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-05T15:38:57.000Z","msg":"對方冇反應<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-07-05T15:44:52.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-05T16:37:36.000Z","msg":"有冇約出街先<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-05T16:53:08.000Z","msg":"我主動約嗰陣佢成日都話唔得閒"},{"pid":"93d632c2e9b55a94407bdaefb8109b540a683ce7","tid":1288313,"uid":84172,"like":0,"dislike":0,"score":0,"quote":{"pid":"b4e12b5c11592495fac5f157a075c3c29df62cc5","tid":1288313,"uid":270548,"like":0,"dislike":1,"score":-1,"quote":{"pid":"cff1fa47148708f15d0da2037dc551d63254ef4f","tid":1288313,"uid":84172,"like":1,"dislike":0,"score":1,"quote":{"pid":"1d5afcdd114311c8c7b92ac0cdcb903c482aebfc","tid":1288313,"uid":270548,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-07-05T15:44:52.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-05T16:08:35.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-05T16:52:38.000Z","msg":"<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />我諗住試多一兩次都唔得就放棄<br />\n<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />好人永遠比人欺負欺騙<br />\n<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />就算放幾多心機去關心對方都係空氣<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />睇黎我註定永遠單身<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />好羨慕啲賤男，佢哋對女仔咁衰反而有女仔鍾意有女仔關心<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />自己本身對異性比較被動。因為怕醜，二來又唔識追女仔。<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />難得遇到個對自己好主動又溫柔，我初頭唔敢主動，但係見佢肯我同我傾計又一齊去玩，而且同佢一齊真係幾開心，佢又咁主動。<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />我先諗住試下主動再搵佢傾計，試下再約佢出街，點知佢態度同之前大翻轉<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />我拎個心出黎真係想試下做主動既時候就咁樣對我<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />連個天都要欺負我<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />當初諗住主動出擊嘅時候就已經打算放啲心機手整份禮物比佢<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />但見到佢態度忽然間咁冷淡，真心覺得好失望<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />點解當自己願意交個心出黎去看待對方就咁樣比人傷害<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />好恨自己心太軟，我依然相信佢同我解釋既理由<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />等到而家，佢終於得閒<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />我諗住試下搵佢傾計佢就直接唔睇<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />心好累，一直等佢既同時仲一邊傻傻咁整份禮物<br />\n<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />份禮物就嚟做好，但見到佢對我反應忽冷忽熱<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />其實我有諗過不如死左去算<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />以前成日都比女仔利用，而家嘗試拎個真心出嚟待人又遇到類似情況<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />點解係要揀我呢種好人去欺負⋯⋯<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />唔識追女仔，唔識玩女仔<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />偏偏就要受到咁既懲罰<br />\n<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />我只係想搵個女仔比我鍚，又會互相關心，又可以一齊傾計，一齊去玩。"},"citedBy":1,"replyTime":"2019-07-06T00:46:46.000Z","msg":"一句講晒<br />\nShe is not the right one, why don&rsquo;t you move on?<br />\n呢個世界大把女 一個唔得咪下位<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\nBtw, 其實你係咪真係咁鍾意佢? 定只係咁啱一開始佢主動撩你玩"},{"pid":"1c1c86087baef2874eb8f95972595548053c5443","tid":1288313,"uid":119493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-06T00:59:11.000Z","msg":"比心機練跑,跑快d就追到"},{"pid":"bb26b1a8bf971bc370db12aed5f45d95ebc379ec","tid":1288313,"uid":270548,"like":0,"dislike":0,"score":0,"quote":{"pid":"93d632c2e9b55a94407bdaefb8109b540a683ce7","tid":1288313,"uid":84172,"like":0,"dislike":0,"score":0,"quote":{"pid":"b4e12b5c11592495fac5f157a075c3c29df62cc5","tid":1288313,"uid":270548,"like":0,"dislike":1,"score":-1,"quote":{"pid":"cff1fa47148708f15d0da2037dc551d63254ef4f","tid":1288313,"uid":84172,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-05T16:08:35.000Z","msg":"<im