dog/cry.gif\" class=\"hkgmoji\" /> 好感動<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-02-28T13:08:10.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e76aae2c76a1ecb2de81041745c2b9c6c9f237bf","tid":1040862,"uid":223385,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T13:33:27.000Z","msg":"老共強姦咗香港呢片土地<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"6f744ce5a9f53b3003e371b24d0c19ea560272ab","tid":1040862,"uid":167658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T13:37:05.000Z","msg":"eBay 有<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4e792710518251f693d1c3da7fc237ac8ab64c66","tid":1040862,"uid":3167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T13:38:32.000Z","msg":"有隻尿寧艇係到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6e364e985d65c1d08382ac3977da2957a5a40d37","tid":1040862,"uid":13450,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-02-28T13:40:14.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d87269af3f5966541eba45cabfe76d1b03734e80","tid":1040862,"uid":56701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T13:40:34.000Z","msg":"<span style=\"color: red;\">可惜已給支那粗暴地破壞了</span>"},{"pid":"2583b820221304c6333470df17a0bffc93489ffb","tid":1040862,"uid":18547,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T13:47:24.000Z","msg":"東方之珠 我的愛人 你的風采是否浪漫依然"},{"pid":"5afcc9f9d9bcb73c7985feed2c851421d2735b14","tid":1040862,"uid":198900,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T13:51:09.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />