id":"ab7f30fa251edbd86b86f309c886df94fe7a94bd","tid":1021074,"uid":134864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-14T05:04:12.000Z","msg":"豬年第一震（怒）？<img src=\"/assets/faces/lm2lny/haha.gif\" class=\"hkgmoji\" />"},{"pid":"142993105c73eadc61972cadd7b258cd726b0533","tid":1021074,"uid":280,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-14T05:04:56.000Z","msg":"可能個差佬當左銀包係自己隨手袋返好<img src=\"/assets/faces/lny/agree2.gif\" class=\"hkgmoji\" /> <br />\n平時用完人地D筆都不自然咁插落衫袋<img src=\"/assets/faces/lny/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"76cd0b2b3b7ec5fd118871ae3cbfd9220bf85a03","tid":1021074,"uid":35780,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-14T05:14:26.000Z","msg":"巧合"},{"pid":"b0d3c678809f4684f5d67a394902f48130f5d926","tid":1021074,"uid":39551,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-14T05:14:27.000Z","msg":"一時唔記得姐<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"dfd09ceab0b23f44fe21c938362bb4b04679a3a7","tid":1021074,"uid":19978,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-02-14T05:15:40.000Z","msg":"又贏<br />\n<br />\n細個會話樹大有枯枝，警察都有壞人<br />\n<br />\n宜家調番轉，警察都有好人嘅，應該啦"},{"pid":"dac9a8a5477912a58a97b335b67749e1b0559e40","tid":1021074,"uid":5020,"like":0,"dislike":0,"score":0,"quote":{"pid":"6152d555b8bec3b844d44ecae5fc7d35c92288aa","tid":1021074,"uid":6497,"like":19,"dislike":0,"score":19,"quote":{"pid":"acc5a2d8846b48195e3e738638d2a14a80f9d851","tid":1021074,"uid":5020,"like":0,"dislike":7,"score":-7,"quote":{"pid":"0c4f7fdeab1843656cfdce0611ad1c9227717f3b","tid":1021074,"uid":6497,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-14T04:20:40.000Z","msg":"<img src=\"https://static.appledaily.hk/images/e-paper/20190214/large/1550116068_09cb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190214%2Flarge%2F1550116068_09cb.jpg&h=95f60337&s={SIZE}\" /><br />\n<br />\n機場客運大樓報案中心，懷疑有警員監守自盜，私吞市民拾獲的銀包。拾遺者聯絡物主後揭發事件，警方拘捕一名涉案警員調查。<br />\n<br />\n消息稱，昨晚11時左右，有市民在機場內撿獲一個銀包，內有5萬港元，於是好心交到客運大樓的報案中心；由於銀包內有物主的聯絡電話，該名市民也同時致電物主，告知銀包已交予警方。<br />\n約3小時後，物主到報案中心報失及認領，這才揭發事件並沒立案，懷疑有人監守自盜；警方經調查後拘捕一名涉事警員。<br />\n<br />\n《蘋果》正就事件向警方查詢。<br />\n<br />\n根據警方程序，負責處理這類失物案的警員，須將拾遺者的資料用電腦記錄，並向對方發出收據；之後將拾獲財物移交財物室，當物主領回失物時亦需簽署收據。"},"citedBy":1,"replyTime":"2019-02-14T04:24:32.000Z","msg":"呢單嘢好似早兩日有post"},"citedBy":1,"replyTime":"2019-02-14T04:25:46.000Z","msg":"<a href=\"https://hk.news.appledaily.com/breaking/realtime/article/20190214/59257599\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20190214%2F59257599&d=ZfEq%2Fo1sgt4RLlfWMFNbDnwvfzOYOHHotQSumXQzHeA%3D&h=6d9ea7d9\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20190214%2F59257599&h=f3569270\" target=\"_blank\">https://hk.news.appledaily.com/breaking/realtime/article/20190214/59257599</a><br />\nChing由邊個時空返黎<img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-14T05:23:17.000Z","msg":"唔係<br />\n早兩日有人post 話機場執咗銀包<br />\n入面有幾萬銀<br />\n交咗畀警察"},{"pid":"498aab477b4a10f79381eb1123b79ccb1ce5b7ae","tid":1021074,"uid":165493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-14T05:23:28.000Z","msg":"警方發言人：由於負責警員太忙 忘記立案 該事件純屬誤會"},{"pid":"4b844d135ae1336a799ffc97c93259d8fd52620e","tid":1021074,"uid":139242,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-14T05:24:40.000Z","msg":"市民仲正義過警察<br />\n<br />\n不過比著我執到可能都唔報"},{"pid":"839d62150dd0c25d120567aea0b51c8e4d2f690c","tid":1021074,"uid":35014,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2019-02-14T05:25:54.000Z","msg":"此回覆已被刪除"},{"pid":"eb7bfa5b15f92c13452df2279906148ab1238a