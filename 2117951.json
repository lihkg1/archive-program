/clap.gif\" class=\"hkgmoji\" />"},{"pid":"8b0464541f9ad00d014a7a01ef2b987d7d59e367","tid":2117951,"uid":111487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-21T07:48:51.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />要買定汽車股了"},{"pid":"1a2ccdb725ac9ea0ab753da1ea23d8d1551e9d46","tid":2117951,"uid":22736,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-21T07:52:19.000Z","msg":"你重建間屋買過部車冇錢去其它消費咪一撚樣<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1b5ab7f65fcbff69a4ae32d7551a06f75696fbc2","tid":2117951,"uid":301100,"like":2,"dislike":0,"score":2,"quote":{"pid":"ce412a3b72cfdf7bdafdd1e7e8928af8b4350b02","tid":2117951,"uid":53687,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-07-21T07:30:24.000Z","msg":"第二點係德國開心，唔係中國開心喎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-21T08:01:22.000Z","msg":"best friend開心咪即係自己開心<img src=\"/assets/faces/lm2/yeah.gif\" class=\"hkgmoji\" />"},{"pid":"d9f9b53f23922406cd96e7633a083cd63e5a2bbb","tid":2117951,"uid":301100,"like":0,"dislike":0,"score":0,"quote":{"pid":"1a2ccdb725ac9ea0ab753da1ea23d8d1551e9d46","tid":2117951,"uid":22736,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-21T07:52:19.000Z","msg":"你重建間屋買過部車冇錢去其它消費咪一撚樣<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-21T08:02:18.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />起樓先容易chock大條數，如果唔係起咁多鬼城做乜"},{"pid":"59d94a52bfcfe8cca4d6e87bf0364aee5dcb7775","tid":2117951,"uid":3149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-21T09:20:36.000Z","msg":"Push <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"62249976fc6d1ab48aadb12f24cd3a4ead82f13a","tid":2117951,"uid":293677,"like":0,"di