s://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%2Fi%2FfG2wAOr.png&h=be9d60ce&s={SIZE}\" />"},{"pid":"2508921e24b6330a9c0b4da0f7cb75f547945794","tid":1393582,"uid":128117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T06:52:28.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"9c0f0a650432b14fcfda4ee9b4b74e1cfa5b2e52","tid":1393582,"uid":71237,"like":3,"dislike":4,"score":-1,"quote":{"pid":"0f22d8fe73e3726fb4e510aaf7eb924921a9097d","tid":1393582,"uid":81190,"like":6,"dislike":2,"score":4,"citedBy":1,"replyTime":"2019-08-01T06:46:12.000Z","msg":"讀econ 嘅男仔係咪高質啲"},"citedBy":1,"replyTime":"2019-08-01T06:53:30.000Z","msg":"絕對係啦。<br />\nScience的慎密頭腦、Business的務實、Social Sciences的心腸。"},{"pid":"803ee2ba2c75b244a99d593b58204696289aad56","tid":1393582,"uid":128117,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-01T06:54:25.000Z","msg":"情形其實類似呢到正負皮<br />\nYoutube其實一早大把youtuber解釋過其實dislike幾乎係等同like (當然一定冇like+留comment吸金)<br />\n<br />\n而FB嬲嬲根本直頭就係Like <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e8365b510de6e1b40659dd03492955d869a873b5","tid":1393582,"uid":145277,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-01T06:56:30.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"7509f02adb2fb4e098e0badee773d6fbc4c5be52","tid":1393582,"uid":71237,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-01T07:10:00.000Z","msg":"舉多個例子，前排大陸「帝吧」聲稱要嚟FB洗版。<br />\n依啲所謂網軍只會集中喺FB page最新的一兩個post大量留言，依種攻擊根本唔洗驚。<br />\n<br />\n只要你唔好click入去睇留言，其實佢留一億個comment對你都係毫無影響。<br />\n你事後直接del post可以一次過全部刪哂添。<br />\n<br />\n比較麻煩嘅對方喺你所有嘅post都留言，咁就比較難清理。<br />\n不過大規模的網軍一般都諗唔到依點，只有三毛／真心膠先會咁做。"},{"pid":"99ab402e712e0015a4a7beb408628fa9adb87e81","tid":1393582,"uid":71237,"like":0,"dislike":0,"score":0,"quote":{"pid":"803ee2ba2c75b244a99d593b58204696289aad56","tid":1393582,"uid":128117,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-01T06:54:25.000Z","msg":"情形其實類似呢到正負皮<br />\nYoutube其實一早大把youtuber解釋過其實dislike幾乎係等同like (當然一定冇like+留comment吸金)<br />\n<br />\n而FB嬲嬲根本直頭就係Like <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-01T07:38:15.000Z","msg":"係呀<br />\n高登派膠同連登比負評都唔會令對方收皮。<br />\n有啲人反而仲會沾沾自喜。"},{"pid":"f56c4c387507dcd623c283c2b9a3b8e797fe3154","tid":1393582,"uid":997,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-01T07:39:34.000Z","msg":"dislike可以令到youtube唔比錢條臭閪,咁又叫冇用?"},{"pid":"e013876ac63a74c38626552ed0accfa747a9d244","tid":1393582,"uid":24466,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T07:43:16.000Z","msg":"推"},{"pid":"872b449ece096faaf5d85696e226bce3d7cfef2f","tid":1393582,"uid":263219,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c0f0a650432b14fcfda4ee9b4b74e1cfa5b2e52","tid":1393582,"uid":71237,"like":3,"dislike":4,"score":-1,"quote":{"pid":"0f22d8fe73e3726fb4e510aaf7eb924921a9097d","tid":1393582,"uid":81190,"like":6,"dislike":2,"score":4,"citedBy":1,"replyTime":"2019-08-01T06:46:12.000Z","msg":"讀econ 嘅男仔係咪高質啲"},"citedBy":1,"replyTime":"2019-08-01T06:53:30.000Z","msg":"絕對係啦。<br />\nScience的慎密頭腦、Business的務實、Social Sciences的心腸。"},"citedBy":0,"replyTime":"2019-08-01T07:46:37.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"7d019c59cda115fb41e812df74416d5a5c1e7932","tid":1393582,"uid":71237,"like":0,"dislike":0,"score":0,"quote":{"pid":"f56c4c387507dcd623c283c2b9a3b8e797fe3154","tid":1393582,"uid":997,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-01T07:39:34.000Z","msg":"dislike可以令到youtube唔比錢條臭閪,咁又叫冇用?"},"citedBy":0,"replyTime":"2019-08-01T07:47:29.000Z","msg":"1. 有冇sources? 佢自己本人講出嚟都未必可信。<br />\n因為YouTube廣告費本身賺得唔多，經YouTube捐錢又會抽3成。<br />\n可能佢想人地直接入錢落佢戶口先聲稱自己被dislike搞到無錢收。<br />\n<br />\n2. 外國有冇其他YouTuber內容無違規無hateful content，純粹多人比dislike就比YouTube cut廣告？"},{"pid":"11c31f44af3953f1096b5dc725d53f54adfbf778","tid":1393582,"uid":262674,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-08-01T07:48:01.000Z","msg":"<span style=\"font-size: x-large;\">因為 dislike 可以係代表你對入面既內容 dislike<br />\n<br />\n「你講既呢樣野係令人好嬲，我同意你」<br />\n<br />\n而唔係對條片 dislike<br />\n<br />\n所以係唔會令人收皮仲加速佢發達</span>"},{"pid":"a385c00902cd2c4713d6c1c38c2e2f59855f4893","tid":1393582,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T10:36:37.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"5ad35de2e52b19f514a1dc26e56c58a9e2dc3e5a","tid":1393582,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T12:55:24.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"086bd1196a11404e1ca80aef849eef4a7b3ddd03","tid":1393582,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T16:07:34.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"603ab3c94ba149bc6d9e2fc7910435fda407c305","tid":1393582,"uid":258362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T16:34:26.000Z","msg":"<a href=\"https://lihkg.com/thread/1395073/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1395073/page/1</a><br />\n<br />\n尋晚反應非常熱烈，今晚繼續"},{"pid":"ccf245adc6c0ff7f50f85319c5950e8a05b321c7","tid":1393582,"uid":75072,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T16:36:04.000Z","msg":"請善用檢舉功能"},{"pid":"2e276596862305423718353e0cfd9282ec09884c","tid":1393582,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T02:09:28.000Z","msg":"李力持 FB 被禁30日！！！（報捷）<br />\n<a href=\"https://lih.kg/1481910\" target=\"_blank\">https://lih.kg/1481910</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n依個post證明比嬲嬲係無用<br />\n要report先有用"}]}