出咋"},{"pid":"b4a165fe910a823ed61332cb9e3d2c9d37ee406f","tid":1176141,"uid":44458,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-28T08:49:02.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2019/06/28/164846_157655081a55954b4637fe2613b24ba2.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F06%2F28%2F164846_157655081a55954b4637fe2613b24ba2.JPG&h=617ae19e&s={SIZE}\" />"},{"pid":"e0c5c21bf711344dc3300649b5061d3242117a40","tid":1176141,"uid":291957,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T12:13:11.000Z","msg":"<img src=\"https://na.cx/i/fh7sN7j.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Ffh7sN7j.png&h=84b5bc68&s={SIZE}\" /><br />\n<br />\n我們【香港之旗團隊】好想集合大家的意見及設定，去創造一枝能代表香港嘅旗！<br />\n<br />\n【香港之旗設計大賽】<br />\n活動會分主要兩個階段<br />\n階段一：收集設計 <br />\n大家藝術人/設計師可將設計發送到電郵：<br />\nhongkongflag2019@gmail.com<br />\n / 或TG: @hongkongflag<br />\n 1. 不大於1 Gb 的JPG 檔案<br />\n 2. 連同你的創作意念 (不多於200字）<br />\n 3. 所有投稿都會以匿名發表<br />\n 4. 必須要是原創<br />\n<br />\n階段二：全民投票<br />\n到時會於合適的平台，供大家投票<br />\n(詳細資料，之後公佈）<br />\n<br />\n香港之旗，由你決定！<br />\n光復香港，時代革命！<br />\n五大訴求，缺一不可！<br />\n-----------------------------<br />\n想討論？可去以下TG group: <br />\n <a href=\"https://t.me/joinchat/Ndm9DhXqd9p3ZHosNDNggQ\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fjoinchat%2FNdm9DhXqd9p3ZHosNDNggQ&d=DJJewhOFhIMK5JRdM%2BI1LnqjnVJZrvj6qhhAu%2BA3ahw%3D&h=76779999\" data-auto-link target=\"_blank\">https://t.me/joinchat/Ndm9DhXqd9p3ZHosNDNggQ</a>"}]}