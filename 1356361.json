a58f729ef","tid":1356361,"uid":38842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T15:06:25.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"fbfcbf6b1dc4f11ad61486f081d2dc71c53525f6","tid":1356361,"uid":275475,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T15:11:48.000Z","msg":"LM"},{"pid":"b39c043b51aa3988612e6058e3a36949dfeb8fab","tid":1356361,"uid":47135,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T15:20:51.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f0f6792e3f2f4223559f08b69b10a6ad98ad41f6","tid":1356361,"uid":38842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T15:27:06.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a6f0e30ce5d5fbce9a976ff056bc73870096ecbf","tid":1356361,"uid":38842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T15:40:57.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"8e6f106a8d2bd4819e866b6616d2fc04ebd2235a","tid":1356361,"uid":13125,"like":1,"dislike":0,"score":1,"quote":{"pid":"260efbf731f4452fd809293e391a6e19f9b1d229","tid":1356361,"uid":38842,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-23T14:10:54.000Z","msg":"<a href=\"https://www.inmediahk.net/node/1065889\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1065889&d=YTg1cObnFWHTBoRPd5eD4fSletu%2BpyBbwtETYsduqsw%3D&h=c7abd570\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1065889&h=d1aa8038\" target=\"_blank\">https://www.inmediahk.net/node/1065889</a><br />\n石鏡泉撤回藤條論 朱凱廸指已涉刑事：留返上法庭自辯<br />\n<br />\n（獨媒特約報導）《香港經濟日報》副社長石鏡泉周六（20日）高調現身參與「守護香港」集會，揚言「教仔」要用藤條、鐵通及膠水喉。昨晚（21日）民陣遊行後，有市民遭大批白衣人在元朗西鐵站以鐵枝和藤條等武器暴力亂舞狂毆致血流成河，石鏡泉一語成真。有《經濟》記者發起聯署，譴責石鏡泉公然散怖白色恐怖。他最終跪底認錯，表示撤回藤條論，對引發社會不安致歉。<strong><span style=\"color: red;\">立法會議員朱凱廸表示，石的言論已衍生嚴重暴力，更涉及刑事罪行，「唔係一句道歉可以了結」。朱凱廸促請警察盡快拘捕和檢控石鏡泉，「上法庭以自己的解讀辯護吧」。</span></strong><br />\n<br />\n在集會當日，石鏡泉稱美國此等「惡勢力」令中國崛起，並賄賂年輕人「亂中亂港」，但及後突然語無倫次，先多謝元朗鄉親正義敢爲（撕毀連儂牆及及於元朗放映會上搗亂）；又指「我哋唔係暴，我哋連語言暴力都冇」，但對抗「暴徒」時卻要挺身而出。他更反問在場人士，「屋企有冇藤條啊？拿藤條出嚟，搵長少少嘅，打仔！屋企冇藤條點呀？我哋去五金舖，買條20mm嘅水喉通，教仔！」<br />\n<br />\n而大批參與民陣遊行後的元朗居民，在晚上乘坐西鐵回到元朗站時，突然遭大批白衫人士施襲，孕婦和長者同未能倖免，立法會議員林卓廷更遭毆打至嘴角需縫針。近百名經濟日報記者今日便聯署，譴責石鏡泉煽惑暴力的言論，指「深表震驚及極度遺憾」。<br />\n<br />\n石鏡泉最終在晚上「跪低」，發聲明道歉，又稱當日的言論只屬個人意見，不代表《經濟日報》。他表示出席集會的原因是要反暴力，認為這是每名香港人的責任。他更指「藤條論」經過網上剪接，更質疑有媒體砌詞造假，形容是「節錄式地」東併西接，未能反映事實的全部。<br />\n<br />\n朱凱廸則呼籲，石鏡泉應誠實面對自己說過的話，又重申一個理解能力正常的人，都會認為石在集會上的發言，是鼓吹民眾以藤條等武器，攻擊反送中的示威者，而非自衛。"},"citedBy":1,"replyTime":"2019-07-23T15:52:47.000Z","msg":"上法庭自辯？<br />\n辯咩先告咩先係咪煽惑暴動先"},{"pid":"fb31e0f782fb76319d92ac2b6d2c73c2da3ce275","tid":1356361,"uid":38842,"like":0,"dislike":0,"score":0,"quote":{"pid":"8e6f106a8d2bd4819e866b6616d2fc04ebd2235a","tid":1356361,"uid":13125,"like":1,"dislike":0,"score":1,"quote":{"pid":"260efbf731f4452fd809293e391a6e19f9b1d229","tid":1356361,"uid":38842,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-23T14:10:54.000Z","msg":"<a href=\"https://www.inmediahk.net/node/1065889\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1065889&d=YTg1cObnFWHTBoRPd5eD4fSletu%2BpyBbwtETYsduqsw%3D&h=c7abd570\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1065889&h=d1aa8038\" target=\"_blank\">https://www.inmediahk.net/node/1065889</a><br />\n石鏡泉撤回藤條論 朱凱廸指已涉刑事：留返上法庭自辯<br />\n<br />\n（獨媒特約報導）《香港經濟日報》副社長石鏡泉周六（20日）高調現身參與「守護香港」集會，揚言「教仔」要用藤條、鐵通及膠水喉。昨晚（21日）民陣遊行後，有市民遭大批白衣人在元朗西鐵站以鐵枝和藤條等武器暴力亂舞狂毆致血流成河，石鏡泉一語成真。有《經濟》記者發起聯署，譴責石鏡泉公然散怖白色恐怖。他最終跪底認錯，表示撤回藤條論，對引發社會不安致歉。<strong><span style=\"color: red;\">立法會議員朱凱廸表示，石的言論已衍生嚴重暴力，更涉及刑事罪行，「唔係一句道歉可以了結」。朱凱廸促請警察盡快拘捕和檢控石鏡泉，「上法庭以自己的解讀辯護吧」。</span></strong><br />\n<br />\n在集會當日，石鏡泉稱美國此等「惡勢力」令中國崛起，並賄賂年輕人「亂中亂港」，但及後突然語無倫次，先多謝元朗鄉親正義敢爲（撕毀連儂牆及及於元朗放映會上搗亂）；又指「我哋唔係暴，我哋連語言暴力都冇」，但對抗「暴徒」時卻要挺身而出。他更反問在場人士，「屋企有冇藤條啊？拿藤條出嚟，搵長少少嘅，打仔！屋企冇藤條點呀？我哋去五金舖，買條20mm嘅水喉通，教仔！」<br />\n<br />\n而大批參與民陣遊行後的元朗居民，在晚上乘坐西鐵回到元朗站時，突然遭大批白衫人士施襲，孕婦和長者同未能倖免，立法會議員林卓廷更遭毆打至嘴角需縫針。近百名經濟日報記者今日便聯署，譴責石鏡泉煽惑暴力的言論，指「深表震驚及極度遺憾」。<br />\n<br />\n石鏡泉最終在晚上「跪低」，發聲明道歉，又稱當日的言論只屬個人意見，不代表《經濟日報》。他表示出席集會的原因是要反暴力，認為這是每名香港人的責任。他更指「藤條論」經過網上剪接，更質疑有媒體砌詞造假，形容是「節錄式地」東併西接，未能反映事實的全部。<br />\n<br />\n朱凱廸則呼籲，石鏡泉應誠實面對自己說過的話，又重申一個理解能力正常的人，都會認為石在集會上的發言，是鼓吹民眾以藤條等武器，攻擊反送中的示威者，而非自衛。"},"citedBy":1,"replyTime":"2019-07-23T15:52:47.000Z","msg":"上法庭自辯？<br />\n辯咩先告咩先係咪煽惑暴動先"},"citedBy":0,"replyTime":"2019-07-23T15:58:39.000Z","msg":"告普通市民告得咁兇狠，唔係唔拉何君堯呀"},{"pid":"86b19df75be8762c42b01184dbec9892103ec2f0","tid":1356361,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T16:03:30.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"087519a75b5c7a128f42fdbe8b79cfaaee6a6a80","tid":1356361,"uid":38842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T16:38:04.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"3fb56a4363cd95dd9edd6d79fc7e4375678293ef","tid":1356361,"uid":13125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T16:59:39.000Z","msg":"<a href=\"https://www.info.gov.hk/gia/general/201907/22/P2019072200828.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.info.gov.hk%2Fgia%2Fgeneral%2F201907%2F22%2FP2019072200828.htm&d=YTg1cObnFWHTBoRPd5eD4fSletu%2BpyBbwtETYsduqsw%3D&h=0f044b96\" target=\"_blank\">https://www.info.gov.hk/gia/general/201907/22/P2019072200828.htm</a><br />\n康文署都話有公眾安全考慮要早收<br />\n咁有無破壞社會安寧<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"dc9bb7ba4c6e4ab955815140e51f04d4cd19e9a0","tid":1356361,"uid":13125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T18:19:51.000Z","msg":"<a href=\"https://hk.news.appledaily.com/breaking/realtime/article/20190723/59853326\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledai