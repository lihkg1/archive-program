8:19.000Z","msg":"明老屈啦"},{"pid":"55170a86f0c1a236791b9e167ed8142211c346f0","tid":1782663,"uid":159583,"like":1,"dislike":0,"score":1,"quote":{"pid":"b427e56906481ebd9f65d93dac811c67ee6937f8","tid":1782663,"uid":302917,"like":3,"dislike":16,"score":-13,"citedBy":6,"replyTime":"2019-12-14T07:16:01.000Z","msg":"Dklm意圖傷人唔叫犯法，咁係咪只要唔掟中人，日日可以喺大馬路上面玩磚頭派對？"},"citedBy":0,"replyTime":"2019-12-14T07:39:49.000Z","msg":"你老母掟磚 又唔告暴動?"},{"pid":"8cd246f102e555eb53da334c15181616c4cf0ed0","tid":1782663,"uid":314611,"like":0,"dislike":0,"score":0,"quote":{"pid":"9ae2ae87aa9aedfc18e94ed5a0cb3487ffecef25","tid":1782663,"uid":37869,"like":21,"dislike":0,"score":21,"citedBy":2,"replyTime":"2019-12-14T07:13:06.000Z","msg":"旺角騷亂】現場有警員掟磚？ 高級警司：無可厚非可以接受<br />\n<br />\n2016年大年初二旺角發生騷亂，本土民主前線前發言人梁天琦及「美國隊長」容偉業等人被控暴動罪，案件繼續審理。當日置身現場的高級警司莫慶榮出庭作供，辯方盤問時播出當晚疑有警員掟磚片段，質疑莫明知警員掟磚卻未有阻止，同屬參與暴動。莫不同意，堅稱當晚沒留意到有警員掟磚。辯方追問，警方掟磚是否可取？莫直言當時警方遭受生命威脅，面對暴徒投擲「磚雨」，警方還手掟磚絕對是「無可厚非，可以接受」。<br />\n<a href=\"https://hk.news.appledaily.com/local/realtime/article/20181231/59089645\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20181231%2F59089645&d=wPrcUaBjKD1L%2BB1JqNzGIPUUj30esm9w7dCaRgXMgeE%3D&h=de272208\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20181231%2F59089645&h=c9875692\" target=\"_blank\">https://hk.news.appledaily.com/local/realtime/article/20181231/59089645</a>"},"citedBy":1,"replyTime":"2019-12-14T07:40:17.000Z","msg":"咁呢單係咪可以引用黎打？<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"0c1cde28915e9383a58e28c3836222a7e220d504","tid":1782663,"uid":226739,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-12-14T07:41:20.000Z","msg":"其實就算掟唔中，會唔會照告謀殺/誤殺？"},{"pid":"c2ee5d58cffc4743da99b8d610f75bccdfb550a7","tid":1782663,"uid":146737,"like":0,"dislike":0,"score":0,"quote":{"pid":"91a78192ad98bbccb40d004d7658a598e9d3beb2","tid":1782663,"uid":21545,"like":19,"