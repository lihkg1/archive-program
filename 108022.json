hkgmoji\" />"},{"pid":"efa33d3c822fb3b221754d43b1ba45099a132c31","tid":108022,"uid":37666,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-05T03:35:34.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"507ef254e1d62c05a8d1706b0f25a3ee0dc30ce1","tid":108022,"uid":61974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-05T03:37:01.000Z","msg":"封建時代VS後帝王時代"},{"pid":"64c0c81d22ae36f47338cbcde9064c68eeddc09a","tid":108022,"uid":609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-05T03:39:41.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 大陸 人唔笑狗都吠"},{"pid":"542b0ef38b15834a165fbdfb81cdced5f00f20f7","tid":108022,"uid":45252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-05T03:49:22.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>人地退役，中共都未發明到出來<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n佢而家果隻遼寧號其實同二戰日本果啲有冇得比？因為我冇睇過話日本果隻可能會有裂痕阿之類嘅戇鳩野<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n日本嗰隻無超市，無手信舖，入面無籃球聯賽<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n二戰時期日本其實好多航母都係改裝而成，當時好多航母都係咁，因為除咗美國佬之外無人睇好航母，航母嘅霸主地位係二戰之後先確立。<br />\n好似日本最大航母信濃號船體原本係用黎起第三艘大和級戰列艦<br />\n當時好多航母都係貨船改裝，有裂痕真係正常不過"},{"pid":"17088d62a1029e46f84a5ddaa6cf49827a14de70","tid":108022,"uid":16034,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-05T03:54:19.000Z","msg":"攞企業號比唔好玩啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />  翻新後既企業號做標準根本屌打其他國家既航母 就算戴高樂號計排水量同艦載機都要低知level<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c37eb2e32c9