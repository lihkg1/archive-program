25:53.000Z","msg":"唔太熟 容我先做a再慢慢諗<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<br />\np(a')=1-a<br />\np(b|a')=0.3<br />\np(a')p(b|a')=p(a' n  b)=0.3(1-a)<br />\np(b)=b<br />\np(a'|b)=0.6<br />\np(b)p(a'|b)=p(a' n  b)=0.6b<br />\n0.6b=0.3(1-a)<br />\n2b=1-a<br />\na+2b=1"},{"pid":"79e0071aab184adae04132435ccccfed3fc5b632","tid":93852,"uid":45055,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-24T18:31:48.000Z","msg":"<blockquote>唔太熟 容我先做a再慢慢諗<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<br />\np(a')=1-a<br />\np(b|a')=0.3<br />\np(a')p(b|a')=p(a' n  b)=0.3(1-a)<br />\np(b)=b<br />\np(a'|b)=0.6<br />\np(b)p(a'|b)=p(a' n  b)=0.6b<br />\n0.6b=0.3(1-a)<br />\n2b=1-a<br />\na+2b=1</blockquote><br />\n<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />等你既b"},{"pid":"b9a3e0d5814c538413b84c43fd82825cff04be0c","tid":93852,"uid":14144,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-24T18:36:00.000Z","msg":"依d數 畫左個 venn diagram 應該無野係解唔到 <br />\n除左conditional probability"},{"pid":"04c9b2b564de22c9b9a27deb6bf1aa4f11db61e9","tid":93852,"uid":49004,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-24T18:40:46.000Z","msg":"p(a u b')<br />\n=p(a)+p(b')-p(a  n  b')<br />\n=a + (1-b) - p(a)p(b'|a)<br />\n=a+1-b-0.7a<br />\n=0.3a-b+1<br />\n<br />\nsince 相反關係<br />\n1-b+0.3a = 1- (0.6b) = 1- 0.3(1-a)<br />\na題 prove到  一條式 a+2b=1<br />\n另外 1-b+0.3a=1-0.6b<br />\n==&gt; a=(4/3)b<br />\nthen sub落1式 a+2b=1<br />\n(4/3)b+2b=1<br />\nb=0.3<br />\na=0.4"},{"pid":"965ecb3e60401dd22c2fe2ca421702c7dca5c28b","tid":93852,"uid":60948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-24T18:43:09.000Z","msg":"我唔肯定咁樣岩定錯<img src=\"/assets/faces/lomoji/25.png\" class=\"hkgmoji\" /> <br />\n<br />\nP(AUB') + P(A'andB) =1<br />\nP(A) + P(B') -P(AandB') +P(A'andB)=1<br />\na+(1-b)-0.7a+(1-a)(0.3)=1<br />\na+1-b-0.7a+0.3-0.3a=1<br />\n1.3-b=1<br />\nb=0.3<br />\n<br />\n然後用番上面證明到a+2b=1黎計<br />\na+2(0.3)b=1<br />\na=0.4"},{"pid":"94091c98ef673cb68bcc707a7f6b63cf9200460e","tid":93852,"uid":45055,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-24T18:51:35.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />兩位都岩曬<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n連登有愛thx"},{"pid":"80bb4870d7b62ffa8f5156f7f2a1ba5928535743","tid":93852,"uid":45055,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-24T18:51:46.000Z","msg":"<blockquote>依d數 畫左個 venn diagram 應該無野係解唔到 <br />\n除左conditional probability</blockquote><br />\n<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />試下先"},{"pid":"e5685fa177d84e49fa86166bde9379e15c0113d7","tid":93852,"uid":49004,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-24T18:51:54.000Z","msg":"c)<br />\np(b'|a)=0.7<br />\nthen p(b|a)=1-0.7=0.3<br />\np(a)p(b|a)=p(a  n  b)=0.4 x 0.3 =0.12<br />\np(a)p(b)=0.4x0.3=0.12<br />\nsince p(a   n   b)=p(a)p(b)<br />\nA and B are independent<br />\n<br />\n有錯請屌<br />\n書包早已拋低 啱啱先去查下啲 probability identities<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7791f4003a2627994e39986fb0d26248f77c13fa","tid":93852,"uid":49004,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-24T19:08:08.000Z","msg":"你用 Union呢個字去記住 U =集合=and<br />\nn就好似個骰衷咁cup住一個範圍啲野 = intersect<br />\n可能記得好啲 唔會撈亂兩者 鳩up<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"}]}