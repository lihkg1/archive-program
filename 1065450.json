5:56.000Z","msg":"佢有份掟磚同打差佬"},"citedBy":2,"replyTime":"2019-03-17T10:00:06.000Z","msg":"有Ｄ差佬會放過佢？"},"citedBy":0,"replyTime":"2019-03-17T10:11:31.000Z","msg":"嘩，條友咁都講得出<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"c0defca379b5d3590029a40ad3308318d832fe56","tid":1065450,"uid":149494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-17T10:27:22.000Z","msg":"支持佢<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f46036a9df1246763c844f3df2bc8ffa3cb484ad","tid":1065450,"uid":131245,"like":0,"dislike":1,"score":-1,"quote":{"pid":"88d7d0357f9b5f080493335f8984dbe78b9c5a7c","tid":1065450,"uid":72009,"like":0,"dislike":0,"score":0,"quote":{"pid":"9055520d429c64492b3d95683ad46cb218bb6628","tid":1065450,"uid":131245,"like":2,"dislike":6,"score":-4,"quote":{"pid":"52185e607c9e760306b597e50c069ade8b3f6a7f","tid":1065450,"uid":72009,"like":25,"dislike":4,"score":21,"citedBy":2,"replyTime":"2019-03-17T09:23:41.000Z","msg":"佢從來冇叫人去掟磚，就是太泛民俾你們屌，人總要生活，人地有本事走，懶理你班本土領袖，現在所有反對力量由你們本土揸旗，將立23條，等看你們抗爭！"},"citedBy":1,"replyTime":"2019-03-17T09:55:56.000Z","msg":"佢有份掟磚同打差佬"},"citedBy":2,"replyTime":"2019-03-17T10:00:06.000Z","msg":"有Ｄ差佬會放過佢？"},"citedBy":0,"replyTime":"2019-03-17T10:32:07.000Z","msg":"你up乜撚嘢呀？"},{"pid":"ed9b60b2cb9d1c2480c0d55c2643e90683f7c719","tid":1065450,"uid":48083,"like":0,"dislike":0,"score":0,"quote":{"pid":"467730d601bb5b0d13adfc4b78c7c4314dfdb73f","tid":1065450,"uid":131245,"like":4,"dislike":12,"score":-8,"quote":{"pid":"ce8a989d9c5662fc35128740d6e5c1b92497f69b","tid":1065450,"uid":130626,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-17T09:16:12.000Z","msg":"轉眼間雨傘運動過去逾4年，帶領79日佔領的「學聯五子」，今日可謂天各一方、各有各忙，唯獨時任學聯常委羅冠聰正式踏上政治之路，代表香港眾志出戰立法會選舉，以5萬多票成為立法會史上最年輕的議員。惟其後因宣誓風波，被取消議員資格，歷經在囚等種種風雨。<br />\n羅冠聰昨晚（17日）在其facebook撰文回憶數年以來的從政之路，感慨指這幾年來所學到的，定必比只在課室唸幾年書更多。惟他亦認為，現在是時候提升自己的智慧和學養，透露將會於今年暑假負笈美國耶魯大學，修讀1年東亞研究系碩士課程，並稱「離開是為了回來」。<br />\n繼學聯前秘書長周永康出走、到美國加州大學柏克萊分校進攻博士，羅冠聰昨日亦在其facebook宣佈，將會於今年暑假遠赴美國，修讀1年碩士課程。羅冠聰憶述過去6年，將大學生涯的所有時間都奉獻在學生及民主運動上，由出任嶺大學生會署理主席，到傘運時成為市民口中的「學聯五子」，以至創立眾志、成為立法會議員乃至在囚，形容自己是「在湧流與暴風中成長」，所學到的必比只在課室唸幾年書更多。<br />\n但羅冠聰亦自言，一直以來都希望在學院內充實自己，在經過幾年來的風雨波折後，感到現時自我提升的必要，因此決定於來年升學，「在民主運動的漫漫長路中先進一步充實自己」。羅冠聰坦言，自知學術能力在競爭極大的院校相對疲弱，亦擔心自己的背景會影響對方的決定，慶幸於本月陸續收到錄取通知書。他續指，最終選擇耶魯大學，除了因為其優秀聲譽及課程質素，以及有香港公民社會朋友在此處授業外，更多是因為能獲得耶魯東亞研究系的全額獎學金，對「不用為錢銀奔波煩惱，鬆了一口氣」。羅冠聰同時亦表示，隨著中美關係持續升溫，位於東岸的耶魯距離紐約及華盛頓相對接近；他認為，耶魯在拓展香港在美的民間外交上，有一個相對方便的位置。羅冠聰指，課程將聚焦於中國研究，期望未來能令自己更清楚如何與極權纏鬥。<br />\n羅冠聰在文末承諾，「離開是為了回來」，會回到「自己歸屬的土地上奮鬥」，又感謝各位一直以來支持自己的朋友。<br />\n<img src=\"https://cdn.hk01.com/di/media/images/2559996/org/f3b37da91ce2ecc3fa6693d8458efbf9.png/G146ZqPb24jGueP79oWlZnf899iwAUWPhofo2YaH6Nk?v=w1280\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F2559996%2Forg%2Ff3b37da91ce2ecc3fa6693d8458efbf9.png%2FG146ZqPb24jGueP79oWlZnf899iwAUWPhofo2YaH6Nk%3Fv%3Dw1280&h=b5f2d183&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-03-17T09:17:56.000Z","msg":"讀中國研究做嘜唔返大陸攞first-hand data？"},"citedBy":1,"replyTime":"2019-03-17T10:33:51.000Z","msg":"<img src=\"https://na.cx/i/rqF370U.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrqF370U.png&h=934ef513&s={SIZE}\" /><img src=\"https://na.cx/i/XNu1aee.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXNu1aee.png&h=9ecd9334&s={SIZE}\" />"},{"pid":"152cdd213e2fe7a009fe791831f37ad9ec157e22","tid":1065450,"uid":131245,"like":1,"dislike":1,"score":0,"quote":{"pid":"ed9b60b2cb9d1c2480c0d55c2643e90683f7c719","tid":1065450,"uid":48083,"like":0,"dislike":0,"score":0,"quote":{"pid":"467730d601bb5b0d13adfc4b78c7c4314dfdb73f","tid":1065450,"uid":131245,"like":4,"dislike":12,"score":-8,"quote":{"pid":"ce8a989d9c5662fc35128740d6e5c1b92497f69b","tid":1065450,"uid":130626,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-17T09:16:12.000Z","msg":"轉眼間雨傘運動過去逾4年，帶領79日佔領的「學聯五子」，今日可謂天各一方、各有各忙，唯獨時任學聯常委羅冠聰正式踏上政治之路，代表香港眾志出戰立法會選舉，以5萬多票成為立法會史上最年輕的議員。惟其後因宣誓風波，被取消議員資格，歷經在囚等