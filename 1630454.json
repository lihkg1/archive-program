e=\"font-size: x-large;\"><span style=\"color: red;\">集中連推自己所有既英文台post，我會幫推，唔好放棄推<br />\n</span></span>"},{"pid":"77a1232a7e699fae63061ee3603c25da4c7466e4","tid":1630454,"uid":221919,"like":0,"dislike":0,"score":0,"quote":{"pid":"8f990195e8004785fcf41b40880ce73b46b35447","tid":1630454,"uid":8724,"like":0,"dislike":0,"score":0,"quote":{"pid":"dcb1aa9acc14dad81d793e799c6cfe562d7ebdbd","tid":1630454,"uid":221919,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-06T12:35:34.000Z","msg":"推 勿分化勿標籤<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n[求睇吓］請唔好孤立勇武 唔好重蹈覆轍！！<br />\n<a href=\"https://lih.kg/1628049\" data-auto-link target=\"_blank\">https://lih.kg/1628049</a><br />\n- 分享自 LIHKG 討論區"},"citedBy":1,"replyTime":"2019-10-06T12:37:47.000Z","msg":"呢兩日話唔割唔割 日日都係度嘈咁<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-06T12:55:35.000Z","msg":"冇辨法 冇大台弱點就係分化<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"}]}