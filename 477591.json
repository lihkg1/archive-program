/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"d621a315b10ed673cd29adfc0f412cda372fd557","tid":477591,"uid":11001,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-23T11:16:03.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">聖誕快樂</span></span>"},{"pid":"ccc0f457d58701bc2daae2118f48a2c2b77e2fab","tid":477591,"uid":10667,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-23T11:17:53.000Z","msg":"事不關己 所以咪講到咁囉<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 黑人支那人<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ee250e24f293bafed2128bd2cede5c22edd933f6","tid":477591,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-23T11:19:13.000Z","msg":"<blockquote>前排FB先見到人咁樣駁<br />\n<br />\n個社會係你地控制緊<br />\n官員係你地做<br />\n老闆係你地做<br />\n制度係你地定<br />\n教育係你地定<br />\n仔女係你地生<br />\n下一代完全跟緊你地既一切一切<br />\n依加就話下一代廢<br />\n<br />\n咁個廢既源頭來自邊度? <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"ca42711335cf525d3e09d3e5fc1108bbfe585280","tid":477591,"uid":128261,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-23T11:20:16.000Z","msg":"涼薄"},{"pid":"e14e66777dd90663936b3e7804aa618ab89525a2","tid":477591,"uid":10692,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-11-23T11:23:58.000Z","msg":"此回覆已被刪除"},{"pid":"d50e03d4ca59659d459b988b6ab9edc590b667ed","tid":477591,"uid":65024,"like":0,"dislike":15,"score":-15,"citedBy":0,"replyTime":"2017-11-23T11:24:30.000Z","msg":"老實講佢有佢道理<br />\n<br />\n我細個小學時仲有體罰，老師可以打你<br />\n訓導主任都好暴力，可以當眾飛你個書包出黑板<br />\n<br />\n依家做學生，D老師好似serve客咁"},{"pid":"9e33a9d0196a2d0df8999e8a5082596a13bbd040","tid":477591,"uid":4190,"like":6,"dislike":1,"score":5,"citedBy":0,"replyTime":"2017-11-23T12:59:44.000Z","msg":"<blockquote>老實講佢有佢道理<br />\n<br />\n我細個小學時仲有體罰，老師可以打你<br />\n訓導主任都好暴力，可以當眾飛你個書包出黑板<br />\n<br />\n依家做學生，D老師好似serve客咁</blockquote><br />\n你呢d咪食古不化囉<br />\n時代社會人權都應該要進步<br />\n你就係都想要退返幾十步<br />\n係度鬥食屎<br />\n如果第時你個仔比教師飛書包，煎兩巴<br />\n你會唔會去讚個教師做得好呀？"},{"pid":"6bc9138ef2987d17a9089cbc7920887c81b30a8e","tid":477591,"uid":5490,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-23T13:02:22.000Z","msg":"教大校長召喚"},{"pid":"b2cf7c2ae9d68ad7cb21e43f637270ecf3dfd5a3","tid":477591,"uid":131158,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2017-11-23T13:27:25.000Z","msg":"<blockquote>老實講佢有佢道理<br />\n<br />\n我細個小學時仲有體罰，老師可以打你<br />\n訓導主任都好暴力，可以當眾飛你個書包出黑板<br />\n<br />\n依家做學生，D老師好似serve客咁</blockquote><br />\n<br />\n公道啲講，每個年代要面對既困難都唔同，成人成日用自己標準對小朋友，<br />\n自己頂得順chur既生活就認為小朋友都一樣得，自己識既野就認為小朋友都一定識，<br />\n咁咪造成認知既鴻溝囉，網上成日見果啲痴線功課都咁黎，<br />\n之前viu個2047特首上學去其實幾好，比啲成人了解下而家小朋友係點生活（雖然已經cut晒啲課外活動同補習）<br />\n而成日發表偉論啲人都係富翁，啲仔女都三十幾歲，一係就送去外國/國際學校，<br />\n咁咪叫離地囉，唔係唔比你講，但唔好成日用幾十年前同自己幻想中既現在比較先得架"},{"pid":"4b7d554866646af2f7262a1fa1d907a46acd6ce1","tid":477591,"uid":124804,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2017-11-23T18:45:23.000Z","msg":"夏蟲不可語冰<br />\n試下每日做10幾樣功課 冇時間玩 冇得訓教睇下抑唔抑鬱<br />\n就係呢啲人成日講涼薄說話 所以日日都有學生退驚<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n點解呢啲仆街唔可以死先過班學生<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"fb436624ff7637b5ee84461b59c3321f45e20657","tid":477591,"uid":36901,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-23T21:15:25.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"23c604d1e6e79524418c485b1913e8008312680e","tid":477591,"uid":28256,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-23T22:40:10.000Z","msg":"啲笨柒最鐘意用自己個年代經歷去評宜家,無撚腦<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"fd15cff6158da8dd709f7797b9c64806e9fbbc87","tid":477591,"uid":46910,"like":2,"dislike":0,"score":2,"ci