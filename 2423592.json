assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"50e8156aebb861736283104e699f123d4e055ff2","tid":2423592,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T11:57:20.000Z","msg":"<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"75371480eadcfc2959f930f3863937eef00975e3","tid":2423592,"uid":70238,"like":1,"dislike":3,"score":-2,"citedBy":0,"replyTime":"2021-02-26T12:02:11.000Z","msg":"唉，又要多謝連登。"},{"pid":"9c094d0adb9f635ba9c12766b504fa5a864d2249","tid":2423592,"uid":327169,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-26T12:05:59.000Z","msg":"如果香港人唔好掛住返工，屋企有士巴拿膠索帶嘅，一齊去自首就好喇!! <img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n可惜香港已經支共化，支共滲透嚴重 <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c8db508a318287f257247e1c520a42a46ebacda9","tid":2423592,"uid":224066,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-26T15:35:12.000Z","msg":"<img src=\"https://na.cx/i/UJS41eH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUJS41eH.jpg&h=c92fa272&s={SIZE}\" />"},{"pid":"c10fcd862216d690325d1c4eba917a754dc679d9","tid":2423592,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T16:20:04.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f7a3116fdbe3db9813a718e3f5d170974ea08be6","tid":2423592,"uid":184261,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-26T16:23:16.000Z","msg":"羅德泉於一九五八年在香港出生。一九八四年在英國 Ealing College of Higher Education取得法學士學位。一九八六年通過英國法律教育委員會的大律師公會期終試。一九八六年分別在英格蘭及威爾斯（林肯律師學院）和香港獲大律師資格，並於一九九○年在澳洲首都領地獲大律師及事務律師資格。一九八七年至一九九五年期間私人執業。一九九五年獲委任為常任裁判官。<br />\n<br />\n咪乜嘢野雞學校嚟<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}