:"5c5297692a8187ac9d9887075f97391deea0e672","tid":1607324,"uid":280648,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T03:57:20.000Z","msg":"推"},{"pid":"f9962f036b34ed73f791d054ef6bd8cb3a61016a","tid":1607324,"uid":19482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T03:57:25.000Z","msg":"揸緊中共春袋"},{"pid":"3934b2836b223a86b804b85109c9f6e09b926698","tid":1607324,"uid":19482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T03:57:57.000Z","msg":"揸緊中共春袋"},{"pid":"ccd27f6ede25beed9bc92c7ddefd18a2117ecd01","tid":1607324,"uid":19482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T03:58:07.000Z","msg":"揸緊中共春袋"},{"pid":"79e5dcec0d71f6ef5b828659a772635b46d190b0","tid":1607324,"uid":19482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T03:58:18.000Z","msg":"揸緊中共春袋"},{"pid":"fbcd64af75599686a3d8d6f12d9d674d22963b42","tid":1607324,"uid":19482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T04:03:58.000Z","msg":"揸緊中共春袋"},{"pid":"671ded8eabeaa747408069de4470fa70fc1d2d43","tid":1607324,"uid":250951,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T07:25:42.000Z","msg":"push"},{"pid":"346eb8e2fe1a78e44fc0abe8aaaf8d9fb3049226","tid":1607324,"uid":194298,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T07:27:30.000Z","msg":"各區都好大煙，春袋好緊火"},{"pid":"bc6fd690b508942e7a60f117f14dc6c3da89b4ed","tid":1607324,"uid":271434,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T07:29:24.000Z","msg":"<strong>我以颱風風眼橫過比喻，預測閱兵期間香港唔會發生衝突</strong><br />\n<br />\n<span style=\"font-size: x-large;\">昨日警察不斷恐嚇大家十一唔好出，同埋有很多假消息話各地暴徒會燒商場，呢個奇怪現象同早幾日批不反對通知書後立即大搜捕完全不同，<span style=\"color: red;\">就係因為警察知道，十一當日唔可以捉人、唔可以出現血腥畫面，</span><span style=\"color: gold;\">但中共又唔容許有大量人上街反共反雜，所以先嚇定大家。<br />\n</span><br />\n現在就好似颱風風眼即將略過時候，警察瘋狂捉人，製造白色恐怖。<span style=\"color: red;\">風眼將會在閱兵期間橫過香港，忽然晴天萬里，到時候社會上一定太平無事，警察唔會拉人，大家可以放膽出街。</span><span style=\"color: blue;\">但要小心，當10月1日半夜過後，就有可能好似風眼過後，又出現狂風暴雨，</span>所以大家意見表達完結後，就盡快返歸，唔好戀戰。<br />\n<br />\n點解警察聽日閱兵期間唔捉人？<span style=\"color: gold;\">因為北大人唔想在世界各地直播閱兵期間，同時直播出現血腥鎮壓嘅場面，咁會落佢面，令雜種即時受到黨內外以及西方社會譴責，</span>所以十一閱兵嘅時候唔會清場鎮壓。<br />\n<span style=\"color: limegreen;\">聽講呢個安排僅十一閱兵嘅時段限定！</span></span><br />\n<br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://lih.kg/1606271\" data-auto-link target=\"_blank\">https://lih.kg/1606271</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n今日香港慘劇係雜種一手造成，冤有頭債有主，請大家對準政權目標<br />\n<br />\n<br />\n<span style=\"color: red;\">有明確訊息證實係習近平一人當日堅持拒絕「撤回」及下令將44人極速起訴暴動！</span><br />\n<a href=\"https://lih.kg/1602129\" target=\"_blank\">https://lih.kg/1602129</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<br />\n<span style=\"color: gold;\">十一遊行要高叫「天滅中共！習近平全家死」口號落中共面！</span><br />\n<a href=\"https://lih.kg/1568634\" target=\"_blank\">https://lih.kg/1568634</a><br />\n- 分享自 LIHKG 討論區"}]}