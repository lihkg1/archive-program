":46226,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-23T15:49:59.000Z","msg":"夠膽搞9良心店<br />\n藍屍店唔想開工鳥"},{"pid":"fc61591ce9122504716ddcd15db0df238d7d0157","tid":1590170,"uid":66049,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-23T15:52:00.000Z","msg":"近排乾燥，我想滋潤下"},{"pid":"866da4175b9579af69cfcbf7100f766f58cee13c","tid":1590170,"uid":42734,"like":1,"dislike":0,"score":1,"quote":{"pid":"c69173efc266d4e646d9b6b927929aa0bd6257d0","tid":1590170,"uid":810,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-09-23T15:27:44.000Z","msg":"<img src=\"https://na.cx/i/EsHNgiT.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEsHNgiT.jpg&h=375c1b23&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-09-23T15:59:12.000Z","msg":"清好波"},{"pid":"f2c6bc19c12d11c2f1794ab94d380f7d4b8ca99c","tid":1590170,"uid":61105,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-23T16:47:30.000Z","msg":"上星期六想食見到門口貼住東主有喜<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"}]}