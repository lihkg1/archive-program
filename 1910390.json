":0,"replyTime":"2020-03-04T16:09:04.000Z","msg":"三個都無病徵？<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"b56566fa9e6c3d4b40674eb821e7997691ebeb0d","tid":1910390,"uid":269498,"like":0,"dislike":0,"score":0,"quote":{"pid":"75e5a2e8bdf34f1c274cfd6883239b8f880ca3d8","tid":1910390,"uid":212626,"like":9,"dislike":0,"score":9,"citedBy":2,"replyTime":"2020-03-04T15:27:21.000Z","msg":"印度輸入個案<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-04T16:10:42.000Z","msg":"<span style=\"color: red;\">Live</span><br />\n奧委會稱很大機會改期"},{"pid":"55419960eb141142602be814bc176e83528c2fb1","tid":1910390,"uid":95452,"like":1,"dislike":0,"score":1,"quote":{"pid":"5c601292c8003be71bd55a32163becbd68d64c02","tid":1910390,"uid":228995,"like":13,"dislike":0,"score":13,"citedBy":4,"replyTime":"2020-03-04T15:34:24.000Z","msg":"係咪即係印度已大爆發"},"citedBy":0,"replyTime":"2020-03-04T16:17:05.000Z","msg":"印度：唔驗未零確診囉"},{"pid":"b4ba328186458d1f02cd48a6cd72681b1ee59be7","tid":1910390,"uid":63491,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-04T16:21:07.000Z","msg":"咁樣每日3,4個loop 到幾時先完呢"},{"pid":"6df584e626f9641b34cdd9ea228ad59f3aee96ef","tid":1910390,"uid":10505,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-04T16:23:18.000Z","msg":"唔通又係佛教徒？<br />\n去印度呢個年紀通常去修練"},{"pid":"36ddb4bf6b538d5d8009461dbad508199e23c51d","tid":1910390,"uid":303794,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-04T16:25:02.000Z","msg":"國泰<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e5db5942c081c7913779b6b6c94e9dfad0b00b2d","tid":1910390,"uid":257974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-04T16:29:15.000Z","msg":"睇中醫<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a6