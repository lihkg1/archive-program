jrnz38%3D&h=6b8a77d7\" data-auto-link target=\"_blank\">https://orientaldaily.on.cc/cnt/news/20130731/mobile/odn-20130731-0731_00176_131.html</a>"},{"pid":"e0e409cd974aa887f440c469eb0600100059fae3","tid":1729240,"uid":214534,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-17T07:13:10.000Z","msg":"3M耳塞咪得囉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"4e9b541229b5e9d4a30dc617b3cf336d60348897","tid":1729240,"uid":134993,"like":1,"dislike":0,"score":1,"quote":{"pid":"e0e409cd974aa887f440c469eb0600100059fae3","tid":1729240,"uid":214534,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-17T07:13:10.000Z","msg":"3M耳塞咪得囉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-17T07:14:16.000Z","msg":"內臟共振呢？"},{"pid":"668f089d248cdb53de1f185f367541d1c1bd4d3b","tid":1729240,"uid":10241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T07:15:34.000Z","msg":"音波炮都出埋喇<br />\n仲唔係想屠城"},{"pid":"401188fb2113ffd6b876d14bb53b60b2bfde887d","tid":1729240,"uid":60815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T07:15:35.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"254e692f496f14dab36d148e9a186a0b36e1f490","tid":1729240,"uid":287621,"like":0,"dislike":0,"score":0,"quote":{"pid":"e0e409cd974aa887f440c469eb0600100059fae3","tid":1729240,"uid":214534,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-17T07:13:10.000Z","msg":"3M耳塞咪得囉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-17T07:16:06.000Z","msg":"耳塞可以保護內臟？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7dcaafa4fd71d695bea9d20fde9281476c334c14","tid":1729240,"uid":17443,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T07:19:51.000Z","msg":"前線需要AirPods pro"},{"pid":"aed6168c2ab752e2790d6d5ed096f827c270a640","tid":1729240,"uid":171742,"like":0,"dislike":0,"score":0,"quote":{"pid":"f6cc4717f38608329b7fc7641b43cf3bb6ebb3d6","tid":1729240,"uid":136150,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-17T07:04:51.000Z","msg":"<img src=\"https://na.cx/i/0hQCwhB.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0hQCwhB.jpg&h=da7ae81f&s={SIZE}\" /><br />\n<br />\n開花救手足呀屌！！！！！<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-17T07:45:07.000Z","msg":"音波炮，稱「LRAD（Long Range Acoustic Device）長距離揚聲裝置」，內藏多個喇叭，利用反射原理，把各喇叭的發聲匯向一個位置發出，如光線般有導向性且覆蓋範圍更廣。<br />\n香港警察擁有兩部共 76.5 萬的「音波泡」，有效距離達 600 米。以中環計，若在舊立法會大樓（現時終審法院）外使用這個音波炮，受影響範圍可遠至金鐘統一中心。<br />\n音波炮高達 140db，持續分貝達 137db，相當於一架噴射式飛機在30米內發動引擎的聲量，或一架 Formula 1 產生的分貝水平（F1 為 125db-145db）。當音波炮在近距離啟動時，群眾的聽覺即時受到侵害，以手掩耳只能減低「聲壓水平」25分貝，並不能逃避音波炮影響。"}]}