\n被告人沒有犯罪前科，系初犯；[24]<br />\n被告人具有強烈的悔罪態度。<br />\n法院經審議後，翌日宣判劉強制猥褻罪和猥褻兒童罪罪成，各項罪名判處有期徒刑一年六個月，合併執行有期徒刑二年六個月，刑期至2018年9月27日"},{"pid":"1e68ec302812a8a283234e32b6a0b56ebae13fa6","tid":828973,"uid":208722,"like":16,"dislike":1,"score":15,"citedBy":0,"replyTime":"2018-09-20T06:45:52.000Z","msg":"八婆！八婆！食屎狗！！！！"},{"pid":"6abaf5a123ef21944bc6cf8300e983250f500859","tid":828973,"uid":209153,"like":7,"dislike":1,"score":6,"quote":{"pid":"350499652c5eab1214a0862a72b0f4164010c704","tid":828973,"uid":3478,"like":5,"dislike":39,"score":-34,"quote":{"pid":"12bcfdc9e88ff4b223203186c01ee09acff2499a","tid":828973,"uid":167828,"like":69,"dislike":75,"score":-6,"citedBy":1,"replyTime":"2018-09-20T05:28:26.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-09-20T05:33:11.000Z","msg":"唔睇笑波子唔通睇達狗呀<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-20T06:49:38.000Z","msg":"其實兩個都唔應該睇 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"dac9d3b18ea74f6951dcf81db8d9810ddc28c392","tid":828973,"uid":166622,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-09-20T06:51:25.000Z","msg":"男神歸位<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"3900471ae16b807a50ef1e81498116b1d43a72aa","tid":828973,"uid":14449,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-09-23T00:56:59.000Z","msg":"有冇連登仔去接馬車歸來<img src=\"/assets/faces/mf/tongue.png\" class=\"hkgmoji\" />"},{"pid":"d2d9ff4f7ab1bd2edf5cf48de10a9641985e6495","tid":828973,"uid":32861,"like":4,"dislike":6,"score":-2,"citedBy":0,"replyTime":"2018-09-23T01:02:36.000Z","msg":"香港pewdepie <img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"61877af9e94ecc9e671d4260898e2cc0d34237fa","tid":828973,"uid":10520,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-09-23T01:06:20.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3