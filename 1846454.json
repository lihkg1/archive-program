ssets/faces/lny/clown4.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/clown3.gif\" class=\"hkgmoji\" />"},{"pid":"bda09c9771a0875c3e2b437fffc53cc28e871a0d","tid":1846454,"uid":53238,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-01-27T15:43:36.000Z","msg":"全香港都屌緊啦<br />\n成撚日縮喺屋企扮哂指點江山<br />\n咁有咩 solution 呀廢老"},{"pid":"8f13873c401ba922362907d55084ff13dd2affa4","tid":1846454,"uid":270506,"like":0,"dislike":0,"score":0,"quote":{"pid":"9caeaa64b4eed93fe4ec9844873e2faab0bf02cf","tid":1846454,"uid":242537,"like":1,"dislike":5,"score":-4,"citedBy":3,"replyTime":"2020-01-27T15:32:18.000Z","msg":"竟然有食藥<img src=\"/assets/faces/lm2lny/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2lny/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2lny/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2lny/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2lny/jable.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-27T15:45:18.000Z","msg":"大家唔好唔記得美國都可以向中共港共施壓，麻煩大家幫手推下呢個post<img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n[國際戰線] 請求美國向中共同港共施壓，立即封鎖中港邊境保護美國85000個在港僑民<br />\n<a href=\"https://lih.kg/1846141\" data-auto-link target=\"_blank\">https://lih.kg/1846141</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"9c89e95a5ee457da07313264040ef65e11154397","tid":1846454,"uid":191790,"like":0,"dislike":0,"score":0,"quote":{"pid":"bda09c9771a0875c3e2b437fffc53cc28e871a0d","tid":1846454,"uid":53238,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-01-27T15:43:36.000Z","msg":"全香港都屌緊啦<br />\n成撚日縮喺屋企扮哂指點江山<br />\n咁有咩 solution 呀廢老"},"citedBy":0,"replyTime":"2020-01-28T05:04:34.000Z","msg":"在醫院門口舉起橫額，用中英文歡迎大陸病人來港免費治療，香港特區政府及醫護人員全力支援中央政府號召抗疫之類。英文要寫到大大隻字，消息傳到外國，例如tweet到特朗普總統那裡呼籲求助，就有好戲看，特朗普總統發現香港醫療人員不足，向北京要求派美軍醫療船來香港，嚇怕北京即刻下令香港政府免責，不必支援中央了。<br />\n如果你懂得高級政治，可以在舉起紅旗的時候，宣讀毛澤東的〈紀念白求恩（醫生）〉，篇章不長的。<br />\n<a href=\"https://www.facebook.com/wan.chin.75\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.fac