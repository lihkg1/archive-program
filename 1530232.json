d5514b70","tid":1530232,"uid":204194,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T04:35:41.000Z","msg":"push"},{"pid":"569f6087632e3a2424278300de06fc2ee80a4fcc","tid":1530232,"uid":181286,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T08:24:07.000Z","msg":"其實各位應該好好同警畜子女做朋友，大家都是年輕人會反叛，導佢地向善，一齊參與朋友「聚會」<br />\n越多警畜子女參加聚會，警畜打中自己子女機會就越大，越多畜仔畜女受傷，警畜內部就越容易分裂"},{"pid":"d16aaf7ca26b3e078164790857e71937d092c7f8","tid":1530232,"uid":48935,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T08:28:43.000Z","msg":"呢篇高汁<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"e3683af65ed4ee6ec5d8e54c6d92b00d9dc74a05","tid":1530232,"uid":77850,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T08:36:22.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dadc33efbbb32bad2334bd607dfae251d704b426","tid":1530232,"uid":269649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T08:59:08.000Z","msg":"推"},{"pid":"b6edd79ac0cc6aa81c6297956e0cc82a4bdf365a","tid":1530232,"uid":52621,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T13:06:01.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"b4218d2bd37a5aa6632d389f501dea37b9dd5a67","tid":1530232,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T13:07:13.000Z","msg":"才子"},{"pid":"c0ab39f1160c348d12129c595fca64c2b39db538","tid":1530232,"uid":296350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T17:35:29.000Z","msg":"有冇人分享下開學日撚狗仔女嘅開心事振奮下人心<br />\n<a href=\"https://lih.kg/1533428\" data-auto-link target=\"_blank\">https://lih.kg/1533428</a><br />\n- 分享自 LIHKG 討論區"}]}