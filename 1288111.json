=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"bb9b0b34034454931014c5cdea93dc14069bc449","tid":1288111,"uid":59855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T04:25:08.000Z","msg":"推"},{"pid":"1511409549c6b8381ddcfd3da7afe59e896c8d6b","tid":1288111,"uid":59855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T01:06:57.000Z","msg":"推"},{"pid":"f5b598cb78419dd6eed75fb7ddb9656762957f15","tid":1288111,"uid":59855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T11:02:39.000Z","msg":"推"},{"pid":"ff79bc1e8c1b8916fdf90918a4110a865f9c041b","tid":1288111,"uid":59855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T04:39:33.000Z","msg":"推"},{"pid":"7fb9e15a4ec5802f8d51fc9bc6d52fa761f69185","tid":1288111,"uid":59855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T03:47:37.000Z","msg":"推"},{"pid":"379a5ae7f7857a1858407978c88c78446538228f","tid":1288111,"uid":59855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T02:27:00.000Z","msg":"推"},{"pid":"e4a840ebee4a1f8daa88016d7dc48d9909912961","tid":1288111,"uid":59855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T01:25:55.000Z","msg":"推"},{"pid":"282f97406c80da3b28544855dc2fe10de6bcfc9e","tid":1288111,"uid":79353,"like":0,"dislike":0,"score":0,"quote":{"pid":"66c76d4e8f5d448cb156426a9639691da192a421","tid":1288111,"uid":79353,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2019-07-11T04:44:40.000Z","msg":"其實人不嬲都係咁虛偽<br />\n<br />\n同你同一陣線同一條船既時候<br />\n你死左緊係呼天搶地一齊悼念你<br />\n<br />\n但平時有人喺鬧市主要交通通道企跳<br />\n或者有D佢地覺得就算自殺死左都要被恥笑既人<br />\n佢地就笑得最不遺餘力<br />\n<br />\n又或者話自己現實中過得唔如意<br />\n但唔夠膽自殺<br />\n喺新聞見到有人自殺死左, 咪拎黎恥笑下發洩下囉<br />\n<br />\n又或者純粹係人類欺善欺弱怕惡既天性<br />\n拎D人生冇咁成功既人黎笑下<br />\n<br />\nEG 以前有個讀OU既女大學生自殺死左<br />\nD人comment係咁笑人讀OU唔怪得要自殺<br />\n<br />\nEG2 以前有個post係銀行經理頂唔住工作壓力自殺死左<br />\nD人又係咁鬧人, 咁大個人少少工作壓力都頂唔順, 抵死, 快D死<br />\n<br />\nEG3 以前有隻真-小學雞男仔, SEND埋D淫相俾人, 搞到俾人擺上網唱通天<br />\nD網民玩大件事, 玩大到SEND EMAIL去人地學校投訴<br />\n人地細路仔咁細個緊係嚇到學都唔敢返, 連試都冇考<br />\n<br />\n有D人睇唔過眼叫班人收手, 話: 算數啦, 細路邊個冇ON9過<br />\n<br />\n之後底下班人鬧返D良心人士轉頭, 話人地係道德撚, 仲話個細路如果小小事都頂唔順, 咁大個係咪要死幾十次 ETC<br />\n<br />\n再唔係有D佢地睇唔過眼既人, 可能人地只係生得個樣普通D, 乜乜物物<br />\n或者求其換部手機偷相做whatsapp相老作個conversation出黎, 就屈人做雞, 屈人做鴨, 乜柒物柒...<br />\n佢地會笑人笑到人地跳樓死止<br />\n<br />\n人性根本就係咁黑暗, 扮乜野者<br />\n唔通你仇人自殺死左你會悼念佢你會可憐佢咩<br />\n<br />\n<strong>利申 反送中反林鄭反支那, 唔好屈我五毛</strong>"},"citedBy":0,"replyTime":"2019-09-02T09:56:31.000Z","msg":"推<br />\n提醒我自己要自強"},{"pid":"a87ef9cc9419a6dd922211e487577414bfd1a41d","tid":1288111,"uid":79353,"like":2,"dislike":0,"score":2,"quote":{"pid":"4881f6f08517e36e8f6b2003bc061a688fbb6e10","tid":1288111,"uid":79353,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-07-11T04:52:04.000Z","msg":"offtopic, 仲有個例子我覺得幾好笑<br />\n<br />\n話說以前上網見到某人開post話想自殺<br />\n眾人追問關懷之下, 發現某人屋企經濟環境原來唔錯<br />\n係對自己人生 前途覺得無力感重.<br />\n<br />\n其實以佢屋企經濟衡量, 佢係有機會有時間繼續讀書<br />\n...<br />\n<br />\n轉過頭香港自殺潮開始<br />\n佢本人既問題應該已經得到解決<br />\n如果唔係個態度點會咁意氣風發<br />\n<br />\n佢就開post恥笑D自殺者<br />\n話人自殺係抵死, 冇撚用, 唔識解決問題... etc<br />\n<br />\n我一見到佢個網名就認得係佢<br />\n睇下佢果排開過既post<br />\n發現佢話自己讀緊宗教master 學new age野之類<br />\n就知佢本人既生活應該過得十分寫意<br />\n否則點會上網踩D suppose同佢係同一條船既人 即係D自殺者<br />\n<br />\n打完齋唔要和尚 扑完野中出即飛踢條女落床 - 最佳典範<br />\n利用完自己既background R同情<br />\n到自己既人生順利返既時候, 緊係開始睇唔起班地底泥loser, 轉風向恥笑所謂同路人係廢物垃圾抵死<br />\n <img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-02T09:56:46.000Z","msg":"推<br />\n提醒我自己要自強"},{"pid":"5c91bfc20d663a4bf31373d515dd76216b74f368","tid":1288111,"uid":59855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T14:20:11.000Z","msg":"推"},{"pid":"3f73dc9671f0389807c61524172fe8e5d5f7fa9d","tid":1288111,"uid":59855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T00:17:12.000Z","msg":"推"},{"pid":"f4479e8b55487