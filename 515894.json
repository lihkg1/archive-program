5_fce8a3efb2bf5d69d49422b321080cb2.jpeg&h=7dd86e29&s={SIZE}\" />"},{"pid":"be2cd91794d2fe79af7fe063c3a1e0264ed98030","tid":515894,"uid":106955,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-02T18:21:37.000Z","msg":"<blockquote><blockquote>想問一下有咩野要注意</blockquote>我本身養緊隻哥基 領養既 記住唔好比佢咁多行樓梯/跳sofa 因為佢地條腰唔好 <img src=\"https://img.eservice-hk.net/upload/2018/01/02/185135_fce8a3efb2bf5d69d49422b321080cb2.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F02%2F185135_fce8a3efb2bf5d69d49422b321080cb2.jpeg&h=7dd86e29&s={SIZE}\" /></blockquote><br />\n想問問點樣教佢地去廁所<img src=\"/assets/faces/xm/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"86dd8e379d7dbfd2003fafc2f25223056c7f15fb","tid":515894,"uid":68784,"like":0,"dislike":0,"score":0,"quote":{"pid":"be2cd91794d2fe79af7fe063c3a1e0264ed98030","tid":515894,"uid":106955,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-02T18:21:37.000Z","msg":"<blockquote><blockquote>想問一下有咩野要注意</blockquote>我本身養緊隻哥基 領養既 記住唔好比佢咁多行樓梯/跳sofa 因為佢地條腰唔好 <img src=\"https://img.eservice-hk.net/upload/2018/01/02/185135_fce8a3efb2bf5d69d49422b321080cb2.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F02%2F185135_fce8a3efb2bf5d69d49422b321080cb2.jpeg&h=7dd86e29&s={SIZE}\" /></blockquote><br />\n想問問點樣教佢地去廁所<img src=\"/assets/faces/xm/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-10T07:28:29.000Z","msg":"食完野 / 瞓醒 5至10分鐘 or 出黎放風玩左15分鐘後<br />\n見佢地周圍聞地下牆邊, 就係想去廁所<br />\n咁就放返佢入佢嘅廁所 - 籠 or 廁板<br />\n等佢屙, 屎尿都好, 屙啱就立即讚同獎<br />\n獎完先放返出黎, 一定要等佢屙完先出得返黎<br />\n<br />\n其實唔關哥基事, 狗都係咁教"},{"pid":"cbdcff56554fd5f0a0f323015153af416b9c24fa","tid":515894,"uid":144631,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-10T10:51:17.000Z","msg":"其實如果有心<br />\n你早晚帶佢去街<br />\n佢就會自然係街去廁所<br />\n<br />\n同埋其實哥基好需要放電<br />\n所以帶佢去街去廁所順便放電係最好"}]}