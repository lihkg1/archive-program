mg src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},{"pid":"51c565a90fd2f76f7d00cdb86380da5112bbaa40","tid":456851,"uid":26506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-04T03:52:42.000Z","msg":"<blockquote><blockquote><a href=\"https://www.hk01.com/%E6%B8%AF%E8%81%9E/130129/-%E6%9B%BE%E8%94%AD%E6%AC%8A%E6%B6%89%E8%B2%AA%E6%A1%88-%E9%99%AA%E5%AF%A9%E5%93%A1%E8%A2%AB%E6%8C%87%E6%98%AF%E9%99%B6%E5%82%91-%E7%B2%89%E7%B5%B2-%E6%8E%A7%E6%96%B9%E8%A6%81%E6%B1%82%E8%A7%A3%E9%99%A4%E5%85%B6%E8%81%B7%E5%8B%99\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E6%25B8%25AF%25E8%2581%259E%2F130129%2F-%25E6%259B%25BE%25E8%2594%25AD%25E6%25AC%258A%25E6%25B6%2589%25E8%25B2%25AA%25E6%25A1%2588-%25E9%2599%25AA%25E5%25AF%25A9%25E5%2593%25A1%25E8%25A2%25AB%25E6%258C%2587%25E6%2598%25AF%25E9%2599%25B6%25E5%2582%2591-%25E7%25B2%2589%25E7%25B5%25B2-%25E6%258E%25A7%25E6%2596%25B9%25E8%25A6%2581%25E6%25B1%2582%25E8%25A7%25A3%25E9%2599%25A4%25E5%2585%25B6%25E8%2581%25B7%25E5%258B%2599&d=xfNzcqQ1qKezir9uKNQTE%2F7vEz4FU%2Bq4m%2F6ZFrWLoTs%3D&h=274dae03\" target=\"_blank\">https://www.hk01.com/%E6%B8%AF%E8%81%9E/130129/-%E6%9B%BE%E8%94%AD%E6%AC%8A%E6%B6%89%E8%B2%AA%E6%A1%88-%E9%99%AA%E5%AF%A9%E5%93%A1%E8%A2%AB%E6%8C%87%E6%98%AF%E9%99%B6%E5%82%91-%E7%B2%89%E7%B5%B2-%E6%8E%A7%E6%96%B9%E8%A6%81%E6%B1%82%E8%A7%A3%E9%99%A4%E5%85%B6%E8%81%B7%E5%8B%99</a> <br />\n開post就貼link啦唔差在做多一步, 懶到...</blockquote><br />\n做乜要比01賺點擊率<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /></blockquote><br />\n冇source同畀link有咩關係? 使唔使幫你archive/cache埋?"}]}