.com%2Fpolitics%2F%25E7%2591%259E%25E5%25A3%25AB%25E6%25A8%25A1%25E5%25BC%258F%25E6%25B8%25AF%25E7%258D%25A8-%25E4%25B8%25AD%25E6%25B8%25AF%25E9%259B%2599%25E8%25B4%258F-%25E4%25B8%25AD%25E7%25AB%258B%25E6%2596%25B9%25E6%25A1%2588%25E7%259A%2584%25E5%2586%258D%25E6%258F%2590%25E5%2587%25BA%2F&d=zkxump%2FGNOlz%2FwmZAqM4lA9axkDoCoA19ZsVt7gViHY%3D&h=6641deaa\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%25E7%2591%259E%25E5%25A3%25AB%25E6%25A8%25A1%25E5%25BC%258F%25E6%25B8%25AF%25E7%258D%25A8-%25E4%25B8%25AD%25E6%25B8%25AF%25E9%259B%2599%25E8%25B4%258F-%25E4%25B8%25AD%25E7%25AB%258B%25E6%2596%25B9%25E6%25A1%2588%25E7%259A%2584%25E5%2586%258D%25E6%258F%2590%25E5%2587%25BA%2F&h=ca098f72\" target=\"_blank\">https://thestandnews.com/politics/%E7%91%9E%E5%A3%AB%E6%A8%A1%E5%BC%8F%E6%B8%AF%E7%8D%A8-%E4%B8%AD%E6%B8%AF%E9%9B%99%E8%B4%8F-%E4%B8%AD%E7%AB%8B%E6%96%B9%E6%A1%88%E7%9A%84%E5%86%8D%E6%8F%90%E5%87%BA/</a>"},{"pid":"d6f9e566ec88084cf173b6eb3bf49bdc98a3d47b","tid":1629782,"uid":279810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T12:08:55.000Z","msg":"<img src=\"https://na.cx/i/oYzmzLU.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FoYzmzLU.gif&h=f90c999c&s={SIZE}\" />"},{"pid":"c0624d99ea53a5ff9361c902f421790d471a8e35","tid":1629782,"uid":239250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T12:15:41.000Z","msg":"推"},{"pid":"575aca6db91566b180f7be9e76862a26cb51a05f","tid":1629782,"uid":38109,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T12:18:30.000Z","msg":"Crazy <br />\nIs the driver arested?"},{"pid":"4a61a61bc9cbccb34cfa1e0c5f231ced0ad37855","tid":1629782,"uid":27713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T12:24:28.000Z","msg":"打到佢斷手斷腳打到佢食又食唔落瞓教都痛醒 屌你老母！！！！！！"},{"pid":"84f5022d9930c31150eb485dcdad42a74faed6c2","tid":1629782,"uid":1130,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T12: