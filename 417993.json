a73f.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F09%2F29%2F155554_376bdc659c05676c209ad2579ea3a73f.gif&h=615e5b37&s={SIZE}\" />"},{"pid":"61384b643bad1ecf7dd67fb7e08a0135e24be462","tid":417993,"uid":23635,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-09-29T08:02:11.000Z","msg":"說好的愛国呢？"},{"pid":"d800dcc41c3866e351184bd318204a247ec777f1","tid":417993,"uid":49392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-29T08:03:58.000Z","msg":"<blockquote>叮噹法寶</blockquote><br />\n果舊舉弱，成舊海棉咁大舊"},{"pid":"b94a7b683d95bf137dd049bd756d7ffe8a7e8c68","tid":417993,"uid":49197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-29T08:06:59.000Z","msg":"<blockquote><blockquote><blockquote>抵制日貨都唔記得 唔怪得要買</blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /></blockquote><br />\n呢個社會實驗比較複雜，我地一定要記住所有步驟，如果冇記性，就會好危險&hellip;&hellip;"},{"pid":"25a70c5103884e02f198c358cf183b180d40e761","tid":417993,"uid":5056,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-09-29T08:09:53.000Z","msg":"<blockquote>香口膠都得condom都得啦</blockquote><br />\n<br />\n好似有典故:<br />\n一個美國人在中國一家飯店吃飯。結帳的時候，美國人一邊嚼着香口膠，一邊笑着問侍者：「請問你們怎樣處理吃剩的香口膠？」「當然是吐掉啦，」侍者道。美國人搖搖頭，得意的說，「在我們美國，嚼過的香口膠就送進工廠做成保險套，然後再賣到你們中國。」<br />\n侍者不耐煩的問道：「那你知道在我們中國，如何處理用過的套套嗎？」<br />\n「當然是扔掉啦，」美國人道。侍者搖搖頭說：「 NO! No! No!在我們中國，用過的保險套就送進工廠做成香口膠，然後再賣到你們美國。」"},{"pid":"3ae0516eded91a6741e72054acac0b09c21fe381","tid":417993,"uid":55913,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-29T13:16:40.000Z","msg":"支那狗 反日<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"950e302e6af8bd308d0c35e47d9f73c5df0fdb02","tid":417993,"uid":86938,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-29T13:26:09.000Z","msg":"其實幾難食下<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://holland.pk/t4dgy9fc\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Ft4dgy9fc&h=65c06152&s={SIZE}\" />"},{"pid":"c7592b7dcd6d063a9f8a595c9b240777460bb93f","tid":417993,"uid":41245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-29T14:33:26.000Z","msg":"<blockquote><blockquote><blockquote>抵制日貨都唔記得 唔怪得要買</blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /></blockquote><br />\n原來佢地只係想記得抵制日貨<img src=\"/assets/faces/mf/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/frown.gif\" class=\"hkgmoji\" /> <br />\n你地睇下人地幾勇武"}]}