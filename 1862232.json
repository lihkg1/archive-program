b57786","tid":1862232,"uid":217430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:00:21.000Z","msg":"幫推<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n醫護罷工必須一鼓作氣，不能有絲毫退縮<br />\n<a href=\"https://lih.kg/1862233\" data-auto-link target=\"_blank\">https://lih.kg/1862233</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"708df97eeb200c8bc562ac883cae86a86351366c","tid":1862232,"uid":268591,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:00:33.000Z","msg":"三罷封關！刻不容緩！"},{"pid":"6309dcab8f8d8a7600d4fb79d37c68cb9eccb0e3","tid":1862232,"uid":79524,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:00:36.000Z","msg":"全民三罷<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4db195e92ee9257651f9997bd59b5861952fda47","tid":1862232,"uid":46317,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:00:43.000Z","msg":"推"},{"pid":"089c235d543110747e5e6a68d83663a7c03b7d30","tid":1862232,"uid":73143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:01:44.000Z","msg":"全民三罷 刻不容緩"},{"pid":"b253ca29fe8f60d067c28ec68cf1ca17e8c9a5d6","tid":1862232,"uid":247845,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:01:53.000Z","msg":"<img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" />勁野"},{"pid":"989adfd7525026e17713f6d7f8d13a4b88c01a20","tid":1862232,"uid":217430,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-02-04T14:02:07.000Z","msg":"各行業請緊隨醫護手足的步伐。複製醫護罷工的成功方程式。<br />\n<br />\n<span style=\"color: gold;\">一.成立公會</span><br />\n並高調召開會員大會表決罷工，一定要有直播影著過程。<br />\n<br />\n<span style=\"color: gold;\">二.開口牌</span><br />\n簽署罷工宣言承諾罷工。<br />\n<br />\n<span style=\"color: gold;\">三.全民醒覺</span><br />\n大家放心。已經有八成香港市民支持全面封關。<br />\n<br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: xx-large;\">罷工救港<br />\n全面封關</span></span>"},{"pid":"ce00d4a640eb3607f4bade0bcbfa99615d2ea2e1","tid":1862232,"uid":73143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:02:58.000Z","msg":"全民三罷 刻不容緩"},{"pid":"371b615194077494cdb4d4d69fe7dc9e6a5445b5","tid":1862232,"uid":215876,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:03:22.000Z","msg":"突然間大量p牌同五毛狗係度帶風嘅<br />\n表示而家爆發左就封關都無用<br />\n叫醫護復工<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n實情係同機場果招一樣<br />\n佢地無法破<br />\n就等大家自己放棄<br />\n<br />\n<br />\n大家一定唔可以再中港共依招<br />\n<br />\n罷到底<br />\n<br />\n唔從源頭開始減少<br />\n<br />\n做死都幾多醫護都無用<br />\n<br />\n<br />\n<br />\n我希望大家可以明白依個道理<br />\n同埋堅定醫護個心<br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">而家開始配合埋港鐵工會同巴士公會<br />\n發展成全港大罷工<br />\n日日都係年初一</span></span>"},{"pid":"1dae778daa0a4e8a5c1b595946bef89b96166532","tid":1862232,"uid":73143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:04:48.000Z","msg":"全民三罷 刻不容緩"},{"pid":"f1de55eedaffca76bec99a94ba8669f01776c93c","tid":1862232,"uid":35456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:05:37.000Z","msg":"此回覆已被刪除"},{"pid":"e23e30f2a24eed8e1b826793117eee4435b7d535","tid":1862232,"uid":73143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:07:15.000Z","msg":"全民三罷 刻不容緩"},{"pid":"4c472f07422913a9aa9ff7ce1526f6a33b8a51c7","tid":1862232,"uid":73143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:12:19.000Z","msg":"全民三罷 刻不容緩"},{"pid":"4a3e427a1b9f304397665dce418efc601d5e2d21","tid":1862232,"uid":73143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T14:14:33.000Z","msg":"全民三罷 刻不容緩"},{"pid":"277ed846f55cddb4909050a0c21c98a1bd5fbf64","tid":1862232,"uid":73143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T1