mg src=\"https://static.appledaily.hk/images/apple-photos/apple/20200404/large/1585930564_7b64.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fapple-photos%2Fapple%2F20200404%2Flarge%2F1585930564_7b64.gif&h=bccb8099&s={SIZE}\" /><br />\n<br />\n<img src=\"https://static.appledaily.hk/images/apple-photos/apple/20200404/large/1585930566_5a10.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fapple-photos%2Fapple%2F20200404%2Flarge%2F1585930566_5a10.gif&h=8fe75423&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-04-04T08:07:38.000Z","msg":"36至35歲<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"f8f0c2adbf4bf2806d849eccb4b3d20da6375a28","tid":1957860,"uid":308492,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2020-04-04T08:09:06.000Z","msg":"投票率最低幾個係啲高收入區<br />\n香港啲精英階層完全冇道德感召加政治冷感"},{"pid":"3d6b09c2716a8d75dbd71d0632d1cb680258d5bf","tid":1957860,"uid":100772,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-04-04T08:09:21.000Z","msg":"但登記率最低 得5十幾"},{"pid":"ef75a86f6faa65db38a5c1e299c24e08213f53d7","tid":1957860,"uid":226155,"like":3,"dislike":0,"score":3,"quote":{"pid":"805e88d2eb38324191f7eb60100bc7613f597826","tid":1957860,"uid":160176,"like":8,"dislike":0,"score":8,"quote":{"pid":"80ca3ef9331bb73c978e58684a722ae049aefcd5","tid":1957860,"uid":42090,"like":5,"dislike":3,"score":2,"citedBy":3,"replyTime":"2020-04-04T08:04:33.000Z","msg":"仲有果25%死撚左？"},"citedBy":2,"replyTime":"2020-04-04T08:05:21.000Z","msg":"蝗童、三萬警犬既狗仔狗女<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-04T08:10:16.000Z","msg":"移民 留學 下話<br />\n嗰堆一定投左"},{"pid":"1b9ad377956fed27a4171e35ed743c67353677c2","tid":1957860,"uid":3122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-04T08:11:32.000Z","msg":"遲D仲多<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d8fc16ebfba29936cd2a6c