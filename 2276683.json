f5376c7","tid":2276683,"uid":94771,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-08T04:18:32.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"731789f58e7108979264c4b09eeb05ad92bf6fbd","tid":2276683,"uid":113250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-08T04:19:03.000Z","msg":"梓想快樂。"},{"pid":"dedd1a5ea29c4ac694836dc728968a2b53c02030","tid":2276683,"uid":94771,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-08T04:19:24.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"82d1e060af73ee928dd29ea613df370c61628cbc","tid":2276683,"uid":168389,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-08T04:26:45.000Z","msg":"<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"af85172771642c05ac77ff13bb7b74645e1bb946","tid":2276683,"uid":206668,"like":0,"dislike":0,"score":0,"quote":{"pid":"77fc1313a5eb5b154618b7dbfb2747ebca310052","tid":2276683,"uid":131245,"like":0,"dislike":12,"score":-12,"quote":{"pid":"0d0c3e8e79832322ad3534b90f576ff4c23c1e78","tid":2276683,"uid":94771,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-11-08T03:33:00.000Z","msg":"<span class=\"orange\">最近有朋友問我，今日去獻花安唔安全，好老實我答你唔到，狗會做咩無人知</span><br />\n但如果獻個花都唔敢，我建議你離開香港好Ｄ<br />\n<br />\n希望大家注意下黎邊先，反正美國會打法律戰，等埋法庭點講就知個真相啦，美國法院又唔係港共個隻<br />\n<br />\n<img src=\"https://na.cx/i/Nb6miTq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNb6miTq.jpg&h=b3d19fa9&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/ZhFik6M.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZhFik6M.jpg&h=c60187a3&s={SIZE}\" /><br />\n⚠️#更改活動詳情⚠️<br />\n因應場地及人手不足關係 , <strong><span class=\"orange\">原定網上追悼活動將會取消</span></strong> , 但是將會安排同工在老地方處建一個弔唁區供市民自行拜祭。<br />\n1⃣基於周梓樂為基督徒 , 請以鮮花💐和電蠟燭🕯取代燒香及溪錢等方式 , 尊重他人的信仰<br />\n2⃣11月15日有機會舉辦沙嶺導賞團以悼念其他逝世手足 , 請留意公佈<br />\nSource : <a href=\"https://t.me/TheInheritedlove/478\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FTheInheritedlove%2F478&d=ltJnWG3kir489%2BLnRwft2%2Bu9cyR3gY7uP1sO3WVLDIg%3D&h=229bd69f\" data-auto-link target=\"_blank\">https://t.me/TheInheritedlove/478</a><br />\n<br />\n<img src=\"https://na.cx/i/pruCBGp.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpruCBGp.jpg&h=1ad66f9b&s={SIZE}\" /><br />\n#8Nov #南區 #悼念周同學<br />\n<span class=\"orange\"><strong>【「南區人未忘梓樂」獻花悼念】</strong></span><br />\n日期 : 11月8日 (日)<br />\n時間 : 15：00 <br />\n地點 : 香港仔市中心香港仔廣場水池<br />\n備註：<br />\n1⃣ 15：00乃開始於池邊獻花的時間，大家可提早到附近買花 🌷 未能於下午獻花的市民，可於晚上獻花，惟請注意入夜後之活動風險或會上升<br />\n2⃣ 活動沒有指定司儀、主持，大家可自行將花束、悼物放在池邊上，再於默禱後自行離開 (參考太子站獻花模式) <br />\n3⃣ 活動以哀悼為主，請避免於他人默禱期間高喊口號<br />\n4⃣ 請配戴口罩並保持適當的社交距離<br />\n5⃣ 如遇上突發事宜，請保持冷靜並Be Water，勿與生事者硬碰，留有用之軀<br />\nSource : <a href=\"https://t.me/southern_scout/26902\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fsouthern_scout%2F26902&d=ltJnWG3kir489%2BLnRwft2%2Bu9cyR3gY7uP1sO3WVLDIg%3D&h=bd19806f\" data-auto-link target=\"_blank\">https://t.me/southern_scout/26902</a><br />\n<br />\n<img src=\"https://na.cx/i/EWEOJmi.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEWEOJmi.jpg&h=e23d7bae&s={SIZE}\" /><br />\n#8Nov <span class=\"orange\"><strong>#台灣日程</strong></span><br />\n【周梓樂逝世一週年悼念會】<br />\n日期 : 11月8日 (日)<br />\n時間 : 18:30-20:00<br />\n地點 : 二二八和平紀念碑前<br />\nSource : <a href=\"https://www.facebook.com/430322067806030/posts/816827889155444/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F430322067806030%2Fposts%2F816827889155444%2F%3Fd%3Dn&d=ltJnWG3kir489%2BLnRwft2%2Bu9cyR3gY7uP1sO3WVLDIg%3D&h=1c714be9\" data-auto-link target=\"_blank\">https://www.facebook.com/430322067806030/posts/816827889155444/?d=n</a>"},"citedBy":1,"replyTime":"2020-11-08T03:36:08.000Z","msg":"獻完花之後佢會復活？借屍還魂？"},"citedBy":1,"replyTime":"2020-11-08T04:32:35.000Z","msg":"我諗今日咩都唔做嘅話 以後更加冇人會記得港共政府嘅邪惡"},{"pid":"d9f46c46c5091037a3a0e