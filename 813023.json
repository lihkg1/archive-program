9_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F11%2F130319_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=df5f3fb5&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/09/11/130322_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F11%2F130322_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=29559f68&s={SIZE}\" />"},{"pid":"09c6955723a5fab5f3306ea18858fb4bed23c6b1","tid":813023,"uid":78392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T05:07:08.000Z","msg":"G持"},{"pid":"bd30c0d0a44e7ec1b5192faf3d8e6c35790f7bbf","tid":813023,"uid":207291,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T07:11:14.000Z","msg":"樓主加油<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2cbd9a3c068050b15a706d7fc45aa77eb32b5bdc","tid":813023,"uid":14715,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-11T07:44:38.000Z","msg":"同我一樣<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /> <br />\n<br />\n但我係玩音樂。<br />\n<br />\n係屋企抑鬱左兩年，不停同自己焦慮爭扎，搬部琴出街彈。 已經抑鬱到個地步係覺得呢個次元呢個世界所有野都唔再重要，成個人好似比種恐懼侵佔左。 覺得唔得掂，唔可以日日呢係屋企自己彈琴，加上財政壓力，又買琴又借錢生活.. 到岩岩又出來打返工<img src=\"/assets/faces/lomoji/21.png\" class=\"hkgmoji\" />"},{"pid":"82c9f7d92e7b0cae07b25cd6f37df63cd3715642","tid":813023,"uid":208103,"like":0,"dislike":0,"score":0,"quote":{"pid":"2cbd9a3c068050b15a706d7fc45aa77eb32b5bdc","tid":813023,"uid":14715,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-11T07:44:38.000Z","msg":"同我一樣<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /> <br />\n<br />\n但我係玩音樂。<br />\n<br />\n係屋企抑鬱左兩年，不停同自己焦慮爭扎，搬部琴出街彈。 已經抑鬱到個地步係覺得呢個次元呢個世界所有野都唔再重要，成個人好似比種恐懼侵佔左。 覺得唔得掂，唔可以日日呢係屋企自己彈琴，加上財政壓力，又買琴又借錢生活.. 到岩岩又出來打返工<img src=\"/assets/faces/lomoji/21.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-11T08:04:07.000Z","msg":"我都唔知講咩好..