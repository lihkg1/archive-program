5adaf4eda0592f4f49ab12c8a721","tid":813023,"uid":192754,"like":0,"dislike":0,"score":0,"quote":{"pid":"d500f01924e114a06961a6a449020d69c45a7f65","tid":813023,"uid":208103,"like":0,"dislike":0,"score":0,"quote":{"pid":"b891fc0680051d16e359bb2089d153040c0e23ec","tid":813023,"uid":192754,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-09-10T10:25:00.000Z","msg":"覺得每幅都有d狐狸既痕跡"},"citedBy":1,"replyTime":"2018-09-10T10:30:00.000Z","msg":"乜狐狸<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-10T11:04:30.000Z","msg":"九尾<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7dff00cbf99bd4a6e698fd645ac9bd14416ed609","tid":813023,"uid":124169,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-10T11:06:34.000Z","msg":"亂得黎好似又有d pattern<br />\n好特別 加油<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"38b6d150288b8b6ef428cb0c92cbaea15a9cb576","tid":813023,"uid":48887,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-10T11:08:11.000Z","msg":"試下將你嘅畫風 畫下動物呀人呀建築物 睇睇ok?"},{"pid":"f91ace3a17ab7179676ba39ade698e7ffd873621","tid":813023,"uid":165711,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-10T11:14:16.000Z","msg":"呢啲應用喺設計度應該會唔錯<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />  樓主加油<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"e99a735de0981f055e5dae54dfc5745a933f8ea9","tid":813023,"uid":208103,"like":8,"dislike":0,"score":8,"quote":{"pid":"18deed9519a2524fe66fb2de7f2f8f47f90cd67e","tid":813023,"uid":154054,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-10T11:02:09.000Z","msg":"不如試下讀d畫畫有關既野<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /> ？"},"citedBy":0,"replyTime":"2018-09-10T11:19:48.000Z","msg":"順便講埋我個計劃<br />\n依家既打算係喺sem1完之前，扮番學，其實番full time，儲夠哂咗嘅學費之後再同阿媽坦白，然後下年報番art相關嘅asso，都係自己出學費<br />\n<br />\n番完幾日發現除咗接受唔到學校個氣氛，其實自己對畫畫外嘅課程都冇興趣，冇興趣就冇可能有gpa(對我嚟講)<br />\n依家係後悔自己當初唔夠膽報art，為咗&quot;將來&quot;報咗讀唔落去嘅就業性hd<br />\n<br />\n唯有呃自己，叫做畀一年自己諗清楚真正嘅想法<br />\n<br />\n我真係好撚冇用"},{"pid":"da07b1061b32508ea317389877b2206870cfca56","tid":813023,"uid":208103,"like":0,"dislike":0,"score":0,"quote":{"pid":"7dff00cbf99bd4a6e698fd645ac9bd14416ed609","tid":813023,"uid":124169,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-10T11:06:34.000Z","msg":"亂得黎好似又有d pattern<br />\n好特別 加油<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-10T11:21:56.000Z","msg":"多謝讚賞！！！！"},{"pid":"307753b81e0db674dd88f3b95ee3f8e260688995","tid":813023,"uid":208103,"like":0,"dislike":0,"score":0,"quote":{"pid":"38b6d150288b8b6ef428cb0c92cbaea15a9cb576","tid":813023,"uid":48887,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-10T11:08:11.000Z","msg":"試下將你嘅畫風 畫下動物呀人呀建築物 睇睇ok?"},"citedBy":1,"replyTime":"2018-09-10T11:29:55.000Z","msg":"雖然我咁講好失禮，好無知，但我由細就對畫一啲有形/既存嘅嘢無興趣<br />\n<br />\n至於畫人，覺得窮極一生都追唔上啲畫師，留喺我個comfort zone遠觀好了<br />\n<br />\nbtw我係感受到自己畫畫嘅進步，雖然好慢，我嗰種畫風係仲未到頂，所以未算固步自封<br />\n<br />\n得閒再試"},{"pid":"515f41cdb380f600af498f2a4598957e11b59924","tid":813023,"uid":29532,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-10T11:30:10.000Z","msg":"期待樓主更多既作品 希望你堅持畫落去 加油<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"8b487d25d6c32738a573e8b8366c48116511bf51","tid":813023,"uid":208103,"like":0,"dislike":0,"score":0,"quote":{"pid":"515f41cdb380f600af498f2a4598957e11b59924","tid":813023,"uid":29532,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-10T11:30:10.000Z","msg":"期待樓主更多既作品 希望你堅持畫落去 加油<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-10T11:38:33.000Z","msg":"多謝鼓勵<img src=\"/assets/faces/big/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a56e10fc41c3ff0f228e4be7bf97eb52e72d9ff4","tid":813023,"uid":192754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-10T12:07:50.000Z","msg":"支持樓主<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n可以睇下pollock"},{"pid":"75f334f575573119306664257e3fd0d7810022f4","tid":813023,"uid":96007,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-10T12:41:58.000Z","msg":"同我好似 不過我衰啲<br />\n讀得耐啲先退學，畫亦都冇你咁好<br />\n都係一年做野，但衰大洗冇意志定力，只係儲到一年學費，第二年屋企人比，好內疚，一樣窮撚公屋<br />\n心理壓力好大，遲朋友兩年，屋企窮，遲比到家用再加讀哩啲難搵錢，更內疚<br />\n然後最後，連對讀緊嘅野愈來愈迷茫"},{"pid":"845704a4fe28a711fac026eefe1cc4c5b30d7981","tid":813023,"uid":20867,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-10T12:44:23.000Z","msg":"U need a mentor, son."},{"pid":"adeee0f744839ba5b232592999c5800e43601051","tid":813023,"uid":144894,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2018-09-10T13:40:18.000Z","msg":"加油呀 難得有樣嘢係由衷地喜歡同投入<br />\n其實好多人可能對畫畫作技能搵食唔太認識<br />\n對視畫畫為工作嘅人有好大誤解<br />\n<br />\n不過如果你想畫好啲冇得逃避具象㗎<br />\n抽象只係一種可以選擇嘅表現形式 當中係有基礎而衍生<br />\n樓上有講到Jackson pollock <br />\n但佢畫為人所知嘅潑墨之前其實係畫landscape<br />\n抽象係由具象而生  <br />\n<br />\n有興趣交流下<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"a396a4d10e5bc1b24d3be165e092e23f4859f89d","tid":813023,"uid":208103,"like":0,"dislike":0,"score":0,"quote":{"pid":"75f334f575573119306664257e3fd0d7810022f4","tid":813023,"uid":96007,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-10T12:41:58.000Z","msg":"同我好似 不過我衰啲<br />\n讀得耐啲先退學，畫亦都冇你咁好<br />\n都係一年做野，但衰大洗冇意志定力，只係儲到一年學費，第二年屋企人比，好內疚，一樣窮撚公屋<br />\n心理壓力好大，遲朋友兩年，屋企窮，遲比到家用再加讀哩啲難搵錢，更內疚<br />\n然後最後，連對讀緊嘅野愈來愈迷茫"},"citedBy":0,"replyTime":"2018-09-10T13:44:00.000Z","msg":"好驚..."},{"pid":"0dbe2e920ac2b73ed90138e36db32e026f26ec52","tid":813023,"uid":9031,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-10T14:31:11.000Z","msg":"似錦鯉"},{"pid":"d4b339ce4d5652757adece12dd6204ddfd5148a4","tid":813023,"uid":147195,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-10T15:28:29.000Z","msg":"同巴打有啲似<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n不過中三揀科已揀va<br />\ndse後又係讀hd 讀左一個sem已經想死<br />\n之後又有好多問題煩<br />\n都係得畫畫先可以令自己輕鬆啲<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" /> <br />\n<br />\n平時鐘意畫二次元既野多 <br />\n但個人一depress啲畫風就好鬼黑暗<br />\n<br />\n巴打加油 你啲畫好有特色好靚<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"56f34385138171e3f4180a74a328834882a65893","tid":813023,"uid":80443,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-09-10T15:43:32.000Z","msg":"想問下樓主hd咩科？<br />\n<br />\n我覺得樓主要先深入了解下art嘅課程同你想象中一唔一樣，因為鍾意畫畫唔一定鍾意讀畫畫，art有好多歷史嘢理論嘢，更加免不了唔同類型嘅畫法畫風，包括有形嘅物件，趁啱開學睇下學校有無art嘅堂可以扮sit下。<br />\n<br />\n另外有少少意見，雖然樓主話對畫有形嘅嘢無興趣，不過樓主post上嚟嘅幾幅圖靚係靚，但又好似無乜主題，睇頭幾次會覺得新鮮，再睇多幾幅就會覺得無乜特別，會覺得只係一個好靚嘅花紋或者logo。我諗樓上嗰位提議你畫人/物唔係指好細緻咁畫出嚟，而係例如用你哩種pattern砌出嚟，每幅作品有主題/有「嘢」表現先會吸引人繼續睇。<br />\n<br />\n樓主啲畫係幾靚/有特色，儲返咁上下人氣可以試下出啲product仔搵銀，好似ig嗰陣有啲類似寫字嘅出products出出下宜家通街都係唉。<br />\n<br />\nsor for long gas<img src=\"/assets/faces/lomoji/16.png\" class=\"hkgmoji\" />"},{"pid":"8837ad6b477019ef86b39d4f06084850f45100ca","tid":813023,"uid":36673,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-09-10T15:51:59.000Z","msg":"諗清楚自己想行<br />\nFine art / design / illustration 邊條路<br />\n個人點都覺得想做創作前點都要有drawing 底，再學painting composition color theory個堆野<br />\n而呢堆fundamental skills，係香港上堂係唔會真係好學到<br />\n寧願你有份餓唔死既收入先，慢慢自己磨劍<br />\n唔好下下一黎就講「追夢」，將所有野美化<br />\n而最重要，係一定要走出comfort zone，接受批評，如果想靠呢門手藝搵食"},{"pid":"60121c971b59c6066da31c0484422b09849b9a4a","tid":813023,"uid":36673,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-09-10T15:56:46.000Z","msg":"後生用一年兩全心全意去探索一樣野，係非常好既事，好過日後後悔<br />\n但要諗清楚，唔好用追夢黎逃避現實"},{"pid":"83c1f333d09ed5f038887a9f6d0df2255139d535","tid":813023,"uid":144894,"like":0,"dislike":0,"score":0,"quote":{"pid":"60121c971b59c6066da31c0484422b09849b9a4a","tid":813023,"uid":36673,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-09-10T15:56:46.000Z","msg":"後生用一年兩全心全意去探索一樣野，係非常好既事，好過日後後悔<br />\n但要諗清楚，唔好用追夢黎逃避現實"},"citedBy":1,"replyTime":"2018-09-10T16:16:14.000Z","msg":"巴打講好好<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n另外似係行內人喎"},{"pid":"ce39cb7ed6f891c516a8eb97777f5eef749f4128","tid":813023,"uid":36673,"like":2,"dislike":0,"score":2,"quote":{"pid":"83c1f333d09ed5f038887a9f6d0df2255139d535","tid":813023,"uid":144894,"like":0,"dislike":0,"score":0,"quote":{"pid":"60121c971b59c6066da31c0484422b09849b9a4a","tid":813023,"uid":36673,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-09-10T15:56:46.000Z","msg":"後生用一年兩全心全意去探索一樣野，係非常好既事，好過日後後悔<br />\n但要諗清楚，唔好用追夢黎逃避現實"},"citedBy":1,"replyTime":"2018-09-10T16:16:14.000Z","msg":"巴打講好好<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n另外似係行內人喎"},"citedBy":0,"replyTime":"2018-09-10T16:26:41.000Z","msg":"只係一個過來人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n而家重新出發了，有時興趣永遠係興趣最開心，一變成工作就好痛苦<br />\n做自己唔討厭既野已經好足夠<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"71ce699a1ef28c3098777c288ec63b1508a0fb5d","tid":813023,"uid":208103,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2018-09-10T17:09:42.000Z","msg":"一次過回<br />\n<br />\n關於題材:其實唔討厭畫其他風格，具象物，明白會學到好多野，定題亦係吸引人睇必須品，既然咁多位前輩都建議，我就試吓畫，至少會定個題，不過要畫好耐<br />\n<br />\n關於讀art:係，我明讀art同淨畫有好大分別，(我諗)我比較有興趣去學，如果讀，我會揀設計嗰邊而非traditional art，應該會少啲歷史同死記硬背？<br />\n<br />\n關於將來:其實我重視現實&gt;夢想，就算行畫畫失敗咗都冇乜感覺，只係愛好，weekend抽到幾個鐘畫吓已經滿足，我依家係擔心現實，怕真係要拎住dse學歷做成世牛工，啲錢仲要唔夠開支，一日灰到黑，咁做人真係好慘<br />\n如果俾我揀，我會想讀得成書而非畫到靚畫<br />\n我依家甚至想忍住(學校冇fd，學習氣氛差，自己難自律，喺學校好痛苦)繼續讀落去...grad唔係問題，但冇可能升degree，叫做俾張hd啊媽睇，如果delay一年對我對佢都好大壓力，真係好亂好驚好迷惘<br />\n<br />\n我而家最想聽到有人同我講做一世店員(12k起，升少少職，最後15,6k到)可以普普通通，得閒畫吓畫咁樣養到老豆老母過世，然後繼承間公屋，孤獨終老，你話我冇大志，垃圾都好，我已經真係好滿足<br />\n<br />\n另外大家嘅鼓勵我每一句都有睇，由衷咁樣多謝你哋，雖然我都係一樣咁煩，我就唔逐個逐個回啦，但係我真係有睇曬㗎，多謝你哋！！！"},{"pid":"77764df4c357ec0d07411246919605896858dbed","tid":813023,"uid":74380,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-10T17:14:05.000Z","msg":"一齊加油<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> 咩科?"},{"pid":"028d2d756dbe57cc738