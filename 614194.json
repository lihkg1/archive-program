2Fimages%2Fapple%2F20180402%2Flarge%2F1522657163_e71c.png&h=01e45067&s={SIZE}\" /><br />\n<br />\n<img src=\"http://vmagimg.next.hk/images/apple/20180402/large/1522657166_59bb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fvmagimg.next.hk%2Fimages%2Fapple%2F20180402%2Flarge%2F1522657166_59bb.jpg&h=80547bd0&s={SIZE}\" /><br />\n<br />\n<img src=\"http://vmagimg.next.hk/images/apple/20180402/large/1522657175_6d9b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fvmagimg.next.hk%2Fimages%2Fapple%2F20180402%2Flarge%2F1522657175_6d9b.jpg&h=859e423a&s={SIZE}\" /><br />\n<br />\n<img src=\"http://vmagimg.next.hk/images/apple/20180402/large/1522657172_5a36.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fvmagimg.next.hk%2Fimages%2Fapple%2F20180402%2Flarge%2F1522657172_5a36.jpg&h=c3649e85&s={SIZE}\" /><br />\n<br />\n上年他們孖公仔到歐洲玩樂，當時被網民捕獲之後，張振朗回覆傳媒話「我們玩得非常開心」間接承認女友地位，而他們今日所張貼的照片，相信就是他們到歐洲旅遊時的照片。二人相識於第25期訓練班，即使他們多次拍拖被人斷正，但張振朗及陳芷尤都異口同聲以「好好朋友」稱呼對方。 <br />\n<br />\n<a href=\"http://nextplus.nextmedia.com/news/ent/20180402/579804\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnextplus.nextmedia.com%2Fnews%2Fent%2F20180402%2F579804&d=oJJwycnxtbbIxqRg37QJgcn%2FdpYTMnF8ODxps2tmzCA%3D&h=c1da3dd4\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fnextplus.nextmedia.com%2Fnews%2Fent%2F20180402%2F579804&h=cc748fdf\" data-auto-link target=\"_blank\">http://nextplus.nextmedia.com/news/ent/20180402/579804</a>"},"citedBy":1,"replyTime":"2018-04-04T05:38:59.000Z","msg":"第三張圖左下幾靚<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n留名"},{"pid":"6458d2403854bc4d89f4abe4c8f2528e72c22655","tid":614194,"uid":46201,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-04T05:52:25.000Z","msg":"分手分到張相用同一個景同打埋段一樣嘅野<img src=\"/assets/faces/normal/donno.gif\" class=\"h