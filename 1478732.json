ssets/faces/pig/argue.gif\" class=\"hkgmoji\" />"},{"pid":"5a737e13fc531402077fe23c86b4f1a5ae90d642","tid":1478732,"uid":11703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T16:18:03.000Z","msg":"<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" />"},{"pid":"9a0a92217873fdcb499b65ad1dac9884c5bc9e2d","tid":1478732,"uid":36065,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-16T16:18:18.000Z","msg":"求文字版"},{"pid":"4b72338ceb7bb14a73b6138dd9b1eb368a5c85f9","tid":1478732,"uid":11703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T16:19:51.000Z","msg":"<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" />"},{"pid":"055d0a83a6d8de429e07353ebcd7355713db4c55","tid":1478732,"uid":11703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T16:20:59.000Z","msg":"<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" />"},{"pid":"2b5222a0f7132a410cd2c24f556c0198d63ccf70","tid":1478732,"uid":48093,"like":1,"dislike":0,"score":1,"quote":{"pid":"9a0a92217873fdcb499b65ad1dac9884c5bc9e2d","tid":1478732,"uid":36065,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-16T16:18:18.000Z","msg":"求文字版"},"citedBy":0,"replyTime":"2019-08-16T16:21:00.000Z","msg":"「光復香港，時代革命」<br />\n<br />\n「光復香港既自由、人權、民主、資源自主同國際定位。」<br />\n<br />\n「聲稱五十年不變既時代之中，由香港人一齊由下至上撼動政權，改變政治體制。」<br />\n<br />\n「對我地年輕一輩黎講，與其2047年默默死去，倒不如趁香港尚有一絲希望既情況用盡最後一口氣，創造未來。」<br />\n<br />\n「有年長一輩問，到底我地後生既有無勇氣，將抗爭交返俾傳統大台領導。」<br />\n<br />\n「我不禁反問，傳統思維一輩又有無勇氣，放棄三十年黎既模式，放手俾我地手足以新思維方式改寫香港命運？」<br />\n<br />\n「當年青人日以繼夜，夜以繼日以不同方式向政府施壓既同時，旦願我地回過頭黎，會見到年長一輩企係現場，默默支持我地。」<br />\n<br />\n「年輕人需要既唔係金錢、唔係食物，而係活生生既人願意走出黎支持。」<br />\n<br />\n「由今日起，我地唔應該再分勇武同和理非，出得黎既就係手足，係抗爭者，用核彈都唔會割。」<br />\n<br />\n「只要拒絕迷信大台模式，唔割席，唔氣餒，善用國際思維，我地一定會贏。」<br />\n<br />\n「香港人，寧化飛灰，不作浮塵，光復香港，時代革命！」"},{"pid":"5b0d34c9e71159ecbb9e7de3d99a5bf59bf47d32","tid":1478732,"uid":215715,"like":0,"dislike":0,"score":0,"quote":{"pid":"85c076e1d49a06de714de0080fda0ebb35c7fecc","tid":1478732,"uid":43657,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-08-16T15:57:38.000Z","msg":"今日聽果時差d喊左<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n攬炒巴真係痴線架<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-16T16:23:23.000Z","msg":"光復香港<br />\n時代革命<img src=\"/assets/faces/dog/bark.gif\" class=\"hkgmoji\" />"},{"pid":"a35d7d2d251bef27acecb0415a03ca064a06fbcf","tid":1478732,"uid":53349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T16:24:22.000Z","msg":"<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"0181ded4ad1f8e0b548bb9472a37166a3629ff3a","tid":1478732,"uid":279111,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T16:24:23.000Z","msg":"［香港人入］8.18 人數好重要，但理性係關鍵<br />\n<a href=\"https://lih.kg/1478824\" data-auto-link target=\"_blank\">https://lih.kg/1478824</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"abc5be1e653ea36d4825e0658753a39aac6315ed","tid":1478732,"uid":11703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T16:24:24.000Z","msg":"<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" />"},{"pid":"400e45b2bf9494d0c8ed93737222f84b452ee433","tid":1478732,"uid":11703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T16:25:33.000Z","msg":"<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" />"}