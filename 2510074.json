s=\"hkgmoji\" />"},{"pid":"637f595509834f6e9a64568d21d7cf3f04d4fb47","tid":2510074,"uid":384622,"like":0,"dislike":0,"score":0,"quote":{"pid":"11c34477df163aa98398c33a271e6a3b7794a052","tid":2510074,"uid":247839,"like":0,"dislike":0,"score":0,"quote":{"pid":"82c5e27777b22800bb05a85eb2da6e38a7db6003","tid":2510074,"uid":384622,"like":3,"dislike":0,"score":3,"quote":{"pid":"332d5548b117239567071a1b8d0cc9f2f0145ff5","tid":2510074,"uid":189997,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2021-04-30T11:36:30.000Z","msg":"爆post今晚會加更，多謝大家支持<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-04-30T14:46:55.000Z","msg":"跑咩步丫熙熙<br />\n跑完仲緊撚火，睪丸酮上升<br />\n快啲搵kitty扑啦趁study leave<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-30T15:01:25.000Z","msg":"砌到佢唔洗溫書<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-30T15:17:58.000Z","msg":"邊溫邊砌易入腦<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"bb8ebadcbef80c3aeb341c60a01ddc4a49532457","tid":2510074,"uid":384622,"like":0,"dislike":0,"score":0,"quote":{"pid":"6999bf97a745140adf5d00a543fbd3d9aa67234e","tid":2510074,"uid":66044,"like":1,"dislike":0,"score":1,"quote":{"pid":"82c5e27777b22800bb05a85eb2da6e38a7db6003","tid":2510074,"uid":384622,"like":3,"dislike":0,"score":3,"quote":{"pid":"332d5548b117239567071a1b8d0cc9f2f0145ff5","tid":2510074,"uid":189997,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2021-04-30T11:36:30.000Z","msg":"爆post今晚會加更，多謝大家支持<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-04-30T14:46:55.000Z","msg":"跑咩步丫熙熙<br />\n跑完仲緊撚火，睪丸酮上升<br />\n快啲搵kitty扑啦趁study leave<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-30T15:15:55.000Z","msg":"可能會砌咗彈彈妹先<img src=\"/assets/faces/dog/play.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/play.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-30T15:18:45.000Z","msg":"唔會啦kitty先啱佢<br />\n傻熙擺明姐控"},{"pid":"814f5b0b899ccb082ef48d76aa706fd3ab5f9ce5","tid":2510074,"uid":189997,"like":28,"dislike":0,"score":28,"citedBy":0,"replyTime":"2021-04-30T17:04:54.000Z","msg":"一百六十七<br />\n<br />\n每個星期一次既數理科補習，當然冇撚可能令我突飛猛進，但至少我諗今次數學科要合格就應該唔難呱。<br />\n<br />\n雖然放左學仲要溫習真係好撚痛苦，但Jessica 係秋兒姐姐專登為左我而搵返黎既補習老師，唔通我又可以就咁走左去咩？<br />\n<br />\n再講，講起上黎我應該要好好多謝Jessica添。佢真係好有心好認真咁教我，而且一毫子都冇收過。<br />\n<br />\n話就話佢係比面秋兒姐姐先對我咁盡責，但佢真係好用心教又係事實。<br />\n<br />\n我諗考完試之後同佢講句多謝喇。<br />\n<br />\n&hellip;<br />\n<br />\n&hellip;<br />\n<br />\n&hellip;<br />\n<br />\n係呀，冇架喇。<br />\n<br />\n由我把口講出黎，佢應該要好好珍惜喇。<br />\n<br />\n*<br />\n<br />\n又過幾個星期。<br />\n<br />\n會考應該都差唔多尾聲，意味住秋兒姐姐應該好得閒，我應該有好多時間可以同佢相處。<br />\n<br />\n一諗起就好開心。<br />\n<br />\n「你做咩響度傻笑。」Jessica皺眉道：「快啲做埋呢幾題數喇。」<br />\n<br />\n「哦。」唉，又要做數。<br />\n<br />\n一路做一路做，我發覺Jessica一路都冇出聲。我斜眼望過去，佢一副眉頭深鎖既樣，又不斷咁望下自己部手機。<br />\n<br />\n佢今日開始補習以黎就係咁。<br />\n<br />\n其實早一兩個禮拜Jessica好似都有小小唔妥，但仔細再睇又唔似有事，同平時一樣咁專心教我數，我仲以為自己睇錯。<br />\n<br />\n雖然我同Jessica除左補習之外，響學校其實冇乜交集，但見親佢都唔會係而家一副心事重重咁望住電話既樣&hellip;<br />\n<br />\n搞乜鳩？<br />\n<br />\n「嘉嘉，我呢題唔識。」咁啱我遇到一條難題。<br />\n<br />\n但Jessica仲望住個電話發緊吽逗。<br />\n<br />\n「嘉嘉！」我提高聲線：「我唔識做呢題呀！」<br />\n<br />\n「下&hellip;？邊題？」Jessica如夢初醒。<br />\n<br />\n「呢題呀。」我指指課本上既題目。<br />\n<br />\n「呀&hellip;呢題呀&hellip;」然後又專心咁同我解釋。<br />\n<br />\n「唔該晒。」我道。<br />\n<br />\n「嗯。」Jessica點一點頭，又道：「你繼續做，有唔識再問。」然後又皺住眉望住個電話。<br />\n<br />\n「唉。」我歎左口氣：「我有啲攰，不如今日早小小放，好唔好？」<br />\n<br />\n平時既Jessica，一定會嚴辭拒絕（因為我之前試過），然後繼續認真魔人咁逼我做數。<br />\n<br />\n「都好&hellip;」Jessica道，然後開始收拾枱面。<br />\n<br />\n嘩，呢個簡直係非常唔尋常既舉動！<br />\n<br />\n更唔尋常既係Jessica以光速執好晒啲野一枝箭標走左，臨走有小小歉意咁對我講：「Sorry，我都有啲急事要行先&hellip;」<br />\n<br />\n「拜拜。」我都已經執好書包準備走。<br />\n<br />\n因為我有個計劃。<br />\n<br />\n*<br />\n<br />\nJessica一路上真係好似心事重重咁既樣，連我攝手攝腳地一路跟埋佢上巴士佢都唔知。<br />\n<br />\n其實我都唔知點解要咁八咁跟撚住佢，只係覺得Jessica平時咁用心幫我補習，我唔可以對佢有事而坐視不理。<br />\n<br />\n佢上左巴士響下層坐低之後即刻打左個電話，講左幾句就坐好左望住個車窗發呆，連我經過佢隔離都唔知。<br />\n<br />\nJessica落左車之後急急咁打左個電話，然後同一個女同學會合。<br />\n<br />\n係肥婆珍。<br />\n<br />\n驚大家唔記得，提提大家佢係另一個黃社既幹事，Jessica既好朋友。<br />\n<br />\n佢地一路行，走左入個商場度，然後兜黎兜去，最後又出左商場，行黎行去，最後響一間唔起眼既糖水鋪停左落黎。<br />\n<br />\n「咦&hellip;？啱啱明明見到佢兩個響度架？」我隱約聽到肥婆珍對住Jessica講。<br />\n<br />\nJessica好似鬆左一口氣咁，道：「可能係妳睇錯啫。」<br />\n<br />\n「可能我地黎遲左，佢地已經走左喇。」肥婆珍忿忿不平地道：「最衰呢度真係偏僻，如果唔係我睇實佢地，等妳自己入黎喇！我地而家快啲周圍搵下佢地！」<br />\n<br />\n「唔駛喇，可能真係妳睇錯啫。」Jessica拒絕：「不如我地都係走喇。」<br />\n<br />\n肥婆珍望住Jessica半响，先至說道：「妳自己知道發生咩事既，係咪？如果唔係妳都唔會叫我幫手跟住阿邦喇。妳又何苦黎到而家呢個地步先黎自己呃自己呢？」<br />\n<br />\n「我&hellip;」<br />\n<br />\n「唉，算喇。」肥婆珍道：「唔好搵喇，我陪妳返去先喇？定係妳都係決定響附近撞下佢地？」<br />\n<br />\nJessica表情好複雜，道：「我&hellip;唔知&hellip;」<br />\n<br />\n「行喇。」肥婆珍道：「我地返去再諗下點做喇&hellip;」<br />\n<br />\n我見佢地走，自己亦都決定結束呢段跟踪之旅。<br />\n<br />\n*<br />\n<br />\n思前想後，我估計Jessica早幾個星期已經懷疑阿邦社長有第二個，所以非常唔開心。<br />\n<br />\n而同我補習果日，就係阿邦社長最易出軌留低證據既日子，所以Jessica就搵肥婆珍跟住佢地，而肥婆珍亦不負所託，目擊到阿邦社長同另一個女仔出軌響一間偏僻既糖水鋪high tea，只係到最後一刻等唔到Jessica黎到佢地兩個就已經離開左糖水鋪。<br />\n<br />\n雖然事實好明顯，只係Jessica似乎一日未捉到姦，佢自己都唔想相信阿邦社長會有第二個女人。<br />\n<br />\n呢啲情情愛愛既野，我身為局外人又可以點幫佢呢&hellip;<br />\n<br />\n（待續）"},{"pid":"728f5bc729e5360739956074b1a7a19e1ea39dd3","tid":2510074,"uid":189997,"like":7,"dislike":1,"score":6,"citedBy":1,"replyTime":"2021-04-30T17:07:05.000Z","msg":"留言唔方便回覆住<br />\n大家enjoy加更<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />，聽晚過100正評既加更再見<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"7bcb2036b04a91798b3e21d2247e0d4a45611b8e","tid":2510074,"uid":305799,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-30T17:16:26.000Z","msg":"準備200正皮<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n繼續chur爆葉開威<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"ec0b39f20617a3cac283d7f25f08b5632a794aa2","tid":2510074,"uid":55658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-30T17:35:03.000Z","msg":"推"},{"pid":"687ee12a7d6f405a123cb7f745538b87637be582","tid":2510074,"uid":392661,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2021-04-30T17:37:57.000Z","msg":"藥威仔，你今次仲唔仆街<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n熙熙又個後宮喇，你有食幾多條女先肯收手，我係話緊你呀，威仔！<br />\n俾jenny知你仆街都唔得掂呀<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"461213364f97b7e05b358ded5a46c7a6e98463fa","tid":2510074,"uid":392661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-30T17:39:04.000Z","msg":"仆街，我醉得滯打錯字tim<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ff09e2d084e8049cf121cf9824c210493b133967","tid":2510074,"uid":210846,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-04-30T17:47:51.000Z","msg":"睇個勢要食埋Jessica啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"85fda8f0d84d144612d16a22f92d7978ff57e9fb","tid":2510074,"uid":138327,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-04-30T19:20:19.000Z","msg":"熙哥又有新女"},{"pid":"541cc5686c928135392dbf5f772d6771a6c7fd20","tid":2510074,"uid":40723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-30T20:03:02.000Z","msg":"<blockquote>呢啲情情愛愛既野，我身為局外人又可以點幫佢呢&hellip; </blockquote><br />\n<br />\n熙熙淨係職踢波<img src=\"/assets/faces/cow/ball.gif\" class=\"hkgmoji\" />同扑嘢㗎啫<img src=\"/assets/faces/pig/dance3.gif\" class=\"hkgmoji\" /><br />\n<br />\n谷咗咁耐都係時候出吓火喇<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"94194a6ddd647803a3ee9b3ae5bb5ffd2c49f418","tid":2510074,"uid":59408,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-30T20:43:41.000Z","msg":"<blockquote>驚大家唔記得，提提大家佢係另一個黃社既幹事，Jessica既好朋友。</blockquote><br />\n<br />\n堅係唔記得咗有呢個人<br />\n<br />\n熙熙會唔會太耐冇扑嘢食埋肥婆<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"cb3239098db725b69dfe14df71054aa782592e86","tid":2510074,"uid":47198,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-30T23:04:32.000Z","msg":"無睇兩集，咦睇嚟傻熙有新女食"}],"pinned":{"pid":"8e0928cff91f780f816448ec7c6760ba610ea0ac","tid":2510074,"uid":189997,"like":4,"dislike":0,"score":4,"citedBy":4,"replyTime":"2021-05-01T11:12:22.000Z","msg":"嘩一入黎過200正評<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n多謝大家比我呃like<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n應承得大家我點都會再加更既<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n時間暫定如下：<br />\n100正評加更 - 今晚夜啲<br />\n200正評加更 - 星期日夜晚<br />\n<br />\n多謝大家支持，夜啲見<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"}}