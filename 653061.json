0.000Z","msg":"係the rock"},{"pid":"93530b6dcb2db41d1707a6707230751ff81f4790","tid":653061,"uid":5949,"like":0,"dislike":0,"score":0,"quote":{"pid":"664b087893fc37b7899f09b7c8f9f2bd777f87bc","tid":653061,"uid":90634,"like":4,"dislike":2,"score":2,"quote":{"pid":"2141e2c97811bba8be579c4756a47c4389375e07","tid":653061,"uid":5949,"like":1,"dislike":0,"score":1,"quote":{"pid":"861e89085274276c625c63cc158ce9d07f925060","tid":653061,"uid":78522,"like":26,"dislike":0,"score":26,"citedBy":1,"replyTime":"2018-05-04T11:09:32.000Z","msg":"Emma stone"},"citedBy":1,"replyTime":"2018-05-04T11:09:58.000Z","msg":"人類最後一粒stone<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-05T03:48:30.000Z","msg":"係the rock"},"citedBy":1,"replyTime":"2018-05-05T03:49:03.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1915842ce3f4a02f7e2ecf97ea6fb0df17cea95f","tid":653061,"uid":3647,"like":2,"dislike":0,"score":2,"quote":{"pid":"93530b6dcb2db41d1707a6707230751ff81f4790","tid":653061,"uid":5949,"like":0,"dislike":0,"score":0,"quote":{"pid":"664b087893fc37b7899f09b7c8f9f2bd777f87bc","tid":653061,"uid":90634,"like":4,"dislike":2,"score":2,"quote":{"pid":"2141e2c97811bba8be579c4756a47c4389375e07","tid":653061,"uid":5949,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-05-04T11:09:58.000Z","msg":"人類最後一粒stone<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-05T03:48:30.000Z","msg":"係the rock"},"citedBy":1,"replyTime":"2018-05-05T03:49:03.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-05T03:51:36.000Z","msg":"Rock 同stone 識唔識分"},{"pid":"1fa77e248cc91eb059035940a2b95afd68c620ce","tid":653061,"uid":20563,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-05-05T03:54:15.000Z","msg":"「人沒有犧牲就什麼都得不到，為了得到什麼東西， <br />\n　就需要付出同等的代價。這就是等價交換。」 <br />\n<br />\n人稱「極速快Ｊ手」、「零秒出精」既我， <br />\n十九年了！！！！！！ <br />\n我終於參透到鍊成腎者之石既元素係咩！ <br />\n<img src=\"http://confessionsofa20somethingklutz.files.wordpress.com/2014/03/tom-cruise.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fconfessionsofa20somethingklutz.files.wordpress.com%2F2014%2F03%2Ftom-cruise.gif&h=f24f92a1&s={SIZE}\" /><br />\n<br />\n十九年既瘋狂打Ｊ、番工長期忍尿既習慣、少飲水、多飲茶／咖啡， <br />\n一一都係鍊成腎者之石既重要元素。 <br />\n係呢個等價交換既過程中，我非常之咁爽快！！ <br />\n我得到快感，亦換取到一時既方便， <br />\n但係代價，係非常之高&hellip;&hellip; <br />\n我啲頭髮甩到好似撤哈拉沙漠咁，寸草不生； <br />\n有時我好急尿，但係埋到廁所會痾極都唔痾出； <br />\n當然，最重要的就是腎者之石！！！ <br />\n<img src=\"http://static.apple.nextmedia.com/images/apple-photos/apple/20081009/large/09ls2p12.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fapple-photos%2Fapple%2F20081009%2Flarge%2F09ls2p12.jpg&h=c6993d57&s={SIZE}\" /><br />\n<br />\n粒腎石卡拎到我成日腰痛，條腰一郁，果隻痛楚就好似比狼牙棒桶菊花咁， <br />\n搞到我要長期啪止痛藥，真係苦過ＤＥＥ　ＤＥＥ。 <br />\n所謂好腰好腎好男人，我兩樣都無，係名副其實既雙失中年。 <br />\n女女見到都恥笑我　"},{"pid":"85ad48d4612833eb7aeceb9d21a3a84a14c7135e","tid":653061,"uid":175719,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-05T03:57:11.000Z","msg":"問過Time stone未？"},{"pid":"3b01ad0a65972fc02539d005829f3cf7e667ed1a","tid":653061,"uid":5949,"like":0,"dislike":0,"score":0,"quote":{"pid":"85ad48d4612833eb7aeceb9d21a3a84a14c7135e","tid":653061,"uid":175719,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-05T03:57:11.000Z","msg":"問過Time stone未？"},"citedBy":1,"replyTime":"2018-05-05T03:57:37.000Z","msg":"有無得用念力先<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ce760ac5ec2bbd90aa8d7acc7eb878b9d6eddead","tid":653061,"uid":175719,"like":0,"dislike":0,"score":0,"quote":{"pid":"3b01ad0a65972fc02539d005829f3cf7e667ed1a","tid":653061,"uid":5949,"like":0,"dislike":0,"score":0,"quote":{"pid":"85ad48d4612833eb7aeceb9d21a3a84a14c7135e","tid":653061,"uid":175719,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-05T03:57:11.000Z","msg":"問過Time stone未？"},"citedBy"