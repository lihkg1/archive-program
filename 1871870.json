.000Z","msg":"幾百case黑警check左十單炸"},{"pid":"528a0133f2e41dfa0310bcafa3841789ccde5620","tid":1871870,"uid":173598,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-09T18:29:51.000Z","msg":"以為popo又講大話<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"22801e6096e1ecaa1097d72df0844d884321cbe7","tid":1871870,"uid":229369,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-09T18:30:19.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"4bce6fe4ee408444495df88f897b277adac3d137","tid":1871870,"uid":144372,"like":0,"dislike":0,"score":0,"quote":{"pid":"ecbca157856d9ea1978520d8c65577c5bdcbfc9f","tid":1871870,"uid":48222,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-02-09T17:58:57.000Z","msg":"yoyo<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />居家隔離冇做到 每日體溫不報告<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-10T01:11:08.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"184b795705a7442d8b906b4ee11bbd3b3cb5fd19","tid":1871870,"uid":49144,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-10T01:13:36.000Z","msg":"<img src=\"/assets/faces/mouse/solution.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/solution.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/solution.gif\" class=\"hkgmoji\" />"}]}