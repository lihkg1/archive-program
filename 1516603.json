kQGHYm.gif&h=fb459259&s={SIZE}\" /><img src=\"https://na.cx/i/PccaBim.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPccaBim.gif&h=47a9ea95&s={SIZE}\" /><img src=\"https://na.cx/i/ioPoWim.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FioPoWim.gif&h=28d56dc4&s={SIZE}\" />"},{"pid":"b9a978134f8f3b1ed94e2362368f1813116e2934","tid":1516603,"uid":235527,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T15:32:21.000Z","msg":"<img src=\"https://na.cx/i/AqOQBkp.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAqOQBkp.png&h=80197c51&s={SIZE}\" />"},{"pid":"a0a962ab66d8888c54baaa5c5913a09a877d7a96","tid":1516603,"uid":82688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T15:34:54.000Z","msg":"自推廿連"},{"pid":"bd96ee680950d3fb39f1da505497332b211c7021","tid":1516603,"uid":82688,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-29T15:38:36.000Z","msg":"當上了多年共妓的穴蛾，聽到了標準的規範普通話，一股愛國的心驀然湧上腦瓜袋兒，另一股則濕潤了她繡上五顆黃星的紅色內褲。<br />\n穴蛾爬上了辦公桌，掃開裙擺，展開藏在兩腿之間黑漆漆的平台。白衣男亦褪下褲子，露出雄偉如警棍般的巨棒，頂端在漆黑仲閃爍著點點的銀光。穴蛾看不清銀光的真面貌，遠看疑是一顆螺絲帽，一問之下，白衣人卻辯稱只是安全套。"},{"pid":"9530fd397a94c878300a0d9eced563739e9e4a00","tid":1516603,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T15:39:01.000Z","msg":"鑑古知今:中共60年代三年大饑荒既維穩手法<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1516562\" data-auto-link target=\"_blank\">https://lih.kg/1516562</a>"},{"pid":"5654bb3fc83c8748d571b3e66ff7278c9dea25b7","tid":1516603,"uid":126730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T15:42:46.000Z","msg":"我睇到了"},{"pid":"402e6e8acb63834d6c8887211486fe056156730b","tid":1516603,"uid":233815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T16:14:28.000Z","msg":"痴線得幾均循又幾好睇，我要睇後續<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" />"},{"pid":"1329a68d21d141efb8d364732a29713853d9e740","tid":1516603,"uid":91017,"like":0,"disli