.gif\" class=\"hkgmoji\" />"},{"pid":"0ef437bb385d3a028a536d8b46105a44ae9057e0","tid":2061214,"uid":136973,"like":12,"dislike":1,"score":11,"citedBy":0,"replyTime":"2020-06-12T08:37:52.000Z","msg":"建議買六合彩中頭獎易啲"},{"pid":"3067fea17f97224194388a5e9e8a9a13041ede56","tid":2061214,"uid":224510,"like":7,"dislike":1,"score":6,"citedBy":0,"replyTime":"2020-06-12T08:38:28.000Z","msg":"RIP<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f1d55943a4316654a56eb76571dc0745a2f11b7a","tid":2061214,"uid":33357,"like":10,"dislike":1,"score":9,"citedBy":0,"replyTime":"2020-06-12T08:40:43.000Z","msg":"欣賞<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> 雖然都係徒勞無功"},{"pid":"8bbf03f6861c6c24c8b223801c7f00dc6c05b0c6","tid":2061214,"uid":234235,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-06-12T08:41:18.000Z","msg":"R.A.P"},{"pid":"e4a691bfdd3c8f1a9e815350bb52ef72a3222c8e","tid":2061214,"uid":3241,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-06-12T08:41:20.000Z","msg":"又玩命....."},{"pid":"7c7dde87af93bbfe0361fe656649d0d45470aa7b","tid":2061214,"uid":341986,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-06-12T08:41:27.000Z","msg":"花式自殺"},{"pid":"9fe42051fc40a02adbcf527b76b323bc17af0a82","tid":2061214,"uid":1095,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-12T08:42:20.000Z","msg":"花式自殺"},{"pid":"62974cf7af6d59ff536468d3cd279c345d21c372","tid":2061214,"uid":299092,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-12T08:44:27.000Z","msg":"推tweeter"},{"pid":"5a37acace9dbf2a1def40899c9448b4f01b9753f","tid":2061214,"uid":38777,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-06-12T08:45:26.000Z","msg":"一定倒轉告番佢(黨安法)顛覆國家政權罪<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"6b8c7c2863b22a2359311485a2102bce61efff9e","tid":2061214,"uid":55089,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-06-12T08:45:48.000Z","msg":"<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"55f231ed381da7f30062e4e8036dc154e4e17c51","tid":2061214,"uid":3063,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-12T08:46:10.000Z","msg":"托海老豆「拿 我只示範一次"},{"pid":"d13c37f1f2fd6f019897d762c37c27b0d0903189","tid":2061214,"uid":93986,"like":2,"dislike":0,"score":2,"quote":{"pid":"55f231ed381da7f30062e4e8036dc154e4e17c51","tid":2061214,"uid":3063,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-12T08:46:10.000Z","msg":"托海老豆「拿 我只示範一次"},"citedBy":0,"replyTime":"2020-06-12T08:51:58.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n一生人唯一一次既機會終於可以用埋佢。"},{"pid":"e9c351a1d4e4fedfdc2515cd09bea2c1fc6106d3","tid":2061214,"uid":18477,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T08:52:19.000Z","msg":"RAP<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" />"},{"pid":"eaf74fa29708e54de723ce45ef7adcdff37ddefa","tid":2061214,"uid":46128,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-06-12T08:56:49.000Z","msg":"言論自由 1/1"},{"pid":"259a39f6acf5baa5f5db616c0a523dd56f75fb51","tid":2061214,"uid":24036,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2020-06-12T08:57:06.000Z","msg":"武漢肺炎死者家屬試圖挑撥中國共產黨和中國人民的關係，極其陰險。武漢肺炎死者家屬狀告中國政府是搬起石頭砸自己的腳。武漢肺炎死者家屬如果狀告中國政府，不僅將損害中方利益，損害中國和武漢肺炎死者家屬關係，也將嚴重損害武漢肺炎死者家屬自身的利益。我這樣的武漢肺炎死者家屬，能和中國相提並論嗎！<br />\n<br />\n武漢肺炎死者家屬的拙劣表演充分暴露出其不可告人的險惡用心和政治企圖。我們正告武漢肺炎死者家屬認清形勢，懸崖勒馬，立即停止干涉中國內政，以免引火燒身、自食苦果。我們敦促武漢肺炎死者家屬立即停止此類挑釁行為，不要逆勢而動，避免損害地區的和平與安寧。中方將採取一切必要措施，堅定維護國家主權和安全。<br />\n<br />\n我要強調，中國內政不容任何外部反華勢力指手畫腳。武漢肺炎死者家屬狀告中國政府干預干涉中國內政，嚴重違反國際法和國際關係基本準則，是赤裸裸的霸權行徑。武漢肺炎死者家屬這一惡劣行徑不僅損害中方利益，也會損害武漢肺炎死者家屬自身的重要利益。"},{"pid":"356978b91a0a459e934a4dd0a91d793e6a3450f2","tid":2061214,"uid":46906,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T08:58:39.000Z","msg":"唔死已經贏左"},{"pid":"fa588c76241f876783160f44bfad7df20b7aaa05","tid":2061214,"uid":261816,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T09:01:01.000Z","msg":"陽光司法<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"d306a8da8d79f365ce96fefab5ec5a96dd4894b3","tid":2061214,"uid":102984,"like":7,"dislike":0,"score":7,"quote":{"pid":"49398d980610a5caf23c80d3689b65bcc6e53998","tid":2061214,"uid":118120,"like":71,"dislike":1,"score":70,"citedBy":2,"replyTime":"2020-06-12T08:30:03.000Z","msg":"俾你第一單成功左, 之後就會大堆人跟住做<br />\n政府點會肯"},"citedBy":0,"replyTime":"2020-06-12T09:01:04.000Z","msg":"你同我定都得啦，支那政府會定性佢做醫鬧(支那語:借炒作醫療糾紛而獲得非法利益)，然後用上年12月28號出嘅基本醫療衛生與健康促進法收佢皮。"},{"pid":"167d08ea7705e8c8a43506799a6dc9a69cb3ded9","tid":2061214,"uid":301092,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-12T09:02:16.000Z","msg":"你知道嗎 在中國是可以控告政府的<br />\n但一生人 只能做一次<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"639c5f4690db7bc7e3902265080c53d51f86d8d4","tid":2061214,"uid":170988,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T09:04:14.000Z","msg":"武獨"},{"pid":"c65cd720b3934759f73a52fdf670107894d54fb3","tid":2061214,"uid":173817,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T09:04:47.000Z","msg":"一路好走了"},{"pid":"1d5fb856445b9834924fd8bc86a6c6906e759370","tid":2061214,"uid":33868,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T09:05:20.000Z","msg":"好快死多兩個"},{"pid":"91d85a60b8ca333c11d66863bcf1c29d9f2ad6b2","tid":2061214,"uid":271516,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-0