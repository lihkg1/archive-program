1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:20:13.000Z","msg":"二"},{"pid":"1eb6ac3ae48e61a0005d1aa7b6540988913f2628","tid":1467324,"uid":261743,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-08-13T17:20:25.000Z","msg":"老實講<br />\n要捉鬼，又要好睇<br />\n影出黎正面而有說服力<br />\n最好嘅方法，係叫記者去捉<br />\n<br />\n例如第一次喺cwb，tvb記者追問個垃圾係唔係狗，成件事已經令警察單位無任何說服力<br />\n<br />\n我地手足圍鬼，就一定有&quot;人&quot; 會打鬼<br />\n只要唔比佢走，叫記者過黎<br />\n1.說話盤問技巧比我地好<br />\n2.大大個cam影住佢點答都係死<br />\n3.夠正面，夠公道<br />\n4.只要比所有人知入面係有鬼，自然就無人再信警察單位<br />\n<br />\n簡單講之後做乜都可以，因為根本就係警察滲透到各層面而令暴力不斷出現。<br />\n佢呢一步好毒，但因爲太毒，同時風險都太高<br />\n因而有太多野比我地去反利用，要珍惜<br />\n<br />\nMedia時代，用media去解決問題<br />\n用media去令對方不斷失敗<br />\n任何外力，都可以係助力"},{"pid":"e8a898b55e20d16be227251abf8bfc12b6c1393e","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:20:25.000Z","msg":"三"},{"pid":"95a061b270a0805404ff8dec47ef65ec4a457b6d","tid":1467324,"uid":2248,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:20:26.000Z","msg":"612 721 811"},{"pid":"8a978305cbed93bc25b4c321f92bc50980166f43","tid":1467324,"uid":260035,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-08-13T17:20:39.000Z","msg":"推"},{"pid":"cfe26a12cf12b30806d6e4fab2efe6cdcd607f13","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:20:49.000Z","msg":"四"},{"pid":"6d4a28dfe1d1d949aa3ded27caf76ef053d8f3cd","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:20:59.000Z","msg":"五"},{"pid":"16cb0e4170ce6ce3a8df66a990d12e3333178e64","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:21:12.000Z","msg":"六"},{"pid":"2003ca86d63a212780de806d73f112ca1c2ff990","tid":1467324,"uid":62610,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-13T17:21:14.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"3bc9499c5f90b6e13745fb83e35b499b5a7806ea","tid":1467324,"uid":19126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:21:16.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"53ddf46b1fcb136d8c365b76182490b85164656a","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:21:22.000Z","msg":"七"},{"pid":"ad757f39c63cd064b25ffabc312fa97489c8428b","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:21:34.000Z","msg":"八"},{"pid":"c32815184361497a86f94ad68fb4cd3f721a4f86","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:21:50.000Z","msg":"九"},{"pid":"e3dc9384e28c1db552e77ddb8a047fadb394124e","tid":1467324,"uid":243677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:21:54.000Z","msg":"都係果句 核爆都唔割席 五大訴求 缺一不可<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f06fce4ac2814d6d1144366e31c3853d929399d1","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:22:00.000Z","msg":"十"},{"pid":"eae5b6bff5a95503c23eb55ab23e3b1d39484cca","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:22:15.000Z","msg":"一"},{"pid":"0d9addbf91eaccd06dff843af6126ec249325bf8","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:22:25.000Z","msg":"二"},{"pid":"bd58648bcad6ede860b56c615f317856a86543cc","tid":1467324,"uid":45975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:22:36.000Z","msg":"三"},{"pid":"c546420fdd328328