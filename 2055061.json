dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"b96ae67149ed4685c8f1fbbb6442281af36b8c90","tid":2055061,"uid":261118,"like":0,"dislike":0,"score":0,"quote":{"pid":"a17f8394b48d2462276b75557b3c37a3f641ca1a","tid":2055061,"uid":161174,"like":0,"dislike":0,"score":0,"quote":{"pid":"c52bb3deac7eb1beafce1253024666d3df02dc76","tid":2055061,"uid":261118,"like":0,"dislike":0,"score":0,"quote":{"pid":"da961c3b8c222c761aaa91a20f0c01867b513e58","tid":2055061,"uid":161174,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-07T16:19:25.000Z","msg":"選項故"},"citedBy":1,"replyTime":"2020-06-07T16:20:12.000Z","msg":"好累，好想死"},"citedBy":1,"replyTime":"2020-06-07T16:21:20.000Z","msg":"點解一個二個都咁負<br />\n去我個吹水post傾吓?<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-07T16:25:35.000Z","msg":"私"},{"pid":"9584fded9d678b793520bdc6d43f86283bf42de5","tid":2055061,"uid":161174,"like":0,"dislike":0,"score":0,"quote":{"pid":"b96ae67149ed4685c8f1fbbb6442281af36b8c90","tid":2055061,"uid":261118,"like":0,"dislike":0,"score":0,"quote":{"pid":"a17f8394b48d2462276b75557b3c37a3f641ca1a","tid":2055061,"uid":161174,"like":0,"dislike":0,"score":0,"quote":{"pid":"c52bb3deac7eb1beafce1253024666d3df02dc76","tid":2055061,"uid":261118,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-07T16:20:12.000Z","msg":"好累，好想死"},"citedBy":1,"replyTime":"2020-06-07T16:21:20.000Z","msg":"點解一個二個都咁負<br />\n去我個吹水post傾吓?<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-07T16:25:35.000Z","msg":"私"},"citedBy":0,"replyTime":"2020-06-07T17:04:21.000Z","msg":"pmed"},{"pid":"a768e38b376315f8ff7b17dfd1be04cf7b8d32d2","tid":2055061,"uid":161174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-07T23:55:11.000Z","msg":"推"},{"pid":"4d55697aba281016ed423a4793f330316d4750c3","tid":2055061,"uid":297436,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-08T11:16:38.000Z","msg":"A<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"6a5374f37e884db0ca0aaf6fe8357e1819bf0357","tid":2055061,"uid":161174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-08T11:51:46.000Z","msg":"我寫選項故思考方式可能會比較跳脫啲<br />\n唔好介意<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d00bf2a60bea7eaeb6a42d11865443894d6d795b","tid":2055061,"uid":161174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-08T13:07:18.000Z","msg":"A. 扮忠心 (打我老細！再同阿叔舌戰3百回合)<br />\n.<br />\n. <br />\n. <br />\n<br />\n「你媽死了！」阿叔仲唔死心，以為講呢句就攻擊到人。<br />\n<br />\n「你媽死了？」我keep住扮傻。<br />\n<br />\n「是你媽啊！」阿叔如果呢刻手上拎住刀，應該會向我斬埋嚟。<br />\n<br />\n「是你媽啊？節哀順變啦。」我講完已經俾個民賤聯議員拉走。<br />\n<br />\n佢俾一大份傳單我，行一大個圈，一個個信箱咁入。我拎住傳單，喺浩熱嘅太陽底下，去一棟又一棟嘅舊樓信箱入傳單。<br />\n<br />\n不過咁都好嘅，最少唔洗俾佢哋監察住做嘢啊。樂樂就住附近，放工約咗佢食晏。但其實咁多傳單，冇可能喺咁短時間派完。<br />\n<br />\n我返到去同事嘅集合地點，發現佢哋已經走曬。打電話俾個負責人，佢叫我派曬啲傳單先走。但咁樣已經算加班啦。<br />\n<br />\n我決定：<br />\nA. 行遠啲掉曬啲傳單<br />\nB. 拎返屋企摺紙飛機<br />\nC. 上網唱衰個議員<br />\nD. 努力派曬佢<br />\nE. 其他"},{"pid":"cb89300662fa019392c9b7f60a27c06ac51adfd0","tid":2055061,"uid":100695,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-08T14:53:42.000Z","msg":"C"},{"pid":"dc1fd48037164094cb8520ee4c32033566149632","tid":2055061,"uid":161174,"like":0,"dislike":0,"score":0,"quote":{"pid":"cb89300662fa019392c9b7f60a27c06ac51adfd0","tid":2055061,"uid":100695,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-08T14:53:42.000Z","msg":"C"},"citedBy":0,"replyTime":"2020-06-08T15:09:22.000Z","msg":"我而家已經做緊<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"acc791d0b932f3735aad97f417fe53730edb60c2","tid":2055061,"uid":314767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-08T16:07:35.000Z","msg":"A+C"},{"pid":"6a1ffed00307baa5c0a2427f14869230d4b72941","tid":2055061,"uid":335967,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-10T01:46:04.000Z","msg":"支持<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"49cf93d6a880ba77c9b9f200f17e47dbd2bd47e8","tid":2055061,"uid":161174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T00:10:58.000Z","msg":"C. 上網唱衰個議員<br />\n.<br />\n.<br />\n.<br />\n黃思喺幾年後寫咗個故叫《早知當初》，但呢啲都係後話。而家當然要掉曬佢啲傳單啦，要我派曬先收工啊？我彩佢都有味啊。我仲約咗樂樂食飯，邊個得閒做啲冇人工嘅工。<br />\n<br />\n「油油！辛苦你啦。」樂樂見我一個女仔企喺烈日吓曬住太陽派傳單，都有心疼，怕我曬黑。<br />\n<br />\n「放心啦。」我擺一擺手，其實我並唔介意黑唔黑呢啲嘢。<br />\n<br />\n「嘻嘻，呢個請你飲，油油你好努力，好勁。」樂樂偷笑咁將一支偷偷地掂我嘅皮膚，凍一凍我。<br />\n<br />\n我頭先熱到就嚟暈咁，而家凍一凍即刻醒神曬。你望住眼前樂樂無憂無慮嘅笑容，而家平凡忙碌嘅生活，邊個會估到以後嘅事啊。<br />\n<br />\n「多謝。」我感觸咁低頭，令樂樂睇唔到我嘅表情。<br />\n<br />\n雖然而家未到2019年反送中，但你依然可以提前做到好多嘢。<br />\n<br />\n2015年<br />\n<br />\n因為食環署一直打壓無牌小販，本土民主前線決定同其他組織聯手撐小販。<br />\n<br />\n喺2016年6月8日，各個組織喺Facebook呼籲民眾晚上至旺角一帶捍衞旺角夜市。<br />\n<br />\n我嗰晚決定：<br />\nA. 叫埋暗黑小隊成員，join佢哋行動<br />\nB. join本土行動，幫手做號召<br />\nC. 叫天琦唔好去，會俾人拉<br />\nD. 唔敢去，做鍵盤戰士算<br />\nE. 其他"},{"pid":"d17d0da5820afdb1de72570eb07e94412a079649","tid":2055061,"uid":335967,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-12T01:15:34.000Z","msg":"A"},{"pid":"49d941a2ac63e3eb0775589fd6d189c6ec236b6c","tid":2055061,"uid":297436,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-12T03:25:01.000Z","msg":"真玩命B<br />\n<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"7776902a08411bd903c0fdf7ae633148d35befcc","tid":2055061,"uid":161174,"like":0,"dislike":0,"score":0,"quote":{"pid":"49d941a2ac63e3eb0775589fd6d189c6ec236b6c","tid":2055061,"uid":297436,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-12T03:25:01.000Z","msg":"真玩命B<br />\n<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-12T23:47:49.000Z","msg":"係啊"}]}