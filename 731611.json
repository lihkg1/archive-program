tid":731611,"uid":5549,"like":1,"dislike":0,"score":1,"quote":{"pid":"3f678e85ce80cbdb8abaef7c9813af561fc00689","tid":731611,"uid":76310,"like":0,"dislike":0,"score":0,"quote":{"pid":"264e55eecc43aef3f9f7dca8f1b695f36577c79c","tid":731611,"uid":90,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-07-06T10:35:05.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 咁撚多美斯"},"citedBy":1,"replyTime":"2018-07-06T10:59:11.000Z","msg":"新c朗，唔知又有冇事"},"citedBy":1,"replyTime":"2018-07-06T11:00:49.000Z","msg":"麥巴比<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-06T11:03:51.000Z","msg":"zaha, depay"},{"pid":"293a11d0270f687943102726f4405ee9e8583cab","tid":731611,"uid":74361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-06T11:05:55.000Z","msg":"美斯好撚慘<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"f843e56ab9936be735cbfdba8be54765cbd6a950","tid":731611,"uid":87394,"like":0,"dislike":0,"score":0,"quote":{"pid":"a0c2c6451cf474868df8bc2bf67da481981ffa5a","tid":731611,"uid":5549,"like":4,"dislike":3,"score":1,"citedBy":2,"replyTime":"2018-07-06T10:59:51.000Z","msg":"英格蘭美斯係史達寧<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-06T11:06:09.000Z","msg":"250係英超美斯"},{"pid":"dc0d1a0bb070e7abded67a10bf8b833d3a2a6bd2","tid":731611,"uid":72085,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-06T11:16:43.000Z","msg":"Lingard 都可叫美斯 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}