/lm2/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-25T10:18:59.000Z","msg":"其實一直都好想知<br />\n781652376呢串嘢係點得嚟<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"1bb626b42f283a0b10b036e6d79efb9676307730","tid":2034114,"uid":45285,"like":1,"dislike":0,"score":1,"quote":{"pid":"918f3d6f69aafe76554a902cceccf9c62835b501","tid":2034114,"uid":47674,"like":7,"dislike":0,"score":7,"quote":{"pid":"8b0c8af28dff61ebad3aa556f3585a2fd678f035","tid":2034114,"uid":33176,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2020-05-25T09:23:29.000Z","msg":"condolences用喺朋友上都得<br />\ncondolences to my friend and colleague就通<br />\n就咁colleague就&hellip;"},"citedBy":2,"replyTime":"2020-05-25T09:27:51.000Z","msg":"condolences係向生者講"},"citedBy":0,"replyTime":"2020-05-25T10:24:38.000Z","msg":"華小姐想親身落去慰問佢同事吧<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"9e8a715ce769b34111ce7ef49ff6ae5094eca41a","tid":2034114,"uid":63303,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-25T10:25:33.000Z","msg":"中國人悼念中國人點解唔講中文<br />\n華春瑩係崇洋媚外嘅漢奸<img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" />"},{"pid":"f6e7db22e89c8f8696e2fac5fcc606bcb318165b","tid":2034114,"uid":19552,"like":0,"dislike":0,"score":0,"quote":{"pid":"d8b6ae45441fab73de2a545cc5115aa70515e6fc","tid":2034114,"uid":86383,"like":0,"dislike":0,"score":0,"quote":{"pid":"c83559238fbd0b52a670e3479362bf5728771677","tid":2034114,"uid":88982,"like":0,"dislike":0,"score":0,"quote":{"pid":"d25d2deb5b561560873d893eaea4d4670b850007","tid":2034114,"uid":99568,"like":3,"dislike":4,"score":-1,"citedBy":3,"replyTime":"2020-05-25T05:01:49.000Z","msg":"<a href=\"http://www.facebook.com/profile.php?ref=781652376\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.facebook.com%2Fprofile.php%3Fref%3D781652376&d=g30fgRh1OaLpBbOto8aU3ltf78QfJQp2bpA%2BRTfa5cI%3D&h=e766b902\" target=\"_blank\">http://www.facebook.com/profile.php?ref=781652376</a><br />\n蓋ching 呢個你嚟?<i