o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBTMUo1o.jpg&h=8b122460&s={SIZE}\" /><br />\n<br />\n你地就知黑警又做緊野了"},"citedBy":0,"replyTime":"2020-01-05T02:46:45.000Z","msg":"自推"},{"pid":"05c6508b3bdf2568a69bc4e52016a8da61aa7b54","tid":1811701,"uid":141097,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-05T02:47:12.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"4cf8d27e38a6926402cebae8f0ed7d7aec6e1ce9","tid":1811701,"uid":284891,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-05T02:47:37.000Z","msg":"推，一齊去"},{"pid":"2dfe195dff7f4c06ef50a27c2d3e0cbcd5722a22","tid":1811701,"uid":258731,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-05T02:48:33.000Z","msg":"推到比立場/蘋果/議員睇到<br />\n［停止使用建制稱呼親共人士］<br />\n<img src=\"https://na.cx/i/ZQscQho.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZQscQho.jpg&h=56da94ca&s={SIZE}\" /><br />\n<br />\n強烈要求使用「共派」取代「建制」稱呼<br />\n<a href=\"https://lih.kg/1811104\" data-auto-link target=\"_blank\">https://lih.kg/1811104</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"3472752cf2de5a1edc5fc0f7484e7d0d2045a4e5","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"quote":{"pid":"75d1373bb4f86453ff9fdfe6bd79ce034c58df5d","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"citedBy":8,"replyTime":"2020-01-05T02:36:55.000Z","msg":"<img src=\"https://na.cx/i/umuyEzG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FumuyEzG.jpg&h=756d0719&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/BTMUo1o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBTMUo1o.jpg&h=8b122460&s={SIZE}\" /><br />\n<br />\n你地就知黑警又做緊野了"},"citedBy":0,"replyTime":"2020-01-05T02:50:41.000Z","msg":"再推"},{"pid":"b7e36b37e57a51ee09f3dc859f453a84f4860a5b","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"quote":{"pid":"75d1373bb4f86453ff9fdfe6bd79ce034c58df5d","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"citedBy":8,"replyTime":"2020-01-05T02:36:55.000Z","msg":"<img src=\"https://na.cx/i/umuyEzG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FumuyEzG.jpg&h=756d0719&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/BTMUo1o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBTMUo1o.jpg&h=8b122460&s={SIZE}\" /><br />\n<br />\n你地就知黑警又做緊野了"},"citedBy":0,"replyTime":"2020-01-05T02:52:03.000Z","msg":"［1月5日上水遊行的建議］［純粹地簡單遊行］［避免衝突］［避免破壞商鋪］［認同請廣傳］<br />\n<br />\n我們運動主題是五大訴求，反水貨只是非常次要的支線小任務，對大局沒有影響。我們不值得為水貨問題發生激烈衝突，沒有必要因此受傷和被捕。本頻道建議手足純粹地簡單遊行。<br />\n<br />\n如果勇武手足今日要出手，建議在其他較少佈防的地區進行突擊快閃行動，be water my friend。在上水勇武行動的風險很高，黑警已經做好準備，大量便衣埋伏和完善圍捕佈局，勇武手足被捕的機會大增。<br />\n<br />\n另外，上年6月至今，上水的水貨商人沒有對我們的運動和手足構成實際傷害，他們不是元朗白衣人、不是荃灣黑社會，我們沒有合理原因破壞他們的商鋪。<br />\n<br />\n其實好多藥房都係普通商人開黎搵錢，佢地唔係美心 / 吉野家，沒有表達明確政治立場，我地沒有傷害他們的道德理據。<br />\n<br />\n人不犯我，我不犯人。同樣地，我若犯人，人便犯我。如果我們無理地破壞別人的私有財產，只會不必要地樹立敵人，更有可能會得罪相關勢力人士，到時他們便有足夠理據作出回應。<br />\n<br />\n其實每個區都有不同的民生問題，上水有「水貨」，屯門有「公園」，深水埗有「南亞村」...<br />\n<br />\n我們的能力和資源都是相當有限，沒有可能解決所有民生問題。我們要專注五大訴求，唔應該分散力量，唔應該樣樣野都去理，唔應該到處去樹立敵人。<br />\n<br />\n本頻道認為勇武手足是極度重要的寶貴資產，絕對尊重、敬佩前線勇武手足。因此建議勇武手足在重要關頭先至需要出手，唔需要為不影響大局的水貨問題去面對受傷和被捕的風險。<br />\n<br />\n利申：本頻道與水貨生意沒有任何關係，純粹從運動和手足的利益出發。"},{"pid":"4571082df972fe5f18e419a4017a81b2a7bde31c","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"quote":{"pid":"75d1373bb4f86453ff9fdfe6bd79ce034c58df5d","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"citedBy":8,"replyTime":"2020-01-05T02:36:55.000Z","msg":"<img src=\"https://na.cx/i/umuyEzG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FumuyEzG.jpg&h=756d0719&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/BTMUo1o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBTMUo1o.jpg&h=8b122460&s={SIZE}\" /><br />\n<br />\n你地就知黑警又做緊野了"},"citedBy":0,"replyTime":"2020-01-05T03:07:07.000Z","msg":"推唔上去"},{"pid":"6b598c0dcd83f40b9e07a28239b44634a8edf36d","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"quote":{"pid":"75d1373bb4f86453ff9fdfe6bd79ce034c58df5d","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"citedBy":8,"replyTime":"2020-01-05T02:36:55.000Z","msg":"<img src=\"https://na.cx/i/umuyEzG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FumuyEzG.jpg&h=756d0719&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/BTMUo1o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBTMUo1o.jpg&h=8b122460&s={SIZE}\" /><br />\n<br />\n你地就知黑警又做緊野了"},"citedBy":0,"replyTime":"2020-01-05T03:09:55.000Z","msg":"推"},{"pid":"7d76f2bfd8b43b0c33b7b79368897ce4f215fe5e","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"quote":{"pid":"75d1373bb4f86453ff9fdfe6bd79ce034c58df5d","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"citedBy":8,"replyTime":"2020-01-05T02:36:55.000Z","msg":"<img src=\"https://na.cx/i/umuyEzG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FumuyEzG.jpg&h=756d0719&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/BTMUo1o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBTMUo1o.jpg&h=8b122460&s={SIZE}\" /><br />\n<br />\n你地就知黑警又做緊野了"},"citedBy":0,"replyTime":"2020-01-05T03:10:16.000Z","msg":"推"},{"pid":"4f1760697b627981a2cd70c71d15f589d05d8ecd","tid":1811701,"uid":126305,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-11T01:57:38.000Z","msg":"推"}],"pinned":{"pid":"b7e36b37e57a51ee09f3dc859f453a84f4860a5b","tid":1811701,"uid":229380,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-05T02:52:03.000Z","msg":"［1月5日上水遊行的建議］［純粹地簡單遊行］［避免衝突］［避免破壞商鋪］［認同請廣傳］<br />\n<br />\n我們運動主題是五大訴求，反水貨只是非常次要的支線小任務，對大局沒有影響。我們不值得為水貨問題發生激烈衝突，沒有必要因此受傷和被捕。本頻道建議手足純粹地簡單遊行。<br />\n<br />\n如果勇武手足今日要出手，建議在其他較少佈防的地區進行突擊快閃行動，be water my friend。在上水勇武行動的風險很高，黑警已經做好準備，大量便衣埋伏和完善圍捕佈局，勇武手足被捕的機會大增。<br />\n<br />\n另外，上