5273,"uid":50457,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-31T07:52:09.000Z","msg":"香港每年3億人次出入口，仲感受唔夠？"},{"pid":"93333798bcfe6c8d11f827548c554d5b73e23c69","tid":1085273,"uid":202767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-31T07:52:12.000Z","msg":"而家邊忽似係一國兩制<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1f744cc03166b83f66f09de5597f4f6484347570","tid":1085273,"uid":6604,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-31T08:04:42.000Z","msg":"又係陳淑薇個維穩節目"},{"pid":"c7f546cfb7535679023657e1f626baf1393ec281","tid":1085273,"uid":103156,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-31T08:08:44.000Z","msg":"有其形而無其實，連個形都係豆腐渣、半杯水。"}]}