ng\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F2GKH20p.png&h=6178433f&s={SIZE}\" />"},{"pid":"c2b93cbd47133b4c5bab24522bafdff0c87215ed","tid":1540250,"uid":394,"like":0,"dislike":0,"score":0,"quote":{"pid":"04c6675879bd58e806243d6058bc488f6ba8133c","tid":1540250,"uid":185582,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T11:09:10.000Z","msg":"g持"},"citedBy":0,"replyTime":"2019-09-04T11:09:49.000Z","msg":"綠色線制霸"},{"pid":"e600a93722c59b48cef5c8d17c69831a40c1825c","tid":1540250,"uid":245549,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T11:10:50.000Z","msg":"其實係咪大力推就得"},{"pid":"887d8c7288f972e5fb08fc092e9b580435ac5aac","tid":1540250,"uid":33749,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T11:11:21.000Z","msg":"有冇手足知東涌情況點樣"},{"pid":"1c52ad755a03fd68b905b47996036ab3ccda28a6","tid":1540250,"uid":394,"like":0,"dislike":0,"score":0,"quote":{"pid":"e600a93722c59b48cef5c8d17c69831a40c1825c","tid":1540250,"uid":245549,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T11:10:50.000Z","msg":"其實係咪大力推就得"},"citedBy":1,"replyTime":"2019-09-04T11:13:36.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"aa9da6273dbb00f7da9a6c17d1d9c684c834d03d","tid":1540250,"uid":394,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-09-04T11:14:08.000Z","msg":"冇人知咩歌?<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"6b9e8d7b6568a47e4c38e76bef1170b1144469f3","tid":1540250,"uid":272202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T11:14:21.000Z","msg":"五大訴求 <span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>缺一不可</strong></span></span><br />\n咪撚改口號 <span style=\"color: red;\"><span style=\"font-size: xx-large;\">送中仲未正式撤回 依家只係動議</span></span><br />\n<blockquote>林鄭又想過鳩我地一棟啊<br />\n<a href=\"https://lih.kg/1539720\" data-auto-link target=\"_blank\">https://lih.kg/1539720</a><br />\n<br