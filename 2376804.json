1/1611378589251/%e4%bd%90%e6%95%a6%e5%b0%81%e5%8d%80%e4%b8%a8%e4%b8%ad%e5%b9%b4%e6%bc%a2%e8%bf%94%e5%9b%9e%e5%b0%81%e9%8e%96%e5%8d%80%e5%85%a7%e5%af%93%e6%89%80%e8%a2%ab%e6%8b%92-%e6%8f%ae%e6%8b%b3%e6%89%93%e5%82%b7%e7%94%b7%e8%ad%a6%e8%a2%ab%e6%8d%95</a><br />\n<br />\n政府在佐敦設「受限區域」，要求區內的人完成新型冠狀病毒檢測才可離開。早上9時許，一名47歲謝姓男子走到上海街及南京街交界，報稱是「受限區域」居民，下班打算回家時被警員阻止，有警員向他解釋，其住所位於封鎖範圍內，進入後須留在住所，接受強制檢測並等候結果。<br />\n<br />\n謝男疑不滿安排，情緒激動揮拳打傷一名男警臉部，隨即被制服。他涉嫌襲警被捕，被帶往警署錄口供。受傷男警清醒被送往廣華醫院治理。"},{"pid":"587e8ccf7e39855879fb4f18bc7a9737da74d0da","tid":2376804,"uid":76609,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-01-23T05:36:28.000Z","msg":"真勇武<img src=\"/assets/faces/mouse/tea.gif\" class=\"hkgmoji\" />"},{"pid":"5db3ba596e69c7045112ee917a46c7489ab2bc8b","tid":2376804,"uid":195973,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-01-23T05:42:04.000Z","msg":"返完通宵諗住返屋企瞓，點知瞓醒無得返返工<br />\n<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/32.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/33.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" />"},{"pid":"3fed1c32ae9a72aee910b43ea976288c68ace11d","tid":2376804,"uid":187192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-23T05:44:55.000Z","msg":"坐監啦"},{"pid":"2f8a129d5dd183d244fe9dccde0d8e404b448e94","tid":2376804,"uid":284429,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-23T05:53:58.000Z","msg":"国安法拉人未"},{"pid":"3d59cb9924858f6617fdde3d52441ecd32789cb2","tid":2376804,"uid":42588,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-23T05:55:04.000Z","msg":"態度正確"},{"pid":"3c243696ba26f0b56c6a43976cbe2e56029fefd4","tid":2376804,"uid":62226,"like":0,"dislike":0,"score":0,"quote":{"pid":"5db3ba596e69c7045112ee917a46c7489ab2bc8b","tid":2376804,"uid":195973,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-01-23T05:42:04.0