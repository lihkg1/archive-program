faces/big/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4a87ca0c23bd99e79d0ac1b785dcc8b44053fba1","tid":2389004,"uid":313839,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-31T15:01:20.000Z","msg":"noun verb不分"},{"pid":"9e7a3b87fa281a8a5e1cf9458476c7d1efd57cec","tid":2389004,"uid":24788,"like":1,"dislike":0,"score":1,"quote":{"pid":"c1ae8f4b9e21f5c388902bbbcf21cf7f521aa493","tid":2389004,"uid":4574,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2021-01-31T14:43:25.000Z","msg":"梁燕城博士同門師兄王耀宗教授的分享，牟宗三大師果然慧眼識人：「有一年農曆過年，哲學系學生去牟先生家中拜年，學生中僅梁向牟先生跪拜，事後牟先生向人說：此子虚偽。」<br />\n<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-31T15:03:50.000Z","msg":"此子虚偽<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e3e78c7159fc1216fc485a62e1884f24cc2a4c5d","tid":2389004,"uid":103156,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-31T15:16:32.000Z","msg":"is &ldquo;unforgiven&rdquo; and not really mean ... ？！"},{"pid":"28f62aebce45a391b4cb42d4e35518191db44ed6","tid":2389004,"uid":103156,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-31T15:17:34.000Z","msg":"One of the example ?!<br />\n (冇一句係啱)"},{"pid":"852771557f188e3b7b2349aa3a90616948da2ec5","tid":2389004,"uid":295602,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-31T15:22:13.000Z","msg":"英文文法錯到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n翻譯唔分直譯意譯<br />\n如果係undergrad已經俾人屌到開花<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"1d64da71d3f939a5aa5fecb4075800ff9524d24d","tid":2389004,"uid":76657,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-31T15:25:14.000Z","msg":"Push"},{"pid":"42a254cff626e177e01dfd73151feb0facf0582f","tid":2389004,"uid":33586,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-31T15:31:24.000Z","msg":"他每天晚飯後穿著繍上「仁、義」的白色長衫，拿著線裝書，坐在新亞書院圓亭石座閱讀。牟宗三老師亦經常在此散步。聽說某同學一天問牟老師對梁某作為意見，牟說：「書是用來讀的，並非用來曬的。」此語傳轉一時。<br />\n<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\nSource: <a href=\"https://www.facebook.com/story.php?story_fbid=2765273717064953&amp;id=100007470555714\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fstory.php%3Fstory_fbid%3D2765273717064953%26id%3D100007470555714&d=NiOc6rc%2FE9fikVhzT7%2F1G3WT%2F8u5gjw5w0zJU6lVJ48%3D&h=a69d3a34\" target=\"_blank\">https://www.facebook.com/story.php?story_fbid=2765273717064953&amp;id=100007470555714</a>"},{"pid":"f0817775612f8bef50e354236a9ae20ca3b17b53","tid":2389004,"uid":130105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-31T15:41:23.000Z","msg":"佢講乜鳩？寫到咁深，要用Google Translate翻譯返中文先睇得明。<img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><br />\n如今，當人們用這句話說&ldquo;殺無赦&rdquo;時，其含義僅是一種戲劇性的表達。 從現代普通語言分析的角度來看，殺無赦（sha wu she）的含義是&ldquo;無法原諒&rdquo;的，並不是真正的&ldquo;殺戮&rdquo;。 其中一個例子是好萊塢電影，1992年由克林特&middot;伊斯特伍德（Clint Eastwood）執導，大衛&middot;人民（David Peoples）執導的電影《 Unforgiven》，其中文名稱在台灣被譯為殺無赦。 因此，如今使用此短語的方式是證明更多，以表示不可原諒的含義，而不是殺死"}]}