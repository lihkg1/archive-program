"a345927b11638a8e582ecab9501c48c127ffd322","tid":1395744,"uid":127675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-02T01:02:08.000Z","msg":"澳門咁細 應該割珠海比佢"},{"pid":"2a9b45a4e9a6964192bf3295fcf8db3ddfbfd61b","tid":1395744,"uid":63303,"like":0,"dislike":0,"score":0,"quote":{"pid":"923b8b40a160c7fa7689e362625a8703468523e2","tid":1395744,"uid":196924,"like":0,"dislike":0,"score":0,"quote":{"pid":"d64a25c1df459d4744ac00c3fe7ea71119cb9a8b","tid":1395744,"uid":10637,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2019-08-02T00:27:14.000Z","msg":"好心咁有錢就起條隧道啦<br />\n仲起橋<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-02T00:43:13.000Z","msg":"好似有研究緊起隧道<br />\n但係同香港一鳩樣，前期研究有排做<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-02T01:03:50.000Z","msg":"澳門輕軌<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"b7dc8a146aca273ea06f90ee08f0c57b134d05e0","tid":1395744,"uid":49247,"like":0,"dislike":0,"score":0,"quote":{"pid":"6cd5c7dc81bda66820b1057d32f95dab5552b4d2","tid":1395744,"uid":25771,"like":0,"dislike":0,"score":0,"quote":{"pid":"7c81f4ab81b189cf5857c65c6cd6f4ad457658e7","tid":1395744,"uid":37856,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-02T00:57:03.000Z","msg":"根本澳門d交通就廢到不行，d馬路粗糙又窄去水又唔掂，高速公路都冇條，連鐵路都冇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-02T00:58:04.000Z","msg":"對"},"citedBy":0,"replyTime":"2019-08-02T01:39:07.000Z","msg":"咁細起地鐵都維唔到本<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"16f57ebff220dda6e01f2df55d97640c78c0e14a","tid":1395744,"uid":36441,"like":0,"dislike":0,"score":0,"quote":{"pid":"d64a25c1df459d4744ac00c3fe7ea71119cb9a8b","tid":1395744,"uid":10637,"like":1,"dislike":0,"score":1,"citedBy":