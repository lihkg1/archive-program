/upset.gif\" class=\"hkgmoji\" />"},{"pid":"98668213c610c08bd1532af1697f275ff7f901cb","tid":2095004,"uid":164166,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-05T06:46:48.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"a1da480c74e23ae21164f236ffa69ee3d823ee93","tid":2095004,"uid":28818,"like":0,"dislike":0,"score":0,"quote":{"pid":"4cdd6d6baf95685c5abb8a440eb201e3f8aca123","tid":2095004,"uid":201359,"like":0,"dislike":0,"score":0,"quote":{"pid":"a1519743b69faac7c11fd993d70b76eaf17e63b1","tid":2095004,"uid":28818,"like":0,"dislike":0,"score":0,"quote":{"pid":"389a19e7a793db31e36cbd5a9108317e3833b1c5","tid":2095004,"uid":201359,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-05T06:42:04.000Z","msg":"<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-07-05T06:43:16.000Z","msg":"<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-07-05T06:46:17.000Z","msg":"因為你哋，我開始愛上香港<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-07-05T06:49:02.000Z","msg":"喺呢個咁壞嘅時代，有大家陪伴真係好<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" />"},{"pid":"0fbee6042aed02b0e276c7733cdf129bce22c195","tid":2095004,"uid":268868,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-05T06:53:40.000Z","msg":"<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"28b64bc015b432f456b8bd64dd092f214ddc4433","tid":2095004,"uid":201359,"like":0,"dislike":0,"score":0,"quote":{"pid":"a1da480c74e23ae21164f236ffa69ee3d823ee93","ti