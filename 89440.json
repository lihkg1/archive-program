=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0vDGt.gif&h=6e070bbf&s={SIZE}\" /> <img src=\"https://ipfs.infura.io/ipfs/QmfGq65PsZwdz9vMM6RQf4NhHBKusqxCgFfLF3E3eP8UVw?filename=mRF5C.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmRF5C.gif&h=af3ecd02&s={SIZE}\" />"},{"pid":"489806d160b12a312da0287598cc8ea5fb02bbde","tid":89440,"uid":36049,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:16:08.000Z","msg":"wfc<br />\n好人好姐點會睇big bang"},{"pid":"0b19f6db4bd7699060c854c5e03860e6863e6187","tid":89440,"uid":187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:17:30.000Z","msg":"抵撚死<br />\n落大雨淋撚死班韓狗<img src=\"/assets/faces/lomoji/33.png\" class=\"hkgmoji\" />"},{"pid":"75c24ea7eed7067161ebfceb31c3d3bbdd393c23","tid":89440,"uid":55468,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:19:44.000Z","msg":"睇韓狗就預左啦<br />\n冇搵保安打你地咪算好囉"},{"pid":"8478a9583e160f20aff5995e91fa05729335e66d","tid":89440,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:20:28.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"597e751bf05d1f1e1cc1b569d1c9ba0548671e79","tid":89440,"uid":19305,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:25:01.000Z","msg":"咁撚不滿咪撚睇囉<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <br />\n又要睇又要屌<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"4b34d6a3981a897102e2c7d0ce7c308e5a9e45dd","tid":89440,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:28:01.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />白痴港女"},{"pid":"b02a70e9065f5c5c062142ef53e00da57b4173e3","tid":89440,"uid":60831,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:28:26.000Z","msg":"佢地入去為左睇全亞洲第二型男:大腸<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"5af27f4da52bfd37dd7c912bced4a6be6f7e3cb6","tid":89440,"uid":3167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:30:26.000Z","msg":"睇jerjer 痕<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <br />\n見到篇野唔知點解好暗爽"},{"pid":"158c0ef586f3a3bb372cb6e46e01e35d2decbf7b","tid":89440,"uid":22696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:32:08.000Z","msg":"撚下啲泡狗幾好<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"3ad0bda2a9ef13e87e80c58e2891d0bcf78a9349","tid":89440,"uid":20460,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:35:28.000Z","msg":"各位快啲煲水啦<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" />"},{"pid":"7a70fe42fe1338abb46f41336213ac1d9651216b","tid":89440,"uid":1498,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T11:35:54.000Z","msg":"真係狗先睇<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}