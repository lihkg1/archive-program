ets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"cfc52868e920bc5212f6cfef84e6ddb19c078043","tid":1643044,"uid":21545,"like":0,"dislike":0,"score":0,"quote":{"pid":"a1bc277564eba9b52308d533f66dc34b1e4b1176","tid":1643044,"uid":21716,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-10T05:27:38.000Z","msg":"佢如果去做7仔，果間7仔會日日爆棚"},"citedBy":0,"replyTime":"2019-10-11T01:18:48.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2f5efffe1a180c94034bf9ed3328b67634e8c3c3","tid":1643044,"uid":56627,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-11T01:19:02.000Z","msg":"依家係講緊我地言論自由受到打壓<br />\n而佢係其中一個比較出名嘅名人<br />\n打壓到被人炒左都叫唔關我地事<br />\n係咪想個個做晒護𣄃手<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f365cfa765ac0f3762083833224cfedbb435d008","tid":1643044,"uid":60814,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2019-10-11T01:22:43.000Z","msg":"12年男友<br />\n<br />\n由佢17歲屌到而家29歲<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"cd48202dff975b75666c8656f48173c36ebd32b1","tid":1643044,"uid":52654,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-11T01:44:20.000Z","msg":"睇佢講野口吻，有腦過好多女仔<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"31f4687fd139474c30572a928d1b9f16766b6782","tid":1643044,"uid":46435,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-11T02:04:39.000Z","msg":"佢男友真係幸福賓周.."},{"pid":"a65ab97e738ee0b0835f87c869af90a0b27d2f16","tid":1643044,"uid":11062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-11T05:01:05.000Z","msg":"如果我地唔撐佢養佢 以後仲有邊個藝人敢撐香港？"}]}