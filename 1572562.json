2cd82f96ed4333c2d28c5abc2633fce0ca","tid":1572562,"uid":50414,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T01:19:33.000Z","msg":"推"},{"pid":"15400dfad7224e298f2380a155565a5862831c68","tid":1572562,"uid":69334,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T01:20:57.000Z","msg":"推"},{"pid":"8775413ee1e35288047b97b703b32124f19832b2","tid":1572562,"uid":197540,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T01:22:23.000Z","msg":"推！"},{"pid":"b366519f92604c895e5c512863a14f365c2f1abd","tid":1572562,"uid":321724,"like":0,"dislike":0,"score":0,"quote":{"pid":"b73a3ffdfb30a28bca122d59529e36ed357f3727","tid":1572562,"uid":136618,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-15T17:14:26.000Z","msg":"btw以後大家番屋企記得反跟蹤<br />\n已經有POST話狗係識得聞你浸除跟你番屋企再咬鳩你架<br />\n小心啲呀<img src=\"/assets/faces/mf/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-16T01:22:45.000Z","msg":"聞到浸除<img src=\"/assets/faces/mf/dead.png\" class=\"hkgmoji\" />"},{"pid":"c1adf733293b1d25e3c1ea01c2efc75aa7c1418b","tid":1572562,"uid":4739,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T01:23:57.000Z","msg":"所以大家應該唔好買保險等佢哋無錢claim<img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"98868f8536795cc0ef38cba8039434bc2aad816e","tid":1572562,"uid":74083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T01:26:44.000Z","msg":"推"},{"pid":"a273f2bc6f49980c143b9258a96269a91ff09313","tid":1572562,"uid":56224,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T01:28:36.000Z","msg":"推"},{"pid":"866bbaacc07eca31a8416c44e2518c1af09b4391","tid":1572562,"uid":66798,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T01:29:14.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"875fda7f0282ca95acd7c9e2ec7eec4b00fae334","tid":1572562,"uid":269988,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T01:34:27.000Z","msg":"推<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"15f042f8f946bcb5d45f57a22b9d86d5573a0ab5","tid":1572562,"uid":274329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T01:36:05.000Z","msg":"有好多大陸人過嚟香港讀個master<br />\n畢業之後就留喺香港做保險sell返大陸人<br />\n唔知關唔關事"},{"pid":"57343a544c01eef8154596f323cb36e6ae9f4f13","tid":1572562,"uid":277598,"like":0,"dislike":0,"score":0,"quote":{"pid":"cba312a110d07034cc226b739ded3a995ecfc454","tid":1572562,"uid":136618,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-15T17:03:57.000Z","msg":"我哋成功揭露嘅係中共對自己陣營嘅人民都如此地殘暴、同埋香港徹底地腐敗嘅面貌；我地用血打贏嘅一場仗，喚起咗全民自衛覺醒嘅勇氣同解開咗我哋嘅道德枷鎖。<br />\n<br />\n假保險、假醫生紙做嘅事，唔單止係大部份人諗嘅「示威者打傷人、街頭示威演變成為政治鬥爭」咁簡單。試想想，如果係真係要挑起兩方嘅鬥爭同埋做到文宣效果，俾官媒大做文章，其實只要有鏡頭捕捉到我哋打鬥就得，唔需要用到呢啲手段去做咁多手腳。<br />\n<br />\n惟一嘅可能性就係&mdash;&mdash;呢個係中聯辦或背後政權勢力出手，請黑社會搞事嘅出糧方法。而家成件事就係，有好多大陸同埋澳門過嚟嘅鄉黑同埋黑社會都係要收錢。要請得郁呢啲人，同721一樣，都係要錢。問題係，如果個銀碼唔夠大，根本係唔會動員到咁多人去做呢一件事。我思疑，就算何妖開晒post通晒天話要請啲人去參與「清潔行動」，我都覺得只係做「面」。即係根本背後水喉同埋勢力係大有人在，何妖呢條垃圾只係喺時任內被中共駛撚盡，用佢「良田村鄉民」嘅身份，令人聯想多一次其實只係鄉黑勢力搞事。<strong><span style=\"color: red;\">但件事根本唔係咁。</span></strong><br />\n<br />\n用假保險去「埋單」嘅最大嘅啟示，莫過於：中國嘅<strong><span style=\"color: gold;\">經濟同流動資金比我哋想像中更加不濟、更加綁手綁腳</span></strong>，要靠權力同政治手段去擺平呢啲我哋以為「用錢就解決到」問題。一張保險單已經係夠難claim。而家我哋尋日手足搵到嘅係一堆過千、過萬嘅保險單同埋有醫生簽名嘅證明。連醫生都收買到，背後嘅勢力一定係比我哋想像中更大（中共政權本身）；而咁多份保險一齊去claim其實都好有難度。根本分分鐘係連保險公司／經紀都施晒壓甚至收賣埋，又或者串謀專業人士行騙保險公司，顯見制度崩壞。<br />\n<br />\n我哋要做嘅就係要捉住呢粒核彈，不斷做文宣，俾人知道呢一班出嚟打示威者嘅黑社會根本背後係有中共勢力去刻意將抗爭污名化，同時落到我想講嘅第二點。<br />\n<br />\n知道對方係有咁嘅邪惡集團對任何抗爭者都唔係新鮮事。但往往我哋更加要知道嘅係，我哋要點樣先可以攞返場運動嘅主導權。就正正因為呢啲黑社會收錢搞事，而同時背後有咁大嘅共匪集團去科水，所以呢啲人／撐警嘅市民往往都係鏡頭前拉人、鏡頭後放走。前線嘅警犬絕對係唔會自己徇私咁做。佢哋一定係收咗上頭指示而有咁嘅行動。因為實際上，佢哋根本係唔會分到邊啲係真．憨鳩藍絲（平民）、邊啲係收錢做嘢、中共科水派嚟嘅黑社會。而得出嘅結論就係，往後有任何區內嘅光復行動（例如下星期六嘅屯門，同何妖虛張聲勢嘅「清理行動」根本係撞晒日子）都唔排除有機會會有黑社會＋鄉黑嘅出現。<br />\n<br />\n因此，我認為今日嘅手足係做咗個絕佳嘅示範，有人打我哋嘅時候，出於自衛同埋救走朋友，用適當嘅武力去自保根本就無問題。你諗吓人哋一個人單拖都夠膽郁你哋幾十個手足，分明就係笑我哋善良得太耐，奈佢幾惡，我哋都唔敢還手。同其他廢老無啦啦抗爭人群中嗌「中共萬歲」其實本質無異，根本就係恰你咩嘢都唔敢做，俾人打都淨係識報警。<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">我哋要口徑一致話俾中共知道&mdash;&mdash;話俾全世界人知道：我哋唔係怕事任打嘅懦夫。</span></span><br />\n<br />\n我想同大家講，「無分和勇」更深層嘅意思唔單止係「不割蓆、不分化」，而係唔應該用「和」同「勇」去為自己喺呢場運動中嘅定位。如果和理非永遠喺有人傷害自己嘅時候都驚、唔敢還手，即使勇武肯付出，我哋心態上都會輸咗俾自己。所有幫到場運動嘅行動，我哋都要去做，<span style=\"color: red;\">唔好俾任何角色同身份刻板地限制咗自己可以做嘅事、對運動、革命嘅想象。</span><br />\n<br />\n目標要一致，意志要堅定。我哋要做足萬全嘅工夫。我建議所有嚟緊會出去嘅手足都必定要組隊，尤其屯門區嚟緊嘅光復行動，大家要做好心理準備會有人搞事，而有事時手足一定要還拖。根本上，好似之前已經講過嘅5-10分鐘嘅黃金時間內，大家要爭分奪秒「做嘢」，be water，好好保護身邊嘅手足，唔可以再怕呢啲人性醜陋嘅勢力。<br />\n重要嘅事例如要記住，天時暑熱，飲多啲水，<span style=\"color: gold;\">細細個嘅<span style=\"font-size: small;\">金屬</span>水壺喺必要時&mdash;&mdash;必要時會救你一命</span>。<br />\n<br />\n<span style=\"color: teal;\">「今天政府毆打學生，明天就會毆打所有人民&mdash;&mdash;只有懦夫才會傷害孩子。」<br />\n「他們視我們為威脅，因為我們正帶來改變。」</span><br />\n<br />\n光復香港，時代革命。"},"citedBy":0,"replyTime":"2019-09-16T02:29:51.000Z","msg":"五大訴求，缺一不可 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"1fcf9081ff55c2eb69536e6cc28d4d722c26d655","tid":1572562,"uid":136618,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-16T03:04:29.000Z","msg":"<img src=\"/assets/faces/mf/smile.png\" class=\"hkgmoji\" />"}]}