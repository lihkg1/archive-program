tid":942854,"uid":204917,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-16T06:06:55.000Z","msg":"此回覆已被刪除"},{"pid":"e5c49c6e8d1e9fa6629d9706988e3ad631b4f46f","tid":942854,"uid":213441,"like":0,"dislike":0,"score":0,"quote":{"pid":"200715724b9ed54377c1815539d21e92e1da575b","tid":942854,"uid":204917,"like":0,"dislike":0,"score":0,"quote":{"pid":"0cdbb9e88427618d135d57a5f2de81200ae85666","tid":942854,"uid":213441,"like":2,"dislike":5,"score":-3,"quote":{"pid":"60593694eab8b32785918a799fbe19218da4b9f6","tid":942854,"uid":204917,"like":3,"dislike":10,"score":-7,"citedBy":2,"replyTime":"2018-12-16T06:04:55.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-12-16T06:05:52.000Z","msg":"你老母俾我屌緊<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-12-16T06:06:55.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-12-16T06:11:03.000Z","msg":"u like la"},{"pid":"c42c09f5a7e7a4e87ce3ef5b0e75302b1c73743e","tid":942854,"uid":209157,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-12-16T06:20:26.000Z","msg":"你個雷公鼻聞乜都臭架啦樓豬"},{"pid":"eb6fe382bc84d52d5698432bbcb735d22d41eb14","tid":942854,"uid":53026,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-16T08:57:32.000Z","msg":"冷氣機臭味洗極無用？　浸大首證人體皮屑是異味根源 (15:46)<br />\n（楊柏賢攝）<br />\n<br />\n<img src=\"https://fs.mingpao.com/ins/20180131/s00001/ef799997bb07fbcf1858e27c95bb4098.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffs.mingpao.com%2Fins%2F20180131%2Fs00001%2Fef799997bb07fbcf1858e27c95bb4098.jpg&h=08d20008&s={SIZE}\" /><br />\n圖3之1 - （楊柏賢攝）<br />\n<br />\n冷氣機傳出臭味，洗極都無用，異味來源可能與你我身體有關！浸大公布一項研究成果，首次證實人體皮屑如頭皮、手皮、腳皮等，可以成為冷氣製冷系統的細菌食物來源，令冷氣噴出怪味似腳臭、口臭，以至是小便味。<br />\n<br />\n浸會大學生物系副教授賴嘉雯表示，人體皮膚角質細胞每日老化，會產生死皮。皮屑含角質蛋白、脂質及脂肪酸等，吸進製冷系統後，內藏細菌可產生角質蛋白酵素將之分解，繼而經出風口傳播異味。<br />\n<br />\n研究從浸大10間冷氣傳出臭味的教職員辦公室進行實驗，從冷氣系統收集細菌樣本中，以葡萄球菌揮發性脂肪酸及角質蛋白酵素活性較高，前者會傳出體臭，後者較易傳出尿味。<br />\n<br />\n賴嘉雯表示，重複清洗冷氣非減輕異味長遠對策，治本之法是減少皮膚鱗屑進入冷氣系統，例如安裝或更換密度合適的隔塵網，有些可阻隔10微米（0.001厘米）皮屑，效果最理想。"},{"pid":"5938f534f97148d81da208be12ed8271827c9a8b","tid":942854,"uid":73536,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-16T09:00:41.000Z","msg":"此回覆已被刪除"},{"pid":"d2e1ccb76b3d0649706b8b89ee278ec4bfc6ef63","tid":942854,"uid":213441,"like":1,"dislike":0,"score":1,"quote":{"pid":"5938f534f97148d81da208be12ed8271827c9a8b","tid":942854,"uid":73536,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-16T09:00:41.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-12-16T09:06:16.000Z","msg":"co2有味<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"8360714b5f8f70e7b94d09d38c7c817d8459ef8e","tid":942854,"uid":73536,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-16T09:07:20.000Z","msg":"此回覆已被刪除"},{"pid":"45fdaa48c2d22488a9a9e3594b50ec70caa865a6","tid":942854,"uid":73536,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-12-16T09:08:52.000Z","msg":"此回覆已被刪除"},{"pid":"c138036834d11dcdebb701e003f1e60d09ca8292","tid":942854,"uid":28831,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-16T09:10:08.000Z","msg":"人嘅問題"},{"pid":"8a3da86f5f686816d9e3171eb20c160f54f45350","tid":942854,"uid":53026,"like":0,"dislike":1,"score":-1,"quote":{"pid":"45fdaa48c2d22488a9a9e3594b50ec70caa865a6","tid":942854,"uid":73536,"like":0,"dislike":0,"score":0,"quote":{"pid":"8360714b5f8f70e7b94d09d38c7c817d8459ef8e","tid":942854,"uid":73536,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2e1ccb76b3d0649706b8b89ee278ec4bfc6ef63","tid":942854,"uid":213441,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-12-16T09:06:16.000Z","msg":"co2有味<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal