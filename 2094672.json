A%2F%2Ftwitter.com%2FLotusOak2%2Fstatus%2F1251043604728029184&h=550666cd\" data-auto-link target=\"_blank\">https://twitter.com/LotusOak2/status/1251043604728029184</a><br />\n<br />\n<a href=\"https://onenewsnow.com/perspectives/bryan-fischer/2020/04/27/fauci-knew-about-hcq-in-2005-nobody-needed-to-die\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fonenewsnow.com%2Fperspectives%2Fbryan-fischer%2F2020%2F04%2F27%2Ffauci-knew-about-hcq-in-2005-nobody-needed-to-die&d=IQhlkTl0XfvqnQYO1cGwmk2FGjryiJR74P7%2B0uEOyUg%3D&h=fa45692a\" data-auto-link target=\"_blank\">https://onenewsnow.com/perspectives/bryan-fischer/2020/04/27/fauci-knew-about-hcq-in-2005-nobody-needed-to-die</a><br />\n<br />\n<a href=\"https://docs.google.com/document/d/1545C_dJWMIAgqeLEsfo2U8Kq5WprDuARXrJl6N1aDjY/edit\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdocs.google.com%2Fdocument%2Fd%2F1545C_dJWMIAgqeLEsfo2U8Kq5WprDuARXrJl6N1aDjY%2Fedit&d=IQhlkTl0XfvqnQYO1cGwmk2FGjryiJR74P7%2B0uEOyUg%3D&h=3de673d2\" data-auto-link target=\"_blank\">https://docs.google.com/document/d/1545C_dJWMIAgqeLEsfo2U8Kq5WprDuARXrJl6N1aDjY/edit</a>"},"citedBy":3,"replyTime":"2020-07-04T23:37:58.000Z","msg":"求其搵都有幾張RCT 都話無用喎...<br />\n<br />\n<a href=\"https://www.nejm.org/doi/full/10.1056/NEJMoa2016638\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.nejm.org%2Fdoi%2Ffull%2F10.1056%2FNEJMoa2016638&d=IQhlkTl0XfvqnQYO1cGwmk2FGjryiJR74P7%2B0uEOyUg%3D&h=d9d8b820\" target=\"_blank\">https://www.nejm.org/doi/full/10.1056/NEJMoa2016638</a><br />\n<em>&quot;After high-risk or moderate-risk exposure to Covid-19, hydroxychloroquine did not prevent illness compatible with Covid-19&quot;</em><br />\n<br />\n<a href=\"https://www.bmj.com/content/369/bmj.m1849\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.bmj.com%2Fcontent%2F369%2Fbmj.m1849&d=IQhlkTl0XfvqnQYO1cGwmk2FGjryiJR74P7%2B0uEOyUg%3D&h=85f278b6\" target=\"_blank\">https://www.bmj.com/content/369/bmj.m1849</a><br />\n<em>&quot;Administration of hydroxychloroquine did not result in a significantly higher probability of negative conversion than standard of care alone in patients admitted to hospital with mainly persistent mild to moderate covid-19. Adverse events were higher in hydroxychloroquine recipients than in non-recipients.&quot;</em><br />\n<br />\n無咩心機further research 呢個Topic, 反正就算有效個effect size都肯定好低, 同之前 prednisolone 個effect 唔會有得比<br />\n<br />\n巴打如果咁有信心佢有用, 請提供 good quality evidence, e.g. RCT, meta-analysis, either for treatment and prophylaxis as you claimed<br />\n希望唔好用新聞做reference, 垃圾新聞報science 野一向係亂9咁報"},{"pid":"b8dad85cbf850ca6d012d4754f2cae4d9d4cacf1","tid":2094672,"uid":294518,"like":1,"dislike":0,"score":1,"quote":{"pid":"957fea24a041ca1690bdc98eb6a6ab6ce0bde85c","tid":2094672,"uid":143343,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2020-07-04T23:21:21.000Z","msg":"譚德塞害死咁多人<br />\n縮返入你老母個閪度啦"},"citedBy":0,"replyTime":"2020-07-04T23:45:22.000Z","msg":"Trump 是低齊量用來預防，同時醫生臨床低劑量用來醫武肺，無一例死亡。有報告講療效副作用都係大劑量用藥（這是用來醫紅斑狼瘡的劑量），或武肺已到後期嚴重，就無用。<br />\n呢隻藥曾在美軍駐軍非洲用來預防瘧疾，也是低劑量長期服用，沒有嚴重不良反應。是安全的<br />\n呢隻藥已註冊40+年，無專利，但用了甘耐對其藥理，功效，份量及不良反應，臨床經驗已非常清楚。最壞來講既使無效，都不至於死人。但對藥廠就無利可圖，因為無專利，藥價非常便宜。<br />\n所以反對呢隻藥，一來係政治原因反Trump,凡Trump 支持的，就反對； 一來係有經濟利益，想大家用新開發的新藥，貴價藥，藥廠及背後控制勢力有錢收。但新藥係臨床都剛剛用，好多副作用/不良反應都無知，你就用自己命去試，再加呢隻病毒變異快，藥可否真有效？"},{"pid":"87e1acf2c42e6d7002d23ac79e152342a02756f0","tid":2094672,"uid":342398,"like":0,"dislike":0,"score":0,"quote":{"pid":"b2fa1407400d67b8c81e0331133ad63601648c5f","tid":2094672,"uid":171273,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-04T23:32:05.000Z","msg":"<blockquote><blockquote>死link</blockquote><a href=\"https://www.foxnews.com/politics/hydroxychloroquine-helped-save-coronavirus-study\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.foxnews.com%2Fpolitics%2Fhydroxychloroquine-helped-save-coronavirus-study&d=IQhlkTl0XfvqnQYO1cGwmk2FGjryiJR74P7%2B0uEOyUg%3D&h=ca1e1dc0\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.foxnews.com%2Fpolitics%2Fhydroxychloroquine-helped-save-coronavirus-study&h=74e7faad\" data-auto-link target=\"_blank\">https://www.foxnews.com/politics/hydroxychloroquine-helped-save-coronavirus-study</a><br />\n<br />\n<a href=\"https://www.ijidonline.com/article/S1201-9712(20)30534-8/fulltext\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ijidonline.com%2Farticle%2FS1201-9712%2820%2930534-8%2Ffulltext&d=IQhlkTl0XfvqnQYO1cGwmk2FGjryiJR74P7%2B0uEOyUg%3D&h=1bd755ac\" target=\"_blank\">https://www.ijidonline.com/article/S1201-9712(20)30534-8/fulltext</a></blockquote>"},"citedBy":0,"replyTime":"2020-07-04T23:46:15.000Z","msg":"原文<br />\n<a href=\"https://www.ijidonline.com/article/S1201-9712(20)30534-8/fulltext\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ijidonline.com%2Farticle%2FS1201-9712%2820%2930534-8%2Ffulltext&d=IQhlkTl0XfvqnQYO1cGwmk2FGjryiJR74P7%2B0uEOyUg%3D&h=1bd755ac\" target=\"_blank\">https://www.ijidonline.com/article/S1201-9712(20)30534-8/fulltext</a><br />\n<br />\n首先係 retrospective cohort study, level of evidence 好低<br />\n另外, 睇到一半已經見到大問題, 唔同group用steroid既比例差好遠<br />\nSteroid use (%)<br />\nNo med     35.7<br />\nHCQ only  78.9<br />\nAZM only   38.8<br />\nHCQ+AZM 74.3<br />\n<br />\nSteroid use 係之前一張大RCT 度proven 有好大既mortality benefit<br />\n我覺得此post已完"},{"pid":"fbe7d7349f40d076ada920c3bd672abbd456f455","tid":2094672,"uid":294518,"like":0,"dislike":0,"score":0,"quote":{"pid":"cbfea1e055ac11456d7b409b68d00a900665c648","tid":2094672,"uid":342398,"like":0,"dislike":0,"score":0,"quote":{"pid":"c5372b25d981ba1df27bdb72cdf4a1b675377306","tid":2094672,"uid":130699,"like":2,"dislike":0,"score":2,"quote":{"pid":"f80c216443b7a34a5f683461f3777cbf14c067e8","tid":2094672,"uid":171273,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-04T23:16:18.000Z","msg":"<a href=\"https://www.foxtv.com/news/study-finds-hydroxychloroquine-treatment-associated-with-lower-mortality-rate-for-covid-19-patients\" data-sr-url=\"https://r.lih