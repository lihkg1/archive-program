5aa25b","tid":1722991,"uid":320676,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-15T06:15:56.000Z","msg":"簡單啲四個字「臨時政府」"},{"pid":"80b0c828c800e327981b9db08998a3eb0794dbaf","tid":1722991,"uid":327411,"like":0,"dislike":0,"score":0,"quote":{"pid":"d8e7b9d342ee4d4ca7b6d6a2ceb09c7a115aa25b","tid":1722991,"uid":320676,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-15T06:15:56.000Z","msg":"簡單啲四個字「臨時政府」"},"citedBy":0,"replyTime":"2019-11-15T06:21:12.000Z","msg":"類似<br />\n<br />\n<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"8b474e06ab3220d91ab4ece92684dac05cd21675","tid":1722991,"uid":262329,"like":0,"dislike":0,"score":0,"quote":{"pid":"fb00f3caa9fd175b66fd52c3f1b9231d608deff4","tid":1722991,"uid":327411,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-15T05:06:16.000Z","msg":"<span style=\"color: red;\">長文</span><img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><span style=\"font-size: x-small;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\">睇</span></span>完先屌我</span><br />\n<br />\n所謂既升級其實係一個全民可參與既<span style=\"color: red;\"><span style=\"font-size: xx-large;\">議會</span></span>，主要討論抗爭方向同目標。<br />\n<br />\n要做既好簡單，首先喺大學，例如中大，搞<span style=\"color: red;\">全民身份驗證</span>同埋查袋，以防設立關口之前入黎既鬼，好處係提高互相既信仼度。如果捉到便衣，可能會有<span style=\"color: red;\">高級獎勵</span><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><br />\n<br />\n第二，設立一個<span style=\"color: red;\">議會</span>去討論抗爭未來方向，所有在內既人都可以參與，<span style=\"color: red;\">學生，非學生</span>都得。依個議會可能會決定到抗爭既方向，以及<span style=\"color: red;\">制衡</span>過份既行為，重組紀律，分工合作。<br />\n<br />\n<span style=\"color: red;\">議會</span>你可以話係一個小社區既行政機關，主要和理非擔當，而勇武就係執法機關，而同時，每一個勇武其實都係一個和理非，一樣可以參與議會，可以<span style=\"color: red;\">解決<span style=\"font-size: small;\">唔係前排既收聲</span></span><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><span style=\"color: red;\">互相制衡</span>。<br />\n<br />\n<br />\n議會由學生會主持，但參與者係black bloc，保護參與者，而議會過程係記者直播既<span style=\"color: red;\">高透明度討論</span>。<br />\n<br />\n好處係議會重組紀律，校內組織，增加公信力，對香港既影響力。<br />\n<br />\n建立左議會之後，<span style=\"color: red;\">政府有2個方案</span>：<br />\n<span style=\"color: red;\">1. 繼續冷處理</span>，大學議會強大，八大組成聯盟，超強影響力既組織<br />\n<span style=\"color: red;\">2. 強攻大學</span>，一間大學死守，其他大學繼續搞議會，死守既大學可以有社會既高度支持同支援，其他繼續發展，popo用<span style=\"color: red;\">方案1</span>對待其他大學（良好發展）或者<span style=\"color: red;\">方案2</span>，最後變成同時攻擊八大，全民保持開花，和你lunch之類既熱情，直達攬炒。<br />\n<br />\n實際既仔細步驟都諗好，可行性唔低，而依個係<span style=\"font-size: xx-large;\"><span style=\"color: red;\">和理非既升級</span></span>，但都要勇武既配合先做到，希望各方合作一致。<br />\n<br />\n有人會講，18區開花就夠，但學校係一個重要戰略地點，唔放棄得，而重兵死守，政府冷處理，專搞地區開花，唔夠人就會好快搞散<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n覺得有道理，可行性既就唔該<span style=\"font-size: xx-large;\"><span style=\"color: red;\">幫推到學生會見到</span></span><img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: x-small;\"><span style=\"color: gold;\">光復香港，時代革命。<br />\n五大訴求，決一不可。</span></span>"},"citedBy":0,"replyTime":"2019-11-15T06:22:41.000Z","msg":"贊成一切正面方案"},{"pid":"e00cd9cb110585500faf4759cfd7be93ce19a945","tid":1722991,"uid":222360,"like":0,"dislike":0,"score":0,"quote":{"pid":"d8e7b9d342ee4d4ca7b6d6a2ceb09c7a115aa25b","tid":1722991,"uid":320676,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-15T06:15:56.000Z","msg":"簡單啲四個字「臨時政府」"},"citedBy":0,"replyTime":"2019-11-15T06:38:53.000Z","msg":"推"},{"pid":"0a7876248b52ae8fe11ef67eeef3690af1de182e","tid":1722991,"uid":327411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T07:20:37.000Z","msg":"大學戰線係咪想好似機場咁失去<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />？"},{"pid":"e26ecf14bebb6386affac3e7671920ced83c9035","tid":1722991,"uid":9483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T07:32:21.000Z","msg":"Tui"},{"pid":"1d75aaf637258fd04879cb903c98df9645d87ead","tid":1722991,