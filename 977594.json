tid":977594,"uid":18955,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-01-12T07:19:47.000Z","msg":"滑稽程度同侵侵下令<br />\n美國學生簽證加多一條<br />\n必需擁護美國共和黨執政<br />\n維護共和黨嘅利益為根本<br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/beg_connect.gif\" class=\"hkgmoji\" />"},{"pid":"62d07841266f5d8a5b85902ca97b824f395da5b5","tid":977594,"uid":6604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-13T04:11:42.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"}]}