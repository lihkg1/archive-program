{"tid":2237022,"cid":5,"subCid":10,"title":"涉協助12港人偷渡，警方再拘捕9人：11:30AM 召開記者會，交代案情。","createTime":"2020-10-10T02:55:12.000Z","updateTime":"2020-10-10T05:59:44.000Z","uid":79563,"like":1,"dislike":11,"uniUserReply":4,"replies":[{"pid":"f7e60b46b09d5cc00f76f63b2e7c81beb3781311","tid":2237022,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-10T02:55:12.000Z","msg":"<img src=\"https://dw-media.wenweipo.com/dams/wwpproduct/image/202009/08/5f56e688e4b0483f530b19d8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fdw-media.wenweipo.com%2Fdams%2Fwwpproduct%2Fimage%2F202009%2F08%2F5f56e688e4b0483f530b19d8.jpg&h=2793335e&s={SIZE}\" /><br />\n<br />\n12名港人7月底涉嫌潛逃離境時被廣東海警截獲，現被扣押在深圳鹽田區看守所。據了解，警方以涉嫌協助12港人偷渡離境拘捕9人，他們涉及「安排偷渡船隻」、「安排接應車輛」及「提供住宿窩藏罪犯」等三宗罪。<br />\n<br />\n消息指，警方將於11時30分在灣仔軍器廠街1號灣仔分區警署召開記者會，交代案情。"},{"pid":"a548cfc6d3f5331f48494f51af8065e7e8690f20","tid":2237022,"uid":343361,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-10-10T03:08:34.000Z","msg":"此回覆已被刪除"},{"pid":"c66df0bd71551d9f7ec48220d446742187c42df7","tid":2237022,"uid":168389,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-10-10T03:37:33.000Z","msg":"即係一早知"},{"pid":"e83b8fe8f64ef3d8eb58ef9240d1e31ccb6abe57","tid":2237022,"uid":79563,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-10-10T04:42:44.000Z","msg":"<img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4a01415ce5a40104561344ecf767db14940522af","tid":2237022,"uid":92448,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-10-10T05:59:44.000Z","msg":"黑警+狗官+太監=港共曱甴集團"}]}