b947ed81963fd38d888e5df8fc35e82c","tid":778933,"uid":90601,"like":5,"dislike":1,"score":4,"citedBy":0,"replyTime":"2018-08-15T04:37:22.000Z","msg":"<del>上海自貿區&gt;一帶一路&gt;前海商機&gt;大灣區</del><br />\n<br />\n<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"8ee94d4d2751dc547a5b9eb6bf20644e04800198","tid":778933,"uid":47714,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-16T01:19:31.000Z","msg":"<img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" />"},{"pid":"7b020e3edc50a7c9759314d0977b2fef919d7c74","tid":778933,"uid":113000,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-16T01:21:07.000Z","msg":"fake news 尋日先開會黎<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"39a8480422656ac3ad2f9e428a0cb05856b8a283","tid":778933,"uid":41545,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2018-08-16T01:54:13.000Z","msg":"支那人真係永遠覺得其他人種蠢過佢地<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n無人知佢地做緊乜咁<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"c0687dbf59918d64d655f58a3132afe8d4f34d4d","tid":778933,"uid":141151,"like":6,"dislike":0,"score":6,"quote":{"pid":"61e4ed7310d1bf121027ed618e4a7ed73b31077c","tid":778933,"uid":51840,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2018-08-15T04:23:25.000Z","msg":"落實大灣區之時 = 取消香港關係法之日"},"citedBy":1,"replyTime":"2018-08-16T02:38:10.000Z","msg":"佢想慢慢做，以為美國冇人知<br />\n以後佢出咩policy，馬上download copy cap screen，send比美國國務院同國會外交事務委員會"},{"pid":"7d3a58d5f9a80571ee3e747a1a7239019364670e","tid":778933,"uid":47714,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T03:17:08.000Z","msg":"<img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" />"},{"pid":"8ad817c4faf567fd8d348f34254b980a3b4f1023","tid":778933,"uid":47714,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-17T11:04:58.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"808ee9375907d9aa9784990bf5a32d5406a3e5bd","tid":778933,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-18T00:58:11.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"90c501c2a6439361aa5206d3b589892952464b58","tid":778933,"uid":47714,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-19T00:34:43.000Z","msg":"<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" />"},{"pid":"78cc7b6538a6b149a05ca01402dbd298600aa95e","tid":778933,"uid":29804,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-19T00:46:33.000Z","msg":"去侵個Twitter"},{"pid":"ef4d68df402247c343a12c986f130d07c6bf4cb8","tid":778933,"uid":47714,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-19T17:56:33.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"}]}