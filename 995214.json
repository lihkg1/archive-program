y.hk/images/e-paper/20190125/large/1548397248_013a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190125%2Flarge%2F1548397248_013a.jpg&h=f42931e1&s={SIZE}\" /><br />\n馬貫東都有出席，但不見Mandy的蹤影。<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20190125/large/1548397337_280f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190125%2Flarge%2F1548397337_280f.jpg&h=985e322b&s={SIZE}\" /><br />\n《愛．回家之開心速遞》的收視好好，力壓另外兩套劇。"},"citedBy":1,"replyTime":"2019-01-25T09:38:06.000Z","msg":"Mandy<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-25T18:55:03.000Z","msg":"都唔知幾時至可以再見到mandy<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"93b746b3c8176bf21a6cfc34ca18d688c5ea1012","tid":995214,"uid":35014,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-25T23:26:05.000Z","msg":"此回覆已被刪除"},{"pid":"b84fea0e19b588367752e1fa495cbc0e3bfb381b","tid":995214,"uid":130901,"like":1,"dislike":0,"score":1,"quote":{"pid":"b001c39890c6406f88e1aa66d505564ef92f5896","tid":995214,"uid":130626,"like":0,"dislike":0,"score":0,"quote":{"pid":"4f56f9a8bd3e0997bb2b5afa991e1afd05ce6921","tid":995214,"uid":138713,"like":0,"dislike":1,"score":-1,"quote":{"pid":"12b9393115c4840298878e568ecc349f5b2a824c","tid":995214,"uid":130626,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-25T09:25:51.000Z","msg":"劉丹、滕麗名、呂慧儀昨日在將軍澳出席《愛．回家之開心速遞》團年晚宴，劉愷威和楊冪在上月宣佈離婚，將以親人身份共同撫養女兒小糯米(新聞連結： <a href=\"https://bit.ly/2QLaVky\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F2QLaVky&d=Ev%2FgGGd3hbiNhm%2BUCJXp8P755KD0hvcRsprRlRVhNBc%3D&h=a0b944b7\" data-auto-link target=\"_blank\">https://bit.ly/2QLaVky</a> )，不過近日有傳楊冪爭小糯米撫養權，丹爺還不惜減產，希望有更多時間照顧孫女，丹爺說：「點會呀？我驚自己嘅戲份少，反而叫佢哋加多啲我嘅戲份，其他嘢就等大家自己猜測喇！」<br />\n之後丹爺就轉移話題，他表示劉愷威已回港，準備一齊過年，他笑說：「本來佢都話想嚟晚宴，不過佢都冇份演出，又點可以嚟呢？」笑稱會否邀請兒子客串？他則說：「唔知佢得唔得閒，等我返去問吓！」他還說希望《愛．回家》長拍長有，自己一直可以演出，目標希望打破《真情》1128集的紀錄。<br />\n「大小姐」林淑敏和與許家傑異口同聲表示此劇令他們豬籠入水，不過林淑敏笑說：「收入同機會係好咗好多，但係可以更加好同更加多。」許家傑亦表示今年會派開工利是給一班幕後同事，當一份心意和祝福。<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20190125/large/1548397271_03c8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190125%2Flarge%2F1548397271_03c8.jpg&h=33136774&s={SIZE}\" /><br />\n丹爺避談有傳楊冪爭小糯米撫養權。<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20190125/large/1548397337_acac.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190125%2Flarge%2F1548397337_acac.jpg&h=153fafe0&s={SIZE}\" /><br />\n許家傑同林淑敏呢對情侶好受歡迎。<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20190125/large/1548397247_21b8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190125%2Flarge%2F1548397247_21b8.jpg&h=a475e0cd&s={SIZE}\" /><br />\n呂慧儀話希望長拍長有。<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20190125/large/1548397330_9456.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190125%2Flarge%2F1548397330_9456.jpg&h=c381e530&s={SIZE}\" /><br />\n阿滕話要陪老公去旅行。<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20190125/large/1548397248_013a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190125%2Flarge%2F1548397248_013a.jpg&h=f42931e1&s={SIZE}\" /><br />\n馬貫東都有出席，但不見Mandy的蹤影。<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20190125/large/1548397337_280f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190125%2Flarge%2F1548397337_280f.jpg&h=985e322b&s={SIZE}\" /><br />\n《愛．回家之開心速遞》的收視好好，力壓另外兩套劇。"},"citedBy":1,"replyTime":"2019-01-25T09:38:06.000Z","msg":"Mandy<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-25T18:55:03.000Z","msg":"都唔知幾時至可以再見到mandy<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-25T23:37:17.000Z","msg":"劇情係咪仲坐緊監?"},{"pid":"890f820cb82dd57cfbcd8baf31057b72b06d2018","tid":995214,"uid":130626,"like":0,"dislike":1,"score":-1,"quote":{"pid":"b84fea0e19b588367752e1fa495cbc0e3bfb381b","tid":995214,"uid":130901,"like":1,"dislike":0,"score":1,"quote":{"pid":"b001c39890c6406f88e1aa66d505564ef92f5896","tid":995214,"uid":130626,"like":0,"dislike":0,"score":0,"quote":{"pid":"4f56f9a8bd3e0997bb2b5afa991e1afd05ce6921","tid":995214,"uid":138713,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-01-25T09:38:06.000Z","msg":"Mandy<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-25T18:55:03.000Z","msg":"都唔知幾時至可以再見到mandy<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-25T23:37:17.000Z","msg":"劇情係咪仲坐緊監?"},"citedBy":0,"replyTime":"2019-01-25T23:44:00.000Z","msg":"放左，不過對白交代佢去左英國讀書"},{"pid":"3350dafb20a78e1f5b7ab46adeeee2af241360ef","tid":995214,"uid":130626,"like":0,"dislike":0,"score":0,"quote":{"pid":"93b746b3c81