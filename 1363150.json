8F%A0z-bucchigiri-match%E6%96%B0%E6%89%8B%E9%81%8A%E5%8D%B3%E6%99%82%E7%B6%B2%E6%88%B0-%E8%90%AC%E8%AE%8A%E5%8D%A1%E5%9B%9E%E6%AD%B8-%E6%9C%89%E7%89%87#media_id=1223974</a><br />\n<br />\n廢話少講，網上偷左啲圖比大家J<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://upload.cc/i1/2019/07/25/1l5cCX.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2019%2F07%2F25%2F1l5cCX.png&h=9b5335f9&s={SIZE}\" /><br />\n<img src=\"https://upload.cc/i1/2019/07/25/UtwxKC.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2019%2F07%2F25%2FUtwxKC.png&h=946e4b67&s={SIZE}\" /><br />\n<img src=\"https://upload.cc/i1/2019/07/25/mF9cWZ.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2019%2F07%2F25%2FmF9cWZ.png&h=43760e2d&s={SIZE}\" /><br />\n<img src=\"https://upload.cc/i1/2019/07/25/UhkFS2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2019%2F07%2F25%2FUhkFS2.png&h=38487efa&s={SIZE}\" />"},{"pid":"c5b9e7771dff33570cc57fb6eaa0358fd80bf9a0","tid":1363150,"uid":254214,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T05:47:44.000Z","msg":"game今日開始1周年<br />\n每日1次免費10抽，係入坑大好時機<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n我自己都冇玩成大半年<br />\n多人入坑一齊玩的話我再試下出教學<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},{"pid":"fecacfa50dafb018747234395ae6d02044397d20","tid":1363150,"uid":254214,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T10:36:22.000Z","msg":"<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},{"pid":"5e316fb49fe4ba972cf32110b24996fa5194af5c","tid":1363150,"uid":38576,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-25T12:56:33.000Z","msg":"無人應嘅，唔好玩咩？"},{"pid":"8c2cb2a1af0dd38be2a594f17d21c49efbd9349d","tid":1363150,"uid":254214,"like":0,"dislike":0,"score":0,"quote":{"pid":"5e316fb49fe4ba972cf32