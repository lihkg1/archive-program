1880620,"uid":15730,"like":1,"dislike":1,"score":0,"quote":{"pid":"a6865b2e7f8c6cbd4805efa2f934eb76033e4416","tid":1880620,"uid":240448,"like":12,"dislike":1,"score":11,"citedBy":5,"replyTime":"2020-02-15T03:57:32.000Z","msg":"佢個樣似日本人 多過 中國人"},"citedBy":0,"replyTime":"2020-02-15T04:07:56.000Z","msg":"個樣算係正氣少少<br />\n但個格一樣咁衰"},{"pid":"cd4fa92e5dea927e859a10e2c9e19880b17f149a","tid":1880620,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-15T04:09:58.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"cd748e8de706dee738a6d3a5f6359007be9e0771","tid":1880620,"uid":175523,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-02-15T04:10:46.000Z","msg":"用瘟疫維穩<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"259a51b7abaef35ba91a2f1944ead55b8d93976e","tid":1880620,"uid":297997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-15T04:11:58.000Z","msg":"堅定脫離支共"},{"pid":"2f77082a1b576d05dbeb3893e802b1ceb530de14","tid":1880620,"uid":276548,"like":0,"dislike":0,"score":0,"quote":{"pid":"a6865b2e7f8c6cbd4805efa2f934eb76033e4416","tid":1880620,"uid":240448,"like":12,"dislike":1,"score":11,"citedBy":5,"replyTime":"2020-02-15T03:57:32.000Z","msg":"佢個樣似日本人 多過 中國人"},"citedBy":0,"replyTime":"2020-02-15T04:12:15.000Z","msg":"咪成個蠟筆小新咁既樣<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"47355c56a38e1341300851a3ed9745fb588f1151","tid":1880620,"uid":139244,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-02-15T04:13:22.000Z","msg":"夠鐘抗爭了，當你沉默得高調<br />\n當得我歷劫低潮 ，為何尚要打擾"},{"pid":"075011e1fbb999c1e970b772cc285887416be429","tid":1880620,"uid":132380,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-15T04:15:20.000Z","msg":"收皮拉"},{"pid":"991753bcf7a2a1b3a30de9aaccbaaac9692a161e","tid":1880620,"uid":240448,"like":0,"dis