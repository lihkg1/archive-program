/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"30541754363ce77f9400dc29fa1285f93943a6a6","tid":151613,"uid":47160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-12T10:04:34.000Z","msg":"<blockquote>一野秒十萬兵</blockquote><br />\n前面明明收收埋埋驚俾其他玩家打，跟住一出手就大屠殺<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1187398ff8a5e37873dcdd662e379a4c1c8ef39a","tid":151613,"uid":15302,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-12T14:09:36.000Z","msg":"蜥蜴篇好糞<br />\n入侵篇幾好"},{"pid":"07869943f6cf73b129c4db64e78f3ca779e9ba0c","tid":151613,"uid":15194,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-12T15:58:32.000Z","msg":"<blockquote><blockquote>一野秒十萬兵</blockquote><br />\n前面明明收收埋埋驚俾其他玩家打，跟住一出手就大屠殺<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n係7萬人+馬 <br />\n之後黑山羊清場 一下3萬人<br />\n我好奇 動畫要點做 噗,支,噗,支,噗,支 果種音效<br />\n<br />\n安茲大人萬歲~"},{"pid":"75f375dd7673fb645f9c018f8076a8c84ed994bb","tid":151613,"uid":15194,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-12T15:59:59.000Z","msg":"<blockquote>蜥蜴篇好糞<br />\n入侵篇幾好</blockquote><br />\n<br />\n蜥蜴篇好好睇啊 又有王者威風 <br />\n又可以睇高大康 出來丟巨石<br />\n還可以睇成堆高級骷髏兵 做樓梯<br />\n還可以睇超位魔法 天地改變"},{"pid":"3437754ab34df7569cf9facc95cec7f0daa160f6","tid":151613,"uid":33907,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-12T16:10:47.000Z","msg":"<blockquote><blockquote>一野秒十萬兵</blockquote><br />\n前面明明收收埋埋驚俾其他玩家打，跟住一出手就大屠殺<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n前面係驚仲有其他玩家"},{"pid":"635afc0cb9788308fa31bb81da1cdb1c9accb5a2","tid":151613,"uid":16885,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-12T16:14:40.000Z","msg":"Overlord內容 世界觀屌打晒乜柒刀劍 加速<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal