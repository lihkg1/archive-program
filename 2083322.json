.ntdtv.com%2Fassets%2Fuploads%2F2019%2F11%2F1573451094_0bbd.jpg&h=29aa9a53&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-06-28T16:07:59.000Z","msg":"我重慶大廈門口跟機派一萬份masala tea"},{"pid":"f66320d310cb1f22cb816d9831c9641cf901bd74","tid":2083322,"uid":277888,"like":0,"dislike":0,"score":0,"quote":{"pid":"f0e48e1dabd6fcd162724709b1967a6b2abcc2a4","tid":2083322,"uid":36551,"like":5,"dislike":0,"score":5,"citedBy":2,"replyTime":"2020-06-28T16:05:37.000Z","msg":"如果係依兩條撚樣嘅其中一個，我去佐敦站派咗政府嗰一萬蚊<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://fs.mingpao.com/ins/20180322/s00001/0000308c90b3c042481c4cc0fb797173.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffs.mingpao.com%2Fins%2F20180322%2Fs00001%2F0000308c90b3c042481c4cc0fb797173.jpg&h=d4b50240&s={SIZE}\" /><br />\n<img src=\"https://i.ntdtv.com/assets/uploads/2019/11/1573451094_0bbd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.ntdtv.com%2Fassets%2Fuploads%2F2019%2F11%2F1573451094_0bbd.jpg&h=29aa9a53&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-06-28T16:08:17.000Z","msg":"好撚柒 <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"23182a4926000c09e41199fa6b8b7bc5da3924d1","tid":2083322,"uid":304769,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-28T16:10:51.000Z","msg":"屌，又要開香檳啦<br />\n<br />\n今年七一要加主題：<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\"><br />\n寧願最後不得善終<br />\n也不考慮含淚折衷<br />\n<br />\n我要美國制裁，無懼與支共同歸於盡，寧死捍衛自由民主</span></span></strong><br />\n<br />\n認同就拎張紙舉比美國睇，咪比條廢老Martin Lee騎劫我地，搞到美國以為我地驚攬炒而唔做野<br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">黃世澤出左香港政策法篤灰指南，好有用，大家入去睇</span></span></strong><br />\n<br />\n\t<br />\n\t<a href=\"https://youtu.be/s6o2r5DkT-w\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fs6o2r5DkT-w&d=wLbnxcWodPR608ZqId7G8aEbpHCTTcQcXY6VsQHNTK4%3D&h=05187412\" target=\"_blank\">https://youtu.be/s6o2r5DkT-w</a><br />\n<br />\n<br />\n借個位<br />\n正視聽：若抗爭方向不隨局勢改變，只會無謂地損兵折將<br />\n香港街頭抗爭目標，亦都係街頭抗爭最大效果；&ldquo;攬炒&rdquo;已經達到，今次搞蟈安法其實仲攬炒過上年出老解。<br />\n宜家<strong><span style=\"color: red;\">跟著落黎就係引導全球政府同議會（尤其美國）對付支那以及滅共</span></strong>，所以大家重點應該著眼帶出清晰民意授權比各國政府做野，畫面靚+全球廣泛報導（類似反蟈安法銅鑼灣自由行）係最理想，用選票帶出民意亦十分重要。<br />\n<br />\n<strong><span style=\"color: red;\">大家要小心五毛、熱狗放負風向：美國唔會幫我地（舊年年尾）-》英國係廢國無用架（今年年頭）-》歐盟奶共唔會幫我地（宜家）</span></strong><br />\n<br />\n大家要記住，香港生路只有一條：救香港人+攬炒促進支爆+重建香港。<strong><span style=\"color: red;\">沒有支爆，香港獨立或者歸英等重建方案全部都係痴人說夢。</span></strong><br />\n<br />\n未來幾個月至支共瓦解期間大家要做嘅事：1.<strong><span style=\"color: red;\">走資</span></strong>2.全球救生艇<strong><span style=\"color: red;\">救手足加有細路既黃絲家庭</span></strong>（細路是重點，香港未來棟樑，正如今時今日d前線義士，咪比佢地洗腦變小糞紅，否則香港係真正玩完）3.比足夠<strong><span style=\"color: red;\">民意授權，敦促美國以至各國凌遲式消除香港作為支那獲得外資渠道</span></strong>，包括但不限於：禁止美國個人或公司投資港股，暫停接受香港用美元結算等等4.最後就真係等<span style=\"color: red;\"><strong>支那自己爆</strong></span>"},{"pid":"c7675102c427b377f8606b9198b4fb4dda20ea82","tid":2083322,"uid":29858,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-28T16:11:11.000Z","msg":"見到有條友話鄭國泉愈黎愈大膽 笑到仆街<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0b0d8ef39220d88cf5d28c90efc595c613d69bb4","tid":2083322,"uid":19527,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-06-28T16:31:19.000Z","msg":"<a href=\"https://www.facebook.com/1412878685473594/posts/3304899402938170/?vh=e&amp;d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F1412878685473594%2Fposts%2F3304899402938170%2F%3Fvh%3De%26d%3Dn&d=wLbnxcWodPR608ZqId7G8aEbpHCTTcQcXY6VsQHNTK4%3D&h=7167e0a0\" target=\"_blank\">https://www.facebook.com/1412878685473594/posts/3304899402938170/?vh=e&amp;d=n</a><br />\n仲要兩隻，唔係咁開心啊<img src=\"/assets/faces/lm2/jable