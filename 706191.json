c7e1939013d7aee9d","tid":706191,"uid":18020,"like":2,"dislike":7,"score":-5,"citedBy":1,"replyTime":"2018-06-17T17:33:24.000Z","msg":"ON9仔 你覺得真係冇？<br />\n澳洲同澳大利亞呀"},{"pid":"6918c5bdf97d0341574571f25db87b2bebd8ddf1","tid":706191,"uid":10616,"like":0,"dislike":2,"score":-2,"quote":{"pid":"a4645abd52e2e1754ed535ac7e1939013d7aee9d","tid":706191,"uid":18020,"like":2,"dislike":7,"score":-5,"citedBy":1,"replyTime":"2018-06-17T17:33:24.000Z","msg":"ON9仔 你覺得真係冇？<br />\n澳洲同澳大利亞呀"},"citedBy":0,"replyTime":"2018-06-17T17:34:05.000Z","msg":"係喎<br />\nSor"},{"pid":"38bc1421d5ea712ed634a151e35d9c69e7914699","tid":706191,"uid":38588,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2018-06-17T17:38:00.000Z","msg":"支那國: 老撾 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n中華民國: 寮國 <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<br />\n陶傑都屌香港人跟左支那個低劣叫法 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"https://hk.lifestyle.appledaily.com/lifestyle/realtime/article/20160830/55570458\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.lifestyle.appledaily.com%2Flifestyle%2Frealtime%2Farticle%2F20160830%2F55570458&d=nIY874o3ksuotb5ZNJCUEozu7PIJYhBZqlGrkalTKs4%3D&h=d15483c4\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.lifestyle.appledaily.com%2Flifestyle%2Frealtime%2Farticle%2F20160830%2F55570458&h=d660e218\" target=\"_blank\">https://hk.lifestyle.appledaily.com/lifestyle/realtime/article/20160830/55570458</a><br />\n<br />\n方今由中國人的勢利視點，名字最醜陋的國家叫做「老撾」。本名寮國，中華民國、新加坡、英治時代的香港，都稱寮國，物產豐富，民風純樸，直到法治時代，本來安居樂業。<br />\n寮國在中國古代，曾稱為南業、瀾滄、蘭章，本來都體面，不知何故，又曾稱老撾、老抓、老丫、潦渣，這另一組名字，狀未開化，就很野蠻。<br />\n中國的陳毅，親自統一定性為「老撾」──這個「撾」字，是一隻野獸，伸出爪子來敲抓的意思，像你家養的狗直立時抓門板。陳毅不知與寮國有什麼仇，要將人家這樣妖魔化。當然，在定為「老撾」時，老撾剛出現了共產黨，首領是一個叫蘇發努馮的工人，雖皇族出身，法國留學回到寮國，卻發動鬥殺地主，與胡志明波爾布特等獠廝混在一起，所以這個名稱，倒也貼切。<br />\n中文凡以「老」字起頭，除了老師，都不是好東西，像老千、老鴇、老舉。我很奇怪為何寮國今日會容許中國人暗示自己是直立的一群獸爪子，可能窮得交關，需要中國的資金也說不定。<br />\n香港特區的華文傳媒，今天也跟着大陸，老撾老撾的亂叫。香港不是有反歧視條例和平機會的嗎？偶爾直立伸爪子抓狂敲打的犬類動物，自己倒有很多，所以我一聽見叫「老撾」，就想笑。"},{"pid":"badf3a81f3a6f47af0bda906225a9f1e92a20edb","tid":706191,"uid":173179,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-17T17:42:02.000Z","msg":"突尼斯"},{"pid":"b657666f7a80bc81ad59381dfb07b70527c5adcf","tid":706191,"uid":22589,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-17T17:42:51.000Z","msg":"新西蘭<br />\n紐西蘭"},{"pid":"d432da9f2455cb06c115f984686531ecaf50ca77","tid":706191,"uid":45582,"like":0,"dislike":0,"score":0,"quote":{"pid":"a6d24931e6fb4c7111a310d94a68553c6fa99090","tid":706191,"uid":50386,"like":0,"dislike":2,"score":-2,"citedBy":3,"replyTime":"2018-06-17T17:32:37.000Z","msg":"港支譯哥斯達黎加<br />\n台灣譯哥斯大黎加<br />\n<br />\n港支譯科特迪瓦<br />\n台灣譯象牙海岸"},"citedBy":1,"replyTime":"2018-06-17T17:46:05.000Z","msg":"事實上，在西元1985年時，該國總統在聯合國大會上，嚴正要求世界各國全面改稱該國為「科特迪瓦」，不要再用舊稱或是意譯的國名稱呼該國<br />\n此要求受到聯合國承認，於該年度的12月31日起，全球國家正式改稱其「科特迪瓦」<br />\n但我國一直這麼稱呼他們，他們難道不想找我們算帳嗎？<br />\n說到這裡就心酸了，由於兩國並無邦交，且我國在西元1985年早已失去聯合國會員資格"},{"pid":"1aac5825ad74d70a999666d399b19f80a1d1e0d8","tid":706191,"uid":122245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-17T17:46:59.000Z","msg":"克羅埃西亞，克羅地亞<br />\n奈及利亞，尼日利亞"},{"pid":"59f3b286072ab39058a3b0c7d3e37b07bdae8e5a","tid":706191,"uid":29784,"like":0,"dislike":0,"score":0,"quote":{"pid":"a6d24931e6fb4c7111a310d94a68553c6fa99090","tid":706191,"uid":50386,"like":0,"dislike":2,"score":-2,"citedBy":3,"replyTime":"2018-06-17T17:32:37.000Z","msg":"港支譯哥斯達黎加<br />\n台灣譯哥斯大黎加<br />\n<br />\n港支譯科特迪瓦<br />\n台灣譯象牙海岸"},"citedBy":0,"replyTime":"2018-06-17T17:47:54.000Z","msg":"弱會都上到抄登🤔"},{"pid":"290466b6aafb8279f3bc4757989e9c8b23e6fae0","tid":706191,"uid":294,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-06-17T17:48:44.000Z","msg":"中國香港<br />\nvs<br />\n香港"},{"pid":"070287ae221a65b1de80bd799c37442d32cd9022","tid":706191,"uid":76488,"like":5,"dislike":2,"score":3,"citedBy":0,"replyTime":"2018-06-17T17:49:09.000Z","msg":"此回覆已被刪除"},{"pid":"88abe20d8b33f73465ad7690207d