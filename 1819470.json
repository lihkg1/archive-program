":1819470,"uid":342968,"like":0,"dislike":1,"score":-1,"quote":{"pid":"54e12eabd85f9f3d6ce1546abd71bb0c0d104195","tid":1819470,"uid":163167,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-10T22:22:13.000Z","msg":"又標題黨<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />不過照推一推啦"},"citedBy":1,"replyTime":"2020-01-10T22:22:55.000Z","msg":"唔做標題黨冇人睇 sorry"},{"pid":"81bf20d1d6e49129fe764f46535fc00227c8d6cf","tid":1819470,"uid":207294,"like":0,"dislike":0,"score":0,"quote":{"pid":"3cf8efb0bc0398c6f018ef88c48079abe94a522c","tid":1819470,"uid":342968,"like":0,"dislike":0,"score":0,"quote":{"pid":"e85e4f47391a81708ff5ce25d9de44675b9f4437","tid":1819470,"uid":207294,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-10T22:19:36.000Z","msg":"屌醒咗我<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-01-10T22:20:30.000Z","msg":"手足 每個人都會錯 <br />\n身邊太多人分化 實在睇唔過眼"},"citedBy":1,"replyTime":"2020-01-10T22:25:26.000Z","msg":"無錯 再喺繼續分化<br />\n場運動唔喺俾對家瓦解<br />\n喺俾自己人瓦解<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"ababe18918cf16f99d7b523987a720a7255c2482","tid":1819470,"uid":303522,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-10T22:29:35.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"e6ff26dd203f9187a0e3dc5de49540571ee7970b","tid":1819470,"uid":342968,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-10T22:30:38.000Z","msg":"同埋同手足可唔可以禮貌啲啊<br />\n<br />\n我知大家好大壓力 但唔好下下向手足發洩"},{"pid":"27ea18b024e2ad24b1f37ac34cc5bd2336cd853c","tid":1819470,"uid":342968,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-10T22:31:40.000Z","msg":"不分化 不割蓆 不督灰"},{"pid":"8795a7391e64f96750b7ce90378e9df340b199a7","tid":1819470,"uid":116466,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-10T