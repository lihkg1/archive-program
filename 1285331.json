嘅可以睇privacy guide<br />\n<a href=\"https://www.privacytools.io\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.privacytools.io&d=mquyjxz0VyBhytkWBmIwRWsgcJLaMXzh2FZp7TjlN88%3D&h=9f4ad9d8\" data-auto-link target=\"_blank\">https://www.privacytools.io</a>"},{"pid":"25288b1439ed784bd861b8d543c0f6759512c407","tid":1285331,"uid":196924,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-04T14:14:02.000Z","msg":"由十一哥安然無恙嗰日開始就冇法治啦"},{"pid":"351d4a53e31087348a95e41a5606c2d4bb782a05","tid":1285331,"uid":68772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T14:15:58.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a38fbd3e6d748f2cbaedd782f53e6f03d11b1be6","tid":1285331,"uid":203889,"like":0,"dislike":0,"score":0,"quote":{"pid":"25288b1439ed784bd861b8d543c0f6759512c407","tid":1285331,"uid":196924,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-04T14:14:02.000Z","msg":"由十一哥安然無恙嗰日開始就冇法治啦"},"citedBy":0,"replyTime":"2019-07-04T14:16:20.000Z","msg":"[[緊急澄清]] 我係 [[夢見尋日 ifc 單野！ 我地比人玩]]樓主<br />\n<a href=\"https://lih.kg/1285228\" data-auto-link target=\"_blank\">https://lih.kg/1285228</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"82b0e2cc86e474a7f1c033744ebce55af4d3e24c","tid":1285331,"uid":16338,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-07-04T14:16:30.000Z","msg":"衰十一唔洗坐都知香港無法治啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1c4e1a30bee9263d35ac573133dbea24465c49ce","tid":1285331,"uid":68772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T14:19:21.000Z","msg":"法律幫唔到我地 我地更加要學識保護自己<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"34451e6b0c62e6678e2c7e1f34848e56e6ba8c15","tid":1285331,"uid":68772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T14:22:49.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"78ecf7308b1cb255fcd67f451664b314f77b5c5f","tid":1285331,"uid":68772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T14:26:48.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"1d112167ebfb12d7efd7b63177bada70695e420f","tid":1285331,"uid":68772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T14:32:16.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"4214cbc303fc6bfbc0b17987ed29daec6c7f82b9","tid":1285331,"uid":68772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T14:35:28.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"146e3d266cfbb983a7c73c21ed4c885d37a08d8a","tid":1285331,"uid":68772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T14:37:31.000Z","msg":"起錯標題<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"de06a2f5b48acb8054c014064b1bc41dc87c91e0","tid":1285331,"uid":54719,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T14:37:40.000Z","msg":"pro<br />\n<code>我冇野講</code>"},{"pid":"a778563ac7ebf0399d74387f051173532183b520","tid":1285331,"uid":68772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T14:40:19.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"57ede9697d4fd189fbdac10ea2f04208a713b2ce","tid":1285331,"uid":68772,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T14:40:29.000Z","msg":"<code>我無野講