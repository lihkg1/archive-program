83%85/345053/%E8%AD%B0%E5%93%A1%E4%BF%83%E5%BB%A2%E9%99%A4%E4%B8%AD%E7%92%B0%E6%B5%B7%E6%BF%B1%E8%AE%8A%E8%BB%8D%E4%BA%8B%E7%A2%BC%E9%A0%AD%E8%AD%B0%E6%A1%88-%E6%9C%B1%E5%87%B1%E5%BB%B8-%E5%90%A6%E5%89%87%E6%9C%83%E6%9C%89%E7%A4%BA%E5%A8%81%E6%8A%97%E8%AD%B0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E6%2594%25BF%25E6%2583%2585%2F345053%2F%25E8%25AD%25B0%25E5%2593%25A1%25E4%25BF%2583%25E5%25BB%25A2%25E9%2599%25A4%25E4%25B8%25AD%25E7%2592%25B0%25E6%25B5%25B7%25E6%25BF%25B1%25E8%25AE%258A%25E8%25BB%258D%25E4%25BA%258B%25E7%25A2%25BC%25E9%25A0%25AD%25E8%25AD%25B0%25E6%25A1%2588-%25E6%259C%25B1%25E5%2587%25B1%25E5%25BB%25B8-%25E5%2590%25A6%25E5%2589%2587%25E6%259C%2583%25E6%259C%2589%25E7%25A4%25BA%25E5%25A8%2581%25E6%258A%2597%25E8%25AD%25B0&d=BBPgAQHQe62%2Fb%2Fw120tVmZ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=345df2c9\" data-auto-link target=\"_blank\">https://www.hk01.com/%E6%94%BF%E6%83%85/345053/%E8%AD%B0%E5%93%A1%E4%BF%83%E5%BB%A2%E9%99%A4%E4%B8%AD%E7%92%B0%E6%B5%B7%E6%BF%B1%E8%AE%8A%E8%BB%8D%E4%BA%8B%E7%A2%BC%E9%A0%AD%E8%AD%B0%E6%A1%88-%E6%9C%B1%E5%87%B1%E5%BB%B8-%E5%90%A6%E5%89%87%E6%9C%83%E6%9C%89%E7%A4%BA%E5%A8%81%E6%8A%97%E8%AD%B0</a><br />\n[/url]<br />\n<br />\n<br />\n點解可以先訂後審自動生效？<br />\n<br />\n因為呢個法案係以附屬法例形式提交，簡單黎講係基於某條條例再加啲詳細細節。<br />\n<br />\n<a href=\"https://www.legco.gov.hk/education/files/chinese/Factsheet/Factsheet6.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Feducation%2Ffiles%2Fchinese%2FFactsheet%2FFactsheet6.pdf&d=BBPgAQHQe62%2Fb%2Fw120tVmZ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=34733242\" target=\"_blank\">https://www.legco.gov.hk/education/files/chinese/Factsheet/Factsheet6.pdf</a><br />\n<br />\n<a href=\"https://www.inmediahk.net/node/1062241\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1062241&d=BBPgAQHQe62%2Fb%2Fw120tVmZ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=5f250fdd\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1062241&h=b5d2583e\" target=\"_blank\">https://www.inmediahk.net/node/1062241</a><br />\n<br />\ncredit to 蘑菇毒病患者 巴打"},{"pid":"68682c0e8a6ae121388388f744abea0e0187c7bb","tid":1258750,"uid":261298,"like":16,"dislike":1,"score":15,"citedBy":0,"replyTime":"2019-06-26T09:13:17.000Z","msg":"有冇得諗？From Heidi朱 Facebook:<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n【發夢】<br />\n<br />\n立法會今日討論區諾軒和朱凱廸提出的修正案，廢除或押後5條將中環海濱及對開海面劃為軍事管制區的附屬法例。若果4組修正案均被否決，5條附屬法例將於6月29日自動生效。﹝ 詳情見：<a href=\"https://www.legco.gov.hk/yr18-19/chinese/hc/sub_leg/sc109/general/sc109.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr18-19%2Fchinese%2Fhc%2Fsub_leg%2Fsc109%2Fgeneral%2Fsc109.htm&d=BBPgAQHQe62%2Fb%2Fw120tVmZ1QB7Ma9ovE6nvZW%2BRTqP4%3D&h=fd09b976\" data-auto-link target=\"_blank\">https://www.legco.gov.hk/yr18-19/chinese/hc/sub_leg/sc109/general/sc109.htm</a> ﹞<br />\n<br />\n我發左個夢，夢見6月29日法例生效後，好多香港人為了一睹解放軍新軍事碼頭的丰采，一齊由添馬公園湧入碼頭野餐。然後解放軍聘請的特派守衛話要根據《受保護地方 ( 保安 ) 條例》拉人，但咁多人點拉得晒呢？<br />\n<br />\n醒番後，我才意識到今日4組修正案用心良苦，保皇派議員如果唔想夢境成真，搞到阿爺尷尬，理應支持修正案，稍為拖一拖件事。<br />\n<br />\n唔知多唔多人發埋同一個夢？係我就同番啲保皇同事單聲。<br />\n<br />\nPS：陳淨這張圖做得好清楚，但最後嗰句要加番幾隻字：「香港人將永遠無法(在解放軍不批准時)進入該處」<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n星期六圍碼頭, 請正負評"},{"pid":"a18d4f33baa6494684b1ceb6ba6c2aa64882fc6f","tid":1258750,"uid":32558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-26T09:14:09.000Z","msg":"pish"},{"pid":"6879cb6d9d090a571519a6b7a42301a3d0286782","tid":1258750,"uid":10056,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-26T09:15:26.000Z","msg":"幾時復會"},{"pid":"f7ead491fcd54bb9d738226ce8edc0a9748e7a78","tid":1258750,"uid":53369,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-26T09:16:16.000Z","msg":"今日真係精彩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n但無撚用"},{"pid":"080a6f68eaa9fbb7e5e254b92e8a91bffd55dbf3","tid":1258750,"uid":71770,"like":2,"dislike":0,"s