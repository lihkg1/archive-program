5b996f50cba979e86f1cbaa35","tid":1520103,"uid":42960,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-30T17:04:52.000Z","msg":"我知大家會怕會驚<br />\n試諗下我又未嘗唔係呢？<br />\n但當大家忍一忍恐懼<br />\n再望下身邊嘅人都同樣面對<br />\n咁仲有咩需要驚？"},{"pid":"2a3e2c23c3fecff61805b4686a7b1aef8b2fc3c8","tid":1520103,"uid":16425,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T17:04:56.000Z","msg":"其實香港人行街睇戲食飯好正常 行得正企得正洗鬼驚佢咩！"},{"pid":"1f5b7472b4f1cfcf5eaadac1f678023592eaa7bf","tid":1520103,"uid":42960,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T17:05:05.000Z","msg":"6/20"},{"pid":"ff73736e1c77f2541dab4fc6ef35b12c54d551a5","tid":1520103,"uid":139173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T17:05:11.000Z","msg":"<img src=\"https://na.cx/i/LUpTHxB.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLUpTHxB.jpg&h=6bd49a3d&s={SIZE}\" /><br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: gold;\"><br />\n點解政府做咁多嘢煲大民怨<br />\n急住要喺831決戰<br />\n因為九月有機場有三罷<br />\n記住不受傷不被捕<br />\n九月份繼續齊上齊落<br />\n</span></strong></span>"},{"pid":"4e7f450f57486085b3df9ca47cb20350dbd896b8","tid":1520103,"uid":42960,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T17:05:24.000Z","msg":"7/20"},{"pid":"25ec4cb8ba11ee284115b5cb76daa982526564c9","tid":1520103,"uid":42960,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-30T17:05:38.000Z","msg":"8/20"},{"pid":"f8e65a3f19ff67f5c88f7217a58ed9fbe205ea3a","tid":1520103,"uid":8948,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T17:05:39.000Z","msg":"標題黨 = 不推"},{"pid":"66bd395d33596f4707104bace06bddcb13c291d8","tid":1520103,"uid":42960,"like":0,"dislike":0,"score":0,"quote":{"pid":"f8e65a3f19ff67f5c88f7217a58ed9fbe205ea3a","tid":1520103,"uid":8948,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-30T17:05:39.000Z","msg":"標題黨 = 不推"},"citedBy":1,"replyTime":"2019-08-30T17:06:17.000Z","msg":"內文呢？"},{"pid":"7dc