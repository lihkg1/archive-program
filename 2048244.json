61974,"like":0,"dislike":0,"score":0,"quote":{"pid":"7985ebe63cdf1cc796093b570cd2e21abdca4742","tid":2048244,"uid":127331,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-02T16:05:04.000Z","msg":"你用邊隻洗鼻<br />\n用唔岩方法洗鼻有機會令炎症難好<br />\n專科呢個唔得就睇第2個啦<br />\n個個醫生都有唔同做法"},"citedBy":1,"replyTime":"2020-06-02T16:06:30.000Z","msg":"呢隻<br />\n<img src=\"https://www.clublike.com.hk/media/catalog/product/cache/225c4df3cbd4ddb6c21509056e5fe2f0/7/0/705928001008.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.clublike.com.hk%2Fmedia%2Fcatalog%2Fproduct%2Fcache%2F225c4df3cbd4ddb6c21509056e5fe2f0%2F7%2F0%2F705928001008.jpg&h=e2116148&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-06-02T16:15:15.000Z","msg":"我第一個醫生都係介紹呢款<br />\n開頭可以有instant relief 但好快又會塞返發炎<br />\n之後一路loop左年幾<br />\n後來轉左第二個醫生介紹我用另一個洗鼻方法同prescibe 左另外2支噴鼻藥 <br />\n第二日就立刻症狀已經減少左好多了lol<br />\n佢話要自己開粉個d 容易開得唔準(eg. 溫度, 水質, 水量) 反而容易加深症狀<br />\n之後佢介紹左另外一款唔駛自己開既鹽水來洗 (加埋藥)<br />\n佢就解釋個隻款用d咩hypertonic既原理來舒緩, 又唔駛自己開<br />\n我分享個人經驗啦<br />\n唔知你情況係咪我個情況咁<br />\n所以睇另一個醫生轉下方法或者有效家"},{"pid":"dcf776a7699724c921d909a11565a38e1d7f3fc9","tid":2048244,"uid":61974,"like":0,"dislike":0,"score":0,"quote":{"pid":"fc2254fb1324869f81bd018b78a352f3a11df601","tid":2048244,"uid":248116,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2020-06-02T16:12:56.000Z","msg":"要斷你睡房既致敏源<br />\n<br />\n被鋪有無大洗過，例如拎去洗衣鋪大洗<br />\n<br />\n枕頭有無成個換過<br />\n<br />\n床褥係咪你出世瞓到而家<br />\n<br />\n同埋瞓覺千祈唔好大動作打開張被<br />\n<br />\n屋企有空氣清新機就明<br />\n<br />\n你一楊開張被部機個度係會爆升"},"citedBy":1,"replyTime":"2020-06-02T16:15:20.000Z","msg":"我又唔似係鼻敏感，因為冇鼻塞流鼻水"},{"pid":"2705070d751186562e02515ef8d829d8dbc01b0b","tid":2048244,"uid":61974,"like":0,"dislike":0,"score":0,"quote":{"pid":"6309c7b11abe427c38afd6cac31f7a4dfff2cd23","tid":2048244,"uid":127331,"like":0,"dislike":0,"score":0,"quote":{"pid":"040cc4e4747279d791cef7a755ed0688176b5af9","tid":2048244,"uid":61974,"like":0,"dislike":0,"score":0,"quote":{"pid":"7985ebe63cdf1cc796093b570cd2e21abdca4742","tid":2048244,"uid":127331,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-02T16:05:04.000Z","msg":"你用邊隻洗鼻<br />\n用唔岩方法洗鼻有機會令炎症難好<br />\n專科呢個唔得就睇第2個啦<br />\n個個醫生都有唔同做法"},"citedBy":1,"replyTime":"2020-06-02T16:06:30.000Z","msg":"呢隻<br />\n<img src=\"https://www.clublike.com.hk/media/catalog/product/cache/225c4df3cbd4ddb6c21509056e5fe2f0/7/0/705928001008.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.clublike.com.hk%2Fmedia%2Fcatalog%2Fproduct%2Fcache%2F225c4df3cbd4ddb6c21509056e5fe2f0%2F7%2F0%2F705928001008.jpg&h=e2116148&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-06-02T16:15:15.000Z","msg":"我第一個醫生都係介紹呢款<br />\n開頭可以有instant relief 但好快又會塞返發炎<br />\n之後一路loop左年幾<br />\n後來轉左第二個醫生介紹我用另一個洗鼻方法同prescibe 左另外2支噴鼻藥 <br />\n第二日就立刻症狀已經減少左好多了lol<br />\n佢話要自己開粉個d 容易開得唔準(eg. 溫度, 水質, 水量) 反而容易加深症狀<br />\n之後佢介紹左另外一款唔駛自己開既鹽水來洗 (加埋藥)<br />\n佢就解釋個隻款用d咩hypertonic既原理來舒緩, 又唔駛自己開<br />\n我分享個人經驗啦<br />\n唔知你情況係咪我個情況咁<br />\n所以睇另一個醫生轉下方法或者有效家"},"citedBy":1,"replyTime":"2020-06-02T16:23:06.000Z","msg":"可唔可以講下佢介紹嗰款鹽水？<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n我呢年都買左唔少噴鼻產品，安鼻靈，鹽水噴劑，洗鼻啫喱...<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"451f27c71278c3a013ac6c91e8077ac0ec25c801","tid":2048244,"uid":238920,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-02T16:24:40.000Z","msg":"似係黏膜比較乾<br />\n半夜訓教打橫訓,如果有鼻水就會積係鼻腔入面<br />\n流唔到出黎就越黎越乾,越黎越濃,又呻唔出黎<br />\n沖沖鹽水就令鼻腔濕潤d,鼻水流返出黎就舒服返<br />\n鼻敏感係流到水喉咁,你唔似係<br />\n有冇半夜喉嚨痕咳到醒?飲啖水之後係咪好好多就訓得返?"},{"pid":"dea03d22797889ec21edd336409f17d3850f9443","tid":2048244,"uid":127331,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-02T16:29:17.000Z","msg":"<img src=\"https://na.cx/i/d33APwq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fd33APwq.jpg&h=4321ae8a&s={SIZE}\" /><br />\n我而家用緊呢款 <br />\n海豚呢隻鹽水好出名 可能你都試過<br />\n但呢隻係hypertonic 唔係isotonic (兩款都係海豚樣)<br />\nhypertonic 專for嚴重既<br />\n噴完個下要自己索到d鹽水入鼻先有效<br />\n每次噴6至8下<br />\n<br />\n不過都係個句 人人情況唔同 最好就係換另一個醫生睇<br />\nA醫生睇既問題同B醫生睇既問題又唔同<br />\n有時真係要trial and error"},{"pid":"87cc4688b44fb7ec9f2a762c92d7cbbe12835beb","tid":2048244,"uid":61974,"like":0,"dislike":0,"score":0,"quote":{"pid":"451f27c71278c3a013ac6c91e8077ac0ec25c801","tid":2048244,"uid":238920,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-02T16:24:40.000Z","msg":"似係黏膜比較乾<br />\n半夜訓教打橫訓,如果有鼻水就會積係鼻腔入面<br />\n流唔到出黎就越黎越乾,越黎越濃,又呻唔出黎<br />\n沖沖鹽水就令鼻腔濕潤d,鼻水流返出黎就舒服返<br />\n鼻敏感係流到水喉咁,你唔似係<br />\n有冇半夜喉嚨痕咳到醒?飲啖水之後係咪好好多就訓得返?"},"citedBy":1,"replyTime":"2020-06-02T16:29:19.000Z","msg":"冇喉嚨痕冇咳，但就經常痰上頸咁<br />\n初時都以為氣管有事，但睇過呼吸專科check過肺氣管冇事"},{"pid":"23bdaf97a865b3331261fcca60396535357b2683","tid":2048244,"uid":238920,"like":0,"dislike":0,"score":0,"quote":{"pid":"87cc4688b44fb7ec9f2a762c92d7cbbe12835beb","tid":2048244,"uid":61974,"like":0,"dislike":0,"score":0,"quote":{"pid":"451f27c71278c3a013ac6c91e8077ac0ec25c801","tid":2048244,"uid":238920,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-02T16:24:40.000Z","msg":"似係黏膜比較乾<br />\n半夜訓教打橫訓,如果有鼻水就會積係鼻腔入面<br />\n流唔到出黎就越黎越乾,越黎越濃,又呻唔出黎<br />\n沖沖鹽水就令鼻腔濕潤d,鼻水流返出黎就舒服返<br />\n鼻敏感係流到水喉咁,你唔似係<br />\n有冇半夜喉嚨痕咳到醒?飲啖水之後係咪好好多就訓得返?"},"citedBy":1,"replyTime":"2020-06-02T16:29:19.000Z","msg":"冇喉嚨痕冇咳，但就經常痰上頸咁<br />\n初時都以為氣管有事，但睇過呼吸專科check過肺氣管冇事"},"citedBy":1,"replyTime":"2020-06-02T16:31:58.000Z","msg":"喉嚨有野係度但又唔上唔落咳唔出咁?<br />\n洗鼻有冇睇到個鼻流左咩出黎?"},{"pid":"4eb651dc7ef4af2209eb00143168ebe85a516d5c","tid":2048244,"uid":61974,"like":0,"dislike":2,"score":-2,"quote":{"pid":"7ce7df4a9b9566eeffffc4f960abbcb88549d0fa","tid":2048244,"uid":215734,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2020-06-02T16:11:51.000Z","msg":"我鼻敏感食左益生菌之後好左好多<br />\niherb 幾十蚊就有 可以試下會唔會岩你<br />\n身體發炎魚油都有幫助"},"citedBy":0,"replyTime":"2020-06-02T16:32:39.000Z","msg":"我今日買咗薑黃素黎食，睇到話薑黃有抗炎功效，唔知有冇用<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"faf96e6917fb35cf7493b61b12f5722f13b24155","tid":2048244,"uid":61974,"like