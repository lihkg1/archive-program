c429e323132bc28fa","tid":2057944,"uid":82267,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2020-06-10T03:22:19.000Z","msg":"不嬲立法會都係冇用<br />\n班傻鳩黃絲希望越大失望越大"},{"pid":"83e7e8ed66be917edb4b6bad7522db275c9e5f94","tid":2057944,"uid":112581,"like":0,"dislike":0,"score":0,"quote":{"pid":"3f368486c2e64f7baa23092c429e323132bc28fa","tid":2057944,"uid":82267,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2020-06-10T03:22:19.000Z","msg":"不嬲立法會都係冇用<br />\n班傻鳩黃絲希望越大失望越大"},"citedBy":0,"replyTime":"2020-06-10T04:22:23.000Z","msg":"垃圾會唯一用處就喺送頭<br />\n選入去個班全部都喺被捕師<br />\n只要佢地全部比支共咬曬港豬先會開始正視自己一直都喺精神抗爭緊"},{"pid":"dc3993a566e4f796f4eba2f73b566f132bdda39d","tid":2057944,"uid":134342,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-10T04:39:54.000Z","msg":"否決權咪岩咯, 就係唔比政府設立惡法同亂咁用香港人既錢喎"},{"pid":"8b33dcb21dec9d83847abf5f97bc4415c94c6c93","tid":2057944,"uid":91771,"like":1,"dislike":0,"score":1,"quote":{"pid":"cd12d127968bc2c4804fac48adb8766369999caa","tid":2057944,"uid":96708,"like":0,"dislike":24,"score":-24,"quote":{"pid":"9c1d8da10573d43be4e5defdfd97173f3dfac17e","tid":2057944,"uid":264326,"like":19,"dislike":1,"score":18,"quote":{"pid":"6e62a455304858e34caef3d7d0f4a50df114fe99","tid":2057944,"uid":96708,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-06-09T18:40:33.000Z","msg":"你必須知道的立法會「立法權」<br />\n<br />\n（一）可以提案，不過不能涉及公共開支、政治體制或政府運作，否則提案要<span style=\"color: red;\">行政長官同意才可提出</span>（基本法74）<br />\n<br />\n（二）私人議案要分組點票通過<br />\n<br />\n（三）不論通過任何議案，<span style=\"color: red;\">人大常委都可以發回法律，並會立即失效</span>(基本法17）<br />\n<br />\n（四）不論通過任何議案，行政長官可以發還重審，需要三分二議員支持下再次通過（基本法49）。如果仍然獲得通過，<span style=\"color: red;\">行政長官可以解散立法會</span>（基本法50）<br />\n<br />\n（五）過半可以否決政府議案及財政預算案，但<span style=\"color: red;\">行政長官可以解散立法會重選</span>（基本法50）<br />\n<br />\n（六）四分一議員聯合動議可提彈劾案，成立調查委員會，要三分二議員通過，最後<span style=\"color: red;\">中央政府作最終決定</span>（基本法73）<br />\n<br />\n（七）人大可以對基本法釋法，或修改基本法（基本法158、159）<br />\n<br />\n結論：立法會沒有權拿到五大訴求的任何一項，過半的唯一作用是無限否決所有政府議案，達致攬炒，令社會無法運作<br />\n<br />\n#其實立法會係無立法權<br />\n#個啲叫否決權<br />\n#立法會101<br />\n<br />\nsource: <a href=\"https://www.vjmedia.com.hk/articles/2020/03/09/204569\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.vjmedia.com.hk%2Farticles%2F2020%2F03%2F09%2F204569&d=oKnYn5PLwsF01pzJS7XeliHfnck7qU2fF1mVfqY7ZMk%3D&h=cb8ebf3e\" target=\"_blank\">https://www.vjmedia.com.hk/articles/2020/03/09/204569</a><br />\n<br />\n投唔投，投邊個，自己諗，但唔好幻想35+之後改變到d乜<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2020-06-09T18:43:00.000Z","msg":"我就係想要個否決權，一開始提35+就係為呢樣野啊<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2020-06-09T18:44:21.000Z","msg":"否決權雖然有用，但都係唔會達到任何訴求<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-10T04:51:52.000Z","msg":"你無籌碼佢梗係睬你都有味<br />\n否決權應該係幾好嘅籌碼"}],"pinned":{"pid":"6b6df174f2dad27329f2f1658665544def7db9a8","tid":2057944,"uid":96708,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-06-09T19:12:55.000Z","msg":"都係要含淚投架喇，咪睇下會點<br />\n<br />\n但唔睇都唔知原來特首有咁大權姐<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}}