:3,"quote":{"pid":"3921baf04e6d49512556b87e01453131256224da","tid":575374,"uid":26451,"like":0,"dislike":0,"score":0,"quote":{"pid":"97b7e9013e1d3f4e01ba7b91ed6ddd73d411d575","tid":575374,"uid":106326,"like":1,"dislike":0,"score":1,"quote":{"pid":"adbefdf17cbf005461d7163a927769bbbc1e3aef","tid":575374,"uid":26451,"like":5,"dislike":0,"score":5,"citedBy":3,"replyTime":"2018-02-28T07:15:30.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-02-28T07:17:55.000Z","msg":"賺萬零人工個啲扣起晒啲雜費其實用得既鬆動錢真係差唔多"},"citedBy":2,"replyTime":"2018-02-28T07:19:27.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-02-28T07:32:09.000Z","msg":"其實好多消費係返工而產生出黎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n一日起碼早餐同午餐係返工而食<br />\n唔返工唔洗起身已經慳返早餐<br />\n日日過海返工一個月都成千蚊<br />\n返完工個人心理唔平衡又要搵方法治療自己，又係要洗錢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n如果個人毒的話其實留係屋企打機食老綜好過<br />\n然後出去秘撈打風流工，起碼做幾多出幾多， 即pay<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d4af04c4dc0fbcbe4cabb256a494f2a534ea0353","tid":575374,"uid":38262,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-02-28T07:40:16.000Z","msg":"重點<br />\n一家四口蝗<br />\n唔洗做就有錢，真正鬆動錢嚟<br />\n唔好覺得你搵萬幾萬多綜援好多<br />\n要記著你返份萬零蚊工係賣緊自己時間<br />\n仲要扣埋日常開支已冇鬆動錢<br />\n佢地唔做都唔會餓死<br />\n但你就捱足一世冇自由嘅<br />\n完~~~"},{"pid":"e6270ada2ba4e57e06519c2387cc5bf987a81397","tid":575374,"uid":20933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-28T08:03:58.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"2b68182e3beb7be27d06b3fb2139d4ff526efeab","tid":575374,"uid":26451,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-28T08:15:17.000Z","msg":"此回覆已被刪除"}]}