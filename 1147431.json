istory/%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B-%E4%BF%AE%E8%A8%82-%E6%AE%BA%E5%88%B0%E5%9F%8B%E8%BA%AB-%E6%B8%AF%E4%B9%9D%E6%96%B0%E7%95%8C%E7%84%A1%E5%BE%97%E9%81%BF-b516c57f30e1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmedium.com%2Fdecoding-hong-kongs-history%2F%25E9%2580%2583%25E7%258A%25AF%25E6%25A2%259D%25E4%25BE%258B-%25E4%25BF%25AE%25E8%25A8%2582-%25E6%25AE%25BA%25E5%2588%25B0%25E5%259F%258B%25E8%25BA%25AB-%25E6%25B8%25AF%25E4%25B9%259D%25E6%2596%25B0%25E7%2595%258C%25E7%2584%25A1%25E5%25BE%2597%25E9%2581%25BF-b516c57f30e1&d=7bK604G145JEtCxDEZ4NGspe%2FvQB%2B59L3xQItPRvby0%3D&h=1e000133\" data-auto-link target=\"_blank\">https://medium.com/decoding-hong-kongs-history/%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B-%E4%BF%AE%E8%A8%82-%E6%AE%BA%E5%88%B0%E5%9F%8B%E8%BA%AB-%E6%B8%AF%E4%B9%9D%E6%96%B0%E7%95%8C%E7%84%A1%E5%BE%97%E9%81%BF-b516c57f30e1</a><br />\n<br />\n（三）<br />\n讓惡法多睡一會<br />\n<a href=\"https://medium.com/@decodinghkshistory/%E8%AE%93%E6%83%A1%E6%B3%95%E5%A4%9A%E7%9D%A1%E4%B8%80%E6%9C%83-4a4c3d299e69\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmedium.com%2F%40decodinghkshistory%2F%25E8%25AE%2593%25E6%2583%25A1%25E6%25B3%2595%25E5%25A4%259A%25E7%259D%25A1%25E4%25B8%2580%25E6%259C%2583-4a4c3d299e69&d=7bK604G145JEtCxDEZ4NGspe%2FvQB%2B59L3xQItPRvby0%3D&h=5927760e\" data-auto-link target=\"_blank\">https://medium.com/@decodinghkshistory/%E8%AE%93%E6%83%A1%E6%B3%95%E5%A4%9A%E7%9D%A1%E4%B8%80%E6%9C%83-4a4c3d299e69</a>"},{"pid":"4f2aa5a4ee9edfca3000e608efb83e2e1fd1b944","tid":1147431,"uid":6799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-10T23:24:34.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8064fb202ce4e2d3a5e0cd9c50e7756a6e4b1cd1","tid":1147431,"uid":113373,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-10T23:35:01.000Z","msg":"<strong><span style=\"color: red;\"><span style=\"font-size: xx-large;\">香港人要行出嚟啦</span></span></strong>"},{"pid":"36145a3cca633a91ba