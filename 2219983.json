s://na.cx/i/gm3aD6u.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fgm3aD6u.jpg&h=2956076b&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-09-27T10:38:26.000Z","msg":"多謝巴打俾credit<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"3273ab08e7e92357cb7c5005a38d812f5f32c325","tid":2219983,"uid":195136,"like":1,"dislike":0,"score":1,"quote":{"pid":"9a7c703e1d9f6a5e1c1acf2020e55276cc9eafec","tid":2219983,"uid":51346,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-27T09:38:25.000Z","msg":"夢遺完up住成晚都會對jj唔好<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" /><br />\n<br />\n女士每個月用m巾最多咪10日<br />\n<br />\n但男士每次瞓覺都有機會夢遺 <img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /><br />\n<br />\n瞓晏覺一次 夜晚一次 再乘30日 即係60次<br />\n<br />\n根本商機無限<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />  <br />\n<br />\n唔好同我講打得多飛機就唔會夢遺 <br />\n<br />\n想像力豐富根本打幾多飛機都會發春夢<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /><br />\n<br />\n唔通真係要用m巾頂住<img src=\"/assets/faces/lm2/oh.gif\" class=\"hkgmoji\" /> 不過相信好多巴絲同我一樣身懷巨龍 著住m巾瞓會好焗促<br />\n<br />\n應該得安睡褲比較適合<br />\n<br />\n<img src=\"https://na.cx/i/qnaz5mO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fqnaz5mO.jpg&h=aafae5db&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n好入正題 <br />\n以上講嘅都係治標唔治本<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><br />\n<br />\n所以我發明咗呢樣嘢幫各位巴絲<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/uKoBzfz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuKoBzfz.jpg&h=46567488&s={SIZE}\" /><br />\n<br />\n好似個名講咁 用咗佢就唔會再夢遺<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n用家示意圖：<br />\n<br />\n<img src=\"https://na.cx/i/4nbO9Pp.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4nbO9Pp.jpg&h=d8eccf33&s={SIZE}\" /><br />\n<br />\n紅色帶固定雙腳 黃色杯左右再有支架固定住用家同張床<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/25FMb3O.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F25FMb3O.jpg&h=f5c1d41e&s={SIZE}\" /><br />\n紅色路線為夢遺後精液嘅走向<br />\n<br />\n射出嚟之後會撞頂 然後順住流線型嘅杯身流返入龜頭 <br />\n（杯身已搽滿消炎藥 防止精液倒流引起發炎）<br />\n<br />\n用耐咗之後 精液多次嘅彈出彈入相信會引發身體嘅學習機能 發春夢都唔會再射精<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /><br />\n再加埋上個post講嘅精子進化論 喺出面見過世面嘅精子 衣錦還鄉之後會同初出茅蘆嘅後生精分享經驗 就算再夢遺都會q手起人牆 唔出精 <br />\n費事白行一趟<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><br />\n<br />\n不過都要keep住打丁 唔係我怕會爆袋而死<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-09-27T10:38:30.000Z","msg":"一劑斷尾<br />\n一剪搞掂<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"3f1a862b3230dc3ddb7db4c2e91944c473d7d6e8","tid":2219983,"uid":367090,"like":5,"dislike":0,"score":5,"quote":{"pid":"97ce35cc66539e24f0b30c158150dcfd85646f64","tid":2219983,"uid":51346,"like":5,"dislike":0,"score":5,"quote":{"pid":"454c464ac430cf9269fe29b8d9ebb5d1652a211c","tid":2219983,"uid":367090,"like":4,"dislike":0,"score":4,"quote":{"pid":"e2d27ef0cf070db0ccf9dddb78105d35be831604","tid":2219983,"uid":51346,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-09-27T10:33:12.000Z","msg":"我瞓覺成日轉身 你條丁仲健在嗎<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-09-27T10:37:26.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-09-27T10:38:00.000Z","msg":"進來吧<img src=\"/assets/faces/lomoji/37.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-27T10:39:55.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"fb8d53e5cbee72fa6d53e3