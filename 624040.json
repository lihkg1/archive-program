%2582%25B5%25E3%2582%25A6%25E3%2583%25B3%25E3%2583%2589%25E3%2583%2588%25E3%2583%25A9%25E3%2583%2583%25E3%2582%25AF%2BSide%2BB&d=%2FR2c0YqBzdZlJdC6XAdWm8VakpCEQgWe3bOYm8oES40%3D&h=ce178d2f\" data-auto-link target=\"_blank\">https://www.amazon.co.jp/%E9%BE%8D%E3%81%8C%E5%A6%82%E3%81%8F0-%E8%AA%93%E3%81%84%E3%81%AE%E5%A0%B4%E6%89%80-%E3%82%AA%E3%83%AA%E3%82%B8%E3%83%8A%E3%83%AB%E3%82%B5%E3%82%A6%E3%83%B3%E3%83%89%E3%83%88%E3%83%A9%E3%83%83%E3%82%AF-Side-B/dp/B00UB64E4Q/ref=sr_1_1?s=dmusic&amp;ie=UTF8&amp;qid=1523364489&amp;sr=1-1-mp3-albums-bar-strip-0&amp;keywords=%E9%BE%8D%E3%81%8C%E5%A6%82%E3%81%8F0+%E8%AA%93%E3%81%84%E3%81%AE%E5%A0%B4%E6%89%80+%E3%82%AA%E3%83%AA%E3%82%B8%E3%83%8A%E3%83%AB%E3%82%B5%E3%82%A6%E3%83%B3%E3%83%89%E3%83%88%E3%83%A9%E3%83%83%E3%82%AF+Side+B</a><br />\n<br />\nOTOTOY有無損格式(接受海外信用卡但要申請帳號)<br />\n<a href=\"https://ototoy.jp/_/default/p/50041\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fototoy.jp%2F_%2Fdefault%2Fp%2F50041&d=%2FR2c0YqBzdZlJdC6XAdWm8VakpCEQgWe3bOYm8oES40%3D&h=b0890ee0\" data-auto-link target=\"_blank\">https://ototoy.jp/_/default/p/50041</a><br />\n<a href=\"https://ototoy.jp/_/default/p/50042\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fototoy.jp%2F_%2Fdefault%2Fp%2F50042&d=%2FR2c0YqBzdZlJdC6XAdWm8VakpCEQgWe3bOYm8oES40%3D&h=fa107994\" data-auto-link target=\"_blank\">https://ototoy.jp/_/default/p/50042</a>"},{"pid":"89eac5ee0a797b49a210336e89bbf0a7f3fa3599","tid":624040,"uid":28974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-10T13:01:23.000Z","msg":"<strong><ins><span style=\"font-size: x-large;\"><span style=\"color: green;\">人中之龍 極2 前集背景重溫</span></span></ins></strong><br />\n<br />\n<br />\n<br />\n雖然人中之龍<span style=\"font-size: x-large;\"><span style=\"color: red;\">0 &rarr; 極 &rarr; 極2</span></span>咁順住玩落去既話會好好多。但未玩過前作既話都值得入手，故事都只係成個系列既其中一章<br />\n<br />\n<br />\n人龍0 以及人龍極 除左真島既轉變令人深刻之外，桐生失去錦山、由美 兩位一齊長大既「家人」既悲慘經歷都好唏噓。<br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=JJBqg5bavbk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DJJBqg5bavbk&d=%2FR2c0YqBzdZlJdC6XAdWm8VakpCEQgWe3bOYm8oES40%3D&h=1b5b4181\" target=\"_blank\">https://www.youtube.com/watch?v=JJBqg5bavbk</a><br />\n<br />\n<br />\n雖然錦山既黑化可以理解，佢前半生有兩個最重要既人&mdash;&mdash; 桐生一馬,佢自己個妹，<br />\n桐生因為知道佢個妹對錦山好重要而幫佢坐左十年監，導致係錦山最難捱既日子桐生不在佢身邊，<br />\n一直視桐身做奮鬥目標既錦山不斷受同組既人溪落，一直抑壓住對桐生既仰慕變成妒忌,開始思考自己，直至佢比庸醫厄走一大敗醫療費導致佢個妹死亡<br />\n佢終於決心徹底改變 做一番大事<br />\n<br />\n但我由此至終都相信錦山確實曾經當過桐生係兄弟， <br />\n桐生十年冤獄 未黑化既錦山雖然無去探過一次監 我諗只係錦山內心既唔肯面對自己既懦弱，就同佢有勇氣殺堂島宗兵但無勇氣承擔一樣。<br />\n但可惜最終錦山敵不過妒忌心，以怨報德<br />\n<br />\n<br />\n<br />\n冇玩過以前集數 可以睇睇<br />\n<a href=\"https://www.youtube.com/watch?v=cN-ua43SxSw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DcN-ua43SxSw&d=%2FR2c0YqBzdZlJdC6XAdWm8VakpCEQgWe3bOYm8oES40%3D&h=a6c7dae1\" target=\"_blank\">https://www.youtube.com/watch?v=cN-ua43SxSw</a> <br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<strong><ins><span style=\"font-size: x-large;\"><div style=\"text-align: center;\"><span style=\"color: teal;\">遊戲元素:</span></div></span></ins></strong><br />\n<br />\n風化島回歸 (悅子回歸) <br />\n另外官方確認風化島參與既女優包括 明日花綺羅、AIKA、高橋聖子、桃乃木香奈、三上悠亞。<br />\n<br />\n<img src=\"https://i.imgur.com/fwEXGZs.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FfwEXGZs.jpg&h=fae7ec08&s={SIZE}\" /><br />\n<br />\n<img src=\"https://i.imgur.com/NJ7rGAt.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FNJ7rGAt.jpg&h=cc9d1a3a&s={SIZE}\" /><br />\n<br />\n<br />\n戰鬥系統回復人中之龍0多元化 + 爽快 + 多種武器極，配合6代無逢戰鬥引擎既優點結合，流暢度十分高。<br />\n小遊戲方面:<br />\n<br />\nVirtual On, 象棋, 北風太陽, 噴奶, 龍友攝影棚, AV果堆野 etc<br />\n<img src=\"http://rs3.sinahk.net/cap/3/2017/11/24/3/33d74e4f6782e58e69570d85b6fa281f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Frs3.sinahk.net%2Fcap%2F3%2F2017%2F11%2F24%2F3%2F33d74e4f6782e58e69570d85b6fa281f.jpg&h=4ebaf9d6&s={SIZE}\" /><img src=\"http://rs3.sinahk.net/cap/3/2017/11/24/e/ebe919ca51ab4b01ed68356c7af2f73d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Frs3.sinahk.net%2Fcap%2F3%2F2017%2F11%2F24%2Fe%2Febe919ca51ab4b01ed68356c7af2f73d.jpg&h=c521b54e&s={SIZE}\" /><img src=\"http://rs3.sinahk.net/cap/3/2017/11/24/4/4e5a8a400a4cdba6aa1a5b8beae2ce87.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Frs3.sinahk.net%2Fcap%2F3%2F2017%2F11%2F24%2F4%2F4e5a8a400a4cdba6aa1a5b8beae2ce87.jpg&h=bcacb16c&s={SIZE}\" /><img src=\"http://rs3.sinahk.net/cap/3/2017/11/24/b/baebde525788f333a327e249b3e9178f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Frs3.sinahk.net%2Fcap%2F3%2F2017%2F11%2F24%2Fb%2Fbaebde525788f333a327e249b3e9178f.jpg&h=a81585a8&s={SIZE}\" /><br />\n<br />\n<img src=\"https://p2.bahamut.com.tw/B/2KU/41/0900604c4422262e3584c02429bz6gt4.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fp2.bahamut.com.tw%2FB%2F2KU%2F41%2F0900604c4422262e3584c02429bz6gt4.JPG&h=c57de736&s={SIZE}\" /><img src=\"https://p2.bahamut.com.tw/M/2KU/42/6d3ffecdc42d9a0161f03e58f00z6gu4.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fp2.bahamut.com.tw%2FM%2F2KU%2F42%2F6d3ffecdc42d9a0161f03e58f00z6gu4.JPG&h=29b83bb2&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n痾尿game 點玩先贏到? [只供參考]<br />\n<br />\n( 人中之龍本命 提供)<br />\n柯尿果個終於解哂三個難度 其實好易玩 控制好條bar同佢<br />\n大約係開始玩之前買水飲 飲兩支水就得 姐係1200 咁你儲覺醒技速度就會快好多 相反你飲太多水 3000 pt去玩 你就會變左持久戰 姐係你輸既機會會大左 除非你好勁 可以勁長時間keep住同電腦條bar控制個度數一樣 唔係唔建議咁玩 姐係話隻game飲愈少水就愈易贏 當然唔可以就咁一支 因為就咁飲一支 會唔夠時間比你儲覺醒<br />\n<br />\n另外睇女人果個mode 就飲愈多水就愈易贏 <br />\n<br />\n飲夠5支礦泉水 就full 姐係3000 pt 咁就有好足夠時間比你吹起佢條裙<br />\n<br />\n簡單建議<br />\n女人mode 飲夠3000pt 就ok <br />\n另1個 飲到2100pt (由頭到尾一直按 唔洗放手)3個難度都可以贏<br />\n茶 ( 1支500ml 1支280ml )<br />\n<br />\n----------------------------------------------------------------------------------------------------<br />\n哥爾夫球9格 (打哂9格會有 球桿揮擊技能書)<br />\n一閞始我建議打 7 8 9 號 大約力度50 <br />\n之後會轉位置 想打1 2 4號 大約力度95-100(留意風向)<br />\n3 5 6 我自己憑感覺經驗打<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> (留意風向)<br />\n<br />\n高級好難入 / 信天翁支線任務[要過290分] ( TheProphet 巴打提供 )<br />\n<br />\n1/10 <span style=\"color: orange;\">方向稍微右</span> 力道90-95 黃條最中間<br />\n2/10 <span style=\"color: orange;\">方向稍微右</span> 力道50-55 黃條中間或偏右<br />\n3/10 方向稍微右側移動與綿羊前腿吻合即可 力道45左右 黃條最中間<br />\n4/10 方向不變 力道95-100 黃條最中間<br />\n5/10 <span style=\"color: orange;\">方向右側綿陽的後腿偏右 力道100 黃條最中間 (要打落牆彈番轉頭) </span><br />\n6/10 方向上方黃色星球球體右側邊緣 力道50 黃條中間紅色部位的右側<br />\n7/10 方向不變 力道60-70 黃條最中間<br />\n8/10 <span style=\"color: orange;\">方向不變或稍稍偏左 力道100 黃條最中間 (要打落牆彈番轉頭) </span><br />\n<br />\n9/10 方向最下面UFO底部的圓形左側 力道55 黃條中間紅色部位最右側或再偏右<br />\n10/10 方向左側綿陽腳底下綠色草的最左側草 力道60-70 黃條最中間<br />\n<br />\n完成支線有 信天翁球桿 攻72<br />\n中級 高級 打到有400分會有球桿武器(喜歡儲武器可以再打)<br />\n<br />\n---------------------------------------------------------------------------------------------------<br />\n麻雀支線好難搞<br />\n唔識打嘅話可以用道具 (無雙牌) 或 搵屋企人幫手<br />\n唔用道具可以弱桌慢慢玩慢慢自學<br />\n<br />\n<br />\n門前清（唔碰唔上）<br />\n斷么九 （冇1同9 牌）<br />\n平胡 （一對眼 + 4對順子 123 234 345）<br />\n<br />\n報聽(有1番) 要門前清先叫到 牌型要唔計報聽要有 1番 (唔計報聽） <br />\n報聽要按正方掣<br />\n<br />\n報聽後首圈有人打出你食糊就叫一發(有1番) 如果自摸了又多1番(門清自摸)<br />\n<br />\n如果叫糊要既牌之前有打出就唔可以食人打出 要自摸 (叫做振聽） <br />\n解決方法 自摸or 改變牌型就冇事<br />\n<br />\n到懸賞牌又有1-3番 （冇人開槓既話）<br />\n最簡單碰懸賞牌有3番<br />\n<br />\n(Fireball!巴打提供)<br />\n<span style=\"color: orange;\">無雙牌位置喺蒼天崛賭場3/F，神室町麻雀館3/F office，同古牧修行4任務報酬。<br />\n每1個周目會有3隻</span><br />\n<br />\n有巴打證實 無雙牌 喺冇使用情況下轉下周目會消失<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <span style=\"color: orange;\">(不能繼承下周目)</span><br />\n建議使用於 支線 同 2個大賽 (大賽都可以用)<br />\n強中弱桌慢慢自打牌 (食糊 10次 20次 30次)<br />\n<br />\n<br />\n<br />\n棒球點玩咖? ( 麥記老母會 提供 )<br />\n如果冇信心打既話安心球棒,易打好多   <br />\n打完計分 安心0.7 普通1.0 高手1.5<br />\n<br />\n呢個係全壘打挑戰既打法  (挑戰賽程)<br />\n初1------ 5 9 1 7 3 4 6 5      <br />\n<br />\n初2------ 9 4 3 7 6 8 2 7 1 9<br />\n<br />\n初3------ 9 7 9 6 4 8 7 9 7 6<br />\n<br />\n<br />\n中1------ 6 8 5 9 1 7 9 7<br />\n<br />\n中2 ------ 6 4 8 8 5 9 7 3 1<br />\n<br />\n中3 ------ 5 8 6 7 4 9 2 8 7 6<br />\n<br />\n<br />\n高1 ------ 6 6 7 9 1 3 9 9 4 7<br />\n<br />\n高2 ------ 6 1 8 7 9 4 6 8 3 7<br />\n<br />\n向上彈跳 美國夢 向下 向右下飄 平飛<br />\n向右 向左飄 向左下飄 向右 向下 <br />\n<br />\n美國夢 向下 向右下飄 平飛 向左下飄 向左<br />\n向右 美國夢 向下 美國夢 <br />\n<br />\n向左 直 平飛 向右 美國夢 向左 直 向上彈跳 <br />\n向左 美國夢<br />\n<br />\n最尾就會隨機抽尾個三個係咁重覆<br />\n就咁就打可以打到30 sets"},{"pid":"b5f1f9161a804c88b71ff0e7c729e0178d2b7d41","tid":624040,"uid":28974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-10T13:01:39.000Z","msg":"神室町置物櫃鑰匙最齊 ( 好似係 )<br />\n殘體注意<a href=\"https://img.eservice-hk.net/upload/2017/12/25/194744_bd5d7ebab49a4722cc04753049c2df09.jpg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F25%2F194744_bd5d7ebab49a4722cc04753049c2df09.jpg&d=%2FR2c0YqBzdZlJdC6XAdWm8VakpCEQgWe3bOYm8oES40%3D&h=d29f8a3e\" target=\"_blank\">https://img.eservice-hk.net/upload/2017/12/25/194744_bd5d7ebab49a4722cc04753049c2df09.jpg</a><br />\n<br />\n<blockquote><img src=\"https://img.eservice-hk.net/upload/2017/12/12/222238_ac63b1ea7c99222d14f6917a66d5d6eb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F12%2F222238_ac63b1ea7c99222d14f6917a66d5d6eb.jpg&h=ceaec5a7&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/12/12/222240_1ab6cd36cdb9d985066cb64c337721a1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F12%2F222240_1ab6cd36cdb9d985066cb64c337721a1.jpg&h=602c47f3&s={SIZE}\" /></blockquote><br />\n蒼天崛J4 要做支線任務 復仇代理人 完成獎勵<br />\n神室町C1 要做支線任務 用簡訊談工作會出現<br />\n<br />\n<br />\n18名徘徊頭目<br />\n<br />\n打哂18個有三重墊步技能書<br />\n墊步技能書<br />\n<img src=\"http://upload.lsforum.net/users/public/v6807345234533524m128.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fupload.lsforum.net%2Fusers%2Fpublic%2Fv6807345234533524m128.jpg&h=b237f790&s={SIZE}\" /><br />\n<img src=\"http://upload.lsforum.net/users/public/w2859615134866_936q128.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fupload.lsforum.net%2Fusers%2Fpublic%2Fw2859615134866_936q128.jpg&h=fd432557&s={SIZE}\" /><br />\n神戶町：<br />\n<br />\n<br />\n徘徊頭目1共有18個 神室町同蒼天崛各9個<br />\n<br />\n1.猛者登場 劇情觸發<br />\n2.猛者（續）：小混混<br />\n3.偷襲：小混混<br />\n4.麻煩人物：流氓<br />\n5.不良幫派份子：不良幫派份子<br />\n6.新時代黑道：流氓<br />\n7.便利商店獵人：不良幫派份子<br />\n8.致堂島之龍 地點限定：<span style=\"color: orange;\">甲魚大街 / 天下一番大街 流氓</span>  出現短迅條友喺甲魚大街出現<br />\n9.武士 地點限定：劇場前廣場 不良幫派份子<br />\n<br />\n蒼天堀：<br />\n<br />\n1.熱愛幹架 不良幫派份子或者小混混<br />\n2.試試身手 不良幫派份子<br />\n3.刺客 流氓 觸發條件是招福町卡拉ok館門口小混混變成流氓，打完就出<br />\n4.破壞者 不良幫派份子或者小混混<br />\n5.武器獵人 小混混<br />\n6.強者 不良幫派份子或者小混混<br />\n7.在嚴橋 小混混 觸發條件是嚴橋不良幫派份子變成小混混，打完就出<br />\n8.血花 時間限定 夜間 暢快管附近小混混<br />\n9.金色的 地點限定 蒼天堀大街西側 流氓<br />\n<br />\n<span style=\"color: orange;\">有時會出現打極都打唔到 轉1下地方可能會有 <br />\n打多啲種類 小混混  流氓  不良幫派份子</span>"},{"pid":"f624c404d606841eed544b4c73264a437cde304e","tid":624040,"uid":28974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-10T13:02:14.000Z","msg":"Q1: 主線有幾多章?<br />\nA2: 桐生16章真島3章<br />\n<br />\nQ2: <span style=\"color: orange;\">風化島</span>第幾章幾有? <br />\nA2: 第4章主線會迫你玩1場   <br />\n最好主線到第6章可以1次過玩哂風化島主線<br />\n<br />\nQ3: 我好想用<span style=\"color: orange;\">悅子</span>黎玩第幾章有? ( pedro_7提供)<br />\nA3: 第11章支線喺招福町南側(大嬸的悲劇) 完成獎勵 悅子加入  喺forshine 旁邊對話加入<br />\n(能力唔錯) (好似第5章) <span style=\"color: orange;\">園長</span>喺神室町中道大街 昭和大街交界 做3次支線任務 喺同1個位搵佢加入風化島<br />\n<br />\nQ4: 想做<span style=\"color: orange;\">龍友</span>第幾章會有?<br />\nA4: 第5章 神室町 公園前大街東側( 以前0,極 桌球酒吧 或 地圖右上角)<br />\n同男人對話就可以入去&quot;攝影&quot;<br />\n<br />\nQ5: <span style=\"color: orange;\">針炙</span>係邊到?<br />\nA5: 喺蒼天崛招福町南側 有3個門 icon 最上嗰個就係 中間係葵 最下係forshine (風化島)<br />\n<br />\nQ6: 我想<span style=\"color: orange;\">賣走道具</span>可以邊到賣<br />\nA6: 歷代都係 惠比壽屋<br />\n<br />\nQ7: 點解我買咗啲<span style=\"color: orange;\">武器用唔到</span><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><br />\nA7: 要去<span style=\"color: orange;\">&quot;WORK上山&quot;</span>武器商買CD <span style=\"color: orange;\">再去 FUSION(神室町) 或 乾陀羅(蒼天崛)</span> 睇1次就可以學招( 睇咗之後要用能力值學 )<br />\n神室町 天下一番大街後巷 (第三公園旁邊)<br />\n乾陀羅 招福町南側 (地圖底部中間)<br />\n<br />\nQ8: 想問維修武器喺邊到<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><br />\nA8: 要去 WORK上山 先有得維修<br />\n<br />\nQ9: 我好想出<span style=\"color: orange;\">虎落</span>打人好爽<img src=\"/assets/faces/xm/tongue.gif\" class=\"hkgmoji\" /> 唔知幾時有得學?<br />\nA9: 要過12章之後再去蒼天崛搵針灸院 畀錢就有得學<br />\n<br />\nQ10: 支線 鬥技場 搵 河內元匠  <br />\nA10: 河內元匠係&quot;柔術&quot; 打之前有冇 打到柔術可能未必係佢 打多幾次就有<br />\n<br />\nQ11: 我做哂所以有支線任務 點解都仲有幾個???<br />\nA11: 有1個係棒球，哥爾夫(完成中級要有300分)，4個阿門支線(七福大街停車場 瑟蕾娜後巷 劇場前劇場 千禧塔地下(亞門丈)<br />\n最底係完成所有支線任務<br />\n<br />\n<span style=\"color: orange;\">Q12: 想問下周目再玩會唔會唔見嘢?  <br />\nA12: 全支線都會化為0/76 (重新做) <br />\n無雙牌(唔識麻雀巴打們小心啲) <br />\n儲物櫃可以再攞  <br />\n風化島主線 真島建設主線 都要重做(啲人能力等級唔會會回1 LV ) </span><br />\n<br />\n<span style=\"color: orange;\">Q13: 鬥技場尾2同最尾嗰個點樣解鎖?<br />\n A13: 尾2完成真島建設主線就會出現<br />\n最尾係要打敗阿門丈之後會閞</span><br />\n<br />\n花牌好難玩點搞? (Fireball! 巴打提供)<br />\ngoogle 日本花牌( 花札 )，aim住月見酒，花見酒，三光，四光，五光，呢啲高分組合，中一次就應該搞掂。<br />\n<br />\n一些隱藏武器、防具或技能的開放條件 (轉貼巴哈) <br />\n( 去惠比壽屋買300萬的劍 賣畀上山為30萬 )<br />\n<br />\n1、 武器(要賣武器或防具給上山)<br />\n<br />\n(一)  累積金額1萬元以上<br />\n1.   ダブルスパイカー<br />\n2.   幻のトンファー<br />\n<br />\n(二)  累積金額10萬元以上<br />\n古牧家伝火縄銃<br />\n<br />\n(三)  累積金額90萬元以上<br />\n1.   髑髏のトンファー<br />\n2.   双龍のバチ<br />\n<br />\n(四)  累積金額140萬元以上<br />\n裏輸入・改造トンファー(走私拐棍 攻88 次數&infin;  有火效果 注意會燒死自己)<br />\n<br />\n(五)  累積金額200萬元以上<br />\n御禁制・毒塗り小太刀  (斬人有暈既效果 幾好用)<br />\n<br />\n(六)  累積金額300萬元以上<br />\nフォトンブレードW  (雙棍光劍版 攻速比光劍慢 唔太好用)<br />\n<br />\n(七)  累積金額500萬元以上<br />\n昏睡銃 (槍)<br />\n<br />\n<br />\n2、防具(要賣武器或防具給上山)<br />\n<br />\n(一)  累積金額5萬元以上<br />\n1.   古牧流グローブ<br />\n2.   上山謹製マウスガード<br />\n<br />\n(二)  累積金額20萬元以上<br />\n1.   古牧流インソール<br />\n2.   上山謹製インソール<br />\n<br />\n(三)  累積金額90萬元以上<br />\n1.     古牧流道衣<br />\n2.     上山謹製防護ベスト<br />\n3.     侠のサラシ<br />\n<br />\n<br />\n3、   熱血技<br />\n1.   バットスイングの極み&rarr;打擊中心拿到2000點以上就能兌換奧義書<br />\n2.   ゴルフスイングの極み&rarr;高爾夫中心賓果挑戰8個賓果都進<br />\n3.   ボウルの極み&rarr;遙的要求達到SS<br />\n4.   究極の極み&rarr;打倒亞門丈(通過除了亞門丈以外的所有支線任務)<br />\n <br />\n4、技能(以下技能都要限界突破後才能出現)<br />\n1.   強チャージ攻撃・極&rarr;稱霸地下鬥技場所有比賽<br />\n2.   三重墊步&rarr;擊敗全部的徘迴頭目<br />\n3.   武器大師&rarr;打倒亞門丈以後，可以向上山購買，一個999萬<br />\n  <br />\n4.   鬥神的精髓&rarr;通過所有保鑣任務(包括各難度) (按下掣串人加熱血最大值)<br />\n      仲有把火劍<img src=\"/assets/faces/xm/slick.gif\" class=\"hkgmoji\" /><br />\n保鑣任務完成獎勵的裝備有啲可以組合 有加承 (好似仁王咁)<br />\n<br />\n【心得】人中之龍 極2 裝備獎勵篇 (全26種更新完畢) 轉貼巴哈<br />\n<a href=\"https://forum.gamer.com.tw/C.php?bsn=8805&amp;snA=12756&amp;tnum=2&amp;subbsn=21\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforum.gamer.com.tw%2FC.php%3Fbsn%3D8805%26snA%3D12756%26tnum%3D2%26subbsn%3D21&d=%2FR2c0YqBzdZlJdC6XAdWm8VakpCEQgWe3bOYm8oES40%3D&h=9b686776\" target=\"_blank\">https://forum.gamer.com.tw/C.php?bsn=8805&amp;snA=12756&amp;tnum=2&amp;subbsn=21</a>"},{"pid":"0ba2b81ecbd37b471d5823ca949e4e2efac28389","tid":624040,"uid":4523,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-10T13:51:36.000Z","msg":"仲有新post<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n留個名<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"17449bfeff25edaed85e2735d1e0d6ad99d2cfd5","tid":624040,"uid":28974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-10T16:01:08.000Z","msg":"吹水都得<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"44b2510eb9d2bf111e0f25338bdda2008a5ba06d","tid":624040,"uid":42571,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-04-11T00:42:48.000Z","msg":"新手無玩過人中 只想玩一章 邊隻好？"},{"pid":"22f52077f1ce9663dc6c51e6741cc9d996b83455","tid":624040,"uid":6078,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-11T03:02:39.000Z","msg":"竟然有新post<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmo