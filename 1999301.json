9a5c819674b6101e","tid":1999301,"uid":6864,"like":1,"dislike":0,"score":1,"quote":{"pid":"b9125e74b0ca187b18b6619d9d11e0a69e5ebf10","tid":1999301,"uid":162567,"like":4,"dislike":1,"score":3,"quote":{"pid":"54ad9f44fc40d3cdf5c67a51539ff6c163e5791f","tid":1999301,"uid":254745,"like":7,"dislike":0,"score":7,"citedBy":2,"replyTime":"2020-05-03T05:38:20.000Z","msg":"臨死前賣左層樓<br />\n預返啲錢用黎租樓+環遊世界"},"citedBy":3,"replyTime":"2020-05-03T05:46:47.000Z","msg":"點知自己幾時死?"},"citedBy":0,"replyTime":"2020-05-03T06:22:56.000Z","msg":"好似有逆按揭，等於擺低層樓同按揭公司賭命"},{"pid":"8dfd9ee5d7f7d2535c65527349123312bf109c35","tid":1999301,"uid":19454,"like":0,"dislike":0,"score":0,"quote":{"pid":"2af3bfe03e379a2745de0b1b0611cbd60772de0c","tid":1999301,"uid":173272,"like":0,"dislike":0,"score":0,"quote":{"pid":"b2c640ef3466f7eaec9f25cfea21fabdd70e8a08","tid":1999301,"uid":173272,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-03T06:03:27.000Z","msg":"逆回購"},"citedBy":1,"replyTime":"2020-05-03T06:04:45.000Z","msg":"sorry, 逆按揭"},"citedBy":2,"replyTime":"2020-05-03T08:20:36.000Z","msg":"<a href=\"https://www.moneyhero.com.hk/blog/zh/逆按揭的遊戲規則\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.moneyhero.com.hk%2Fblog%2Fzh%2F%E9%80%86%E6%8C%89%E6%8F%AD%E7%9A%84%E9%81%8A%E6%88%B2%E8%A6%8F%E5%89%87&d=5G%2Bx0n%2BFJXS0hP%2BJIuhjgl8MSy0xNzs2bKpftArA8vk%3D&h=20656c6d\" data-auto-link target=\"_blank\">https://www.moneyhero.com.hk/blog/zh/逆按揭的遊戲規則</a><br />\n<br />\n唔好以為將層樓按比銀行就大晒，唔駛比息，其實唔係，係需要比息，仲唔平添；由於「逆按揭」貸款利息係用總結欠嘅年利率P-2.5厘，同埋按月用複息計算，不過，因為借款人，即係長者在生時係唔駛還錢，所以利息計算就會變成「利疊利」咁加上去，咁就即係增加咗你嘅債務，又暗示長者可以留比下一代嘅資產變少咗，甚至當層樓不足以抵銷債務嘅時候，到時可能需要由子女承擔。<br />\n<br />\n<br />\n<br />\n當然，如果「老友記」膝下無子嘅話，咁呢個問題就變咗唔係問題啦。<br />\n<br />\n仲有最後一樣嘢就係，其實借錢都要俾「成本」，有無聽過人哋話借10萬，但到手時可能只得8萬？呢啲所謂嘅「成本」，包括評估費、顧問費、律師費同其他雜費等；若然借款少但年期長，咁呢啲「成本」就可以攤分嚟俾，變相減低「成本」開支；但如果借款多但年期短嘅話，分分鐘「借10萬，實收5萬」，被人cut 咁一半添。"},{"pid":"1b4a844678b03023851e02e6d452c364afe8a3e8","tid":1999301,"uid":155949,"like":1,"dislike":0,"score":1,"quote":{"pid":"d929a6