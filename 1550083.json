=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6d0bd4cfda93b1f214e35a0fe8176f0e9c342f29","tid":1550083,"uid":117906,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T14:24:43.000Z","msg":"[警世][最終文宣] 喚醒對中共既不信任 聯合世界圍堵#Chinazi<br />\n<a href=\"https://lih.kg/1548891\" data-auto-link target=\"_blank\">https://lih.kg/1548891</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<img src=\"https://na.cx/i/3E7OjKb.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3E7OjKb.gif&h=66b4ea40&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/uZFWW8o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuZFWW8o.jpg&h=4196affc&s={SIZE}\" />"},{"pid":"648c9862548f6e2c148839017c1f910e7066915e","tid":1550083,"uid":9411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T14:25:16.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"6e485ada2c6847238f83cb222869e5608680ee2e","tid":1550083,"uid":123991,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T14:25:24.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><div style=\"text-align: center;\">出黎呀，自由閪！</div></strong></span><br />\n<span style=\"color: red;\"><br />\n<span style=\"font-size: xx-large;\"><strong>不闖入、不塗鴉、不鐳射</strong></span></span><br />\n如有發現，批淮大家往死裡打 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"color: red;\">明日之公眾集會(遮打花園)及公眾遊行(前往美領)已獲發不反對通知書。</span></strong><br />\n<br />\n集會部分<br />\n地點：中環遮打花園<br />\n時間：13:30 - 18:30<br />\n四節主題：時代子民、獄中讚歌、審判將至、天佑美國<br />\n<br />\n※※ 遮打現場將收集香港人權與民主宣言聯署至14:30﹐隨後出發向美領遞交 ※※<br />\n<br />\n遊行部分<br />\n集合地點：中環遮打花園金鐘道出口<br />\n集合時間：14:30<br />\n遊行路線：遮打花園經花園道往下亞厘畢道巴士站公眾活動區，向美國領事館遞交請願信<br />\n<br />\n<img src=\"https://na.cx/i/ZY3Vs7C.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZY3Vs7C.jpg&h=2d1d3d5a&s={SIZE}\" />"},{"pid":"94b4facacbbadcaa99ddf71eb4c4461cad317ebc","tid":1550083,"uid":148187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T14:25:50.000Z","msg":"自推"},{"pid":"f7b17ce231f2a7da4192ad7061f3eafc28e49675","tid":1550083,"uid":117906,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T14:25:51.000Z","msg":"[警世][最終文宣] 喚醒對中共既不信任 聯合世界圍堵#Chinazi<br />\n<a href=\"https://lih.kg/1548891\" data-auto-link target=\"_blank\">https://lih.kg/1548891</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<img src=\"https://na.cx/i/3E7OjKb.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3E7OjKb.gif&h=66b4ea40&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/uZFWW8o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuZFWW8o.jpg&h=4196affc&s={SIZE}\" />"},{"pid":"503b1f05f131e8d7cd4eaa7f200608481f761a15","tid":1550083,"uid":148187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T14:27:06.000Z","msg":"oh say can you see"},{"pid":"182be04be086b668cd98a14341004f736815ce41","tid":1550083,"uid":148187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T14:28:10.000Z","msg":"又要無恥自推<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"add5155303e9437b834410d937b086eaf6d084bc","tid":1550083,"uid":148187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T14:28:21.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"2748021505fff4a4ea1f88fcd3f2ae3d89c3ae23","tid":1550083,"uid":148187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T14:28:36.000Z","msg":"sir, this way!"},{"pid":"84107e0872d4d6108d1b23feedc5da7bdcae4d42","tid":1550083,"uid":148187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T14:29:12.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/asse