 src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"22f3c329c565e7c7cfc6956b943b2e5bf6e51d9f","tid":802344,"uid":73750,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-09-01T12:14:09.000Z","msg":"焗豬既一哥係咪大家樂<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /> <br />\n暫時食過真心覺得最好食係佢"},{"pid":"8d3f86d23c05297dfeccc0f315eca593eb30efba","tid":802344,"uid":48083,"like":0,"dislike":0,"score":0,"quote":{"pid":"6bcc0877f9464aa5207be4cec4bbca2741149769","tid":802344,"uid":45232,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-01T12:13:01.000Z","msg":"係咪睇地區<br />\n我有時一件大 或者兩件細<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-01T12:18:18.000Z","msg":"好耐冇見過有兩塊<br />\n兩間大xx都係"},{"pid":"bc8014fc9737db0088f9a037a4abc3a2d3a040cf","tid":802344,"uid":48083,"like":0,"dislike":0,"score":0,"quote":{"pid":"22f3c329c565e7c7cfc6956b943b2e5bf6e51d9f","tid":802344,"uid":73750,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-09-01T12:14:09.000Z","msg":"焗豬既一哥係咪大家樂<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /> <br />\n暫時食過真心覺得最好食係佢"},"citedBy":0,"replyTime":"2018-09-01T12:19:01.000Z","msg":"兩塊---》一塊厚切---》一塊<img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />"},{"pid":"ff65ae46529d06958c160285f6fafd7daaf6b090","tid":802344,"uid":16864,"like":0,"dislike":0,"score":0,"quote":{"pid":"22f3c329c565e7c7cfc6956b943b2e5bf6e51d9f","tid":802344,"uid":73750,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-09-01T12:14:09.000Z","msg":"焗豬既一哥係咪大家樂<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /> <br />\n暫時食過真心覺得最好食係佢"},"citedBy":0,"replyTime":"2018-09-01T12:28:02.000Z","msg":"依家都好撚細塊"},{"pid":"696d926306dd53c535a38b50b06642895f4d620e","tid":802344,"uid":22889,"like":2,"dislike":1,"score":1,"quote":{"pid":"22f3c329c565e7c7cfc6956b943b2e5bf6e51d9f","tid":802344,"uid":73750,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2018-09-01T12:14:09.000Z","msg":"焗豬既一哥係咪大家樂<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /> <br />\n暫時食過真心覺得最好食係佢"},"citedBy":0,"replyTime":"2018-09-01T15:17:10.000Z","msg":"十幾年前可能係，依家回晒塘，mx個撚大唷好過佢"},{"pid":"8f814c376f1b9cec7221e962937d77e65f1aecbb","tid":802344,"uid":117552,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2018-09-01T16:31:51.000Z","msg":"咪話呀叔唔教精你，我身經百戰，而家一腸（睇）個餐牌就知咩料。<br />\n拿，大家樂而家最抵食既得一隻，叫上海骨菜飯，有豬扒幾舊，炸到酥，跟涼菜、半隻鹵強同菜飯，先29蚊。<br />\n而焗豬呢都要叫得有技巧，唔係乜lan野時候都叫得，你一定要見佢個牌寫成呎長焗豬先叫得，唔係中伏！[1]<br />\n<br />\n<br />\n拿，大家樂唔可以成日加價，所以佢d野食質素同果期既食材來價有關！<br />\n如果果期d冰凍豬扒平，佢就會入d大大件成個飯盒咁長，而且有1.748cm厚既豬扒。入左筍野佢地當然唔會放過晒命機會，所以個牌就會寫「成呎長一哥焗豬扒飯」！<br />\n<br />\n如果果期d豬扒來價略貴，佢就會縮lan左成呎長幾隻字，淨係寫「一哥焗豬」！咁你叫時就要心中有數了！<br />\n<br />\n如果果期連一哥兩隻字都冇埋，變成乜lan野鴛鴦焗飯，雞球併豬扒之類咁，就係果期豬扒來貨好貴，佢就整d垃圾出黎頂檔，07年～08年就發生過，一唔小心就中伏！！<br />\n<br />\n不過大家唔駛驚會中伏，其實呢d係有路捉既，果期你上美國芝加哥期貨交易所個網睇豬肉期貨既價，如果巴西豬肉期貨價大跌就係準備有成呎長豬扒既時候了！ <br />\n<br />\n下次叫上海骨飯啦，唔跟野飲29蚊，睇師傅手神，有時會整5～6舊細扒入去，仲有一盒仔涼菜，係炸菜青瓜果d，仲有半隻鹵強，而跟飯有盒仔調味醬油，本來係撈涼菜既，但涼菜既夠味，就咁倒落菜飯到撈更香口。鍾意既加多杯佢地既即磨咖啡，以平價啡黎講算十分香口澴滑，+4蚊抵飲！"},{"pid":"5966e88ddd9a751357640028fe2773df37c3caac","tid":802344,"uid":63593,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-09-01T16:33:49.000Z","msg":"但奈何 最好食既焗豬 仲係大家樂"},{"pid":"8db1e21734a02800357f87353f2657f05e0585ef","tid":802344,"uid":48083,"like":0,"dislike":0,"score":0,"quote":{"pid":"8f814c376f1b9cec7221e962937d77e65f1aecbb","tid":802344,"uid":117552,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2018-09-01T16:31:51.000Z","msg":"咪話呀叔唔教精你，我身經百戰，而家一腸（睇）個餐牌就知咩料。<br />\n拿，大家樂而家最抵食既得一隻，叫上海骨菜飯，有豬扒幾舊，炸到酥，跟涼菜、半隻鹵強同菜飯，先29蚊。<br />\n而焗豬呢都要叫得有技巧，唔係乜lan野時候都叫得，你一定要見佢個牌寫成呎長焗豬先叫得，唔係中伏！[1]<br />\n<br />\n<br />\n拿，大家樂唔可以成日加價，所以佢d野食質素同果期既食材來價有關！<br />\n如果果期d冰凍豬扒平，佢就會入d大大件成個飯盒咁長，而且有1.748cm厚既豬扒。入左筍野佢地當然唔會放過晒命機會，所以個牌就會寫「成呎長一哥焗豬扒飯」！<br />\n<br />\n如果果期d豬扒來價略貴，佢就會縮lan左成呎長幾隻字，淨係寫「一哥焗豬」！咁你叫時就要心中有數了！<br />\n<br />\n如果果期連一哥兩隻字都冇埋，變成乜lan野鴛鴦焗飯，雞球併豬扒之類咁，就係果期豬扒來貨好貴，佢就整d垃圾出黎頂檔，07年～08年就發生過，一唔小心就中伏！！<br />\n<br />\n不過大家唔駛驚會中伏，其實呢d係有路捉既，果期你上美國芝加哥期貨交易所個網睇豬肉期貨既價，如果巴西豬肉期貨價大跌就係準備有成呎長豬扒既時候了！ <br />\n<br />\n下次叫上海骨飯啦，唔跟野飲29蚊，睇師傅手神，有時會整5～6舊細扒入去，仲有一盒仔涼菜，係炸菜青瓜果d，仲有半隻鹵強，而跟飯有盒仔調味醬油，本來係撈涼菜既，但涼菜既夠味，就咁倒落菜飯到撈更香口。鍾意既加多杯佢地既即磨咖啡，以平價啡黎講算十分香口澴滑，+4蚊抵飲！"},"citedBy":0,"replyTime":"2018-09-01T16:34:20.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"66217cd58eac35354acae3e61e66e75270663c19","tid":802344,"uid":39531,"like":0,"dislike":0,"score":0,"quote":{"pid":"8f814c376f1b9cec7221e962937d77e65f1aecbb","tid":802344,"uid":117552,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2018-09-01T16:31:51.000Z","msg":"咪話呀叔唔教精你，我身經百戰，而家一腸（睇）個餐牌就知咩料。<br />\n拿，大家樂而家最抵食既得一隻，叫上海骨菜飯，有豬扒幾舊，炸到酥，跟涼菜、半隻鹵強同菜飯，先29蚊。<br />\n而焗豬呢都要叫得有技巧，唔係乜lan野時候都叫得，你一定要見佢個牌寫成呎長焗豬先叫得，唔係中伏！[1]<br />\n<br />\n<br />\n拿，大家樂唔可以成日加價，所以佢d野食質素同果期既食材來價有關！<br />\n如果果期d冰凍豬扒平，佢就會入d大大件成個飯盒咁長，而且有1.748cm厚既豬扒。入左筍野佢地當然唔會放過晒命機會，所以個牌就會寫「成呎長一哥焗豬扒飯」！<br />\n<br />\n如果果期d豬扒來價略貴，佢就會縮lan左成呎長幾隻字，淨係寫「一哥焗豬」！咁你叫時就要心中有數了！<br />\n<br />\n如果果期連一哥兩隻字都冇埋，變成乜lan野鴛鴦焗飯，雞球併豬扒之類咁，就係果期豬扒來貨好貴，佢就整d垃圾出黎頂檔，07年～08年就發生過，一唔小心就中伏！！<br />\n<br />\n不過大家唔駛驚會中伏，其實呢d係有路捉既，果期你上美國芝加哥期貨交易所個網睇豬肉期貨既價，如果巴西豬肉期貨價大跌就係準備有成呎長豬扒既時候了！ <br />\n<br />\n下次叫上海骨飯啦，唔跟野飲29蚊，睇師傅手神，有時會整5～6舊細扒入去，仲有一盒仔涼菜，係炸菜青瓜果d，仲有半隻鹵強，而跟飯有盒仔調味醬油，本來係撈涼菜既，但涼菜既夠味，就咁倒落菜飯到撈更香口。鍾意既加多杯佢地既即磨咖啡，以平價啡黎講算十分香口澴滑，+4蚊抵飲！"},"citedBy":0,"replyTime":"2018-09-01T17:34:04.000Z","msg":"d圖先係重點"}]}