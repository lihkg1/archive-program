lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F2GKH20p.png&h=6178433f&s={SIZE}\" />"},{"pid":"2df740fddb65988736d6c08ff5386d7ad2215931","tid":1536594,"uid":271234,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:36:45.000Z","msg":"唔好意思借位一用<br />\n<span style=\"color: red;\">【Google 廣告】上線啦 !</span><br />\n<a href=\"https://lih.kg/dOiORS\" data-auto-link target=\"_blank\">https://lih.kg/dOiORS</a>"},{"pid":"9e17b3c495e8f90e9c935cb460a864db3da4d19e","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:36:51.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"b57d80f29d7ab29cf7ba803f5c3b8430fd501abc","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:37:25.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"a6722ccf0874dfa8f9c5ffcec76ea500db189197","tid":1536594,"uid":3234,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:37:36.000Z","msg":"（1669 鍾國恩 警長、48958 李彼得 高級警員、54538 張文麟 高級警員、58248 梁智顯 高級警員）<br />\n<br />\n推撚到佢地死全家"},{"pid":"e7c608a6f7c9778d80918acafb349fadc9d2812c","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:37:41.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"55142a077a7e5c4f22a8dd26dd28a067000c078f","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:37:56.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"13ad8e5a2445005add4656ce74b3e22d9456efc9","tid":1536594,"uid":289649,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-03T16:38:43.000Z","msg":"全民皆兵，破釜沉舟<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<br />\n［全部人同我入黎］《致眾表》望各位香港市民出自己的一份綿力<br />\n<a href=\"https://lih.kg/1532967\" data-auto-link target=\"_blank\">https://lih.kg/1532967</a><br />\n- 分享自 LIHKG 討論區<br />\n同我推上去<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">武裝起義<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /></span></span>"},{"pid":"d25ff4e303566eb3f618911646e8197f181f9579","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:39:00.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"932aa215d2872bf7c1a6bb8ea8423dd143df9073","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:39:32.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"12be1cb1e2acce8db89ef7f3d52c6323a0b604e2","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:39:45.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"ea79f52a34383ce1ee02b4f78150af978093c2cb","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:40:12.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"8fa5acf159d0d02d12efdf952a9e19275005f393","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:40:55.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"763a1332b86b9b5fba3e60a05cdfb83e4b0c971f","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:41:38.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"c95f9315f5abf9375af5662668c85c14ddcd2b1d","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:42:07.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"3a1d82fd661f839a7ba5f07fc25da6b35885e2aa","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:43:23.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"8d6db763249c5961004feafc686429fbe32c4a36","tid":1536594,"uid":11753,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:43:33.000Z","msg":"黑警死全家"},{"pid":"fbcf209a2e3c238ff7ee24da4f0bea226f08b75f","tid":1536594,"uid":67410,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-03T16:44:10.000Z","msg":"GestaPoPo"},{"pid":"18f780cda3711640ae64d73f28dc68ab0bed300f","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:44:27.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"566fd2a27be669903bd808228563a10aeb912ed2","tid":1536594,"uid":74303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:44:49.000Z","msg":"香港popo 除良安暴"},{"pid":"745ca9ce8754398c3915dcf1258e78936e032c67","tid":1536594,"uid":186,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:44:54.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: gold;\"><div style=\"text-align: center;\"><strong>中央「三春袋」不能碰</strong></div></span></span><br />\n中國國務院港澳辦發言人楊光29日表示，一國兩制是個完整概念，一國是本、是根，根生才能葉茂，有三條底線不能觸碰，一是絕不允許任何危害國家主權安全行為、絕不允許挑戰中央權力、絕不允許香港對內地進行滲透破壞，他強調這三條紅線不可觸碰。<br />\n<br />\n<span style=\"color: gold;\">楊光頭兩點都有話香港。<br />\n但值得留意，楊光講話沒有更多涉及官方絕不允許香港對內地進行滲透破壞的內容。<br />\n呢個我地睇到中共根本唔會理外國點諗，三條紅線無一條係勾結外國勢力。因為佢地同我地都知道外國係好難好難出兵幫香港。</span><br />\n<br />\n<br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: red;\">但中共最怕係咩，就係內部人民搞革命。就好似Hunger game 入面，或者毛澤東既概念。</span></strong></span><br />\n<span style=\"font-size: small;\"><span style=\"color: pink;\">《星星之火，可以燎原》，原名《時局估量和紅軍行動問題》是中國共產黨紅四軍收到中共中央的「二月來信」後，林彪給毛澤東寫信，毛澤東回覆的一封公開信<br />\n</span></span><br />\n<br />\n要做到更多影響力，就要影響我地最討厭既內地人。我地要分化內地人同中共政府。<br />\n<br />\n原文：<a href=\"http://trad.cn.rfi.fr/%E4%B8%AD%E5%9C%8B/20190729-%E4%B8%AD%E5%9C%8B%E6%B8%AF%E6%BE%B3%E8%BE%A6%E6%8F%903%E5%BA%95%E7%B7%9A-%E8%AD%A6%E5%91%8A%E6%A8%A1%E7%B3%8A%E9%A1%AF%E6%AE%BA%E6%A9%9F\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ftrad.cn.rfi.fr%2F%25E4%25B8%25AD%25E5%259C%258B%2F20190729-%25E4%25B8%25AD%25E5%259C%258B%25E6%25B8%25AF%25E6%25BE%25B3%25E8%25BE%25A6%25E6%258F%25903%25E5%25BA%2595%25E7%25B7%259A-%25E8%25AD%25A6%25E5%2591%258A%25E6%25A8%25A1%25E7%25B3%258A%25E9%25A1%25AF%25E6%25AE%25BA%25E6%25A9%259F&d=KYuNOZm%2F4ip93LesI4%2B6vpNY2w26zYPSLCKwhaLFqs8%3D&h=c008e5d7\" target=\"_blank\">http://trad.cn.rfi.fr/%E4%B8%AD%E5%9C%8B/20190729-%E4%B8%AD%E5%9C%8B%E6%B8%AF%E6%BE%B3%E8%BE%A6%E6%8F%903%E5%BA%95%E7%B7%9A-%E8%AD%A6%E5%91%8A%E6%A8%A1%E7%B3%8A%E9%A1%AF%E6%AE%BA%E6%A9%9F</a><br />\n<br />\n<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><div style=\"text-align: center;\">對在內地的內地人進行滲透</div></span></span><br />\nWe are formless. We are shapeless. We can flow. We can crash.  We are like water.  <br />\nWe are #Hongkongers!<br />\n<br />\n第一，我地係Formless，所以我地呢三個月所做既運動／革命都無一個official 名<br />\n禁既然我地係formless，我地呢場運動／革命都唔一定只有一個名，我地可以有無限個名。<br />\n英文可以叫water revolution<br />\n但中文 我地只要有個水字就係我地既名號<br />\n我地要利用中共怕事既方法 將所有文宣都加上#水<br />\n你可以叫呢場叫<br />\n水運動 <br />\n汽水運動<br />\n膠水運動<br />\n水泥運動<br />\n眼水運動<br />\n總之有個水字<br />\n仲有所有巴打一齊做，禁中共會入左一兩難局面<br />\n8964 5月35日 都可以block <br />\n但日常多變既字佢點block<br />\n<img src=\"https://na.cx/i/egf0UmF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fegf0UmF.jpg&h=dca6ebfb&s={SIZE}\" /><br />\n「不許百姓飲水」增加敏感字眼 water revolution 水運動 #水 <br />\n<a href=\"https://lih.kg/dOoocS\" target=\"_blank\">https://lih.kg/dOoocS</a><br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><div style=\"text-align: center;\">對已來港內地人地進行滲透</div></span></span><br />\n第二， 我地要令吃兩家茶禮既人 加入我地 或者被加入我地<br />\n幫已來港內地人<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">破釜沉舟</span></span></strong><br />\n<br />\n我要攬炒 舉報每日150 嚟讀書工作嘅大陸人都被暴徒洗腦<br />\n<a href=\"https://lih.kg/dNPtqS\" target=\"_blank\">https://lih.kg/dNPtqS</a>"},{"pid":"84f9d90db8c7aaf72e069a158295106848bafdf5","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"quote":{"pid":"fbcf209a2e3c238ff7ee24da4f0bea226f08b75f","tid":1536594,"uid":67410,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-03T16:44:10.000Z","msg":"GestaPoPo"},"citedBy":0,"replyTime":"2019-09-03T16:45:15.000Z","msg":"HK PoPo<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\nGestaPoPo<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"55db2a4326ec65c6bd091985ee6e9e995c01a56f","tid":1536594,"uid":40979,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:45:39.000Z","msg":"文宣！"},{"pid":"6a094874a3cb2a4ee2436354c4e0ffbd4442139c","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:45:40.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"b9c84168ceb1aed59bf58e5d088053ecf2804043","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:46:03.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"70d130f052b51851bef9cf37877e056d63e3700d","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:47:02.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"f27075496091be02e51783fb18d33d47415f4a6a","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:47:49.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"dd98b0bbcdd551bf0802e1c9db26678f4f92bacb","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:49:12.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"797049805d51233702feb8eda73e67752325068d","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:49:54.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"a6cf60511cd5be96afaaad188aa5fc42b959a7c4","tid":1536594,"uid":268160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:49:55.000Z","msg":"Cls"},{"pid":"015cbffe0fedbfc5a6d599609c43fbcca7ef7cf5","tid":1536594,"uid":300023,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:50:32.000Z","msg":"將由盧偉聰處長領導的香港警務處（警務處）正式列為恐怖組織<br />\n由中央人民政府駐香港特別行政區聯絡辦公室（中聯辦）和國務院港澳事務辦公室（港澳辦）支持的臭名昭著的香港警務處已經變為一個類似於20世紀30年代的納粹黨衛隊（SS）的組織。<br />\n不斷使用暴力、威脅、脅迫和性侵犯危害人民的生命和人權，壓制言論自由，拒絕任何抗議政治問題的抗議活動，以及危害「一國兩制」。<br />\n於二零一九年七月二十一日，警務處容許黑社會幫會在元朗進行恐怖襲擊。除了過去及持續濫用權力及暴力外，於二零一九年六月十二日起，其他同樣令人髮指的罪行出現在香港街頭發生。警務處不分青紅皂白地襲擊和平抗議者、記者和平民，造成頭部受傷，並逮捕和指控騷亂， 數十名平民現在被指控最高可判10年徒刑的暴動罪。<br />\n<br />\n<a href=\"https://petitions.whitehouse.gov/petition/officially-recognize-hong-kong-police-force-hkpf-led-commissioner-stephen-lo-wai-chung-terrorist-organization\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fofficially-recognize-hong-kong-police-force-hkpf-led-commissioner-stephen-lo-wai-chung-terrorist-organization&d=KYuNOZm%2F4ip93LesI4%2B6vpNY2w26zYPSLCKwhaLFqs8%3D&h=d8b5473b\" data-auto-link target=\"_blank\">https://petitions.whitehouse.gov/petition/officially-recognize-hong-kong-police-force-hkpf-led-commissioner-stephen-lo-wai-chung-terrorist-organization</a><br />\n<br />\n未簽嘅快D簽。請廣傳！"},{"pid":"03a2a5041b481f21eef9696dc829d455dadb8b3b","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:50:34.000Z","msg":"文宣！"},{"pid":"2df5729c25d368e093f8ea30c5f39a001c6c3038","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"20