{"tid":1536594,"cid":5,"subCid":0,"title":"Hong Kong PoPo = Gestapo","createTime":"2019-09-03T16:34:58.000Z","updateTime":"2019-09-03T17:38:10.000Z","uid":47857,"like":20,"dislike":1,"uniUserReply":17,"replies":[{"pid":"f521680cc8532b93a4dfa08a8ed966c01290abd4","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-03T16:34:58.000Z","msg":"<img src=\"https://upload.wikimedia.org/wikipedia/commons/7/74/Jews_rounded_up_in_Warsaw_cph.3c32739.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.wikimedia.org%2Fwikipedia%2Fcommons%2F7%2F74%2FJews_rounded_up_in_Warsaw_cph.3c32739.jpg&h=ebd4daef&s={SIZE}\" /><br />\n<img src=\"https://media.bastillepost.com/wp-content/uploads/hongkong/2019/09/20190903_PO_%E5%B7%B4%E5%A3%AB_7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.bastillepost.com%2Fwp-content%2Fuploads%2Fhongkong%2F2019%2F09%2F20190903_PO_%25E5%25B7%25B4%25E5%25A3%25AB_7.jpg&h=6f9f1da6&s={SIZE}\" />"},{"pid":"31991bb59c6f06bcbe24d0c2e0e03dee712202d0","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:35:34.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d894ce008555b9b85997e49d3c3b4855f2e47942","tid":1536594,"uid":47857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T16:36:02.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"5a52926dc8bc3fb04a35856a3298be8067e5e44d","tid":1536594,"uid":153771,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-03T16:36:26.000Z","msg":"<div style=\"text-align: center;\"><span style=\"font-size: large;\"><strong><span style=\"color: blue;\">9月8日 (日) 2PM<br />\n香港人權與民主法案集會<br />\n美國駐港澳總領事館</span></strong></span></div><br />\n<br />\n<div style=\"text-align: center;\">0908公海 <a href=\"http://t.me/hk908group\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ft.me%2Fhk908group&d=KYuNOZm%2F4ip93LesI4%2B6