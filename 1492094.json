By":0,"replyTime":"2019-08-20T16:36:41.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"fb6865aa8937d82c40009a47cd35530233fb6450","tid":1492094,"uid":2248,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T16:43:55.000Z","msg":"五大訴求 缺一不可"},{"pid":"e9c3a65a6adbb45b5b968db80d6ee6b77408da7a","tid":1492094,"uid":70201,"like":0,"dislike":0,"score":0,"quote":{"pid":"fb6865aa8937d82c40009a47cd35530233fb6450","tid":1492094,"uid":2248,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T16:43:55.000Z","msg":"五大訴求 缺一不可"},"citedBy":1,"replyTime":"2019-08-20T16:46:26.000Z","msg":"你漏咗光復香港 時代革命"},{"pid":"223088ec05b92f0a16aa27fa56fee0599f2b94a7","tid":1492094,"uid":258318,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T16:47:26.000Z","msg":"推"},{"pid":"1746747bc82110b4c0a71328747461c943c65ecf","tid":1492094,"uid":251530,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-20T16:56:15.000Z","msg":"推推推 支持絲打"}]}