{"tid":1075833,"cid":5,"subCid":0,"title":"太古城女子疑墮樓重創 送院搶救","createTime":"2019-03-24T12:09:30.000Z","updateTime":"2019-03-24T13:04:01.000Z","uid":160807,"like":4,"dislike":0,"uniUserReply":11,"replies":[{"pid":"cdbed3d9205ac99af298acd9b43977219de538d8","tid":1075833,"uid":160807,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-24T12:09:30.000Z","msg":"<img src=\"https://static.appledaily.hk/images/e-paper/20190324/large/1553425856_f6ab.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190324%2Flarge%2F1553425856_f6ab.jpg&h=4c02b656&s={SIZE}\" /><br />\n<br />\n鰂魚涌太古城金星閣，下午5時許，保安發現一名女子倒卧1樓簷篷上，懷疑她由高處墮下，於是報案。消防接報趕至，將懷疑墮樓女子救下，交由救護車送院搶救。警方正在場調查。<br />\n<br />\n<a href=\"https://hk.news.appledaily.com/breaking/realtime/article/20190324/59407082\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20190324%2F59407082&d=6SPFYKHnGSG2Q49qavPU8llsl4SrcEEyWLual4COuMU%3D&h=929794b3\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20190324%2F59407082&h=b79a24af\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/breaking/realtime/article/20190324/59407082</a>"},{"pid":"238527cf0cb1acc46994d7027726a04a4decb809","tid":1075833,"uid":29929,"like":2,"dislike":5,"score":-3,"citedBy":2,"replyTime":"2019-03-24T12:10:00.000Z","msg":"住太古都要跳樓<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"50d229675ccab8033d528217dccb8d9e09fcb61f","tid":1075833,"uid":46943,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-03-24T12:10:12.000Z","msg":"太<img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" />古"},{"pid":"3f6159e6d7364b8f6accebe40f0f26561d716999","tid":1075833,"uid":99642,"like":1,"dislike":0,"score":1,"quote":{"pid":"238527cf0cb1acc46994d7027726a04a4decb809","tid":1075833,"uid":29929,"like":2,"dislike":5,"score":-3,"citedBy":2,"replyTime