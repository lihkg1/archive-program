633%2F%25E3%2580%2590%25E6%25AD%25A6%25E6%25BC%25A2%25E8%2582%25BA%25E7%2582%258E%25E3%2580%259115%25E8%25AD%25B7%25E5%25A3%25AB%25E8%25AB%258B%25E7%2597%2585%25E5%2581%2587%25E4%25BF%2583%25E5%2585%25A8%25E9%259D%25A2%25E3%2580%258C%25E5%25B0%2581%25E9%2597%259C%25E3%2580%258D-%25E6%259D%25B1%25E5%258D%2580%25E9%2586%25AB%25E9%2599%25A2-%25E5%25B7%25B2%25E8%25AA%25BF%25E9%2585%258D%25E4%25BA%25BA%25E6%2589%258B%25E7%25B6%25AD%25E6%258C%2581%25E6%259C%258D%25E5%258B%2599&h=d5624f94\" target=\"_blank\">https://news.mingpao.com/ins/%E6%B8%AF%E8%81%9E/article/20200128/s00001/1580215628633/%E3%80%90%E6%AD%A6%E6%BC%A2%E8%82%BA%E7%82%8E%E3%80%9115%E8%AD%B7%E5%A3%AB%E8%AB%8B%E7%97%85%E5%81%87%E4%BF%83%E5%85%A8%E9%9D%A2%E3%80%8C%E5%B0%81%E9%97%9C%E3%80%8D-%E6%9D%B1%E5%8D%80%E9%86%AB%E9%99%A2-%E5%B7%B2%E8%AA%BF%E9%85%8D%E4%BA%BA%E6%89%8B%E7%B6%AD%E6%8C%81%E6%9C%8D%E5%8B%99</a>"},"citedBy":0,"replyTime":"2020-01-28T14:15:42.000Z","msg":"調條毛咩 睇你頂到幾耐"},{"pid":"730a5997cc094b8f475b04cf98983d984de03b8b","tid":1848593,"uid":162272,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-01-28T14:28:58.000Z","msg":"希望唔會秋後算帳<br />\n不過醫護揾工話咁易"},{"pid":"e53de2c802e39d6d92a5da28894fd9a2595c8f4f","tid":1848593,"uid":194325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T14:30:08.000Z","msg":"<img src=\"https://na.cx/i/1DtKWpn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1DtKWpn.jpg&h=a27c226a&s={SIZE}\" /><br />\n<br />\n白色，是醫護常用顏色。不含任何色素，並容易發現污漬，適用於醫院最應保持潔淨的地方。除此之外，白色還代表純粹的善良和堅定的信念。<br />\n<br />\n當日，醫護們憑藉良心忠實履行自己的使命。今日，政權道德綁架他們這一份熱誠和信念。<br />\n<br />\n他們守護了我們生命和健康，但又誰能守護他們？<br />\n<br />\n全城白絲帶，支持醫護罷工。醫護不是condom，我們與醫護同行。<br />\n<br />\n#全城白絲帶 #撐醫護 #撐罷工 #封關口 #醫護非condom #與醫護同行<br />\n#香港金總 #HKFU #standwithmedics<br />\n<br />\n各位金融人都麻煩幫手填問卷，謝謝。<br />\n<br />\n⚠️⚠️緊急⚠️⚠️<br />\n<br />\n香港金融業職工共同抗疫意見調查<br />\n<br />\n香港金融業職工總會欲以問卷方式詢問同業以工業行動共同抗疫的意願和意見，以制定有效方式向僱主及政府表達對僱員對於安全和健康的憂慮，全民共同抗疫。<br />\n<br />\n由於事態緊急，如策劃任何工業行動必需經過既定程序。故此是次問卷將於1月31日23:59截止。希望同業們積極參與此調查，讓金總能全面理解金融界僱主於防疫措施現況，以及會員和同業於共同抗疫的意願，以制定下一步行動。<br />\n<br />\n<a href=\"https://forms.gle/toVdkp2QMVwtZXVr7\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2FtoVdkp2QMVwtZXVr7&d=rcEdfnhTqGmqsB%2B6X%2FYCGSVDAD9kR8TUwRzNJuuVR5U%3D&h=08595593\" data-auto-link target=\"_blank\">https://forms.gle/toVdkp2QMVwtZXVr7</a><br />\n<br />\n原post傳送門：<br />\n［行動］［請置頂］全民白絲帶 罷工撐醫護<br />\n<a href=\"https://lih.kg/1848612\" data-auto-link target=\"_blank\">https://lih.kg/1848612</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"58ca5eb8b45902ae843612a54817e8241e1076c7","tid":1848593,"uid":82938,"like":0,"dislike":0,"score":0,"quote":{"pid":"730a5997cc094b8f475b04cf98983d984de03b8b","tid":1848593,"uid":162272,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-01-28T14:28:58.000Z","msg":"希望唔會秋後算帳<br />\n不過醫護揾工話咁易"},"citedBy":1,"replyTime":"2020-01-28T14:34:10.000Z","msg":"去第2個地方or轉行"},{"pid":"a39ef21885ff685be501d1c183ade3883d183855","tid":1848593,"uid":237295,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-28T14:34:43.000Z","msg":"respect"},{"pid":"659e5788ebdbb0b1e72aa637e6edc8c132d28a6f","tid":1848593,"uid":194281,"like":0,"dislike":0,"score":0,"quote":{"pid":"58ca5eb8b45902ae843612a54817e8241e1076c7","tid":1848593,"uid":82938,"like":0,"dislike":0,"score":0,"quote":{"pid":"730a5997cc094b8f475b04cf98983d984de03b8b","tid":1848593,"uid":162272,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-01-28T14:28:58.000Z","msg":"希望唔會秋後算帳<br />\n不過醫護揾工話咁易"},"citedBy":1,"replyTime":"2020-01-28T14:34:10.000Z","msg":"去第2個地方or轉行"},"citedBy":1,"replyTime":"2020-01-28T14:35:28.000Z","msg":"私家"},{"pid":"7dae80d35c15529e5d709ad1130215f28be0513a","tid":1848593,"uid":78392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T14:37:10.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" cl