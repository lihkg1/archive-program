ormal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"1edb3217867ff884a3ef2dd9306a6ddc8e2028a2","tid":1357344,"uid":271064,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T17:05:03.000Z","msg":"推"},{"pid":"529931ea04bedcc2bce38a7dcb4bc82841fdc8bd","tid":1357344,"uid":3433,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-23T17:09:15.000Z","msg":"光復香港 時代革命"},{"pid":"32f4b3ac26de865b33bd3cd5a47891b7a0bb17a9","tid":1357344,"uid":226955,"like":1,"dislike":0,"score":1,"quote":{"pid":"2ab56b157e59b8431d42a9970deae77e8c23925c","tid":1357344,"uid":89966,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-23T16:54:18.000Z","msg":"唔好當人地condom仔好冇，定係大家已經見慣義士食彈覺得不足為奇呀？？？"},"citedBy":0,"replyTime":"2019-07-23T17:14:01.000Z","msg":"冇人當義士係condom，好多人都為呢場逆權運動付出咗無數心血，亦為每一個出事嘅手足擔心同支援，由大大小小嘅遊行、連續不斷嘅白宮聯署、眾籌國際登報、遍地開花嘅連儂牆、台灣總統府向蔡英文呈書、梵蒂岡向教宗呈書、日內瓦聯合國總部10個鐘內靠各位巴打努力寫完嘅呈書、攬炒巴團隊嘅貢獻、好多打工仔同商戶罷工罷市、有啲教堂肯開放比示威者休息，示威現場上有義務急救，被捕之後有義務律師支援，仲有好多，好多，連我都記唔曬，我地香港人大家都係坐緊同一條船，同一條心，每一個手足都係互相扶持，而最後我地一定會爭取到我地要嘅嘢"},{"pid":"b7dc74d0cda4d7135b2cfcb52394670300c6e880","tid":1357344,"uid":154241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T17:54:16.000Z","msg":"推！大家唔好忘記個36槍！"},{"pid":"06f1729dc557e33140ddd96957fc32779515878b","tid":1357344,"uid":76297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T23:41:54.000Z","msg":"推到有義士消息"},{"pid":"7f63a293bec12fb7ed57aa89b55b812f5e736ec3","tid":1357344,"uid":24853,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-23T23:49:20.000Z","msg":"兩邊都有推 <br />\n唔好再二元對立 <br />\n<br />\n集中討論啦 講左好多日"},{"pid":"47d16a45b30723312be0409965503ae7444dab27","tid":1357344,"uid":38438,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T23:51:23.000Z","msg":"Push"},{"pid":"63ad60373bc761b65bd1b432426ad54e11a37b69","tid":1357344,"uid":41481,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T23:52:40.000Z","msg":"推"},{"pid":"f81b4a13a5b6c30f139bf5aa34725793a042fd61","tid":1357344,