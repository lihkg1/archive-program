ts/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"e6a9f35fb0ee96885915f177e9407b162a09a7e2","tid":1414602,"uid":48083,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-05T12:46:53.000Z","msg":"<img src=\"https://na.cx/i/iDmfxiB.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiDmfxiB.png&h=07e6310c&s={SIZE}\" />"},{"pid":"f07e2afc93d7b87a480469e5b564dc4e2437bfb3","tid":1414602,"uid":19255,"like":0,"dislike":0,"score":0,"quote":{"pid":"e6a9f35fb0ee96885915f177e9407b162a09a7e2","tid":1414602,"uid":48083,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-05T12:46:53.000Z","msg":"<img src=\"https://na.cx/i/iDmfxiB.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiDmfxiB.png&h=07e6310c&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-08-05T12:48:12.000Z","msg":"咁應該點做呀，不如你教下我地<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"f400f9aaccf83d7cf44e1fdabb5be908ed584cf0","tid":1414602,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-05T12:48:35.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: gold;\">放核彈都唔割呀！！</span></strong></span><br />\n<br />\n呢D咁既post我都出到啦on9<br />\n<br />\n諗下啦<br />\n我地和理非同勇武已經係命運共同體<br />\n就算我地割左，最尾冇左自由既都係我地<br />\n大家已經番唔到轉頭嫁啦<br />\n<br />\n記唔記得<br />\n<strong><span style=\"font-size: xx-large;\">兄弟爬山，各自努力</span></strong><br />\n自由社會就係每個人都有唔同意見<br />\n勇武派有冇真係傷害過普通市民？有冇針對民居？冇呀<br />\n<br />\n由始至終都係D狗先會亂係民居出彈，射街坊射記者<br />\n佢地而家燒狗屋，唔係對準政權係乜野？<br />\n係呀冇錯佢地有搞到其他紀律部隊，但係點到唔同黑警同黑社會與民為敵仆街！！"},{"pid":"f2fea656024664c190343401920d7791c03dddd2","tid":1414602,"uid":297658,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-05T12:48:41.000Z","msg":"拿唔好屈我地呀，從來無割蓆，你地係我既英雄<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><br />\n利伸：和理非"},{"pid":"aa110c77f6015afe64980266a2a052e0be45db19","tid":1414602,"uid":19255,"like":0,"dislike":0,"score":0,"quote":{"pid":"e6a9f