":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T04:45:21.000Z","msg":"同意<br />\n冇大台 唔應該係冇方向<br />\n應該係要先聚人再討論決策"},{"pid":"931b23c4784bde5303f9b931329fbcc9ecb6bded","tid":1737633,"uid":152411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T06:00:58.000Z","msg":"推"},{"pid":"1212faddd3ad54e3656862d20628917ffbbdf1d6","tid":1737633,"uid":152411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T06:14:36.000Z","msg":"推"},{"pid":"bee8c17cab4ee271017d154b8fb8f0a1b64b7560","tid":1737633,"uid":152411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T06:14:46.000Z","msg":"推"},{"pid":"1491b9804cac7f33134c75622bb802d474a8cb28","tid":1737633,"uid":152411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T06:25:45.000Z","msg":"推"},{"pid":"04c8ad2e350e9f455985cbda586935c11a80eb6b","tid":1737633,"uid":152411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T06:26:04.000Z","msg":"推"},{"pid":"70a69ff140f3b6715d6599fb0e98e689df79564f","tid":1737633,"uid":152411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T08:19:06.000Z","msg":"推"},{"pid":"e98a0ccee8c157dac7305a9114666c5cfc31a4f6","tid":1737633,"uid":152411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T08:19:18.000Z","msg":"推"},{"pid":"46899d2709a0d52c3f5c9187123d0c0159e75cda","tid":1737633,"uid":152411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-19T08:20:10.000Z","msg":"推"}]}