新世界<br />\n<a href=\"https://lih.kg/1247490\" target=\"_blank\">https://lih.kg/1247490</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"aba4c4acbc6e0fae656e6b4978be90dfe9b8db10","tid":1285610,"uid":257516,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T16:16:49.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://i.lihkg.com/540/https://na.cx%2Fi%2FoB5zb9J.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%252Fi%252FoB5zb9J.gif&h=b18959b2&s={SIZE}\" />"},{"pid":"dd7bfcb3d4509afe56d19571f381a17e39a130d4","tid":1285610,"uid":52621,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-04T16:18:13.000Z","msg":"<img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5969c951836aa57a59d40849ff2501510fac4b9a","tid":1285610,"uid":257516,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd7bfcb3d4509afe56d19571f381a17e39a130d4","tid":1285610,"uid":52621,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-04T16:18:13.000Z","msg":"<img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-04T16:19:02.000Z","msg":"老師好波<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f997de79e45c38d75d4c13d51b1136720381e1d7","tid":1285610,"uid":14494,"like":0,"dislike":1,"score":-1,"quote":{"pid":"671b80178324814315df87b5bceb9c29cb5de835","tid":1285610,"uid":42364,"like":14,"dislike":0,"score":14,"citedBy":3,"replyTime":"2019-07-04T16:02:50.000Z","msg":"<img src=\"https://na.cx/i/6mD1ECf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6mD1ECf.png&h=61614bad&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-07-04T16:20:12.000Z","msg":"迷雲黨<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5925e356dd69f0eb5058102864bfe7d5ded81183","tid":1285610,"uid":224095,"like":2,"dislike":0,"score":2,"quo