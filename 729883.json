By":0,"replyTime":"2018-07-05T12:18:42.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"866751527c21cb6b3e5ef6ff3316c7294f6e57f3","tid":729883,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-06T03:39:41.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d63af2efeb0d5be3506dc5f19348e2bd616a3bfc","tid":729883,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-06T04:55:27.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a6d3b20db6d3aa33c9982de47783b3dcab65d4aa","tid":729883,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-06T06:28:57.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"dd9f72f91ace3a81df299450e39e276f2b5855ce","tid":729883,"uid":45914,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-07-06T07:03:17.000Z","msg":"此回覆已被刪除"},{"pid":"35b8ee187afeff4de032193b37912687776dff71","tid":729883,"uid":60545,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2018-07-06T07:25:04.000Z","msg":"其實負皮咩意思？<br />\n我只係話香港而家嘅書面語唔係根據粵語而嚟，香港要抗中就應該建立自己嘅粵語書面語而唔係直接用漢語(官話）嘅書面語"}]}