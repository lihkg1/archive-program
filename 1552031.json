pid":"712e27d760a0f0460c82b422b2f986ca553a83d8","tid":1552031,"uid":8075,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-08T09:24:57.000Z","msg":"不如就獅子山啦"},{"pid":"fb95d23cc75429f950a460aad90969392a7f98fd","tid":1552031,"uid":89530,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-09-08T09:28:57.000Z","msg":"真心<br />\n用獅子山做Main應該冇咩人會反對，"},{"pid":"8e7bbbc2a18484a884183458df61ceb1b0ecdc6e","tid":1552031,"uid":27946,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-09-08T09:29:00.000Z","msg":"直接藍底師子旗就可以 <br />\n國旗唔可以太雜架"},{"pid":"4f7559acf147a4c1900387243ba3291f12cba72d","tid":1552031,"uid":265192,"like":5,"dislike":78,"score":-73,"citedBy":1,"replyTime":"2019-09-08T09:33:33.000Z","msg":"<img src=\"https://na.cx/i/Zng76Jt.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZng76Jt.png&h=72da44ba&s={SIZE}\" />"},{"pid":"35aa5fd516416364c926b6531930c7da94359e52","tid":1552031,"uid":130698,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-08T10:03:33.000Z","msg":"認真諗咗好耐都冇野有廣泛共識代表香港， 洋紫荊都係選出嚟，我地都要選返樣。<br />\n<br />\n比較多人識係獅子山，雨傘，舊啲係帆船"},{"pid":"f7da6c4319b72b1a877bda5a5ed9e9ecddcffad8","tid":1552031,"uid":130698,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-09-08T10:06:43.000Z","msg":"轉底色已經好好多了<br />\n五塊花瓣變六塊 上面睇落去係雨傘"},{"pid":"2c5ed411442132b5ab69fa194d91e990a21f087d","tid":1552031,"uid":235152,"like":6,"dislike":25,"score":-19,"citedBy":7,"replyTime":"2019-09-08T10:23:26.000Z","msg":"<img src=\"http://www.passiontimes.hk/flags/109.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F109.jpg%3Fv%3D1&h=372e409a&s={SIZE}\" /><br />\n國旗用色以英國旗為基調配以暖黃突出國徽 紀念香港以英國文化之形響下成為集東西文化於一身之國度 國徽概念以洋紫荆之形浴火重生，以大鵬金翅鳥之形相重現 象徵香港歷中共浩刼而後自強獨立成國，必然有更美好前景<br />\n<br />\n<img src=\"http://www.passiontimes.hk/flags/110.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F110.jpg%3Fv%3D1&h=7711a38e&s={SIZE}\" /><br />\n<br />\n獅子山旗&mdash; 國旗由藍、白兩個平行相等的長方形及具象化的獅子山組成。正中的獅子象徵香港人不屈不撓的精神，中間的星代表港人獨立的意志和決心。藍色代表民主，自由；白色代表和平，公正。<br />\n<br />\n<img src=\"http://www.passiontimes.hk/flags/94.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F94.jpg%3Fv%3D1&h=f927caf3&s={SIZE}\" /><br />\n<br />\n木棉有英雄樹之稱，象徵香港雄視亞東；其花落不散，喻各地國民皆心繫母國；十八花蕊象徵十八區國民子嗣繁衍。金黃雲雷紋拱衛木棉，香港建國順天應人，承繼華夏。普魯士藍底色，象徵海洋，呼應英治。"},{"pid":"ae2cc8bc7404fbf9a8b3ea68c4f1aad8be96c446","tid":1552031,"uid":136431,"like":3,"dislike":0,"score":3,"quote":{"pid":"2c5ed411442132b5ab69fa194d91e990a21f087d","tid":1552031,"uid":235152,"like":6,"dislike":25,"score":-19,"citedBy":7,"replyTime":"2019-09-08T10:23:26.000Z","msg":"<img src=\"http://www.passiontimes.hk/flags/109.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F109.jpg%3Fv%3D1&h=372e409a&s={SIZE}\" /><br />\n國旗用色以英國旗為基調配以暖黃突出國徽 紀念香港以英國文化之形響下成為集東西文化於一身之國度 國徽概念以洋紫荆之形浴火重生，以大鵬金翅鳥之形相重現 象徵香港歷中共浩刼而後自強獨立成國，必然有更美好前景<br />\n<br />\n<img src=\"http://www.passiontimes.hk/flags/110.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F110.jpg%3Fv%3D1&h=7711a38e&s={SIZE}\" /><br />\n<br />\n獅子山旗&mdash; 國旗由藍、白兩個平行相等的長方形及具象化的獅子山組成。正中的獅子象徵香港人不屈不撓的精神，中間的星代表港人獨立的意志和決心。藍色代表民主，自由；白色代表和平，公正。<br />\n<br />\n<img src=\"http://www.passiontimes.hk/flags/94.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F94.jpg%3Fv%3D1&h=f927caf3&s={SIZE}\" /><br />\n<br />\n木棉有英雄樹之稱，象徵香港雄視亞東；其花落不散，喻各地國民皆心繫母國；十八花蕊象徵十八區國民子嗣繁衍。金黃雲雷紋拱衛木棉，香港建國順天應人，承繼華夏。普魯士藍底色，象徵海洋，呼應英治。"},"citedBy":0,"replyTime":"2019-09-09T06:34:17.000Z","msg":"木棉好靚 但有啲大粵民國feel"},{"pid":"6ee713d746dccf52ebac0ff301b3125aee53d43b","tid":1552031,"uid":282535,"like":1,"dislike":0,"score":1,"quote":{"pid":"5fc64243f72cdd2b21c5c9d79868a561768acf8c","tid":1552031,"uid":182933,"like":2,"dislike":11,"score":-9,"citedBy":2,"replyTime":"2019-09-08T09:20:46.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-09-09T06:37:32.000Z","msg":"咪撚柒<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f7cfec9c14ad5c01fb7377beac0f9ffbac1dc2d1","tid":1552031,"uid":282535,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-09T06:37:59.000Z","msg":"龍只係代表清帝國"},{"pid":"f40cc37ae652574087c7e3814720c0620ef81909","tid":1552031,"uid":237747,"like":1,"dislike":22,"score":-21,"citedBy":1,"replyTime":"2019-09-09T07:15:40.000Z","msg":"<img src=\"https://na.cx/i/1yYnoOb.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1yYnoOb.png&h=33e28626&s={SIZE}\" />"},{"pid":"2a36ce6a68380f441a52843ce75856fb3a0e3fa6","tid":1552031,"uid":35348,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-09T07:17:37.000Z","msg":"三色旗 黑藍黃<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0bbe145eb1db8a38298f3acd6fc02cf84ff1da57","tid":1552031,"uid":281966,"like":2,"dislike":0,"score":2,"quote":{"pid":"2c5ed411442132b5ab69fa194d91e990a21f087d","tid":1552031,"uid":235152,"like":6,"dislike":25,"score":-19,"citedBy":7,"replyTime":"2019-09-08T10:23:26.000Z","msg":"<img src=\"http://www.passiontimes.hk/flags/109.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F109.jpg%3Fv%3D1&h=372e409a&s={SIZE}\" /><br />\n國旗用色以英國旗為基調配以暖黃突出國徽 紀念香港以英國文化之形響下成為集東西文化於一身之國度 國徽概念以洋紫荆之形浴火重生，以大鵬金翅鳥之形相重現 象徵香港歷中共浩刼而後自強獨立成國，必然有更美好前景<br />\n<br />\n<img src=\"http://www.passiontimes.hk/flags/110.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F110.jpg%3Fv%3D1&h=7711a38e&s={SIZE}\" /><br />\n<br />\n獅子山旗&mdash; 國旗由藍、白兩個平行相等的長方形及具象化的獅子山組成。正中的獅子象徵香港人不屈不撓的精神，中間的星代表港人獨立的意志和決心。藍色代表民主，自由；白色代表和平，公正。<br />\n<br />\n<img src=\"http://www.passiontimes.hk/flags/94.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F94.jpg%3Fv%3D1&h=f927caf3&s={SIZE}\" /><br />\n<br />\n木棉有英雄樹之稱，象徵香港雄視亞東；其花落不散，喻各地國民皆心繫母國；十八花蕊象徵十八區國民子嗣繁衍。金黃雲雷紋拱衛木棉，香港建國順天應人，承繼華夏。普魯士藍底色，象徵海洋，呼應英治。"},"citedBy":0,"replyTime":"2019-09-09T07:19:28.000Z","msg":"獅子旗<img src=\"/assets/faces/lm2/ok.gif\" class=\"hkgmoji\" />"},{"pid":"1b5a685bed85c91837b801ad3ab838d7b416c827","tid":1552031,"uid":155246,"like":2,"dislike":0,"score":2,"quote":{"pid":"2c5ed411442132b5ab69fa194d91e990a21f087d","tid":1552031,"uid":235152,"like":6,"dislike":25,"score":-19,"citedBy":7,"replyTime":"2019-09-08T10:23:26.000Z","msg":"<img src=\"http://www.passiontimes.hk/flags/109.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F109.jpg%3Fv%3D1&h=372e409a&s={SIZE}\" /><br />\n國旗用色以英國旗為基調配以暖黃突出國徽 紀念香港以英國文化之形響下成為集東西文化於一身之國度 國徽概念以洋紫荆之形浴火重生，以大鵬金翅鳥之形相重現 象徵香港歷中共浩刼而後自強獨立成國，必然有更美好前景<br />\n<br />\n<img src=\"http://www.passiontimes.hk/flags/110.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F110.jpg%3Fv%3D1&h=7711a38e&s={SIZE}\" /><br />\n<br />\n獅子山旗&mdash; 國旗由藍、白兩個平行相等的長方形及具象化的獅子山組成。正中的獅子象徵香港人不屈不撓的精神，中間的星代表港人獨立的意志和決心。藍色代表民主，自由；白色代表和平，公正。<br />\n<br />\n<img src=\"http://www.passiontimes.hk/flags/94.jpg?v=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.passiontimes.hk%2Fflags%2F94.jpg%3Fv%3D1&h=f927caf3&s={SIZE}\" /><br />\n<br />\n木棉有英雄樹之稱，象徵香港雄視亞東；其花落不散，喻各地國民皆心繫母國；十八花蕊象徵十八區國民子嗣繁衍。金黃雲雷紋拱衛木棉，香港建國順天應人，承繼華夏。普魯士藍底色，象徵海洋，呼應英治。"},"citedBy":0,"replyTime":"2019-09-09T07:20:32.000Z","msg":"圖1 成個香港航空咁"},{"pid":"45b0428dbe32816d897e55fe2fc31bbb81ab5df9","tid":1552031,"uid":189077,"like":0,"dislike":13,"score":-13,"citedBy":0,"replyTime":"2019-09-09T07:22:32.000Z","msg":"<img src=\"https://na.cx/i/dZFEq3x.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FdZFEq3x.jpg&h=fad9da94&s={SIZE}\" /><br />\n<br />\n藍黃獅子旗，為了香港！"},{"pid":"a3ad45a6157d8041ce2e26dc092865f04b573484","tid":1552031,"uid":281334,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"