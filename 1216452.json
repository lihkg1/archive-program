VC.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLUxq7VC.gif&h=721ac9a4&s={SIZE}\" /><br />\n<br />\n<strong>一名少年於金鐘一帶背向警察站立，遭十多名速龍小隊成員<span style=\"color: red;\">強行拉扯到地上用警棍圍毆</span>。</strong><br />\n<br />\n<img src=\"https://na.cx/i/aQu85Ja.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaQu85Ja.gif&h=0ec58946&s={SIZE}\" /> <br />\n<br />\n<strong>一名少女下午於立法會地下門外落單，遭近十名警員<span style=\"color: red;\">以盾牌及警棍按倒地上瘋狂圍毆</span>。</strong><br />\n<br />\n<img src=\"https://na.cx/i/wk41Gxi.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fwk41Gxi.gif&h=5c8616cb&s={SIZE}\" /><br />\n<br />\n<strong>一名手無寸鐵市民於大會堂對出方向，遭4-5名警員<span style=\"color: red;\">揮棍不停攻擊頭部倒地。</span></strong><br />\n<br />\n<img src=\"https://i.lihkg.com/540/https://na.cx/i/4g17BRj.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%2Fi%2F4g17BRj.gif&h=509faf8a&s={SIZE}\" /><br />\n<br />\n<strong>一名外藉男子於愛丁堡廣場附近，因行動不便獨自坐於花槽旁，<span style=\"color: red;\">遭警員以胡椒噴劑近距離向臉部射擊。</span></strong><br />\n<br />\n<img src=\"https://na.cx/i/eLz5ovx.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeLz5ovx.gif&h=58851dc8&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/i8PQzCe.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fi8PQzCe.gif&h=58a9a71f&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/UvSnqJW.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUvSnqJW.gif&h=c1469b1b&s={SIZE}\" /><br />\n<br />\n<strong>下午時份於金鐘天橋附近一帶，一名中年婦人向警員哭求停止對香港人使用武力，<span style=\"color: red;\">遭警員近距離以不明武器擊中頭部。</span></strong><br />\n<br />\n<img src=\"https://i.lihkg.com/540/https://na.cx/i/d6KQzNf.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%2Fi%2Fd6KQzNf.gif&h=b3ebd9eb&s={SIZE}\" /><br />\n<br />\n<strong>一名市民於金鐘橋底下，遭警員<span style=\"color: red;\">以布袋彈瞄準頭部射擊</span>。</strong><br />\n<br />\n<br />\n同場加映：<br />\n示威者吐血<br />\n<a href=\"https://youtu.be/hRCPds07zSM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FhRCPds07zSM&d=BSpFugi7VYdA%2F48z81zRmUcGFqE5jXx4AE4DM0839cs%3D&h=74975088\" data-auto-link target=\"_blank\">https://youtu.be/hRCPds07zSM</a> <br />\n<br />\n拖行暈倒示威者<br />\n<a href=\"https://youtu.be/GfhHJqNVPig\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FGfhHJqNVPig&d=BSpFugi7VYdA%2F48z81zRmUcGFqE5jXx4AE4DM0839cs%3D&h=36056931\" data-auto-link target=\"_blank\">https://youtu.be/GfhHJqNVPig</a> <br />\n<br />\n唔比救護車入<br />\n<a href=\"https://youtu.be/mT8SH2EJctk\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FmT8SH2EJctk&d=BSpFugi7VYdA%2F48z81zRmUcGFqE5jXx4AE4DM0839cs%3D&h=70c461cf\" data-auto-link target=\"_blank\">https://youtu.be/mT8SH2EJctk</a> <br />\n<br />\n地鐵站噴椒<br />\n<a href=\"https://youtu.be/sQk9mLw07WM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FsQk9mLw07WM&d=BSpFugi7VYdA%2F48z81zRmUcGFqE5jXx4AE4DM0839cs%3D&h=0b1b3b45\" data-auto-link target=\"_blank\">https://youtu.be/sQk9mLw07WM</a> <br />\n<br />\n開槍<br />\n<a href=\"https://youtu.be/9bbFANmVWZ4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F9bbFANmVWZ4&d=BSpFugi7VYdA%2F48z81zRmUcGFqE5jXx4AE4DM0839cs%3D&h=1dce89a0\" data-auto-link target=\"_blank\">https://youtu.be/9bbFANmVWZ4</a> <br />\n<br />\n向記者放tear gas<br />\n<a href=\"https://youtu.be/cWZ0R67V5Yg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FcWZ0R67V5Yg&d=BSpFugi7VYdA%2F48z81zRmUcGFqE5jXx4AE4DM0839cs%3D&h=46a72fb6\" data-auto-link target=\"_blank\">https://youtu.be/cWZ0R67V5Yg</a> <br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">強烈建議歐美向對示威者施過度武力嘅警察懲處！終生不得踏入歐美國家半步！呢班人渣注定世世代代共享中國人嘅榮耀</span></span>"},{"pid":"a0c05da340b3c54f85c2aa3e41a0f8e6afeb5458","tid":1216452,"uid":143343,"like":21,"dislike":0