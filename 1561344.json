like":9,"dislike":0,"score":9,"quote":{"pid":"9015bb0bebd43e6482b60728e2c1ab8f53441f3b","tid":1561344,"uid":245670,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-09-11T14:36:06.000Z","msg":"<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-11T14:38:02.000Z","msg":"好啦咁<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: x-large;\">就係「愛滋藥」</span></span><br />\n<br />\n絕對唔係有歧視 但touch wood 比人捉左去新屋嶺<br />\n叫天不應 叫地不聞<br />\n只可以諗各樣方法保護自己<br />\n<br />\n如果你有「愛滋藥」（未必要真藥）<br />\n+ 手機好多有關控制病情既folder / 手機lock screen 已經係有關既圖<br />\n<br />\n佢又無得fc 你係咪真係有<br />\n至少可以阻嚇到d 垃圾姦女義士<br />\n男義士比人打到流曬血 一行近就噴血or 噴口水<br />\n顏射落佢面 <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><br />\n再行近就再噴 <br />\n<br />\n佢唔信就再補d 數據佢聽<br />\n&quot;至2018年年底，中國大陸存活愛滋病感染者約125萬&quot;<br />\n&quot;香港 自1984年以來，累積發現8,053人受愛滋病病毒感染&quot;<br />\n<br />\n<br />\n當然我唔清楚入面咩情況 做唔做到咁理想真係唔清楚<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n希望拋磚引玉 大家再諗下有咩保護自己既方法"},"citedBy":0,"replyTime":"2019-09-12T03:51:57.000Z","msg":"收到"},{"pid":"e77eb4ba5f55ac52767b4b37421c1005f740e610","tid":1561344,"uid":183950,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T03:57:00.000Z","msg":"其實又唔會<br />\n當義士有就到對方驚<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"a900699a125a1c82858f06acb9946dddc6f609e3","tid":1561344,"uid":223198,"like":0,"dislike":0,"score":0,"quote":{"pid":"1f650c5490e13452b4cb584867218136bb966a4a","tid":1561344,"uid":72228,"like":15,"dislike":0,"score":15,"citedBy":3,"replyTime":"2019-09-11T14:35:14.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-12T03:57:33.000Z","msg":"<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"f017f5a7a15b483a9cfa038f7a73e5cbd4bc69db","tid":1561344,"uid":82536,"like":0,"dislike":0,"score":0,"c