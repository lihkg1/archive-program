F6n3WK8P.png&h=1b852422&s={SIZE}\" /><br />\n<br />\n推呀<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-23T09:59:55.000Z","msg":"<img src=\"https://na.cx/i/x5TGWgg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fx5TGWgg.jpg&h=ef34f276&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-07-23T10:14:24.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"4fc68205411c8b54f6ed659433fb9c3904ce260e","tid":1353623,"uid":263423,"like":0,"dislike":0,"score":0,"quote":{"pid":"93a2dc9a36cea973eb730bfab11503179cb771f0","tid":1353623,"uid":112405,"like":0,"dislike":0,"score":0,"quote":{"pid":"e54e1448c79583295a0cc48f931e0b7e1a1e7564","tid":1353623,"uid":263423,"like":0,"dislike":0,"score":0,"quote":{"pid":"0d3e8d64cbbe8be5b5cdabb515c4f07ce0378deb","tid":1353623,"uid":151987,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-23T09:57:42.000Z","msg":"<img src=\"https://na.cx/i/6n3WK8P.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6n3WK8P.png&h=1b852422&s={SIZE}\" /><br />\n<br />\n推呀<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-23T09:59:55.000Z","msg":"<img src=\"https://na.cx/i/x5TGWgg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fx5TGWgg.jpg&h=ef34f276&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-07-23T10:14:24.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-23T10:20:55.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d0e2e3cda9c98c4d7b2c52f26c8491727d04285c","tid":1353623,"uid":174084,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-23T12:17:19.000Z","msg":"好似有D道理<img src=\"/assets/faces/lm2/think.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://www.facebook.com/chuhoidick/photos/a.203826656349933/2352511678148076/?type=3&amp;theater\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fchuhoidick%2Fphotos%2Fa.203826656349933%2F2352511678148076%2F%3Ftype%3D3%26theater&d=3INNoT16QYf2eZrqTwRUihV%2B9HGzyIzIqBo2vIhly3s%3D&h=af4fcfdd\" data-auto-link target=\"_blank\">https://www.facebook.com/chuhoidick/photos/a.203826656349933/2352511678148076/?type=3&amp;theater</a><br />\n八鄉朱凱廸 Chu Hoi Dick<br />\n <br />\n【727挖墳拆祠堂=幫何君堯上彈 令「保家衞族」劇本成真】<br />\n<br />\n1) 721元朗無差別襲擊案，是「香港版義和團事件」，上線是中聯辦，中線是保皇派政治人物，下線是與該人合作開的幫會領袖。幫會領袖以「保家衛族」作為意識形勢，再以假消息誤導村勇/幫會兄弟，讓他們以為會有民主派議員﹝包括鄺俊宇和我﹞在7月21日帶幾百人到元朗「搞事」。結果事件演變成無差別襲擊正在回家的元朗、天水圍和屯門居民，完全與「保家衛族」風馬牛不相及，全城鬧爆。傳聞幫會領袖已離港避風頭。<br />\n<br />\n2) 這次事件，一方面利用了傳統鄉村的「保家衛族」意識形態作動員，另一方面亦採用了各地專制政府的「流氓管治策略」──警察刻意退場，任由流氓攻擊政敵，以製造恐慌。民眾無法忍受混亂的「無警時分」，政權就得以強勢回歸，並將流氓恐嚇常態化。俄羅斯、中國、伊朗都是好此道者。<br />\n<br />\n3) 按目前的形勢，負責721襲擊的幫會力量已被壓制，暫時應難以在元朗或其他地區發動大型襲擊，鄉議局和民建聯亦高調與白衫暴徒切割。其中鄉議局的聲明及主席劉業強的發言，更是可圈可點。聲明不接受721襲擊是「保家衛族」，反映主流鄉事派不希望被元朗幾條村的鄉黑勢力騎劫，破壞整體鄉事派形象﹝雖然本身都冇乜﹞。網上亦有不少原居民留言，表示自己來自元朗的村落，但並不認同721襲擊，希望市民在表達憤怒時要區分清楚。<br />\n<br />\n4) 我今早在港台訪問上指出，何君堯不是一個人，他是一種現象，背後是北京在香港發展「義和團暴民政治」的陰謀。就算沒有何君堯，北京也會找另一個代言人擔當煽動暴力角色。這種角色的特點是，你愈對他發動暴力攻擊，他的政治能量就愈大，其支持者也會被煽動報復，激起惡性循環。<br />\n<br />\n5) 我們更加要警惕的是，千萬不要將對721暴民的憤怒，發展成攻擊鄉村、村內祠堂或祖墳的行動。如前所述，721是一次假的「保家衛族」行動，所以失盡民心，很多敢怒而不敢言的原居民都不恥暴徒所為。但是，一旦示威者主動破壞祠堂或祖墳，即是對所有宗族成員﹝不管他/她是否黑社會或有沒有參與打人﹞宣戰，到其時，整個新界鄉議局廿七鄉的鄉村領袖都沒有選擇，要替祠堂或祖墳被破壞的鄉村報復，與所有反送中運動的參與者為敵。本來絕對站不住腳的原居民「保家衛族」抗爭，就會弄假成真，戰友「送頭」兼樹敵，最尾出來收割的政治贏家又係何君堯。<br />\n<br />\n6) 香港不容警黑合作，721襲擊必須追究到底。一日政府不回應五大訴求，香港人一定抗爭到底。"}]}