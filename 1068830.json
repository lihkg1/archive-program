{"tid":1068830,"cid":19,"subCid":0,"title":"油麻地男子留遺書墮樓亡","createTime":"2019-03-19T13:34:29.000Z","updateTime":"2019-03-19T18:03:06.000Z","uid":160807,"like":3,"dislike":0,"uniUserReply":4,"replies":[{"pid":"3996327ea9b065cd04545504e66f9d51f42ff65e","tid":1068830,"uid":160807,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-19T13:34:29.000Z","msg":"<img src=\"https://static.appledaily.hk/images/e-paper/20190319/large/1552956197_df30.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20190319%2Flarge%2F1552956197_df30.jpg&h=ac628403&s={SIZE}\" /><br />\n<br />\n油麻地利業街15號一後巷，凌晨4時許，警員巡經時發現一名63歲姓陳男子倒卧地上昏迷，即時將他送院搶救，但陳男最終不治。警員調查後，相信陳男由大廈天台墮下，又撿獲遺書，現場地面遺下一副假牙，案件初步沒有可疑。<br />\n<br />\nrip<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://hk.news.appledaily.com/breaking/realtime/article/20190319/59384474\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20190319%2F59384474&d=pHv7ulxaPAPTUdGhwq1YMeBrFmK%2FfjgW9YhWFGnkYF4%3D&h=6d8324cf\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Fbreaking%2Frealtime%2Farticle%2F20190319%2F59384474&h=361187f0\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/breaking/realtime/article/20190319/59384474</a>"},{"pid":"2b05b5963604c4886dd37ce796c38a6aaf34777f","tid":1068830,"uid":71508,"like":1,"dislike":3,"score":-2,"citedBy":2,"replyTime":"2019-03-19T13:35:13.000Z","msg":"廢老-1"},{"pid":"d8d91887221a194d1227656e5412e6c780db019c","tid":1068830,"uid":149329,"like":3,"dislike":2,"score":1,"quote":{"pid":"2b05b5963604c4886dd37ce796c38a6aaf34777f","tid":1068830,"uid":71508,"like":1,"dislike":3,"score":-2,"citedBy":2,"replyTime":"2019-03-19T13:35:13.000Z","msg":"廢老-1"},"citedBy":0,"replyTime":"2019-03-19T13:37:49.000Z","msg":"口德分-1"},{"pid":"7bf900f62e965d751dcabc492f898be15553db31","tid":1068830,"uid":154255,"like":