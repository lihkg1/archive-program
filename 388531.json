ookie.net/evchk/images/9/94/4MG7kQw.gif/revision/latest?cb=20140422075612\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fevchk%2Fimages%2F9%2F94%2F4MG7kQw.gif%2Frevision%2Flatest%3Fcb%3D20140422075612&h=d8e6e7e6&s={SIZE}\" />"},{"pid":"568c904d5f3cf0c050d2a58bcd2ee35a672ca128","tid":388531,"uid":66943,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-05T20:07:56.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"http://www.3636dy.com/dongman/24811/0-2.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.3636dy.com%2Fdongman%2F24811%2F0-2.html&d=03AktAJquTfWmOz0pf1dJi7bS0i5kAixZS1hjGmvpwM%3D&h=b84f92c6\" target=\"_blank\">http://www.3636dy.com/dongman/24811/0-2.html</a>"},{"pid":"4390a18cee3a61cd049f065f771dd38818990785","tid":388531,"uid":142233,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-05T20:11:19.000Z","msg":"<blockquote>馬鞍山半裸女離奇死亡惹兇案驚魂，晚上近7時，一名男子返回錦豐苑錦萱閣住所時，赫見胞姊（37歲）倒臥家中，口吐白沫陷於昏迷，由於其衣衫不整及下半身赤裸，下體更有血滲出，懷疑她曾受性侵犯，慌忙報警求助。救護員趕至現場，將女事主抬上擔架床，由救護車將她送院，惜<span style=\"color: red;\">證實不治</span>。<br />\n<br />\n據了解，醫生初步檢查後，不排除因外來因素造成，因事件撲朔迷離，一時間未確定事件是否有可疑，遂交由沙田警區重案組接手調查，其後聯絡到女事主一名男性友人助查。<br />\n<br />\n消息指，探員經深入調查後，發現女事主為紅斑狼瘡症及類風濕關節炎患者，近日因事不快，搬到上址與胞弟同住，不排除傷口因病造成，並因病發失救致死，<span style=\"color: red;\">案件列有人暈倒處理，</span>初步相信事件無可疑，確實原因有待進一步調查。</blockquote><br />\n咩料"},{"pid":"ccc7f3ff68efdab99bcbe37fcc020757e1ae1988","tid":388531,"uid":98624,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-05T22:26:39.000Z","msg":"屌穿你個閪啊屌爆你個閪啊"},{"pid":"28582322569f82b82e3a9a71fa64a36377a68cca","tid":388531,"uid":83060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-05T22:32:17.000Z","msg":"女果陰道搵到細佬精液可以點拆?"},{"pid":"a3674b9098c2abe3708328fc8673261fc8017eb0","tid":388531,"uid":99346,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-05T22:46:46.000Z","msg":"<blockquote><blockquote>從前有個人叫阿爽。<br />\n<br />\n他死掉了。 。 。<br />\n<br />\n出殯那天。<br />\n<br />\n他的家人哭喊：爽阿&hellip;&hellip;爽阿。<br />\n<br />\n路人不解。問道：&lsquo;你們爽什麼啊。 &rsquo;<br />\n<br />\n家人痛哭流涕：爽死了&hellip;&hellip;爽死了!!</blockquote><br />\n好撚好笑？<br />\n積下口德啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n真係幾好笑<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}