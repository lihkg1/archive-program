/371174/%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B-3%E8%A2%AB%E6%8D%95%E5%AD%B8%E7%AB%A5%E8%A2%AB%E5%88%A4%E5%85%A5%E5%85%92%E7%AB%A5%E9%99%A2-%E5%85%92%E7%AB%A5%E6%AC%8A%E5%88%A9%E5%A7%94%E5%93%A1%E6%9C%83%E6%96%A5%E5%81%9A%E6%B3%95%E4%B8%8D%E7%95%B6</a><br />\n<br />\n去問下UNICEF 割唔割黑警"},{"pid":"bf95202559321a76e43a75d480e56f25cf68ed60","tid":1537013,"uid":267425,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T19:10:40.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>解散警隊 刻不容緩</strong></span></span><br />\n<br />\n我屌曬你地老母快啲推第六大訴求<br />\n<a href=\"https://lih.kg/1536852\" data-auto-link target=\"_blank\">https://lih.kg/1536852</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<img src=\"https://na.cx/i/iBWrQR5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiBWrQR5.jpg&h=8316617f&s={SIZE}\" />"}]}