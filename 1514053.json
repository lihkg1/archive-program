ps%3A%2F%2Fna.cx%2Fi%2FOCBypV8.gif&h=d3183b47&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/tqFvr8Y.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FtqFvr8Y.gif&h=4c38f9ed&s={SIZE}\" /><img src=\"https://na.cx/i/3prq0tY.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3prq0tY.jpg&h=40f5c367&s={SIZE}\" />"},{"pid":"5af1d3722347e9550f4af4e917e4f91732f11451","tid":1514053,"uid":57677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:12:00.000Z","msg":"<img src=\"https://na.cx/i/uu6eUTD.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fuu6eUTD.png&h=e6f79686&s={SIZE}\" />"},{"pid":"9404ec507a396bb8c9bed876bb30914761bee960","tid":1514053,"uid":90073,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:14:02.000Z","msg":"每日準時嗌<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n不嬲唔洗搭地鐵<br />\n做唔到跳閘task<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"25dfd938d42a043209544f3922e6580fdbcb70cd","tid":1514053,"uid":108687,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:15:36.000Z","msg":"跳閘 (2/4)<br />\n大叫 (0/1)"},{"pid":"8123ea13da9c9517b79f6000caf20791e83fbbc7","tid":1514053,"uid":147785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:20:06.000Z","msg":"做任務 做任務"},{"pid":"d416b6c0b169d1e064cafa4d216f663f7973d080","tid":1514053,"uid":147785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:31:19.000Z","msg":"推呀 做每日任"},{"pid":"3dc36c5b188d5c3e2781aab735cc3195e6059df0","tid":1514053,"uid":147785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:42:18.000Z","msg":"3"},{"pid":"0aa8aeb325abe5927e7e324be4eb9bca0f5b06e9","tid":1514053,"uid":147785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T15:50:44.000Z","msg":"2"},{"pid":"a8b77463cca70308b34a5583a6e2b8cf438c0