7e93cd03f08e93dfcbc801f3891","tid":1724373,"uid":173599,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:30:57.000Z","msg":"老豆搵仔見<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},{"pid":"eb39e7b3e36df070f056b7a966587edeb5aeb821","tid":1724373,"uid":119610,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:31:36.000Z","msg":"推"},{"pid":"e77cced107a96e51c6f0bfd3978c68007e33806a","tid":1724373,"uid":287211,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:31:44.000Z","msg":"我好尊重民安隊<br />\n千萬不要傷害他們的車 <br />\n起底也不要 不過 提提大家 老豆搵仔又番咗嚟"},{"pid":"3f2341bd2d590d14edd24be0e4e45aad901c625a","tid":1724373,"uid":24730,"like":1,"dislike":0,"score":1,"quote":{"pid":"4ccabfbb68e82749cd677ac32cacfbac301b1598","tid":1724373,"uid":335434,"like":11,"dislike":0,"score":11,"citedBy":2,"replyTime":"2019-11-15T13:20:57.000Z","msg":"<blockquote>膊頭有花既民安隊朋友冇連登account  幫手轉貼<br />\n<br />\n「民安隊人有黃有藍 有前線手足亦有垃圾廢老<br />\n但重點係所有更係自己報名 冇人可以逼你當更<br />\n所以報得呢啲更既係手足定廢老大家自己諗<br />\n而民記裝備只係得個爛鬼頭盔有啲用 <br />\n手足連狗都唔驚 民記嗰班叫佢行山都懶既廢老係毫無威脅<br />\n不過 同佢哋正面衝突係冇意思 清路障行動多數有狗係附近<br />\n所以應對方法有二<br />\n1) 佢哋最驚係被起底 做副業做到要俾人全家起曬底既話 你估仲有冇藍屍廢老報呢啲更<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><br />\n所以大家街坊行過影低下佢哋啲樣 老豆搵仔見 身邊總有一個人識佢哋<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n2) 民記車出名維修耐 仲要得嗰幾部 唔好話爆玻璃 就算只係爆胎爆倒後鏡 佢嚟緊所有活動都唔使出人<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /><br />\n順帶一提 民記每次選舉都幾乎要總動員出去票站做人群管理 到時如果冇車唔知點算呢<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n如果有一日保安局真係用緊急動員令要民安隊人出動<br />\n記者朋友們準備定鏡頭影住一車車民記人全套制服加入示威者行列啦<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />」</blockquote><br />\n柒婆出完call out跟住影到成堆著晒政府制服嘅人走去示威果邊..諗起個畫面都夠晒爆..肯定國際報章頭版<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-15T14:32:57.000Z","msg":"新軍叛變，可惜冇武器<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"1f9f8e2ed4bac5e5de3aa4e7552029d106372cdf","tid":1724373,"uid":13318,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:35:55.000Z","msg":"唔好推"},{"pid":"e38090a7f74b7447e0cd4b74f7fc396a45a35a12","tid":1724373,"uid":146535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:37:36.000Z","msg":"推"},{"pid":"08151112e0bba75301c5995822a2b50dab87e9b3","tid":1724373,"uid":151324,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:41:12.000Z","msg":"yes sir"},{"pid":"976fddb6ef61d68c9ea9f322898b3c1b2dc1b59d","tid":1724373,"uid":262575,"like":0,"dislike":0,"score":0,"quote":{"pid":"3f2341bd2d590d14edd24be0e4e45aad901c625a","tid":1724373,"uid":24730,"like":1,"dislike":0,"score":1,"quote":{"pid":"4ccabfbb68e82749cd677ac32cacfbac301b1598","tid":1724373,"uid":335434,"like":11,"dislike":0,"score":11,"citedBy":2,"replyTime":"2019-11-15T13:20:57.000Z","msg":"<blockquote>膊頭有花既民安隊朋友冇連登account  幫手轉貼<br />\n<br />\n「民安隊人有黃有藍 有前線手足亦有垃圾廢老<br />\n但重點係所有更係自己報名 冇人可以逼你當更<br />\n所以報得呢啲更既係手足定廢老大家自己諗<br />\n而民記裝備只係得個爛鬼頭盔有啲用 <br />\n手足連狗都唔驚 民記嗰班叫佢行山都懶既廢老係毫無威脅<br />\n不過 同佢哋正面衝突係冇意思 清路障行動多數有狗係附近<br />\n所以應對方法有二<br />\n1) 佢哋最驚係被起底 做副業做到要俾人全家起曬底既話 你估仲有冇藍屍廢老報呢啲更<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><br />\n所以大家街坊行過影低下佢哋啲樣 老豆搵仔見 身邊總有一個人識佢哋<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n2) 民記車出名維修耐 仲要得嗰幾部 唔好話爆玻璃 就算只係爆胎爆倒後鏡 佢嚟緊所有活動都唔使出人<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" /><br />\n順帶一提 民記每次選舉都幾乎要總動員出去票站做人群管理 到時如果冇車唔知點算呢<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n如果有一日保安局真係用緊急動員令要民安隊人出動<br />\n記者朋友們準備定鏡頭影住一車車民記人全套制服加入示威者行列啦<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />」</blockquote><br />\n柒婆出完call out跟住影到成堆著晒政府制服嘅人走去示威果邊..諗起個畫面都夠晒爆..肯定國際報章頭版<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-15T14:32:57.000Z","msg":"新軍叛變，可惜冇武器<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-15T14:41:44.000Z","msg":"救人工具比較多，<br />\n武器諗唔到有乜<img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" />"},{"pid":"bf377fc60ff230b7d0a0df111fe852a194b24653","tid":1724373,"uid":258602,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:43:39.000Z","msg":"真係好過份<img src=\"/assets/faces/pig/bye.gif\" class=\"hkgmoji\" />"},{"pid":"5937e489cfbd0077b9fe93f9d0434160be7d8d5a","tid":1724373,"uid":101383,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:43:56.000Z","msg":"推"},{"pid":"7526d01903d58b522b5e014b431861a8e00bce58","tid":1724373,"uid":78510,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2019-11-15T14:44:25.000Z","msg":"點解黃嘅唔報名<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 有公權力嘅同路人<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e6df334eb4cd5bc8c4d1786b60318dd62d728ca1","tid":1724373,"uid":50055,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-15T14:45:58.000Z","msg":"禁老豆唔比搵仔個令好似只係比狗?<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"0978b1bf39017a738d750fef2ae8666301f114b5","tid":1724373,"uid":138594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:46:44.000Z","msg":"推"},{"pid":"47120e8aced888ca7e7cb0c6bace964790876a47","tid":1724373,"uid":121716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:47:04.000Z","msg":"輕輕一推<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"59c3a36097b27ba6bf7b924eecd118d299b474c2","tid":1724373,"uid":29739,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:52:21.000Z","msg":"push"},{"pid":"d5da35ad6c752003daefda4d9b4de79e998111ed","tid":1724373,"uid":166245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T14:55:08.000Z","msg":"民記阿伯唔驚二噁英？"},{"pid":"402796bc01928f63616072f60eda8e05af922821","tid"