t9.gif&h=11a04d32&s={SIZE}\" />"},{"pid":"2b13f5774406bb6b2b8f5ee8d3062bed7564627b","tid":1284722,"uid":151700,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T09:50:31.000Z","msg":"<img src=\"https://na.cx/i/gmMKzt9.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgmMKzt9.gif&h=11a04d32&s={SIZE}\" />"},{"pid":"e663b58320ea37148b9787d2c53b34f9817fc178","tid":1284722,"uid":151700,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T09:52:36.000Z","msg":"<img src=\"https://na.cx/i/gmMKzt9.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgmMKzt9.gif&h=11a04d32&s={SIZE}\" />"},{"pid":"986ddfa044ce262a197ce7fb484892db6cddd1bc","tid":1284722,"uid":151700,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T09:56:04.000Z","msg":"<img src=\"https://na.cx/i/gmMKzt9.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgmMKzt9.gif&h=11a04d32&s={SIZE}\" />"},{"pid":"bd48e1c417d1c305c7fce6561d3ea93881189231","tid":1284722,"uid":65300,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-04T09:57:54.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"f43f3d7f1840d55c2b7d10428ec7b3faad3dd449","tid":1284722,"uid":151700,"like":1,"dislike":0,"score":1,"quote":{"pid":"bd48e1c417d1c305c7fce6561d3ea93881189231","tid":1284722,"uid":65300,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-04T09:57:54.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-04T10:00:30.000Z","msg":"Privacytool果度有推介<br />\nProtonVPN有free版而且速度還可接受（之前試過用黎睇abematv 唔知家下有冇block)<br />\n其他vpn未試過<br />\n講真私隱有價可考慮下果堆要比錢既我覺得"},{"pid":"7e3cadf78cba1bd25fc10ad9478dd2131a09b2db","tid":1284722,"uid":151700,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T10:00:57.000Z","msg":"<img src=\"https://na.cx/i/gmMKzt9.gif\" data-thumbnail-src=\"https://i.lih.kg/