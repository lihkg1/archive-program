%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F01%2F27%2F034715_0fa2c283db9fc282f5da6b7b3335da07.gif&h=4ce43269&s={SIZE}\" />"},"citedBy":2,"replyTime":"2019-02-03T14:11:05.000Z","msg":"有觀眾嚟到呢幕頂唔順，出咗去<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5c82bd3036ff50f9df4e7c5f0b81aa67db4a17ed","tid":994501,"uid":7329,"like":0,"dislike":0,"score":0,"quote":{"pid":"675d8916e25f41d52996018f1719523df2f4fb1d","tid":994501,"uid":182951,"like":0,"dislike":2,"score":-2,"quote":{"pid":"4cd0686b6f5e41a7f36b04a14b547263a8ad0ee8","tid":994501,"uid":27616,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-01-26T19:49:20.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2019/01/27/034715_0fa2c283db9fc282f5da6b7b3335da07.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F01%2F27%2F034715_0fa2c283db9fc282f5da6b7b3335da07.gif&h=4ce43269&s={SIZE}\" />"},"citedBy":2,"replyTime":"2019-02-03T14:11:05.000Z","msg":"有觀眾嚟到呢幕頂唔順，出咗去<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-03T14:30:05.000Z","msg":"呢幕既前一part有啲睇唔明<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 唔係好明無啦啦點解會咁"},{"pid":"d767ff36ceaf0699205c293c277db5e08cd8d4bb","tid":994501,"uid":118767,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-02-03T15:58:52.000Z","msg":"冇睇過Argento 77年版本冇得比較，但聞說77原作劇本相對簡單，新作則取其形，然後塑造出全新嘅故事，內容層次多而複雜，不但扣連七十年代西德政治氛圍，又融入神秘主義、舞蹈、歷史等元素。全片充塞大量意像隱喻，訊息量極多，不容易消化，整體定位偏鋒，絕非一般荷里活口味，但以兩個半鐘片長嚟計節奏算係頗快。<br />\n<br />\n<br />\n我覺得整體氣氛營造不俗，多用特色手法，如快速移鏡，復古得嚟陰森味濃，同導演前作《Call Me By Your Name》嘅陽光味大相逕庭。<br />\n<br />\n可能宣傳吹得太大，血腥程度冇想像中高，尾場血祭盛宴雖然大派血漿，但配合詭異舞蹈，迷離多於噁心，更有一種難以言喻嘅喜感。反而早段一場肢體扭曲虐殺戲睇得幾煎熬，係近年睇過最不安嘅場面之一。<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\nChloe比預期少戲，只係導入之用，反而Tilda Swinton甚具女皇風範，即使角色唔算立體，單單幾句對白戲都極其壓場，分飾多角亦令人眼前一亮，但要細心留意才可發現。<br />\n<br />\n相