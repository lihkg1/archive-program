39ad9adfe3640ca5b4aa69f9df826e8bfd","tid":1286140,"uid":234940,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T19:50:55.000Z","msg":"推"},{"pid":"86d85df65701a0f5f8c077ebf8b5fd5b819e0e82","tid":1286140,"uid":100356,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T19:51:55.000Z","msg":"推"},{"pid":"e0d1355ba2309ed39e83ec2d1f4ac3e2e7293d89","tid":1286140,"uid":96799,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c5ea8a317a8beffe59af8386511e63efb1d22db","tid":1286140,"uid":81273,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-04T19:38:01.000Z","msg":"老實講好難搞<br />\n大陸人根本好想你同佢一齊做中國人<br />\n你反乜春都會話你搞港獨<br />\n一搞港獨就會中左條根<br />\n佢地搞死香港都唔會俾香港走得甩"},"citedBy":0,"replyTime":"2019-07-04T20:43:09.000Z","msg":"你講既係無乜學識 又比人洗腦深 又衝動憤怒個班 可能係仇日會周街打爛日本車個班<br />\n<br />\n但係有好多讀過書既，<br />\n真係！只要我地可以以理服人，並且用軟攻唔用硬攻，咁就有機會！"},{"pid":"ae499903c950af2a0c5b919c8f0e609dd776f393","tid":1286140,"uid":67292,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-04T22:51:18.000Z","msg":"我無野講"},{"pid":"e3ac42b0cce6f2d1267647d1547a4f6fe159a3b1","tid":1286140,"uid":96799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-05T17:36:36.000Z","msg":"推！！！！"},{"pid":"4ab5806f0a687be1feb71b5df7cf42a3306a8746","tid":1286140,"uid":133427,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-07-06T11:15:47.000Z","msg":"輕輕一推<br />\n<br />\n會唔會有高手可以幫手出設<br />\n小弟聽日想幫手派，但唔擅長設計<br />\n<br />\n岩岩睇左其他post有講會唔會可以加d佢地切身處地既內容<br />\n例如黑心食物<br />\n黑心企業<br />\n官員外國國籍<br />\n<br />\n雖然都想寫多d有關克警既野，但未必引起佢地共嗚。"}]}