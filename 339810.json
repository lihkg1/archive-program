/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"82375bafb6b498790d2fbce11cdc86921b631109","tid":339810,"uid":28051,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-31T01:00:48.000Z","msg":"i"},{"pid":"2516f9f2892ba3f64f5112605cf874f725e9bb2f","tid":339810,"uid":15572,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-31T01:02:13.000Z","msg":"係我第一隻online game<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"3727b1dde2ecf432fe386a03ef02fddd60c241df","tid":339810,"uid":70221,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-31T01:42:23.000Z","msg":"<blockquote><blockquote>點解無私服</blockquote><br />\n因為無人有果個Server既檔<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />  保密太好</blockquote><br />\n雷爵d game好小見有私服<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a661be5a523c69eae32852934bb0cfd2fd0e96c9","tid":339810,"uid":38098,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-31T02:01:48.000Z","msg":"隻game真係衰左係外掛手上"},{"pid":"9ba4080f5d15f1bd11742ed0d1d141f8a2934832","tid":339810,"uid":93062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-31T02:06:44.000Z","msg":"<img src=\"https://holland.pk/6t2h3ceq\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2F6t2h3ceq&h=5de808ee&s={SIZE}\" />"},{"pid":"419f5592a20131113cf336c03e1d471fdc09bc45","tid":339810,"uid":127075,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-31T07:33:07.000Z","msg":"<blockquote><img src=\"https://holland.pk/6t2h3ceq\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2F6t2h3ceq&h=5de808ee&s={SIZE}\" /></blockquote><br />\n天外懶人族 同死仔包(好似係)<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><br />\n攻略都好齊全<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"fc363bcb41fe4b63fe4884f770912a3a7e514baa","tid":339810,"uid":8175,"like":0,"dislike":0,"score":0,"citedBy":0,"r