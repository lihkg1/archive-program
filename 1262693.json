1262693,"uid":136083,"like":0,"dislike":0,"score":0,"quote":{"pid":"211c173b5770147690d14471f69550409995167e","tid":1262693,"uid":185990,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-28T07:44:29.000Z","msg":"幫喇沙仔推po<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-28T08:10:33.000Z","msg":"盧萎蔥 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"4301512c339bb6ad3e63bbe94a506ef2ff279fee","tid":1262693,"uid":6833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-28T08:19:26.000Z","msg":"同意"},{"pid":"c54927367735e244841ccd92fbd0cec014fd2a9b","tid":1262693,"uid":136083,"like":0,"dislike":0,"score":0,"quote":{"pid":"cc2de0f61d6f4041280d0352f690f4e50887ef1f","tid":1262693,"uid":259901,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-28T07:50:45.000Z","msg":"你同民陣講先得<br />\n佢地一味鳩嗌「林鄭下台」都冇佢符<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-28T08:21:54.000Z","msg":"民陣要玩和理非拉中間派嘅話根本就應該聚焦獨立調查委員會哩個訴求，放林鄭下台喺第一位係放唔低哩二十年嘅迷思，以為七一就一定要主打拉特首下台。唔係要否定民陣，只係覺得聚焦唔到一個合情合理+最有機會爭取+各路兄弟都認同嘅訴求，實在有啲可惜"},{"pid":"a189427c45fa1a4eb061e9fef2c7ea320c0dee62","tid":1262693,"uid":136083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-28T08:23:21.000Z","msg":"理性討論，請比意見"},{"pid":"9c2a7780c28fd869e886ac14ff6abf9a4d622f8c","tid":1262693,"uid":135740,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-28T08:26:12.000Z","msg":"削一削班狗嘅勢力先啦 打人打到咁high<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"a05cef7d26145bbe1068a51d14a2f2c80c101b76","tid":1262693,"uid":136083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-28T08:28:03.000Z","msg":"其中可能出現嘅問題：<br />\n1. 放大哩個訴求就會令其他訴求相對縮細<br />\n2. 如果到時政府真係整個調查委員會，但全部安曬自己啲人入去，咁就又會令淺黃/中間派覺得政府已經讓步，最後調查完結果係警察冇做錯，跟住救唔到義士不突止仲追究唔到黑警責任"},{"pid":"4081e8128901e009a2021c693d3f82b4248168fc","tid":1262693,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-28T08:28:59.000Z","msg":"係<br />\n要打擊黑警呢班朝庭鷹犬"},{"pid":"95463cbf6662b20f9d13c6d1b2d8e004f208b6f7","tid":1262693,"uid":117673,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-28T08:29:53.000Z","msg":"PUSH"},{"pid":"ac9c81e602a219f30b18e636d7f706a2d8aad101","tid":1262693,"uid":136083,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c2a7780c28fd869e886ac14ff6abf9a4d622f8c","tid":1262693,"uid":135740,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-28T08:26:12.000Z","msg":"削一削班狗嘅勢力先啦 打人打到咁high<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-28T08:30:14.000Z","msg":"兩樣冇衝突，一定可以同步做。例如圍狗屋嘅時候多啲注重表達哩個訴求，取代部分純粹嘅發洩，更加可以落到佢地面"},{"pid":"5763887234377f04cb338bb1cba01ea9eb625d61","tid":1262693,"uid":266372,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-28T08:30:40.000Z","msg":"推"}]}