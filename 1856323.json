ets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />扮撚到自己做左野，我就唔撚信個保安聽到央視都敢攔，央視記者又扮到好撚守法咁，你係有心拍，女明星裙底都影到啦，影唔撚到個倉庫？搞撚笑咩"},{"pid":"a849ad8bc0e8f8ab2473890a7394503d2f111185","tid":1856323,"uid":250903,"like":0,"dislike":0,"score":0,"quote":{"pid":"80a6e186f4f662cee7a16609e292c88cc37e31ed","tid":1856323,"uid":149494,"like":0,"dislike":0,"score":0,"quote":{"pid":"1e57d00de6f5a49509f6df8e09855ffba16c6576","tid":1856323,"uid":51621,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-01T15:39:33.000Z","msg":"睇完ptt超簡單sum up<br />\n成件事既大佬係王岐山,借國難發大財"},"citedBy":1,"replyTime":"2020-02-01T15:45:30.000Z","msg":"同之前紅三代揸車入故宮一樣<br />\n係維尼用黎轉移視線既技倆<br />\n根本唔撚使理"},"citedBy":0,"replyTime":"2020-02-01T15:48:52.000Z","msg":"上網睇有王歧山同維尼內鬥緊既新聞<br />\n唔知真唔真<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ea0763e737d796f5d87c6bbe1a8e7598748fb4e1","tid":1856323,"uid":250903,"like":0,"dislike":0,"score":0,"quote":{"pid":"06d943e776a3d2f7869d960254e7613c12d908f3","tid":1856323,"uid":142712,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-02-01T15:15:28.000Z","msg":"上微博睇佢哋狗咬狗，好開心<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" />我係咪好黑心"},"citedBy":0,"replyTime":"2020-02-01T15:50:04.000Z","msg":"黑乜撚野心<br />\n支那狗唔抵同情<img src=\"/assets/faces/lny/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8952815f7a61ead437304e8b009e4f602645881d","tid":1856323,"uid":250903,"like":0,"dislike":0,"score":0,"quote":{"pid":"3242688e00684ff381bd485faa5f494d800412c8","tid":1856323,"uid":232949,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-02-01T15:24:12.000Z","msg":"所以真係咪撚捐任何野返大陸<br />\n錢又好物資又好 捐完淨係落到班貪官手"},"citedBy":0,"replyTime":"2020-02-01T15:51:13.000Z","msg":"點會仲捐<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji