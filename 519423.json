ice-hk.net/upload/2017/06/20/084606_43513e78aeb238c63fb2c3824dfd42e6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttp%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F20%2F084606_43513e78aeb238c63fb2c3824dfd42e6.jpg&h=c54a15e2&s={SIZE}\" /><br />\n<img src=\"https://i.lihkg.com/540/http://img.eservice-hk.net/upload/2017/06/20/084607_a51ee980eb67416a235df1b3888bc02d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttp%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F20%2F084607_a51ee980eb67416a235df1b3888bc02d.jpg&h=94248f8a&s={SIZE}\" /><br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">正啊，豆腐細五臟俱全！</span></span><span style=\"font-size: xx-large;\">🐷</span><br />\n<br />\n<img src=\"https://i.lihkg.com/540/http://livedoor.blogimg.jp/all_nations/imgs/e/0/e08e7c56.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttp%3A%2F%2Flivedoor.blogimg.jp%2Fall_nations%2Fimgs%2Fe%2F0%2Fe08e7c56.jpg&h=0bf9e2b0&s={SIZE}\" /><br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">福氣到極點</span></span><span style=\"font-size: xx-large;\">😻😻😻</span><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>超落後、超唔環保深圳你睇下幾多白煙</strong></span></span><br />\n<img src=\"https://i.lihkg.com/540/https://img.eservice-hk.net/upload/2017/07/11/074118_dd7e45444da53dcb3924d3b86c070673.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F11%2F074118_dd7e45444da53dcb3924d3b86c070673.jpg&h=0ac04b60&s={SIZE}\" /><br />\n<img src=\"https://i.lihkg.com/540/https://img.eservice-hk.net/upload/2017/07/11/074119_dd7e45444da53dcb3924d3b86c070673.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F11%2F074119_dd