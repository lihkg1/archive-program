/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"dc509699f3e924fd392c4ab6a4721704eed8be76","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T10:09:05.000Z","msg":"有無文宣圖可以share"},{"pid":"2830f1c7bbeb7c9de1d04f98264dd481705027ea","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T10:09:18.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"235ac2815eaf056dd996dab4bdade11d3bbd48da","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T10:09:30.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"0e78ea188d8676eb10a002f396897608d6594ecc","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T10:13:03.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3223eba0a573fbe1572e6a07b48d8aed2601f9b8","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T10:13:13.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"9812ef927a639d9e58e3213379ef959fc6bcf06a","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T10:13:23.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3c540ac0d3d4d1a43585d828f352f63e845ef9ce","tid":1394093,"uid":27198,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T10:41:51.000Z","msg":"幫推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"bc04dd3467b24c26db33b3e262e3c75c0f56afc3","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T11:29:28.000Z","msg":"thx<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"cc2d35aef4d8a31eb8165cf556d51cbd7d92932f","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T11:35:39.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"733cad8240d6b5e8c9dad30a6ccc553e2b69e767","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T11:35:50.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a1cbd35d22aea398b1f294fc569fe16b4f7bc6c4","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T11:36:00.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4595936daf76f9e2e91b4ace67d28b4f0d9a4c83","tid":1394093,"uid":6528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T11:41:33.000Z","msg":"全民8月5日大罷工！五大訴求，缺一不可！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n雙普選一定要排最頭，仲要好似美國咁設時限係2020年之前落實<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n全民黑衫、口罩同頭盔，返工返學行街，唔擺工既日子一齊做，將抗爭帶入生活，保護示威者<br />\n<a href=\"https://lih.kg/1379839\" data-auto-link target=\"_blank\">https://lih.kg/1379839</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n當新移民夠多，雙普選自然會落實，港共明顯會用偽民主反真港人<br />\n（雖然係舊post，但都想人諗下，一定要止左血先）<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1328467\" data-auto-link target=\"_blank\">https://lih.kg/1328467</a><br />\n<br />\n光復香港，時代革命！<br />\n－－－－－－－－－－－－－－－－－－－－－－－－－－－－－－－－<br />\n想比更多人知道其實而家呢一刻基本上得番<span style=\"color: gold;\">香港獨立</span>呢條路，<br />\n我知好多人未準備好，我知而家急唔黎。<br />\n但係想大家思考下，種下一個思想，唔好屌我住。<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n而家就算有真普選其實都係under中共！！<br />\n咁唔通去到2047再抗爭過咩，西方國家都出唔到手幫你地。<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n因為白紙黑字寫明50年，西方國家唔好話出手，連發聲既正當性都冇啊<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n可能好多前人都係到諗點解英國當時唔寫999年！<br />\n可能好多我地呢代既諗點解上一代冇去抗爭！<br />\n可能好多下一代係2047係到諗點解我地唔直接爭取獨立！！！<br />\n<br />\n我地唔可以好似上一代咁，計好哂數50年後都死左啦，唔好理啦。<br />\n我地唔可以再咁自私啦，過埋2047都嗰頭近啦，之後再算啦。<br />\n我想我地既下一代唔需要再為呢啲事再受苦啦，我只係希望下一代可以係呼吸住自由既空氣出世係呢個地球上。<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n所有既問題，所有既恩怨，係我地呢代到解決哂啦，好嗎？<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n所有問題去到最後只會追究到主權問題，希望大家思考下。<br />\n今次搞到咁大真係最後一次反擊同最大力量。<br />\n<br />\nBTW，五大訴求，缺一不可！<br />\n雙普選應要排最頭，仲要設時限，最好2020年之前！"},{"pid":"58f7cfc171d2b78bb71aa980af7862f027d45cdf","tid":1394093,"uid":261113,"like":0,"dislike":0,"score":0,"quote":{"pid":"af40b6c1379dc80986466cbead58f0626bc1031e","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-01T09:59:25.000Z","msg":"和大家share 多啲 文宣，長輩圖<br />\n提供fb gp link<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: orange;\">鍵盤戰士！！assemble</span></span>"},"citedBy":0,"replyTime":"2019-08-01T12:31:58.000Z","msg":"幾有道理，幫手幫手推"},{"pid":"97f32b8da1b53c397c352ef306523e071b66dc33","tid":1394093,"uid":82829,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T12:44:55.000Z","msg":"有"},{"pid":"82f05756888d5c7eda42287a5467684662aa075c","tid":1394093,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-01T12:45:56.000Z","msg":"吃力"},{"pid":"995cb43339e796e5a390eb0b9e65d741213f27c7","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"quote":{"pid":"82f05756888d5c7eda42287a5467684662aa075c","tid":1394093,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-01T12:45:56.000Z","msg":"吃力"},"citedBy":0,"replyTime":"2019-08-01T13:18:26.000Z","msg":"鍵盤戰士係要俾多啲腦力<br />\n頂硬上"},{"pid":"0bf9f1aa8f1afab610b1b26652b96af733c22085","tid":1394093,"uid":61520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:36:33.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"2e669721e001e8c9678d2e8b126ac330b0e00f2c","tid":1394093,"uid":122275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T13:42:04.000Z","msg":"推"}]}