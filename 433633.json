s/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"08157bebcc100d915598c33d8d045474886a2105","tid":433633,"uid":88029,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-13T00:56:19.000Z","msg":"此回覆已被刪除"},{"pid":"8abcecaeef49e7029c0254a36d96bf4383ef5f1e","tid":433633,"uid":93903,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-13T01:01:19.000Z","msg":"拍親拖個個都扑過，用條鳩諗野嘅人<br />\n性慾咁旺盛好難可以成世對同一條女"}]}