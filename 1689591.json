=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F11%2F03%2F094721_71c2ac70f6e1d3468a2a2988fb0ea47d.png&h=2cd6a581&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-11-03T01:48:57.000Z","msg":"求日文巴絲幫手"},{"pid":"6f2bd0f7ea6be217202a8e1af0d405322d84dc50","tid":1689591,"uid":45983,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-03T01:57:00.000Z","msg":"光復香港時代革命"},{"pid":"71e4635989bfc6e39945bcbe00795866a98a77a2","tid":1689591,"uid":53735,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-03T02:00:39.000Z","msg":"Push"},{"pid":"d6dbfc19adce4cfc6a9899eac085d0b6762cc64b","tid":1689591,"uid":285171,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-03T02:10:25.000Z","msg":"大慨係叫你要等 雖然最初令人擔心既事會不絕 但係之後會萬事都如願 幸福下去 要正確地生活下去<br />\n<br />\n後面譯d可能關事<br />\n<br />\n方位：西與北之間做咩都順行<br />\n爭事：有d難，要d時間<br />\n<br />\n唔肯定第一句係咪應該譯做：請等待注意之時的來臨<br />\n<br />\n廢譯住先 等其他日文勁嘅巴打接手<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n光復香港 時代革命"},{"pid":"b17fabaf863d081f339e838fa31917970621b02b","tid":1689591,"uid":133042,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-03T02:22:20.000Z","msg":"朋友翻譯<br />\n<br />\n(中吉)<br />\n時刻保持警覺，等候時機來臨。<br />\n初時令人擔心的事情不斷發生，但之後任何事情都能如預期一樣，幸福會繼續。<br />\n正確地活著。<br />\n<br />\n25番 「言」<br />\n將信仰當成己身散播的種子，智慧是己身耕作的鋤頭。<br />\n把身體、嘴巴和精神上的惡業除去就如為己身的田地除草。"},{"pid":"bc52516ec3152288e5c1244fe0d71c0c922331c9","tid":1689591,"uid":228868,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-03T02:25:10.000Z","msg":"<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" />"},{"pid":"7b68d3e41c0edfe4db9c8548243899eb64bb1106","tid":1689591,"uid":45983,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-03T02:27:07.000Z","msg":"好似好準咁"},{"pid":"c055e6815835fa9ed1499b9b7823867f6094be15","tid":1689591,"uid":334285,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-03T02:33:14.000Z","msg":"求其翻，有錯請指責<br />\n<br />\n願事（祈求的事情）<br />\n比起春天，有更常在秋天想起來的事情就應在月尾前有所行動。<br />\n<br />\n待人（等待的人）<br />\n雖然會遲來但一定會到。<br />\n<br />\n失物<br />\n隨著時間流逝一定會出來。<br />\n<br />\n旅行<br />\n小心交通意外，不心急匆忙的話會比較好。<br />\n<br />\n商売（生意）<br />\n起衝突的話會有損失。<br />\n<br />\n學問<br />\n偷懶的話應該會危險。"},{"pid":"19d0e34faa82e2cbb98715f709b96acbf27bf045","tid":1689591,"uid":334285,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-03T02:46:42.000Z","msg":"方向同爭事同樓上大致一樣<br />\n<br />\n求人<br />\n請別人幫助的話應該不錯。<br />\n<br />\n転居（搬屋）<br />\n越早越好。<br />\n<br />\nお産（生子）<br />\n開始時身體會有阻礙。<br />\n<br />\n病気（疾病）<br />\n無問題。會漸漸好。<br />\n<br />\n縁談<br />\n有心唔怕遲，唔會因為遲咗而出現唔想出現嘅結果，會圓滿收場。要耐心等待。"},{"pid":"94f88024c53b7aae6abe01b2a5a71ea9fa03f025","tid":1689591,"uid":45983,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-03T03:39:53.000Z","msg":"大須觀音同香港觀音係一樣？"}]}