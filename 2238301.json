=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"204d948cbc6c1ceef59584494eebbd37cdad1856","tid":2238301,"uid":8227,"like":16,"dislike":0,"score":16,"quote":{"pid":"1f6fb61e8f0c68bf80563e81d6e8c48159c5be73","tid":2238301,"uid":344173,"like":6,"dislike":0,"score":6,"citedBy":2,"replyTime":"2020-10-11T05:01:04.000Z","msg":"佢嗰啲電影好似係大陸都唔係話特別受歡迎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-11T05:06:10.000Z","msg":"因為佢唔明大陸人鍾意嘅係以前唔奶嘅香港<br />\n有種風骨佢地先like<br />\n而家走去奶佢地 佢地就憎㗎啦<br />\n社會政策 銷售策略 甚至電影都係<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n好似係"},{"pid":"76791f705fbc0d11259e6fe704c90dbb98873853","tid":2238301,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T05:11:35.000Z","msg":"佢都收咗皮"},{"pid":"e86e38d5f604ae981c4d36c7fcc05b37be0c9a5a","tid":2238301,"uid":70013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T05:18:45.000Z","msg":"就當佢90年代係為大陸而拍<br />\n拍到咁多諷刺土共嘅情節咪得囉<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" /><br />\n佢聲稱對象係咩唔緊要<br />\n內容<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><br />\n佢今日敢拍返呢啲內容<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><br />\n就算口講係為只為人仔服務<br />\n我都可能會睇下嘅<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><br />\n如果有部分只係把口奶共但行動係相反嘅相信都好多人會明白"},{"pid":"842779e4fd2abb13fb22aede70a5d577015476d4","tid":2238301,"uid":120070,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-10-11T05:23:24.000Z","msg":"香港電影界毒瘤<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f0df78d58d6dc885c60a64581b8b5a99cf7c4d3b","tid":2238301,"uid":134071,"like":0,"dislike":0,"score":0,"quote":{"pid":"842779e4fd2abb13fb22aede70a5d577015476d4","tid":2238301,"uid":120070,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-10-11T05:23:24.000Z","msg":"香港電影界毒瘤<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-11T05:26:10.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d5941f624c61ff75b020c042ff3fb0e40df1740a","tid":2238301,"uid":7508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-11T05:56:49.000Z","msg":"咁講真 香港人自己都唔支持香港電影係難搞，普通人又唔知行業困難。<br />\n<br />\nanyway ，香港電影風光過，上左神枱咪算，好過睇住佢腐爛。"},{"pid":"d0542fcaf25470e336ca79122216e4994fe3408d","tid":2238301,"uid":57023,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-12T13:36:28.000Z","msg":"大部分8/90年代港產片根本不會獲批正式上映，當年一般只會在小型影像廳播老翻港片dvd，港方影人不會收益😔"},{"pid":"6fc317865132aba4c6d2f693df2ee02b9fa70dae","tid":2238301,"uid":39812,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-10-12T13:41:43.000Z","msg":"成鳩日都話香港人睇戲咁差嘅口味<br />\n係王晶養出來<img src=\"/assets/faces/lm2/nosee.gif\" class=\"hkgmoji\" />"},{"pid":"a2cc5fc18d0df60c1ad6c26dd36e8a845daa1cb7","tid":2238301,"uid":353078,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-10-12T14:14:20.000Z","msg":"點講都好，咁耐以嚟王晶只係市場導向為上嘅電影工作者<br />\n唔太相信佢喺九十年代就已經為大陸市場而拍戲<br />\n當年大陸影業都未蓬勃，又多老翻<br />\n港產片靠賣埠已經有市場，邊駛咁快奶大陸水<br />\n<br />\n百變星君根本係粗製濫造嘅大雜燴<br />\n亦都係王晶胡鬧片種開始回塘嘅分水嶺<br />\n不過真心覺得1995-2005，王晶所拍嘅片仍然有港味<br />\n佢嘅大陸化應該都係CEPA後嘅事lu"},{"pid":"5c855309d68d397b850b509f6c155ab378e176d0","tid":2238301,"uid":353078,"like":5,"dislike":0,"score":5,"quote":{"pid":"1f6fb61e8f0c68bf80563e81d6e8c48159c5be73","tid":2238301,"uid":344173,"like":6,"dislike":0,"score":6,"citedBy":2,"replyTime":"2020-10-11T05:01:04.000Z","msg":"佢嗰啲電影好似係大陸都唔係話特別受歡迎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-12T14:20:52.000Z","msg":"但事實上近年佢越嚟越識玩呢個遊戲<br />\n初期用個必勝方程式，大堆頭明星，滾大舊錢佢<br />\n但賭城風雲已經唔得，因為劇本太廢<br />\n佢自己hea底得嚟又回塘，諗唔到橋<br />\n<br />\n最終家陣搵返個模式<br />\n係咁玩懷舊，唔駛諗橋<br />\n又係四大探長、賊王、倚天，將90年代玩過嘅嘢再翻炒<br />\n上大陸滾到幾億當贏<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d104eefb16d94bd04923a2e4a3d5859f6cd0b813","tid":2238301,"uid":134071,"like":0,"dislike":0,"score":0,"quote":{"pid":"d0542fcaf25470e336ca79122216e4994fe3408d","tid":2238301,"uid":57023,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-12T13:36:28.000Z","msg":"大部分8/90年代港產片根本不會獲批正式上映，當年一般只會在小型影像廳播老翻港片dvd，港方影人不會收益😔"},"citedBy":0,"replyTime":"2020-10-12T14:22:49.000Z","msg":"百變星君有係大陸上映，仲係向生自己發行（果時大陸未改制，仲容許香港公司係大陸發行港產片）"},{"pid":"52993c67c6a01056d04fe1bd605155aef345a2fd","tid":2238301,"uid":51933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-12T14:25:17.000Z","msg":"咁撚有種當年唔好拍廣東話呀嘛<br />\n拍比大陸人用廣東話拍?"},{"pid":"eb7943ebc9f6ee9920a819cdca1092b2e377b296","tid":2238301,"uid":42848,"like":3,"dislike":0,"score":3,"quote":{"pid":"5c855309d68d397b850b509f6c155ab378e176d0","tid":2238301,"uid":353078,"like":5,"dislike":0,"score":5,"quote":{"pid":"1f6fb61e8f0c68bf80563e81d6e8c48159c5be73","tid":2238301,"uid":344173,"like":6,"dislike":0,"score":6,"citedBy":2,"replyTime":"2020-10-11T05:01:04.000Z","msg":"佢嗰啲電影好似係大陸都唔係話特別受歡迎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-12T14:20:52.000Z","msg":"但事實上近年佢越嚟越識玩呢個遊戲<br />\n初期用個必勝方程式，大堆頭明星，滾大舊錢佢<br />\n但賭城風雲已經唔得，因為劇本太廢<br />\n佢自己hea底得嚟又回塘，諗唔到橋<br />\n<br />\n最終家陣搵返個模式<br />\n係咁玩懷舊，唔駛諗橋<br />\n又係四大探長、賊王、倚天，將90年代玩過嘅嘢再翻炒<br />\n上大陸滾到幾億當贏<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" clas