 Kong<br />\n<br />\n歌曲<br />\n《願榮光歸香港》《黃金入球》<br />\n8:15  8:30  8:45  9:00<br />\n<br />\n行動TG group: <a href=\"https://t.me/joinchat/LSlOKkiPRAnfTT-s4Mu8RA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fjoinchat%2FLSlOKkiPRAnfTT-s4Mu8RA&d=ZtzEMfLxU%2BwdrFVc2rz1%2F8TiFwqRwBg1VWT7Je45URE%3D&h=a4bdbf7c\" data-auto-link target=\"_blank\">https://t.me/joinchat/LSlOKkiPRAnfTT-s4Mu8RA</a>"},{"pid":"51ec58ebc7d240e42fcdbe72ca5d123b97f6a731","tid":1576282,"uid":21501,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-09-17T07:26:24.000Z","msg":"戇鳩"},{"pid":"df0a08672279e5539b3fdf704348bc2259ee9c93","tid":1576282,"uid":53672,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-17T07:28:03.000Z","msg":"你on9"},{"pid":"3d4f3aaab75dbe759fc350488a2436ca20f7ec5f","tid":1576282,"uid":129988,"like":2,"dislike":10,"score":-8,"quote":{"pid":"ee8052cb3741fe3dd28311624fcbd4bb2d013ef1","tid":1576282,"uid":301479,"like":40,"dislike":4,"score":36,"citedBy":1,"replyTime":"2019-09-17T07:24:37.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">Block柒你<br />\n扮假膠 實際想屈自己人<br />\n收嗲啦</span></strong></span>"},"citedBy":0,"replyTime":"2019-09-17T07:28:43.000Z","msg":"<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"24131d68e44ee821cc72bb698d766e409f96d2dd","tid":1576282,"uid":258696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T07:30:00.000Z","msg":"On9"},{"pid":"1ed2f1dbcafe35f9be6c22a95d2546730febdcfb","tid":1576282,"uid":49329,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-09-17T07:31:52.000Z","msg":"老屈，死返支那啦，三毛風向撚！"},{"pid":"f529950b6cc66823752ecd1a7be6cca6677057ff","tid":1576282,"uid":129988,"like":0,"dislike":8,"score":-8,"citedBy":0,"replyTime":"2019-09-17T07:33:03.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"67539cb345a3ebca5b90335a4a84b8d2d472d4f3","tid":1576282,"uid":181997,"like":1,"dislike":1,"score":0,"citedBy