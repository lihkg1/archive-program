normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-17T16:08:18.000Z","msg":"都估到5毛會咁講<br />\n<br />\n仲有, 幫你度埋幾個藉口<br />\n<br />\n1. 抗體未出現者<br />\n2. 打之前已經確診<br />\n<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"398a27c707414f28632d59f9ee84e8c9674a4f51","tid":2493131,"uid":76310,"like":3,"dislike":0,"score":3,"quote":{"pid":"a42c10e716f91536324cefbcd62a6e9d2775728d","tid":2493131,"uid":37596,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2021-04-17T16:07:28.000Z","msg":"笑死人咩, 過左14日後中又屈藥效過期?<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-17T16:08:56.000Z","msg":"上面5毛咪話, 外國野都唔係100%啦<br />\n<br />\n比我估中左<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"ae031f6bd784ab091ca229f9f41a2e0ec24fd0fe","tid":2493131,"uid":127955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-17T16:09:27.000Z","msg":"玩撚曬啦"},{"pid":"a0789509eca5aa83ec5b7bd04c6d56dc59cc4bd6","tid":2493131,"uid":71393,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2021-04-17T16:10:10.000Z","msg":"點都話14日前中<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n之後就話隔太耐無補打失咗效<br />\n一定係除非唔係<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ac20c31bb5f6ae2c8d6e63ca5cef694c4a94c3a2","tid":2493131,"uid":15730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-17T16:12:04.000Z","msg":"仆街 打完14日先有用 打嚟做咩"},{"pid":"dd45b8961a585adcb49dc3ba46b6fe73ee4b5bfa","tid":2493131,"uid":264683,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2021-04-17T16:14:08.000Z","msg":"14日後中，就話要21日，21日後中就話要一個月，一個月後中就話患者體質同疫苗唔相容，唔關疫苗事<img src=\"/as