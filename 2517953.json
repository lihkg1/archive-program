":0,"dislike":0,"score":0,"quote":{"pid":"64486ea70a95d9458623869c5fe80616ba510306","tid":2517953,"uid":300630,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-05-05T17:05:56.000Z","msg":"學歷只係裝飾品"},"citedBy":1,"replyTime":"2021-05-05T17:06:50.000Z","msg":"人哋就係睇你外表先"},{"pid":"a4e5151e1223bccf8bfb114e64c07f5c5ba5a6a4","tid":2517953,"uid":339272,"like":1,"dislike":1,"score":0,"quote":{"pid":"fe080664ac560b07db51cfd7f1cde9a6105e16d6","tid":2517953,"uid":89683,"like":0,"dislike":2,"score":-2,"citedBy":3,"replyTime":"2021-05-05T16:28:11.000Z","msg":"曾志偉無degree都做到上市公司高層啦"},"citedBy":0,"replyTime":"2021-05-05T17:07:26.000Z","msg":"姜濤冇degree都做到亞一"},{"pid":"1a9f26554844a3685584d52738d98d3c730726e6","tid":2517953,"uid":146917,"like":0,"dislike":2,"score":-2,"quote":{"pid":"1507da58274f7aee9e3a2a550a8b1c46c8ab0199","tid":2517953,"uid":38904,"like":18,"dislike":2,"score":16,"citedBy":2,"replyTime":"2021-05-05T16:21:39.000Z","msg":"得啲讀唔成書嘅人先會話讀書冇用<br />\n除非你係兒仔/小部份天材<br />\n不過喺連登100%都係前者"},"citedBy":1,"replyTime":"2021-05-05T17:12:07.000Z","msg":"連登大把垃圾<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dfadf3256812bc875d15ffa3934ebc30ccfecaf4","tid":2517953,"uid":300630,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c76f880821fa6f07f0cbcb830c587895d21c333","tid":2517953,"uid":198503,"like":0,"dislike":0,"score":0,"quote":{"pid":"64486ea70a95d9458623869c5fe80616ba510306","tid":2517953,"uid":300630,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-05-05T17:05:56.000Z","msg":"學歷只係裝飾品"},"citedBy":1,"replyTime":"2021-05-05T17:06:50.000Z","msg":"人哋就係睇你外表先"},"citedBy":0,"replyTime":"2021-05-05T17:13:28.000Z","msg":"That&rsquo;s the point"},{"pid":"a9ee534486e86fffebfd22608dd03ae9719439cd","tid":2517953,"uid":146917,"like":0,"dislike":1,"score":-1,"quote":{"pid":"64486ea70a95d9458623869c5fe80616ba510306","tid":2517953,"uid":300630,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-05-05T17:05:56.000Z","msg":"學歷只係裝飾品"},"citedBy":0,"replyTime":"2021-05-05T17:13:43.000Z","msg":"老實講係 <br />\n但係人地對你3唔識7 <br />\n一定係睇你CV 先 你裝飾品都要包得好先有人睇<br />\n唔通人地會肯用時間睇你有冇料？ <br />\n唔好玩我啦 hr覺得唔對路就下一個啦"},{"pid":"4d4d15368de9dbd361a7df5ab67bfc72afb7231a","tid":2517953,"uid":290850,"like":1,"dislike":0,"score":1,"quote":{"pid":"69014991aee91834d6026721f5f4db8bfc49bfb0","tid":2517953,"uid":146917,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-05-05T16:19:38.000Z","msg":"基本上 所有上市公司員工／中上產都有大學學歷<br />\n話讀書冇用 識人好過識寫根本係呃鳩你<br />\n入場卷都冇 識幾多人都冇用<br />\n因為完全唔同程度<br />\n比你識到 升職都唔關你事<br />\n做到一半發現你廢 踢走你都得<br />\n如果讀書冇用 外國都基本上唔會要你<img src=\"/assets/faces/pig/read.gif\" class=\"hkgmoji\" /><br />\n加大 英國 澳洲 美國都唔會請你<br />\n讀緊書嘅你 快撚d讀好佢再走佬<img src=\"/assets/faces/pig/read.gif\" class=\"hkgmoji\" /><br />\n就算唔走 唔想大個窮就努力讀書<img src=\"/assets/faces/pig/read.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-05-05T17:17:26.000Z","msg":"唔想講自己有幾多~<br />\n<br />\n不過真係講你勤唔勤同識唔識睇準機會一步步<br />\n識人同轉行&nbsp;<br />\n我認我係有少少人際運<br />\n<br />\n呢個世代比唔到咩意見<br />\n不過我覺得每個年代都有難處<br />\n依家個難度係高到你想棄GAME咁解<br />\n所以個門檻係高左~但讀唔成書<br />\n真係唔一定無出路~加油<br />\n<br />\n<br />\n利申:2001年&nbsp;中5&nbsp;[修業(即係中都畢唔到業)]"}]}