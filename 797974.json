動計劃<br />\n<br />\n<a href=\"https://addons.mozilla.org/en-US/firefox/addon/ghostery/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Faddons.mozilla.org%2Fen-US%2Ffirefox%2Faddon%2Fghostery%2F&d=%2F7PvxGVesDDcZSZb%2Fw0AhQHuyxefasl%2FZxVLfhQSBMM%3D&h=9a8be505\" target=\"_blank\">https://addons.mozilla.org/en-US/firefox/addon/ghostery/</a><br />\n<a href=\"https://chrome.google.com/webstore/detail/ghostery/mlomiejdfkolichcflejclcbmpeaniij?hl=zh-TW\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fchrome.google.com%2Fwebstore%2Fdetail%2Fghostery%2Fmlomiejdfkolichcflejclcbmpeaniij%3Fhl%3Dzh-TW&d=%2F7PvxGVesDDcZSZb%2Fw0AhQHuyxefasl%2FZxVLfhQSBMM%3D&h=2cb29fb8\" target=\"_blank\">https://chrome.google.com/webstore/detail/ghostery/mlomiejdfkolichcflejclcbmpeaniij?hl=zh-TW</a><br />\n裝左睇V台就唔會見左上果舊野<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"},{"pid":"263c59c7fa85e234663c5d9c5fbc93438f0b6d24","tid":797974,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T03:12:31.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"8d485d677950d061ed9f7177228bb9da04dc5ee0","tid":797974,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T04:01:33.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"bc02390d465fc6964db1e61d346dca9c5d6efa1a","tid":797974,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T05:01:41.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"ce081c977f157d47d4cdabc6ba2e8177539413d4","tid":797974,"uid":29160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-30T04:32:26.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <