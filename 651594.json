5,"like":0,"dislike":0,"score":0,"quote":{"pid":"41c9480843f833df85dd54c496842f8ef905c80c","tid":651594,"uid":26752,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-05-03T10:14:43.000Z","msg":"<img src=\"https://vignette.wikia.nocookie.net/cnc/images/f/fa/Yuri_red_alert.jpg/revision/latest?cb=20120226190519\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fcnc%2Fimages%2Ff%2Ffa%2FYuri_red_alert.jpg%2Frevision%2Flatest%3Fcb%3D20120226190519&h=6106287d&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-05-04T01:14:47.000Z","msg":"佢都只係1 on 1咋喎，out date啦<br />\n依家1 on 14億"},{"pid":"7a927400c202b0cdacac2ab4e23ee7b438e9498a","tid":651594,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-04T02:12:22.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"}]}