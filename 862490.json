if\" class=\"hkgmoji\" />"},{"pid":"685fc401bfddfbdca6c3d2c64da160759b66c06e","tid":862490,"uid":59536,"like":0,"dislike":0,"score":0,"quote":{"pid":"9afc7772f75bf3636c6bb955dcf8a427d19fa073","tid":862490,"uid":19990,"like":1,"dislike":32,"score":-31,"quote":{"pid":"29f5c043d63d7b201946d526b125bb1908f3a028","tid":862490,"uid":26953,"like":205,"dislike":1,"score":204,"citedBy":4,"replyTime":"2018-10-15T01:55:22.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/10/15/095516_e8c578a0add50618fa479bfb596a889d.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F15%2F095516_e8c578a0add50618fa479bfb596a889d.png&h=7cd4ed1c&s={SIZE}\" />"},"citedBy":2,"replyTime":"2018-10-15T05:24:09.000Z","msg":"咩咩健？<br />\n印象中好矮<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-15T05:34:06.000Z","msg":"清水 <br />\n幾高下..."},{"pid":"8de8c6e170ed9be2c1eb8223f7256fa8f2f36bd4","tid":862490,"uid":205462,"like":1,"dislike":28,"score":-27,"quote":{"pid":"3629304d64cb2621e9d5e2bdd79c00195e2efd84","tid":862490,"uid":32511,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-15T00:53:39.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/10/15/003455_7a5eea2bb04b5cd1a455228035818260.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F15%2F003455_7a5eea2bb04b5cd1a455228035818260.png&h=19409e32&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/10/15/003456_9c36bb5cc5923c8ec6edb07d200e80ca.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F15%2F003456_9c36bb5cc5923c8ec6edb07d200e80ca.png&h=6538258f&s={SIZE}\" /><br />\n<br />\n女生常常會被搔癢異味、分泌物過多所擾，如果白帶分泌濕濕黏黏的過多，一整天下來讓人難以忍受。國外女性健康網站就指出，從這6種分泌物狀態就能看出身體的健康狀態，尤其指出分泌物若是黃綠色，就代表可能感染淋病。<br />\n <br />\n國外女性健康網站《Women's Health》報導，整理出以下6種不同的分泌物顏色，來看出其代表身體的健康狀態。<br />\n <br />\n <br />\n1. 透明、白色濕黏分泌物<br />\n <br />\n這代表身體處於「排卵期」，這是你的身體為了讓精子能順利進入陰道與卵子結合，所產生的分泌物，這些黏液就像蛋清一樣。<br />\n <br />\n <br />\n2. 白色、塊狀分泌物，伴隨發癢狀況<br />\n <br />\n可能是「白色念珠菌」（陰道酵母菌的一種）所引起的感染，容易讓下體產生搔癢的症狀。這時分泌物會呈現白色奶酪質地的結塊，且外陰也會出現腫脹的情形。此症狀通常出現在潮濕環境，建議可以使用非處方的抗真菌藥物。<br />\n <br />\n <br />\n3.黃綠色分泌物、下體刺痛<br />\n <br />\n如果私處分泌物呈現黃綠色，並伴隨刺痛感、排尿灼熱等症狀，就要小心可能是感染淋病（gonorrhea）、砂眼衣原體（chlamydia）細菌型性病。淋病菌可經由性行為口交傳染他人，因此建議性伴侶雙方都到醫院檢查。<br />\n <br />\n <br />\n4. 分泌物呈現灰色、而且有強烈味道<br />\n <br />\n感染「細菌性陰道炎」會產生強烈的魚腥味，15到44歲的女性最常出現感染，這代表陰道中的細菌失衡。<br />\n <br />\n <br />\n5. 分泌物呈現灰綠色、泡沫狀<br />\n <br />\n內褲飄出陣陣難聞的意味，又出現頻尿、陰道搔癢的情形，則可能是感染「滴蟲性陰道炎（trichomoniasis）。該症狀會透過性行為、共用毛巾、貼身衣物、浴缸等途徑傳染，且不論男女都可能被感染。<br />\n <br />\n <br />\n6. 分泌物是粉紅色，帶紅色或棕色<br />\n <br />\n月經周期時殘留的血絲與「子宮內膜出血」會讓分泌物變成粉色或咖啡色，通常在女性剛生產後的幾個月較容易出現是正常的，因為她的身體還在調整荷爾蒙。但如果持續發現分泌物褐色斑點情況時，還是建議看醫生檢查，要注意是否為子宮頸癌會卵巢癌的警訊。"},"citedBy":0,"replyTime":"2018-10-15T05:41:41.000Z","msg":"<img src=\"https://na.cx/i/Rj8WhWv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRj8WhWv.jpg&h=5aeb7fe1&s={SIZE}\" /><br />\n<br />\n好想瘋狂地奶"},{"pid":"e670a6071bb12bd54aa72b8c64aa4f55ff91d136","tid":862490,"uid":44454,"like":46,"dislike":1,"score":45,"quote":{"pid":"9afc7772f75bf3636c6bb955dcf8a427d19fa073","tid":862490,"uid":19990,"like":1,"dislike":32,"score":-31,"quote":{"pid":"29f5c043d63d7b201946d526b125bb1908f3a028","tid":862490,"uid":26953,"like":205,"dislike":1,"score":204,"citedBy":4,"replyTime":"2018-10-15T01:55:22.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/10/15/095516_e8c578a0add50618fa479bfb596a889d.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F15%2F095516_e8c578a0add50618fa479bfb596a889d.png&h=7cd4ed1c&s={SIZE}\" />"},"citedBy":2,"replyTime":"2018-10-15T05:24:09.000Z","msg":"咩咩健？<br />\n印象中好矮<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-15T05:44:40.000Z","msg":"你性能力差過佢，係要用身高黎自我安慰<img src=\"