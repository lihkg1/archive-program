:0,"score":0,"citedBy":0,"replyTime":"2020-02-06T07:29:13.000Z","msg":"<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"759a7d311b1939de1788a433b79da336325ddcf4","tid":1865401,"uid":89974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T07:29:23.000Z","msg":"<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b4b908fbf307a7666330442c0dba81af6e50dc49","tid":1865401,"uid":147010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T07:31:30.000Z","msg":"我地冇權冇武力，最大嘅武器就係人數。人數上我地係佔優。而我地令對方感到威脅嘅亦正正係<span style=\"font-size: x-large;\"><span style=\"color: gold;\">人數</span></span><br />\n<br />\n記住槍口對外呀大家<br />\n<br />\n明明個個都識講中共最叻分化<br />\n點解對面要玩分化？因為人地擺到明知道我地嘅優勢係人數！<br />\n<br />\n所以希望大家真係唔好比人得逞<br />\n<br />\n<br />\n我地要好好集火呀<br />\n所以大家求下你地，好好善用我地嘅優勢"},{"pid":"b80b348777736c3584a4a6f87a1d83e8be014cc2","tid":1865401,"uid":266010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T07:32:53.000Z","msg":"<img src=\"/assets/faces/lny/offtopic.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/offtopic.gif\" class=\"hkgmoji\" />推上去"},{"pid":"bc9942d0dba1459370371f0c05d2000615411d29","tid":1865401,"uid":89974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T07:34:59.000Z","msg":"<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"aa227bacfecdf7d67d3405a76836d1fcb165a2ed","tid":1865401,"uid":139484,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T07:38:47.000Z","msg":"推"},{"pid":"5837ed545966b55effaef2fd55db5d34274c556f","tid":1865401,"uid":89974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T07:44:38.000Z","msg":"<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"14b4e7fc961cae6b57292ba3ca7f4d7752e23254","tid":1865401,"uid":89974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T07:47:16.000Z","msg":"<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"06