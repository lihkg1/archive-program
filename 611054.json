hkgmoji\" />"},{"pid":"b79307c989b8193e0690bd0d14bc4f1011950c30","tid":611054,"uid":67500,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-03-30T15:23:21.000Z","msg":"做幾年後都係13k<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"909751459db2516090dd97c3cbcf46034adb7194","tid":611054,"uid":123304,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-30T15:23:41.000Z","msg":"萬三真係俾狗做"},{"pid":"0a112a73e41aa0348bd768873d3f24705f66db66","tid":611054,"uid":19552,"like":2,"dislike":4,"score":-2,"citedBy":0,"replyTime":"2018-03-30T15:26:38.000Z","msg":"連登仔不願面對<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<br />\n酒店學科最受DSE考生歡迎<br />\n<br />\n優才資源中心於去年底作調查，問卷訪問逾4千名應屆中學文憑試考生。酒店及旅遊管理連續3年被選為最受歡迎學科，第二及第三位分別為心理學和護士。最不受考生歡迎的科目則為計算機工程，其次是統計及精算。優才資源中心總監陳偉權解釋，考生傾向選擇服務性工作，而計算機工程則主要有關硬件，故較不吸引考生。"},{"pid":"3c023c20288280a59d6c89f50b17607c0759f0ed","tid":611054,"uid":31920,"like":9,"dislike":1,"score":8,"citedBy":0,"replyTime":"2018-03-30T15:30:08.000Z","msg":"<blockquote>萬三真係俾狗做</blockquote><br />\n其實計年尾係有二萬<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n不過收20000做狗 無人生 無尊嚴 賣青春 好撚辛苦<br />\n果斷quit撚柒左<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0fc0be4ae158acc78b0ce97d9282ba6da97733da","tid":611054,"uid":115516,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-30T15:30:56.000Z","msg":"酒店一向辛苦到爆"},{"pid":"e73289453569c9e28c4311aed9cbf350fb2ac5ec","tid":611054,"uid":12628,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-30T15:31:53.000Z","msg":"酒狗唔係睇重雙糧花紅嘅咩"},{"pid":"69cf1af77c5ea7759b9a2d64ec5dd4462ce93868","tid":611054,"uid":19552,"like":3,"dislike":2,"score":1,"citedBy":0,"replyTime":"2018-03-30T16:01:15.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class