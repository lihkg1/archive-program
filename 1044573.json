ote":{"pid":"7277f1c6240bd44c490c4474e5bbc0ac2f4a86ba","tid":1044573,"uid":50385,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-03T04:39:16.000Z","msg":"在下半場，蘇斯克查換上的達洛與費特都有助攻。<br />\n<br />\n費特傳失彈到對手又屈佢助攻<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-03T10:09:29.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />重睇啦"}]}