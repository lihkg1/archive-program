s/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"58cc75704d911bded060827f377f4391b8fe6eaa","tid":1864654,"uid":213246,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-05T18:52:57.000Z","msg":"在港臨時政府暫時代表為一眾民主派之議員"},{"pid":"7dc4cb5b0cb21f2354bdc9c83ffd3d57ec053aa1","tid":1864654,"uid":174502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T18:53:48.000Z","msg":"屌 <br />\n又黎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"eec227022d0d9b522bd114a507e4b877613492a5","tid":1864654,"uid":213246,"like":0,"dislike":0,"score":0,"quote":{"pid":"58cc75704d911bded060827f377f4391b8fe6eaa","tid":1864654,"uid":213246,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-05T18:52:57.000Z","msg":"在港臨時政府暫時代表為一眾民主派之議員"},"citedBy":0,"replyTime":"2020-02-05T18:54:12.000Z","msg":"睇下會唔會有人有氣魄去拎"},{"pid":"a6ee09f98e19d322cbb15030906eaa0c8da24ed4","tid":1864654,"uid":1654,"like":0,"dislike":0,"score":0,"quote":{"pid":"b54acae1e54126f71c11d60600275e42390faad4","tid":1864654,"uid":196092,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-02-05T17:35:11.000Z","msg":"其實有好多人已經嶄露頭角。雖然組織好多，編制互不從屬，但係大家都係香港人 ，都係為香港而戰。<br />\n<br />\n本土工會，經濟圈，制度內既既區議會，眾多手足<br />\n<br />\n依家好多人都冇浮面，我認為當香港需要佢哋浮面既時候 佢地就會挺身而出。<br />\n<br />\n要順利獨立就要成立臨時政府，由臨時政府宣布獨立，解決獨立路上所有障礙，主持真普選，從而過渡去民選政府。<br />\n<br />\n而臨時政府既人選，我認為要選擇忠於香港人，從本土利益出發，有遠見既有識之士。<br />\n<br />\n如果搞到政權更替，要賭既係全球反共圈既團結力。話晒我地都冇兵係手，係靠大國博弈先制衡到中國。民間陸續有團練出現，但係成個大環境都未製造到/製造唔到全民勇武既場面出黎。長遠黎講我覺得要展現香港人對國際既價值，影響先可以實現呢個目標"},"citedBy":0,"replyTime":"2020-02-05T18:56:14.000Z","msg":"所以港共死都唔放梁天琦"},{"pid":"3be7001a2d6d53eb13c953c41b560dbc61e0ae47","tid":1864654,"uid":17802,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T18:57:28.000Z","msg":"樓上有人質問你冇乜冇物，我就諗起一個字頭的誕生裡面嘅劉青雲同班垃圾古惑仔嗰段戲<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"0070f01cc146a7256aa49138fda292e7659b024c","tid":1864654,"uid":250721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T19:00:46.000Z","msg":"推"},{"pid":"b8f2905237f7243b18b2cc2f2b5a74c1a7da2af1","tid":1864654,"uid":127447,"like":3,"dislike":0,"score":3,"quote":{"pid":"b638513736402be261cd88614c91a45b8c3bb28d","tid":1864654,"uid":18147,"like":35,"dislike":12,"score":23,"citedBy":4,"replyTime":"2020-02-05T17:17:26.000Z","msg":"認受性？<br />\n<br />\n邊個出錢？<br />\n<br />\n對家有警察， 你有咩？<br />\n<br />\n國際認唔諗同你？<br />\n<br />\nConclusion, 早d 訓"},"citedBy":0,"replyTime":"2020-02-05T19:39:09.000Z","msg":"好多流亡政府都冇警察冇軍隊冇邦交國，但成立臨時政府係一種表態。"},{"pid":"a71bdd9cf276c8fa0a8c107be7161020b8822c11","tid":1864654,"uid":213246,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-02-05T20:00:16.000Z","msg":"行政：<br />\nstep1-搵外國手足共同宣佈臨時政府成立（於各大社交媒體發佈）並宣佈香港現時屬於戰爭狀態<br />\nstep2-宣佈其他三司十二局之下所有政府職位原地待命及維持有限度服務 待臨時政府全面接管<br />\nStep3-香港臨時政府在巷發言人為一眾民主派議員<br />\n<br />\n<br />\n軍權：<br />\nStep1-宣佈香港警察為叛軍,要求即時解散及由普通青壯於自己區內維持有限度治安直至香港臨時政府另行通告<br />\nStep2-香港臨時政府允許全港勇武派衛隊就地擊殺任何作出反抗行為之叛軍 但一律接受投降之叛軍 投降後所屬之勇武派衞隊不可作出額外之人身傷害所屬之判決會經由臨時軍事法庭審判<br />\n<br />\n司法：<br />\nStep1-宣佈被除名之法官名單 該等法官所判之案例一律不受香港臨時政府之認可及該法官有可能干犯香港臨時政府所頒佈之新法例（呢part要請法律巴打去度度）<br />\n<br />\n如果你係想件事有可能發生既就唔好淨係屌 一齊去諗點先可以做到出黎<br />\n<br />\n同埋臨時政府雖然暫時無仼何權力 所以要不停刷存在感令到有人意識到臨時政府之存在<br />\n<br />\n歡迎加更多建議 令到成件事更work"},{"pid":"191eca99469ec641c34089d2485cceef88529069","tid":1864654,"uid":35877,"like":0,"dislike":0,"score":0,"quote":{"pid":"a71bdd9cf276c8fa0a8c107be7161020b8822c11","tid":1864654,"uid":213246,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-02-05T20:00:16.000Z","msg":"行政：<br />\nstep1-搵外國手足共同宣佈臨時政府成立（於各大社交媒體發佈）並宣佈香港現時屬於戰爭狀態<br />\nstep2-宣佈其他三司十二局之下所有政府職位原地待命及維持有限度服務 待臨時政府全面接管<br />\nStep3-香港臨時政府在巷發言人為一眾民主派議員<br />\n<br />\n<br />\n軍權：<br />\nStep1-宣佈香港警察為叛軍,要求即時解散及由普通青壯於自己區內維持有限度治安直至香港臨時政府另行通告<br />\nStep2-香港臨時政府允許全港勇武派衛隊就地擊殺任何作出反抗行為之叛軍 但一律接受投降之叛軍 投降後所屬之勇武派衞隊不可作出額外之人身傷害所屬之判決會經由臨時軍事法庭審判<br />\n<br />\n司法：<br />\nStep1-宣佈被除名之法官名單 該等法官所判之案例一律不受香港臨時政府之認可及該法官有可能干犯香港臨時政府所頒佈之新法例（呢part要請法律巴打去度度）<br />\n<br />\n如果你係想件事有可能發生既就唔好淨係屌 一齊去諗點先可以做到出黎<br />\n<br />\n同埋臨時政府雖然暫時無仼何權力 所以要不停刷存在感令到有人意識到臨時政府之存在<br />\n<br />\n歡迎加更多建議 令到成件事更work"},"citedBy":0,"replyTime":"2020-02-05T20:08:44.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d66f35127526a2120ffc1c023acab402b3b6d270","tid":1864654,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T20:20:00.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"17c259f05cabe7d52cb74018b046dea92846f3fd","tid":1864654,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T20:20:26.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>【我屌番我自己】呢個時候，出post話臨時乜野既人應該入呢個post諗諗<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1864795\" data-auto-link target=\"_blank\">https://lih.kg/1864795</a></strong></span></span>"},{"pid":"3ca64c9b18c8361d5855f3d56f1200483f22dec7","tid":1864654,"uid":258230,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T20:31:57.000Z","msg":"大家都想要<br />\n大家都搞唔到"},{"pid":"305fd76512bcd43b57bec6b41dc5463555a61924","tid":1864654,"uid":34355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T20:38:19.000Z","msg":"玩左咁多個月，一直理念都係無大台無leader<br />\n突然有個臨時政府，一旦起左就好似雨革咁政府攻大台然後收皮<br />\n退一步而言，起到，臨時政府最top嘅人係咩人？咪又係班左膠泛民，比左膠泛民起到大台，次次都肯退步同政府傾就場運動就係咁先<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},{"pid":"5f0314d53d65450231b769ef43ec382cf80850a8","tid":1864654,"uid":220985,"like":0,"dislike":0,"score":0,"quote":{"pid":"a71bdd9cf276c8fa0a8c107be7161020b8822c11","tid":1864654,"uid":213246,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-02-05T20:00:16.000Z","msg":"行政：<br />\nstep1-搵外國手足共同宣佈臨時政府成立（於各大社交媒體發佈）並宣佈香港現時屬於戰爭狀態<br />\nstep2-宣佈其他三司十二局之下所有政府職位原地待命及維持有限度服務 待臨時政府全面接管<br />\nStep3-香港臨時政府在巷發言人為一眾民主派議員<br />\n<br />\n<br />\n軍權：<br />\nStep1-宣佈香港警察為叛軍,要求即時解散及由普通青壯於自己區內維持有限度治安直至香港臨時政府另行通告<br />\nStep2-香港臨時政府允許全港勇武派衛隊就地擊殺任何作出反抗行為之叛軍 但一律接受投降之叛軍 投降後所屬之勇武派衞隊不可作出額外之人身傷害所屬之判決會經由臨時軍事法庭審判<br />\n<br />\n司法：<br />\nStep1-宣佈被除名之法官名單 該等法官所判之案例一律不受香港臨時政府之認可及該法官有可能干犯香港臨時政府所頒佈之新法例（呢part要請法律巴打去度度）<br />\n<br />\n如果你係想件事有可能發生既就唔好淨係屌 一齊去諗點先可以做到出黎<br />\n<br />\n同埋臨時政府雖然暫時無仼何權力 所以要不停刷存在感令到有人意識到臨時政府之存在<br />\n<br />\n歡迎加更多建議 令到成件事更work"},"citedBy":0,"replyTime":"2020-02-05T20:58:57.000Z","msg":"其實ok"},{"pid":"312e89c01f179e270df50b335d4ce1784503596e","tid":1864654,"uid":72186,"like":0,"dislike":0,"score":0,"quote":{"pid":"a71bdd9cf276c8fa0a8c107be7161020b8822c11","tid":1864654,"uid":213246,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-02-05T20:00:16.000Z","msg":"行政：<br />\nstep1-搵外國手足共同宣佈臨時政府成立（於各大社交媒體發佈）並宣佈香港現時屬於戰爭狀態<br />\nstep2-宣佈其他三司十二局之下所有政府職位原地待命及維持有限度服務 待臨時政府全面接管<br />\nStep3-香港臨時政府在巷發言人為一眾民主派議員<br />\n<br />\n<br />\n軍權：<br />\nStep1-宣佈香港警察為叛軍,要求即時解散及由普通青壯於自己區內維持有限度治安直至香港臨時政府另行通告<br />\nStep2-香港臨時政府允許全港勇武派衛隊就地擊殺任何作出反抗行為之叛軍 但一律接受投降之叛軍 投降後所屬之勇武派衞隊不可作出額外之人身傷害所屬之判決會經由臨時軍事法庭審判<br />\n<br />\n司法：<br />\nStep1-宣佈被除名之法官名單 該等法官所判之案例一律不受香港臨時政府之認可及該法官有可能干犯香港臨時政府所頒佈之新法例（呢part要請法律巴打去度度）<br />\n<br />\n如果你係想件事有可能發生既就唔好淨係屌 一齊去諗點先可以做到出黎<br />\n<br />\n同埋臨時政府雖然暫時無仼何權力 所以要不停刷存在感令到有人意識到臨時政府之存在<br />\n<br />\n歡迎加更多建議 令到成件事更work"},"citedBy":1,"replyTime":"2020-02-05T21:25:18.000Z","msg":"軍權部分暫時都重係天馬行空 幾個揸槍防暴逐個捉你都已經夠"},{"pid":"227d9f01b9d4026a5071abb8037a8b8c3d0163c8","tid":1864654,"uid":183103,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T21:25:35.000Z","msg":"推"},{"pid":"9e30ccd2ebbfff991ca8c7ca3060eb35a068c7dd","tid":1864654,"uid":343574,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-05T21:29:35.000Z","msg":"推<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"92cd1c5ca80098efd057ec2ca175f03ba2fd10b1","tid":1864654,"uid