n.com.tw/upfiles/B_MA/marsma11/PSN_PHOTO/339/f_11573339_1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fg.udn.com.tw%2Fupfiles%2FB_MA%2Fmarsma11%2FPSN_PHOTO%2F339%2Ff_11573339_1.jpg&h=af12247d&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-07-26T08:20:40.000Z","msg":"比蒙古人吞併<br />\n然後格硬話蒙古都係中國一部分<br />\n再寫入中史書<br />\n笑話黎"},{"pid":"66b633d2fe28598d668758bf0cd17e7433c35436","tid":1367023,"uid":148987,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T08:21:08.000Z","msg":"又南海又北極<br />\n都幾撚大野心"},{"pid":"4009902204a1411a25736adc2c605e295bd43750","tid":1367023,"uid":33878,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T08:25:20.000Z","msg":"第三次世界大戰應該打撚梗<br />\n支那根本厚顏無恥  無法無天"},{"pid":"1fd4cd22d8368aead84a669fb378612263f5d316","tid":1367023,"uid":44454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T08:27:26.000Z","msg":"北冥自古以來是中國不可分割的一部分，外國不應說三道四"},{"pid":"498919bd7e2cc57077a132babe86bc0eae410eaf","tid":1367023,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T16:39:33.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}