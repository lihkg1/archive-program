期：下午８時至凌晨１時），讓我們的義工為你加油打氣！<br />\n <br />\n我們願意聆聽你的心聲，伴你一起走過這段艱難的時候！只因『晴天雨天要樂天，難關難過總會過』！<br />\n<br />\n《自殺．自療．互助舍》"},{"pid":"ecd70fca32e0db46d67074d35bd39da89fb5336b","tid":1982362,"uid":65439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-21T13:37:42.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n有陷球剷掣即禁"},{"pid":"84d8d7c6ee5a9986109a1d7ad43ada5218265cc1","tid":1982362,"uid":54740,"like":0,"dislike":0,"score":0,"quote":{"pid":"395815cf1b3f1d4deb736fbdb8d2ad351cecb7de","tid":1982362,"uid":279694,"like":1,"dislike":0,"score":1,"quote":{"pid":"18e41df69eef6330b9a327b509c2e69f5dcbe6a7","tid":1982362,"uid":3379,"like":0,"dislike":0,"score":0,"quote":{"pid":"6346ce3f1fa6bdb86a1e485efb4beb6802fe568f","tid":1982362,"uid":279694,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-21T08:13:12.000Z","msg":"<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-21T08:25:38.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-04-21T08:46:03.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-23T03:06:15.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}