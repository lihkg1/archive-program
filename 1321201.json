/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"db80ba6eb31924621d062e3e2aea9404a7c28e5f","tid":1321201,"uid":55851,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T15:43:24.000Z","msg":"馬車<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"341693d368abfb300e6b21a599823630dc76bda5","tid":1321201,"uid":18660,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T15:44:43.000Z","msg":"好彩無圖"},{"pid":"f2a9ec9c4c56d487e970c9648b43bb34b3f9ceb6","tid":1321201,"uid":258566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T22:26:55.000Z","msg":"此回覆已被刪除"}]}