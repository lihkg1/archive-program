 src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" />"},{"pid":"2cb65ac71019f3f31352984a79d5945f655da746","tid":2297142,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T09:11:38.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"9d758358791b1495f0c81bfe9e5d33e14e7113bb","tid":2297142,"uid":1690,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T09:12:48.000Z","msg":"唔封關檢疫<br />\n就賴落香港人度<br />\n呢份工都幾好做<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"0ebf15f9c23b31ef97672272e89522d3c0fb0357","tid":2297142,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T09:13:50.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"fc63b10b1193c07ae70fbf8398ec5e0e5c7ac80f","tid":2297142,"uid":36807,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T09:29:20.000Z","msg":"<img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" />"},{"pid":"c77b72ef36cd6665af4d672e030298130f8b05fb","tid":2297142,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T11:40:25.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"8f55409ffa06f7b4a1ffd9403f38c4bc9d5e9847","tid":2297142,"uid":36807,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T12:29:07.000Z","msg":"<img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" />"},{"pid":"1838b8137c693d5fed0762275003f7eb96916414","tid":2297142,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-01T08:17:21.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"cc83c309808c9b686fbc86cd3853f3522554e967","tid":2297142,"uid":301479,"like":0,"dislike":0,"score":0,"quote":{"pid":"c8f7550625f0990e49f12aea93a0e6048eeb80e7","tid":2297142,"uid":36807,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-23T05:21:14.000Z","msg":"<ins><strong><span class=\"x-large\">首先睇下免檢疫數據：</span></strong></ins><br />\n保安局局長李家超回應立法會議員質詢時，公開獲豁免14天強制檢疫的入境人士數字，由本年5月至9月期間，<span class=\"red\">每月均有逾4萬人獲豁免，7月更高達逾5萬3千人</span>，累計共有逾22萬6千人獲豁免強制檢疫。<br />\n<br />\n另外，李家超亦公佈，今年5月至9月期間，經各出入境管制站入境的香港居民、內地及其他國家等訪客人次，5月共有逾8萬8千萬人次，7月高達逾19萬人次，上月則有逾14萬8千人次，另有3,907人於6月至9月期間持單程證來港。<br />\n<strong><span class=\"red\"><ins>拎7月數據嚟睇 有19萬人入境香港 但係有成5萬3千人免檢疫 呢個比例係好高</ins></span></strong><br />\n<br />\n<ins><strong><span class=\"x-large\">再睇下近期免檢疫人士確診情況：</span></strong></ins><br />\n01/11昨天新增的一例確診者是一名疑似偷渡、沒有居港證的42歲中國女子，她在10月28日被港警逮捕後被羈留，在10月30日移至馬頭角羈留中心，結果在昨天確診；<span class=\"red\">目前不清楚該女子何時入港</span>，但她聲稱捕前一直待在九龍塘尾道的一間酒店，詳細行蹤仍有待港警調查，也編列10多名密切接觸者。<br />\n<ins><span class=\"red\">偷渡嚟香港？淨係留喺酒店冇出過街？</span></ins><br />\n<br />\n另外，有名境外移入確診者是在信德中心、隸屬中聯辦物產工作的44歲男子，他的居所也是中聯辦的員工宿舍，據說是中聯辦的職員，港府也證實，該男子獲免檢疫入境，10月27日出現症狀，隨後在10月30日確診，雖然一度聲稱從過年以來未曾前往中國，但港府發現他曾在9月底至10月6日至深圳辦公，隨後才利用獲免檢疫入境香港。<br />\n<ins><span class=\"red\">免檢疫入嚟確診咗仲要隱瞞旅遊紀錄，最少有三日以上喺社區</span></ins><br />\n<br />\n咁其他個案呢？豁免人士須接受醫學監察，如當中有人確診，衛生署理應知悉。結果只獲衛生署回覆：「衞生署衞生防護中心並沒有備存閣下查詢的相關數字分類。」<br />\n<ins><span class=\"red\">衛生署聲稱無免檢疫而又確診嘅人數據</span></ins><br />\n<br />\n<ins><strong><span class=\"x-large\">點解免檢疫漏洞影響咁大？：</span></strong></ins><br />\n所有機組人員及船員在機場入境時，強制留下深喉唾液樣本做測試。不過，措施仍有漏洞，到內地出席股東會的上市公司董事、在廣東省設有生產線的公司僱員、與履行與政府相關運作的政府人員和符合相關條件的仲裁員等<strong>仍獲豁免接受病毒測試</strong>，未能杜絕相關輸入個案風險。<br />\n許樹昌亦指，第三波爆發與早前<strong>放寬邊境措施</strong>，容許特定人士豁免檢疫有關，&ldquo;機組人員同海員，或者公務、商務人士，以往這些人在香港都不需要留樣本，而他們很可能將病毒帶入社區&rdquo;。<br />\n<span class=\"red\"><ins>原來仍然有批人唔使隔離之餘病毒測試都唔使做</ins></span><br />\n<br />\n第三波疫情爆發初期，已有多名專家點出免檢疫造成漏洞。周四（23日）港大醫學院公布，根據部分確診者的病毒基因，發現第三波並非源於5月和6月的本地個案。港大醫學院院長梁卓偉因此估計，新一波疫情源於多名獲豁免檢疫者，經的士司機傳入社區，並形成最少3個播毒源頭。<br />\n<span class=\"red\"><ins>病毒基因反映第三波唔係本地個案傳染</ins></span><br />\n<br />\n袁國勇在接受電視訪問中同時估計，零號個案很可能是的士司機，並可能在機場接載過新冠病毒肺炎患者而感染，&ldquo;的士司機其中接客的地方是機場，很可能（患者）坐的士，的士司機惹到（病毒），他們去了不同食肆，將病毒傳給員工，員工再傳給顧客，於是社區大爆發，因為經其他交通工具去到各區&rdquo;。<br />\n<ins><span class=\"red\">點解中咗招仲可以喺機場搭的士？因為有免檢疫，而社區爆發原因源於免檢疫人士出市區。<br />\n</span></ins><br />\n<br />\n<br />\n<span class=\"xx-large\"><strong><ins>咁大個漏洞無專家同政府講？</ins></strong></span><br />\n<br />\n最早指出邊境漏洞的，是政府專家顧問袁國勇、許樹昌，那時候是7月中，每日新增確診數字仍徘徊40宗左右。他們提出疫情源頭可能是豁免人士，的士司機接載過他們之後將病毒帶到社區。但<span class=\"red\">政府隨即在7月19日發稿反駁，認為說法是誤解，食物及衛生局局長陳肇始同日亦都指說法無證據支持</span>。<br />\n<span class=\"red\"><ins><strong>完全無視專家顧問意見</strong></ins></span><br />\n<br />\n身兼政府專家顧問的中文大學醫學院呼吸系統學講座教授許樹昌，7月21日接受眾新聞訪問，披露自7月8日政府開始為抵港機組人員及海員做病毒測試，至少有10多名獲豁免檢疫的海員、機組人員已經確診，而且早於6月尾已經有貨機機師、9名香港登船海員確診，<span class=\"red\"><ins><strong>支持「邊境漏洞」一說</strong></ins></span>。後來，<strong><span class=\"red\">理大團隊的分析發現第三波疫情多個大型群組患者的基因排序，與菲律賓、哈薩克的輸入個案相似，陳肇始終於7月28日承認豁免人士可能是源頭的說法，</span></strong>有證據支持、會嚴肅跟進。<br />\n<span class=\"red\"><strong><ins>科學角度睇 「邊境漏洞」有個案同證據支持</ins></strong></span><br />\n<br />\n<strong><ins><span class=\"x-large\">你以為政府承認咗免檢疫人士就係源頭，會有改善就控制到疫情？</span></ins></strong><br />\n政府經過第三波 繼續增加免檢疫名額：<br />\n政府推出的「回港易」計劃今起（23/11）實施，身處廣東省及澳門的港人，回港時可獲豁免14日強制檢疫，經由深圳灣口岸入境或港珠澳大橋香港口岸入境的名額，每日分別有3000個及2000個，<strong><span class=\"red\">已有超過1萬人申請預約本周回港。</span></strong>"},"citedBy":0,"replyTime":"2020-12-01T08:27:55.000Z","msg":"push"},{"pid":"9b1f0a1f2752859d60780afd074a14efbc800dcd","tid":2297142,"uid":23160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-01T08:31:13.000Z","msg":"疫情持續全因你當佢係一回事<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"5c45f14f087f461eb197cfdd6ebdfd86927ffacc","tid":2297142,"uid":36807,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-01T09:13:24.000Z","msg":"<img src=\"/assets/faces/cat/stretching.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/stretching.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/stretching.gif\" class=\"hkgmoji\" />"},{"pid":"8d586c3af3b0d24dfdcc0ade496a620aea79aeaf","tid":2297142,"uid":311128,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-01T09:16:47.000Z","msg":"個「東亞病夫」一早blk咗<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e1b795d8201c3e22408724efe0f57474a4847b95","tid":2297142,"uid":36807,"like":0,"dislike":0,"score":0,"quote":{"pid":"8d586c3af3b0d24dfdcc0ade496a620aea79aeaf","tid":2297142,"uid":311128,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-01T09:16:47.000Z","msg":"個「東亞病夫」一早blk咗<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-01T09:18:16.000Z","msg":"條友好奇怪<img src=\"/assets/faces/cat/annoyed.gif\" class=\"hkgmoji\" />"},{"pid":"b2b8c21f85d2d7d87d97d6bf257f835872de4aca","tid":2297142,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-02T03:57:48.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"23ba2b264a7ee3afa9d492ca14e9340d60d6774a","tid":2297142,"uid":36807,"like":0,"dislike":0,"score":0,"quote":{"pid":"b2b8c21f85d2d7d87d97d6bf257f835872de4aca","tid":2297142,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-02T03:57:48.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-02T03:59:24.000Z","msg":"<img src=\"/assets/faces/cat/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/angel.gif\" class=\"hkgmoji\" />"},{"pid":"7bfeda9504f2292e97915728aca909923e04a32d","tid":2297142,"uid":174013,"like":2,"dislike":0,"score":2,"quote":{"pid":"e1b795d8201c3e22408724efe0f57474a4847b95","tid":2297142,"uid":36807,"like":0,"dislike":0,"score":0,"quote":{"pid":"8d586c3af3b0d24dfdcc0ade496a620aea79aeaf","tid":2297142,"uid":311128,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-01T09:16:47.000Z","msg":"個「東亞病夫」一早blk咗<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-01T09:18:16.000Z","msg":"條友好奇怪<img src=\"/assets/faces/cat/annoyed.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-02T04:04:47.000Z","msg":"一係pr狗，一係弱智"},{"pid":"a31e657cbeea867341b08a303a6ea64a8db68008","tid":2297142,"uid":72058,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-02T04:06:39.000Z","msg":"<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" />"},{"pid":"6191e755ff7bcf022d428daa3114ca5b64c142c7","tid":2297142,"uid":36807,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-02T05:22:49.000Z","msg":"<img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" />"},{"pid":"eab821784682953e993845fd4d40673ccfdb5f9e","tid":2297142,"uid":36807,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-02T09:51:38.000Z","msg":"男子透過「回港易」計劃抵港後確診 <br />\n<br />\n一名確診新型冠狀病毒65歲男病人，經「回港易」從內地回港後確診。有關個案是昨日公佈的個案，衛生防護中心相信，他在本地感染。 <br />\n<br />\n衛生防護中心傳染病處主任張竹君指，這名病人上周三經「回港易」回港，回港前有病毒測試陰性結果，獲豁免檢疫，是養和醫院逝世確診患者的親友，死亡患者上周三起發燒，而回港易患者至前日發燒，而養和醫院有醫護確診，因此相信他在醫院內，透過其他家庭成員受感染，較在內地感染機會大。"},{"pid":"aaba9de8f8c73818dbfd9ab86315b836a88a2c55","tid":2297142,"uid":198035,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-07T17:37:24.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"94f85c6b33a91