/faces/lm2/cry.gif\" class=\"hkgmoji\" />"},{"pid":"45f816ab98454a2125219cae46ad79d320301f47","tid":2446274,"uid":88504,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-14T11:44:02.000Z","msg":"可能係金錢癬，要睇皮膚科，食類固醇"},{"pid":"ea9d9a84e71b9d97a4d41b26424b161d53f7bf33","tid":2446274,"uid":393300,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-14T11:46:56.000Z","msg":"濕疹，先搵出致敏原，可能係食物，可以戒食牛肉，海鮮，蛋，奶及奶製品<br />\n<br />\n可能係休息時間唔夠，要盡量固定作息時間，一日最少瞓7個鐘<br />\n<br />\n可能係壓力，工作壓力或生活壓力，咁呢個就冇L得搞，要避開壓力來源就自然會好"},{"pid":"0128a96abb54537679dea3e869c9b655cca2bbb4","tid":2446274,"uid":298442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-14T11:47:21.000Z","msg":"一睇就知生癬啦 <br />\n食兩個星期抗真菌藥 搽藥膏 <br />\n兩個星期內會好返 去睇皮膚科專科啦 <br />\n你唔理佢 只會越生越大撻<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c7b976a2e45770c497ff63fdf1ca31470be38d42","tid":2446274,"uid":393300,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-14T11:48:50.000Z","msg":"我以前濕疹斷斷續續成10年，最後自己好返，冇搽過一次類固醇。<br />\n<br />\n仲有要定期做下運動"}]}