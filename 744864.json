gmoji\" />"},{"pid":"9c0809276be6ea8bfe7dacbcaa2ab5b4ba996b07","tid":744864,"uid":45657,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-07-16T11:44:34.000Z","msg":"畀埃及人知道 佢哋死撚緊"},{"pid":"6b974a0d8d2daa88f7846dd0c789e7b2b8585b2f","tid":744864,"uid":37413,"like":12,"dislike":6,"score":6,"citedBy":4,"replyTime":"2018-07-16T11:46:24.000Z","msg":"同支那狗一樣係低劣人種，偏偏呢兩個民族大量繁殖，人口最多<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"c6de1da8b77ff73b01b6132e74491e56d8bb68a2","tid":744864,"uid":1977,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-07-16T11:48:28.000Z","msg":"餓到佢地互咬唔係仲好睇咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"85f1a63a38fc49744ffc45fe2bb72cac082fd64e","tid":744864,"uid":134323,"like":0,"dislike":6,"score":-6,"citedBy":0,"replyTime":"2018-07-16T11:48:55.000Z","msg":"中國有無殺過印度人<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"2c9016400b3053cef9066a81ee1b4e7fe5ffb843","tid":744864,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-16T11:51:26.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"ce6057fc7dfe9d270587ae14c43714ee80b1e73a","tid":744864,"uid":144024,"like":0,"dislike":0,"score":0,"quote":{"pid":"f7b33d7e6ccda271b7b97a587aeb2900984d4879","tid":744864,"uid":36029,"like":70,"dislike":5,"score":65,"quote":{"pid":"661e31b518e4db519873c6e8d04a3acce7b6f999","tid":744864,"uid":142819,"like":125,"dislike":1,"score":124,"citedBy":1,"replyTime":"2018-07-16T09:40:50.000Z","msg":"會唔會有啲鱷魚係度扮死  等待覆灼<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-16T10:08:52.000Z","msg":"估國家？ 報復人類屠殺鱷魚 鱷魚群集體咬死292個人<br />\n<br />\n印尼發生屠殺人類慘案！一座位於印尼東部的小鎮，鱷魚群為了報復屠殺鱷魚的村民，竟然決定咬死早前在養殖場外居住的村民，數量高達292個。<br />\n<br />\n當地媒體報導，西巴布亞（West Papua）因鱷魚誤咬死人事件，一群村民拿著斧頭、棍棒及利刃，擅自衝進養殖場把所有292隻鱷魚全部殺光，結果屍體被堆成一堆，畫面相當驚人。其他附近的鱷魚上周六為他們舉行完喪禮後，決定要展開報復，一堆鱷魚紛紛伸出利牙及利爪，衝進養殖場外的部落把所有村民合共292個人全部殺光，屍體偏佈如山，畫面相當恐怖。<br />\n地方首領表示，這座養殖場外的部落村民擁有合法居留權，西巴布亞的原住部落已有一段長久的歷史。雖然先前的確是鱷魚咬死了人類，他們才繼而展開報復，此具對當地的養殖鱷魚形成了困擾，但其他鱷魚把所有村民全殺光，也實在令人無法接受。西巴布亞自然資源獵食首領馬努郎（Basar Manullang）說：「人類也是造物者賜與的生命，牠們也需要受到保護。」<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/07/16/180648_c56397e21edef422a99d281df0e7dd46.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F16%2F180648_c56397e21edef422a99d281df0e7dd46.png&h=8364e045&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-07-16T11:53:46.000Z","msg":"之後又到村民嘅朋友覆灼，又殺返292條鱷魚"},{"pid":"8813d3f5c3d453d3942b2419a29eb695f85ad20b","tid":744864,"uid":4934,"like":42,"dislike":1,"score":41,"citedBy":0,"replyTime":"2018-07-16T11:54:07.000Z","msg":"擅自進入一座鱷魚養殖場，結果被養殖場內的鱷魚攻擊狠咬，男子傷重不治死亡<br />\n<br />\n條友自己戇鳩在先 做乜要搵鱷魚陪葬"},{"pid":"2d8a137251cbfd95809b3017044c40767c66a13a","tid":744864,"uid":68728,"like":6,"dislike":11,"score":-5,"citedBy":1,"replyTime":"2018-07-16T11:55:28.000Z","msg":"鱷魚殺人就得 人殺鱷魚就唔得 咩世界<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"5b4c773eab9089a0942f106ff43cc24d5f81aa11","tid":744864,"uid":120729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-16T12:01:36.000Z","msg":"估啱咗一個字<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"ef5a1ef0f0d3bcb5e84e34e2614ba64c9fb29fb3","tid":744864,"uid":3180,"like":15,"dislike":0,"score":15,"quote":{"pid":"2d8a137251cbfd95809b3017044c40767c66a13a","tid":744864,"uid":68728,"like":6,"dislike":11,"score":-5,"citedBy":1,"replyTime":"2018-07-16T11:55:28.000Z","msg":"鱷魚殺人就得 人殺鱷魚就唔得 咩世界<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-16T12:02:33.000Z","msg":"一命填一命呀 做咩要死全家先"},{"pid":"fa82ac58c15d9124f93d6addfe4d552338509a56","tid":744864,"uid":116896,"like":1,"dislike":5,"score":-4,"citedBy":0,"replyTime":"2018-07-16T12:04:28.000Z","msg":"無用槍算公平決鬥啦<br />\n值得尊重"},{"pid":"cc1f8e5d48b99130d6