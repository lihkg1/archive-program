e":0,"dislike":0,"score":0,"quote":{"pid":"bfbb7aa5ea856bf17bd35bd724386181305c6093","tid":788251,"uid":199360,"like":0,"dislike":0,"score":0,"quote":{"pid":"8bf17a2464c8cb957db2a33203fbbff0a6e33808","tid":788251,"uid":176657,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-22T07:02:15.000Z","msg":"又係十月去，我仲未bk住宿<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-22T08:30:37.000Z","msg":"你幾多人會？揀酒店訂民宿"},"citedBy":0,"replyTime":"2018-08-22T08:37:49.000Z","msg":"一個人去 應該會揀酒店喇<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"539d4ff45ccf2112c5b0587141ce56c049c65173","tid":788251,"uid":43545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-22T08:45:33.000Z","msg":"先搵d 可以免費cancel既book 左先<br />\nPlan 好有其他選擇再book 間新cancel 舊果間<br />\n<br />\nPs:決定左轉就唔好hold 住人地間房咁仆街"},{"pid":"50e89b654d4a51eaa450bccc20cfe6c887ed7c50","tid":788251,"uid":201374,"like":0,"dislike":0,"score":0,"quote":{"pid":"7b044d367e5d3bbacbb289003ef0f8e52f4bab6a","tid":788251,"uid":199360,"like":0,"dislike":0,"score":0,"quote":{"pid":"d6342c4440c90c0cac1b91d28a485434983a75a9","tid":788251,"uid":52605,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-08-22T06:59:17.000Z","msg":"大阪梗係訂新今宮嗰堆酒店 <br />\n平過棺材酒店 又有個人空間 不過要共用廁所"},"citedBy":1,"replyTime":"2018-08-22T08:30:11.000Z","msg":"嗰堆酒店 每晚幾錢左右？"},"citedBy":0,"replyTime":"2018-08-22T08:57:35.000Z","msg":"我上年住過兩晚&quot;ビジネスホテル　福助&quot;<br />\n平係堅平，單人房1300~1500yen/day<br />\n3.5畳，應該細過監倉<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/22/164911_8f438ee8321f69b337a8a7bf433519c7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F22%2F164911_8f438ee8321f69b337a8a7bf433519c7.jpg&h=485a67c3&s={SIZE}\" /><br />\n不過個環境真係唔多得<br />\n牆身好似紙板咁薄，有人住嘅話行行企企都聽到動靜，走廊有人行過都聽到<br />\n試過夜晚出房去廁所，返房關門唔小心大力咗，隔離即刻大大力拍牆<br />\n間房本身幾乾淨，但廁所同沖涼房有尿餲味<br />\n好就好在都算係一間房，可以放行李同鎖門<br />\n但如果背包遊我會揀膠囊/青旅"},{"pid":"c64e3e17ab4ad54998178d24e8e3ea6aab35221a","tid":788251,"uid":21378,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-22T11:41:33.000Z","msg":"10月中   開始多人BOOK 房 有紅葉睇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n要提早BOOK 定"}]}