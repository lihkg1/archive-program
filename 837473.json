.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2018%2F06%2F07%2FTYKm6u.gif&h=253e8d20&s={SIZE}\" />"},{"pid":"51592bcd47aa89f352a5326ec2f2aa797f676f68","tid":837473,"uid":191019,"like":10,"dislike":1,"score":9,"citedBy":0,"replyTime":"2018-09-26T11:51:28.000Z","msg":"香港最後都係輸硬<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"77a6afdcbda51d62bcad24c6eee66ddbb5df84bf","tid":837473,"uid":68896,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-26T11:51:34.000Z","msg":"跪低？<img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"890c0b8fb782c96f7dedd57a3bc086f2d2cc68a2","tid":837473,"uid":74171,"like":1,"dislike":0,"score":1,"quote":{"pid":"77a6afdcbda51d62bcad24c6eee66ddbb5df84bf","tid":837473,"uid":68896,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-26T11:51:34.000Z","msg":"跪低？<img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-26T11:53:51.000Z","msg":"唔係啦<br />\n做乜都好，一定係最後贏家"},{"pid":"3eb808dfcc14a5eb3099f2593a7cbded79f07c3e","tid":837473,"uid":48083,"like":6,"dislike":1,"score":5,"citedBy":2,"replyTime":"2018-09-26T11:53:57.000Z","msg":"王毅原文好強調有得傾<br />\n我自己覺得係比之前軟化咗<br />\n日月報咁寫，可能係對內（港豬）吹勁啲費事冇面<br />\n<br />\n陸外長王毅 批美沒誠意談判<br />\n<br />\n工商時報【黃欣╱綜合報導】<br />\n<br />\n中美經貿談判暫時中斷，使得貿易戰局勢更加險峻。中國國務委員兼外交部長王毅昨（25）日會見美中關係全國委員會、美中貿易全國委員會負責人時強調，<span style=\"color: red;\">中國無意尋求貿易順差，也願意通過協商解決貿易不平衡問題，但美方在新一輪對話前夕啟動更大規模的單邊徵稅行動，「只能說明沒有解決問題的誠意」。他強調，中方願和美方重啟談判，前提是應建立於平等和誠信的基礎上。</span><br />\n<br />\n根據中國外交部官網的新聞稿，王毅針對美於24日起正式對2,000億美元中國商品加徵關的措施，提出抨擊，他表示，徵稅的時間點正好在中美新一輪對話前夕，「顯示美方沒有解決問題的誠意」。中國將繼續堅定深化改革、擴大開放，中國仍然是發展中國家，需要根據自身國情有序地推進改革進程。<br />\n<br />\n<a href=\"https://tw.mobi.yahoo.com/news/陸外長王毅-批美沒誠意談判-215013590--finance.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftw.mobi.yahoo.com%2Fnews%2F%E9%99%B8%E5%A4%96%E9%95%B7%E7%8E%8B%E6%AF%85-%E6%89%B9%E7%BE%8E%E6%B2%92%E8%AA%A0%E6%84%8F%E8%AB%87%E5%88%A4-215013590--finance.html&d=Df%2F4XjLza5srvzb%2B%2BQj%2Fb7IOlR6kLHi1VdsYCD5DrTY%3D&h=59013645\" target=\"_blank\">https://tw.mobi.yahoo.com/news/陸外長王毅-批美沒誠意談判-215013590--finance.html</a>"},{"pid":"e122bc16102edfa5b95830573e32347b09ad14a0","tid":837473,"uid":48083,"like":23,"dislike":0,"score":23,"citedBy":0,"replyTime":"2018-09-26T11:55:31.000Z","msg":"同埋唔俾軍艦入黎係因為凍結共官資產<br />\n咁寫係spin到個原因變咗貿易戰<img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" />"},{"pid":"3ebdbc8525de397d93a32beab41d12562e54e7fc","tid":837473,"uid":140538,"like":35,"dislike":0,"score":35,"citedBy":1,"replyTime":"2018-09-26T11:58:04.000Z","msg":"短評指出，自從中國與美國展開貿易戰以來，中方一直忍口不出惡言<br />\n<img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"b279ab756c9ae96179f44293b63e00492c1ed6ac","tid":837473,"uid":121146,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-09-26T11:58:06.000Z","msg":"中國或成最大嬴家"},{"pid":"bb47ed589ad201f1e738d7315a79ef682daee3e1","tid":837473,"uid":121146,"like":33,"dislike":0,"score":33,"quote":{"pid":"3ebdbc8525de397d93a32beab41d12562e54e7fc","tid":837473,"uid":140538,"like":35,"dislike":0,"score":35,"citedBy":1,"replyTime":"2018-09-26T11:58:04.000Z","msg":"短評指出，自從中國與美國展開貿易戰以來，中方一直忍口不出惡言<br />\n<img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-26T11:59:00.000Z","msg":"e句既意思係咪指  未展開貿易戰以前  中方都不斷出口惡言 <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b0cd6d8fe44f83d45838a79263ad290b930bfcdf","tid