src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"2eb97bff60d5e84abb0a9a50709089f6f570e949","tid":1646741,"uid":169665,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-11T12:45:28.000Z","msg":"外國政府快收返哂黨鐵經營權啦 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n又成日炒車唔安全，又受中共政治干預鐵路運作"},{"pid":"774290161597d9746c151ad648628a68da2d215a","tid":1646741,"uid":53062,"like":0,"dislike":0,"score":0,"quote":{"pid":"2bb47108692bb4d935d64b06c0a6632c0f923339","tid":1646741,"uid":51271,"like":0,"dislike":0,"score":0,"quote":{"pid":"15fb99445090b4f96341e9b9f538814ef2c5a19b","tid":1646741,"uid":155137,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-10-11T12:23:42.000Z","msg":"就算日日啲人咪又係照搭 吹咩<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-10-11T12:35:52.000Z","msg":"你估個個有比錢<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-11T12:47:56.000Z","msg":"日日用緊綠卡<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"ea7fcab5cba38b0eb5ef411a03546845c12d9730","tid":1646741,"uid":307619,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-11T13:55:27.000Z","msg":"警世<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n今時今日<br />\n如果<span style=\"color: orange;\">有其他選擇嘅情況</span><br />\n你仍俾正價搭黨鐵<br />\n<span style=\"color: brown;\">你每搭1蚊<br />\n嗰1蚊就係資助佢地運狗<br />\n同埋出賣港人</span><br />\n你良心過唔過意得去<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">黨鐵仲唔笑你班人無骨氣咩</span></span><br />\n<br />\n<img src=\"https://na.cx/i/kkkdJhO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FkkkdJhO.jpg&h=58322cc9&s={SIZE}\" /><img src=\"https://na.cx/i/55r07Ku.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F55r07Ku.jpg&h=b2de0f25&s={SIZE}\" />"}]}