ike":0,"score":0,"quote":{"pid":"f2b7d507758f36769f084a31ffa3092623f12229","tid":2505774,"uid":33359,"like":0,"dislike":1,"score":-1,"quote":{"pid":"b18b2061365b6f4cb84145d47c3d160e534f339f","tid":2505774,"uid":45255,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-27T01:03:24.000Z","msg":"印仔肯肯定係揀單人<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-04-27T01:03:54.000Z","msg":"是<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-27T01:15:27.000Z","msg":"你唔同定仔住？<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"a0cd355dde711d225938ed75b83a08681ac61691","tid":2505774,"uid":180515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-27T01:15:37.000Z","msg":"兩個人租單人單位得唔得<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"4cce0544b5e851035e37969109f4183bc1bff90b","tid":2505774,"uid":19552,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2021-04-27T01:44:30.000Z","msg":"大埔<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"},{"pid":"da3e9564df7a9ce7c4a40cd855bbcd45f5344b73","tid":2505774,"uid":71379,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-04-27T01:52:04.000Z","msg":"大埔咁遠 點去觀塘返工<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" />"},{"pid":"b1b3881c633452ba7ecd19cd7e4342829f25e4b2","tid":2505774,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-27T01:54:57.000Z","msg":"對面寶鄉邨2000蚊又大又新"},{"pid":"1b8d20bf576946ed6de35ff8e42b0b15d35075ae","tid":2505774,"uid":33359,"like":0,"dislike":1,"score":-1,"quote":{"pid":"4cce0544b5e851035e37969109f4183bc1bff90b","tid":2505774,"uid":19552,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2021-04-27T01:44:30.000Z","msg":"大埔<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-27T02:05:25.000Z","msg":"是<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid"