95%86-%E6%AA%94%E4%BD%8D%E6%8A%97%E8%AD%B0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E7%25A4%25BE%25E6%259C%2583%25E6%2596%25B0%25E8%2581%259E%2F352779%2F%25E6%259B%25B8%25E5%25B1%25952019-%25E6%259B%25B8%25E5%25B1%2595%25E6%258F%25AD%25E5%25B9%2595-%25E9%25A6%2599%25E6%25B8%25AF%25E7%259C%25BE%25E5%25BF%2597%25E6%2588%2590%25E5%2593%25A1%25E5%2588%25B0-%25E4%25B8%2589%25E4%25B8%25AD%25E5%2595%2586-%25E6%25AA%2594%25E4%25BD%258D%25E6%258A%2597%25E8%25AD%25B0&d=mJB0HZfowtkqKRKkSYSHE%2FaDgzkAO6tKN2FhpyhCcE0%3D&h=ecd2c7cc\" data-auto-link target=\"_blank\">https://www.hk01.com/%E7%A4%BE%E6%9C%83%E6%96%B0%E8%81%9E/352779/%E6%9B%B8%E5%B1%952019-%E6%9B%B8%E5%B1%95%E6%8F%AD%E5%B9%95-%E9%A6%99%E6%B8%AF%E7%9C%BE%E5%BF%97%E6%88%90%E5%93%A1%E5%88%B0-%E4%B8%89%E4%B8%AD%E5%95%86-%E6%AA%94%E4%BD%8D%E6%8A%97%E8%AD%B0</a>"},"citedBy":1,"replyTime":"2019-07-18T17:58:43.000Z","msg":"第一日去果陣見到佢<br />\n見到有好多人係三中商買書, 唔知d人係因為唔知三中商係咩定係覺得唔關佢事"},"citedBy":1,"replyTime":"2019-07-18T18:03:08.000Z","msg":"去書展既多數斯文人, 斯文人普遍唔支持暴力行為, 大聲吶喊只會令在場人士更反感, 在入面要用番合適方法, 一味大叫同女人扑野亂鳩咁叫無分別"},"citedBy":0,"replyTime":"2019-07-18T18:07:03.000Z","msg":"其實呢幾年都有人係個到示威<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />但作用都好似不大咁<br />\n當年個記者刮到背後係中聯辦做大老細都以為一定震驚成個社會 但最後迴響都不大<br />\n三中商而家一樣咁撈得<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n可能大家覺得個影響唔係太貼身<img src=\"/assets/faces/fs/lomore_smile.gif\" class=\"hkgmoji\" />但其實佢嘅影響係好大 仲要影響香港下一代 慢慢灌輸大中華情意 唔比啲人接觸其他反對聲音 其實就係維穩"},{"pid":"0d569df8450ee898a25a1f4e8d9b7e34d4db0595","tid":1330840,"uid":162626,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-18T18:07:51.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"cf4a334a7d06924aa5be4eaa3082d04edba30d77","tid":1330840,"uid":162626,"like":0,"dislike":0,"score":0,"quote":{"pid":"0d569df8450ee898a25a1f4e8d9b7e34d4db0595","tid":1330840,"uid":162626,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-07-18T18:07:51.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-18T18:08:20.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"53580da5673ff3cae88db37d6fa4d758c8b0c74d","tid":1330840,"uid":273252,"like":0,"dislike":0,"score":0,"quote":{"pid":"368077b952fe8721e4100ecdfb890755277e9f11","tid":1330840,"uid":212365,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-18T17:13:50.000Z","msg":"一年一度嘅書展又黎<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n呢到多左咁多uncle auntie 相信你地都會帶啲仔女去行下買下書咁(補充練習就唔好喇<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />) <br />\n而家香港咁亂咁緊張去下行書展唔緊要 但緊記<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">抵制三中商！！</span></span><br />\n三中商係咩？<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><br />\n佢地係三聯書店、中華書局同商務嘅代稱。而呢三間大型連鎖書店已經係多年前被揭發係由中聯辦直接持有！<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n意味著中共暗中操控住文化傳播，係你揀書睇前佢已經幫你揀左先！<br />\n<br />\n三中商全部隸屬於聯合出版集團<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />佢地唔單單話唔比你本書係佢舖頭賣，更加控制埋出版同物流，只要你本書比佢地定義為「敏感」你就唔使指意可以係佢地到出書<br />\n而「敏感」嘅書籍絕對唔單指政治書籍，一啲比較開放嘅議題例如同性戀、LGBTQ嘅書籍都有可能不被出版。<br />\n同場加映：寫BL小說遭判監10年 網民批刑罰過重<br />\n<a href=\"https://china.hket.com/article/2211091/%E5%AF%ABBL%E5%B0%8F%E8%AA%AA%E9%81%AD%E5%88%A4%E7%9B%A310%E5%B9%B4%20%E7%B6%B2%E6%B0%91%E6%89%B9%E5%88%91%E7%BD%B0%E9%81%8E%E9%87%8D\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fchina.hket.com%2Farticle%2F2211091%2F%25E5%25AF%25ABBL%25E5%25B0%258F%25E8%25AA%25AA%25E9%2581%25AD%25E5%2588%25A4%25E7%259B%25A310%25E5%25B9%25B4%2520%25E7%25B6%25B2%25E6%25B0%2591%25E6%2589%25B9%25E5%2588%2591%25E7%25BD%25B0%25E9%2581%258E%25E9%2587%258D&d=mJB0HZfowtkqKRKkSYSHE%2FaDgzkAO6tKN2FhpyhCcE0%3D&h=7046a94a\" data-auto-link target=\"_blank\">https://china.hket.com/article/2211091/%E5%AF%ABBL%E5%B0%8F%E8%AA%AA%E9%81%AD%E5%88%A4%E7%9B%A310%E5%B9%B4%20%E7%B6%B2%E6%B0%91%E6%89%B9%E5%88%91%E7%BD%B0%E9%81%8E%E9%87%8D</a><br />\n無錯，係中國就係連出一本講同性戀嘅書都可以比人拉去坐監。中共係香港當然唔會咁大膽，就係靠呢啲軟性嘅控制，令到我地慢慢接觸講大中華嘅書多左，控制我地嘅思想同言論。最可怕嘅係，我地可能唔會察覺<img src=\"/assets/faces/fs/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: green;\">咁對我地有咩影響？</span><br />\n第一，佢危害到香港嘅出版自由。<br />\n不少作家嘅書因為題材被定義為敏感就未能出版，而三中商佔香港約一半的零售網絡，缺少呢啲零售點，呢啲作家同獨立出版商都非常難經營。<br />\n第二，佢踐踏緊一國兩制。<br />\n暗地裡插手我地嘅出版同文化交流，無疑係扼殺緊香港人嘅核心價值， 踐踏思想自由。<br />\n第三，代表緊我地送緊錢比中共洗呀！！<br />\n屌你老母！助長班仆街！文化係軟實力呀！<br />\n<br />\n想了解多啲三中商背後嘅運作同手段推介你睇呢段鏗鏘集<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<a href=\"http://m.liberalstudies.hk/video/programme.php?vid=tcs18-1753\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fm.liberalstudies.hk%2Fvideo%2Fprogramme.php%3Fvid%3Dtcs18-1753&d=mJB0HZfowtkqKRKkSYSHE%2FaDgzkAO6tKN2FhpyhCcE0%3D&h=a35806ff\" data-auto-link target=\"_blank\">http://m.liberalstudies.hk/video/programme.php?vid=tcs18-1753</a><br />\n<br />\n其實香港仲有好多獨立嘅書店又好多唔同種類嘅書<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />加上小店比起大集團難經營 希望大家都可以支持下本地嘅書店同創作啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />一嚟抵制紅色滲透 二嚟支持小店<br />\n以下開放討論有咩香港書店值得推介<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />大家多啲幫襯"},"citedBy":0,"replyTime":"2019-07-19T03:27:37.000Z","msg":"去書展幫手airdrop條影片<br />\n<br />\n<a href=\"https://youtu.be/tIn4OMx-UdA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FtIn4OMx-UdA&d=mJB0HZfowtkqKRKkSYSHE%2FaDgzkAO6tKN2FhpyhCcE0%3D&h=2dc62f4f\" data-auto-link target=\"_blank\">https://youtu.be/tIn4OMx-UdA</a><br />\n<br />\n<br />\n[有片有download Link]蘆葦蔥暗地表示藍白衫克警係暴徒<br />\n<br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<a href=\"https://lih.kg/1326547\" data-auto-link target=\"_blank\">https://lih.kg/1326547</a>"}]}