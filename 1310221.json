幾耐"},{"pid":"9a4b06bd88fd6b9b993c649df25da10e6341e369","tid":1310221,"uid":173952,"like":0,"dislike":0,"score":0,"quote":{"pid":"3efa5beb30b30d55d75cae11defe7124aa0f04b3","tid":1310221,"uid":43785,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-12T15:13:53.000Z","msg":"完未呀今次？<br />\n48小時內講左幾耐"},"citedBy":0,"replyTime":"2019-07-12T15:15:39.000Z","msg":"即將官宣"},{"pid":"4326e5000d8b3619367106f8de6aec55cb0f9d24","tid":1310221,"uid":34490,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T15:19:12.000Z","msg":"真係好煩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cbdadfab4d7b5f33ccf3d8ba849400d7f42b1c1f","tid":1310221,"uid":173952,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-13T06:13:00.000Z","msg":"訓醒，份文件仲未整好<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"fbe02cc5e1cb69c64dadf73d94cb7ffb727560fa","tid":1310221,"uid":70988,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T07:58:16.000Z","msg":"麥龜 1億<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c212e270cdb42a38efc80d44bfc3af555c90b2da","tid":1310221,"uid":173952,"like":0,"dislike":0,"score":0,"quote":{"pid":"cbdadfab4d7b5f33ccf3d8ba849400d7f42b1c1f","tid":1310221,"uid":173952,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-13T06:13:00.000Z","msg":"訓醒，份文件仲未整好<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-13T11:02:20.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}