kgmoji\" />"},{"pid":"dddbfb7232d2ee1c0d8ca7e8a2d477ebba2207f3","tid":896291,"uid":125193,"like":0,"dislike":0,"score":0,"quote":{"pid":"ba9c1ce929522f9e3bad66396463cfb9fae71d80","tid":896291,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-10T01:40:35.000Z","msg":"<img src=\"https://fs.mingpao.com/pns/20181110/s00007/c1e8f6a206f1dda64c91796677725ac9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffs.mingpao.com%2Fpns%2F20181110%2Fs00007%2Fc1e8f6a206f1dda64c91796677725ac9.jpg&h=eb339b18&s={SIZE}\" /><br />\n<br />\n【明報專訊】經港珠澳大橋來港的內地客聚集東涌惹地區不滿，政府設法分流人潮至市區，但有從羅湖入境的旅客，在尖沙嘴掃貨後，反而想到東涌再血拼。<br />\n<br />\n「崇光（SOGO）感謝周年慶」昨展開，記者昨午2時到尖沙嘴SOGO中間道門市，目測約200多人排隊，入口塞滿人，場內同樣水泄不通。至於銅鑼灣SOGO門市亦人頭湧湧，昨午約3時半，該店人龍從正門排到東角道。<br />\n<br />\n來自深圳的王小姐和齊小姐，昨早從羅湖口岸過關到港，約10時抵達尖沙嘴SOGO。王小姐表示買了香水、護膚品和鞋，共花費約8000港元。齊小姐則不欲排隊，貨品也不太適合自己，反問記者東薈城怎去，準備與王小姐一起「轉戰」東涌。她們又表示，有了高鐵來港方便了不少，齊小姐月前從長沙到香港，僅花3個半小時；但港珠澳大橋對她們幫助不大，現不會考慮以此方法到港。<br />\n<br />\n排隊4小時購物 「不清楚便宜多少」<br />\n<br />\n乘坐高鐵從廣州至香港購物的藍小姐說，昨午1時左右到達尖沙嘴SOGO，高鐵令她能更快更方便到港。她說自己不是「代購」，只花了1000多元買了資生堂護膚品，不太想再排隊，但笑說已預留時間，買了最晚一班高鐵回廣州。<br />\n<br />\n同樣從廣州乘坐高鐵來港的李小姐則到銅鑼灣SOGO購物，她稱已花兩小時排隊買護膚品，準備再花兩小時排隊買另一品牌貨品 ，但她表示「其實我不清楚（貨品）便宜了多少」。<br />\n<br />\n<a href=\"https://news.mingpao.com/pns/dailynews/web_tc/article/20181110/s00002/1541788761958\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2Fdailynews%2Fweb_tc%2Farticle%2F20181110%2Fs00002%2F1541788761958&d=zfwdrVeov7tmN0wJiUKtBozu7PIJYhBZqlGrkalTKs4%3D&h=97f128d7\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2Fdailynews%2Fweb_tc%2Farticle%2F20181110%2Fs00002%2F1541788761958&h=9509e7a7\" target=\"_blank\">https://news.mingpao.com/pns/dailynews/web_tc/article/20181110/s00002/1541788761958</a>"},"citedBy":0,"replyTime":"2018-11-10T16:21:07.000Z","msg":"好呀 姐係成條東涌線都有大量蝗蟲搭<br />\n一齊仆街啦on 9 仔<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" />"},{"pid":"42ac03f365f9cf48dcf3d00ee70cc5930c9e3670","tid":896291,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-11T04:14:20.000Z","msg":"<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"}]}