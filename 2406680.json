aces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"b3c37416de1e9b839cbc38c17ed6ed487d915d7b","tid":2406680,"uid":48362,"like":9,"dislike":13,"score":-4,"citedBy":0,"replyTime":"2021-02-13T14:00:03.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"0692cf08a4ee39288e6cd950a727184ff9445b09","tid":2406680,"uid":332345,"like":0,"dislike":0,"score":0,"quote":{"pid":"da26dddf984f9e0ebd5cbff977d2d32ccfb5501f","tid":2406680,"uid":18547,"like":0,"dislike":1,"score":-1,"quote":{"pid":"1b8381bd47f362285a2a40c7f61cd00b96b3f26b","tid":2406680,"uid":155818,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-13T11:58:02.000Z","msg":"無<br />\n我都想知買咩醫保會好D"},"citedBy":2,"replyTime":"2021-02-13T12:08:10.000Z","msg":"諗住買自願醫保<img src=\"/assets/faces/lm2lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2lny/sosad.gif\" class=\"hkgmoji\" />會唔會好on9"},"citedBy":0,"replyTime":"2021-02-13T15:50:09.000Z","msg":"唔會"},{"pid":"39b10832748112aa4532574dea8158e7ef737348","tid":2406680,"uid":294066,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2021-02-13T16:01:26.000Z","msg":"識做生意既朋友唔買保險，因為做生意就係用風險換錢，而保險就係用錢減風險。<br />\n<br />\n我有買，但好後悔。如果我可以再選擇，我會：<br />\n<br />\n1. 計埋機會率後，睇下其他投資會否好過保險。一般都係投資抵D<br />\n3. 睇下有咩病可以接受無錢入公家醫，保險就唔洗保呢D。例如cancer有錢都未必好既，入公家算。<br />\n3. 選份好工，有埋醫保既。公司既plan一般都真係抵。"},{"pid":"821c4c143f924c4a8e982e971b05e4bc90aa8d7a","tid":2406680,"uid":27210,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-02-13T16:06:40.000Z","msg":"有買開但有次發窮惡cut咗"},{"pid":"32a908acf9de1e590e31a08944b0a27ea1145ef2","tid":2406680,"uid":157676,"like":0,"dislike":0,"score":0,"quote":{"pid":"edfa3f0ff7ba0cc5fca3c7af8748fa28560ba1ff","tid":2406680,"uid":18547,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2021-02-13T11:52:30.000Z","msg":"好奇問下<br />\n同朋友提起個個當我怪人咁<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /><br />\n<br />\n自己一直對保險無咩興趣（咩儲蓄、危疾個啲）<br />\n身邊個個都叫我起碼買份醫保，唔係到時啲積蓄一鋪清袋<br />\n但係我又寧願將啲錢自己滾大佢好過<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-13T16:18:08.000Z","msg":"保險最大好處係 萬一有事，有份保險頂左你巨大開支失去的預算<img src=\"/assets/faces/cow/power.gif\" class=\"hkgmoji\" /><br />\n<br />\n但首先要問下自己<br />\n你公司有無團體保？<br />\n就算有團體保，有無SMM 呢d附加保？<br />\n<br />\n如果全部有，你相信自己身體健康既話 可以乜都唔駛買<br />\n一般SMM 都可以一年食到25萬，如果唔係咩嚴重病，打爆左basic plan 去claim SMM 個pool 都係自己俾20%<br />\n<br />\n如果有cancer 呢d病就麻煩，基本上係燒錢...<br />\n呢個情況你可能要買 canner 呢類保險<br />\n<br />\n意外保係 最抵玩，成本低，萬一有意外（通常係交通意外），差不多100% claim 足<br />\n<br />\n如果你有老婆仔女供緊樓，人壽走唔甩<br />\n<br />\n危疾唔識講<img src=\"/assets/faces/cow/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c802f2132b1d53f5fa161a8a75416cf359b62ac3","tid":2406680,"uid":278219,"like":8,"dislike":0,"score":8,"quote":{"pid":"2b5c3748e4f22b1d51bd44d8e7778dc9d041f7aa","tid":2406680,"uid":64694,"like":15,"dislike":1,"score":14,"citedBy":2,"replyTime":"2021-02-13T12:01:06.000Z","msg":"其實最驚係你買完之後，咁啱你患嗰種病賠唔到咁就仆得街喇，重有係唔知到最後賠得足唔足"},"citedBy":0,"replyTime":"2021-02-13T16:24:22.000Z","msg":"講中真正最大既問題，小心有保險狗咬你"},{"pid":"5d1b1084dd440781c074f4c263a495801e09a9d5","tid":2406680,"uid":194876,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2021-02-14T08:46:36.000Z","msg":"做乜連燈仔成日講到投資一定賺<br />\n保險都係1個月千零蚊<br />\n差依千零蚊好似就冇錢投資咁"},{"pid":"dc251728249b8cadf40b46684d28f215ead44544","tid":2406680,"uid":93050,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2021-02-14T09:49:06.000Z","msg":"保險公司都係計過數先賣保險比你<br />\n<br />\n所以如果你係一個average 嘅人 你比嘅保費一定多過你之後claim 到嘅醫藥費<br />\n<br />\n利申<br />\n無買"},{"pid":"7f7dab9c9226005656be2b1137b85784d7573f5d","tid":2406680,"uid":21586,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-14T09:51:15.000Z","msg":"有 直到有次入左私家住一晚+MRI $15000<br />\n但出返黎都係冇買<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"dbbdde83faced205175feb9ed6c5d614c8533726","tid":2406680,"uid":120972,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-14T09:52:29.000Z","msg":"十幾年前買過兩份<br />\n一份醫保&nbsp;4百幾一個月&