1c34489a62dbc29dc","tid":1868402,"uid":22231,"like":1,"dislike":1,"score":0,"quote":{"pid":"1e64b41017687ff31d995d25948e1c4a2783548a","tid":1868402,"uid":320306,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2020-02-07T14:35:10.000Z","msg":"我個個都係咁<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-07T15:23:23.000Z","msg":"你個個女朋友都係咁？<br />\n你有幾多個😅"},{"pid":"822520199613dad815a3b4739dc9b03c94a9f365","tid":1868402,"uid":139676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-07T15:55:44.000Z","msg":"垃圾"},{"pid":"d96f63ff257b83154096d0807a3fa4945781b74e","tid":1868402,"uid":348357,"like":1,"dislike":0,"score":1,"quote":{"pid":"42c7d02cce9afe5309195bd05ae79f264d41956b","tid":1868402,"uid":142861,"like":0,"dislike":2,"score":-2,"quote":{"pid":"ed11643a98538a534ae90f7f6a5d988b821dc9bf","tid":1868402,"uid":348357,"like":0,"dislike":1,"score":-1,"quote":{"pid":"8c51baffb6201c9a5b5e3dd7b97a48ff5ca5dddc","tid":1868402,"uid":142861,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-02-07T14:20:02.000Z","msg":"知佢成日都將好多負面野都自己收埋自己去承受<br />\n佢成日覺得因為我同佢住得遠所以唔洗我黎搵佢<br />\n驚我返工攰 過黎搵佢會好辛苦<br />\n但我想講我真係唔介意任何野 我只想係佢唔開心既時候可以係佢身邊陪住佢幫佢分擔就夠<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />...."},"citedBy":1,"replyTime":"2020-02-07T14:39:51.000Z","msg":"一齊冇耐？"},"citedBy":3,"replyTime":"2020-02-07T14:41:52.000Z","msg":"係<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-07T16:02:58.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"1958647f43f82bd2