=\"/assets/faces/cat/stare.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-09T15:16:53.000Z","msg":"<img src=\"/assets/faces/mouse/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-09T15:18:06.000Z","msg":"咪撚柒囤貨啦撚樣<br />\n<br />\n<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"ca27446275a3fb2c22b779b6f730b7dc432023f9","tid":1871592,"uid":21742,"like":1,"dislike":0,"score":1,"quote":{"pid":"57e65a93e653b7cd881563789a30c79af504abcc","tid":1871592,"uid":61831,"like":8,"dislike":0,"score":8,"quote":{"pid":"9cbdbff2719b26854c4ac2443c086bf702e32772","tid":1871592,"uid":91442,"like":8,"dislike":0,"score":8,"quote":{"pid":"b9542852024e52fc973c4701f95946cdbacd926d","tid":1871592,"uid":150100,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-09T14:11:24.000Z","msg":"是咁的<br />\n今日約咗個兄弟出街食飯，個兄弟我中一frd到依家，識咗成10年<br />\n咁食食下飯佢就嚟料<br />\n我：<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><br />\n佢：<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n<br />\n佢：話說你搶唔搶到口罩？<br />\n我：搶到啲咁啦，本身有幾盒，網上訂嚟咗10盒，加埋出去排嗰啲都有十幾盒到<br />\n佢：咁多<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />可唔可以俾少少我<br />\n我：你冇咩？<br />\n佢：係，得返幾個咋，仲要返工<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><br />\n我：哦，係咩？<br />\n佢：堅㗎，幫下手啦<br />\n我：俾咗你我仲點屌閪呀？宜家市價1Q20個，處女double，好貴㗎。我得嗰十幾盒，已經嫌少<br />\n佢：整少少嚟啦，頂多我俾錢你<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n我：你自己唔去搵？<br />\n<br />\n講到依刻佢已經開始眼濕濕<br />\n<br />\n佢：我已經試過網上訂，但係俾人cut單，hktvmall又幾秒冇曬，出街排通宵又得嗰幾個，返幾日工都用曬&hellip;<br />\n<br />\n去到依刻我實在忍唔住，一嘢喝鳩佢<br />\n<br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">你同我跪喺度！！！<img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /></span></strong></span><br />\n<br />\n<br />\n<br />\n佢一嘢嚇到跪咗喺度，仲開始成個女人咁喊<br />\n<br />\n我：屌你老母臭閪，網上訂嘢都唔識，你弱智㗎？hktvmall幾秒就冇？咁你唔㩒快啲？屌你老母你小兒麻痺㗎？返工就用曬咁咪咪撚帶囉，你啲廢柴中肺炎死都抵啦。難得約出嚟食飯你問我攞口罩？你當我開善堂呀？係呀，我有口罩，但係就唔俾你，吹咩<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /> 我唔駛返工唔駛出街，就日日坐喺屋企數口罩，你咬我食呀<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<br />\n屌到依度佢開喊到收唔到聲，仲開始窒息<br />\n<br />\n咁我見一場朋友，就廢事再屌落去<br />\n於是我放低兩個口罩，同佢講當我施捨佢，依餐就你嘅就走咗去<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />：樓主屌得好，依啲損友唔屌唔得<br />\n<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />：我冇口罩，我係低能仔"},"citedBy":2,"replyTime":"2020-02-09T14:47:16.000Z","msg":"完全唔明你作個咁嘅故仔有乜意義"},"citedBy":1,"replyTime":"2020-02-09T14:48:10.000Z","msg":"樓主已經作左十幾廿個咁樣format既on9故仔<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-09T15:18:27.000Z","msg":"入黎就係為左睇紅字同窒息"},{"pid":"9b30e2bca2c616794094e35ad440813152f6baed","tid":1871592,"uid":342609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-09T15:18:39.000Z","msg":"<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" />"},{"pid":"0dddf4db75d00ea94dbba9e866a2c1fe04f9dbfb","tid":1871592,"uid":85805,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-09T15:19:33.000Z","msg":"Motherfucker<br />\nDiu nei lo mo"},{"pid":"7aa6929dbed138c3b0430773cd8d25a58d462e69","tid":1871592,"uid":205482,"like":1,"dislike":0,"score":1,"quote":{"pid":"ca27446275a3fb2c22b779b6f730b7dc432023f9","tid":1871592,"uid":21742,"like":1,"dislike":0,"score":1,"quote":{"pid":"57e65a93e653b7cd881563789a30c79af504abcc","tid":1871592,"uid":61831,"like":8,"dislike":0,"score":8,"quote":