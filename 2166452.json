{"tid":2166452,"cid":16,"subCid":0,"title":"и•ӯз”ҹеҸҲзӣҠиЎ—еқҠпјҒ","createTime":"2020-08-20T12:21:32.000Z","updateTime":"2020-08-21T23:55:21.000Z","uid":228143,"like":12,"dislike":4,"uniUserReply":10,"replies":[{"pid":"cd8730dd614f942ae8c3cf85e8e3d0c5b9f89308","tid":2166452,"uid":228143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-20T12:21:32.000Z","msg":"гҖҗжҷҡеёӮеӨ–иіЈе„Әжғ   $100 дёүйӨёгҖ‘<br />\n<br />\nжҷҡеёӮзҰҒе ӮйЈҹ рҹҳЈеҸҲеҶҚе»¶й•·<br />\nж”ҫе·Ҙрҹ’је’Ғж”° д»ІйӮҠжңүжҷӮй–“ рҹҚіз…®йЈҜ<br />\nRedRice ж–°е„Әжғ е°ұе•ұжҷ’дҪ е–ҮпҪһ<br />\nд»Ҡж—Ҙй–Ӣе§Ӣ (18/8) 6:00pmеҫҢ <br />\nрҹҚӣрҹҚІрҹҘҳ$100е°ұжңү3еҖӢйӨёе–ҮпјҒрҹӨ©жҠөеҲ°зҲӣе‘ҖпјҒ<br />\nиҗҪе–®жҷӮрҹ“қиЁҳеҫ—еҗҢжҲ‘е“ӢеҗҢдәӢи©ұрҹ’ҒрҹҸ»иҰҒе‘ўеҖӢе„Әжғ е•ҰпҪһ<br />\n<br />\nрҹ’ҒрҹҸ»д»ҘдёӢиҸңејҸйҒё1ж¬ҫ (*еҝ…й ҲйҒёж“Ү1ж¬ҫжө·еҚ—йӣһпјҸеҸЈж°ҙйӣһ)<br />\nрҹ‘ҮрҹҸ»рҹ‘ҮрҹҸ»рҹ‘ҮрҹҸ»рҹ‘ҮрҹҸ»рҹ‘ҮрҹҸ»рҹ‘ҮрҹҸ»рҹ‘ҮрҹҸ»рҹ‘ҮрҹҸ»рҹ‘ҮрҹҸ»рҹ‘ҮрҹҸ»<br />\nеҠҹиӘІ&bull;з„ЎйӘЁжө·еҚ—йӣһ(дҫӢзүҢ)<br />\nе·қе‘і&bull;з„ЎйӘЁеҸЈж°ҙйӣһ(дҫӢзүҢ)<br />\n==========================<br />\nрҹ’ҒрҹҸ»д»ҘдёӢиҸңејҸеҸҜйҒё2ж¬ҫ<br />\nрҹҘҡж—ҘеҮәи’ёиӮүйӨ…<br />\nрҹҚіеҸүзҮ’йҹӯй»ғзӮ’иӣӢ<br />\nрҹҗҹзІҹзұійӯҡеЎҠ<br />\nрҹҘҳе’•еҡ•жҺ’йӘЁ<br />\nрҹҗ·йўЁжІҷйӘЁ<br />\nрҹҘ¬иҠұиҶ жҝғж№ҜжөёеЁғеЁғиҸң<br />\n<br />\nд»ІеҸҜд»Ҙ  +$35 е°Үе…¶дёӯдёҖж¬ҫйӨё вҸ«еҚҮзҙҡрҹҮ°рҹҮ·йҹ“иұ¬еҸүзҮ’ ( 1д»Ҫ )<br />\n<br />\nрҹҚҡйЈҜйғҪе””жғіз…Іпјҹз„Ўе•ҸйЎҢпјҒ<br />\nвңЁ+$10 е°ұеҸҜд»ҘеҠ й…Қ гҖҗи¶…еҖјеҘ—йӨҗгҖ‘(жңҖеӨҡеҸҜеҠ  3д»Ҫ)<br />\nвңЁгҖҗи¶…еҖјеҘ—йӨҗгҖ‘еҢ…жӢ¬жңүрҹ‘ҮрҹҸ»<br />\nрҹҚҡзөІиӢ—йЈҜ<br />\nрҹҚөйӨҗж№Ҝ<br />\nрҹҘӨеҮҚпјҸзҶұйЈІ  (зү№йЈІйңҖ+$6)<br />\n<br />\n*6:00pmеҫҢй–Ӣе§ӢдҫӣжҮүпјҢеҖӢеҲҘеҲҶеә—дҫӣжҮүжҷӮй–“жҲ–жңүжүҖдёҚеҗҢпјҢдёҖеҲҮд»Ҙеә—е…§зӮәжә–гҖӮ<br />\n*еҝ…й ҲйҒёж“Ү1ж¬ҫжө·еҚ—йӣһпјҸеҸЈж°ҙйӣһ<br />\n*ж•ёйҮҸжңүйҷҗпјҢе”®е®ҢеҚіжӯў<br />\n*дёҚеҫ—иҲҮе…¶д»–е„Әжғ еҗҢжҷӮдҪҝз”Ё<br />\n*еӨ–иіЈзӣ’жҜҸеҖӢе°Үж”¶еҸ–$1<br />\n*еҜҰйҡӣдҫӣжҮүжғ…жіҒпјҢеҸҜиғҪеӣ жҮүйғЁеҲҶеҲҶеә—жңүжүҖжӣҙж”№пјҢжҒ•жңӘиғҪеҸҠжҷӮйҖҡзҹҘпјҢдёҚдҫҝд№Ӣиҷ•ж•¬и«ӢиҰӢи«’пјҒ<br />\n*еҰӮжңүд»»дҪ•зҲӯиӯ°пјҢRedRiceзұійЈҜдё»йЎҢйӨҗе»і дҝқ