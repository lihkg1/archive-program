//r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FWrYbvyddS1s&d=mSCPsj%2BCpXNT31el%2F4C9Ko9%2BoveFa0K0Z8Wn6wXPu4k%3D&h=00bafc85\" data-auto-link target=\"_blank\">https://youtu.be/WrYbvyddS1s</a><br />\n<br />\n而印度五年後人口超過中國<br />\n搬係必然既事"},{"pid":"d525aec254ba4e214c40947345ee04a605218af6","tid":970742,"uid":50095,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-06T06:24:35.000Z","msg":"係創業，唔係失業<img src=\"/assets/faces/xm/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2af4ff11ceb8d5c927d389c09dd50e7c276bac8d","tid":970742,"uid":27597,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-06T06:29:04.000Z","msg":"爆了爆了"},{"pid":"eda7c299888a7325b8cf455c4b664ab687218f5a","tid":970742,"uid":30169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-06T06:30:14.000Z","msg":"死500萬人就冇事"},{"pid":"40e2436760f35364d829a0ac565873f4a8f5ff87","tid":970742,"uid":25794,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-06T06:38:30.000Z","msg":"蘋果敗走<br />\n中國又贏"}]}