assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"12f7b1244b428374e920bd4ad9fdd5a21755637e","tid":2464052,"uid":381069,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-27T08:06:03.000Z","msg":"李：對鞋莆田貨<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"06a9c201f204761dbaeb5242ead370a5bea38af6","tid":2464052,"uid":321002,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-27T08:07:08.000Z","msg":"屌你，內地開始收疆，你仲玩咁大<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"203fd6409b123b0a285192fc4ea7e8cfb3910f03","tid":2464052,"uid":392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-27T08:08:16.000Z","msg":"唔怪得區選滅黨"},{"pid":"5738dc18bdfac62e9e72c429fe77e42d9eb498cd","tid":2464052,"uid":53000,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-27T08:10:49.000Z","msg":"新疆棉事件，引起內地有民眾義和團式抵制西方服裝品牌。正當外界以為事件將持續蔓延、發酵之際，官媒《環球時報》昨凌晨發表的一篇評論文章，稱「抵制H&amp;M的隊伍裏混進了壞人」，形容有人藉風潮推動「加速主義」，「我反對不了你，就給你下套，鼓譟你走向極端，製造分裂」，呼籲民眾「保持理性」，提防煽動。<br />\n<br />\n相關新聞：總部在瑞士 響應保護維人法案倡停用疆棉 BCI被官媒指收美國錢<br />\n<br />\n<br />\n促防「高級黑」搞加速主義<br />\n<br />\n抵制H&amp;M、Nike等國際品牌的行動幾近狂熱，《環時》旗下網站「環球網」昨日凌晨發文圖降溫，一。。。。。。」<br />\n<br />\n文章其後大篇幅敍述。。。。。。<br />\n<br />\n相關新聞：小粉紅轟Hugo Boss「彈出彈入」<br />\n《環球時報》"},{"pid":"cff599b9dcf9ddda71eb7ef607056b6f960fe4a2","tid":2464052,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"62752f8e22f6bb358921c65cf0190dbe6bc7cc28","tid":2464052,"uid":241804,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-03-27T07:45:14.000Z","msg":"夠啦兩隻小丑<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\"