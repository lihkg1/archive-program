:666340,"uid":142604,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f61c0106cbed2dd1c87f358b3dfce16fd720f54","tid":666340,"uid":48894,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-15T19:46:05.000Z","msg":"游水/拯溺"},"citedBy":1,"replyTime":"2018-05-15T20:21:15.000Z","msg":"想知道難唔難同要幾耐<br />\n有小小想做消防<br />\n但係考唔成都有一技旁身"},{"pid":"730e0c2cc679a5e6028e31faffafee0ede915ce6","tid":666340,"uid":172357,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-15T20:25:19.000Z","msg":"唱歌"},{"pid":"fc5d53391a71fbf089f194a20c9f958366d418d4","tid":666340,"uid":181797,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-15T20:27:55.000Z","msg":"投資"},{"pid":"79f9c8e7e8e54f620f058158eb2920ed14a80392","tid":666340,"uid":135645,"like":0,"dislike":0,"score":0,"quote":{"pid":"fc5d53391a71fbf089f194a20c9f958366d418d4","tid":666340,"uid":181797,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-15T20:27:55.000Z","msg":"投資"},"citedBy":0,"replyTime":"2018-05-15T20:33:03.000Z","msg":"有諗過 之前我見話要學識睇唔同嘅pattern 但我見太煩就不了了之<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e94963dded0553097423b09d2e8bdf0423d883a3","tid":666340,"uid":48894,"like":0,"dislike":0,"score":0,"quote":{"pid":"9dcbec42daaa070267dbada8ac74f29c404dffe3","tid":666340,"uid":142604,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f61c0106cbed2dd1c87f358b3dfce16fd720f54","tid":666340,"uid":48894,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-15T19:46:05.000Z","msg":"游水/拯溺"},"citedBy":1,"replyTime":"2018-05-15T20:21:15.000Z","msg":"想知道難唔難同要幾耐<br />\n有小小想做消防<br />\n但係考唔成都有一技旁身"},"citedBy":1,"replyTime":"2018-05-16T04:08:44.000Z","msg":"游水定拯溺？<br />\n<br />\n游水就唔難 你當係易學難精 如果要練氣練體能 輕輕鬆鬆慢慢游咁游多幾次都會慢慢變好 同埋我覺得舒服過跑步 不過如果你真係要操到游得快 咁就唔同講法<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 不過都建議跟出面學一兩期學左個正確姿勢先 始終自學都好難執得正個姿勢<br />\n<br />\n拯溺我真係唔知<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />  不過身邊有幾個朋友都有拯溺牌 平時有做下救生員 我諗要考到最低要求既話 肯操下都唔成問題<br />\n<br />\n岩岩google完： (銅章)<br />\n於五分鐘內游畢二百米(任何向前之泳式)<br />\n能踩水三分鐘<br />\n<br />\n200米即係來回2次 肯操下(中等強度)都應該可以練到 踩水都係<br />\n<br />\n不過個人覺得學拯溺 唔應該只係達到最低要求做到出到救生員份糧就算 而係要有決心萬一有意外 自己真係有能力可以救到人 消防員都係一樣道理<br />\n<br />\n希望幫到巴打你<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 因為我都想考消防 而家都岩岩開始操緊<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"4f1a91f50c99dd7543f40c866af9e5bde970ca34","tid":666340,"uid":142604,"like":0,"dislike":0,"score":0,"quote":{"pid":"e94963dded0553097423b09d2e8bdf0423d883a3","tid":666340,"uid":48894,"like":0,"dislike":0,"score":0,"quote":{"pid":"9dcbec42daaa070267dbada8ac74f29c404dffe3","tid":666340,"uid":142604,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f61c0106cbed2dd1c87f358b3dfce16fd720f54","tid":666340,"uid":48894,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-15T19:46:05.000Z","msg":"游水/拯溺"},"citedBy":1,"replyTime":"2018-05-15T20:21:15.000Z","msg":"想知道難唔難同要幾耐<br />\n有小小想做消防<br />\n但係考唔成都有一技旁身"},"citedBy":1,"replyTime":"2018-05-16T04:08:44.000Z","msg":"游水定拯溺？<br />\n<br />\n游水就唔難 你當係易學難精 如果要練氣練體能 輕輕鬆鬆慢慢游咁游多幾次都會慢慢變好 同埋我覺得舒服過跑步 不過如果你真係要操到游得快 咁就唔同講法<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 不過都建議跟出面學一兩期學左個正確姿勢先 始終自學都好難執得正個姿勢<br />\n<br />\n拯溺我真係唔知<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />  不過身邊有幾個朋友都有拯溺牌 平時有做下救生員 我諗要考到最低要求既話 肯操下都唔成問題<br />\n<br />\n岩岩google完： (銅章)<br />\n於五分鐘內游畢二百米(任何向前之泳式)<br />\n能踩水三分鐘<br />\n<br />\n200米即係來回2次 肯操下(中等強度)都應該可以練到 踩水都係<br />\n<br />\n不過個人覺得學拯溺 唔應該只係達到最低要求做到出到救生員份糧就算 而係要有決心萬一有意外 自己真係有能力可以救到人 消防員都係一樣道理<br />\n<br />\n希望幫到巴打你<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 因為我都想考消防 而家都岩岩開始操緊<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-16T04:12:15.000Z","msg":"Agger<br />\n呢啲技能隨時救到身邊人<br />\n但係體能真係差啲<br />\n一齊加油"}]}