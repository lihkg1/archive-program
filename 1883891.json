%3Djpg%26q%3D80%26we%26errorredirect%3Dupload%252Ecc%252Fi1%252F2020%252F02%252F17%252FQT0Mby%252Epng&h=e1964580&s={SIZE}\" />"},{"pid":"c8c7462210e7fa571ea2bf625fb337b6f6a33938","tid":1883891,"uid":41744,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-17T09:10:52.000Z","msg":"系"},{"pid":"7bc7e5d285ebd1744b40249f63c1fa8b342af46d","tid":1883891,"uid":34722,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-02-17T09:14:55.000Z","msg":"好似好勁，但睇一睇，隊波包尾得19分<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"52e3178c48274e84b21889ddc49a4d077896bf91","tid":1883891,"uid":21917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-17T09:27:00.000Z","msg":"成功帶領球隊長期處於榜尾<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"}]}