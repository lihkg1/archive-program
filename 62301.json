ji\" />"},{"pid":"e5ba55f755f319bde29936d9ae7dd8f26401c19c","tid":62301,"uid":60814,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T19:26:00.000Z","msg":"<img src=\"https://holland.pk/muesynd9\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fmuesynd9&h=e17258f9&s={SIZE}\" /><br />\n飲完"},{"pid":"147b3c02af918e640833d44c201f4716b146c736","tid":62301,"uid":15205,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T19:26:21.000Z","msg":"<blockquote><blockquote><blockquote><br />\n巴打點做到咁積極<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n唔係我積極 , 係我唔認輸姐 ,<br />\n人生經歷過既野會成就到將來既自己</blockquote><br />\n當自己人生中既人一個個咁離開 我就開始諗唔到自己一個係度為咩<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n咪 on9 啦 , 我咪又係咁捱 , 我孤獨左成兩年 , <br />\n曾經所謂既朋友兄弟為利益離我而去 ,<br />\n跟住我反思左一排 , 我知自己點樣可以羸返之前失去 ,<br />\n我需要既唔係酒肉朋友 , 我需要既係一個互相相愛既另一半 , 只要有依個人出現我就會羸返晒所以失去既感情<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"dac277d6187d13aab0a91132728b13c1681f43c7","tid":62301,"uid":68981,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T19:27:25.000Z","msg":"此回覆已被刪除"},{"pid":"0c2e31c70381ac938b740d656af502a0b7926446","tid":62301,"uid":63701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T19:27:54.000Z","msg":"<blockquote><img src=\"https://holland.pk/muesynd9\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fholland.pk%2Fmuesynd9&h=e17258f9&s={SIZE}\" /><br />\n飲完</blockquote><br />\n好呀 見係你 我吹左我果杯佢<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"de242784d06726758fa542097d832cb534241180","tid":62301,"uid":68981,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T19:28:19.000Z","msg":"此回覆已被刪除"},{"pid":"9d42fd6b8c5aa2ece7be211ac9553b348051459c","tid":62301,"uid":63701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-31T19:28:48.000Z","msg":"<img src=\