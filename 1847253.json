/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"da1c7807ce39946acd2ed9134f80fd2bbf54b3ff","tid":1847253,"uid":240250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T08:39:35.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"dadaed43f11551a07e0783a0f6ed6295161024d4","tid":1847253,"uid":240250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T14:43:20.000Z","msg":"香港人垃圾"},{"pid":"776eee9f4fff65573c19bfb16a1b502b3ea9bb86","tid":1847253,"uid":194325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T14:43:57.000Z","msg":"<img src=\"https://na.cx/i/1DtKWpn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1DtKWpn.jpg&h=a27c226a&s={SIZE}\" /><br />\n<br />\n白色，是醫護常用顏色。不含任何色素，並容易發現污漬，適用於醫院最應保持潔淨的地方。除此之外，白色還代表純粹的善良和堅定的信念。<br />\n<br />\n當日，醫護們憑藉良心忠實履行自己的使命。今日，政權道德綁架他們這一份熱誠和信念。<br />\n<br />\n他們守護了我們生命和健康，但又誰能守護他們？<br />\n<br />\n全城白絲帶，支持醫護罷工。醫護不是condom，我們與醫護同行。<br />\n<br />\n#全城白絲帶 #撐醫護 #撐罷工 #封關口 #醫護非condom #與醫護同行<br />\n#香港金總 #HKFU #standwithmedics<br />\n<br />\n各位金融人都麻煩幫手填問卷，謝謝。<br />\n<br />\n⚠️⚠️緊急⚠️⚠️<br />\n<br />\n香港金融業職工共同抗疫意見調查<br />\n<br />\n香港金融業職工總會欲以問卷方式詢問同業以工業行動共同抗疫的意願和意見，以制定有效方式向僱主及政府表達對僱員對於安全和健康的憂慮，全民共同抗疫。<br />\n<br />\n由於事態緊急，如策劃任何工業行動必需經過既定程序。故此是次問卷將於1月31日23:59截止。希望同業們積極參與此調查，讓金總能全面理解金融界僱主於防疫措施現況，以及會員和同業於共同抗疫的意願，以制定下一步行動。<br />\n<br />\n<a href=\"https://forms.gle/toVdkp2QMVwtZXVr7\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2FtoVdkp2QMVwtZXVr7&d=ib6ZiIlk8HgX3sh0XBbtb9qeVONt7zbw7GHn8%2FjWPdo%3D&h=362fdca3\" data-auto-link target=\"_blank\">https://forms.gle/toVdkp2QMVwtZXVr7</a><br />\n<br />\n原post傳送門：<br />\n［行動］［請置頂］全民白絲帶 罷工撐醫護<br />\n<a href=\"https://lih.kg/1848612\" data-auto-link target=\"_blank\">https://lih.kg/1848612</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"58905bae5c043726d60d023ab26801df19c809b4","tid":1847253,"uid":305510,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-28T14:49:20.000Z","msg":"今日同fd 打牌，5個唔同行業都係home office <br />\n好難知係咪罷工喎"},{"pid":"f5ebb68b134c8acc6614e00b77de9117ba298458","tid":1847253,"uid":180815,"like":0,"dislike":0,"score":0,"quote":{"pid":"58905bae5c043726d60d023ab26801df19c809b4","tid":1847253,"uid":305510,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-28T14:49:20.000Z","msg":"今日同fd 打牌，5個唔同行業都係home office <br />\n好難知係咪罷工喎"},"citedBy":0,"replyTime":"2020-01-28T15:21:29.000Z","msg":"仲打牌<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"}]}