vice-hk.net%2Fupload%2F2018%2F04%2F30%2F132212_5bd2578a05f63117332c45bf081515ff.png&h=f7dc06d7&s={SIZE}\" /><br />\n<br />\n<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /> 我唔明政府喺2018推政策點解都要用2014估計<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n明明2017數都出咗"},{"pid":"64a50180f9f2de3e2c4dc50164ff0ae2067b9a6f","tid":647510,"uid":51615,"like":0,"dislike":0,"score":0,"quote":{"pid":"faf1a049b33fb1f107b4da0524be7228ec5e9448","tid":647510,"uid":168703,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-30T01:44:24.000Z","msg":"許智峰乜乜乜話之佢啦，真唔真普選都係其次！<br />\n<br />\n點解每日地鐵蝗多過人<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n點解新屋邨全部講蝗語<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n點解起極樓都唔夠屋住<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n點解民香港人上唔到樓<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n點解公立醫院唔夠人手<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n點解交稅俾綜緩養懶人<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n點解派糖益哂蝗你無份<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><br />\n點解民建聯咁多人支持<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n<br />\n所有問題，源自支那新移民，唔係班蝗不停落黎霸哂啲居住空間，地產霸權都唔會好似今日今日咁無法無天。<br />\n<br />\n新移民威脅我地各方面，包括最基本嘅衣、食、住、行、醫療、福利、治安，所以當務之急係唔好俾其他嘢distract到，集中向停止每日150單程證目標進發，喺所有渠道宣傳！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <br />\n<br />\n乜撚嘢平反六四呀嗰啲唔撚使再講(關我撚事？)，集中火力，每日都要講停止每日150單程證！<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-30T05:25:17.000Z","msg":"講有咩用，林鄭聽咩，"},{"pid":"f2460c359711c1839f1a3ed2