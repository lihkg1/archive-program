{"tid":753534,"cid":5,"subCid":0,"title":"【冤家路窄】九龍城新舊男友打鬥案　現任男友不治　警改列誤殺","createTime":"2018-07-23T16:21:50.000Z","updateTime":"2018-07-24T12:48:50.000Z","uid":145384,"like":16,"dislike":2,"uniUserReply":26,"replies":[{"pid":"0d6a1204d9f553045ca52caad48fd94dc278d546","tid":753534,"uid":145384,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-23T16:21:50.000Z","msg":"<a href=\"https://www.hk01.com/%E7%AA%81%E7%99%BC/214251/%E5%86%A4%E5%AE%B6%E8%B7%AF%E7%AA%84-%E4%B9%9D%E9%BE%8D%E5%9F%8E%E6%96%B0%E8%88%8A%E7%94%B7%E5%8F%8B%E6%89%93%E9%AC%A5%E6%A1%88-%E7%8F%BE%E4%BB%BB%E7%94%B7%E5%8F%8B%E4%B8%8D%E6%B2%BB-%E8%AD%A6%E6%94%B9%E5%88%97%E8%AA%A4%E6%AE%BA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E7%25AA%2581%25E7%2599%25BC%2F214251%2F%25E5%2586%25A4%25E5%25AE%25B6%25E8%25B7%25AF%25E7%25AA%2584-%25E4%25B9%259D%25E9%25BE%258D%25E5%259F%258E%25E6%2596%25B0%25E8%2588%258A%25E7%2594%25B7%25E5%258F%258B%25E6%2589%2593%25E9%25AC%25A5%25E6%25A1%2588-%25E7%258F%25BE%25E4%25BB%25BB%25E7%2594%25B7%25E5%258F%258B%25E4%25B8%258D%25E6%25B2%25BB-%25E8%25AD%25A6%25E6%2594%25B9%25E5%2588%2597%25E8%25AA%25A4%25E6%25AE%25BA&d=EKY3ipczev8%2BQ%2F%2FBW9asO9ibCDpHM%2Bj7ejEBwfn5qys%3D&h=bb9c1776\" data-auto-link target=\"_blank\">https://www.hk01.com/%E7%AA%81%E7%99%BC/214251/%E5%86%A4%E5%AE%B6%E8%B7%AF%E7%AA%84-%E4%B9%9D%E9%BE%8D%E5%9F%8E%E6%96%B0%E8%88%8A%E7%94%B7%E5%8F%8B%E6%89%93%E9%AC%A5%E6%A1%88-%E7%8F%BE%E4%BB%BB%E7%94%B7%E5%8F%8B%E4%B8%8D%E6%B2%BB-%E8%AD%A6%E6%94%B9%E5%88%97%E8%AA%A4%E6%AE%BA</a><br />\n<br />\n<br />\n本月16日九龍城侯王道情侶爭執演變成新舊男友打鬥案，當日被打至重傷昏迷的姓王（38歲）現任男友，搶救一星期後，延至昨（23日）午5時18分不治，警方將案件改列作「誤殺」案，稍後將為死者進行驗屍以確定死因。九龍城警區重案組正調查案件。<br />\n<br />\n事發於本月16日晚上7時許，死者與姓黃（38歲）女友，於九龍城侯王道24號對開發生爭執，期間黃女被襲擊，逃至侯王道6至10號對開時，遇上姓岑（42歲）前男朋友，兩男大打出手，死者當時頭部重創昏迷，被送往伊利沙伯醫院搶救。<br />\n<br />\n當日死者亦涉嫌「在公眾地方打架」及「普通襲擊」被捕；而姓岑男子則被落案控以一項「傷人」罪，已於7月19日在九龍城裁判法院提堂。"},{"pid":"4e93a576952c2707916a9941d56d1e85d789ed72","tid":753534,"uid":43575,"like":5,"dislike":2,"score":3,"ci