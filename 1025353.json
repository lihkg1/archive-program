uid":140590,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-26T00:49:49.000Z","msg":"Lm"},"citedBy":0,"replyTime":"2019-02-26T01:15:22.000Z","msg":"hi巴打<br />\n晏d出文"},{"pid":"028cccfb38b194dd30e8921d94ffb2fb676c0ffd","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-26T11:01:45.000Z","msg":"push<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"832b5aa1f7d2d9b0e0fb0798aad12653e6c4f599","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-26T14:00:38.000Z","msg":"push"},{"pid":"24c58658e1d1526a2cd8eb0dc4eadd617590a8cb","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-26T23:32:50.000Z","msg":"push"},{"pid":"92e25a44bc2f7ded78870a0fdc2c13ab86b8f718","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-27T05:34:06.000Z","msg":"再push"},{"pid":"bb1bf287d056783ba8a124cd85e1704f591f4043","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-27T10:06:09.000Z","msg":"push"},{"pid":"6ea6edd206ddd43c4cfff61017efd98849527846","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-27T13:57:40.000Z","msg":"push"},{"pid":"3fd62c0092dddae8929bbb4ed1471eec9b2ba8c7","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-27T22:05:08.000Z","msg":"push"},{"pid":"7e14d7ff2eeec57e82f622d40b00f5fa5cce952d","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T03:35:21.000Z","msg":"【阿Miss，其實我趕住番工，反正你地都咁多人係到，點解唔可以比小朋友入去坐住先?】家長A語帶不滿。<br />\n<br />\n【係囉，好鬼死熱啊!點解呢到唔開冷氣架!】小喊包說道。<br />\n<br />\n我為他改了個別名叫小喊包，他是小三學生，平日愛大聲說話，而且語甚囂張，但每當與別人起衝突而處於下風時，就會大哭一場。<br />\n<br />\n根據我非正式統計，他在暑假班共哭了五次，成為全班之冠。<br />\n<br />\n【呢位先生講得岩，我地落到二樓中心counter，佢地就趕我地上三樓暑假班，上黎唔係問題，要我地罰企埋一份先係問題。點解中心可以安排得咁差?】家長B的食指於空中飛舞，指斥著中心各種不是。<br />\n<br />\n【係囉，都話左唔好黎依d中心架啦。安排差到咁，係屋企睇電視仲好。】公主以一面不屑的容貌看著我。"},{"pid":"b55b523f9a78597b2a685629c493add37e8a22b1","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T07:25:02.000Z","msg":"公主人如其名，性格如同公主一樣，喜歡指指點點，對周遭一切事物都可以挑剔批評，而我就是其中一個被他挑剔最多的導師。<br />\n<br />\n順帶一提，她的容貌卻與公主扯不上半點關係。與其說是公主，倒不如說公主病。<br />\n<br />\n對著不知天高地厚的小朋友，只有一笑置之，這是我對他們的策略，我從不要求自己要在短短個半月教好他們。<br />\n<br />\n【不如咁啦，我地都知各位家長辛苦，不如入去坐住先。】冬菇姑娘安撫道，其他導師沒有反對。<br />\n<br />\n【咁我地交個小朋友比你，你帶佢地入去坐住先，我地趕住番工，唔該哂。】家長A看著手錶，焦急說。<br />\n<br />\n【好啊，等陣再見。】冬菇姑娘將三位小朋友帶到課室，讓他們坐下來。"},{"pid":"815033f073323b08a4eae3d4026f8e67adf82189","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T11:18:48.000Z","msg":"push"},{"pid":"bdb58cfb84ffd3aa87742b4b119f514668388c3c","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T14:05:32.000Z","msg":"push"},{"pid":"589525618341561e21f6486d6053b7c3bbce477c","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T22:49:48.000Z","msg":"push"},{"pid":"d03ef44cecac98ee51d9a38bd4e2c59df2f150d1","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-28T23:47:00.000Z","msg":"push"},{"pid":"82b3103c0fb7bbffe59550d09ec65d7650572537","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-01T13:25:01.000Z","msg":"push"},{"pid":"591b79a0579d8588a5af1e98d2790d7f7fe2fb9a","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-02T02:08:33.000Z","msg":"puah"},{"pid":"8016099c8d757d49dc162a2763029553bc0991ae","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-02T11:20:41.000Z","msg":"push"},{"pid":"c686a1cf40a4aafbfc0adf04cfc8fa6b14f054ec","tid":1025353,"uid":158372,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-02T11:26:03.000Z","msg":"push"},{"pid":"cc20e39234606acdd930d81e69863305e9106801","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-03T00:42:04.000Z","msg":"推"},{"pid":"2e2ff47defcb3dcb398083a159c941b36c6d703d","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"quote":{"pid":"c686a1cf40a4aafbfc0adf04cfc8fa6b14f054ec","tid":1025353,"uid":158372,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-02T11:26:03.000Z","msg":"push"},"citedBy":0,"replyTime":"2019-03-03T01:55:09.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"641a18fb6884355c6037a3561f31c52dba366ba5","tid":1025353,"uid":120629,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-03-03T04:31:20.000Z","msg":"【開電視!】小喊包叫囂。<br />\n<br />\n【開電視?】民民姑娘反問。<br />\n<br />\n【我地朝朝都睇電視，上年都係咁樣。】公主高傲道，雙手交疊胸前。<br />\n<br />\n回想十多年前的我，獨守兒童乃等閒事，假期就是由九時開始一直看電視，父母回家後便一同收看，直至睡覺為止。<br />\n<br />\n九時看交易現場，看著女主播說著一堆奇奇怪怪難以明瞭的數目字與專業述語，十時看半小時的七，八十年代古裝連續劇，十時半與十一時半則是過往在黃金時段播放過的連續劇。<br />\n<br />\n吃過杯面後，是時候收看都市閒情，看著一大堆在我的年齡不會接觸到的資訊，我不覺訥悶而是好奇。<br />\n<br />\n總之而言，我的童年充斥著電視，甚至連教育電視也能倒背如流。<br />\n<br />\n烏龍神探，分數王國，成展權，細菌大會等等。"},{"pid":"ed8c836a314b8d03819b8167d6bb7a7325924b8a","tid":1025353,"uid":58094,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-03-03T04:40:04.000Z","msg":"申請性罪行記錄係105蚊喎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a7563a1688bbf7083107904a989e7e2c7441ae6d","tid":1025353,"uid":120629,"like":0,"dislike":1,"score":-1,"quote":{"pid":"ed8c836a314b8d03819b8167d6bb7a7325924b8a","tid":1025353,"uid":58094,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-03-03T04:40:04.000Z","msg":"申請性罪行記錄係105蚊喎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-03T06:02:20.000Z","msg":"仔細唔記得左，只記得用發達通比，仲要電話預約<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"3e64860017d4d5e077f7539fa1c0133ed2d80d71","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-03T09:18:33.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0c48570441a3169a364fbad594ba09ef1f9dd542","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-03T09:45:03.000Z","msg":"【上年?你地上年都有參加?】民民姑娘問道。<br />\n<br />\n【我就第五年，喊包就第三年，呢到我地仲熟過你，以前西門哥哥一定會開電視比我地睇，如果佢係到就好。】公主用那雙傲慢的眼神看著民民姑娘。<br />\n<br />\n有時候，我挺討厭別人拿以前的人作比較，就像女朋友告訴你，以前他的男朋友多麼無微不致，似是批評你做得不夠好。<br />\n<br />\n我們幾位導師做得不夠好嗎?<br />\n<br />\n【無問題，但你地要安安靜靜睇電視。】肥仔Sir按下開關，電視播映著83台的互動新聞。<br />\n<br />\n【我地要睇youtube啊!】小喊包拍拍桌子。<br />\n<br />\n【肥仔sir,如果比老細睇到會唔會有問題?】我在他耳邊輕聲問道。"},{"pid":"1a3cbaa06557ffdfdad75a61c0113a8b93719b2b","tid":1025353,"uid":11512,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-03T09:55:02.000Z","msg":"其實呢類型既文都幾好睇<br />\n但未必岩現今既人口味<br />\n所以樓主唔洗不停自推等人睇到<br />\n努力啲寫好啲等我地追開既人期待下<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"067132bea553ff9288b34b3c1970862b039daaf5","tid":1025353,"uid":120629,"like":0,"dislike":0,"score":0,"quote":{"pid":"1a3cbaa06557ffdfdad75a61c0113a8b93719b2b","tid":1025353,"uid":11512,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-03T09:55:02.000Z","msg":"其實呢類型既文都幾好睇<br />\n但未必岩現今既人口味<br />\n所以樓主唔洗不停自推等人睇到<br />\n努力啲寫好啲等我地追開既人期待下<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-03T10:31:32.000Z","msg":"我都想多d人睇到，咁先有動力<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"a6f82b8ef8ccedd44e8e30f4714399c5769c48db","tid":1025353,"uid":54597,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-03-03T12:02:36.000Z","msg":"我做呢啲中心做左五年，都未試過好似樓主咁說教或者係想打鳩啲細路仔<br />\n同細路講野係要有技巧，重點係你個心態點擺法"}]}