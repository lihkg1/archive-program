e8ef209","tid":1814923,"uid":218313,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-07T09:12:15.000Z","msg":"推5"},{"pid":"736c4e36a97dfd056d253f873f99ce7a2ae6f8e6","tid":1814923,"uid":131245,"like":0,"dislike":0,"score":0,"quote":{"pid":"2668876e3563b3d27dd74aa4d68896d0804da16b","tid":1814923,"uid":218313,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-07T06:55:24.000Z","msg":"呢幾一大堆勇武退出文<br />\n寫得呢D 文既我只諗到兩類人<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: large;\"><span style=\"color: blue;\"><strong>1&gt; 狗/國安<br />\n2&gt; 悔氣撚<br />\n</strong></span></span><br />\n過左呢幾個月, 經歷左咁多事, 死左咁多人<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: red;\"><strong><span style=\"font-size: large;\"><br />\n乜仲有人覺得香港有得返轉頭?<img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><br />\n乜仲有人覺得個運動可以隨隨便便就完?<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><br />\n係咪禁個Menu 出黎, 按一下logout 就回復正常?</span></strong></span><img src=\"/assets/faces/pig/upset.gif\" class=\"hkgmoji\" /><br />\n<br />\n要呢個運動完, 得幾個可能:<br />\n<strong><span style=\"color: green;\">1&gt; 五大訴求 </span></strong><br />\n中共根本唔會俾你, 而且依家用緊一切方法消滅你抗爭既方法<br />\n所以中共一日存在, 我地係唔會得到我地要既野!<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"color: green;\">2&gt; 中共解體</span></strong><br />\n之後香港自決去路<br />\n歸英/美好<br />\n聯邦好<br />\n獨立都好<br />\n香港人會走出一條路<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"color: green;\">3&gt; WWIII </span></strong><br />\nBOOM<img src=\"/assets/faces/lm2/oh.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" cla