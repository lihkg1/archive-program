8%25AE%25BA&d=CH2%2BOu%2FXd5cykt%2BSaDfKp7%2BnoHux5cIPnxEj5ZZbdh4%3D&h=a9dc8a12\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/zh-tw/%E6%82%96%E8%AE%BA</a>"},"citedBy":2,"replyTime":"2019-01-20T04:44:44.000Z","msg":"又真又假有矛盾，好似一個loop咁咪算paradox⋯⋯"},"citedBy":1,"replyTime":"2019-01-20T06:48:18.000Z","msg":"咁同你拋個三下磚你覺得有啲咩關聯？"},"citedBy":1,"replyTime":"2019-01-20T06:57:11.000Z","msg":"用1做例子，<br />\n如果學到「乜都學唔到」，咁「乜都學唔到」就係錯。<br />\n如果真係乜都學唔到，咁「學到「乜都學唔到」」又係錯。<br />\n咁究竟有冇嘢學到？<br />\n如果咁樣唔算paradoxical 咁呢種句子叫乜？（認真問）"},{"pid":"925823f379d7d046fa6c79b8ab8f317269ea8374","tid":988360,"uid":108756,"like":0,"dislike":0,"score":0,"quote":{"pid":"f644a05125e44b67a7301f249372fa217c2f38ab","tid":988360,"uid":210794,"like":2,"dislike":2,"score":0,"quote":{"pid":"3e26aee6421b3d83a16cfcaaa86136137bee74fe","tid":988360,"uid":108756,"like":0,"dislike":0,"score":0,"quote":{"pid":"ac31b2d524cac9427fa62f3cb8678ca8eee04a8f","tid":988360,"uid":210794,"like":0,"dislike":21,"score":-21,"citedBy":2,"replyTime":"2019-01-20T04:44:44.000Z","msg":"又真又假有矛盾，好似一個loop咁咪算paradox⋯⋯"},"citedBy":1,"replyTime":"2019-01-20T06:48:18.000Z","msg":"咁同你拋個三下磚你覺得有啲咩關聯？"},"citedBy":1,"replyTime":"2019-01-20T06:57:11.000Z","msg":"用1做例子，<br />\n如果學到「乜都學唔到」，咁「乜都學唔到」就係錯。<br />\n如果真係乜都學唔到，咁「學到「乜都學唔到」」又係錯。<br />\n咁究竟有冇嘢學到？<br />\n如果咁樣唔算paradoxical 咁呢種句子叫乜？（認真問）"},"citedBy":0,"replyTime":"2019-01-20T06:59:53.000Z","msg":"我覺得比較似係一啲哲學思考多啲<br />\n好似唔知邊個話聰明既人就係知道自己唔聰明咁 <br />\n而paradox既野比較似係唔係句子而係一啲物件一啲地方 好似個條樓梯咁有兩層 你上到第二層再上會發現其實你上左第一層一路loop"},{"pid":"b314483841f4ee16ab2cfdcc186c9a539cfe529c","tid":988360,"uid":126973,"like":3,"dislike":0,"score":3,"quote":{"pid":"4f2e9552d9446a74a6f02328f0b33ab7ea2ceb7f","tid":988360,"uid":144409,"like":5,"dislike":0,"score":5,"quote":{"pid":"ac31b2d524cac9427fa62f3cb8678ca8eee04a8f","tid":988360,"uid":210794,"like":0,"dislike":21,"score":-21,"quote":{"pid":"d0557e7f282307e6ff3e5bf95adef1d64e988aeb","tid":988360,"uid":144409,"like":32,"dislike":3,"score":29,"citedBy":1,"replyTime":"2019-01-20T04:39:23.000Z","msg":"你明唔明咩係paradox<br />\n<a href=\"https://zh.wikipedia.org/zh-tw/%E6%82%96%E8%AE%BA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fzh-tw%2F%25E6%2582%2596%25E8%25AE%25BA&d=CH2%2BOu%2FXd5cykt%2BSaDfKp7%2BnoHux5cIPnxEj5ZZbdh4%3D&h=a9dc8a12\" data-auto-link target=\"_blank\">https://zh.wikipedia.org/zh-tw/%E6%82%96%E8%AE%BA</a>"},"citedBy":2,"replyTime":"2019-01-20T04:44:44.000Z","msg":"又真又假有矛盾，好似一個loop咁咪算paradox⋯⋯"},"citedBy":2,"replyTime":"2019-01-20T06:19:09.000Z","msg":"有一個命題A，稱為悖論命題。<br />\n有一個邏輯系統L，稱為相關系統。<br />\n有一組命題E, 稱為背景命題。背景命題都是相關係統中的真命題。相關係統被簡化為背景命題，背景命題成為悖論證明的依據。<br />\n相關係統存在兩個證明可以獲得悖論命題A的真值，其中一個證明A為真，而另一個證明A為假，從而出現矛盾。"},"citedBy":1,"replyTime":"2019-01-20T08:22:51.000Z","msg":"樓主引呢幾句 嚴格來講唔係悖論 <br />\n但會引起悖論 <br />\n<br />\n呢幾句本身唔係悖論，<br />\n但譬如，如果我地問，咁蘇格拉底有冇知識，咁就會陷入悖論。<br />\n<br />\n亦有哲學家叫做 The Paradox of Socratic Ignorance<br />\n<a href=\"https://www.jstor.org/stable/43154003?seq=1#page_scan_tab_contents\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.jstor.org%2Fstable%2F43154003%3Fseq%3D1%23page_scan_tab_contents&d=CH2%2BOu%2FXd5cykt%2BSaDfKp7%2BnoHux5cIPnxEj5ZZbdh4%3D&h=cecaa598\" target=\"_blank\">https://www.jstor.org/stable/43154003?seq=1#page_scan_tab_contents</a><br />\n<br />\n<br />\n（試比較 著名嘅說慌者悖論<br />\n呢句悖論，往往先考慮咁樣嘅句子：<br />\n「本句不是真的」<br />\n呢句句子本身唔係悖論<br />\n<br />\n但如果我地問，呢句句子係真，抑或不是真，就會陷入悖論：<br />\n因為如果佢係真，根據句子嘅意思，佢就不是真； <br />\n另一方面，假設佢不是真。佢就正正符合句子所講，所以佢係真。<br />\n所以，無論如何，都會陷入矛盾。）"},{"pid":"8836d9d83818dfc0b7c88a471011d9d0948da1cb","tid":988360,"uid":126973,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-01-20T08:24:53.000Z","msg":"樓主呢幾句句子 可以叫做 paradoxical sentence<br />\n<br />\n佢地本身唔係 paradox<br />\n但當我地問佢地應該點理解 就會陷入 paradox"},{"pid":"d7d4eb07edaeed96959e3575e49f65f624af6636","tid":988360,"uid":14566,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-01-20T08:34:00.000Z","msg":"理髮師會幫全個鎮唔識剪髮既人剪頭髮<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /> <br />\n<br />\n樓主三個都類似Russell&rsquo;s paradox<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"9b4cbdedb030383774c7ee0729a402f9a04f67f6","tid":988360,"uid":12185,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-20T16:09:31.000Z","msg":"呢個問題嘅答案係咪「唔係」？"},{"pid":"d6378054caf0d11a48f4b152a3a07a0592185815","tid":988360,"uid":139157,"like":0,"dislike":0,"score":0,"quote":{"pid":"8836d9d83818dfc0b7c88a471011d9d0948da1cb","tid":988360,"uid":126973,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-01-20T08:24:53.000Z","msg":"樓主呢幾句句子 可以叫做 paradoxical sentence<br />\n<br />\n佢地本身唔係 paradox<br />\n但當我地問佢地應該點理解 就會陷入 paradox"},"citedBy":1,"replyTime":"2019-01-20T16:16:48.000Z","msg":"非台兄可唔可以講下第二句Being and Becoming，之前上堂學唔識<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"2750e3f9ff409059c0800f18d6c36ad87057bbde","tid":988360,"uid":126973,"like":0,"dislike":1,"score":-1,"quote":{"pid":"d6378054caf0d11a48f4b152a3a07a0592185815","tid":988360,"uid":139157,"like":0,"dislike":0,"score":0,"quote":{"pid":"8836d9d83818dfc0b7c88a471011d9d0948da1cb","tid":988360,"uid":126973,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-01-20T08:24:53.000Z","msg":"樓主呢幾句句子 可以叫做 paradoxical sentence<br />\n<br />\n佢地本身唔係 paradox<br />\n但當我地問佢地應該點理解 就會陷入 paradox"},"citedBy":1,"replyTime":"2019-01-20T16:16:48.000Z","msg":"非台兄可唔可以講下第二句Being and Becoming，之前上堂學唔識<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-20T19:27:55.000Z","msg":"Becoming 係一個由錯誤理解 赫拉克理特 而出現嘅概念 <br />\n<br />\n1) 根據柏拉圖 赫拉克理特話，冇人可以踏進同一條河流兩次，<br />\n係想講萬物皆變：<br />\nHeraclitus, I believe, says that all things pass and nothing stays, and comparing existing things to the flow of a river, he says you could not step twice into the same river. (Plato Cratylus 402a = A6)<br />\n好多人由此理解，一種叫 Becoming 嘅概念，就係指呢種不斷變動嘅狀態<br />\n而 Being 就係同 Becoming 對立嘅概念，Being 所指嘅係一種絕對不變嘅野<br />\n<br />\n<br />\n2) 但事實上，赫拉克理特並唔係咁講，佢講：<br />\nOn those stepping into rivers staying the same other and other waters flow. <br />\n<br />\n呢句係講，水係不斷流動，但河流係同一條<br />\n而且呢句暗示，我地可以重覆踏進同一條河流<br />\n<br />\n呢一句雖然好似好 paradoxical, 但其實好合理<br />\n我地可以問：點解河流係同一條河流，即使不斷變動？<br />\n正正因為水不斷變動，而唔係一潭死水，所以先有河流<br />\n<br />\n所以，係赫拉克理特呢句河流比喻之中，唔可以理解Being 同 Becoming 係對立，而係一種相輔相成嘅野"},{"pid":"b5f57334be66f28e374aa7be03db3cf4fe58a5c7","tid":988360,"uid":69779,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-01-21T02:03:27.000Z","msg":"Simpson's paradox<br />\nRao's paradox<br />\n我覺得有practical application嘅paradox最有意義<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"35f580bd48277e069f92ca704aa94a51a33459b1","tid":988360,"uid":69779,"like":0,"dislike":0,"score":0,"quote":{"pid":"b5f57334be66f28e374aa7be03db3cf4fe58a5c7","tid":988360,"uid":69779,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-01-21T02:03:27.000Z","msg":"Simpson's paradox<br />\nRao's paradox<br />\n我覺得有practical application嘅paradox最有意義<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-21T02:07:43.000Z","msg":"有趣方面，以前睇書睇過stein's paradox覺得幾得意，不過application方面就諗唔到<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"4f822bf0c70e6bee5f54cd07be7ff2589945d537","tid":988360,"uid":61577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-21T02:10:46.000Z","msg":"格林斯潘：如果你覺得聽懂了我說的話，那你一定是誤解了我的意思。"},{"pid":"9bb1cbfa59abdfbb7e6dc7bec5d8ad39f74c9183","tid":988360,"uid":29606,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-21T02:14:51.000Z","msg":"此回覆已被刪除"},{"pid":"839574bf086d88cc117b6b725d954b39ae50f68f","tid":988360,"uid":126973,"like":0,"dislike":0,"score":0