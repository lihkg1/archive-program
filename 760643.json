5.gif&h=b637e47a&s={SIZE}\" />"},{"pid":"949e9a3e481995cc189e1565a238c11cfb099e8e","tid":760643,"uid":39838,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-30T04:58:33.000Z","msg":"啲Coser會屌人地做件hea 衫就走去cos搞壞哂個角色<br />\n但唔會屌人樣衰都走去cos搞壞個角色"},{"pid":"d12411f3feff2126b3faaf32d101b4ed3d9f8da4","tid":760643,"uid":16181,"like":0,"dislike":0,"score":0,"quote":{"pid":"589ec04d409e0e28b601fce85c2ad437972fe27b","tid":760643,"uid":175136,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-30T04:46:21.000Z","msg":"你cos啲由頭包到落腳<br />\n不過都驚一除個頭抖氣都嚇走哂人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-30T12:03:37.000Z","msg":"好慘<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"2928527d998e4657981cd39ce27f36e2aeccb5cd","tid":760643,"uid":25028,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-07-30T12:32:14.000Z","msg":"樣衰唔係罪，係不幸。生得醜唔係你嘅責任，要怪嘅，只好怪上帝<br />\n但係，肥，就係你嘅錯！ 一個人好地地係唔會肥嘅，你變得做肥人，梗係食咗多過你需要嘅嘢啦 喺呢個仲有咁多人捱餓嘅時代，你竟然食咁多嘢？ 肥係貪心嘅表現，係唔公平嘅象徵 肥人臃腫畸形嘅身體，已經充分顯示出佢哋嘅唔道德<br />\n<br />\n肥人係罪犯，佢哋甚至比小偷、殺人犯更無恥 一般犯人都會掩飾自己犯咗嘅罪 但係肥人，佢哋竟然將自己嘅罪證放晒響個身上，就好似一個殺人犯拖住條屍周街走咁 你話，見到肥人有乜辦法唔憤怒？<br />\n<br />\n所以，見到肥人應該即刻鬧佢，就算唔鬧佢都要鄙視佢，我哋要透過侮辱嚟喚醒佢嘅良知 喺街見到肥人唔鬧佢，就好似搭地鐵見到痴漢非禮學生妹唔出聲一樣 作為一個有良知嘅人，我哋應該出聲，應該鼓起勇氣挺身而出鬧到佢哋狗血淋頭！"},{"pid":"446c43feedf9e7b808e485492b0954e3205a6931","tid":760643,"uid":98507,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-30T12:59:28.000Z","msg":"不如大家幻想下自己鍾意嘅男/女角色比個柒毒/豬西COSPLAY 會點?<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n唔係話唔支持 不過你COS得即係你都對角色係有愛 至少都唔係討厭<br />\n但你樣衰又要去COS咪即係醜化緊個角色<br />\n唔係架起件衫就叫COS呀大佬<br />\n起碼你個樣同體型都要去到STANDARD先啦<br />\nSTANDARD再加埋MAKE UP<br />\n咁咪EXCELLENT"},{"pid":"bfa8f68ba91d831a3ac4e05f1e29211383f2da24","tid":760643,"uid":178658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-30T13:23:17.000Z","msg":"成日見到啲又肥又樣衰，但偏偏cos啲型男/靚女角色嘅柒頭<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"7f98007f8ed17f051fd8b46ce2fc45b5554bcff7","tid":760643,"uid":9362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-30T13:34:01.000Z","msg":"唔犯法既話你可以鍾意做乜就做乜，<br />\n你可以唔考慮其他人既感受，<br />\n同樣地其他人都可以鍾意做乜就做乜，<br />\n唔考慮你既感受。"},{"pid":"a2d793996569359893e1413948a0b473c9e363f4","tid":760643,"uid":2002,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-30T13:51:04.000Z","msg":"樣衰就安份守己<br />\n唔好扮鬼扮馬啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"a169cc1b99da04515c7df5775703946d4bfa01ee","tid":760643,"uid":156121,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-30T13:54:49.000Z","msg":"應該玩<br />\n但唔該唔好出event"},{"pid":"967655601e7527ff30ca472855a419b92d62a98f","tid":760643,"uid":16181,"like":0,"dislike":0,"score":0,"quote":{"pid":"a169cc1b99da04515c7df5775703946d4bfa01ee","tid":760643,"uid":156121,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-30T13:54:49.000Z","msg":"應該玩<br />\n但唔該唔好出event"},"citedBy":1,"replyTime":"2018-07-30T15:17:01.000Z","msg":"生得樣衰是原罪"}]}