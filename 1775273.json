3,"uid":124711,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-09T01:55:07.000Z","msg":"大部份時間<br />\n<br />\n包括被狗咬都係單拖<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}