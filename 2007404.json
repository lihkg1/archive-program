f3c11845c5a44fac9d","tid":2007404,"uid":77717,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T04:45:17.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c53e4ddbbcaaaf410bd039a7c91019fc629d0133","tid":2007404,"uid":98431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T04:46:52.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d66bce9b1111a5ef4895bfd1e07daa6b03032764","tid":2007404,"uid":77717,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T11:39:13.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f16ece0bc7be825911190e0213f2a21bb230aff3","tid":2007404,"uid":182830,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-05-09T11:46:24.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/20200509/IXVGS5QXW4QMVV7UI63NNCKAHI/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20200509%2FIXVGS5QXW4QMVV7UI63NNCKAHI%2F&d=ZKl1Acg0IOD8KmAOqHMUQAwUjfZSuDKj7BL2vQxkRkA%3D&h=00c08051\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20200509%2FIXVGS5QXW4QMVV7UI63NNCKAHI%2F&h=507657ab\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/20200509/IXVGS5QXW4QMVV7UI63NNCKAHI/</a><br />\n昨日（8日）立法會內務委員會建制派與民主派埋身肉搏，工聯會郭偉強更在會上拉走人民力量陳志全，扯其衣領至跌倒再拖行約半米，甚為殘暴。由昨日至今也腰痛的陳志全，今日到醫院進行磁力共振，發現椎間盤移位，陳志全表明，郭偉強襲擊他的證據確鑿，故短期內將報警，若警方或律政司沒有行動，他將提出私人檢控，又謂律師指郭偉強的入罪機會很大，他將發起眾籌律師費，合眾人之力令施暴的郭偉強被定罪。<br />\n<br />\n陳志全指，昨日受傷後，腰部十分痛楚，他昨先照X光，未有發現大礙，今日再到醫院進行磁力共振，發現椎間盤移位，現要服食止痛藥和肌肉鬆弛的藥物，稍後要做物理治療。<br />\n<br />\n他又指，短期內就會報警追究郭偉強拉扯及拖行他，又指如果今次事件倒過來，是他拉扯和拖行李慧琼，相信自己已被捕和被扣留：「防暴（警察）一早入咗嚟立法會添啦。」但他坦言，即使自己報警，警方和律政司礙於政治立場偏幫建制派，也未必會行動，故今日已和律師研究，他同時會以私人檢控控告郭普通襲擊。律師已向他表示，從片段的證據可見，郭偉強十分大機會被入罪。為了應付官司費用，他稍後或會發起眾籌。<br />\n<br />\n記者 姚國雄"},{"pid":"c15a8309584ff159c223167c0f1dd2d07a9bd8db","tid":2007404,"uid":56381,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T11:46:33.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"73950dfa832264dd732930f6a26e151da964ed10","tid":2007404,"uid":63311,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T11:47:20.000Z","msg":"陳志全捉住郭偉強隻手捉住陳志全"},{"pid":"3e1fa5cbebcab47a9bce7fa962cadc70d22eef3a","tid":2007404,"uid":238301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T11:51:10.000Z","msg":"<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"4b9c75809ddfa9b323c51ad033049d8b0f8127a4","tid":2007404,"uid":77717,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T12:08:25.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"1a8445f1404e97a1c985b103cfed77bb54f7a148","tid":2007404,"uid":77717,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T14:15:14.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f2503402fb25aa32ec24b54c4c06ca322b0996c6","tid":2007404,"uid":130573,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T14:53:24.000Z","msg":"404 - File or directory not found.<br />\nThe resource you are looking for might have been removed, had its name changed, or is temporarily unavailable."},{"pid":"9322baa16a0524af83140549c785a9e3faad747e","tid":2007404,"uid":151074,"like":0,"dislike":0,"score":0,"quote":{"pid":"9af1d5bc26ee765d50b32ce37536e82758ef3155","tid":2007404,"uid":297045,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-05-08T11:28:58.000Z","msg":"唔好話投訴啦<br />\n分分鐘私人檢控都WORK<br />\n上晒新聞通晒天<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-09T15:01:45.000Z","msg":"同意，告唔入都要搞下佢"},{"pid":"7b3440b0f57c8858b5bb79a8e477aa96db2a1fa3","tid":2007404,"uid":271516,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-09T15:07:09.000Z","msg":"<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" />"}]}