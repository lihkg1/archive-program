{"tid":1609203,"cid":1,"subCid":0,"title":"仲係旺角手足要快走","createTime":"2019-10-01T13:56:22.000Z","updateTime":"2019-10-01T15:39:25.000Z","uid":194674,"like":7,"dislike":2,"uniUserReply":15,"replies":[{"pid":"f8aadbadeb2710f329162b215dd2126c14726c73","tid":1609203,"uid":194674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T13:56:22.000Z","msg":"<img src=\"https://na.cx/i/eKyBtC9.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeKyBtC9.png&h=cfe13ab7&s={SIZE}\" /> <br />\n由我朋友傳黎 話佢有朋友係入面做指揮官（唔講得邊區）<br />\n話現場旺角好靜 因為係成個新世紀變曬班狗休息室 <br />\n一收到ORDER就會行動<br />\n仲係旺角手足真係要走<br />\n我知單靠一張wtsapp cap圖未必fc到咩<br />\n但我呢個朋友講到似層層 仲話好肯定個消息由果位指揮官到收返黎<br />\n我只想大家都平安 唔好送頭 唔好被捕<br />\n光復香港 時代革命"},{"pid":"a20c835ca8def84fbf161be829e11a7a529bfd86","tid":1609203,"uid":194674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T13:57:06.000Z","msg":"推"},{"pid":"5a09b0af227e7acd109ca913993adc98565270a7","tid":1609203,"uid":194674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T13:57:20.000Z","msg":"推"},{"pid":"a671f2646d60556e07d9c74986712b3e93b24d71","tid":1609203,"uid":194674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T13:57:30.000Z","msg":"推"},{"pid":"fddcc91cc093790ed820231a1cd140dca7e95e61","tid":1609203,"uid":194674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T13:57:40.000Z","msg":"推"},{"pid":"bc13c5a9d585fe41026e0a3358f004ab1855e8de","tid":1609203,"uid":194674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T13:58:05.000Z","msg":"推"},{"pid":"d8d63f5b6c3d7185155963c502f2da850ed8b706","tid":1609203,"uid":282798,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-01T13:58:08.000Z","msg":"喺tg grp講"},{"pid":"95a8a26189745e6fa062d0574c2a0769065a9877","tid":1609203,"uid":194674,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T13:58:16.000Z","msg":"推"},{"pid":"9314ac17a2a056e98c3f0e6722af3ccd0e0adc7c","tid":1609203,"ui