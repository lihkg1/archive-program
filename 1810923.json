,{"pid":"e69c6c82fe23bdae531cc05a57ce7ac547f397d4","tid":1810923,"uid":24044,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-20T11:00:12.000Z","msg":"<img src=\"https://scontent-hkg3-1.xx.fbcdn.net/v/t1.0-9/81197195_10157617572265726_5618819608405344256_n.jpg?_nc_cat=108&amp;_nc_ohc=tqG3uc5Rr_AAX8br5Sg&amp;_nc_ht=scontent-hkg3-1.xx&amp;oh=164404312bc892ee0075e7f039d74969&amp;oe=5E9CCE4E\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkg3-1.xx.fbcdn.net%2Fv%2Ft1.0-9%2F81197195_10157617572265726_5618819608405344256_n.jpg%3F_nc_cat%3D108%26_nc_ohc%3DtqG3uc5Rr_AAX8br5Sg%26_nc_ht%3Dscontent-hkg3-1.xx%26oh%3D164404312bc892ee0075e7f039d74969%26oe%3D5E9CCE4E&h=7f0eecf7&s={SIZE}\" />"},{"pid":"81456bcd209fc0bb394327826b685337f37313a3","tid":1810923,"uid":24044,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-20T11:01:57.000Z","msg":"<img src=\"https://scontent-hkg3-2.xx.fbcdn.net/v/t1.0-9/83158014_583565465553936_4176554287440068608_n.jpg?_nc_cat=109&amp;_nc_ohc=T75-POxTvFEAX9P0cmZ&amp;_nc_ht=scontent-hkg3-2.xx&amp;oh=6ea83f323ea6f2084ff1e5d1c83bd0a5&amp;oe=5E9C6262\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkg3-2.xx.fbcdn.net%2Fv%2Ft1.0-9%2F83158014_583565465553936_4176554287440068608_n.jpg%3F_nc_cat%3D109%26_nc_ohc%3DT75-POxTvFEAX9P0cmZ%26_nc_ht%3Dscontent-hkg3-2.xx%26oh%3D6ea83f323ea6f2084ff1e5d1c83bd0a5%26oe%3D5E9C6262&h=4b6aafb9&s={SIZE}\" /><br />\n<br />\n<img src=\"https://scontent-hkg3-1.xx.fbcdn.net/v/t1.0-9/82939219_583565492220600_2417987637559164928_n.jpg?_nc_cat=103&amp;_nc_ohc=F5FNj9-8CIcAX9wIkC5&amp;_nc_ht=scontent-hkg3-1.xx&amp;oh=2fc83d08a165431bdec2e74a45a6b1ac&amp;oe=5EDAFCAD\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkg3-1.xx.fbcdn.net%2Fv%2Ft1.0-9%2F82939219_583565492220600_2417987637559164928_n.jpg%3F_nc_cat%3D103%26_nc_ohc%3DF5FNj9-8CIcAX9wIkC5%26_nc_ht%3Dscontent-hkg3-1.xx%26oh%3D2fc83d08a165431bdec2e74a45a6b1ac%26oe%3D5EDAFCAD&h=b50b13a6&s={SIZE}\" /><br />\n<br />\n<img src=\"https://scontent-hkg3-1.xx.fbcdn.net/v/t1.0-9/82505037_583565405553942_6873762868513210368_n.jpg?_nc_cat=102&amp;_nc_ohc=RPJTkk6tZHMAX9FHVhQ&amp;_nc_ht=scontent-hkg3-1.xx&amp;oh=d3ca9c47dd7f4a78256b5d4e600b4c8e&amp;oe=5ED0D5B6\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkg3-1.xx.fbcdn.net%2Fv%2Ft1.0-9%2F82505037_583565405553942_6873762868513210368_n.jpg%3F_nc_cat%3D102%26_nc_ohc%3DRPJTkk6tZHMAX9FHVhQ%26_nc_ht%3Dscontent-hkg3-1.xx%26oh%3Dd3ca9c47dd7f4a78256b5d4e600b4c8e%26oe%3D5ED0D5B6&h=93ba7fa4&s={SIZE}\" /><br />\n<br />\n<img src=\"https://scontent-hkg3-1.xx.fbcdn.net/v/t1.0-9/82227886_583565445553938_1380302884347838464_n.jpg?_nc_cat=108&amp;_nc_ohc=wxj-F-kRS_4AX-4AoSM&amp;_nc_ht=scontent-hkg3-1.xx&amp;oh=71302efd2c4b2313525176dd17594183&amp;oe=5E961240\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkg3-1.xx.fbcdn.net%2Fv%2Ft1.0-9%2F82227886_583565445553938_1380302884347838464_n.jpg%3F_nc_cat%3D108%26_nc_ohc%3Dwxj-F-kRS_4AX-4AoSM%26_nc_ht%3Dscontent-hkg3-1.xx%26oh%3D71302efd2c4b2313525176dd17594183%26oe%3D5E961240&h=a3fbc187&s={SIZE}\" /><br />\n<br />\n#黃店#<br />\n店舖名 「發花癲」<br />\n旺角塘尾道66-68號福強工業大廈B座1301室<br />\n​Whatsapp 9781 7511<br />\n<br />\n花墟真係好多藍店😡每年又要自己用又要送禮，一月頭特意上網搵黃色小店，發覺呢間黃到爆，而且老細曾經去過外國幾間大師級名店學習花藝￼￼￼￼￼￼￼。<br />\n之後留言訂花，點知佢話要去台灣被邀請睇選舉。終於等到佢返嚟交花，尋日去咗取其中已訂盆栽￼￼。<br />\n價錢真係好公道￼。$2xx幾蚊（我忍唔住手買咗六盤，仲有三盤大盤未攞￼￼😅）<br />\n各位街坊可以WhatsApp問佢仲有冇花賣。<br />\n因為小本經營，平日應該主要做婚禮花球，所以係隱身係工業大廈內。<br />\n店舖名￼「發花癲」"},{"pid":"00414099783ee7b5b3431de5a83caaf2e6bfdf2d","tid":1810923,"uid":24044,"like":0,"dislike":0,"score":0,"quote":{"pid":"e69c6c82fe23bdae531cc05a57ce7ac547f397d4","tid":1810923,"uid":24044,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-20T11:00:12.000Z","msg":"<img src=\"https://scontent-hkg3-1.xx.fbcdn.net/v/t1.0-9/81197195_10157617572265726_5618819608405344256_n.jpg?_nc_cat=108&amp;_nc_ohc=tqG3uc5Rr_AAX8br5Sg&amp;_nc_ht=scontent-hkg