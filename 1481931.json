mal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"23544ef1488db4c410710bf64999efe833a1f2cc","tid":1481931,"uid":261672,"like":10,"dislike":2,"score":8,"quote":{"pid":"7f8ab10bce211a20d920161af9cd81b95cc8bbaa","tid":1481931,"uid":34029,"like":106,"dislike":0,"score":106,"citedBy":3,"replyTime":"2019-08-18T02:25:14.000Z","msg":"大家以後盡可能簡坐返國泰<br />\n如果國泰都收埋皮 變中國南方航空進駐"},"citedBy":0,"replyTime":"2019-08-18T04:26:48.000Z","msg":"hkexpress得唔得<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"db2a6912794cfef402944670e0429cffaac2ae08","tid":1481931,"uid":194745,"like":1,"dislike":27,"score":-26,"citedBy":0,"replyTime":"2019-08-18T05:05:16.000Z","msg":"國泰不嬲好嘅只係啲機師空姐，國泰航空間公司同管理層不嬲對機師空姐極差，只因有機師空姐工會幫佢哋。啲管理層只是吸血蛀米大蟲，吸盡機師同空姐的工作成果。<br />\n<br />\n啲管理層炒燃油對沖蝕錢，就搵員工裁員找數。自己亂駛錢大花筒就刻薄空姐，減航班人手加座位。<br />\n<br />\n大家要分開公司同員工，pacific place啲員工幫手，唔代表太古幫手。太古不嬲都是奶共㗎<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">啲管理層已經將員工名單交給民航局，嗰啲示過威表過態嘅黃絲空姐機師冇得飛越中國領空，好快會被迫走，成間公司上上下下管理層機師空姐都會係藍絲。<br />\n<br />\n太古一早已經奶共，當初自願將國泰股權交出媚共自保，繼續揾銀。反而怡和遷冊撤出香港。</span></span><br />\n<br />\n<a href=\"https://eastweek.my-magazine.me/main/86420\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Feastweek.my-magazine.me%2Fmain%2F86420&d=qWNbGjuqVnVY%2B89Bav9Y1JnDkpC49KclrNwegNic%2Fqo%3D&h=1054f81d\" data-auto-link target=\"_blank\">https://eastweek.my-magazine.me/main/86420</a><br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">新CEO 鄧生來自港機工程，一早紮根厦門，一定好識做</span></span><br />\n<br />\n去台灣，長榮/中華<br />\n<br />\n去日本， JAL ANA PEACH<br />\n<br />\n去歐洲 英航，三寶, virgin Air France lufthansa<br />\n<br />\n去澳洲 virgin qantas<br />\n<br />\n去美國 AA United<br />\n<br />\n去中國  冇計 國泰港龍"},{"pid":"ad5cb07b39544ef29d5ab551cc457147f0af82ad","tid":1481931,"uid":38737,"like":0,"dislike":0,"score":0,"quote":{"pid":"8fb1c5447ecd02c14b785054520bc491e7f8ce22","tid":1481931,"uid":5809,"like":61,"dislike":1,"