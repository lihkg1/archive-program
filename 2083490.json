/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"a5401004ef41406db4eee21d22fcb4e03bad45f9","tid":2083490,"uid":298415,"like":0,"dislike":0,"score":0,"quote":{"pid":"85f5042cbf865c68613f6b32478cf8eb18b35b93","tid":2083490,"uid":35081,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2020-06-28T20:00:14.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-28T20:03:47.000Z","msg":"唔通係師姐？<img src=\"/assets/faces/dog/on_hold.gif\" class=\"hkgmoji\" />"},{"pid":"37f0a577f9876105ea01b9504910af8b4c5ece3e","tid":2083490,"uid":35081,"like":0,"dislike":0,"score":0,"quote":{"pid":"a5401004ef41406db4eee21d22fcb4e03bad45f9","tid":2083490,"uid":298415,"like":0,"dislike":0,"score":0,"quote":{"pid":"85f5042cbf865c68613f6b32478cf8eb18b35b93","tid":2083490,"uid":35081,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2020-06-28T20:00:14.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-28T20:03:47.000Z","msg":"唔通係師姐？<img src=\"/assets/faces/dog/on_hold.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-28T20:18:58.000Z","msg":"<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},{"pid":"f0512e8d1e3be25f7a53196f6b51d85c236f9b1e","tid":2083490,"uid":325269,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2020-06-28T20:27:02.000Z","msg":"教學方式hea唔係學校事啦，係個tutor 問題。據聞多港豬同NDS。<br />\n<br />\n但如果你係想有分穩定工嘅話，係睇工作，而唔係睇學校，講真八大fg都未必一定搵到工，搵到之後咪又係睇你工作表現。<br />\n<br />\n你不如睇下media相關工作邊啲工唔會容易受啲外來因素（例如疫情）影響、需求大。<br />\n<br />\n如果你諗住讀完就搵工，bu可能好啲，傳理出名，出bu cert 嘅話，咪等同bu傳理出嚟，而且睇落工作出路較另外兩個出路多。你諗住master洗底，三間都冇所謂。<br />\n<br />\n其實普遍啲人都係話唔受外界影響，又肯付出，會容易上到岸。<br />\n<br />\n個人覺得： bu &gt;&gt;&gt;&gt;&gt; speed = thei"},{"pid":"ca7f53e04e05535abb311292ce4e04b1469db27d","tid":2083490,"uid":195821,"like":0,"dislike":0,"score":0,"quote":{"pid":"7e7e686a203ccb7fb87699c8066e33b3e799090b","tid":2083490,"uid":298415,"like":0,"dislike":0,"score":