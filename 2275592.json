108206506e73154f04b8ce","tid":2275592,"uid":19668,"like":0,"dislike":0,"score":0,"quote":{"pid":"afc255f6a2ab84084dd9b124a234a09f8600964d","tid":2275592,"uid":24688,"like":0,"dislike":0,"score":0,"quote":{"pid":"056cff618d93a5bae4b85a1594dda0e4c23c147e","tid":2275592,"uid":19668,"like":1,"dislike":0,"score":1,"quote":{"pid":"1b7e0c40eaa47aa41e948ef0d3d2d4c4337e98e5","tid":2275592,"uid":24688,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-07T09:29:27.000Z","msg":"FEEL到佢湧緊出殷 <img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-07T09:30:47.000Z","msg":"建議扯下旗忍住"},"citedBy":1,"replyTime":"2020-11-07T09:45:14.000Z","msg":"同女神搭緊車 對住佢扯唔太好<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-07T12:08:58.000Z","msg":"圖呢<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"2fec30277aa8939a9e6411cf706a2739061ed885","tid":2275592,"uid":62,"like":0,"dislike":0,"score":0,"quote":{"pid":"f482ed25b9c876605c812e03b918fd1e4053bef2","tid":2275592,"uid":154478,"like":2,"dislike":6,"score":-4,"citedBy":1,"replyTime":"2020-11-07T09:30:11.000Z","msg":"急屎師<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-08T06:06:50.000Z","msg":"屍撚鳩未呀屌你<br />\n師師師又唔係好笑<br />\n我真係屌你老師"}]}