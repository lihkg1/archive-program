lyTime":"2020-08-03T05:07:06.000Z","msg":"林多都講總辭"},{"pid":"05a96798ab75d0fafa3194b1d7c1da4a57be5d11","tid":2137291,"uid":85629,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-03T05:07:31.000Z","msg":"集體總辭 變相公投？"},{"pid":"f84f9ca21c9ccb1f9de8c5e0b46e3451a9a76f9b","tid":2137291,"uid":120575,"like":0,"dislike":0,"score":0,"quote":{"pid":"05a96798ab75d0fafa3194b1d7c1da4a57be5d11","tid":2137291,"uid":85629,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-03T05:07:31.000Z","msg":"集體總辭 變相公投？"},"citedBy":0,"replyTime":"2020-08-03T05:16:49.000Z","msg":"訓左幾耐仲點會比你投<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"7263b1fba92bb47646209405767f2b954cd07cb7","tid":2137291,"uid":33028,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-03T05:18:31.000Z","msg":"總辭咪冇哂約滿酬金<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"275d38eb8402c4f4c3dd6e5f08fde1f10065b8cd","tid":2137291,"uid":332804,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-03T05:23:54.000Z","msg":"我反而覺得應該有dq先總辭，要港共先樣衰左，泛民先話唔接受。"},{"pid":"029e2806a56ef17e605caca38c7697db4de2f412","tid":2137291,"uid":86980,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-03T05:24:15.000Z","msg":"白鴿黨淨係會睇錢嘅啫"},{"pid":"25957c0e6103acaa7706cc9e0dc08f19d5407af3","tid":2137291,"uid":82938,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-08-03T05:27:12.000Z","msg":"1/3都無埋仲唔總辭係度托咩"},{"pid":"ff96194ad1ed56e5d0cd872802385041f00769ae","tid":2137291,"uid":106955,"like":0,"dislike":0,"score":0,"quote":{"pid":"7263b1fba92bb47646209405767f2b954cd07cb7","tid":2137291,"uid":33028,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-03T05:18:31.000Z","msg":"總辭咪冇哂約滿酬金<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-03T05:28:43.000Z","msg":"而家咪約滿左 講緊黎緊果年續任"}]}