 你 們 說 、 奉 特 斯 拉 名 來 的 是 應 當 稱 頌 的 。 （馬斯克福音1:9）"},{"pid":"cf56dafe59b9f7bac8b8b68ec4a6667df712c1b9","tid":2299423,"uid":92603,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2020-11-24T23:49:24.000Z","msg":"all in apple"},{"pid":"0c96d7bb0cb7036817edbb5aad9e6a9e4423f15a","tid":2299423,"uid":92603,"like":0,"dislike":0,"score":0,"quote":{"pid":"cf56dafe59b9f7bac8b8b68ec4a6667df712c1b9","tid":2299423,"uid":92603,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2020-11-24T23:49:24.000Z","msg":"all in apple"},"citedBy":0,"replyTime":"2020-11-24T23:50:09.000Z","msg":"得佢未升起等埋大家上車"},{"pid":"fc1ded45c9626a0db365370a85cee85ecd364e9f","tid":2299423,"uid":72228,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-11-25T00:03:42.000Z","msg":"樓主唔死都無用"},{"pid":"0adea09633e0d38b3f2f943610528dd663d1e482","tid":2299423,"uid":36303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T00:06:15.000Z","msg":"ACB welcome you<img src=\"/assets/faces/mouse/potion.gif\" class=\"hkgmoji\" />"},{"pid":"7c5986bdb41f3c065103d8d56c5ba1c6256541da","tid":2299423,"uid":18085,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T00:07:01.000Z","msg":"all in tsla<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"22dc36e1a192cfc34c93d02925be5ab2d1ba73b5","tid":2299423,"uid":1059,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T00:09:00.000Z","msg":"This week Tesla 600 call"},{"pid":"e29bfef72471e52dca954cb37c9817b7dcdead75","tid":2299423,"uid":114010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T00:09:36.000Z","msg":"All in nio 小鵬 理想 tesla"},{"pid":"fad5e1692899f28a48e2bc31ae32c6e5748d0528","tid":2299423,"uid":34060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T00:11:55.000Z","msg":"新手開始追入市<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"1a0e736e7202e1f7fd183f7203081239dc245593","tid":2299423,"uid":8921,"like":0,"dislike":0,"score":0,"citedBy":0,"rep