sets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"3731efb46c421beb09e0fdb95b0d4310a5af0dca","tid":2356973,"uid":226829,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-10T08:33:11.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"da41f38d313a55aa3f13bb882f5816d3be679fcf","tid":2356973,"uid":72306,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-01-10T08:41:32.000Z","msg":"冬蟬=垃圾,眼高手低"},{"pid":"d44afe7c825a7784cb60c3099e4bfb11ca05b952","tid":2356973,"uid":306340,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2021-01-10T08:46:47.000Z","msg":"概念ok<br />\n但盡量唔好用「一個人」漫畫<br />\n佢本身好多邏輯謬誤，同本地漫畫家有好大仇"},{"pid":"0c7012507b23bfb726b1fd539779f245deaf7883","tid":2356973,"uid":226829,"like":2,"dislike":0,"score":2,"quote":{"pid":"d44afe7c825a7784cb60c3099e4bfb11ca05b952","tid":2356973,"uid":306340,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2021-01-10T08:46:47.000Z","msg":"概念ok<br />\n但盡量唔好用「一個人」漫畫<br />\n佢本身好多邏輯謬誤，同本地漫畫家有好大仇"},"citedBy":0,"replyTime":"2021-01-10T14:40:02.000Z","msg":"哦，呢幾格漫畫夠晒簡而清又中point，味用囉，我對事不對人，理鳩佢邊個作者"}]}