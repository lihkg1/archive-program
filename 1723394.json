mal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"61a4b829122d35b5195c5729f02dde73aff9a61e","tid":1723394,"uid":322685,"like":0,"dislike":0,"score":0,"quote":{"pid":"4f9db58806586f80103cdb03de8029926d519c22","tid":1723394,"uid":44925,"like":17,"dislike":1,"score":16,"citedBy":5,"replyTime":"2019-11-15T07:36:46.000Z","msg":"而且佢拋波俾非CU人<br />\n某程度上係保緊中大學生<br />\n<br />\n大家諗下先"},"citedBy":0,"replyTime":"2019-11-15T07:39:49.000Z","msg":"推"},{"pid":"0bda169bef425f7b0b5f35e78809f0ae17b3e6ea","tid":1723394,"uid":261697,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-15T07:39:53.000Z","msg":"佢非真心被逼出封信嘅話，咁我地都非真心被逼咁屌佢<br />\n<br />\n每個行為都必須有相應後果，否則會變雙重標準"},{"pid":"0bfbc8265edc55fd7b6ecbace5221fafc484214f","tid":1723394,"uid":109505,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T07:42:22.000Z","msg":"到而家都唔敢講譴責狗隊<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"5a736e8a3c863cb890d229d26d9adc7da902487e","tid":1723394,"uid":127889,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-11-15T07:45:17.000Z","msg":"人地校長<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />緊係剩係攬學生啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />要佢保埋你班非學生做咩撚<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"b7a41573b391a8f3c1d0c55ca5ecb88546cec123","tid":1723394,"uid":262063,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-15T07:46:38.000Z","msg":"中大同學進退有度，要be water！<br />\n<br />\n劉進圖：<br />\n<br />\n<br />\n各位正在校園不同位置守護中大的同學：<br />\n<br />\n<br />\n我是中文大學新聞傳播學院的兼職講師，自1996年起在中大教授傳播法，看到中大校門被攻打，美麗的校園淪為戰場，感到無比痛心，看到你們冒着生命危險守護大學，既感動又擔憂。現在形勢險惡，我感到有必要告訴你們幾點事情，雖然未必中聽，但本着愛心說誠實話，是作為老師對同學的基本責任。<br />\n<br />\n（一）大學校園內若沒有發生罪案或緊急事故，警方不應擅自闖入校園，即使有人報案，也應先知會校方，在校方陪同下進入校園，這是警方和大學多年來的協議。不過，由於大學校園內出現大量自製汽油彈，二號橋上又持續有人向吐露港公路擲物，警方不難說服法院頒布搜查令，合法進入大學校園，檢取危險物品及拘捕管有這些物品的人，其間可以使用合理武力，而何謂合理武力，取決於反抗的武力程度，同學受傷甚至死亡的風險相當高。<br />\n<br />\n<br />\n（二）國際社會雖然關注香港的人權與自由狀況，但當中外媒體把大量汽油彈引發的熊熊火光，通過媒體鏡頭向世人展示，即使警方用了大量武器，不幸造成了一定程度人命傷亡，只要大致合乎比例，國際社會也難以譴責，遑論聯手制裁，不會達致某些抗爭者希冀出現的「攬炒」結局，最終同學付出慘重代價，可能一無所得，這和當年天安門鎮壓軍人射殺手無寸鐵學生，觸發國際制裁，情況有所不同。<br />\n<br />\n（三）當警方成功進駐校園，就會展開一連串的後續執法行動，包括大規模的搜查、拘捕和檢控，大學管理層極可能被撤換，許多院校和宿舍的管理者將被追究責任，大學原來的自由、開明、包容的學術風氣，可能一夜消失。同學們矢志守護一道校門、一條天橋，若因此犧牲了一代的師生和大學的自由，是否值得？這是同學們需要深思的。<br />\n<br />\n（四）大學校方雖然無法強迫同學為自身安全暫時撤離，也無法阻止同學用各種方法自衛，但校方有責任勸喻同學銷毀危險物品，也有責任以合理可行方法阻止衝突和悲劇發生，例如暫時封鎖二號橋，這些措施可能成功，也可能不成功，但在情在理在道義都必須嘗試，希望同學們理解。<br />\n<br />\n但願同學們有勇有謀，以Be Water的靈巧，避過這次危機，因為你們的生命和自由，才是大學最需要守護的無價資產。<br />\n<br />\n作者是資深傳媒人暨中文大學新聞傳播學院兼職講師"},{"pid":"814f13d3ba23f0940ca93dcf9a7d22f1fdebf0d5","tid":1723394,"uid":44925,"like":1,"dislike":0,"score":1,"quote":{"pid":"0bda169bef425f7b0b5f35e78809f0ae17b3e6ea","tid":1723394,"uid":261697,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-15T07:39:53.000Z","msg":"佢非真心被逼出封信嘅話，咁我地都非真心被逼咁屌佢<br />\n<br />\n每個行為都必須有相應後果，否則會變雙重標準"},"citedBy":1,"replyTime":"2019-11-15T07:46:49.000Z","msg":"中環拉跌女手足條仆街都仲未有後果啦<br />\n上水荃灣斬人班友都仲未有後果<br />\n更仆街既人都未有後果既時候你蝦個文弱書生<br />\n其實係欺善怕惡"},{"pid":"a2c6aa98bd5e49155655805263a442585b1ba76e","tid":1723394,"uid":761,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T07:47:11.000Z","msg":"扮"},{"pid":"e8d4aa985638b4a267afbf89fb4442ffeafddc9d","tid":1723394,"uid":761,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T07:47:31.000Z","msg":"推"},{"pid":"56a5b9dce1ba2ad5ff36a0e4a8dbc759fa3c46b0","tid":1723394,"uid":188998,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T07:48:47.000Z","msg":"望下郭位<img src=\"/assets/faces/dog/on_hold.gif\" class=\"hkgmoji\" /><br />\n再望下段王爺<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"4aeabc5f4679b77463b92e1a14221b2810f66094","tid":1723394,"uid":761,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T07:48:56.000Z","msg":"推"},{"pid":"9ea73ad59a32d554ce4ed6b56a4