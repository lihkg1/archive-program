ore":0,"citedBy":0,"replyTime":"2019-06-17T17:20:37.000Z","msg":"同為nursing人 辛苦哂<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\nPish pish pish"},{"pid":"4e3ecbaaa352a9fe5b76fee5d7522d7a7fd6eb91","tid":1238093,"uid":263019,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T17:23:36.000Z","msg":"搵人放上Reddit<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"cadb53b564c2e2b0e209d94b6e7631cb731d93ed","tid":1238093,"uid":29291,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-17T17:40:09.000Z","msg":"中信真係重災區<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4a3b068fd994e0e6d809dd780fd981a71f2754a6","tid":1238093,"uid":29291,"like":0,"dislike":0,"score":0,"quote":{"pid":"e2f2115c5ac9af3431a3e441bc72bae400e29563","tid":1238093,"uid":204045,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-17T17:18:23.000Z","msg":"發夢係現場食曬彈又比防暴趕<br />\n入面好多人抽搐又呻吟<br />\n人間煉獄咁<br />\n喊足成個星期"},"citedBy":0,"replyTime":"2019-06-17T17:57:10.000Z","msg":"係 當時好多人都呼吸唔到 大叫問有冇藥<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />"},{"pid":"992ff8495055636f0e0ea9f05a05390af3403079","tid":1238093,"uid":60916,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T18:01:34.000Z","msg":"推爆<br />\n推到班警察去歐洲"},{"pid":"659911d6dcae255e6c27c99818a9a1bd1ec1f65e","tid":1238093,"uid":212182,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T18:07:32.000Z","msg":"推"},{"pid":"b78a5cdcda1310fcf75489159b39efb192cb64ce","tid":1238093,"uid":92951,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T18:08:59.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"699cbc2ec60e4747ad1f9eafc0f1342aca087975","tid":1238093,"uid":204045,"like":0,"dislike":0,"score":0,"quote":{"pid":"cadb53b564c2e2b0e209d94b6e7631cb731d93ed","tid":1238093,"uid":29291,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-17T17:40:09.000Z","msg":"中信真係重災區<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-18T00:50:14.000Z","msg":"最後防休息區變前線 痴左咩線啊！！<br />\n黑警一定要受審！！"},{"pid":"77f76238105c045c98a08a875c441656867455d2","tid":1238093,"uid":29291,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-18T02:50:15.000Z","msg":"Push<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"dbc699af865464bf4f3dfa6cd9f38956cdb51eee","tid":1238093,"uid":215241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-18T02:54:29.000Z","msg":"拰"},{"pid":"a0e575ad48d93da714501f512561a289fafa4f43","tid":1238093,"uid":30633,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-18T03:24:37.000Z","msg":"還原真相中，三語同步放送<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n香港版<br />\n<a href=\"https://youtu.be/13eauJMTOkU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F13eauJMTOkU&d=7EcP4%2BvGpl6inSsjOqiUXpuyGkzLGvEkvhYecc72uXM%3D&h=941a927d\" target=\"_blank\">https://youtu.be/13eauJMTOkU</a><br />\nEnglish Version<br />\n<a href=\"https://youtu.be/3V_wVnyvbuQ\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F3V_wVnyvbuQ&d=7EcP4%2BvGpl6inSsjOqiUXpuyGkzLGvEkvhYecc72uXM%3D&h=dc866374\" target=\"_blank\">https://youtu.be/3V_wVnyvbuQ</a><br />\n日本語版<br />\n<a href=\"https://youtu.be/RGqbhEF6Hyc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FRGqbhEF6Hyc&d=7EcP4%2BvGpl6inSsjOqiUXpuyGkzLGvEkvhYecc72uXM%3D&h=51478e11\" target=\"_blank\">https://youtu.be/RGqbhEF6Hyc</a>"}]}