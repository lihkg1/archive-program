.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDZK5Xjk.jpg&h=c8bd18ae&s={SIZE}\" /><img src=\"https://na.cx/i/6606dcM.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6606dcM.jpg&h=7abaf024&s={SIZE}\" /><br />\n我就想剪完側邊會係係上圖效果<br />\n但係個髮型師就好似馬明個張咁係半剷半留咁嘅狀態<br />\n利伸先：我去剪之前已經留到好長<br />\n比埋相佢睇話要呢隻效果<br />\n如果咁都可以話係我問題真係冇野好講<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n巴打好慘 <br />\n利申 側面上面長度"},{"pid":"c236e099a3668d379d2fbc4f234034cfb8c7aceb","tid":143423,"uid":19929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T13:18:40.000Z","msg":"貼埋你而加個頭黎睇先<br />\n要睇埋你髮質<br />\n<br />\n<br />\n利申：星級髮型師"},{"pid":"e1e9a838c4ad2799c6240224495d356d30e20641","tid":143423,"uid":27416,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T13:21:14.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote>之前就玩開油頭<br />\n但係臉型太長 唔好睇<br />\n叫個髪型師留2邊 拉返闊個臉型<br />\n好似韓仔果隻咁<br />\n但佢搞到好似剷青剷完1個月果種狀態咁<br />\n打橫生<br />\n呢家d髪型師係咪唔剷就唔識剪頭髪呢?<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n主要係你樣柒</blockquote><br />\n樣柒我就認<br />\n但係呢個擺明就髪型師技術問題</blockquote><br />\n樣柒你瀨乜野落髮型師度？樣柒你不如搵整容醫生執執個樣丫。</blockquote><br />\n呢家討論吓髮型師姐<br />\n又唔洗吓吓攻擊人嘅</blockquote><br />\ngel出黎嫁喎<br />\n叫佢兩邊留長露耳就得"},{"pid":"45bfb7c3a48284a0a975d93b2b2ce8305daa6014","tid":143423,"uid":35315,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T13:23:40.000Z","msg":"髮質同生長方向都信個唔同啦"},{"pid":"ec7aab6e2b68086d69f3b3f47eba80d0eed9c330","tid":143423,"uid":85384,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T13:38:39.000Z","msg":"冇圖真心難討論 <br />\n利申 用開電鋸剪髮"},{"pid":"5e270654d4274cd0d869c3311175b0a10f74144f","tid":143423,"uid":61974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T13:38:54.000Z","msg":"你不如直接比相佢睇<br />\n如果仲係做唔到你想要既效果<br />\n索性去d幾十蚊單剪算"},{"pid":"fb17a5ace910cb70c348f03b211685e621bfcbe1","tid":143423,"uid":61,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T13:44:32.000Z","msg":"你個髮質問題關髮型師咩事...所有明星相嘅髮型都係gel出黎，你唔gel想有咁嘅效果，諗撚大咗？"},{"pid":"b1280cce16ec87a7c1bb5178105bf6d3f0417658","tid":143423,"uid":9387,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T13:52:16.000Z","msg":"韓仔頭髮質係軟同貼過普遍香港人好多 香港人多數好粗硬"},{"pid":"a3a53493379b4be44ba1cb714d83ecbedcf2dbc4","tid":143423,"uid":22643,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-03-05T13:52:17.000Z","msg":"<blockquote>你個髮質問題關髮型師咩事...所有明星相嘅髮型都係gel出黎，你唔gel想有咁嘅效果，諗撚大咗？</blockquote><br />\n我話側邊呀<br />\n我點樣gel長我d頭髮呀大佬"},{"pid":"0bc5f531af02abbd4d1b40e4143f5add82194f79","tid":143423,"uid":38102,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T14:04:00.000Z","msg":"你去邊間？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bc71f100c4bfdabb4507e8b218a17c04654ffc24","tid":143423,"uid":36137,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T14:04:28.000Z","msg":"你依家睇緊嘅係"},{"pid":"eb1dd122832f16dd570baa7ce915fc2ac4a4d9c5","tid":143423,"uid":77029,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T14:09:49.000Z","msg":"無意針對，以下係個人感覺<br />\n樓主其實講得岩，有fd 叫髮型師（3舊1次）留長2邊，最後都係同佢剷曬<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> 我推介左佢幾個外籍髮型師，廢事佢留完又被人剷<img src=\"/assets/faces/big/sosad.gif\" class=\"hkgmoji\" /> <br />\n心理層面上我認為d髮型師同IT人一樣，孤芳自賞，唔聽人講野/要求（即使你係客<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> ），利申假IT人<br />\n技術層面我認為佢地無理由唔識，定係香港髮型師大多出身自同一學校，教剪男仔頭風格就係剷2邊？<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"},{"pid":"43a7db7eec2237dcf0944774bc0dab6657ab25ab","tid":143423,"uid":19929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T14:19:23.000Z","msg":"<blockquote><blockquote>你個髮質問題關髮型師咩事...所有明星相嘅髮型都係gel出黎，你唔gel想有咁嘅效果，諗撚大咗？</blockquote><br />\n我話側邊呀<br />\n我點樣gel長我d頭髮呀大佬</blockquote><br />\n如果你髮質係下圖都唔代表你兩邊長返會有圖一既效果"},{"pid":"b77517bcdfd3aefc943eca626736b7c8513975e8","tid":143423,"uid":5148,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T14:21:18.000Z","msg":"<blockquote><img src=\"https://na.cx/i/DZK5Xjk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDZK5Xjk.jpg&h=c8bd18ae&s={SIZE}\" /><img src=\"https://na.cx/i/6606dcM.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6606dcM.jpg&h=7abaf024&s={SIZE}\" /><br />\n我就想剪完側邊會係係上圖效果<br />\n但係個髮型師就好似馬明個張咁係半剷半留咁嘅狀態<br />\n利伸先：我去剪之前已經留到好長<br />\n比埋相佢睇話要呢隻效果<br />\n如果咁都可以話係我問題真係冇野好講<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n你本身咩長度先?<br />\n<br />\n如果你本身係圖1長度<br />\n佢剪到咁就佢唔岩<br />\n<br />\n如果你本身只係長過圖2少少<br />\n咁正常就算你要留長佢都會幫你修整齊d<br />\n等你留長既過程唔好咁柒<br />\n<br />\n如果樓主一開始連一刀都唔想剪就早d講<br />\n叫人淨係剪top<br />\n<br />\n不過其實要留長個青+你本人髮質叉起<br />\n點整都一定柒<br />\n除非你捱到好長<br />\n長到d青都drop返落黎"},{"pid":"d501440cf12ce924bef2d11f6d8c8888089a0a52","tid":143423,"uid":5218,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T14:33:45.000Z","msg":"<blockquote><blockquote><img src=\"https://na.cx/i/DZK5Xjk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDZK5Xjk.jpg&h=c8bd18ae&s={SIZE}\" /><img src=\"https://na.cx/i/6606dcM.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6606dcM.jpg&h=7abaf024&s={SIZE}\" /><br />\n我就想剪完側邊會係係上圖效果<br />\n但係個髮型師就好似馬明個張咁係半剷半留咁嘅狀態<br />\n利伸先：我去剪之前已經留到好長<br />\n比埋相佢睇話要呢隻效果<br />\n如果咁都可以話係我問題真係冇野好講<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n你本身咩長度先?<br />\n<br />\n如果你本身係圖1長度<br />\n佢剪到咁就佢唔岩<br />\n<br />\n如果你本身只係長過圖2少少<br />\n咁正常就算你要留長佢都會幫你修整齊d<br />\n等你留長既過程唔好咁柒<br />\n<br />\n如果樓主一開始連一刀都唔想剪就早d講<br />\n叫人淨係剪top<br />\n<br />\n不過其實要留長個青+你本人髮質叉起<br />\n點整都一定柒<br />\n除非你捱到好長<br />\n長到d青都drop返落黎</blockquote><br />\n我諗條戇鳩想個髮型師幫佢剪長 d，即係剪完要長過之前，總之諗到就係。"},{"pid":"c865215ed9a4cd8435cee43a23f00f5b4b9d9029","tid":143423,"uid":22643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T14:43:41.000Z","msg":"<blockquote><blockquote><blockquote><img src=\"https://na.cx/i/DZK5Xjk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDZK5Xjk.jpg&h=c8bd18ae&s={SIZE}\" /><img src=\"https://na.cx/i/6606dcM.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6606dcM.jpg&h=7abaf024&s={SIZE}\" /><br />\n我就想剪完側邊會係係上圖效果<br />\n但係個髮型師就好似馬明個張咁係半剷半留咁嘅狀態<br />\n利伸先：我去剪之前已經留到好長<br />\n比埋相佢睇話要呢隻效果<br />\n如果咁都可以話係我問題真係冇野好講<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n你本身咩長度先?<br />\n<br />\n如果你本身係圖1長度<br />\n佢剪到咁就佢唔岩<br />\n<br />\n如果你本身只係長過圖2少少<br />\n咁正常就算你要留長佢都會幫你修整齊d<br />\n等你留長既過程唔好咁柒<br />\n<br />\n如果樓主一開始連一刀都唔想剪就早d講<br />\n叫人淨係剪top<br />\n<br />\n不過其實要留長個青+你本人髮質叉起<br />\n點整都一定柒<br />\n除非你捱到好長<br />\n長到d青都drop返落黎</blockquote><br />\n我諗條戇鳩想個髮型師幫佢剪長 d，即係剪完要長過之前，總之諗到就係。</blockquote><br />\n討論吓又唔洗戇鳩前戇鳩後嘅<br />\n我剪之前就特登留到韓仔咁<br />\n2邊己經留到過哂耳仔<br />\n佢都問我係咪要圈返耳<br />\n而未剪之前2邊都貼貼服服<br />\n係個頂同後邊好厚 <br />\n佢就剪到好似你剷青剷完一個月果種狀態咁<br />\n<br />\nBtw<br />\n連登仔講咩吓吓都要一開波就人身攻擊<br />\n連少少討論空間都冇<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"a2e161cff25ad17dd78595a6579101c653c979ca","tid":143423,"uid":20736,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T14:50:52.000Z","msg":"我明啊樓主<br />\n你要同佢講側邊唔好剷咁高就會剪到架啦<br />\n最後指埋比佢睇大概剷到幾高<br />\n因為要剷高就一定會剷青<br />\n剷低先留到<br />\n<br />\nBtw 我都係咁樣剪<br />\n不過剪完同冇剪成日冇咩分別<br />\n同埋好快要再剪 唔係嘅話就一舊野咁"},{"pid":"32b99c1d38a73c1cb8eff8741254062ae0198eda","tid":143423,"uid":20736,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T14:52:21.000Z","msg":"男仔頭髮好快長<br />\n一個月黎咪又一條好漢<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"fb924e435d8139e40ee6c79fef59840fa7374a6d","tid":143423,"uid":22643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-05T15:10:19.000Z","msg":"<blockquote>我明啊樓主<br />\n你要同佢講側邊唔好剷咁高就會剪到架啦<br />\n最後指埋比佢睇大概剷到幾高<br />\n因為