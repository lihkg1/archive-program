=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"ccc3358c38e09212cb2c840bef78b58d4d04cb11","tid":615654,"uid":78571,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-04T12:25:25.000Z","msg":"lm"},{"pid":"eb6e9fff5b7752e3f248ffa9b6d7f15c32b63edd","tid":615654,"uid":180373,"like":0,"dislike":0,"score":0,"quote":{"pid":"b6bb8acd614202331065c1e9152b895f3d94986b","tid":615654,"uid":9844,"like":0,"dislike":0,"score":0,"quote":{"pid":"5564330c74d438196734e8bf86335efe520b26dc","tid":615654,"uid":9844,"like":0,"dislike":0,"score":0,"quote":{"pid":"de1a9b7995dd17f8a3d56dc73f4535a7eed97565","tid":615654,"uid":180373,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T12:13:30.000Z","msg":"大家互相交流 25年<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-04T12:18:44.000Z","msg":"樓主點睇未來五年700既發展正負面野？"},"citedBy":1,"replyTime":"2018-04-04T12:19:30.000Z","msg":"三到五年都得"},"citedBy":0,"replyTime":"2018-04-04T12:27:46.000Z","msg":"只要政治冇問題 小馬哥清醒 700就冇問題<br />\n其他因素只會短暫影響<br />\n雖然我都係今年先開始重倉騰訊，上年重倉融創中國<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"6f1a92fe9eb39cf0f63aac22574e56fd624953f3","tid":615654,"uid":148772,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T12:40:42.000Z","msg":"升左兩年先玩價投？"},{"pid":"e674737186ed06ab0a412570a6df5ddb4eb4aeed","tid":615654,"uid":180373,"like":0,"dislike":0,"score":0,"quote":{"pid":"6f1a92fe9eb39cf0f63aac22574e56fd624953f3","tid":615654,"uid":148772,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-04T12:40:42.000Z","msg":"升左兩年先玩價投？"},"citedBy":0,"replyTime":"2018-04-04T12:51:25.000Z","msg":"請追post"}]}