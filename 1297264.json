wQ2WUgHlXPv3B7QU%2BsV1%2BUkEKpk%3D&h=6eab76fd\" target=\"_blank\">https://www.kanjipedia.jp/kanji/0006395100</a><br />\n日本&quot;豐&quot;嘅簡化字嚟<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2019-07-08T15:49:44.000Z","msg":"「豊」字和「豐」字是音意各不同、不可相混的兩個獨立漢字<br />\n<a href=\"https://zh.m.wiktionary.org/zh-hant/%E8%B1%8A\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wiktionary.org%2Fzh-hant%2F%25E8%25B1%258A&d=QWAfKg5qpFwl7mzrwQ2WUgHlXPv3B7QU%2BsV1%2BUkEKpk%3D&h=2d61a49c\" target=\"_blank\">https://zh.m.wiktionary.org/zh-hant/%E8%B1%8A</a>"},"citedBy":0,"replyTime":"2019-07-08T15:56:40.000Z","msg":"咁你講緊日本豊洲市場係咪要用返豐個音，你睇返自己個網都有寫人地個豊字音讀係ほう (hō) 同ふう (fū)，點睇都唔似係禮個音掛<br />\n<br />\n音讀（日語：音読み／おんよみ On'yomi），是日語漢字的一種發音方式，係保留該等漢字當初傳入日本時的漢語發音[1]。相對的，若使用該等漢字之日本固有同義語匯的讀音，則稱為訓讀[2]。<br />\n<br />\n音讀往往在很大程度上保留了中古漢語讀音的特徵，如唐代長安音、古漢語的入聲。這些古漢語的特徵，在今日通用的現代標準漢語中皆已丟失。"},{"pid":"35f82eb661b5b70b20b9eb338131b8606c026c60","tid":1297264,"uid":8632,"like":0,"dislike":3,"score":-3,"quote":{"pid":"f86ff55824d6c0f5e4ab76ba619fb2cc5dc4c340","tid":1297264,"uid":200713,"like":0,"dislike":5,"score":-5,"quote":{"pid":"eedac4db26259866dc2c0bbd20f2f6f44c3766c5","tid":1297264,"uid":8632,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-07-08T15:46:45.000Z","msg":"<a href=\"https://www.kanjipedia.jp/kanji/0006395100\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.kanjipedia.jp%2Fkanji%2F0006395100&d=QWAfKg5qpFwl7mzrwQ2WUgHlXPv3B7QU%2BsV1%2BUkEKpk%3D&h=6eab76fd\" target=\"_blank\">https://www.kanjipedia.jp/kanji/0006395100</a><br />\n日本&quot;豐&quot;嘅簡化字嚟<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2019-07-08T15:49:44.000Z","msg":"「豊」字和「豐」字是音意各不同、不可相混的兩個獨立漢字<br />\n<a href=\"https://zh.m.wiktionary.org/zh-hant/%E8%B1%8A\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wiktionary.org%2Fzh-hant%2F%25E8%25B1%258A&d=QWAfKg5qpFwl7mzrwQ2WUgHlXPv3B7QU%2BsV1%2BUkEKpk%3D&h=2d61a49c\"