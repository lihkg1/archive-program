34822384638372ec895f0784bb59949","tid":1988863,"uid":224066,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-25T14:51:10.000Z","msg":"<img src=\"https://i.epochtimes.com/assets/uploads/2018/07/425aa13f28983c794c41272d91b56da4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.epochtimes.com%2Fassets%2Fuploads%2F2018%2F07%2F425aa13f28983c794c41272d91b56da4.png&h=9b6ab1e5&s={SIZE}\" />"},{"pid":"1d1d636c3f88a88ea7e768028ff094f7edd0900d","tid":1988863,"uid":31215,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-25T15:31:22.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"}]}