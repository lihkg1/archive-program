fc47d4","tid":1792210,"uid":41818,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2019-12-22T01:02:38.000Z","msg":"網上做好了 現場劇透係好仆街&hellip;<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-22T01:38:48.000Z","msg":"下，對住高級港豬你想唔仆街?<br />\n咁元氣都唔好攪啦"},{"pid":"ffc61004264b56cff962f28db505de069e7855e5","tid":1792210,"uid":245347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-22T01:39:28.000Z","msg":"不如<br />\n直接share 套戲比身邊人睇<br />\n聽講已經有得online 睇"},{"pid":"e048cb954b4466112bf203bced4c79bbff6c0e9d","tid":1792210,"uid":133806,"like":0,"dislike":0,"score":0,"quote":{"pid":"53881fc02b82fcc5ecf26b7e9d53f1143ffc47d4","tid":1792210,"uid":41818,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2019-12-22T01:02:38.000Z","msg":"網上做好了 現場劇透係好仆街&hellip;<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-22T01:39:37.000Z","msg":"本身俾錢睇呢啲吹奏支那民族主義嘅垃圾爛片嘅都好仆街啫<br />\n咁撚鐘意奶共，咪俾佢感受下咩叫共產主義嘅真諦<br />\n就係將自己睇完覺得好嘅故事，不分貧富，公諸同好<img src=\"/assets/faces/pigxm/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"3be9573ef3eea41741be5ea3a15730141a04d99b","tid":1792210,"uid":26876,"like":2,"dislike":0,"score":2,"quote":{"pid":"cf8137ff2fc9048cc66b5ee304577cebac1dc3fb","tid":1792210,"uid":736,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-21T12:47:24.000Z","msg":"外國例子:<br />\n<a href=\"https://youtu.be/t95aLo7R1NM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Ft95aLo7R1NM&d=xB%2B%2BVT6yLqhkLUe0erjI3MWiAETkOtN%2FvKUl8N5Dwlc%3D&h=a6aa0843\" data-auto-link target=\"_blank\">https://youtu.be/t95aLo7R1NM</a><br />\n<br />\n<br />\n即日起三五知己 （有大聲公更佳）<br />\n於戲院門口 交通工具 商場 餐廳<br />\n24/7 大聲討論葉問劇情<img src=\"/assets/faces/pigxm/hehe.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\nyoutube fb留言<br />\n好似&quot;epstein didn't kill himself&quot;個meme咁<br />\n每句comment後面都加劇透<br />\n例&quot;近排有幾聲咳 希望唔會好似葉問咁生cancer &quot;<br />\n<br />\n<img src=\"/assets/faces/pigxm/cook.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-22T01:48:13.000Z","msg":"#不是劇透 #必須看到尾<br />\n#入戲院前你要知的小背景<br />\n<br />\n【無雷】你不能不知道的＜葉問4＞基礎認識<br />\n<br />\n葉問得了癌症，偏偏兒子不學好，在學校打架鬧事，慘遭學校退學。葉問只好接受弟子李小龍的邀請，去美國為兒子申請學校，豈知華人到了美國受盡歧視，處處碰壁。<br />\n<br />\n李小龍於美國出書，收鬼佬徒弟教功夫，引起唐人街華人武術界不滿。李小龍因此得罪了中華總會會長萬宗華。葉問與萬會長相識之初，因為對於中華傳統武術意見不合，隨即展開了一場詠春對戰太極的戲碼，萬會長發現葉問受傷了，直接收起一隻手跟對方打。<br />\n<br />\n葉問拿不到萬會長的推薦信，無法讓兒子葉正入學。人在異鄉的葉問很想聽到兒子的聲音，可是每次的長途電話都被兒子拒絕接聽，父子關係惡劣。<br />\n<br />\n這時，李小龍的美軍徒弟吳建豪，想將詠春引入美國部隊，受空手道教官打壓，派人去唐人街踢館，被葉問狠狠教訓，挑起了美國海軍陸戰隊跟唐人街的仇恨。<br />\n<br />\n美國軍官趁著中秋晚會把會長綁走，並且打趴了所有會中的武師，找移民局拉人。這時葉問出馬，打趴了挑釁的美國人，美國人又把會長綁入海軍陸戰隊，並且打到重傷。葉問看不下去，認為中國人不能再被欺侮，於是叫吳建豪把他帶入海軍陸戰隊，美國人跟葉問一番激戰之後，再度打趴美國人。<br />\n<br />\n葉問解救了中華總會的貌美女兒若男，但還是無法讓萬宗華會長點頭寫推薦信。<br />\n<br />\n於是，葉問放棄了兒子的留學計劃，決定回香港並與兒子和好，教授兒子葉正畢生絕學，還叫他兒子用機器拍攝。最後，葉問在79歲因癌症去世，畫面切換至徒弟李小龍祭拜，然後開始播放前幾集畫面，包括洪金寶、黃曉明、熊黛林等場景。全劇完。<br />\n<br />\n#不是劇透<br />\n#不要share<br />\n#share了觀眾便不會購票"},{"pid":"565be66b8ed2a2b8952853a1b68a8e8d7dc338e2","tid":1792210,"uid":268516,"like":0,"dislike":0,"score":0,"quote":{"pid":"809713ec65607d25f82fba5ef0f45910011e81be","tid":1792210,"uid":188282,"like":2,"dislike":1,"score":1,"citedBy":2,"replyTime":"2019-12-21T12:56:44.000Z","msg":"會唔會變另類傳宣?<br />\n始終呢類戲知晒劇情都冇影響"},"citedBy":0,"replyTime":"2019-12-22T01:51:53.000Z","msg":"所以劇透同時要解釋點解罷睇"},{"pid":"3a598f1906ea95d4dfca7002fa2fee6d95f8cc8f","tid":1792210,"uid":1886,"like":0,"dislike":0,"score":0,"quote":{"pid":"53881fc02b82fcc5ecf26b7e9d53f1143ffc47d4","tid":1792210,"uid":41818,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2019-12-22T01:02:38.000Z","msg":"網上做好了 現場劇透係好仆街&hellip;<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-22T03:11:55.000Z","msg":"<strong><span style=\"font-size: small;\"><span style=\"color: violet;\">人生可否重來 &bull; 會員編號: #41818 &bull; 註冊日期: 2016/11/29</span></span></strong><br />\n<br />\n<span style=\"color: gold;\">以下係有關你喺 2019 年 11 月 11 日嘅可疑留言</span><img src=\"/assets/face