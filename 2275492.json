na.cx/i/5yPK0z5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F5yPK0z5.jpg&h=4eebbaa0&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-11-07T10:57:06.000Z","msg":"2015年<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-07T11:00:04.000Z","msg":"英國《泰晤士高等教育》（Times Higher Education,THE）發表新一輪全球大學聲譽排名，首10位的排名大致維持不變，美國哈佛大學更連續10年排榜首。而本港今年共有4間大學打入頭200位，但排名均較往年下跌，且只有港大及科大排在首100位內，<span class=\"red\"><strong>中大跌出百大排名</strong></span>，而當中排名最高的港大，亦較去年下跌最少7位。<br />\n<br />\n<img src=\"https://resource01-proxy.ulifestyle.com.hk/res/v3/image/content/2790000/2794669/010_01_a_20201105_L.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fresource01-proxy.ulifestyle.com.hk%2Fres%2Fv3%2Fimage%2Fcontent%2F2790000%2F2794669%2F010_01_a_20201105_L.jpg&h=7f5fa727&s={SIZE}\" />"},{"pid":"5ac282195e0253585a965c775003a0beec215a1e","tid":2275492,"uid":29836,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-11-07T11:00:13.000Z","msg":"蝌大小粉紅<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"63116858794014f312c556b50e5d375a46482b05","tid":2275492,"uid":225931,"like":5,"dislike":1,"score":4,"quote":{"pid":"5ac282195e0253585a965c775003a0beec215a1e","tid":2275492,"uid":29836,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-11-07T11:00:13.000Z","msg":"蝌大小粉紅<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-07T11:04:03.000Z","msg":"中大engine狗冇point就人身攻擊<img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://blog.adioma.com/wp-content/uploads/2019/12/how-to-argue-PG-hierarhy-of-disagrement-infographic.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fblog.adioma.com%2Fwp-content%2Fuploads%2F2019%2F12%2Fhow-to-argue-PG-hierarhy-of-disagrement-infographic.png&h=351ae35b&s={SIZE}\" />"},{"pid":"bbe5d288b5426215b1e2e27789b4b14a58405bbf","tid":2275492,"uid":88374,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-07T12:35:08.000Z","msg":"食花生<br />\n<br />\n利申 kongu"},{"pid":"4ed99ef5aec66de6cfe04b67d7dbaefe5d1f7c21","tid":2275492,"uid":370010,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-11-07T13:35:08.000Z","msg":"此回覆已被刪除"},{"pid":"5cf10689f50dcd29cc6c757d05481241cd62fbda","tid":2275492,"uid":225931,"like":0,"dislike":0,"score":0,"quote":{"pid":"4ed99ef5aec66de6cfe04b67d7dbaefe5d1f7c21","tid":2275492,"uid":370010,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff6aab15080fdec4bd1b8bcc9173326b57d761f5","tid":2275492,"uid":29836,"like":1,"dislike":0,"score":1,"quote":{"pid":"6d0f2b5835d8e2c7e4a41ffd92c345fad1e14c6a","tid":2275492,"uid":225931,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2020-11-07T10:51:33.000Z","msg":"提醒你 科大排名&gt;&gt;cuhk"},"citedBy":2,"replyTime":"2020-11-07T10:52:49.000Z","msg":"qs排名冇撚用<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /><br />\n有錢就可以洗排名<br />\n你睇睇city"},"citedBy":2,"replyTime":"2020-11-07T13:35:08.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2020-11-07T13:50:01.000Z","msg":"夢幻----------&gt;超夢<br />\n..........QS............."},{"pid":"384f91c6eaa7abadfe575545c445cbd7066112f7","tid":2275492,"uid":370010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-07T13:50:26.000Z","msg":"此回覆已被刪除"},{"pid":"410f123a1a7214a119db13b1b3971f8560f63445","tid":2275492,"uid":371815,"like":0,"dislike":0,"score":0,"quote":{"pid":"4ed99ef5aec66de6cfe04b67d7dbaefe5d1f7c21","tid":2275492,"uid":370010,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff6aab15080fdec4bd1b8bcc9173326b57d761f5","tid":2275492,"uid":29836,"like":1,"dislike":0,"score":1,"quote":{"pid":"6d0f2b5835d8e2c7e4a41ffd92c345fad1e14c6a","tid":2275492,"uid":225931,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2020-11-07T10:51:33.000Z","msg":"提醒你 科大排名&gt;&gt;cuhk"},"citedBy":2,"replyTime":"2020-11-07T10:52:49.000Z","msg":"qs排名冇撚用<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /><br />\n有錢就可以洗排名<br />\n你睇睇city"},"citedBy":2,"replyTime":"2020-11-07T13:35:08.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-11-07T13:54:33.000Z","msg":"THE全球大學聲譽排名　港大跌出首50名　清華大學亞洲第2<br />\n<br />\n英國《泰晤士高等教育》THE公布2020年全球大學聲譽排名榜（World Reputation Rankings 2020），香港共有四所院校入圍全球首200間「聲譽」大學，包括香港大學、科技大學、中文大學及理工大學；惟除了新上榜的理大，餘下三校的排名均有所下跌。<br />\n本港排名最高的港大，未能入圍全球50強之內，落後於排名第10的日本東京大學、排名第13的清華大學、排第16的北京大學、以及排名40的國立臺灣大學。港大新聘的候任副校長申作軍及宮鵬，正正是清華大學學者。<br />\n<br />\n港四間大學上榜　理大「新登科」<br />\n<br />\n2020年的《泰晤士高等教育全球聲譽排名》由以往的100所，增至200所，被列入排名榜的大學來自的國家或地方，亦由去年的19個，增至30個。<br />\n<br />\n本港是次共有四所大學位列排名榜之內。包括排名51至60的香港大學、排名91至100的科技大學、排名101至125的中文大學，以及排名126至150的理工大學。除了新上榜的理大，其餘三間院校排名皆較2019年下跌<br />\n<br />\n東京大學成首十位唯一亞洲院校<br />\n<br />\n全球十強之中，首三排位不變，依次是哈佛大學、麻省理工學院及史丹佛大學；英國的劍橋大學和牛津大學則位居第四及第五位；餘下第六到第九名，分別為加州大學柏克萊分校、普林斯頓大學、耶魯大學，以及加州大學洛杉磯分校；日本的東京大學成功晉身十強之內，比去年升一位。<br />\n<br />\n是次排名若以國家劃分，美國仍然是「大贏家」，200所大學中，有三成院校都來自美國，當中哈佛大學連續10年位居榜首；而英國則屬「第二大國」，有25間大學入圍，劍橋大學排名第四。<br />\n<br />\n清華及北大列全球首20位<br />\n<br />\n至於亞洲區大學排名方面，日本東京大學排名最高，其次為中國的清華大學（全球排名13）及北京大學（全球排名16）。亞洲第四至第七依序為京都大學（全球排名23）、新加坡國立大學（全球排名24）、國立臺灣大學（全球排名40）及首爾大學（全球排名45）。<br />\n<br />\n至於上海的復旦大學、香港大學、新加坡的南洋理工大學，以及上海交通大學，則同時位列在全球51至60。 <br />\n<br />\n來源來自支共01，我就唔貼了，大家無謂鬥香港嘅大學無論是港中科也好，都已面臨跌出世界50大名校的命運"}]}