img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"c93eb5f7d72169b8bfe65b768b05061309e9633b","tid":1250121,"uid":252854,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-22T05:12:03.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />多謝伯伯"},{"pid":"22897ebe372d050226504be27247129d3b931d18","tid":1250121,"uid":219244,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-22T05:15:04.000Z","msg":"真心感動<br />\n睇到眼濕濕<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"5682e8835a2af10bf23f5eafcb1ed328d29b1aec","tid":1250121,"uid":19725,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-22T05:19:42.000Z","msg":"82歲仲行得走得，係福氣！希望企係人面角度既人都有咁既身體繼續支持<br />\n<br />\n政府走狗，人民公敵，60歲就唔靠周身都係病"}]}