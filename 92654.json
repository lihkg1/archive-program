rown.gif\" class=\"hkgmoji\" />"},{"pid":"042f34a3f2205a236a5391212715e033b240323b","tid":92654,"uid":3671,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T13:13:45.000Z","msg":"回憶的刺 想念痛多一次 只求不相見<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5aa80ee77bdad544d799889bc6526397f4634c63","tid":92654,"uid":2241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T15:46:53.000Z","msg":"我只能永遠讀著對白 讀著我給你的傷害 <br />\n我原諒不了我 就請你當作我已不在 <br />\n<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"220c0cb4accbe1dd6720304edbdb6ad94b4b80e4","tid":92654,"uid":11644,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T16:00:12.000Z","msg":"如果，可以把秒針轉往後退<br />\n那段，快樂時光可以重聚"},{"pid":"b980cbb29a0238945f97e62806d407c94d7ea674","tid":92654,"uid":54076,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T16:03:59.000Z","msg":"次就算在這刻很孤單<br />\n往日那些的燦爛<br />\n有天轉身從頭盛放或會可以"},{"pid":"0feffd54bcc5b4521d1a1177d2626118efe161cf","tid":92654,"uid":30895,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T16:18:02.000Z","msg":"唔屌到你 以為自己好撚型 屌那星!"},{"pid":"e29a2f84e4046ef9483bae620bdb0e36a6cbac02","tid":92654,"uid":78795,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T17:41:16.000Z","msg":"沒有後來　我們才學會愛<br />\n但現在　說來感慨　不是那個未來"},{"pid":"e4b26ad7fa76f44f4a57ac1881d4324ba21e469b","tid":92654,"uid":25086,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T18:33:41.000Z","msg":"有一個人曾讓我知道<br />\n寄生於世上原是那麼好<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"41ce50a1cf7330b4bc98c3a5962012976fabf4ff","tid":92654,"uid":79496,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T18:41:33.000Z","msg":"沒有心 別再拖 好心一早放開我"},{"pid":"1955394e5fe81a21ea423f6eaaf645378b765588","tid":92654,"uid":14217,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T19:30:22.000Z","msg":"I couldn't live without you<br />\nGoodbye my lover"},{"pid":"d41795124896ecfa1a1a95114c235449c2dea71d","tid":92654,"uid":75010,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T19:33:17.000Z","msg":"但一不小心 總記起你"},{"pid":"f9a449e94099833888fb4d6990b68d95d466711f","tid":92654,"uid":10255,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T19:44:01.000Z","msg":"<blockquote><blockquote>你千萬不要在我婚禮的現場<br />\n我聽完你愛的歌 就上了車<br />\n<br />\n明明同現任仲算好地地<br />\n尋晚訓覺發夢見到佢 竟然仲係毫不猶豫咁拖起佢<br />\n我係咪以後都要活係佢陰影之下<br />\n我幾時先可以完全放低佢<br />\n雖然好憎佢咁無情咁放棄我<br />\n但我仲係好希望佢開心幸福 如果我唔岩佢 都想佢搵到個錫佢既人<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> 我真係好賤</blockquote><br />\n<br />\n有一天晚上 夢一場<br />\n你白髮蒼蒼 說帶我流浪<br />\n我還是未猶豫 就隨你去天堂 <img src=\"/assets/faces/fs/lomore_smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n不管能怎樣 我能陪你到天亮"},{"pid":"6f0d63704343da6819ab29f6453b369d765db516","tid":92654,"uid":77479,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T19:48:01.000Z","msg":"曾撞板 先知我因爲愛 曾經多失控<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"6d0e55b9f664a47b7423f533c8809c79b8774f4a","tid":92654,"uid":78054,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-25T19:48:16.000Z","msg":"旁人從不贊同 連情理也不容<br />\n<br />\n分左手差唔多三年<br />\n仲係好掛住佢"},{"pid":"a4b417973f771730095fedbfdfd9019e8f37d156","tid":92654,"uid":14217,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-26T14:12:56.000Z","msg":"If time is all I have<br />\nI'll waste it all on you"},{"pid":"f863f3a5ee70ce0bf6ee4c08af1179749f55ce73","tid":92654,"uid":68047,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T12:10:42.000Z","msg":"<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"0ad41032c21783dc8566eaab1e3628665f03b088","tid":92654,"uid":46935,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T12:17:31.000Z","msg":"We don't talk anymore, we don't love anymore like we used to do <img src=\"/assets/faces/lomoji/22.png\" class=\"hkgmoji\" />"},{"pid":"67266f7a064b8a95bda7f7b37c5771fe41f57a5c","tid":92654,"uid":79497,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T13:02:42.000Z","msg":"你一句簡單的問好 我掀起反覆的煩惱<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"0ea4a9e4938a2d603a894203083cb4672e25246b","tid":92654,"uid":48310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T15:27:26.000Z","msg":"你可以為我們的散 不用承擔<br />\n是我投入到一半有點不半"},{"pid":"950f2bf7586f0a3d1fba085adef4e14348dba2d2","tid":92654,"uid":74253,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T15:30:43.000Z","msg":"全是我的錯 現在認錯有沒有用<br />\n你說你已經不再愛我<br />\n我帶你回憶曾經快樂的時空<br />\n你只是勸我別再執著"},{"pid":"a3699054464920803426d450e9399a79aee81b49","tid":92654,"uid":74253,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T15:33:13.000Z","msg":"我不要你怎樣 沒怎樣<br />\n我陪你走的路你不能忘<br />\n因為那是我 最快樂的時光"},{"pid":"dbb2087bd0a9fc44cf6af169a78e7b4bff79bced","tid":92654,"uid":64487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T15:34:01.000Z","msg":"我們的愛情到這剛剛好<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"/assets/faces/big/angel.gif\" class=\"hkgmoji\" />"},{"pid":"0c9f29d05f40395bf47b3f486934c4a91695a943","tid":92654,"uid":74253,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T15:37:00.000Z","msg":"<blockquote>我們的愛情到這剛剛好<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<img src=\"/assets/faces/big/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n再不爭也不吵 不必再煎熬<br />\n你可以不用記得我的好<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"5d76401775433ddf17b8a6d11110950bf31a5961","tid":92654,"uid":47639,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T15:38:45.000Z","msg":"I pray your birthday comes and nobody calls<br />\n<br />\nI pray you're flyin' high when your engine stops<br />\n<br />\nI pray all your dreams never come true"},{"pid":"8ded41cd78d9875ee7e6d88d847c584d9f353cc4","tid":92654,"uid":25857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T15:39:17.000Z","msg":"曾跟你約定下個淡季 浪漫旅遊"},{"pid":"f7d5961279dad6f2953da02b74bd4dda45328ba0","tid":92654,"uid":60561,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T16:09:34.000Z","msg":"曾如何情重 曾是真摯與自信&nbsp;<br />\n卻叫我掉進 這半空中&nbsp;<br />\n<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"6cef7c301679670ad063e7f29b32df95fe151d63","tid":92654,"uid":54293,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T16:34:01.000Z","msg":"誰還記得是誰先説 永遠的愛我<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"b8e001451b1cb0246a4fd5b85bbdfcf1df17324f","tid":92654,"uid":80269,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T17:03:41.000Z","msg":"我想祝福她 永遠都吸引 然後聽不到你傳聞"},{"pid":"07367930e88133c8c896ae6f8b0eaed62d0b0ab4","tid":92654,"uid":77774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T17:38:03.000Z","msg":"浮華千萬相 相愛或創傷"},{"pid":"37d09878c37b6f460c688e198e8c687bf24074ab","tid":92654,"uid":39852,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T18:13:03.000Z","msg":"我只能永遠讀著對白    讀著我給你的傷害<br />\n我原諒不了我    就請你當作我已不在"},{"pid":"a06cf2f293ec2c564e61bebb614afb960a745124","tid":92654,"uid":10504,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T18:16:47.000Z","msg":"記得你最愛冬天 <br />\n他都愛上吧<br />\n與他過最暖的寒假<br />\n熱戀的你們<br />\n幸福得太像童話<br />\n<br />\n執房既時候 睇返你寫比我既卡 <br />\n令我諗返起我同你之間既回憶 <br />\n我諗 我依一世 都唔會再遇到 <br />\n對我咁好既另一半<br />\n當年我唔識珍惜你 亦比唔到 你應該擁有既野 <br />\n但 你現任比到你 <br />\n雖然我依家有能力比到你 但已經太遲<br />\n唔敢再打擾你 無面目再同你有聯繫 <br />\n唯有暗地裏 祝你日後幸福快樂 <br />\n多謝你 曾經對我既付出"},{"pid":"0024194aa6f6121543bcf110530b0e339164f67b","tid":92654,"uid":63920,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T18:17:38.000Z","msg":"誰需要日後被誰想起 誰貪你想起我的好處"},{"pid":"b773bc9279dcde3cd7465c5b6e357a45d95a915d","tid":92654,"uid":15289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T18:21:31.000Z","msg":"從你的世界路過 把全盛的我都活過<br />\n多謝你教曉左我咩係愛<br />\n希望你以後都唔會再遇到我哩d負心漢"},{"pid":"a0e02842244311997d575471a66a80c9b74633f2","tid":92654,"uid":58687,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T18:22:57.000Z","msg":"離開了你都可以代你歡笑代你哭<br />\n<br />\n就算别離後我亦會痛"},{"pid":"18666e1d2993f5ff79ec07f23a30dc6078aec712","tid":92654,"uid":71888,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T18:27:29.000Z","msg":"曾給你馴服到就像綿羊何解會反咬你一下你知嗎<br />\n<span style=\"font-size: x-small;\">屌你老母</span>"},{"pid":"ba458acf8f1026bf217edd03c8718b69df6e2590","tid":92654,"uid":71225,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T18:44:59.000Z","msg":"愛一個人 別太認真<br />\n你受傷的眼神 令人心疼<br />\n沒有一個人 非要另一個人<br />\n才能過一生<br />\n你又何苦逼自己 面對傷痕<br />\n<br />\n我知道你很難過<br />\n感情的付出 不是真心就會有結果<br />\n別問怎麼做 愛才能長久<br />\n這道理有一天你會懂<br />\n我知道你很難過<br />\n昨天是戀人 今天說分手就分手<br />\n別問你的痛 要怎麼解脫<br />\n多情的人注定 傷得比較久"},{"pid":"385f02054a27b94a6ab8bfe80c91e4fe4d9ec4c5","tid":92654,"uid":68047,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-29T01:05:56.000Z","msg":"<blockquote>離開了你都可以代你歡笑代你哭<br />\n<br />\n就算别離後我亦會痛</blockquote><br />\n<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"31e91f33b6081134422125ba6dd75485fa6df1ad","tid":92654,"uid":79497,"like":0,"dislike":0,"score":0,"citedBy":0,"repl