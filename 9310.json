s/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5242e43aee5bc4b8b2c737d850e484581d3f86cc","tid":9310,"uid":7439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-11-29T15:18:42.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>做咩又改名<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n雖然我都係<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n諗唔到自己叫咩名好<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n羊格<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n又有啲想寫返文青 巴打你覺得我上唔上返水先</blockquote><br />\n<br />\n唔爛尾咪上（你好似已經開咗po<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />  )<br />\n你啲爛尾故多到我唔記得<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> <br />\n有一個好似係大學生墮樓事件？一個離家出走？<br />\n<br />\nBtw閱"},{"pid":"f2fd9550264689d87c6a6195820221a414d9ce7a","tid":9310,"uid":11842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-11-29T18:30:32.000Z","msg":"羊格<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" /> <br />\n你終於出返黎 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> 望穿秋水<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n冇壓力 慢慢完成個故<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"b25ad80f4845fc468e8b4c1d5d1add29fe22cc7e","tid":9310,"uid":2756,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-11-29T19:03:33.000Z","msg":"格仔<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"bd70db61a43d120f9de436d59a6b1f1e7cbce35b","tid":9310,"uid":22360,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-11-29T19:14:42.000Z","msg":"Lm"},{"pid":"12cf0f68af619ff7010af0b7d5838b9263807f19","tid":9310,"uid":35301,"like":0,"dislike":0,"score":0,"citedBy":0