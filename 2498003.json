normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-21T01:33:25.000Z","msg":"係咪合拍睇投資商<br />\n以前大把台灣支那演員喺香港拍<br />\n李連杰都係香港發跡，唔通佢啲黃飛鴻方世玉又係合拍"},"citedBy":0,"replyTime":"2021-04-21T01:40:03.000Z","msg":"好似周冠威咁講，不接受中共（全球性）審查，就係本土電影。<br />\n<br />\n一秒拳王跟星馬片商合拍，但星馬政府唔會審查控制全球上映版本。<br />\n中共會嚴格審查控制中國合拍片既全球上映版本。<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"2cdcdedef1aea7268f637c63e96036487f85d3f3","tid":2498003,"uid":134071,"like":0,"dislike":0,"score":0,"quote":{"pid":"36516af24a676225034c0809091eb75ac7bcb4e1","tid":2498003,"uid":2730,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-04-21T01:38:56.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />好好睇真係"},"citedBy":0,"replyTime":"2021-04-21T01:42:23.000Z","msg":"多謝大家支持<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"b13f2f884420b3a85ba209624d48748a1f5ecdad","tid":2498003,"uid":134071,"like":0,"dislike":0,"score":0,"quote":{"pid":"b5e5a0468f03fcb82186dba92028efec380486a1","tid":2498003,"uid":279333,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-04-21T01:36:35.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-21T01:48:23.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"2d2da842abeadec8d2d54851f0a13f97548d9c02","tid":2498003,"uid":167956,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-04-21T01:50:55.000Z","msg":"真心唔想不停睇極都係黑警匪片........"},{"pid":"c4b8493fc7a3894bf4c