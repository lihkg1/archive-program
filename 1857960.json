assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"51b6c7cad6058c441f007c7f0064d1e4b82cffc2","tid":1857960,"uid":66866,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T16:55:39.000Z","msg":"加油<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"cc6978d4683eb385b0264c61af94b681b7e58f38","tid":1857960,"uid":281170,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T17:27:52.000Z","msg":"姦巴爹<img src=\"/assets/faces/lny/slick.gif\" class=\"hkgmoji\" />"},{"pid":"25aa40634eddee7fc33b12fb7d219fc6d4a36161","tid":1857960,"uid":315534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T19:38:04.000Z","msg":"加油吖樓主<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"d8b50f1f5e461cd410e0d50f0bbebcf4174ea03e","tid":1857960,"uid":122513,"like":0,"dislike":0,"score":0,"quote":{"pid":"45aff25f8b4d7a99c01c5a9d88f8730c954ccd44","tid":1857960,"uid":342563,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-02-02T12:12:35.000Z","msg":"可唔可以？<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-03T05:27:30.000Z","msg":"你好，這是《自殺．自療．互助舍》。看來你已累積了不少負面情緒，是嗎？人就好像氣球一樣，若積存的鬱結和壓力太多，便會有爆發的一天。何不暫時停一停，到我們的網站 <a href=\"http://www.help4suicide.com.hk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.help4suicide.com.hk&d=m5PK5j%2F1EvBSK5XTwnZL9H4HMPoqNxaa4E9h32y1mRE%3D&h=a3305be8\" data-auto-link target=\"_blank\">www.help4suicide.com.hk</a>。 那裡有一些勵志故事和有趣短片，你可以隨心看看。你也可以進入網站內的『Chat窿』（星期一至五：上午六時至凌晨一時；星期六、日及公眾假期：下午８時至凌晨１時），讓我們的義工為你加油打氣！<br />\n<br />\n我們願意聆聽你的心聲，伴你一起走過這段艱難的時候！只因『晴天雨天要樂天，難關難過總會過』！<br />\n<br />\n《自殺．自療．互助舍》"},{"pid":"bfbcc49abd5ec2bfc2d0a470c95600ace1d06eea","tid":1857960,"uid":142017,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-03T05:32:36.000Z","msg":"加油<img src=\"/assets/faces/lny/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/agree2.gif\" class=\"hkgmoji\" /><br />\n船到橋頭自然直<img src=\"/assets/faces/lny/biggrin.gif\" class=\"hkgmoji\" /><br />\n頂住呀清！<br />\n休息是為了走更長的路<img src=\"/assets/faces/lny/slick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/slick.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/slick.gif\" class=\"hkgmoji\" />"},{"pid":"40325f9511d3063080f87c9b0278f5dfad03b70e","tid":1857960,"uid":342563,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-02-03T05:39:46.000Z","msg":"無言感激！<br />\n雖然好難逐一回覆，但你地嘅每個回覆我都有睇，都好感激！<br />\n難得大家為我集氣，我會繼續勇敢咁，同手足們、同香港人一齊行落去。<br />\n我應承大家，往後我遇到咩挫敗，唔開心，就會拎返呢個post出來睇，鼓勵自己，絕不輕言放棄！<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"be6806377e1908fdfd7f5d0acff54477a3cec002","tid":1857960,"uid":16032,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-03T05:43:34.000Z","msg":"一齊加油<img src=\"/assets/faces/cat/sneeze.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/sneeze.gif\" class=\"hkgmoji\" />"},{"pid":"c3338c8fa76e89fa349c771eae8a41b3d38ddadd","tid":1857960,"uid":209087,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-03T20:16:03.000Z","msg":"加油"},{"pid":"1a962be7768b2574da04081141af9ca0763fed0b","tid":1857960,"uid":309206,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-03T20:19:46.000Z","msg":"加油<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /> 唔好既事會成為過去 更好既明天一定會來臨！"},{"pid":"c4787af1bd5f8cb7f49eb116600afbcba11b267c","tid":1857960,"uid":71085,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-03T20:23:48.000Z","msg":"手足我愛你<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />加油<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />加加油<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"4eb3feed369d62a8f36d4833d897234ecbf915ec","tid":1857960,"uid":326777,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-04T00:22:41.000Z","msg":"加油 堅持落去 好多人同你一齊奮鬥緊 <img src=\"/assets/faces/pig/sowhat.gif\" class=\"