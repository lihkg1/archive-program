c=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"51af9d35bc56d9741d8985b5afe661cf2841126d","tid":2357641,"uid":128763,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T15:02:19.000Z","msg":"此回覆已被刪除"},{"pid":"6d5627d794ad253301f93a9b0e9e5f5132a6647a","tid":2357641,"uid":43062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T15:02:42.000Z","msg":"戰狼<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ea8aa65b12f7d76fbe5a324ecc1d42ca6c655380","tid":2357641,"uid":283080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T15:04:08.000Z","msg":"口氣果然大左<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"184de291e2d2d2c880b18a579e5810327678060b","tid":2357641,"uid":243677,"like":3,"dislike":0,"score":3,"quote":{"pid":"3cd1ec211c9a8ef5a1f47b73111885ef62c5efa4","tid":2357641,"uid":124382,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2021-01-07T14:33:42.000Z","msg":"其實呢單嘢個 timing 都幾耐人尋味。舊年7月嘅事，唔等都等咗咁耐啦，仲有兩個星期多啲美國就轉話事人，China Joe 上台，咁都等唔到？係要俾機會人哋出手？<br />\n<br />\n睇 Pompeo 篇聲明，三幾日內必定會做嘢。"},"citedBy":1,"replyTime":"2021-01-07T15:05:48.000Z","msg":"因為佢知奶共拜登一上場 就會撒回 驚hi咩<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7fb30ad5155e22a3a31f7a366798636e03b25f12","tid":2357641,"uid":123738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T15:08:25.000Z","msg":"支那不嬲都未驚過，最多咪搵柒婆呢班支那狗出嚟祭旗，唔通制裁維尼咩<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"2fd94623683cd94e0316cfe43a5f66ee767110b0","tid":2357641,"uid":8307,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T15:10:52.000Z","msg":"<img src=\"https://img.komicolle.org/2020-10/16020072670293.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.komicolle.org%2F2020-10%2F16020072670293.jpg&h=fbce90f2&