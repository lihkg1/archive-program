/DiUN74w.jpg\" />"},{"pid":"5cba768e968a83f9d11c45eeb69abfe21a010cb9","tid":1701883,"uid":60259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T11:30:12.000Z","msg":"推推推 <br />\n11 10 開花<br />\n11 11 三罷<br />\n<br />\n<br />\n利申 每次都罷！"},{"pid":"bb0e596fde6cdeb670552cfa64ca835d3e6d0fbf","tid":1701883,"uid":60259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T11:30:42.000Z","msg":"推呀<br />\n<br />\n<br />\n推推推 <br />\n11 10 開花<br />\n11 11 三罷"},{"pid":"750e9a489eb25c4a6bd463e2916418594ceac4df","tid":1701883,"uid":37729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T11:32:15.000Z","msg":"聽朝和平紀念日 去既記得著得靚仔啲"},{"pid":"c072a3bcaeaae9d95aec0245148be31991c3523d","tid":1701883,"uid":60259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T11:32:21.000Z","msg":"推呀屌"},{"pid":"49420c2ec8da59b82402308990634099573b7f24","tid":1701883,"uid":214192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T11:32:48.000Z","msg":"聽朝和平紀念碑有event<br />\n<br />\nFrom 香港人日程表：<br />\n每年11月11日，是英聯邦國家「國殤紀念日」，以悼念一二戰和其他戰爭中犧牲的軍民。今年的國殤，在香港人心中或會有更深層的意義。<br />\n<br />\n本組現誠邀各公務員同事及市民出席本年席之「國殤紀念日」儀式，詳情如下：<br />\n<br />\n日期：2019年11月10日（星期日）<br />\n時間：早上10時45分（建議提早到場）<br />\n地點：中環遮打道和平紀念碑前<br />\n主辦方：香港退伍軍人協會<br />\n詳情：儀式完畢後會場將允許公眾獻花，本組將以「公務員團體」名義獻上花圈；各同事或市民亦可自行帶同鮮花到場<br />\n<br />\n屆時請各位保持禮貌，切勿在場叫囂或高舉任何旗幟，以最合適的方式悼念陣亡軍民"},{"pid":"a3e942b8f5830b29123919eda891ac891b733d94","tid":1701883,"uid":168267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T11:32:56.000Z","msg":"聽日仲係和平紀念日正日啊，開個post又冇日程又冇文宣咁推番啲行動post好過啦<br />\n<br />\n和平紀念日悼念儀式<br />\n十一月十日<br />\n朝早十點四十五分<br />\n中環和平紀念碑<br />\n<br />\n香港英烈我哋對你哋唔住！<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1679958\" data-auto-link target=\"_blank\">https://lih.kg/1679958</a>"},{"pid":"877a4303aa1b06c6ef934304cc0662e647b5a74d","tid":1701883,"uid":180124,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T11:39:37.000Z","msg":"每日都開花先係上策"}]