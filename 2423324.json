/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bec9c00613669d46e2e2b4343c0574d4bff990da","tid":2423324,"uid":354704,"like":1,"dislike":0,"score":1,"quote":{"pid":"556d82d843598bdca7b71ac6da15f42b398986fb","tid":2423324,"uid":385898,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-02-26T00:31:13.000Z","msg":"請教巴打，日常生活或者閒聊，你地覺得一個女仔做乜行為，講乜話題之類，先會令你定義佢係有內涵，有思想？會令你想深入了解佢更多？<br />\n<br />\n好多男人唔中意講私事，又唔中意講得深入，只講不著邊際閑話，最中意問人做緊乜，平時鍾意做乜睇乜，講吃喝玩樂，咁點樣有深層次交流？"},"citedBy":0,"replyTime":"2021-02-26T02:23:25.000Z","msg":"絲打話你知<br />\n講下你職業上專業知識<br />\n如果平日健身，睇展覽，品酒...咪表達下<br />\n我bf會同我講西史添<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"a85371d024c941c0da285139c73cf0774756de7b","tid":2423324,"uid":391123,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-26T03:01:44.000Z","msg":"有禮貌 做野有自信 啫係見字飲水腰板挺直<br />\n身體語言算係有好教養<br />\n但係唔好講咁多自己野 聽人講野講返人地自己<br />\n學識要廣 唔洗好精 但一定唔可以學星座心靈雞湯 太追求流行文化 想少啲距離感可以玩啲無咁hit 嘅meme"},{"pid":"0c04111fd1222b56b688f8657f8ac8b7970133b0","tid":2423324,"uid":72750,"like":0,"dislike":0,"score":0,"quote":{"pid":"2177856a18372410f59a14c4063afe294a6deaf9","tid":2423324,"uid":385898,"like":6,"dislike":0,"score":6,"citedBy":4,"replyTime":"2021-02-26T01:04:42.000Z","msg":"始終我唔係男人，而我好奇男人眼中點睇，因為平時大家討論開外貌身材多，少講內在，咪直接請教巴打，並唔係話我要「扮」有內涵有思想。<br />\n<br />\n同埋身邊男性搵親我都係問我做緊乜，平時做乜，講吃喝玩樂，真心覺得好無謂，與其浪費時間傾不著邊際，我不如同自己啱傾的朋友傾⋯原意都係想了解點同依類型人相處。"},"citedBy":0,"replyTime":"2021-02-26T03:10:08.000Z","msg":"其實呢啲埋緊你身既咁做，一係可能驚講野嚇親你先講埋啲不著邊際既野打開話喱子，一係真係冇內涵<br />\n不如你想傾咩既直接開個話題比佢地 咁樣既話仲可以screen 埋啲冇內涵既走你又可以同佢地傾你真正想傾既野<br />\n唔洗埋佢地覺得你如何架<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><br />\n男仔比起我地簡單好多"},{"pid":"1418c32e5e5150c1880b1b0299d7d8b412c69002","tid":2423324,"uid":27793,"like":0,"dislike":0,"score":0,"quote":{"pid":"2177856a18372410f59a14c4063afe294a6deaf9","tid":2423324,"uid":385898,"like":6,"dislike":0,"score":6,"citedBy":4,"replyTime":"2021-02-26T01:04:42.000Z","msg":"始終我唔係男人，而我好奇男人眼中點睇，因為平時大家討論開外貌身材多，少講內在，咪直接請教巴打，並唔係話我要「扮」有內涵有思想。<br />\n<br />\n同埋身邊男性搵親我都係問我做緊乜，平時做乜，講吃喝玩樂，真心覺得好無謂，與其浪費時間傾不著邊際，我不如同自己啱傾的朋友傾⋯原意都係想了解點同依類型人相處。"},"citedBy":0,"replyTime":"2021-02-26T03:21:49.000Z","msg":"首先你自己鍾意咩，你自己走埋去個圈子到玩就得<br />\n例如你鍾意影相/跳舞/音樂，你走去相應圈子，咁自然傾既野都係呢個圈既話題<br />\n<br />\n然後你對於d做緊咩既inbox，你會ignore得好自然順手<br />\n你會唔得閒覆呢d shit talk<br />\n<br />\n大前提你搵自己興趣先"},{"pid":"889170051104deb195c717491a2d36b8145d880f","tid":2423324,"uid":27793,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-02-26T03:25:30.000Z","msg":"好多男人唔中意講私事，又唔中意講得深入<br />\n有2個情況：1佢地真係唔想諗 2佢怕嚇親啱啱識既女仔一開波唔會講呢d<br />\n<br />\n主動講深入野既叫writer，作家，呢個就人人都鍾意既。<br />\n接受者坐定定等付出者(writer)付出，有人會唔鍾意咩？<br />\n<br />\n只講不著邊際閑話<br />\n有2個情況：1佢地真係唔識帶話題 2佢地唔知你鍾意d咩，話題無從入手"},{"pid":"b7d84c7c8cebd5ca065dfba41e78d66b36a9540a","tid":2423324,"uid":385898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T06:05:14.000Z","msg":"多謝每位意見，我亦爬完上面巴打貼的post，知多好多人想法<br />\n<br />\n大家覺得點樣可以擴闊社交圈子？搵到志同道合的人？<br />\n因為我無刻意和無途徑識新朋友，身邊的都是讀書工作時機緣巧合做到朋友就做。<br />\n<br />\n而且因為科目同行業身邊九成女及少同事，發覺女性圈子一圍起就是講是非八卦，聆聽久了我沒興趣討論便選擇疏遠，想找真正志同道合心靈上的朋友⋯"},{"pid":"e1b7cda57580e8972e1b071f34fffecc39230c47","tid":2423324,"uid":369035,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-26T10:00:56.000Z","msg":"點樣入手一個a0巴<img src=\"/assets/faces/mouse/awake.gif\" class=\"hkgmoji\" /><br />\n佢好醒目同識好多野咁<img src=\"/assets/faces/mouse/love.gif\" class=\"hkgmoji\" />"}]}