es/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"797dcc040782b85d35268dc2d48ee9b66894aa86","tid":2266200,"uid":293937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-01T06:29:14.000Z","msg":"鍾意黑面既人"},{"pid":"aa9b5d5e5f0dd8312eb0bc7b071f74123542bcb5","tid":2266200,"uid":111625,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-11-01T06:30:12.000Z","msg":"成班豬西8婆 日日講是非"},{"pid":"4dfc73a20c0eb6c6d97d494f49fc52b0736c644b","tid":2266200,"uid":335003,"like":5,"dislike":0,"score":5,"citedBy":3,"replyTime":"2020-11-01T06:44:45.000Z","msg":"度縮老細<br />\n<br />\n合約朝9晚6返5日，要你無償朝9晚11返7日。<br />\n返工打卡制，收阿工責任制，話知你昨晚要通頂到3點，無補水、無分紅聽朝遲1分鐘罰錢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n你需要OT 一定係你能力問題，無理由補錢俾你。返工時間是公司財產，你唔可以因為能力不足要OT 而影響正常返工時間。<br />\n<br />\n紅日、年假要有特別事解釋到先可以請，批俾你係大恩大德，公司對你好先批。成日話呢行係咁，成日要星期六&amp;紅日返工，係行業生態。而香港一般人都返 1-5 ，所以你係要返 1-5 + 行業生態 嘅星期六&amp;紅日。<br />\n<br />\n份糧成日話高過最低工資咁多已經係良心企業，成日諗方法試9你想減薪。<br />\n<br />\n<br />\n<br />\n<br />\n做咗1個月即遞信，佢仲要好驚訝咁話公司對你咁好做咩走。話佢自己人工(未計花紅)其實都唔係高你好多，不過我知佢花紅出俾自己係佢份&quot;年薪&quot; 嘅幾倍。問公司有出糧俾你點解唔努力放個心落嚟，要驚蝕。<br />\n<br />\n同佢講話招募同簽約時寫明 offer 嘅嘢，同實際上俾嘅嘢&amp;做嘅嘢差天共地喎。佢答你，個個都係咁，果啲都係正常做樣㗎啫，無人會當真<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n 跟住仲想說9你雖然合約無寫但係要貼返3個月錢俾公司。<br />\n<br />\n<br />\n呢個老細個老鼠樣可以記成世"},{"pid":"3b8f78759ffa7a51c5ce4ebde07c1358716e5cd1","tid":2266200,"uid":38376,"like":2,"dislike":0,"score":2,"quote":{"pid":"4dfc73a20c0eb6c6d97d494f49fc52b0736c644b","tid":2266200,"uid":335003,"like":5,"dislike":0,"score":5,"citedBy":3,"replyTime":"2020-11-01T06:44:45.000Z","msg":"度縮老細<br />\n<br />\n合約朝9晚6返5日，要你無償朝9晚11返7日。<br />\n返工打卡制，收阿工責任制，話知你昨晚要通頂到3點，無補水、無分紅聽朝遲1分鐘罰錢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n你需要OT 一定係你能力問題，無理由補錢俾你。返工時間是公司財產，你唔可以因為能力不足要OT 而影響正常返工時間。<br />\n<br />\n紅日、年假要有特別事解釋到先可以請，批俾你係大恩大德，公司對你好先批。成日話呢行係咁，成日要星期六&amp;紅日返工，係行業生態。而香港一般人都返 1-5 ，所以你係要返 1-5 + 行業生態 嘅星期六&amp;紅日。<br />\n<br />\n份糧成日