g\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0JzV1td.jpg&h=5913ac8d&s={SIZE}\" />"},{"pid":"831feda04ad9e5b00ffec44833188ecd6a5e7f9e","tid":2461744,"uid":299865,"like":1,"dislike":0,"score":1,"quote":{"pid":"104b54c278c03fe705fe0617782ccd17deebc37c","tid":2461744,"uid":273006,"like":0,"dislike":0,"score":0,"quote":{"pid":"4d594396cbba9b6d981ea1e870755b02ada58a12","tid":2461744,"uid":241103,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-25T14:45:46.000Z","msg":"土炮方法<br />\n<br />\n見你原本天花個燈窿度有個螺絲位 <br />\n直接用長螺絲將新燈扭上去<br />\n你預只扭一口 因為你新燈得求其開窿 外個口窿for走線<br />\n想穩陣啲就就睇下屋企有啲咩現成嘢 木片膠片之類 當戒指增加同天花嘅受力面積<br />\n咁就應該唔跌<br />\n<br />\n<img src=\"https://na.cx/i/8pSpahd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8pSpahd.jpg&h=4f3daa62&s={SIZE}\" />"},"citedBy":2,"replyTime":"2021-03-25T14:55:57.000Z","msg":"巴打我本來都想咁做<br />\n不過我怕盞燈真係會跌落嚟<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n同埋想問扭螺絲駛唔駛下面綠色一粒粒嘅嘢？<br />\n<img src=\"https://na.cx/i/0JzV1td.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0JzV1td.jpg&h=5913ac8d&s={SIZE}\" />"},"citedBy":0,"replyTime":"2021-03-25T15:12:47.000Z","msg":"<img src=\"https://ipfs.infura.io/ipfs/QmT8siJJFXp7zH4hYZfsN727YezoF4ESVxHH6RqpBNPvci?filename=mN3LEjv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmN3LEjv.jpg&h=4df6e6a4&s={SIZE}\" /><img src=\"https://ipfs.infura.io/ipfs/QmaLfKa4DGsRsq1xaJFhAo1uCDLWAPAFGxZVcpGnVyX19A?filename=xhGxjjv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxhGxjjv.jpg&h=bdd5fac5&s={SIZE}\" /><br />\n你將電線改黃色箭咀出，紅色箭咀兩個窿收戒指同螺絲，用返過路箱一對平頭螺絲，唔洗用膠塞"},{"pid":"17f556e75d73e55a4742b60b9120d83d4a3553c0","tid":2461744,"uid":241103,"like":1,"dislike":0,"score":1,"quote":{"pid":"104b54c278c03fe705fe0617782ccd17deebc37c","tid":2461744,"uid":273006,"like":0,"dislike":0,"score":0,"quote":{"pid":"4d594396cbba9b6d981ea1e87