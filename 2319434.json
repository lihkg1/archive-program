787889059-7430360530944000000-o_orig.jpg&h=b8e24fc8&s={SIZE}\" /><br />\n<img src=\"https://cdn.i-scmp.com/sites/default/files/styles/1200x800/public/d8/images/methode/2019/11/29/4e43349a-1189-11ea-82cd-148dc44829b8_image_hires_114315.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.i-scmp.com%2Fsites%2Fdefault%2Ffiles%2Fstyles%2F1200x800%2Fpublic%2Fd8%2Fimages%2Fmethode%2F2019%2F11%2F29%2F4e43349a-1189-11ea-82cd-148dc44829b8_image_hires_114315.JPG&h=ce09bcd6&s={SIZE}\" />"},{"pid":"b3bdbd60f16ebdfea84df460879bf826b468a2d0","tid":2319434,"uid":35315,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-10T06:37:06.000Z","msg":"禁完係咪照出糧先<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"46948877cb3d2fb83c7650e425f56948d8109c27","tid":2319434,"uid":106476,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-12-10T06:37:20.000Z","msg":"禁足令係喺有封關既情況下先work ga,你禁香港人足，但繼續比過千人免檢疫落黎香港，用屎忽諗都知，就算做到都唔會有效。<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /> 一諗起納咁多年稅係攞黎養垃圾同暴力狗就心痛。"},{"pid":"343a9a4c8fab769eeb978a16b094340a17e1311a","tid":2319434,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"b274c78b8cf164744f74ca1d77ea299ab21b473c","tid":2319434,"uid":45910,"like":117,"dislike":1,"score":116,"citedBy":3,"replyTime":"2020-12-10T06:01:13.000Z","msg":"三萬城管好樂意做人肉戒嚴<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-10T06:37:35.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b74f6c97772387f0e9e56034135a54fff021fe15","tid":2319434,"uid":123606,"like":0,"dislike":0,"score":0,"quote":{"pid":"2efb6dbe98501de79b4d88abb85e40fafa4174d4","tid":2319434,"uid":5195,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-12-10T05:55:36.000Z","msg":"行政會議早前通過引入禁足檢測令，惟昨日有數個屋邨大廈被政府要求強制檢測，都沒有動用「禁足令」。港大感染及傳染病中心總監何栢良今（１０日）接受商台節目《在晴朗的一天出發》電話訪問時表示，覺得政府有意引用「禁足令」，但無法動員或不知如何動員為大廈進行採樣等工作，質疑公務員在家工作影響跨部門動員。<br />\n<br />\n何栢良認為，麗晶花園感染個案有５宗與跳舞群組相關，而檢視個案由發病到確診「全部好慢」，約要５至７日才確診，加上當時無禁足令，即使有強制檢測，亦相信部分人曾上班、食飯、看戲等，令傳播不斷發生，認為是沒有做好快速跟進及強制檢測所衍生的問題。<br />\n<br />\n他續指，現時已有禁足法例，認政府有意引用，「<span class=\"red\">只不過佢個問題就出喺動員唔到，或不知如何動員， 咁就會唔會發生個情況淨係得衛生防護中心同事孤軍作戰，變咗要頂硬上。</span>」<br />\n<br />\n他認為，政府高層要跨部門動員，質疑公務員在家工作或令工作受影響，形容政府早前進行社區大型檢測時，亦有約6000醫護人員報名，認為可以在名單上，當出現爆疫時即時派100人到現場設立採樣亭或入屋為長者採樣，相信「大把醫護人員去做」。<br />\n<br />\n他指，政府亦應有由工程師組成、專責喉管現場調查人員，在懷疑同幢大廈的同一座向出現兩三宗個案時，可立即派人檢查。<br />\n<br />\n<br />\n<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />3萬大軍呢"},"citedBy":0,"replyTime":"2020-12-10T06:37:42.000Z","msg":"香港無工返<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"144e2dd8b123a467495b370eb040d33152e6eba2","tid":2319434,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"65febcf3c728730db7dcfcfed11c0331be3fc1d1","tid":2319434,"uid":300006,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-12-10T06:07:51.000Z","msg":"一兩隻狗去守<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><br />\n人丁單薄，隨時比人溶左<img src=\"/assets/faces/pig/cut.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-10T06:38:05.000Z","msg":"<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" />"},{"pid":"7d67c7836f4cb01257054213b6a8a1ee85f70c98","tid":2319434,"uid":6946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-10T06:38:21.000Z","msg":"出老解<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},{"pid":"6ae269c465f4c8da88403aa1118c885a697b7d43","tid":2319434,"uid":140104,"like":0,"disli