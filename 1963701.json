faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"bbed74f40670356352df0cd263e30c4fd60e1f57","tid":1963701,"uid":61197,"like":14,"dislike":0,"score":14,"citedBy":1,"replyTime":"2020-04-08T10:25:38.000Z","msg":"$2 變$1.6? <br />\n利申:幫我呀婆計數"},{"pid":"3b1731e33e03436c08ba8d3117a2fd9c49b82376","tid":1963701,"uid":208376,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2020-04-08T10:25:58.000Z","msg":"2蚊8折平得0.4蚊。。。。"},{"pid":"391e944893836763dfaf1480be7e61a31e587601","tid":1963701,"uid":157799,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-04-08T10:26:11.000Z","msg":"<blockquote><span style=\"font-size: xx-large;\">2020年4月8日，係梓樂逝世5個月嘅日子<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></span><br />\n今日有好多新聞，又有限聚令，大家可能忘記咗<span style=\"font-size: x-large;\">每月8號</span>就係香港兒女周梓樂逝世嘅日子<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />大家可唔可以幫一幫推<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">這是香港人永久的痛</span></span><br />\n<img src=\"https://na.cx/i/PEc2uPw.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPEc2uPw.png&h=44e78ee5&s={SIZE}\" /><br />\n<br />\n2019年11月4日晚上，科大生周梓樂從將軍澳尚德停車場墮樓，原因至今未明。<br />\n<img src=\"https://na.cx/i/qydMWtg.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqydMWtg.png&h=78033d4c&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/6KOw7JO.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6KOw7JO.png&h=85b332a4&s={SIZE}\" /><br />\n<br />\n梓樂墮樓後，黑警曾阻止救護車駛進，阻止人道救援。<br />\n<img src=\"https://na.cx/i/3CaO9Rv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3CaO9Rv.jpg&h=d674bd89&s={SIZE}\" /><br />\n<br />\n而當晚，係有一位義士挺身而出，單人匹馬阻止黑警繼續發射催淚彈，同埋開路俾救護車駛入，結果被黑警打至頭破血流，並作出拘捕及起訴。<br />\n<img src=\"https://na.cx/i/GttAP24.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FGttAP24.jpg&h=8359b0c4&s={SIZE}\" /><br />\n-<br />\n如果你記得周梓樂，請你都記得佢<br />\n<a href=\"https://lihkg.com/thread/1786327/page/1\" target=\"_blank\">https://lihkg.com/thread/1786327/page/1</a><br />\n-<br />\n2019年11月8日上午8時9分，據消息指，梓樂於伊利沙白醫院中，因心臟停頓而被宣告死亡。<br />\n<img src=\"https://na.cx/i/wR5fPST.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwR5fPST.png&h=d91b3cd1&s={SIZE}\" /><br />\n<br />\n而點解梓樂當晚會出現喺尚德停車場，好大可能係因為當晚有黑警結婚。當晚佢地為咗結婚擺酒，call哂成班綠衫狗過去、tg放題。<br />\n<img src=\"https://na.cx/i/F3oX3dB.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FF3oX3dB.jpg&h=273e6a65&s={SIZE}\" /><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">徐岸暘 麥鈺熒</span></span><br />\n-<br />\n過去4個月之中，每個月嘅8號，都會有網民自發嘅悼念活動。而簡簡單單一個悼念儀式，政府、黑警竟然大費周章打壓，「梓樂之死並無可疑」的確相當有可疑。<br />\n<img src=\"https://na.cx/i/a0VO9WV.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fa0VO9WV.png&h=b9e2527f&s={SIZE}\" /><img src=\"https://na.cx/i/dcSt9WW.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FdcSt9WW.png&h=d643dc7b&s={SIZE}\" /><img src=\"https://na.cx/i/bzegzoC.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbzegzoC.png&h=c986eb69&s={SIZE}\" /><br />\n-<br />\n<span style=\"font-size: large;\">梓樂嘅死，我地必需時刻牢記，這是香港人與政權、黑警，不共戴天之仇。</span><br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">仲有好多無名烈士，不明不白地死去了，就讓我們在這天一同紀念。</span></span><br />\n<img src=\"https://na.cx/i/PZVjxhK.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPZVjxhK.png&h=2b122f37&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: x-large;\">港共政權藉疫情為由，推出限聚令，打壓為實，致今天我們難以進行公眾拜祭活動。是故今晚會有網上悼念活動，亦請大家於<span style=\"color: red;\">8時9分</span>自行默哀1分鐘。</span><br />\n<img src=\"https://na.cx/i/UXCYNS2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUXCYNS2.png&h=9048652b&s={SIZE}\" /><br />\n<br />\n但願各位手足不要氣餒，革命往往是要花很長的時間才能達成，而且身邊同行者未必多。想當初國父孫中山搞革命之年，乃封建滿清之時，愚民豈不是更多，同行者不是更難找到。<br />\n<span style=\"font-size: xx-large;\">君子報仇，十年未晚</span><br />\n<span style=\"font-size: xx-large;\">今日未報，時辰未到</span><br />\n<br />\n我地即管同呢個政權鬥長命，最緊要要保全自己嘅性命。<br />\n<img src=\"https://na.cx/i/jdkzk9s.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fjdkzk9s.png&h=748484b0&s={SIZE}\" /><img src=\"https://na.cx/i/fbiX3nO.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfbiX3nO.png&h=a2cdcef8&s={SIZE}\" /></blockquote>"},{"pid":"c4b1112631bcf9a6f2af1b945fa5df8b38200e85","tid":1963701,"uid":202464,"like":0,"dislike":0,"score":0,"quote":{"pid":"bbed74f40670356352df0cd263e30c4fd60e1f57","tid":1963701,"uid":61197,"like":14,"dislike":0,"score":14,"citedBy":1,"replyTime":"2020-04-08T10:25:38.000Z","msg":"$2 變$1.6? <br />\n利申:幫我呀婆計數"},"citedBy":0,"replyTime":"2020-04-08T10:26:25.000Z","msg":"平$0.4都好"},{"pid":"2facce81253d7756ee45158efbe7e58a29150582","tid":1963701,"uid":106683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T10:26:37.000Z","msg":"俾狗搭"},{"pid":"0666bb9376e9cff6a7a0cbd8c7f23d04201ae05e","tid":1963701,"uid":205043,"like":5,"dislike":1,"score":4,"citedBy":2,"replyTime":"2020-04-08T10:26:38.000Z","msg":"我跳開閘<br />\n關我撚事"},{"pid":"a3b4b75ef17571698608a2825d0b2dd81ce7dd5f","tid":1963701,"uid":202464,"like":0,"dislike":2,"score":-2,"quote":{"pid":"0666bb9376e9cff6a7a0cbd8c7f23d04201ae05e","tid":1963701,"uid":205043,"like":5,"dislike":1,"score":4,"citedBy":2,"replyTime":"2020-04-08T10:26:38.000Z","msg":"我跳開閘<br />\n關我撚事"},"citedBy":1,"replyTime":"2020-04-08T10:26:58.000Z","msg":"仲有跳？"},{"pid":"d312cd77dbb98728fc3fd2e90d59cb68f3e00064","tid":1963701,"uid":30506,"like":0,"dislike":4,"score":-4,"quote":{"pid":"3b1731e33e03436c08ba8d3117a2fd9c49b82376","tid":1963701,"uid":208376,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2020-04-08T10:25:58.000Z","msg":"2蚊8折平得0.4蚊。。。。"},"citedBy":3,"replyTime":"2020-04-08T10:27:01.000Z","msg":"點樣搭2蚊地鐵<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"a8f91433a17f6fb6aa904a82f4b7ad0409e4553f","tid":1963701,"uid":353267,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T10:27:56.000Z","msg":"<span style=\"font-size: x-large;\">即係都係納稅人啲錢<br />\n但係就送錢比地鐵<br />\n想多啲人坐</span>"},{"pid":"b0fbe0f60c062be9376d42294c6afe7cb32a3873","tid":1963701,"uid":256246,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-04-08T10:28:02.000Z","msg":"地鐵減價由納稅人埋單，咁咪即係又係自己俾返，嚴格上黎講仲要幫人俾埋添<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"6f267adb8a21a62083b37fd01697b75109827c7e","tid":1963701,"uid":63449,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-08T10:28:18.000Z","msg":"街都無得出 又唔洗返工/學 咁搭乜鳩黨鐵 傻撚左個鼻<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n咁對市民有乜用<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"20c147e29ac5bb8028543f7ef3de65679d4c119c","tid":1963701,"uid":205043,"like":1,"dislike":0,"score":1,"quote":{"pid":"a3b4b75ef17571698608a2825d0b2dd81ce7dd5f","tid":1963701,"uid":202464,"like":0,"dislike":2,"score":-2,"quote":{"pid":"0666bb9376e9cff6a7a0cbd8c7f23d04201ae05e","tid":1963701,"uid":205043,"like":5,"dislike":1,"score":4,"citedBy":2,"replyTime":"2020-04-08T10:26:38.000Z","msg":"我跳開閘<br />\n關我撚事"},"citedBy":1,"replyTime":"2020-04-08T10:26:58.000Z","msg":"仲有跳？"},"citedBy":2,"replyTime":"2020-04-08T10:28:59.000Z","msg":"831開始跳到而家<br />\n咩撚野事都冇"},{"pid":"1e509acb0780eaa05a7cbe8a51fd600d281d7d47","tid":1963701,"uid":205043,"like":1,"dislike":0,"score":1,"quote":{"pid":"d312cd77dbb98728fc3fd2e90d59cb68f3e00064","tid":1963701,"uid":30506,"like":0,"dislike":4,"score":-4,"quote":{"pid":"3b1731e33e03436c08ba8d3117a2fd9c49b82376","tid":1963701,"uid":208376,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2020-04-08T10:25:58.000Z","msg":"2蚊8折平得0