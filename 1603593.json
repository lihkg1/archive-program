2b3c26a390f307b35","tid":1603593,"uid":119623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T18:16:51.000Z","msg":"<img src=\"/assets/faces/dog/itdog3.gif\" class=\"hkgmoji\" />"},{"pid":"d34962d54e37bad9f474336350769c47ddcd2db5","tid":1603593,"uid":119623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T18:17:02.000Z","msg":"<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"a0aeac3ed1e57444767c4ea7a60b6c8ae52c2cec","tid":1603593,"uid":119623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T18:17:13.000Z","msg":"1/100"},{"pid":"d641969474485ca7e16a7610d3bfb183e96a51ec","tid":1603593,"uid":119623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T18:17:24.000Z","msg":"2/100"},{"pid":"5353385a85845259d828e1e1f2b2a90ad648e868","tid":1603593,"uid":119623,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-09-29T18:17:34.000Z","msg":"3/100"},{"pid":"5baae406a4859fdc4aa2a77efcf56e128b163af0","tid":1603593,"uid":317169,"like":0,"dislike":0,"score":0,"quote":{"pid":"aaeff4f3c3c05284591069aa074ff184f748cd9f","tid":1603593,"uid":119623,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-29T17:08:34.000Z","msg":"<img src=\"https://na.cx/i/KoegX8Z.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKoegX8Z.png&h=3df3ac6a&s={SIZE}\" /><br />\n<br />\n今日見到有唔少人著得靚一靚，但而家係抗爭，唔係開party，唔該著返套舒適方便嘅衫。<br />\n<br />\n較高戰鬥力服裝：防水風褸 + 防水長褲 + 雨褸<br />\n較低戰鬥力服裝：黑TEE + 冰袖 + 黑色長褲<br />\n<br />\n記得帶返頂帽，將頭髮收好。有黑超就帶埋，口罩/包面頭巾是必須的。總之愈認唔到你就愈好。飾物可免則免。如果你會接觸到任何野，最好帶對手套。<br />\n<br />\n袋孭返個背囊，方便。散物資時又可以塞多啲。可以孭多個腰包，放貴重物品，走難時冇咁易唔見嘢。<br />\n<br />\n女仔忍忍手唔好化妝，萬一中咗嘢就會kick曬係皮膚入面，好難搞。當然可以帶啲化妝品走時變身用。<br />\n<br />\n帶多一、兩套衫換是常識吧。仲有記住攝衫喔<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<br />\n好多裝備深水埗都有得買，好聽日去入貨<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n每人順手帶多包索帶、士巴拿、六角匙等等嘅工具，到時就冇咁手足無措。<br />\n<br />\n一人一把長遮攜身，再袋多把縮骨遮。長遮畀咗人，都仲有把縮骨遮保護自己。<br />\n<br />\n有嘢要補充，歡迎留言。<br />\n<br />\n今時唔同往日，大家要萬事小心，細心留意四周，謹慎行動。為人為己，應要有充分裝備<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><br />\n矛同盾互相配合，先會有好嘅發揮。<br />\n好想同大家齊上齊落⋯<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: xx-large;\">10 . 1 要見到你<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /></span><br />\n<br />\n<img src=\"https://na.cx/i/sQaWX9R.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FsQaWX9R.jpg&h=ca8c60fc&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-09-29T18:19:25.000Z","msg":"呢張圖都睇到 冇戴帽/戴非黑色 係好搶眼"},{"pid":"6efa3ca3c18c4d0bfb525cd243e8b8830b6c40f8","tid":1603593,"uid":119623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T00:45:01.000Z","msg":"全民black bloc <br />\n全民皆兵<br />\n全民攝衫"},{"pid":"77d2de1e5921394472bbfb8e67c01b2783141549","tid":1603593,"uid":119623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T00:45:21.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"df71eda65e926c6a75815ac740cf2a9bc9dc0408","tid":1603593,"uid":119623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T00:45:32.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"d9845ddda1a28dcbaeec74bb51176b93074932e2","tid":1603593,"uid":119623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T00:45:49.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"599739fea110356a16987f6a981e342da2ad01a0","tid":1603593,"uid":119623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T00:51:38.000Z","msg":"撞"},{"pid":"9ad62b5ba56eec3d00d2905869548f882263f373","tid":1603593,"uid":191638,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T00:52:04.000Z","msg":"Push push"},{"pid":"36e840cd6ee0a081bc42f630e1