pid":"4d92006eaafc311ac2507629ab00eec7078bbc14","tid":1545062,"uid":123991,"like":0,"dislike":0,"score":0,"quote":{"pid":"823ba303d7902485109ac1783c4f0ec68199202a","tid":1545062,"uid":313312,"like":1,"dislike":1,"score":0,"quote":{"pid":"271db68d8a6faf5ce276433ff79746ba52e93a0e","tid":1545062,"uid":123991,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-05T18:55:48.000Z","msg":"[行動post] 肯入黎睇9.7點樣揸機場輸精管未 | LIHKG <br />\n<a href=\"https://lihkg.com/thread/1535579/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1535579/page/1</a> <br />\n<br />\n<img src=\"https://na.cx/i/reLz9Yb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FreLz9Yb.jpg&h=bc5ea362&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/VeJJ3id.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVeJJ3id.jpg&h=50bde3c1&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-09-05T18:57:16.000Z","msg":"你全職？一日24小時都秒回，系統信息？"},"citedBy":0,"replyTime":"2019-09-06T00:34:45.000Z","msg":"冇24 小時<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"95d3cb0004b2e61d2873bdb5cfa154c5dab511ca","tid":1545062,"uid":313312,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-09-06T00:38:09.000Z","msg":"首先我地要既係真相，但政府就係想隱瞞真相，冷處理。<br />\n<br />\nFc無需要，即是有警察爆料影埋證件，都可以假。以64例子，有相有人證都可以話假。隨時有心放流料。<br />\n<br />\n去到依刻除非有好權威消息來源，否則fc無意義，有人話如果假消息俾傳媒報導抄車點算？<br />\n<br />\n要明白我地唔係去證明事實，一日唔交cctv一日都無fc，<span style=\"color: red;\"><span style=\"font-size: large;\">重點：我地唔係確定事實，我地只係根據現有說法推斷一個可能性；只係一個說法一個謠言唔存在真實性，只係講緊合理性，可能性</span></span><br />\n<br />\n<span style=\"color: red;\"><strong>所以大家唔做標題黨，用可能，疑似字眼做標題，就唔會有人抄車</strong></span><br />\n<br />\n係依個時候，政府就會進入悖論狀態，佢唔辟謠，就係對坊間謠言最好，最強力證明，佢澄清，交出cctv就等於提交黑警恐襲鐵證<br />\n<br />\n所以政府交唔交cctv都會得到真相<br />\n<br />\n越多人恐慌，越多人討論，政府壓力就越大，只要謠言夠強大，政府進退兩難<br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">用謠言迫出真相</span></span><br />\n<br />\n認同幫我推，p牌推唔到"},{"pid":"4cb157fa782b0ba7a77dda0a3aad966ff92babb2","tid":1545062,"uid":73100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T04:33:25.000Z","msg":"幫推"},{"pid":"4a0c3b9b2d977f9a1d8f32dff80958e890866ad4","tid":1545062,"uid":157891,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T06:06:07.000Z","msg":"推"},{"pid":"499dc94951af1fee274fc7c3d56bbbaaf8397c09","tid":1545062,"uid":157891,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T06:09:39.000Z","msg":"推"},{"pid":"ba4525e40eff6b8acb3c1df5c6e5f062744622a8","tid":1545062,"uid":3424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-06T06:11:16.000Z","msg":"推"}]}