上男會員，他將「交通工具」[2]與「公共交通工具」[3]混淆，結果被其他真心膠會員恥笑小學程度不如：因為小學已教學生何謂交通工具。<br />\n<br />\n亦有會員以標題回覆開文者，指其「男人到三十歲仲未知道私家車係交通工具一種好可憐」。亦有會員揶揄開文者為超人、多啦A夢，可以飛天或使用法寶代步；更有會員設計了一張多啦A夢由隨意門探頭出來，說出「我覺得男人要依賴交通工具好可憐」的圖片。"},{"pid":"4f44c14866f956a0a8e2acd912668d9d464afe76","tid":1088951,"uid":66099,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-02T12:14:47.000Z","msg":"拎張白卡俾佢睇"},{"pid":"c5a97895bafff718c98d4dd1bece14eea85db789","tid":1088951,"uid":124256,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-02T12:16:02.000Z","msg":"我bmi有30"},{"pid":"ae703f4e76fd17894b01c3408ae5862eaa46b394","tid":1088951,"uid":33495,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-02T12:19:33.000Z","msg":"I go to school by bus"},{"pid":"4e39f131e25b8698d5b6a421e3ce4eb05432dc8d","tid":1088951,"uid":431,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-02T12:20:11.000Z","msg":"有話錯你咩？"},{"pid":"473b4b854a3c6fc40dc36a09505417f9457d00dc","tid":1088951,"uid":106875,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-02T12:20:23.000Z","msg":"弱智人士你都串<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"c1af69efcfbb3fc0ebd612442ca415e168609910","tid":1088951,"uid":218575,"like":0,"dislike":0,"score":0,"quote":{"pid":"4f44c14866f956a0a8e2acd912668d9d464afe76","tid":1088951,"uid":66099,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-02T12:14:47.000Z","msg":"拎張白卡俾佢睇"},"citedBy":0,"replyTime":"2019-04-02T12:32:34.000Z","msg":"我沒"},{"pid":"538d848c9ce2c6f0000ed81bb72312bb083ff3e3","tid":1088951,"uid":218575,"like":0,"dislike":0,"score":0,"quote":{"pid":"c5a97895bafff718c98d4dd1bece14eea85db789","tid":1088951,"uid":124256,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-02T12:16:02.000Z","msg":"我bmi有30"},"citedBy":1,"replyTime":"2019-04-02T12:32:45.000Z","msg":"我過咗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ae07c7f4caa63ae6c34c42da85a8442a18c18b12","tid":1088951,"uid":21857