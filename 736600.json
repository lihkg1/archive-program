ces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"e00c4974fbda106a1de63d32970c1b8c63b3dcfc","tid":736600,"uid":35870,"like":1,"dislike":4,"score":-3,"quote":{"pid":"8899280c9bdd9fc72a739a90ea46c5dfc7f991b2","tid":736600,"uid":138409,"like":12,"dislike":0,"score":12,"citedBy":3,"replyTime":"2018-07-10T11:03:33.000Z","msg":"push<br />\n留名等會員「哲學撚」進場屌9本研社<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-07-10T14:08:23.000Z","msg":"我唔係乜都屌，有明顯嘅錯野先屌<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 唔明顯嘅錯野我都無能力去屌或者根本發現唔到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n上次我屌過本土研究社係因為佢連填海vs棕地比較成本都吹錯晒先畀我大條道理屌<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"527e9c0f03ef77ed97a9ab294e301ad08e560f9d","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"quote":{"pid":"e00c4974fbda106a1de63d32970c1b8c63b3dcfc","tid":736600,"uid":35870,"like":1,"dislike":4,"score":-3,"quote":{"pid":"8899280c9bdd9fc72a739a90ea46c5dfc7f991b2","tid":736600,"uid":138409,"like":12,"dislike":0,"score":12,"citedBy":3,"replyTime":"2018-07-10T11:03:33.000Z","msg":"push<br />\n留名等會員「哲學撚」進場屌9本研社<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-07-10T14:08:23.000Z","msg":"我唔係乜都屌，有明顯嘅錯野先屌<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 唔明顯嘅錯野我都無能力去屌或者根本發現唔到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n上次我屌過本土研究社係因為佢連填海vs棕地比較成本都吹錯晒先畀我大條道理屌<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-10T14:10:59.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"ef06275fa865efa15911731f73baa01b28e8a5f6","tid":736600,"uid":76310,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-10T14:12:09.000Z","msg":"一早知, 一早話左凸手同港共正苦要炒高樓價<br />\n<br />\n只係有班傻仔仲信正苦者"},{"pid":"d118338f4c34548307e0d92f5151289be45792e5","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T14:18:41.000Z","msg":"解釋一下件事係點先<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/07/10/221814_5f75c3313b077d65ae50165c6fc52154.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F10%2F221814_5f75c3313b077d65ae50165c6fc52154.png&h=d5f35e8b&s={SIZE}\" /><br />\n<br />\n一般來說,所有物業都是由個人或公司身份持有,大部分物業買賣都是透過轉<br />\n換業主的方式進行;即一個普通人或公司向另一個人或公司購買住宅單位,並<br />\n成為該物業的新業主。<span style=\"color: red;\">然而,以股權轉讓形式進行物業交易卻是透過買入「物<br />\n業公司」股份,成為公司大股東,從而取得住宅單位擁有權。直至交易完成後,<br />\n住宅物業的業主都仍是同一間「物業公司」,但公司及物業的真正控制人已變<br />\n成新買家。</span><br />\n<br />\n6. 現時以股權轉讓方式交易物業,<span style=\"color: red;\">買賣雙方只須繳付 0.2%的股票轉讓印花稅,稅<br />\n率遠低任何一類物業印花稅</span>,成功減低投資者及外來買家進入本港住宅市場的<br />\n稅務成本。「物業公司」往往都是沒有經營任何實際業務的「空殼公司」,通<br />\n常只得幾位公司董事及股東7。"},{"pid":"dd45e822cc9bcb432cd3c6f9e97f9ff97461a11d","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T14:30:33.000Z","msg":"push"},{"pid":"81ad90b3b97a77a5eae22e9b2cb56e014e8c153c","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T14:34:47.000Z","msg":"14.大量買家在香港或內地都有資深的房地產或金融投資背景,甚至本身是中港地 產集團管理層,亦有買家是<span style=\"font-size: x-large;\">前任全國政協委員</span>。有關買家包括著名內地地產商 廣東鼎龍實業集團有限公司總裁龍學勤、中渝置地主席張松橋、晉安集團執行 董事王逢源、人和集團行政總裁戴永革、經緯集團主席及前全國政協委員陳經緯、仙股大王孫粗洪、田生集團前執行董事龐維新、<span style=\"font-size: xx-large;\"><span style=\"color: red;\">藝人關芝琳及容祖兒</span></span>等。"},{"pid":"65eb414d9d2dd34ef80912f759edb1d29da40147","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T14:47:51.000Z","msg":"個案四:關之琳藉股權轉讓炒樓 再享「首置」稅務優惠<br />\n<br />\n1. 個案涉及兩個單位,分別是地利根德閣 3 座 65 樓 C 室(以公司股權轉讓方式購買)及星域軒 1 座 31 樓及 32 樓 B 室複式單位(以首置買家身份持有)。<span style=\"color: red;\">涉及的買家為關家慧(藝名關之琳)。</span><br />\n<br />\n2. 地利根德閣單位由「中衛有限公司」(Terra Limited) 持有。中衛原有的登記董事為何啟穎及「鎮城有限公司」,原股東為 Luna Sol Corp,是一間註冊於<span style=\"color: red;\"><span style=\"font-size: x-large;\">瓦努阿圖</span></span>的公司。研究團隊查冊發現,2017 年 3 月,中衛有限公司全數董事辭任,並改由關家慧擔任唯一董事,唯一股東亦由 Luna Sol Corp 改為關家慧, 顯示關家慧已透過股權轉讓方式取得地利根德閣單位的擁有權。<br />\n<br />\n3. 綜合多份新聞報導,地利根德閣單位的交易涉及約 1.35 億港元,以股權轉讓交易讓買家成功避交約 4,000 萬港元物業印花稅。<br />\n<br />\n4. 研究團隊其後查冊再發現,關家慧於 2017 年 5 月以個人身份購入上述的星域軒複式單位,交易額為 5,400 萬元,她並按 4.25%「首置」稅率繳付約 230 萬元物業印花稅。<span style=\"color: red;\"><span style=\"font-size: x-large;\">但當時她已透過股權轉讓取得地利根德閣住宅單位,明顯是「假首置買家」濫用「首置」稅務優惠。而股權轉讓助她掩飾非首置買家的身份,亦成功避繳 15%雙倍印花稅,相當於節省 580 萬港元稅項。</span></span><br />\n<br />\n5. <span style=\"color: red;\"><span style=\"font-size: x-large;\">綜合多份新聞報導,關家慧多年來一直有炒賣物業記錄,研究團隊亦發現她於 2014 年利用「賣殼」方式炒賣南灣道 16 號 A 的住宅物業。今次她以股權轉讓漏洞濫用「首置」身份購買星域軒單位,極可能同為炒賣物業之用。</span></span>可以說,股權轉讓不但為炒家節省稅務開支,更助他們偽裝「首置買家」,假「自住」之名作炒賣投機之實,排擠「真首置買家」的居住需求。"},{"pid":"f74e69cd34f32bff14893d28f1fda57f0bd9c6d0","tid":736600,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T14:48:47.000Z","msg":"窮人比稅, 有錢人瘋狂炒樓"},{"pid":"5cc0483d86b83f715a7edfe86b1c069ef04b7f40","tid":736600,"uid":98163,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-10T14:51:23.000Z","msg":"高汁post冇人睇<img src=\"/assets/faces/lomoji/02.png\" class=\"hkgmoji\" />"},{"pid":"ce85c05f20563042fefee3c2dc801f035e28233e","tid":736600,"uid":20227,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-10T14:54:01.000Z","msg":"此回覆已被刪除"},{"pid":"1bf266b5d2bbecaf777a399bb0e34532d0411939","tid":736600,"uid":81698,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T14:54:54.000Z","msg":"Pish"},{"pid":"9128d395e6832bc3c89561735ec9fc085e1cde18","tid":736600,"uid":32114,"like":3,"dislike":1,"score":2,"quote":{"pid":"ce85c05f20563042fefee3c2dc801f035e28233e","tid":736600,"uid":20227,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-10T14:54:01.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-07-10T15:07:35.000Z","msg":"所以就冇問題？"},{"pid":"2121716e26d55c46ae42ca96f451e0864d9623a1","tid":736600,"uid":106641,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-10T15:12:32.000Z","msg":"之前好似有個做生意嘅巴打成日有意無意咁講自己做老細開公司交稅重少過幫我打工嘅，又可以將資產落自己公司名，定期交俾啲會計佬搞就交少好多稅"},{"pid":"4d10268533ad58e4e752a5ed0a71af7867fab313","tid":736600,"uid":104513,"like":0,"dislike":0,"score":0,"quote":{"pid":"2121716e26d55c46ae42ca96f451e0864d9623a1","tid":736600,"uid":106641,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-10T15:12:32.000Z","msg":"之前好似有個做生意嘅巴打成日有意無意咁講自己做老細開公司交稅重少過幫我打工嘅，又可以將資產落自己公司名，定期交俾啲會計佬搞就交少好多稅"},"citedBy":0,"replyTime":"2018-07-10T15:56:10.000Z","msg":"消費單據可以減免好多稅係真 差不多比會計人工仲多過啲稅"},{"pid":"c139958f42ed0b4332ab592fc9a2348410ab7764","tid":736600,"uid":104513,"like":0,"dislike":1,"score":-1,"quote":{"pid":"9128d395e6832bc3c89561735ec9fc085e1cde18","tid":736600,"uid":32114,"like":3,"dislike":1,"score":2,"quote":{"pid":"ce85c05f20563042fefee3c2dc801f035e28233e","tid":736600,"uid":20227,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-10T14:54:01.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-07-10T15:07:35.000Z","msg":"所以就冇問題？"},"citedBy":0,"replyTime":"2018-07-10T15:59:33.000Z","msg":"有問題都冇用啦 啲地產經紀都成日教人呢招 基本上所有炒家都識<br />\n<br />\n利申 屋企都係咁買賣物業 一間公司放一間物業 然後成間公司賣比人"},{"pid":"2529e9c67a91624aedce98281e25926dabd28d8e","tid":736600,"uid":42767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T21:06:47.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 避風港，幫支那人避風，犧牲香港人"},{"pid":"4758b8b52f7aa7e17464bdc25c8f60a0c709633a","tid":736600,"uid":88284,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-10T21:29:41.000Z","msg":"幫推"},{"pid":"32270b5db16f89264c95a493e9bf57932d901f09","tid":736600,"uid":24730,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-10T22:08:44.000Z","msg":"Lm"},{"pid":"bfa33723ff4341bd27e12e8a8230c4c4ad51bd64","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T23:09:37.000Z","msg":"push<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"edc2f20d81299064c914e203db67bc3ff77175b8","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T23:14:11.000Z","msg":"<span style=\"font-size: xx-large;\">政府唔堵塞漏洞 根本就係益大陸人</span><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n10. 近六成個案來自外地個人買家、外地註冊公司及來港未滿七年移民:126 宗已核實個案中,有 49 宗確認涉及外地個人買家及來港未滿七年的移民;兩類個案分別有 26 (21%)及 23 宗 (18%),合計佔整體已核實個案約四成。<br />\n<br />\n11.中國內地為外地個人買家的主要來源:<span style=\"font-size: x-large;\"><span style=\"color: red;\">26 宗涉及外地個人買家的個案中,有高達 19 宗 (約 73%)的買家來自中國內地</span></span><br />\n<br />\n12.在外地來港未滿七年的移民方面,研究團隊核實的 <span style=\"color: red;\"><span style=\"font-size: x-large;\">23 宗相關個案中,有 22 宗的買家英文名字以普通話拼音串寫或聯絡地址位於內地。</span></span>這反映部份內地移民因未享有香港永久居民身份,選擇以股權轉讓方式買樓避稅。而在 19 宗無法確認交易時來港是否滿七年的個案中,全數買家名字都以普通話拼音串寫,極有可能同樣來自內地。"},{"pid":"a37ae42db40f67f53c73e5da706aa6444c0eefc3","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T23:16:11.000Z","msg":"個案三:長和系賣豪宅 <span style=\"font-size: x-large;\"><span style=\"color: red;\">潛在稅收變地產商盈利</span></span><br />\n<br />\n5. 個案顯示股權轉讓亦可能成為地產商推銷豪宅別墅的手段。由於投資者及外地買家以正常途徑買樓,最高可能要繳付 30%物業印花稅,地產商以股權轉讓方式放售單位助買家避稅,往往可將該 30%的潛在稅項變成提價空間,以高於市價賣出物業;只要價錢仍低於物業市價連同潛在稅務成本,買家便會傾向接受。<span style=\"font-size: x-large;\"><span style=\"color: red;\">於是政府本應收取的稅款變成賣家的利潤,而地產商有系統地採用股權轉讓出售住宅,足以多賺數以億計盈利。</span></span>"},{"pid":"f51b89112a09059c9a5f2d678f29e8299b9b4b23","tid":736600,"uid":20227,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-10T23:16:54.000Z","msg":"此回覆已被刪除"},{"pid":"15b64dfe794e6a9457294cdd8efddeff29a28528","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"quote":{"pid":"f51b89112a09059c9a5f2d678f29e8299b9b4b23","tid":736600,"uid":20227,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-07-10T23:16:54.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-07-10T23:23:46.000Z","msg":"點解無問題"},{"pid":"cdb08b7db12bce64e2426a247753394d8365468a","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T23:25:41.000Z","msg":"2. 股權轉讓成功「廢辣」:政府一直聲稱多項樓市「辣招」已抑制投資及外地買家置業需求。然而,本研究發現政府 2016 年提高「辣招」稅率後,已核實的股權轉讓個案由 30 宗大增逾兩倍至 96 宗,而政府同期錄到的雙倍印花稅宗數則大幅跌至原有宗數約 2 成。兩個數字一升一跌的時間幾乎完全吻合,顯示股權轉讓已儼如「避稅後門」,能令由公司持有之物業避開所有物業印花稅,<br />\n樓市「辣招」的實質效力大大設限。"},{"pid":"78b944e5ca6b9ce4c0e5f48be52af23ed02316d1","tid":736600,"uid":20227,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-07-10T23:29:59.000Z","msg":"此回覆已被刪除"},{"pid":"51f58310fd339b20994892eee2e3b6949603ffb2","tid":736600,"uid":51183,"like":0,"dislike":0,"score":0,"quote":{"pid":"78b944e5ca6b9ce4c0e5f48be52af23ed02316d1","tid":736600,"uid":20227,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-07-10T23:29:59.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-07-10T23:37:42.000Z","msg":"無話唔得<br />\n投地條件可以禁止公司持有"},{"pid":"096d690788706b990978ec0dc1e5137d530b2c33","tid":736600,"uid":138409,"like":0,"dislike":0,"score":0,"quote":{"pid":"78b944e5ca6b9ce4c0e5f48be52af23ed02316d1","tid":736600,"uid":20227,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-07-10T23:29:59.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-07-10T23:37:56.000Z","msg":"當然唔可以<br />\n<br />\n但係可以參考外國經驗,向所有以股權轉讓方式取得本港住宅單位實益控制權的人士收取物業印花稅,令樓市「辣招」全面覆蓋本地住宅交易,打擊炒賣。<br />\n<br />\n政府過往討論物業印花稅時,其實曾多次將「物業公司」股權轉讓視為轉換物業實益擁有人的一種方式,並採取措施預防避稅。這些措施顯示,為保障市民居住需要,擱置公司獨立法人原則,視公司股東為公司住宅的實益擁有人,其實早有政策先例。<br />\n<br />\n(詳情可見政府回應傳媒有關「買家印花稅」查詢<a href=\"https://www.ird.gov.hk/chi/ppr/archives/12103001.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ird.gov.hk%2Fchi%2Fppr%2Farchives%2F12103001.htm&d=hFCwhsiXD8p2qbGD2KRdAUkviAvgRC9mxyv2vFgVDqU%3D&h=dd35e28c\" data-auto-link target=\"_blank\">https://www.ird.gov.hk/chi/ppr/archives/12103001.htm</a>)。"},{"pid":"41d672bbe760c5f1790d6235df2a4361fc13ec27","tid":736600,"uid":20227,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-10T23:41:29.000Z","msg":"此回覆已被刪除"},{"pid":"4e12979c80ad0dbe84eec8808a1f68727fc99eb9","tid":736600,"uid":57376,"like":3,"dislike":0,"score":3,"citedBy":3,"replyTime":"2018-07-10T23:45:23.000Z","msg":"點解公司可以無限制咁買住宅<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <br />\n話明住宅，係畀人住架嘛仆街<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"}]}