l=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ettoday.net%2Fnews%2F20190517%2F1446422.htm&d=2bx9SR3QHfMC8bM4fPAEX0ngG4XMVyvHznkFIzn%2BcUY%3D&h=a9926c0f\" data-auto-link target=\"_blank\">https://www.ettoday.net/news/20190517/1446422.htm</a>"},"citedBy":0,"replyTime":"2019-05-17T09:53:19.000Z","msg":"好恐怖<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"bc2717f5c6434a65c8e6c33bce7ac4e49b75e3f3","tid":1158854,"uid":44277,"like":0,"dislike":0,"score":0,"quote":{"pid":"30fdfcf4552af6cdc4ab7a724da61d948806da23","tid":1158854,"uid":57,"like":0,"dislike":0,"score":0,"quote":{"pid":"aad1c6a5fb087920d2a0866b1eb52dc718494b10","tid":1158854,"uid":47147,"like":1,"dislike":4,"score":-3,"quote":{"pid":"2efa556f62fc813a84315f8bcdcdc42b92ecc86e","tid":1158854,"uid":160051,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-05-17T09:44:10.000Z","msg":"10年前判了10年<br />\n個女人都應該出咗來了<br />\n<br />\n個BB好似半年後死了"},"citedBy":1,"replyTime":"2019-05-17T09:49:08.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-05-17T09:52:52.000Z","msg":"你係咪弱智架"},"citedBy":1,"replyTime":"2019-05-17T09:53:42.000Z","msg":"佢好似係想quote周星馳"},{"pid":"4c3fc0dd0fd45cf6c1172b1ea4f48d2deead2690","tid":1158854,"uid":57,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc2717f5c6434a65c8e6c33bce7ac4e49b75e3f3","tid":1158854,"uid":44277,"like":0,"dislike":0,"score":0,"quote":{"pid":"30fdfcf4552af6cdc4ab7a724da61d948806da23","tid":1158854,"uid":57,"like":0,"dislike":0,"score":0,"quote":{"pid":"aad1c6a5fb087920d2a0866b1eb52dc718494b10","tid":1158854,"uid":47147,"like":1,"dislike":4,"score":-3,"citedBy":1,"replyTime":"2019-05-17T09:49:08.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-05-17T09:52:52.000Z","msg":"你係咪弱智架"},"citedBy":1,"replyTime":"2019-05-17T09:53:42.000Z","msg":"佢好似係想quote周星馳"},"citedBy":0,"replyTime":"2019-05-17T09:55:53.000Z","msg":"<a href=\"https://hk.appledaily.com/news/art/20100511/14017292\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Fnews%2Fart%2F20100511%2F14017292&d=2bx9SR3QHfMC8bM4fPAEX0ngG4XMVyvHznkFIzn%2BcUY%3D&h=bc7c01ef\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Fnews%2Fart%2F20100511%2F14017292&h=8f6f1c34\" target=\"_blank\">https://hk.appledaily.com/news/art/20100511/14017292</a><br />\n香港果單"},{"pid":"0554281f44e3137e4561c56cc39c947dbed4dd8b","tid":1158854,"uid":85629,"like":2,"dislike":0,"score":2,"quote":{"pid":"bffdcd8c781cc050581514a3827f62e5abf85538","tid":1158854,"uid":44277,"like":2,"dislike":0,"score":2,"quote":{"pid":"361f6b283f59da241cd47c09b4ea058499f50667","tid":1158854,"uid":160051,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-05-17T09:30:12.000Z","msg":"之前香港都有個，google返原來都差唔多10年前"},"citedBy":2,"replyTime":"2019-05-17T09:38:03.000Z","msg":"我都記得<br />\n個女人之前小產<br />\n後尾只係判誤殺"},"citedBy":0,"replyTime":"2019-05-17T09:56:16.000Z","msg":"咁都誤殺<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"c8531e7d80d4ad5bad98ff02e42faf5dbef3e4d9","tid":1158854,"uid":113626,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-17T09:56:25.000Z","msg":"低端人口(肥婆)想殺害高端人口 <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> 贏唔到人就走去殺人"}]}