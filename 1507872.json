lass=\"hkgmoji\" />"},{"pid":"c532a1000f74e31ff5bd292a2dc35788f7d6915b","tid":1507872,"uid":75018,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-26T22:57:38.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />你哋一定要無事<br />\n唔止你哋！所有勇武、和理非、街坊都要無事！<br />\n<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"ce17e37443c83a161f1cc86f6edd9b9117f1b97c","tid":1507872,"uid":240973,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T04:17:39.000Z","msg":"救手足啊 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"92b279d8273db111a935be5729522e6640d6333a","tid":1507872,"uid":127463,"like":0,"dislike":0,"score":0,"quote":{"pid":"c532a1000f74e31ff5bd292a2dc35788f7d6915b","tid":1507872,"uid":75018,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-26T22:57:38.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />你哋一定要無事<br />\n唔止你哋！所有勇武、和理非、街坊都要無事！<br />\n<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-27T04:20:52.000Z","msg":"唔可以再送頭喇我地<br />\n<br />\n<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"48979d1f42768d056665859674c9617b61c3bbd3","tid":1507872,"uid":59569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-27T05:22:55.000Z","msg":"Ok"},{"pid":"06051dc9b12debc7508525ab995b9e94d2dcee2c","tid":1507872,"uid":240004,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-27T05:38:48.000Z","msg":"