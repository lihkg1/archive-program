pid":"3af796d3df1417ae0e1bafb4a2d2eae90963d0a5","tid":1927090,"uid":24345,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-21T08:35:21.000Z","msg":"留名，ripple 其實好似幾好"},{"pid":"fe5fffc9237d3f5574d0a293ed37d18ef0840aa1","tid":1927090,"uid":37238,"like":0,"dislike":0,"score":0,"quote":{"pid":"3af796d3df1417ae0e1bafb4a2d2eae90963d0a5","tid":1927090,"uid":24345,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-21T08:35:21.000Z","msg":"留名，ripple 其實好似幾好"},"citedBy":1,"replyTime":"2020-03-21T08:39:53.000Z","msg":"Ripple呢幾個禮拜跌咗30%都叫好？<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><br />\n希望Facebook搞得成Libra仲好啦"},{"pid":"0dfef7cee1cb78cc1792309f4960879acfd74a52","tid":1927090,"uid":24590,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-21T08:42:32.000Z","msg":"見到穩定幣的主題<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"089892bc9a9a8bde0d7cb9cdaca8b16a902a2955","tid":1927090,"uid":24345,"like":0,"dislike":0,"score":0,"quote":{"pid":"fe5fffc9237d3f5574d0a293ed37d18ef0840aa1","tid":1927090,"uid":37238,"like":0,"dislike":0,"score":0,"quote":{"pid":"3af796d3df1417ae0e1bafb4a2d2eae90963d0a5","tid":1927090,"uid":24345,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-21T08:35:21.000Z","msg":"留名，ripple 其實好似幾好"},"citedBy":1,"replyTime":"2020-03-21T08:39:53.000Z","msg":"Ripple呢幾個禮拜跌咗30%都叫好？<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><br />\n希望Facebook搞得成Libra仲好啦"},"citedBy":1,"replyTime":"2020-03-21T08:43:45.000Z","msg":"冇睇價sor<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />見佢原理好似幾好又快，依排唔係所有cryptocurrency都跌咩<br />\n<br />\nCryptocurrency 目的去中心化，俾FB搞得成唔覺係好事，濕鳩公司<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"b32c35e327eab55b34fcf37dd29aeca670a2b6dd","tid":1927090,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T08:44:07.000Z","msg":"推 唔係好明<br />\n不過我個個月提走戶口錢<br />\n加轉美金<br />\n感到自己過意得去"},{"pid":"d186cf5c1baf9a0f7c134c361c7860f9c81a7e99","tid":1927090,"uid":109706,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-21T08:45:58.000Z","msg":"安全性要講下,usdt係wallet都購定wallet用你個apps?"},{"pid":"ea8aca8c1146407172513204adfd0fbb99055975","tid":1927090,"uid":41355,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-03-21T08:47:47.000Z","msg":"好欣賞金融戰線既玩法<br />\n就咁睇現階段你地想聚焦係零售同眾籌？<br />\n<br />\n我講下零售先<br />\n零售交易對金融體系既衝擊好少<br />\n衝擊唔到現有既銀行體系<br />\n再者現行既交易好完善<br />\n八達通、信用卡已經食左大部分交易<br />\n好難說服人食餐飯埋單要30秒<br />\n<br />\n反而眾籌呢方面諗得過"},{"pid":"248dcd7e17c1d1aed351cfc92c66a94f2faa71bd","tid":1927090,"uid":37238,"like":3,"dislike":0,"score":3,"quote":{"pid":"089892bc9a9a8bde0d7cb9cdaca8b16a902a2955","tid":1927090,"uid":24345,"like":0,"dislike":0,"score":0,"quote":{"pid":"fe5fffc9237d3f5574d0a293ed37d18ef0840aa1","tid":1927090,"uid":37238,"like":0,"dislike":0,"score":0,"quote":{"pid":"3af796d3df1417ae0e1bafb4a2d2eae90963d0a5","tid":1927090,"uid":24345,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-21T08:35:21.000Z","msg":"留名，ripple 其實好似幾好"},"citedBy":1,"replyTime":"2020-03-21T08:39:53.000Z","msg":"Ripple呢幾個禮拜跌咗30%都叫好？<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><br />\n希望Facebook搞得成Libra仲好啦"},"citedBy":1,"replyTime":"2020-03-21T08:43:45.000Z","msg":"冇睇價sor<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />見佢原理好似幾好又快，依排唔係所有cryptocurrency都跌咩<br />\n<br />\nCryptocurrency 目的去中心化，俾FB搞得成唔覺係好事，濕鳩公司<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-21T08:49:39.000Z","msg":"所以樓主推Stablecoin就係想有一個穩定啲嘅crypto嚟做交易媒介<br />\ncoin嘅價值太波動 對買賣雙方都唔係好事嚟<img src=\"/assets/faces/dog/itdog3.gif\" class=\"hkgmoji\" />"},{"pid":"093b39ae298385506d32d4152ec7149bb04ca123","tid":1927090,"uid":109706,"like":0,"dislike":0,"score":0,"quote":{"pid":"d186cf5c1baf9a0f7c134c361c7860f9c81a7e99","tid":1927090,"uid":109706,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-21T08:45:58.000Z","msg":"安全性要講下,usdt係wallet都購定wallet用你個apps?"},"citedBy":0,"replyTime":"2020-03-21T08:50:32.000Z","msg":"安全性要講下,usdt係私人wallet到扣定用你個apps wallet?<br />\n見你地有open source ,有無it人講下"},{"pid":"12532e47ada167b96ae7e9aaf432b0d63d313c18","tid":1927090,"uid":92385,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T08:50:44.000Z","msg":"Push"},{"pid":"1b0b2014c7775a3ebacf6ac01b4fa9d4f02afb94","tid":1927090,"uid":41355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T08:51:18.000Z","msg":"雖然咁講<br />\n不過好欣賞你地將stablecoins換算同交易整成一個好方便既app"},{"pid":"942a584fba57bb4952566439916a8ebedb3b9a2a","tid":1927090,"uid":40718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T08:53:38.000Z","msg":"push"},{"pid":"d4d33d8932f3e245b7393270698398b97a8b2173","tid":1927090,"uid":73137,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T08:58:22.000Z","msg":"(文科生)睇唔明不過推"},{"pid":"61f0a6ab58f25b61fa3f0d17f8165ae30e88704c","tid":1927090,"uid":198175,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-21T09:13:34.000Z","msg":"就算你用美元/USDT消費畀錢, 但係舖頭收到錢, 最後都要用港元入貨出糧交租, 結果咪又係要用美元換返港元, D資金仍然留係香港金融體系<br />\n<br />\n你要連舖頭, 供應批發, 員工, 業主都收美元, 先至可以真正唔用港元<br />\n<br />\n香港銀行體系本身已有提供美元戶口及美元支票結算, 有部份銀行仲可以免費即日美元轉帳, 不過D美元仲留係香港銀行體系, 就算冇換成港元, 都會係銀行手上嘅美元, 可以攞去金管換用聯匯換港元, 又可以借畀支企同買支那債<br />\n<br />\n你要玩完全美元支付其實唔難, 最簡單做法係食飯買嘢你都可以直接畀美元現鈔<br />\n<br />\n舖頭可以用存美元現鈔入銀行(唔好用私人戶口, 記得用公司戶口, 咁先係合法收入), 每月用美元找完vendor數, 美元交租, 用美元支票出糧入數落僱員戶口, 再將每月多餘的美元匯到海外開個離岸戶口, 盡量減少在香港銀行體系嘅資金結餘<br />\n<br />\n以上做法並不會影響商戶及僱員報稅, 到要交稅先將美元匯返香港換港元交稅, 香港而家仲未有外匯管制, 我鍾意將D錢放係外國完全合法"},{"pid":"b940e0f878634826c8b76dc6a53eb49f61a969b2","tid":1927090,"uid":191531,"like":0,"dislike":0,"score":0,"quote":{"pid":"ea8aca8c1146407172513204adfd0fbb99055975","tid":1927090,"uid":41355,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-03-21T08:47:47.000Z","msg":"好欣賞金融戰線既玩法<br />\n就咁睇現階段你地想聚焦係零售同眾籌？<br />\n<br />\n我講下零售先<br />\n零售交易對金融體系既衝擊好少<br />\n衝擊唔到現有既銀行體系<br />\n再者現行既交易好完善<br />\n八達通、信用卡已經食左大部分交易<br />\n好難說服人食餐飯埋單要30秒<br />\n<br />\n反而眾籌呢方面諗得過"},"citedBy":0,"replyTime":"2020-03-21T09:34:11.000Z","msg":"打零售牌嘅好處喺普及化；喺日常生活入面接觸得倒，特別係黃店網絡依加有一定規模，對於推廣同認受性會有幫助<br />\n<br />\n不過交易時間對零售嚟講真係幾關鍵，餐飲耐少少都仲ok，便利店/超市之類PayWave有時都嫌慢"},{"pid":"bb289ae551239c312381fc2b890a052a16eb2a39","tid":1927090,"uid":78985,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T09:38:52.000Z","msg":"push"},{"pid":"1058c04928b2c48219c946a69148db2ca129260a","tid":1927090,"uid":118665,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T13:30:32.000Z","msg":"推"},{"pid":"3d73a5686d5fd219b801258c5c5e32ed48ef7674","tid":1927090,"uid":326037,"like":0,"dislike":0,"score":0,"quote":{"pid":"6529e7cbf89e495e48ef514d0ee5b7602278578e","tid":1927090,"uid":344466,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-15T14:23:44.000Z","msg":"如果大家仲未放棄，仲記唔記得港共春袋？<br />\n回帶<a href=\"https://lihkg.com/thread/1510846/page/1\" target=\"_blank\">https://lihkg.com/thread/1510846/page/1</a><br />\n半年前全民換美元到今日，我想係到問各位打開銀包有幾多人係一張美元都無？<br />\n有幾多人係因為鋪頭怕有偽鈔唔收美元，換完無得用而放棄？<br />\n<span style=\"color: orange;\">換完既美元要周圍用得著，就必需要一個美元版既支付寶。</span><br />\n<br />\n上一個po我地提到<br />\n[招兵買馬] 抵制支付寶來襲，抗衡八達通賣港<br />\n<a href=\"https://lih.kg/1805119\" target=\"_blank\">https://lih.kg/1805119</a><br />\n我地致力用區塊鏈穩定幣技術研發&ldquo;一個小朋友都識用既美元版 Payme/支付寶&rdquo; 以推動全民換美元代替港元。<br />\n網站大綱：<a href=\"https://timespayhk.com/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftimespayhk.com%2F&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=8bc9018e\" target=\"_blank\">https://timespayhk.com/</a><br />\n眼見個app 首階段差唔多完成<br />\n<br />\n先簡單講下咩係穩定幣<br />\n- 穩定幣（Stablecoins）係資產抵押掛鈎發行既代幣。位於龍頭地位既有USDT，USDC，PAX，DAI<br />\n佢地都屬於以太坊Erc20，優點非常多，低成本同全球性。<br />\n- Stablecoin種類咁多，點解我地最後選擇<strong>USDC</strong>做wallet主流交易貨幣？<br />\n係上年年中，美國金管局宣布對幾種穩定幣監管<br />\n<a href=\"https://www.dfs.ny.gov/about/press/pr1809101.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.dfs.ny.gov%2Fabout%2Fpress%2Fpr1809101.htm&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=ba708f26\" target=\"_blank\">https://www.dfs.ny.gov/about/press/pr1809101.htm</a><br />\n有美國政府監管既穩定幣就好似香港發鈔銀行咁，香港三間銀行既100蚊都係100蚊，而 1 穩定幣 = 1 美元。<br />\n所有穩定幣當中USDT嘅流通量最好，其次就係USDC, PAX.<br />\n<blockquote>發展到今年年頭，迷網巨頭Pornhub 宣布接受USDT做結算: (18+) <a href=\"http://pornhub.com/blog/9381\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fpornhub.com%2Fblog%2F9381&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=16269f8f\" target=\"_blank\">pornhub.com/blog/9381</a><br />\n就連JP Morgan都話要加入穩定幣行業<a href=\"https://www.jpmorgan.com/global/news/digital-coin-payments\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.jpmorgan.com%2Fglobal%2Fnews%2Fdigital-coin-payments&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=0f0ba8de\" target=\"_blank\">https://www.jpmorgan.com/global/news/digital-coin-payments</a></blockquote><br />\n不過USDT並<span style=\"color: red;\">未</span>受到美國金管局既認可，另外PAX舊年開始密密奶共同中國Binance合作整BUSD。<a href=\"https://www.paxos.com/how-is-busd-different-than-pax/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.paxos.com%2Fhow-is-busd-different-than-pax%2F&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=fd5a5ddc\" target=\"_blank\">https://www.paxos.com/how-is-busd-different-than-pax/</a><br />\n所以我地選擇USDC作為手機錢包上面嘅主流交易貨幣，個APP會圍繞住USDC而打造。<br />\nUSDC官網：<a href=\"https://www.circle.com/hk/usdc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.circle.com%2Fhk%2Fusdc&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=ee646a33\" target=\"_blank\">https://www.circle.com/hk/usdc</a><br />\n咁當然用戶可以選擇隨時轉USDC 做USDT, PAX or DAI etc...<br />\n呢個APP連接住7大去中心化交易所既聚合器，你可以係介面上隨時轉換Ethereum、穩定幣、穩定黃金或者其他altcoin。當然亦可以隨時傳送USDC到幾個Crypto界有名氣既交易所Coinbase, Binance, kraken 轉換成Bitcoin, Monero, Ripple等做提現或其他用途。<br />\n <br />\n講返個App - Stage1 首階段<br />\n專門為手機設計，非常方便既Stablecoin Payment app 可以通過使用QR code發送/接收資金。<br />\n首階段係<strong><span style=\"color: red;\">完全獨立</span></strong>係手機上，<strong><span style=\"color: red;\">非牟利</span></strong>，[/b]而且<strong><span style=\"color: red;\">open source</span></strong>開發<br />\n<a href=\"https://github.com/TimesPay/Times-Pay\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgithub.com%2FTimesPay%2FTimes-Pay&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=477d9cea\" target=\"_blank\">https://github.com/TimesPay/Times-Pay</a><br />\n歡迎<span style=\"color: red;\">任何人</span>參與，安全測試同審核。<br />\n<span style=\"color: orange;\">不過好似八達通咁，淨係整八達通卡唔夠，要整埋八達通機，售後服務兌換同兌現。一套完善既系統</span><br />\n我地將呢個Project分左做三個階段<br />\n<br />\nStage 1A 首階段 應用程式 只適合已有Stablecoin用戶<br />\n發送與接收資金<br />\n港美匯率結算<br />\nGas refill技術<br />\n去中心化交易所<br />\n <br />\nStage 1B 將會加入DAI stablecoin<br />\n<blockquote>DAI stablecoin 可以話係去中心化穩定幣既大老，crypto央行。以Ether抵押生成，不但去中心化仲有借貸同存款利率。<br />\n如果未來香港需要貨幣央行，亦可以參考呢種技術。有意了解可以去佢地官網，有機會我哋會詳細講解DAI：<a href=\"https://makerdao.com/en/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmakerdao.com%2Fen%2F&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=596f4459\" target=\"_blank\">https://makerdao.com/en/</a></blockquote><br />\nDAI 點對點眾籌平台，告別Gofundme/gogetfund眾籌網既高昂手續費 <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\nMixer (加入Mixer可能AML犯法，暫待定)<br />\nDAI 生成，Ether抵押<br />\nDAI 存款生息，隨存隨取<br />\nDAI Gas代理，無Gas發送"},"citedBy":0,"replyTime":"2020-03-21T13:33:31.000Z","msg":"<img src=\"https://na.cx/i/rYd26Ns.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrYd26Ns.png&h=a70def84&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/NKeRfFO.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNKeRfFO.png&h=e9aa91b9&s={SIZE}\" />"},{"pid":"63ebeb621e5ec168c86d9aa0d9533f5956ef2965","tid":1927090,"uid":326037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T14:02:43.000Z","msg":"係香港一定會用到港元，係外國建立反送中企業先得"},{"pid":"b12d15f3f953753195c10ab70aaadc19d2258b95","tid":1927090,"uid":26045,"like":1,"dislike":0,"score":1,"quote":{"pid":"61f0a6ab58f25b61fa3f0d17f8165ae30e88704c","tid":1927090,"uid":198175,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-21T09:13:34.000Z","msg":"就算你用美元/USDT消費畀錢, 但係舖頭收到錢, 最後都要用港元入貨出糧交租, 結果咪又係要用美元換返港元, D資金仍然留係香港金融體系<br />\n<br />\n你要連舖頭, 供應批發, 員工, 業主都收美元, 先至可以真正唔用港元<br />\n<br />\n香港銀行體系本身已有提供美元戶口及美元支票結算, 有部份銀行仲可以免費即日美元轉帳, 不過D美元仲留係香港銀行體系, 就算冇換成港元, 都會係銀行手上嘅美元, 可以攞去金管換用聯匯換港元, 又可以借畀支企同買支那債<br />\n<br />\n你要玩完全美元支付其實唔難, 最簡單做法係食飯買嘢你都可以直接畀美元現鈔<br />\n<br />\n舖頭可以用存美元現鈔入銀行(唔好用私人戶口, 記得用公司戶口, 咁先係合法收入), 每月用美元找完vendor數, 美元交租, 用美元支票出糧入數落僱員戶口, 再將每月多餘的美元匯到海外開個離岸戶口, 盡量減少在香港銀行體系嘅資金結餘<br />\n<br />\n以上做法並不會影響商戶及僱員報稅, 到要交稅先將美元匯返香港換港元交稅, 香港而家仲未有外匯管制, 我鍾意將D錢放係外國完全合法"},"citedBy":1,"replyTime":"2020-03-21T14:11:17.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"7f825c647c80de391b08ed84dacbec1264c09bc1","tid":1927090,"uid":205166,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T14:13:13.000Z","msg":"Lm"},{"pid":"a3b35738d03dbd0dff604a9ab409a5fb3822070a","tid":1927090,"uid":344466,"like":2,"dislike":0,"score":2,"quote":{"pid":"61f0a6ab58f25b61fa3f0d17f8165ae30e88704c","tid":1927090,"uid":198175,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-21T09:13:34.000Z","msg":"就算你用美元/USDT消費畀錢, 但係舖頭收到錢, 最後都要用港元入貨出糧交租, 結果咪又係要用美元換返港元, D資金仍然留係香港金融體系<br />\n<br />\n你要連舖頭, 供應批發, 員工, 業主都收美元, 先至可以真正唔用港元<br />\n<br />\n香港銀行體系本身已有提供美元戶口及美元支票結算, 有部份銀行仲可以免費即日美元轉帳, 不過D美元仲留係香港銀行體系, 就算冇換成港元, 都會係銀行手上嘅美元, 可以攞去金管換用聯匯換港元, 又可以借畀支企同買支那債<br />\n<br />\n你要玩完全美元支付其實唔難, 最簡單做法係食飯買嘢你都可以直接畀美元現鈔<br />\n<br />\n舖頭可以用存美元現鈔入銀行(唔好用私人戶口, 記得用公司戶口, 咁先係合法收入), 每月用美元找完vendor數, 美元交租, 用美元支票出糧入數落僱員戶口, 再將每月多餘的美元匯到海外開個離岸戶口, 盡量減少在香港銀行體系嘅資金結餘<br />\n<br />\n以上做法並不會影響商戶及僱員報稅, 到要交稅先將美元匯返香港換港元交稅, 香港而家仲未有外匯管制, 我鍾意將D錢放係外國完全合法"},"citedBy":0,"replyTime":"2020-03-21T22:14:33.000Z","msg":"我哋<span style=\"color: limegreen;\">唔</span>係要衝擊整個港元經濟系統，唔係一時三刻要立即全民換美元，我地預咗金融戰線係<span style=\"color: limegreen;\">合法持久戰</span>。<br />\n<br />\n我地係建立一個區塊鏈&quot;<span style=\"color: orange;\">手機美元支付寶</span>&quot;，令到市民食黃店可以<span style=\"color: orange;\">自由地</span>選擇其他可靠既貨幣做結算，<br />\n期望一點一滴咁改變港人使用港元結算嘅習慣，從而合法地<span style=\"color: red;\">減少依賴</span>港共府發行嘅貨幣。<br />\n<br />\n因為我哋每樣生活習慣都影響緊下一代。八達通係一個好例子，現時無數千禧年代學生們都被擁有八達通。<br />\n當手機比錢趨向成為未來社會必需品既時候，唔好等到港豬朋友叫你用支付寶嗰陣時先黎後悔<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><br />\n<br />\n雖然Crypto Payment呢個topic好敏感，不過我相信連登人才、香港人智慧總有方法建立信心證實Crypto <span style=\"color: gold;\">Payment</span>可行而且安全。<br />\n[金融戰線] 手足食飯唔想用港紙？鋪頭員工唔識分美偽鈔？我地需要一個世界級、安全、方便、可靠既美元交易渠道，最重要係<span style=\"color: orange;\">去中心化</span>自己錢自己話事<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">兄弟爬山，各自努力</span></span><br />\n抵制支付寶來襲，抗衡八達通賣港<br />\n<a href=\"http://timespayhk.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ftimespayhk.com&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=7510866b\" data-auto-link target=\"_blank\">timespayhk.com</a>"},{"pid":"f1845e5b2b2e7fdb17f59c742e6ecf4aa5947ff9","tid":1927090,"uid":191531,"like":0,"dislike":0,"score":0,"quote":{"pid":"b12d15f3f953753195c10ab70aaadc19d2258b95","tid":1927090,"uid":26045,"like":1,"dislike":0,"score":1,"quote":{"pid":"61f0a6ab58f25b61fa3f0d17f8165ae30e88704c","tid":1927090,"uid":198175,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-21T09:13:34.000Z","msg":"就算你用美元/USDT消費畀錢, 但係舖頭收到錢, 最後都要用港元入貨出糧交租, 結果咪又係要用美元換返港元, D資金仍然留係香港金融體系<br />\n<br />\n你要連舖頭, 供應批發, 員工, 業主都收美元, 先至可以真正唔用港元<br />\n<br />\n香港銀行體系本身已有提供美元戶口及美元支票結算, 有部份銀行仲可以免費即日美元轉帳, 不過D美元仲留係香港銀行體系, 就算冇換成港元, 都會係銀行手上嘅美元, 可以攞去金管換用聯匯換港元, 又可以借畀支企同買支那債<br />\n<br />\n你要玩完全美元支付其實唔難, 最簡單做法係食飯買嘢你都可以直接畀美元現鈔<br />\n<br />\n舖頭可以用存美元現鈔入銀行(唔好用私人戶口, 記得用公司戶口, 咁先係合法收入), 每月用美元找完vendor數, 美元交租, 用美元支票出糧入數落僱員戶口, 再將每月多餘的美元匯到海外開個離岸戶口, 盡量減少在香港銀行體系嘅資金結餘<br />\n<br />\n以上做法並不會影響商戶及僱員報稅, 到要交稅先將美元匯返香港換港元交稅, 香港而家仲未有外匯管制, 我鍾意將D錢放係外國完全合法"},"citedBy":1,"replyTime":"2020-03-21T14:11:17.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-22T03:51:19.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e86203e1857e4b1573fa75636be74fd4d04ba4ae","tid":1927090,"uid":36073,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-22T03:57:05.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2c21a1af11012d8a69f86f2a5735f1bc6beb1899","tid":1927090,"uid":244315,"like":0,"dislike":1,"score":-1,"quote":{"pid":"8134198561176e07384f341122eb836fff5ab3eb","tid":1927090,"uid":344466,"like":11,"dislike":1,"score":10,"citedBy":2,"replyTime":"2020-03-15T14:23:50.000Z","msg":"Stage 2 與傳統金融接軌 兌換與提現到銀行<br />\n眾所周知港府對科技野一向都俾其他國家慢，令到香港人遲遲享受唔到去中心化、區塊鏈技術。<img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><br />\n<blockquote>USDC兌現官網暫時只適用於歐、美、日、新加坡等地既銀行，未有香港<br />\n<a href=\"https://usdc.circle.com/start?signup=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fusdc.circle.com%2Fstart%3Fsignup%3D1&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=e320de5b\" target=\"_blank\">https://usdc.circle.com/start?signup=1</a></blockquote><br />\n直到2019年年尾，中國話要大搞區塊鏈金融之後香港政府終於跟隨以開放式嘅態度表態對Crypto嘅立場<img src=\"/assets/faces/lm2/donno.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://www.sfc.hk/web/TC/files/ER/PDF/20191106%20Position%20Paper%20and%20Appendix%201%20to%20Position%20Paper%20(Chi).pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.sfc.hk%2Fweb%2FTC%2Ffiles%2FER%2FPDF%2F20191106%2520Position%2520Paper%2520and%2520Appendix%25201%2520to%2520Position%2520Paper%2520%28Chi%29.pdf&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=be3afdf4\" target=\"_blank\">https://www.sfc.hk/web/TC/files/ER/PDF/20191106%20Position%20Paper%20and%20Appendix%201%20to%20Position%20Paper%20(Chi).pdf</a><br />\n過幾年你會見到香港越黎越多crypto ATM, 甚至有找換店都提供到兌換與兌現服務。<br />\n不過暫時本土因為流通量低，所以現有ATM、找換店等都要支付食水深嘅8%+手續費。<br />\n而外國大規模既法定貨幣交易所普遍手續費都低於0.5%甚至零手續費。相信未來隨着認受性同流通量增加，甚至可以同朋友之間兌換。<br />\n<blockquote>兌換：香港人可用，目前只會推薦Gemini. 缺點：KYC &amp; Bank wire<br />\n<a href=\"https://exchange.gemini.com/register\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fexchange.gemini.com%2Fregister&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=03603db4\" target=\"_blank\">https://exchange.gemini.com/register</a><br />\n到上年年尾美國傳統FDIC銀行已經同Crypto機構做到無縫接軌。<br />\n<a href=\"https://support.kraken.com/hc/en-us/articles/360036407971-Silvergate-Exchange-Network-SEN-\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fsupport.kraken.com%2Fhc%2Fen-us%2Farticles%2F360036407971-Silvergate-Exchange-Network-SEN-&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=64154831\" target=\"_blank\">https://support.kraken.com/hc/en-us/articles/360036407971-Silvergate-Exchange-Network-SEN-</a><br />\nSilvergate Bank(需要美國VPN) <a href=\"https://www.silvergatebank.com\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.silvergatebank.com&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=7e705b68\" target=\"_blank\">https://www.silvergatebank.com</a></blockquote><br />\n我地會按需要係香港籌備按證監會標準打造一個法定貨幣對crypto既交易所，為本土IT手足們帶黎就業機會。<br />\n不過淨係兌換兌現其實唔夠，我地亦會申請埋svf牌照，屆時用戶可以使用美元穩定幣交香港水電煤電話費等服務，目標令大家可以唔再依賴紙幣。<br />\n<br />\nStage 3 光速交易收款app，適合商舖收款用途<br />\n個收款app 將會連接住 SPV node同SPV Server，開發完成後可以將平均30秒既交易縮短到可於日常生活使用。（大前提要svf牌照）<br />\n<br />\n本土合法性：金管局提到過<br />\n如果政府認真的要提供「適當的經濟和法律環境，以保持香港的國際金融中心地位」（同樣是根據《基本法》第一百零九條），香港就必須能提供一個平台，好讓有關各方可以以其所選擇的貨幣進行國際金融交易。<br />\n<a href=\"https://www.hkma.gov.hk/chi/news-and-media/insight/2005/08/20050811/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hkma.gov.hk%2Fchi%2Fnews-and-media%2Finsight%2F2005%2F08%2F20050811%2F&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=7e48b618\" target=\"_blank\">https://www.hkma.gov.hk/chi/news-and-media/insight/2005/08/20050811/</a><br />\n另外，如果您係商舖/網店想好似Pornhub咁收美元穩定幣。我地律師話您知絕對<span style=\"color: red;\">無犯法</span>！立法會講過<br />\n交易雙方均可自行決定交易條款，包括決定使用何等支付媒介。<a href=\"https://www.info.gov.hk/gia/general/201001/20/P201001200090.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.info.gov.hk%2Fgia%2Fgeneral%2F201001%2F20%2FP201001200090.htm&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=c7d4c1b7\" target=\"_blank\">https://www.info.gov.hk/gia/general/201001/20/P201001200090.htm</a><br />\n如果您係黃色商舖/網店有USDC但兌現有困難，非常歡迎聯絡我地，我地會以1USDC對1美元入您指定銀行。<br />\n<br />\n<blockquote>我地Project仍屬於種子階段同埋涉及到金融/先進科技，處理既程序可以話係巨量，需要唔同範疇手足們夾時間埋位做野<br />\n所以有時更新得比較慢，希望大家見諒<img src=\"/assets/faces/lm2/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n撐背後默默付出嘅手足們 兄弟爬山，各自努力<br />\n金融戰線Play by the book<span style=\"color: red;\"><strong>識得玩，其實係核彈</strong></span><br />\n我地會將世界級頂尖嘅金融技術合法地帶比大家<br />\n將來食合作黃店除咗港幣俾錢，將會多一個核彈選擇<br />\n一點一滴減少依賴港元系統，建立黃色經濟圈強心針<br />\n<img src=\"https://na.cx/i/kvu8PO4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fkvu8PO4.jpg&h=1bb2e8e1&s={SIZE}\" /><br />\n仲有！<span style=\"font-size: large;\"><span style=\"color: red;\">抵制支付寶來襲，抗衡八達通賣港。</span></span><br />\n<img src=\"https://na.cx/i/O3ADs4L.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FO3ADs4L.jpg&h=25e69f2b&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-03-22T04:48:07.000Z","msg":"你up 完一大論我都唔知你講緊咩 點叫人用呀"},{"pid":"7c42125f153eb821d78a1dfa5d323f18bcaf1ed6","tid":1927090,"uid":46910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-22T04:51:32.000Z","msg":"推呀"},{"pid":"dbcad098f2187db543ee31e2b486309c4ef52987","tid":1927090,"uid":46910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-22T04:51:51.000Z","msg":"黃店指定消費方法"},{"pid":"625a35f283897aea8fb342451ee54259793af309","tid":1927090,"uid":191531,"like":0,"dislike":0,"score":0,"quote":{"pid":"2c21a1af11012d8a69f86f2a5735f1bc6beb1899","tid":1927090,"uid":244315,"like":0,"dislike":1,"score":-1,"quote":{"pid":"8134198561176e07384f341122eb836fff5ab3eb","tid":1927090,"uid":344466,"like":11,"dislike":1,"score":10,"citedBy":2,"replyTime":"2020-03-15T14:23:50.000Z","msg":"Stage 2 與傳統金融接軌 兌換與提現到銀行<br />\n眾所周知港府對科技野一向都俾其他國家慢，令到香港人遲遲享受唔到去中心化、區塊鏈技術。<img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><br />\n<blockquote>USDC兌現官網暫時只適用於歐、美、日、新加坡等地既銀行，未有香港<br />\n<a href=\"https://usdc.circle.com/start?signup=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fusdc.circle.com%2Fstart%3Fsignup%3D1&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=e320de5b\" target=\"_blank\">https://usdc.circle.com/start?signup=1</a></blockquote><br />\n直到2019年年尾，中國話要大搞區塊鏈金融之後香港政府終於跟隨以開放式嘅態度表態對Crypto嘅立場<img src=\"/assets/faces/lm2/donno.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://www.sfc.hk/web/TC/files/ER/PDF/20191106%20Position%20Paper%20and%20Appendix%201%20to%20Position%20Paper%20(Chi).pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.sfc.hk%2Fweb%2FTC%2Ffiles%2FER%2FPDF%2F20191106%2520Position%2520Paper%2520and%2520Appendix%25201%2520to%2520Position%2520Paper%2520%28Chi%29.pdf&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=be3afdf4\" target=\"_blank\">https://www.sfc.hk/web/TC/files/ER/PDF/20191106%20Position%20Paper%20and%20Appendix%201%20to%20Position%20Paper%20(Chi).pdf</a><br />\n過幾年你會見到香港越黎越多crypto ATM, 甚至有找換店都提供到兌換與兌現服務。<br />\n不過暫時本土因為流通量低，所以現有ATM、找換店等都要支付食水深嘅8%+手續費。<br />\n而外國大規模既法定貨幣交易所普遍手續費都低於0.5%甚至零手續費。相信未來隨着認受性同流通量增加，甚至可以同朋友之間兌換。<br />\n<blockquote>兌換：香港人可用，目前只會推薦Gemini. 缺點：KYC &amp; Bank wire<br />\n<a href=\"https://exchange.gemini.com/register\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fexchange.gemini.com%2Fregister&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=03603db4\" target=\"_blank\">https://exchange.gemini.com/register</a><br />\n到上年年尾美國傳統FDIC銀行已經同Crypto機構做到無縫接軌。<br />\n<a href=\"https://support.kraken.com/hc/en-us/articles/360036407971-Silvergate-Exchange-Network-SEN-\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fsupport.kraken.com%2Fhc%2Fen-us%2Farticles%2F360036407971-Silvergate-Exchange-Network-SEN-&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=64154831\" target=\"_blank\">https://support.kraken.com/hc/en-us/articles/360036407971-Silvergate-Exchange-Network-SEN-</a><br />\nSilvergate Bank(需要美國VPN) <a href=\"https://www.silvergatebank.com\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.silvergatebank.com&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=7e705b68\" target=\"_blank\">https://www.silvergatebank.com</a></blockquote><br />\n我地會按需要係香港籌備按證監會標準打造一個法定貨幣對crypto既交易所，為本土IT手足們帶黎就業機會。<br />\n不過淨係兌換兌現其實唔夠，我地亦會申請埋svf牌照，屆時用戶可以使用美元穩定幣交香港水電煤電話費等服務，目標令大家可以唔再依賴紙幣。<br />\n<br />\nStage 3 光速交易收款app，適合商舖收款用途<br />\n個收款app 將會連接住 SPV node同SPV Server，開發完成後可以將平均30秒既交易縮短到可於日常生活使用。（大前提要svf牌照）<br />\n<br />\n本土合法性：金管局提到過<br />\n如果政府認真的要提供「適當的經濟和法律環境，以保持香港的國際金融中心地位」（同樣是根據《基本法》第一百零九條），香港就必須能提供一個平台，好讓有關各方可以以其所選擇的貨幣進行國際金融交易。<br />\n<a href=\"https://www.hkma.gov.hk/chi/news-and-media/insight/2005/08/20050811/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hkma.gov.hk%2Fchi%2Fnews-and-media%2Finsight%2F2005%2F08%2F20050811%2F&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=7e48b618\" target=\"_blank\">https://www.hkma.gov.hk/chi/news-and-media/insight/2005/08/20050811/</a><br />\n另外，如果您係商舖/網店想好似Pornhub咁收美元穩定幣。我地律師話您知絕對<span style=\"color: red;\">無犯法</span>！立法會講過<br />\n交易雙方均可自行決定交易條款，包括決定使用何等支付媒介。<a href=\"https://www.info.gov.hk/gia/general/201001/20/P201001200090.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.info.gov.hk%2Fgia%2Fgeneral%2F201001%2F20%2FP201001200090.htm&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=c7d4c1b7\" target=\"_blank\">https://www.info.gov.hk/gia/general/201001/20/P201001200090.htm</a><br />\n如果您係黃色商舖/網店有USDC但兌現有困難，非常歡迎聯絡我地，我地會以1USDC對1美元入您指定銀行。<br />\n<br />\n<blockquote>我地Project仍屬於種子階段同埋涉及到金融/先進科技，處理既程序可以話係巨量，需要唔同範疇手足們夾時間埋位做野<br />\n所以有時更新得比較慢，希望大家見諒<img src=\"/assets/faces/lm2/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n撐背後默默付出嘅手足們 兄弟爬山，各自努力<br />\n金融戰線Play by the book<span style=\"color: red;\"><strong>識得玩，其實係核彈</strong></span><br />\n我地會將世界級頂尖嘅金融技術合法地帶比大家<br />\n將來食合作黃店除咗港幣俾錢，將會多一個核彈選擇<br />\n一點一滴減少依賴港元系統，建立黃色經濟圈強心針<br />\n<img src=\"https://na.cx/i/kvu8PO4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fkvu8PO4.jpg&h=1bb2e8e1&s={SIZE}\" /><br />\n仲有！<span style=\"font-size: large;\"><span style=\"color: red;\">抵制支付寶來襲，抗衡八達通賣港。</span></span><br />\n<img src=\"https://na.cx/i/O3ADs4L.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FO3ADs4L.jpg&h=25e69f2b&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-03-22T04:48:07.000Z","msg":"你up 完一大論我都唔知你講緊咩 點叫人用呀"},"citedBy":0,"replyTime":"2020-03-22T07:05:07.000Z","msg":"你唔明邊part不妨講下<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"fd27e0768c33a93f3c34e52589245f725fd61b75","tid":1927090,"uid":1224,"like":0,"dislike":0,"score":0,"quote":{"pid":"f1845e5b2b2e7fdb17f59c742e6ecf4aa5947ff9","tid":1927090,"uid":191531,"like":0,"dislike":0,"score":0,"quote":{"pid":"b12d15f3f953753195c10ab70aaadc19d2258b95","tid":1927090,"uid":26045,"like":1,"dislike":0,"score":1,"quote":{"pid":"61f0a6ab58f25b61fa3f0d17f8165ae30e88704c","tid":1927090,"uid":198175,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-21T09:13:34.000Z","msg":"就算你用美元/USDT消費畀錢, 但係舖頭收到錢, 最後都要用港元入貨出糧交租, 結果咪又係要用美元換返港元, D資金仍然留係香港金融體系<br />\n<br />\n你要連舖頭, 供應批發, 員工, 業主都收美元, 先至可以真正唔用港元<br />\n<br />\n香港銀行體系本身已有提供美元戶口及美元支票結算, 有部份銀行仲可以免費即日美元轉帳, 不過D美元仲留係香港銀行體系, 就算冇換成港元, 都會係銀行手上嘅美元, 可以攞去金管換用聯匯換港元, 又可以借畀支企同買支那債<br />\n<br />\n你要玩完全美元支付其實唔難, 最簡單做法係食飯買嘢你都可以直接畀美元現鈔<br />\n<br />\n舖頭可以用存美元現鈔入銀行(唔好用私人戶口, 記得用公司戶口, 咁先係合法收入), 每月用美元找完vendor數, 美元交租, 用美元支票出糧入數落僱員戶口, 再將每月多餘的美元匯到海外開個離岸戶口, 盡量減少在香港銀行體系嘅資金結餘<br />\n<br />\n以上做法並不會影響商戶及僱員報稅, 到要交稅先將美元匯返香港換港元交稅, 香港而家仲未有外匯管制, 我鍾意將D錢放係外國完全合法"},"citedBy":1,"replyTime":"2020-03-21T14:11:17.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-22T03:51:19.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-22T07:31:10.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d5147e624ca4a0abf61443c5dd39a02d20ff14f0","tid":1927090,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-23T16:16:20.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"a3b35738d03dbd0dff604a9ab409a5fb3822070a","tid":1927090,"uid":344466,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-03-21T22:14:33.000Z","msg":"我哋<span style=\"color: limegreen;\">唔</span>係要衝擊整個港元經濟系統，唔係一時三刻要立即全民換美元，我地預咗金融戰線係<span style=\"color: limegreen;\">合法持久戰</span>。<br />\n<br />\n我地係建立一個區塊鏈&quot;<span style=\"color: orange;\">手機美元支付寶</span>&quot;，令到市民食黃店可以<span style=\"color: orange;\">自由地</span>選擇其他可靠既貨幣做結算，<br />\n期望一點一滴咁改變港人使用港元結算嘅習慣，從而合法地<span style=\"color: red;\">減少依賴</span>港共府發行嘅貨幣。<br />\n<br />\n因為我哋每樣生活習慣都影響緊下一代。八達通係一個好例子，現時無數千禧年代學生們都被擁有八達通。<br />\n當手機比錢趨向成為未來社會必需品既時候，唔好等到港豬朋友叫你用支付寶嗰陣時先黎後悔<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><br />\n<br />\n雖然Crypto Payment呢個topic好敏感，不過我相信連登人才、香港人智慧總有方法建立信心證實Crypto <span style=\"color: gold;\">Payment</span>可行而且安全。<br />\n[金融戰線] 手足食飯唔想用港紙？鋪頭員工唔識分美偽鈔？我地需要一個世界級、安全、方便、可靠既美元交易渠道，最重要係<span style=\"color: orange;\">去中心化</span>自己錢自己話事<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">兄弟爬山，各自努力</span></span><br />\n抵制支付寶來襲，抗衡八達通賣港<br />\n<a href=\"http://timespayhk.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ftimespayhk.com&d=ly5XvLwGuIZ6JSW2uqe%2BvnyU4AarvyINc8S1qmu5ZLM%3D&h=7510866b\" data-auto-link target=\"_blank\">timespayhk.com</a>"}}