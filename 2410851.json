/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-17T04:40:17.000Z","msg":"有朋友係員，話根本係淘佬貨改logo"},"citedBy":1,"replyTime":"2021-02-17T04:46:39.000Z","msg":"大部分香港電器牌子都係大陸貼牌貨 <img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"9fecadeac0208f331e5b20b51d84ac395f5a46f3","tid":2410851,"uid":24160,"like":1,"dislike":0,"score":1,"quote":{"pid":"dd1810cce45623872ab1a020b56fd31b177175ab","tid":2410851,"uid":20933,"like":3,"dislike":1,"score":2,"quote":{"pid":"9a2193b7b493896c62106199634e4f575f9de608","tid":2410851,"uid":69013,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-02-17T03:15:31.000Z","msg":"有無數據比較 氣炸 同 油炸 炸薯條，邊個致癌物多d? 因為高溫+amino acid + carbohydrate 就會有polyaromatic compounds <img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-02-17T03:31:29.000Z","msg":"逾150度高溫可產生致癌物<br />\n<br />\n香港專業教育學院（IVE）柴灣院校應用科學系講師陳子聰表示，氣炸鍋是用熱空氣對流的原理，鍋內吹出的熱風最高可達200多度，不用下油就做到油炸食品的效果。生產商聲稱以此方法能更快煮熟食物，因熱空氣對流令傳熱速度更有效，能縮短煮食時間。陳子聰提醒，當食物處於150度或以上的高溫，就會發生「梅納反應」，令食物中的氨基酸、碳水化合物產生化學反應，釋出不同的香味和顏色，但與此同時亦會伴隨產生致癌物「丙烯酰胺」及PAHs（多環芳香族碳氫化合物）等。<br />\n<br />\n與焗爐光波爐燒烤分別不大<br />\n<br />\n陳子聰指出，以氣炸鍋煮雞翼為例，原理是以高溫逼出雞翼中蘊含的脂肪，達至油炸效果，令煮食過程中不必下油。其實此方法與用焗爐、光波爐或油炸、燒烤等的方式分別不大，同樣是高溫煮食，過程中同樣會產生致癌物「丙烯酰胺」及其他致癌物質。「溫度愈高，時間愈長，愈危險。」<br />\n<br />\n有網民認為，不吃氣炸鍋煮出來的食物焦黑部分應該沒有大問題。陳子聰表示，焦黑部分致癌物質無疑會較多，但經高溫煮食的食物即使沒有出現焦黑仍然有致癌物質，進食前要三思。<br />\n<br />\n陳子聰建議健康煮食貼士：<br />\n<br />\n‧ 煮食溫度盡量控制不要超過150度<br />\n<br />\n‧ 煮食時間不要太久<br />\n<br />\n‧ 水煮或蒸的方法因可控制煮食溫度維持100度，相比起來較健康"},"citedBy":1,"replyTime":"2021-02-17T04:51:00.000Z","msg":"就咁用鑊蒸魚炒菜心個溫度點止100度??<br />\n專家食屎啦好冇"},{"pid":"efd95e7a5dfff00e520e00b4c9bc7bf5109423ff","tid":2410851,"uid":4942,"like":2,"dislike":0,"score":2,"quote":{"pid":"00053b70e76be85c8e0567d8ca98144522f07ef9","tid":2410851,"uid":51701,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-17T03:38:57.000Z","msg":"德國寶同德國有咩關係？"},"citedBy":0,"replyTime":"2021-02-17T04:52:48.000Z","msg":"陳國民，1950年生於香港，在港接受教育。1972年中學畢業後，投身電器行業，在一間電器公司的分期付款部門工作。1975年他與親友合資在土瓜灣創辦家庭式企業，以住宅的天井為廠房，生產電熱水器，陳國民負責市場策劃，走遍港九的電器店和百貨公司推銷產品。1976年生產規模擴張，他與合伙人將廠房搬到浙江街的工廠大廈。<span class=\"red\">陳國民從德國入口熱線、恆溫按鈕等原材料，同時向供應商學習應用技術。</span>1982年自立門戶，創辦德國寶（香港）有限公司，並與歐州的供應商合作，創立「德國寶」的家庭電器品牌。德國寶初期的廠房位於葵涌，總部辦公室設在土瓜灣馬頭角道。<br />\n<br />\n當年真係有用德國製parts <img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},{"pid":"71c7b0853651e00b64cdc706e86be783a1bd3c71","tid":2410851,"uid":46943,"like":0,"dislike":0,"score":0,"quote":{"pid":"9fecadeac0208f331e5b20b51d84ac395f5a46f3","tid":2410851,"uid":24160,"like":1,"dislike":0,"score":1,"quote":{"pid":"dd1810cce45623872ab1a020b56fd31b177175ab","tid":2410851,"uid":20933,"like":3,"dislike":1,"score":2,"quote":{"pid":"9a2193b7b493896c62106199634e4f575f9de608","tid":2410851,"uid":69013,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-02-17T03:15:31.000Z","msg":"有無數據比較 氣炸 同 油炸 炸薯條，邊個致癌物多d? 因為高溫+amino acid + carbohydrate 就會有polyaromatic compounds <img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-02-17T03:31:29.000Z","msg":"逾150度高溫可產生致癌物<br />\n<br />\n香港專業教育學院（IVE）柴灣院校應用科學系講師陳子聰表示，氣炸鍋是用熱空氣對流的原理，鍋內吹出的熱風最高可達200多度，不用下油就做到油炸食品的效果。生產商聲稱以此方法能更快煮熟食物，因熱空氣對流令傳熱速度更有效，能縮短煮食時間。陳子聰提醒，當食物處於150度或以上的高溫，就會發生「梅納反應」，令食物中的氨基酸、碳水化合物產生化學反應，釋出不同的香味和顏色，但與此同時亦會伴隨產生致癌物「丙烯酰胺」及PAHs（多環芳香族碳氫化合物）等。<br />\n<br />\n與焗爐光波爐燒烤分別不大<br />\n<br />\n陳子聰指出，以氣炸鍋煮雞翼為例，原理是以高溫逼出雞翼中蘊含的脂肪，達至油炸效果，令煮食過程中不必下油。其實此方法與用焗爐、光波爐或油炸、燒烤等的方式分別不大，同樣是高溫煮食，過程中同樣會產生致癌物「丙烯酰胺」及其他致癌物質。「溫度愈高，時間愈長，愈危險。」<br />\n<br />\n有網民認為，不吃氣炸鍋煮出來的食物焦黑部分應該沒有大問題。陳子聰表示，焦黑部分致癌物質無疑會較多，但經高溫煮食的食物即使沒有出現焦黑仍然有致癌物質，進食前要三思。<br />\n<br />\n陳子聰建議健康煮食貼士：<br />\n<br />\n‧ 煮食溫度盡量控制不要超過150度<br />\n<br />\n‧ 煮食時間不要太久<br />\n<br />\n‧ 水煮或蒸的方法因可控制煮食溫度維持100度，相比起來較健康"},"citedBy":1,"replyTime":"2021-02-17T04:51:00.000Z","msg":"就咁用鑊蒸魚炒菜心個溫度點止100度??<br />\n專家食屎啦好冇"},"citedBy":0,"replyTime":"2021-02-17T05:08:52.000Z","msg":"咁中心温度又好少上到100度嘅<img src=\"/assets/faces/dog/discover.gif\" class=\"hkgmoji\" /><br />\n對比起煎炒煮炸其實焗爐氣炸煱都算底温<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />"},{"pid":"0c0613eb382da706bde0119abb2198ce1018d8d1","tid":2410851,"uid":75256,"like":0,"dislike":0,"score":0,"quote":{"pid":"baf5f429d8b7f9b45466b38910451f2470095264","tid":2410851,"uid":79410,"like":1,"dislike":1,"score":0,"quote":{"pid":"838790d68d101a3c2bd7b409875eb67c2ed9c810","tid":2410851,"uid":280593,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2021-02-17T03:07:39.000Z","msg":"好多係貼紙牌,淘寶／Amazon 賣平好多"},"citedBy":1,"replyTime":"2021-02-17T03:57:37.000Z","msg":"我之前見德國寶個小型暖風機(有放濕功能)賣8xx<br />\n我喺淘寶見一模一樣。賣百幾蚊<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-17T05:12:18.000Z","msg":"好多年前(Samsung anycall 個年代) Samsung 有款2.1 喇叭賣2xx 蚊，之後經過d 小型家電鋪，見到部一模一樣，差在無Samsung logo ge 喇叭賣百鬆d 蚊，果陣諗抄人d 野抄咁足，而家諗返可能都係代工關係。"},{"pid":"cc40c359b4f3d1b32406dd55fb72284328063dab","tid":2410851,"uid":214502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-17T05:13:53.000Z","msg":"支那寶<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"ac1d53e4d38110de6d5a989adeb8088e1632fd58","tid":2410851,"uid":214502,"like":1,"dislike":0,"score":1,"quote":{"pid":"0c0613eb382da706bde0119abb2198ce1018d8d1","tid":2410851,"uid":75256,"like":0,"dislike":0,"score":0,"quote":{"pid":"baf5f429d8b7f9b45466b38910451f2470095264","tid":2410851,"uid":79410,"like":1,"dislike":1,"score":0,"quote":{"pid":"838790d68d101a3c2bd7b409875eb67c2ed9c810","tid":2410851,"uid":280593,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2021-02-17T03:07:39.000Z","msg":"好多係貼紙牌,淘寶／Amazon 賣平好多"},"citedBy":1,"replyTime":"2021-02-17T03:57:37.000Z","msg":"我之前見德國寶個小型暖風機(有放濕功能)賣8xx<br />\n我喺淘寶見一模一樣。賣百幾蚊<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-17T05:12:18.000Z","msg":"好多年前(Samsung anycall 個年代) Samsung 有款2.1 喇叭賣2xx 蚊，之後經過d 小型家電鋪，見到部一模一樣，差在無Samsung logo ge 喇叭賣百鬆d 蚊，果陣諗抄人d 野抄咁足，而家諗返可能都係代工關係。"},"citedBy":0,"replyTime":"2021-02-17T05:15:17.000Z","msg":"以前好多代工 幾隻牌子 但外型一撚樣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n有隻*** Laserjet同其他牌子一樣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6a9ce948ab24c8682f4fe7ce15058dc7dd825908","tid":2410851,"uid":80866,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-17T05:17:14.000Z","msg":"德國寶唔係Made in 德國嫁?? WTF"},{"pid":"e7144756cf07daf5d568de962e8166edea35c44e","tid":2410851,"uid":20933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-17T05:21:30.000Z","msg":"消委會：調低氣炸鍋溫度或烹調時間可減致癌物 本地 發佈<br />\n<br />\n<img src=\"https://stream.881903.com/public/59ebd2af00054ad7a83e74f9071b5103/2021/02/2a0934522fcfaac2df10ef67dd3cd317.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstream.881903.com%2Fpublic%2F59ebd2af00054ad7a83e74f9071b5103%2F2021%2F02%2F2a0934522fcfaac2df10ef67dd3cd317.jpg&h=07a78ab9&s={SIZE}\" /><br />\n<br />\n消委會測試12款氣炸鍋的安全及效能表現，發現半數存在不同的安全問題，包括部件溫度升幅過高、絕緣距離不足及接地裝置欠佳。其中最低評分的樣本，欠缺牌子名稱及產品型號標示，除了不符合法例要求，亦無足夠資訊聯絡代理或生產商跟進。 <br />\n<br />\n消委會又發現，氣炸不同食物的效果十分參差，特別是炸薯條，有兩個樣本在氣炸後，大部份薯條都未煮熟，亦有2個樣本熱力不均，導致部份薯條過熟，但同時又有部份未煮熟。另外，半數氣炸鍋氣炸的薯條，可致癌物「丙烯酰胺」含量超出歐盟基準水平。 <br />\n<br />\n消委會總幹事黃鳳嫺表示，機電署檢視相關測試結果之後，認為市民在正常情況下使用是安全，消費者毋須停用；但如果氣炸鍋冒煙或有異味，就可能不安全，應該立即停用。 黃鳳嫺說，由於氣炸鍋透過發熱線發熱，使用時機身及手柄會發熱，建議用家最好戴隔熱手套，千萬不要讓小童觸摸機身，否則可能會燙傷。她又指，氣炸食物比起傳統油炸方式，會較健康，但就談不上是「健康食物」，重申烚及等烹調方式會比較好。 <br />\n<br />\n消委會研究及試驗小組主席譚鳳儀則表示，測試發現有急凍幼薯條經氣炸之後，可致癌物質「丙烯酰胺」含量，每公斤超過7000微克，遠超歐盟每公斤500微克的標準，建議用家可縮短氣炸時間或溫度，以減少炸物釋出的可致癌物質含量。 <br />\n<br />\n原文網址：<a href=\"https://www.881903.com/news/local/2379328\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.881903.com%2Fnews%2Flocal%2F2379328&d=2uuoLuAEMU6cBVSXjgSp%2BW0Q%2Fwx8zutUsTDhO6XOofs%3D&h=1e7e18a6\" data-auto-link target=\"_blank\">https://www.881903.com/news/local/2379328</a>"},{"pid":"99367b50200b52ea7f226c7f23fca3154e36dc03","tid":2410851,"uid":339053,"like":0,"dislike":0,"score":0,"quote":{"pid":"eacd067304b601dc65d28a53d43ab4bb6bde0eee","tid":2410851,"uid":51271,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2021-02-17T03:05:31.000Z","msg":"CCTVB大客"},"citedBy":0,"replyTime":"2021-02-17T05:28:51.000Z","msg":"viutv咪又係<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5cc26e66782b108e02e0ddce051670a9d2fcf31d","tid":2410851,"uid":71393,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-17T05:28:54.000Z","msg":"氣炸鍋應該差不多要收皮<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"8e0bce1543787f6a7b1d6cb12bceeb2d3573fcf7","tid":2410851,"uid":339053,"like":0,"dislike":1,"score":-1,"quote":{"pid":"5cc26e66782b108e02e0ddce051670a9d2fcf31d","tid":2410851,"uid":71393,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-17T05:28:54.000Z","msg":"氣炸鍋應該差不多要收皮<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-17T05:31:09.000Z","msg":"應該唔會<br />\n光波爐先係垃圾"},{"pid":"e019f9f0c15926272b365c9668e1cddc9da08a64","tid":2410851,"uid":304916,"like":0,"dislike":0,"score":0,"quote":{"pid":"4785956d43f24ec0a3052ee525c0440e1a2558d0","tid":2410851,"uid":194120,"like":11,"dislike":0,"score":11,"quote":{"pid":"bdea2f0ab679cfee038420ec6aae2c39bce276c7","tid":2410851,"uid":4942,"like":17,"dislike":0,"score":17,"citedBy":2,"replyTime":"2021-02-17T02:55:01.000Z","msg":"德國寶咪又係大陸劣質貨 <img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-02-17T03:04:57.000Z","msg":"名叫[德國]但唔係德國公司"},"citedBy":0,"replyTime":"2021-02-17T05:33:27.000Z","msg":"日本城 <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"567d3f22feb0303058af63150cc462dea11be6bc","tid":2410851,"uid":57554,"like":0,"dislike":0,"score":0,"quote":{"pid":"e993600f483cd22fae88167c487c0d9219a092d4","tid":2410851,"uid":20933,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-02-17T02:55:13.000Z","msg":"消委會：6款氣炸鍋炸薯條可致癌物丙烯酰胺超歐盟基準<br />\n<br />\n<img src=\"https://newsstatic.rthk.hk/images/mfile_1575991_1_20210217104926.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fnewsstatic.rthk.hk%2Fimages%2Fmfile_1575991_1_20210217104926.jpg&h=6113ac84&s={SIZE}\" /><br />\n<br />\n消委會測試12款氣炸鍋，發現6款樣本根據說明書的指示或代理商提供的食譜，氣炸急凍幼薯條的丙烯酰胺含量，即可能令人致癌的物質高於歐盟基準水平，其中一款超出13倍。<br />\n<br />\n消委會表示，12款氣炸鍋售價介乎298至2080元不等，樣本的整體表現相若，總評分介乎3.5至4.5分之間。消委會測試氣炸急凍幼薯條的丙烯酰胺含量，其中經「伊瑪牌Imarflex」氣炸後的薯條丙烯酰胺含量最高，達每公斤7038微克，比基準水平高約13倍，可能由於樣本食譜建議的烹調時間過長及溫度過高、烹調均勻度不足等原因，以致部分薯條炸至深啡色等。而「Harrow」及「德國寶German Pool」的薯條中的丙烯酰胺含量最低，但效能測試發現烹調後大部分薯條仍未煮熟。<br />\n<br />\n另外，消委會測試後發現，「普樂氏Proluxury」、「Harrow」及「Midea」的部分內部帶電部分與用戶可接觸部件之間的絕緣距離不足，可能增加短路的風險。<br />\n<br />\n「伊瑪牌Imarflex」回覆消委會表示，實際烹調時間及溫度應按照食物份量及個人口味而作出調整，說明書內建議的時間及溫度只供參考，又指說明書內的食譜是按外國人口味而設計。而「普樂氏Proluxury」、「Harrow」及「Midea」均表示，會改善說明書及生產流程。<br />\n<br />\n消委會建議消費者選購或使用氣炸鍋時，不能與其他高耗電量電器共用電源、每次氣炸食物勿超過氣炸鍋最高容量等。<br />\n<br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1575991-20210217.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1575991-20210217.htm&d=2uuoLuAEMU6cBVSXjgSp%2BW0Q%2Fwx8zutUsTDhO6XOofs%3D&h=303859e4\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1575991-20210217.htm&h=7da83f8d\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1575991-20210217.htm</a>"},"citedBy":0,"replyTime":"2021-02-17T05:34:36.000Z","msg":"呢個本身高溫烹調澱粉食物唔係已經會有咩<br />\n傳統油炸都會有"},{"pid":"aa7e441b5aeec2af6afbcd92bd3a783dcb20cd4a","tid":2410851,"uid":20933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-17T06:07:46.000Z","msg":"<img src=\"https://cdn.thestandnews.com/media/photos/cache/20210217-31_iWjeD_1200x0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2F20210217-31_iWjeD_1200x0.png&h=7ac715f2&s={SIZE}\" /><br />\n<br />\n<a href=\"https://youtu.be/-L-KKTAxl5I\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F-L-KKTAxl5I&d=2uuoLuAEMU6cBVSXjgSp%2BW0Q%2Fwx8zutUsTDhO6XOofs%3D&h=5cd3759a\" data-auto-link target=\"_blank\">https://youtu.be/-L-KKTAxl5I</a>"},{"pid":"4c3532d3efb14d2503e7ce41939a8eff2a48f569","tid":2410851,"uid":20933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-17T08:10:47.000Z","msg":"<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"e2409f153f1b02bc79bd23be2f7e0c6379898ae4","tid":2410851,"uid":4052,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-17T08:24:11.000Z","msg":"咁即係邊款最好?"},{"pid":"04735980ac135887d1e0bead1de60b1062fdd7d5","tid":2410851,"uid":355340,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e2409f153f1b02bc79bd23be2f7e0c6379898ae4","tid":2410851,"uid":4052,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-17T08:24:11.000Z","msg":"咁即係邊款最好?"},"citedBy":1,"replyTime":"2021-02-17T08:37:10.000Z","msg":"無<br />\n氣炸煮食根本唔安全,&nbsp;呢個就係點解美式快餐店唔改用氣炸薯條慳成本<br />\n人地 n 咁多間分店,&nbsp;慳咁多錢都唔用,&nbsp;因為比人告重大鑊"},{"pid":"b6d180801ecfabf19d0aa50c188e999fefb71e38","tid":2410851,"uid":92633,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-17T08:49:02.000Z","msg":"德 國寶"},{"pid":"a52a385229f85c336b9ca89b6998d51886d05362","tid":2410851,"uid":22554,"like":0,"dislike":0,"score":0,"quote":{"pid":"33d7f19ea27a8d9fbb0f5045976a7168a3d91e68","tid":2410851,"uid":56497,"like":3,"dislike":0,"score":3,"quote":{"pid":"916f5c4811f2e35ee8d8e0ad7dbbd8bb5e9b662a","tid":2410851,"uid":22554,"like":2,"dislike":0,"score":2,"quote":{"pid":"b8278e6ee939830d45c957fd443bbf406286be32","tid":2410851,"uid":25468,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2021-02-17T03:12:30.000Z","msg":"貴一倍都買 philps 用"