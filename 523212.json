t/upload/2018/01/08/182612_d25bd7d8adb1ef45965ff5d26b229cba.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F08%2F182612_d25bd7d8adb1ef45965ff5d26b229cba.png&h=ef30706c&s={SIZE}\" />"},{"pid":"6e2c7d55fd73f20ae263072df3e12205279408e5","tid":523212,"uid":14476,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-08T10:30:41.000Z","msg":"有無必要買其他小鏡頭？效果其實係咪有改善？我想知有無對成像有改善嘅accessories <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"877e18cbd4ba686878814c743d127c0820ad8c36","tid":523212,"uid":83426,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-01-08T10:34:20.000Z","msg":"此回覆已被刪除"},{"pid":"dceb136d04549daa1a7c357f42bbee90a2073ad2","tid":523212,"uid":33125,"like":17,"dislike":0,"score":17,"citedBy":1,"replyTime":"2018-01-08T10:37:08.000Z","msg":"樓主 d語氣有浸勁柒既除<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0e16773860b338e5e17ee494cfd18785a8bfa628","tid":523212,"uid":163107,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2018-01-08T10:52:48.000Z","msg":"<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" /><br />\n各位大師屌細力啲 小弟新手"},{"pid":"9235fd8a76abab086f1c8e3a8dc59b6649fd33d6","tid":523212,"uid":38569,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-08T11:05:50.000Z","msg":"樓主做邊行?<br />\n啲意念靈感點嚟 幾特別"},{"pid":"2b43aaed5ae32d9befe2d38940aeccb1a9b78200","tid":523212,"uid":165257,"like":0,"dislike":0,"score":0,"quote":{"pid":"6e2c7d55fd73f20ae263072df3e12205279408e5","tid":523212,"uid":14476,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-08T10:30:41.000Z","msg":"有無必要買其他小鏡頭？效果其實係咪有改善？我想知有無對成像有改善嘅accessories <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-08T11:16:48.000Z","msg":"如果唔好感覺太新手有幾個option：<br />\n<br />\n魚眼鏡自拍一定好過神棍或者就禁影，但係我寧願要個細架hold 住電話較時間+burst mode <br />\n你與你朋友感覺一定自然好多同埋之後再慢慢揀心水<br />\n<br />\n其實我都會用燈，但係懶，如果係屋企用最厲害既檯燈就算數，反正休閒之嘛邊個會理 :0)<br />\n<br />\n你可以買自拍專用燈，細細個好平，我會請一位黑仔既朋友幫我打燈跟住我用相機lol 但係算啦，電筒都無所謂<br />\n<br />\n其實都建議用flash，你之後搞搞vibrance 就會無啦啦變左潮人相🌚<br />\n<br />\n以前都試過買好多gimmick accessories，而家我只可以講，好快過時，唔係太值得花錢落去呢d 野<br />\n<br />\n完！"},{"pid":"1472e9cad0776e3c8766b4c5f289d29c25531868","tid":523212,"uid":165257,"like":0,"dislike":9,"score":-9,"quote":{"pid":"dceb136d04549daa1a7c357f42bbee90a2073ad2","tid":523212,"uid":33125,"like":17,"dislike":0,"score":17,"citedBy":1,"replyTime":"2018-01-08T10:37:08.000Z","msg":"樓主 d語氣有浸勁柒既除<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-01-08T11:18:39.000Z","msg":"多謝你 :&rsquo;) <br />\n通常都係俾人話有痴線除<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4becbb7c600af3f354114ed2d1d8f4bb3abd39d4","tid":523212,"uid":165257,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0e16773860b338e5e17ee494cfd18785a8bfa628","tid":523212,"uid":163107,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2018-01-08T10:52:48.000Z","msg":"<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" /><br />\n各位大師屌細力啲 小弟新手"},"citedBy":0,"replyTime":"2018-01-08T11:19:59.000Z","msg":"如果橫倒個感覺會有cinematic 氣氛呢 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\ntune 得幾好啊"},{"pid":"85f1c40d7621f34c1317aed6911ffb92d87ea873","tid":523212,"uid":165257,"like":0,"dislike":0,"score":0,"quote":{"pid":"9235fd8a76abab086f1c8e3a8dc59b6649fd33d6","tid":523212,"uid":38569,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-08T11:05:50.000Z","msg":"樓主做邊行?<br />\n啲意念靈感點嚟 幾特別"},"citedBy":0,"replyTime":"2018-01-08T11:20:17.000Z","msg":"你估下<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"eb9e3a50fce47f5d39b56bd87cf82c7846e401d0","tid":523212,"uid":120537,"like":1,"dislike":0,"score":1,"quote":{"pid":"1472e9cad0776e3c8766b4c5f2