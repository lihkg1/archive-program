s/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"9ad0d468f3f6fcdf6dbd70abb4612cf9528f1ece","tid":869501,"uid":166885,"like":0,"dislike":0,"score":0,"quote":{"pid":"b84cb7e2285585c225c61c367e97f3e5dfaeaa7e","tid":869501,"uid":54581,"like":0,"dislike":0,"score":0,"quote":{"pid":"d95d3e4910230a64d796ad0901fe77248a232b1f","tid":869501,"uid":166885,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-20T11:33:49.000Z","msg":"自學，而且無打算考試的話，就手就得。<br />\n<br />\n打kick 呢方面，就花d時間係你想彈既譜度，慢慢彈一次，即使慢兩三倍都ok，需要既話就搵位mark低。<br />\n<br />\n隻手會有肌肉記憶，彈慢d，彈多d就會去到下個音。"},"citedBy":1,"replyTime":"2018-10-21T03:22:18.000Z","msg":"多謝巴打！<br />\n<br />\n想問多句， 想練拍子感 同 左右手協調既話<br />\n<br />\n有無邊幾首入門可以練下<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-21T07:52:45.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 無彈鋼琴，不過音樂呢家嘢，係靠練<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> 。<br />\n<br />\n就算彈自己中意既歌，都可以練得熟，甚至叻。鋼琴就算同一首歌，唔同既力度，表達既都可以唔同，呢個先係人之間既差別。<br />\n<br />\n<br />\n<br />\n<br />\n想練基本功就買本bb書去睇睇啦。"},{"pid":"ef49f559358ef10b47d4ee00336a43f259a2002f","tid":869501,"uid":11581,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-21T11:10:22.000Z","msg":"巴絲有咩問題都可以入group問下意見<br />\n我開左個group 俾咁多位對鋼琴有興趣既巴絲交流<br />\n<br />\n<a href=\"https://t.me/joinchat/AAAAAEns5wGtx57NmvsuCg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fjoinchat%2FAAAAAEns5wGtx57NmvsuCg&d=5EGntYUulLQvs09k28hCewRJEaK469wi7EMLOMkgk88%3D&h=275f6f67\" data-auto-link target=\"_blank\">https://t.me/joinchat/AAAAAEns5wGtx57NmvsuCg</a>"}]}