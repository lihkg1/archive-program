\" />"},{"pid":"499579e0491165971e89b045a59da87b8a183d9b","tid":45243,"uid":3799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:01:54.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2016/12/19/200132_a1a5f3ff866a23b05aef3ed2d23aeea5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2016%2F12%2F19%2F200132_a1a5f3ff866a23b05aef3ed2d23aeea5.jpg&h=28531673&s={SIZE}\" /><br />\n<br />\n依家坐係海濱 自己一個坐下"},{"pid":"d15cd0ac5680c42ecc7f758106fae5d174daebb0","tid":45243,"uid":13327,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:03:38.000Z","msg":"巴打20生日？<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"0216ccdd11e46808069e4ecbbcc4fa1f58fc2ddc","tid":45243,"uid":3799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:04:04.000Z","msg":"<blockquote>巴打20生日？<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n係"},{"pid":"098851c5a16fb0c380cb901d5535600d9597e4a0","tid":45243,"uid":12628,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:04:04.000Z","msg":"兄弟撐你<img src=\"/assets/faces/big/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"77d7bbd9610d268f1d86bf8874c8a2c130f3deb4","tid":45243,"uid":17306,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:04:35.000Z","msg":"生日快樂呀<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n巴打早日振作<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"7d5c5ebe4412f715f1eb9a857cdf7fc278230bf1","tid":45243,"uid":13327,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:05:18.000Z","msg":"<blockquote><blockquote>巴打20生日？<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n係</blockquote><br />\n<br />\n<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> 我都係<br />\n生日快樂🎁<br />\n坐多陣好返屋企沖涼喇<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" />"},{"pid":"e05476af7fc3caa4cfecb49bfacea62f4849a102","tid":45243,"uid":3799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:06:08.000Z","msg":"<blockquote><blockquote><blockquote>巴打20生日？<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n係</blockquote><br />\n<br />\n<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> 我都係<br />\n生日快樂🎁<br />\n坐多陣好返屋企沖涼喇<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n我自己一個嘅時候,我就會想喊<br />\n我唔想返屋企,我想一直坐係度"},{"pid":"65cb778fac0d1270eb25b6c8dad80ac19f88a448","tid":45243,"uid":44368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:08:54.000Z","msg":"好彩只係十個月"},{"pid":"bd32142f56c4d4c1a428da81086fe28120f507c2","tid":45243,"uid":13327,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:09:42.000Z","msg":"<blockquote><blockquote><blockquote><br />\n<br />\n係</blockquote><br />\n<br />\n<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> 我都係<br />\n生日快樂🎁<br />\n坐多陣好返屋企沖涼喇<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n我自己一個嘅時候,我就會想喊<br />\n我唔想返屋企,我想一直坐係度</blockquote><br />\n<br />\n喊飽好走喇<br />\n你喊多<br />\n我公升眼淚佢都唔會返黎<br />\n喊埋呢幾個鐘  好做返啲正經野<br />\n身邊仲有好多人值得你關心留意嫁<img src=\"/assets/faces/lomoji/14.png\" class=\"hkgmoji\" />"},{"pid":"d8c92c38ba6049cdcd35698d908ac8ce0c730065","tid":45243,"uid":60796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:10:50.000Z","msg":"生日唔快樂就喊啦 喊左舒服啲<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"9f5830ff6689a115a0b708f323fd401b0b191acd","tid":45243,"uid":52490,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-19T12:11:19.000Z","msg":"巴打加油 我明白分手既時候有幾辛9苦<br />\n撐住呀<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\nBtw happy birthday"},{"pid":"498fa92602e9d8fe290a6b0875590f67e8e107c5","tid":45243,"uid":17945,"like":0,"dislike":0,"scor