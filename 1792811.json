nail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJeGOPgR.jpg&h=42b2dd37&s={SIZE}\" />"},{"pid":"4bf43269bbff236a5e4e302c015804ed64814355","tid":1792811,"uid":205482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-22T02:56:52.000Z","msg":"【和解】關於街頭抗爭一事<br />\n<a href=\"https://lih.kg/1792823\" data-auto-link target=\"_blank\">https://lih.kg/1792823</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"5d4317824919f87212335615467aa1317fc79400","tid":1792811,"uid":123456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-22T02:57:44.000Z","msg":"<span style=\"font-size: xx-large;\">驚嘅話<br />\n上面噴陣膠/灑啲幼鹽噴膠應該會好啲？</span>"},{"pid":"705edb9b344154803b3ff58ccc95764be9f4ddd4","tid":1792811,"uid":271516,"like":0,"dislike":0,"score":0,"quote":{"pid":"33e66bde9c84268da6a3c872af31f93896338702","tid":1792811,"uid":57677,"like":0,"dislike":0,"score":0,"quote":{"pid":"675200e612d0ec24995366f28bd96f082e781b91","tid":1792811,"uid":27349,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-22T02:49:46.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2019-12-22T02:55:50.000Z","msg":"<img src=\"https://na.cx/i/JeGOPgR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJeGOPgR.jpg&h=42b2dd37&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-12-22T03:27:04.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"71611b2f34f45c955319a0e9eebdd0586f3fa1c5","tid":1792811,"uid":27349,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2019-12-22T03:38:44.000Z","msg":"此回覆已被刪除"},{"pid":"570a48042291b81e3be4d04514c15458beaa06d6","tid":1792811,"uid":151074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-22T03:41:02.000Z","msg":"#不是劇透 #必須看到尾<br />\n#入戲院前你要知的小背景<br />\n<br />\n【無雷】你不能不知道的＜葉問4＞基礎認識<br />\n<br />\n葉問得了癌症，偏偏兒子不學好，在學校打架鬧事，慘遭學校退學。葉問只好接受弟子李小龍的邀請，去美國為兒子申請學校，豈知華人到了美國受盡歧視，處處碰壁。<br />\n<br />\n李小龍於美國出書，收鬼佬徒弟教功夫，引起唐人街華人武術界不滿。李小龍因此得罪了中華總會會長萬宗華。葉問與萬會長相識之初，因為對於中華傳統武術意見不合，隨即展開了一場詠春對戰太極的戲碼，萬會長發現葉問受傷了，直接收起一隻手跟對方打。<br />\n<br />\n葉問拿不到萬會長的推薦信，無法讓兒子葉正入學。人在異鄉的葉問很想聽到兒子的聲音，可是每次的長途電話都被兒子拒絕接聽，父子關係惡劣。<br />\n<br />\n這時，李小龍的美軍徒弟吳建豪，想將詠春引入美國部隊，受空手道教官打壓，派人去唐人街踢館，被葉問狠狠教訓，挑起了美國海軍陸戰隊跟唐人街的仇恨。<br />\n<br />\n美國軍官趁著中秋晚會把會長綁走，並且打趴了所有會中的武師，找移民局拉人。這時葉問出馬，打趴了挑釁的美國人，美國人又把會長綁入海軍陸戰隊，並且打到重傷。葉問看不下去，認為中國人不能再被欺侮，於是叫吳建豪把他帶入海軍陸戰隊，美國人跟葉問一番激戰之後，再度打趴美國人。<br />\n<br />\n葉問解救了中華總會的貌美女兒若男，但還是無法讓萬宗華會長點頭寫推薦信。<br />\n<br />\n於是，葉問放棄了兒子的留學計劃，決定回香港並與兒子和好，教授兒子葉正畢生絕學，還叫他兒子用機器拍攝。最後，葉問在79歲因癌症去世，畫面切換至徒弟李小龍祭拜，然後開始播放前幾集畫面，包括洪金寶、黃曉明、熊黛林等場景。全劇完。<br />\n<br />\n#不是劇透<br />\n#不要share<br />\n#share了觀眾便不會購票"},{"pid":"44eb8f05e014cc0d4338a62cbb934d879fd478d4","tid":1792811,"uid":57677,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-22T03:44:43.000Z","msg":"真心已經唔識得分回覆的曲直<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"}]}