:22.000Z","msg":"早瞓最重要"},{"pid":"63f7b5eb66a8b1b99067680d9f4497d681f95b1a","tid":602800,"uid":41684,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f81dcea2e3b7cd75695853d25bae8f1ead951f9","tid":602800,"uid":141594,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-23T13:37:22.000Z","msg":"早瞓最重要"},"citedBy":1,"replyTime":"2018-03-23T13:41:00.000Z","msg":"早訓都無用 我有年半晚晚9點幾訓"},{"pid":"f2b9904355ad7b64a7dc988aaca0499055a6dc8e","tid":602800,"uid":1590,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-03-23T13:57:45.000Z","msg":"我之前有邊面有好多而且範圍好大既一堆啡色印，<br />\n幾年來有增無減。<br />\n<br />\n但有一排的起心肝去試護膚品。<br />\n睇得出令我有轉變既係<span style=\"font-size: x-small;\">clinique 維C精華，kiehl's 既護濕精華、晚間修復精華</span><br />\n我用左第一樣野大約一個月鬆啲，本身都係啲冇咁耐歷史既印淡左/冇左、面色均勻返少少。<br />\n但之後有兩個星期用埋後面個兩樣，用到冇哂之後，<br />\n我發現個一大堆啡色印變到極淡，成個面色都均勻返唔會有暗沉位。<br />\n以前用遮瑕膏遮好耐都遮唔到既印，呢家上一層粉底就見唔到，成堆野變左便淡淡既粉紅色。<br />\n<br />\n不過呢啲睇人，我都有見呢三枝野唔係人人讚。<br />\n<br />\n但因為呢啲野都唔平，我又本身冇乜錢，所以冇繼續用<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n好想做laser同埋海草乜乜針<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4e5f1b57d18b87ad721f1f19f0b3fd73e730d1c2","tid":602800,"uid":141594,"like":0,"dislike":0,"score":0,"quote":{"pid":"63f7b5eb66a8b1b99067680d9f4497d681f95b1a","tid":602800,"uid":41684,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f81dcea2e3b7cd75695853d25bae8f1ead951f9","tid":602800,"uid":141594,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-23T13:37:22.000Z","msg":"早瞓最重要"},"citedBy":1,"replyTime":"2018-03-23T13:41:00.000Z","msg":"早訓都無用 我有年半晚晚9點幾訓"},"citedBy":0,"replyTime":"2018-03-23T13:57:49.000Z","msg":"我都係，但係我淡咗好多喎"},{"pid":"b9fccd67c1e8a2ae1a65a6dea2463a6e717a210c","tid":602800,"uid":159333,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-23T14:23:25.000Z","msg":"First aid beauty幾保濕啊"},{"pid":"cc95bbb5b26aca89d51607807b4e2d1c3254d769","tid":602800,"uid":14153,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-0