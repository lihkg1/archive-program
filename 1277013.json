"},{"pid":"6bd20661b2ca97d3d27fba4b1bd1afbf6d492523","tid":1277013,"uid":11818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T06:08:48.000Z","msg":"無錯 連登仔係金鐘搞事<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n不過係m記party<br />\n<img src=\"https://na.cx/i/pmYs0i7.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpmYs0i7.png&h=5aba0e6f&s={SIZE}\" />"},{"pid":"54a0d3ffafc2808db9f4be78ec2876b5d4195702","tid":1277013,"uid":262086,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T06:09:20.000Z","msg":"愛國愛黨<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}