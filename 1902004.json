lass=\"hkgmoji\" /><img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"50b3123bb0d75ce45ac900f34837a2c6e9aef392","tid":1902004,"uid":24160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T10:18:37.000Z","msg":"幾時嘅事?? 我依家出街都熄咗face id<br />\n<br />\n一直都recognize 唔到"},{"pid":"b0fdf15a8f66d8c7724d70c9074573ba81365490","tid":1902004,"uid":50660,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T10:20:39.000Z","msg":"仲未得<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"719df489cf649239ddf2cdcfa89ad0a339c77ac0","tid":1902004,"uid":231522,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T10:22:01.000Z","msg":"冇用好耐"},{"pid":"0ce082c23a50c1d047993b6fcb43bb40e5ffd09f","tid":1902004,"uid":170247,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2020-02-28T10:30:59.000Z","msg":"香港人仲用face id?"},{"pid":"d950c25bbb68e68f1ef95fa94faaf09fbd10f5d8","tid":1902004,"uid":142712,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-28T11:11:59.000Z","msg":"冇用face id好耐"},{"pid":"c6304fd4b65900e1795b213575f31359ebcec2f1","tid":1902004,"uid":21309,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T13:20:39.000Z","msg":"上個禮拜開始得"},{"pid":"ff0195770ae094f6c51fa4ba3cb2c45106bc38ec","tid":1902004,"uid":283725,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-03-02T01:37:42.000Z","msg":"你地係咪次次成功。 我成功率低於20%"}]}