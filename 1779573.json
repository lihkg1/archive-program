a993f5feb16769b76b135b122f571bc73789","tid":1779573,"uid":290393,"like":0,"dislike":0,"score":0,"quote":{"pid":"21fe9eed0ce253684e18a856c0312df409b3db9b","tid":1779573,"uid":65210,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-12-11T18:26:56.000Z","msg":"唔好習慣 唔好咁快遺忘<br />\n求求各位手足<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-11T18:45:33.000Z","msg":"其實你講得好好, 支持你 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d91df6538aa326d1560a6ecc0a680fc55990ae5b","tid":1779573,"uid":31655,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-11T18:48:08.000Z","msg":"<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" />"},{"pid":"bb797031f30437f7fc5beabc4bba1affe1f7264b","tid":1779573,"uid":184433,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-11T18:52:29.000Z","msg":"推"},{"pid":"0c4176836a01608a8e2e6372c1ac97781b4fd2d0","tid":1779573,"uid":46042,"like":0,"dislike":0,"score":0,"quote":{"pid":"ac918a61019637cf41206245e9e624356628f53c","tid":1779573,"uid":42149,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-11T18:42:58.000Z","msg":"老老實實<br />\n呢啲po 係要po 多啲<br />\n而家個feel 好唔良好"},"citedBy":1,"replyTime":"2019-12-11T18:55:58.000Z","msg":"而家個感覺直頭完。。。"},{"pid":"a31317e8be768d4f3fa4f40bbfa16687dedc8c57","tid":1779573,"uid":24572,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-11T18:57:52.000Z","msg":"推<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" /><br />\n冇冷卻同分化嘅成本了"},{"pid":"facba2b63be5e20c8a6cae8d2b51cd3909c51b20","tid":1779573,"uid":135277,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-11T19:01:21.000Z","msg":"睇連燈以為運動完q咗"},{"pid":"4e874990c4cbf5618456ba03cafd97903d656ca7","tid":1779573,"uid":267423,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-11T19:26:07.000Z","msg":"唔會停<img src=\"/assets/faces/pig/sick.gif\" class=\"hkgmoji\" />"},{"pid":"e015df0f390afc7a6a18b0feaefe5b02438dbc8b",