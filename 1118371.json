l/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c2f7c61b5ef1ba6110b8acbed878b4fb4bc34329","tid":1118371,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"09aed80c46688add5162201ac56b8ed5e7554e2c","tid":1118371,"uid":235152,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-21T11:31:48.000Z","msg":"韓國瑜去中聯辨時已通知左<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-21T12:19:53.000Z","msg":"<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"5d4e7281f6bb5f77b1c36a8da47fdfd22899f912","tid":1118371,"uid":35790,"like":0,"dislike":0,"score":0,"quote":{"pid":"c2f7c61b5ef1ba6110b8acbed878b4fb4bc34329","tid":1118371,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"09aed80c46688add5162201ac56b8ed5e7554e2c","tid":1118371,"uid":235152,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-21T11:31:48.000Z","msg":"韓國瑜去中聯辨時已通知左<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-21T12:19:53.000Z","msg":"<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-21T12:40:23.000Z","msg":"入得中聯辦<br />\n預咗唔選總統？"},{"pid":"555f74effc542bef416c2994bc33f1dcf202415b","tid":1118371,"uid":245310,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-04-21T12:45:29.000Z","msg":"蔣介石翻生見到而家國民黨即刻同你死多次<br />\n由反共變奶共<br />\n華人d劣根性真係痴撚線<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4e21914f816d72bd626b74ea6f31cfedc6d783e0","tid":1118371,"uid":3020,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-21T12:57:00.000Z","msg":"想要新軍備？<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n發緊夢擺明雙殺"},{"pid":"5ede00ec045b3817ced447a06b8511936fc5e36b","tid":1118371,"uid":141151,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d4e7281f6bb5f77b1c36a8da47fdfd22899f912","tid":1118371,"uid":35790,"like":0,"dislike":0,"score":0,"quote":{"pid":"c2f7c61b5ef1ba6110b8acbed878b4fb4bc34329","tid":1118371,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"09aed80c46688add5162201ac56b8ed5e7554e2c","tid":1118371,"uid":235152,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-21T11:31:48.000Z","msg":"韓國瑜去中聯辨時已通知左<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-21T12:19:53.000Z","msg":"<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-21T12:40:23.000Z","msg":"入得中聯辦<br />\n預咗唔選總統？"},"citedBy":0,"replyTime":"2019-04-21T13:21:28.000Z","msg":"推左走右"},{"pid":"8121588cb52f2442b355cb0a9d3b3599f15edb96","tid":1118371,"uid":35790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-21T15:56:49.000Z","msg":"富士康設共黨支部 郭參選引發疑慮<br />\n<br />\n2019-04-19<br />\n<br />\n〔記者鍾麗華、高嘉和、卓怡君／台北報導〕鴻海集團董事長郭台銘宣布投入國民黨內總統初選，但中國富士康內部設有「中共黨支部」組織，引發外界對郭董參選的疑慮。陸委會副主委兼發言人邱垂正昨在例行記者會表示：「大陸相關上市企業集團如果有設置黨支部，對該事業有何影響，宜由該事業集團來對外說明，目前沒有相關評論。」<br />\n<br />\n某工總常務理事坦言，台商在中國被視為「特殊的內資企業群體」，歐美外商可抗拒，但台商多只能照辦，目的是找人幫忙排解疑難雜症。<br />\n<br />\n據中國官媒「新華網」報導，富士康科技集團的黨委成立於二○○一年十二月十五日，截至二○一七年九月，在全國各園區共建立十六個黨委、二百二十九個黨總支、一○三○個黨支部，在冊黨員三萬餘人。<br />\n<br />\n中媒曾報導，中國約一百八十六萬私營企業中，截至二○一七年近七十％有黨組織，而中國證監會去年進一步公布新修訂的「上市公司治理準則」，要求上市公司須設立共產黨組織，進一步強化「企業姓黨」政策。中共去年底也頒布「中國共產黨支部工作條例（試行）」，要求所有企業、社會組織、學校等基層組織設立「黨支部」，引外界質疑是否走回「封閉集權」的老路。<br />\n<br />\n一位工總常務理事指出，不只富士康，達一定規模以上台商都難免被迫要成立黨組。他舉例說，就如同台灣早年國民黨威權統治時代，在政府機關、學校，甚至工商團體都有黨組織；中國是一黨專政，到當地做生意入境隨俗，這應該不算奇怪吧！<br />\n&lt;自由時報&gt;"},{"pid":"c1503972587a7ef340784e8f93f4992a665c7a99","tid":1118371,"uid":174418,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-21T16:31:25.000Z","msg":"郭台銘玩完"},{"pid":"2d49c8ee9413e0a52aa64deb9504d189335d7b56","tid":1118371,"uid":35790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-21T16:42:15.000Z","msg":"台灣發大財"}]}