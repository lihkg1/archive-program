ANMASK #新型冠狀病毒<br />\n<br />\nSource:  RTHK"},{"pid":"abda9fb174a40d005e7ebf441de06a6e211edde0","tid":1852650,"uid":261969,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T15:12:17.000Z","msg":"罰款了事，賣幾十盒啲錢已經返嚟"},{"pid":"d1739c0569c133a89e94c48fbeb3efdc533deabf","tid":1852650,"uid":50218,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T15:13:23.000Z","msg":"<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"ecef9a23ef5704059b1419370615ee4db5d0725b","tid":1852650,"uid":53705,"like":12,"dislike":0,"score":12,"quote":{"pid":"a06e768bcf49b503211cb40a3d25301b1fce06d0","tid":1852650,"uid":51271,"like":117,"dislike":2,"score":115,"citedBy":3,"replyTime":"2020-01-30T14:09:26.000Z","msg":"2020年3月生產<img src=\"/assets/faces/lny/tongue2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/tongue2.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-01-30T15:13:54.000Z","msg":"個老細真係好人<br />\n<br />\n知道香港人無口罩, 特登坐時光機去未來拎<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"fe013370dc9a798ebe1badf7da6f15f30ef3e5b9","tid":1852650,"uid":113257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T15:15:59.000Z","msg":"食人血饅頭嘅賤種<img src=\"/assets/faces/lny/offtopic.gif\" class=\"hkgmoji\" />"},{"pid":"bb7f798549131c8210dd95267148cea19df61b58","tid":1852650,"uid":21545,"like":0,"dislike":0,"score":0,"quote":{"pid":"4aac008a8a6b23abfb69c60996c159d67b627b7b","tid":1852650,"uid":291656,"like":0,"dislike":0,"score":0,"quote":{"pid":"be62f7f1d83001f03fac643b9a9dde0d6b36f4aa","tid":1852650,"uid":21545,"like":0,"dislike":0,"score":0,"quote":{"pid":"72f3f8b254724cafd28f5d4c142084b6af5b5ef4","tid":1852650,"uid":137604,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-30T14:15:48.000Z","msg":"幾時到你？"},"cited