IZE}\" />"},{"pid":"c29dcfcb5085f601552d4d68b59235d32342b187","tid":1049903,"uid":19527,"like":0,"dislike":2,"score":-2,"quote":{"pid":"86aabd9a06ef9029dd619920f05e127fe7e431b9","tid":1049903,"uid":149494,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2019-03-06T15:27:32.000Z","msg":"支持bam咗樓主<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-06T15:34:04.000Z","msg":"五毛駁唔到就想bam人<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"14fea88fdf8ad3b440c2787a3936a8d8880e21fe","tid":1049903,"uid":154106,"like":0,"dislike":0,"score":0,"quote":{"pid":"95bc32b15087b3b53e6e96f042ef13901aeaf6f3","tid":1049903,"uid":19527,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-06T15:17:43.000Z","msg":"<a href=\"https://www.yousign.org/China-Lunatic-punches-dog-to-death-in-front-of-his-daughter-sign-now-t-4358\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.yousign.org%2FChina-Lunatic-punches-dog-to-death-in-front-of-his-daughter-sign-now-t-4358&d=iefYBA3dMTKG%2BriJzBrQhT2nqaxvu5zgGSEBmbQkQbg%3D&h=ac5d9a04\" target=\"_blank\">https://www.yousign.org/China-Lunatic-punches-dog-to-death-in-front-of-his-daughter-sign-now-t-4358</a><br />\n支那呢一個地球毒瘤真係應該用核彈徹底毀滅<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-06T15:44:16.000Z","msg":"香港咁近，你想香港中輻射？"},{"pid":"2fd3cc1444d8f263842caa84f5c104f8646ee6ec","tid":1049903,"uid":195915,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-06T15:47:21.000Z","msg":"唔止支那狗香港都有人虐貓虐狗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"640159262964591c3cd3793751bc74ddb8850efb","tid":1049903,"uid":73089,"like":0,"dislike":0,"score":0,"quote":{"pid":"1d3a51339bb904328c5f8168d7a95245f4ed98e6","tid":1049903,"uid":11310,"like":11,"dislike":9,"score":2,"citedBy":1,"replyTime":"2019-03-06T15:31:19.000Z","msg":"<img src=\"https://na.cx/i/7t9GcMH.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7t9GcMH.png&h=05f3c622&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-03-06T15:49:52.000Z","msg":"i love dogs only"},{"pid":"d455c64248215a94c2938c77da07e9d2fb44b522","tid":1049903,"uid":14918,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-03-06T15:50:33.000Z","msg":"香港都在討論，到底怎樣才算愛國。 做一個愛國的香港中國人，其中一個標準，很簡單的，就是看你喜不喜歡吃狗肉，以及在看見其他中國人屠宰狗隻的時候，是毫無感覺，還是覺得憤慨。 做一個完整的中國人，不要忘記，是愛吃狗肉的。中國人仇恨狗隻：一九六七年，香港左派大暴動，不，「反英抗暴」愛國同胞，其中一條口號，除了叫英國人為「白皮豬」，還對香港的警察高喊：生劏黃皮狗。中國人不喜歡狗：「關門打狗」和「仗義每多屠狗輩」等仇狗諺語，有一大籮。 今日許多香港人，視狗為寵物，是因為受了「英國殖民主義者」長期洗腦。英國人領治香港時，將屠狗列為非法，是明擺著的反華行為。一九九七年「中國人民當家作主」之後，還繼續親英崇洋，梁班子還不敢將吃狗肉非刑事化，可見英國人雖然撤出，但英式文明的餘威猶存。這一點，我佩服英女皇。 大陸上的中國人均勇於食狗肉。他們認為：如果屠狗殘忍，劏豬殺牛，不也一樣？我認為此一中國邏輯，並無瑕疵。 不錯，狗善解人意，但所謂「狗是人類忠誠的朋友」，是英國人的感受。中國人對狗之搖尾乞憐，不視之為「忠誠」，而視之為諂媚的奴性。你是中國人嗎？對於吃狗肉這個民族的大是大非問題，你屁股坐哪一邊，即刻能測試出來。 我曾經教唆香港的中國大陸新移民，告訴他們：當你們抽到了公屋之後，不妨在走廊或你家的廚房，活殺一隻狗。吃狗肉，是你身為中國人天生的權利。香港禁食狗肉，是一條親英反中的惡法，你是中國人，你要公民抗命。 我說：如果有人投訴，你就駁斥：吃狗肉是中國文化，抓人，你可以笑嘻嘻，你叫他們「包容」。如果有警察上門，提醒警察：一九六七年，你們是愛國中國人眼中的黃皮狗，你抓我，是想報復，此一歷史仇怨，還是想維護同類呀？ 看見五星旗而流淚，喜食狗肉，或至少看見屠狗而無動於衷，而不是反過來，我認為，是衡量一個「中國人」的兩大標準。香港遍地的龍獅旗，香港人又那麼愛狗，而且還影響了大陸的九十後，令他們也像西方一樣，厭惡及歧視嗜食狗肉的中國同胞，可見，人心回歸是如何艱難。"},{"pid":"1a98ab72914358a0c3cae40e478f5260fccedec6","tid":1049903,"uid":228831,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-03-06T15:56:45.000Z","msg":"死大陸閪我屌撚穿佢老母個臭化爛閪生條死仆街出黎<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"d41ef40ba1201a5f6b6e9b888cd44e7e6f87d3dc","tid":1049903,"uid":136760,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-03-06T16:02:57.000Z","msg":"唉 寧願冇睇過條片<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"ca9a56845e6b024b8a99619c78237601a8d505cd","tid":1049903,"uid":228831,"like":0,"disli