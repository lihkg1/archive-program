1.000Z","msg":"4/10"},{"pid":"ab0189be5a544ad8be27777f5f445b866fba0ce5","tid":1626034,"uid":171347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T09:39:52.000Z","msg":"要沉了"},{"pid":"e5f8e73d86326648cce608fad99b27862678998a","tid":1626034,"uid":206409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T09:44:08.000Z","msg":"<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"22760059aa5d1ffb3b1545f184cc5ad089f99b42","tid":1626034,"uid":171347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T09:45:26.000Z","msg":"上返去呀"},{"pid":"ba440847b112d80bc20de79e8fc5e6f522660cd3","tid":1626034,"uid":171347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T09:50:01.000Z","msg":"唔好行錯棋呀<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"c39a3301ca7d4ea912f444138ece6aea3e924a39","tid":1626034,"uid":171347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T09:54:30.000Z","msg":"有冇人俾意見呀<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"0bce42933ab154cc0f385c6c48b5188eb99117e3","tid":1626034,"uid":14494,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-05T09:58:08.000Z","msg":"仲有之前既印尼文文宣，106宜合理非"},{"pid":"e57619aa9b40d1ff188c7fcd217804fb4fd8238c","tid":1626034,"uid":330856,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-05T10:20:42.000Z","msg":"同意和理非行動（無論遊行定集會都好）<br />\n<br />\n一嚟要畀前線休息回血<br />\n二嚟要畀時間美國盡快通過人權法，唔好令件事distract咗去其他嘢到或者令美國難做<br />\n首先唔好挑釁警察，唔好同警察對峙，我哋冇能力同警察正面衝突，咁做會越嚟越傷<br />\n內心雖然憤怒，但行動要夠冷靜<br />\n<br />\n但萬一係警察主動挑釁（e.g. 突然由車上衝出嚟制服咩都冇做過嘅人然後搜身），咁可以點應對？<br />\n點樣可以keep住be water？"},{"pid":"a164544a9932f32c590c35590211ab9ce537eb4d","tid":1626034,"uid":171347,"like":0,"dislike":0,"score":0,"quote":{"pid":"e57619aa9b40d1ff188c7fcd217804fb4fd8238c","tid":1626034,"uid":330856,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-05T10:20:42.000Z","msg":"同意和理非行動（無論遊行定集會都好）<br />\n<br />\n一嚟要畀前線休息回血<br />\n二嚟要畀時間美國盡快通過人權法，唔好令件事distract咗去其他嘢到或者令美國難做<br />\n首先唔好挑釁警察，唔好同警察對峙，我哋冇能力同警察正面衝突，咁做會越嚟越傷<br />\n內心雖然憤怒，但行動要夠冷靜<br />\n<br />\n但萬一係警察主動挑釁（e.g. 突然由車上衝出嚟制服咩都冇做過嘅人然後搜身），咁可以點應對？<br />\n點樣可以keep住be water？"},"citedBy":0,"replyTime":"2019-10-05T10:39:23.000Z","msg":"好睇形勢同勇武人數<br />\n最主要係當時目的同埋真勇武夠唔夠人<br />\n如果係打hit and run既話就更加唔應該理。狗一定要清算，但so far我地打陣地<strong>從來都冇贏過</strong>。<br />\n咩都冇做過嘅人俾狗搞其他日日都有，如果係和理非要有心理準備會俾人無限問候，但係真勇武俾狗捉到就67。"},{"pid":"7f8ae4cf2b8fabb86c88f034a030c3f182df42c4","tid":1626034,"uid":67454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T10:41:09.000Z","msg":"推"},{"pid":"d78cfa2c8d15d77b258684760adaa185f8eaa16c","tid":1626034,"uid":171347,"like":0,"dislike":0,"score":0,"quote":{"pid":"e57619aa9b40d1ff188c7fcd217804fb4fd8238c","tid":1626034,"uid":330856,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-05T10:20:42.000Z","msg":"同意和理非行動（無論遊行定集會都好）<br />\n<br />\n一嚟要畀前線休息回血<br />\n二嚟要畀時間美國盡快通過人權法，唔好令件事distract咗去其他嘢到或者令美國難做<br />\n首先唔好挑釁警察，唔好同警察對峙，我哋冇能力同警察正面衝突，咁做會越嚟越傷<br />\n內心雖然憤怒，但行動要夠冷靜<br />\n<br />\n但萬一係警察主動挑釁（e.g. 突然由車上衝出嚟制服咩都冇做過嘅人然後搜身），咁可以點應對？<br />\n點樣可以keep住be water？"},"citedBy":0,"replyTime":"2019-10-05T10:41:52.000Z","msg":"戰略po我應該會另外再出，但依家形勢大方向應該係對外做好文宣先，再係咁好容易流失淺黃街坊同係國際線out focus左。"},{"pid":"7b7eae427ab20bf665c4733ed7985c65ca6e05a6","tid":1626034,"uid":171347,"like":0,"dislike":0,"score":0,"quote":{"pid":"0bce42933ab154cc0f385c6c48b5188eb99117e3","tid":1626034,"uid":14494,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-05T09:58:08.000Z","msg":"仲有之前既印尼文文宣，106宜合理非"},"citedBy":0,"replyTime":"2019-10-05T10:43:37.000Z","msg":"呢幾日發生好多事，隔離有話文宣組根本未追得上，唔好為打要打，該停就停，和勇要無限輪迴。"}]}