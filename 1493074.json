aces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3a968d5f019de49eb438e2e0874a9708f3fc9852","tid":1493074,"uid":135276,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-08-21T06:01:36.000Z","msg":"支持警察<br />\n吞槍自殺"},{"pid":"da115b899d8b6b2be232f5143cbdf8b04bd4fdbe","tid":1493074,"uid":51039,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T06:02:12.000Z","msg":"對香港警犬無效<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"4b57d0979bdf03d424d018f30e45247ff7e2bb7b","tid":1493074,"uid":54927,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T06:02:56.000Z","msg":"原來全世界都有死全家<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"ba49884100b5367927f4043b6303bb130ec3d76c","tid":1493074,"uid":279616,"like":0,"dislike":0,"score":0,"quote":{"pid":"393b731fb8622fbfa66721b7ed7c3cc43aec61c1","tid":1493074,"uid":271857,"like":10,"dislike":0,"score":10,"citedBy":2,"replyTime":"2019-08-21T06:00:32.000Z","msg":"香港警察可以濫用暴力打巿民，又無自尊正直人格的心，點會有勇氣自殺?自殺嗰啲都係爭人周身債嗰啲。"},"citedBy":0,"replyTime":"2019-08-21T06:05:26.000Z","msg":"重申七一宣言，設立死線，立即實行雙普選<br />\n<br />\n「勇武派」、「和理非」係角色，唔係派系，理念一致，只係手法不同<br />\n<br />\n唔係仇警，大家一定要清楚知道點解要清算警隊。警暴（濫捕、濫告、不依法規）係暴政一部分，唔全面改革警隊、監警制度，只會令目前同將來爭取雙普選更加舉步維艱<br />\n<br />\n所以，絕對唔需要否認自己係針對警隊，針對警隊就係對準政權。唔通你淨係針對林鄭、唔針對政制，就會有雙普選？<br />\n<br />\n#五大訴求 缺一不可<br />\n#唔撤就罷<br />\n#罷工罷巿罷買罷課<br />\n#我係香港人<br />\n#我參與全港四罷<br />\n#各區集會<br />\n#出核彈麻包袋都唔割蓆<br />\n#直至政府跪低<br />\n#重組警隊 刑事追究 改革監警制度<br />\n#永遠不光顧荃灣北角元朗商戶<br />\n#抵制一切紅媒相關商業活動"},{"pid":"8d824b0668f4c87dec399e434c5975728cd28179","tid":1493074,"uid":116198,"like":2,"dislike":0,"score":2,"quote":{"pid":"9132931ed24d9b7a912818e85904cd9b07b37df0","tid":1493074,"uid":82482,"like":114,"dislike":1,"score":113,"citedBy":2,"replyTime":"2019-08-21T05:57:14.000Z","msg":"放心,香港班畜生唔知咩叫羞恥"},"citedBy":0,"replyTime":"2019-08-21T06:06:16.000Z","msg":"班克警有職升, 賣佢老婆俾上司屌都肯"},{"pid":"8936394b854d1d9a431a5c82c15986e6e072304f","tid":1493074,"uid":271857,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2019-08-21T06:10:11.000Z","msg":"法國人都是有人格，和國家為自由的革命歷史，這些是他們國家的共同核心價值，追求人格和道德可以為保名聲、尊嚴、正直、氣節而去自殺。<br />\n<br />\n香港警察不同，他們沒有歐洲人那種精神道德的教育。香港警察是一群無人格的人，上司叫佢做違反守則的事，甚至犯法，也不會去思考，豪無愧疚心地去做，酷刑對長者病人，近距離瞄頭射布袋彈，地鐵站放催淚彈，有正常人格的人怎會做得出這事情 ?<br />\n<br />\n香港警察自殺的原因大都是因為爛賭爭人周身債，而不是因為對自身做的事情感到愧疚。"},{"pid":"a4a19a1d9f74c7597b7be72fba89921b9c48803c","tid":1493074,"uid":63311,"like":0,"dislike":0,"score":0,"quote":{"pid":"8936394b854d1d9a431a5c82c15986e6e072304f","tid":1493074,"uid":271857,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2019-08-21T06:10:11.000Z","msg":"法國人都是有人格，和國家為自由的革命歷史，這些是他們國家的共同核心價值，追求人格和道德可以為保名聲、尊嚴、正直、氣節而去自殺。<br />\n<br />\n香港警察不同，他們沒有歐洲人那種精神道德的教育。香港警察是一群無人格的人，上司叫佢做違反守則的事，甚至犯法，也不會去思考，豪無愧疚心地去做，酷刑對長者病人，近距離瞄頭射布袋彈，地鐵站放催淚彈，有正常人格的人怎會做得出這事情 ?<br />\n<br />\n香港警察自殺的原因大都是因為爛賭爭人周身債，而不是因為對自身做的事情感到愧疚。"},"citedBy":0,"replyTime":"2019-08-21T06:11:27.000Z","msg":"甚至主動去做博升職"},{"pid":"2918b0f8366a84a91c9ad30cc9139489625cb1c8","tid":1493074,"uid":268365,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T06:15:31.000Z","msg":"支持警察 <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />吞槍自殺"},{"pid":"c1786c77e6eb359c8382f54fafcc119ffeeb5320","tid":1493074,"uid":197813,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T06:18:18.000Z","msg":"幾時到香港<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ace9a6cb61c4996ace7e85ebd0e5d7667a68a7e7","tid":1493074,"uid":280457,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T06:18:43.000Z","msg":"&quot;法國警察自殺率是百分之三十六&quot;<br />\n純問題：咁點解真係自殺左既得64人? 係警察人太少定係自殺不遂?<br />\n<br />\n香港警察又點會自殺?<br />\n學歷偏低人工偏高<br />\n覺得自己岩哂，有得濫權濫暴<br />\n唔會良心發現<br />\n更唔會畏罪自殺，因為佢地唔覺得僧上身<br />\n<br />\n防止班狗殺人就差唔多<br />\n<img src=\"/assets/faces/pig/angry.gif\" cl