.com/uc?id=10YDWAMo-lGSEleLwlivaAiwSzj-8w9Tt\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fdrive.google.com%2Fuc%3Fid%3D10YDWAMo-lGSEleLwlivaAiwSzj-8w9Tt&h=a637168a&s={SIZE}\" /><br />\n<br />\n<img src=\"https://drive.google.com/uc?id=1mMWBOER8TRV0wEBSYBHAcGmzoVK9-4sc\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fdrive.google.com%2Fuc%3Fid%3D1mMWBOER8TRV0wEBSYBHAcGmzoVK9-4sc&h=9bf98b3a&s={SIZE}\" /><br />\n<br />\n<img src=\"https://drive.google.com/uc?id=1VJXhsQ3QIhzeKyXVuInATkoyyX7FFg34\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fdrive.google.com%2Fuc%3Fid%3D1VJXhsQ3QIhzeKyXVuInATkoyyX7FFg34&h=2d60a0da&s={SIZE}\" /><br />\n<br />\n<img src=\"https://drive.google.com/uc?id=1oNV6GuQFeJDulB2H2eDe1pNSaHzvBfHY\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fdrive.google.com%2Fuc%3Fid%3D1oNV6GuQFeJDulB2H2eDe1pNSaHzvBfHY&h=ae357acd&s={SIZE}\" /><br />\n<br />\n<img src=\"https://drive.google.com/uc?id=1DfuhniLen84bA8vLJ9lGKqmosmZNypes\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fdrive.google.com%2Fuc%3Fid%3D1DfuhniLen84bA8vLJ9lGKqmosmZNypes&h=4f16f337&s={SIZE}\" /><br />\n<br />\n<img src=\"https://drive.google.com/uc?id=14Qp_aAjAqDgKM71EyWyVawPcK8ThzVqH\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fdrive.google.com%2Fuc%3Fid%3D14Qp_aAjAqDgKM71EyWyVawPcK8ThzVqH&h=82fa7daf&s={SIZE}\" /><br />\n<br />\n<img src=\"https://drive.google.com/uc?id=1RCbKlJXvK2XedFgOARTGTGt-bl53m4yM\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fdrive.google.com%2Fuc%3Fid%3D1RCbKlJXvK2XedFgOARTGTGt-bl53m4yM&h=7261b0cc&s={SIZE}\" /><br />\n<br />\n<img src=\"https://drive.google.com/uc?id=1Q_wNm2d67VVSIESrANB5X-MuiSIwvymU\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fdrive.google.com%2Fuc%3Fid%3D1Q_wNm2d67VVSIESrANB5X-MuiSIwvymU&h=04f9d087&s={SIZE}\" /><br />\n<br />\n好彩冇走光！<br />\n<br />\n藝人唐詩詠與伍樂怡到將軍澳出席足球活動，講到世界盃，二人分別表示支持英格蘭和法國！詩詠玩遊戲烏身時更露出事業線及白Bra，非常「胸」湧！而着上露肩裝及短褲的伍樂怡大晒香肩、纖腰及長腿，但同樣失守露出胸墊！<br />\n<br />\n球場「兇」人<br />\n<br />\n受訪時，詩詠自爆小時候唔怕死「兇」人：「鍾意打羽毛球、乓乓波，小學會陪哥哥去踢波，細個會陪爸爸睇波添，不過睇開嘅好似碧咸咁已經冇踢，依家前鋒簡尼係明日之星。（球場上試過暗戀人？）冇喎，反而係我哥提起試過有人嚟打交爭場，我衝埋去同人講『唔好阻住我踢波。』我阿哥即刻抱我走開！」<br />\n<br />\n去澳洲搵男友<br />\n<br />\n她直言擇偶條件要陽光型：「郁吓、做運動嘅會好啲，不過我嚟緊開劇開半年，可能10月去澳洲外景，睇吓有冇適合嘅。（異地情？）只要係中國人同聲同氣就得。（大過你好多呢？）唔會用年齡去衡量愛情。」<br />\n<br />\n抗拒上網識人<br />\n<br />\n談到近日有人於社交網交友受騙，她謂：「我有朋友試過上社交網識人，成功仲結埋婚，不過我嘅性格莫講話上網，面對面介紹個人我識，我都會有啲抗拒，咁我暫時亦未有需要（上網識異性）。」<br />\n<br />\n----------------------------<br />\n<br />\n東網巨星開咗ig喇，大家快啲follow<br />\n<br />\n<a href=\"https://bit.ly/2JjSVcr\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F2JjSVcr&d=EpBiDWHeHEVQSoaZVRr9hTCdMQr7etzq9tFbjrA%2B72k%3D&h=45c0e12b\" data-auto-link target=\"_blank\">https://bit.ly/2JjSVcr</a><br />\n<br />\n來源 source: <a href=\"http://hk.on.cc\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.on.cc&d=EpBiDWHeHEVQSoaZVRr9hTCdMQr7etzq9tFbjrA%2B72k%3D&h=cd9f2fe0\" data-auto-link target=\"_blank\">http://hk.on.cc</a><br />\n<br />\n+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++<br />\n<br />\n係咁連續出新聞，睇來有人好心急 <img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"0e387960f63808fba41173038de23d5d27af4ef5","tid":734903,"uid":58140,"like":245,"dislike":2,"score":243,"citedBy":0,"replyTime":"2018-07-09T05:06:07.000Z","msg":"唐姨(37歲)<br />\n@美人"},{"pid":"3b85ddb18fb44ad9e41bf3465b99fa54731a9d86","tid":734903,"uid":76632,"like":65,"dislike":3,"score":62,"citedBy":1,"replyTime":"2018-07-09T05:06:46.000Z","msg":"召喚大美人<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"9f7e8c798d8ee7a0bd0d46f305c3ee83f36a3b5f","tid":73490