":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e95287f4a51c90fbf036a1f184d3830c60bcb82b","tid":1860400,"uid":73004,"like":0,"dislike":0,"score":0,"quote":{"pid":"306e9b8f64d6dc5c5dddf904e3e748548f9fb614","tid":1860400,"uid":123308,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2020-02-03T15:39:13.000Z","msg":"你見今日佢記者招待會冇戴就知 <img src=\"/assets/faces/lny/smile2.gif\" class=\"hkgmoji\" /><br />\n此人城府極深"},"citedBy":1,"replyTime":"2020-02-04T05:49:40.000Z","msg":"最仆街係背後偷偷地戴<img src=\"/assets/faces/lny/fuck.gif\" class=\"hkgmoji\" />"}]}