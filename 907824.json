/>"},{"pid":"80e696d9aaf39ce0c26486918b3eda0d7a091328","tid":907824,"uid":19454,"like":0,"dislike":0,"score":0,"quote":{"pid":"dfe2859a46d0d9c09ec58c6603a702b38b139fbc","tid":907824,"uid":6026,"like":501,"dislike":2,"score":499,"citedBy":2,"replyTime":"2018-11-19T06:35:02.000Z","msg":"<img src=\"https://na.cx/i/MxJDKUs.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FMxJDKUs.png&h=fe12cf64&s={SIZE}\" /><br />\n殘體唔好屌<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-19T06:36:24.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"7b5a81f3250d9972513365542290437086115711","tid":907824,"uid":14739,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-19T06:36:52.000Z","msg":"包容下啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"96869c3fea0fe6959739d2cff6308e8b4ca95e5b","tid":907824,"uid":14739,"like":9,"dislike":1,"score":8,"citedBy":0,"replyTime":"2018-11-19T06:37:37.000Z","msg":"東涌居民包容下  內地人來港消費帶動區內就業"},{"pid":"3c0c40de11de8d39e17d0aa79ddf511aec3782b0","tid":907824,"uid":199120,"like":52,"dislike":1,"score":51,"citedBy":0,"replyTime":"2018-11-19T06:39:25.000Z","msg":"已經冇野可以阻止到大媽<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" /> <br />\n<br />\n建議人工島分一part比班大媽跳老舞，等佢地跳到島沉<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"036e9429d5aea199e763ec9e67810b9cbf2d181d","tid":907824,"uid":19454,"like":94,"dislike":2,"score":92,"citedBy":1,"replyTime":"2018-11-19T06:43:04.000Z","msg":"亨廷頓舞蹈症<br />\n<br />\n是一種遺傳性疾病，會導致腦細胞死亡[1]。早期症狀往往是情緒或智力方面的輕微問題[2]，接著是不協調和不穩定的步伐（英語：Gait）[3]。隨著疾病的進展，身體運動的不協調變得更加明顯[2]，能力逐漸惡化直到運動變得困難，無法說話[2][3]。心智能力則通常會衰退為癡呆症[4]。罹患此症患者的具體症狀會有所不同[2]。症狀通常在出現在30到50歲之間，但可以從任何年齡開始發生[1][4] 。在帶有與罹患此症相關異常的染色體家族中，其成員可能於較年輕時就發病[2]。大約8％的病例在20歲以前發病，其典型症狀與帕金森病更近似[4]。此症患者經常會低估了自身病狀[2]。<br />\n<br />\n<a href=\"https://zh.m.wikipedia.org/wiki/亨丁頓舞蹈症\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wikipedia.org%2Fwiki%2F%E4%BA%A8%E4%B8%81%E9%A0%93%E8%88%9E%E8%B9%88%E7%97%87&d=1qQUYiz6aatzlv%2BlB%2BK4%2FpZgE6vMW1KEzMhkvokIvkY%3D&h=a839c7a8\" data-auto-link target=\"_blank\">https://zh.m.wikipedia.org/wiki/亨丁頓舞蹈症</a>"},{"pid":"61eec3be49455326ff5d38eb27c817daadc0c9b8","tid":907824,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-19T07:00:56.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"1f021548877785221c54a9050d195e9af9bcbb03","tid":907824,"uid":29080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-19T07:01:20.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0a0459f63e6f6c94dac87cb8c52912802ec251f2","tid":907824,"uid":91833,"like":2,"dislike":0,"score":2,"quote":{"pid":"c59db981b87fb914de4eef2601999d372eaf50e4","tid":907824,"uid":14739,"like":127,"dislike":3,"score":124,"citedBy":3,"replyTime":"2018-11-19T06:30:31.000Z","msg":"青衣準備"},"citedBy":0,"replyTime":"2018-11-19T07:02:30.000Z","msg":"喊出黎"},{"pid":"a4b0b53e312f506b15b94c99f44aea835e99e236","tid":907824,"uid":130858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-19T07:07:30.000Z","msg":"<img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2e458f888209be6ac24ed7d78f84272dafe0cd91","tid":907824,"uid":19454,"like":134,"dislike":0,"score":134,"citedBy":6,"replyTime":"2018-11-19T07:09:55.000Z","msg":"蝗軍 已佔領城池示意圖<br />\n<br />\n<img src=\"https://na.cx/i/wphtnSW.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwphtnSW.png&h=a6c251ef&s={SIZE}\" />"},{"pid":"6742e7a09ccd7019340ab222215cff2ead32d752","tid":907824,"uid":1