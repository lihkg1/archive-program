id":"9eb718bb9aedc68f1b6dc782b461f6e3f79eb73b","tid":1248812,"uid":266755,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:50:08.000Z","msg":"push"},{"pid":"3d94324606f5b6c1a27e240d68fb4f1981f1f899","tid":1248812,"uid":162293,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:50:20.000Z","msg":"Push"},{"pid":"d0c7a3e0965004a5de7916b45f7129264c645d09","tid":1248812,"uid":47042,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:50:20.000Z","msg":"俾現場人士自行判斷啦"},{"pid":"1673a0ba1a7adb32693229b95f1192b80b376524","tid":1248812,"uid":6239,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-21T14:50:22.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">警察永遠唔洗驚 想收工嗰陣就上連登一齊叫人散水 然後成班坐屋企嘅就一齊和應叫人翻歸<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /></span></span>"},{"pid":"431b9df621811e13bddb3cf15a6569636c506065","tid":1248812,"uid":194609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:51:11.000Z","msg":"<span style=\"font-size: x-large;\">冷處理&lt;-政府又開始用最鐘意𠴱招</span><br />\n<br />\n你和平：<br />\n冷處理消耗民意  <br />\n搵一日偷偷開會<br />\n多人抗議就再暫緩<br />\n少人就直接通過    <br />\n佢嘅成本只係一張通告就開會/暫緩<br />\n我地嘅成本就係每次要幾萬人出嚟<br />\n佢只需陰到你一次<br />\n<br />\n<br />\n你勇武：<br />\n我地政府警方都縮緊你都搞事<br />\n你係暴徒  佢地就出師有名<br />\n加上香港人善忘  <br />\n瞄頭開槍   圍毆倒地呀伯   圍困中信示威者<br />\n全部唔記得哂  <br />\n所以先會驚對方有位入   <br />\n人地向你頭開槍，但好多人都仲驚緊比位人入<br />\n<br />\n所以而家最好嘅方法係公眾唔討厭嘅「勇武」<br />\n但你唔一定要攻擊但要搞到佢冇好日子過<br />\n逼佢回應"},{"pid":"24612a3b3a04defa3a28c722566d42f6da863bb2","tid":1248812,"uid":266755,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:51:17.000Z","msg":"又捉到鬼"},{"pid":"48e86dec8324150cfa4203c5b82091afefc53c74","tid":1248812,"uid":266755,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:51:30.000Z","msg":"push"},{"pid":"f210e10c8bbe4ff5c9cae7ca6760cd237acb3de7","tid":1248812,"uid":63043,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:51:59.000Z","msg":"「有勇無謀」指的是一個人只有勇氣，沒有計謀。形容做事或打仗只是猛打猛衝，缺乏計劃，不講策略，只會魯莽的去做事，從不會投機取巧。<br />\n記住香港人係食腦！！！"},{"pid":"0325283aa7ebecfd3bfcfd7dffa1d580e8eb560d","tid":1248812,"uid":36592,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:52:13.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">冷靜，唔好衝，注意安全，be water my friend</span></span>"},{"pid":"336a496ce5af2e8171f11f2296a1caba0e13230a","tid":1248812,"uid":149026,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:52:31.000Z","msg":"Set deadline"},{"pid":"56cc5d40672917fe14c9c7fa26d6336c4fde3d6d","tid":1248812,"uid":79182,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:52:43.000Z","msg":"大家記住 呢個係長期不合作運動<br />\n啲犬清場 我地唔使硬碰<br />\n唔好送人頭俾佢<br />\n我地返去休息 抖足精神 第二日又嚟過<br />\n我地不斷做 搞亂個社會秩序<br />\n然後同政府談判先係辦法<br />\n<br />\n千其唔好死衝 無意思㗎 <br />\n我地做咩都唔合法<br />\n警犬做咩都有政府撐腰<br />\n我真係唔想再有義士犧牲<br />\n<br />\n我知有人會諗 叫咗咁多人出嚟<br />\n咩都唔做咁on9?<br />\n無錯我地係人多 但我地和平遊行又試過<br />\n衝擊佔領又試過 有用咩??<br />\n要贏 一定要試新方法<br />\n一於試吓不合作運動啦"},{"pid":"422eda82cd720eca9c3ec82106e75d830551d5a5","tid":1248812,"uid":132999,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:52:49.000Z","msg":"記得有禮貌講 byebye。"},{"pid":"421769bd5f188e084c86ccfe03ea7b019302f2d7","tid":1248812,"uid":266755,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:52:58.000Z","msg":"push"},{"pid":"4ee71acca2faaf25d29995b6d074ce0529894dda","tid":1248812,"uid":207702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:53:07.000Z","msg":"推"},{"pid":"3ed7da67fe33c676a11840dffd126926d677223f","tid":1248812,"uid":266755,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:53:08.000Z","msg":"push"},{"pid":"bbdbfdb22902975a8d7f3d421001cb57623608f2","tid":1248812,"uid":256875,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:53:18.000Z","msg":"11點？"},{"pid":"86bda0f7bcf969c4a361c5c7da6cdcb76824d395","tid":1248812,"uid"