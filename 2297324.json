,"quote":{"pid":"af252aabd13ae0cf18a89d684571ce307d6e2456","tid":2297324,"uid":337052,"like":0,"dislike":5,"score":-5,"quote":{"pid":"80172b4c659db7f1e21b0e79d111b3fa00407b6d","tid":2297324,"uid":21545,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-11-23T07:55:10.000Z","msg":"Ching 琴晚做乜<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-23T07:57:06.000Z","msg":"恭喜黃之鋒周庭"},"citedBy":2,"replyTime":"2020-11-23T07:57:53.000Z","msg":"恭喜你個頭<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"},{"pid":"20fb53022801ab6df157ff44afec63f41aab663d","tid":2297324,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"781bdce8fe371d7bb6f67d19ce540f819f7b2298","tid":2297324,"uid":173326,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-23T07:57:43.000Z","msg":"拜登肯救自己fans未<img src=\"/assets/faces/mouse/fuck.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-23T07:58:20.000Z","msg":"忙著等訴訟結果"},{"pid":"d9b39b9a07a46e7756823f2b9e4ee2ffe3a42bac","tid":2297324,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-23T07:59:22.000Z","msg":"<strong><span class=\"x-large\">香港の&ldquo;民主の女神&rdquo;周庭さん収監「無事に外に&hellip;」</span></strong><br />\n[2020年11月23日16時28分]<br />\n<br />\n香港の民主活動家で「民主の女神」といわれた周庭さん（英語名アグネス・チョウ）ら3人が23日午後、収監された。<br />\n<br />\n周さんらは昨年6月、無許可で行われたデモを扇動したなどの罪に問われており、この日香港の裁判所で公判が行われた。<br />\n<br />\n周庭さんは22日、自身のツイッターに「去年香港の警察本部であったデモの件で、明日の日本時間朝10時半から裁判があります。裁判所から出られない可能性もありますが、無事に外に出られますように」と、不安の胸の内をつづっていた。<br />\n<br />\n周さんは日本のアニメや漫画が好きで、独学で日本語を学び、SNSでも日本語で発信を続けていた。<br />\n<br />\n<a href=\"https://www.nikkansports.com/general/nikkan/photonews/photonews_nsInc_202011230000375-0.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.nikkansports.com%2Fgeneral%2Fnikkan%2Fphotonews%2Fphotonews_nsInc_202011230000375-0.html&d=4eD5kuUGVNxCcHpGsLYUnf%2FZYLwdGiEzwb2OZuYF8yg%3D&h=fc6e6bf0\" data-auto-link target=\"_blank\">https://www.nikkansports.com/general