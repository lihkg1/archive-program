0,"score":1,"quote":{"pid":"4d813be5d5815884272a9d3d45611295e7228f7d","tid":2214121,"uid":167506,"like":0,"dislike":3,"score":-3,"citedBy":3,"replyTime":"2020-09-23T04:48:45.000Z","msg":"其實點解會係佢 有好多人值過佢"},"citedBy":0,"replyTime":"2020-09-23T06:13:24.000Z","msg":"係囉  點解你冇份? 你明明有係屋企涼冷氣 <img src=\"/assets/faces/lm2/yipes.gif\" class=\"hkgmoji\" /><br />\n我撐你呀! 係呢  你流亡左未? <img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" />"},{"pid":"225b86f3f0dae8148b7243a14a9d9af92aa1b9b9","tid":2214121,"uid":274789,"like":0,"dislike":0,"score":0,"quote":{"pid":"af19e1bf12e2dadaf412bbf37195e4b43fb9f106","tid":2214121,"uid":153600,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2020-09-23T04:46:23.000Z","msg":"<a href=\"https://time.com/collection/100-most-influential-people-2020/5888201/nathan-law/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftime.com%2Fcollection%2F100-most-influential-people-2020%2F5888201%2Fnathan-law%2F&d=UZIDdMkqB5nEVwovtN1d9gjMvzJQG4GdM8cyRMJzdLg%3D&h=c8ca877a\" data-auto-link target=\"_blank\">https://time.com/collection/100-most-influential-people-2020/5888201/nathan-law/</a><br />\n<br />\n篇文由彭定康親自寫架<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-23T06:17:20.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"ff8388b28d83003bfc4c3c1d67c2ee62af73451b","tid":2214121,"uid":345502,"like":0,"dislike":0,"score":0,"quote":{"pid":"af19e1bf12e2dadaf412bbf37195e4b43fb9f106","tid":2214121,"uid":153600,"like":3,"dislike":1,"score":2,"citedBy":2,"replyTime":"2020-09-23T04:46:23.000Z","msg":"<a href=\"https://time.com/collection/100-most-influential-people-2020/5888201/nathan-law/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftime.com%2Fcollection%2F100-most-influential-people-2020%2F5888201%2Fnathan-law%2F&d=UZIDdMkqB5nEVwovtN1d9gjMvz