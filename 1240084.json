:"38e04c34baf9abd379d27ba42534dfc352f4649f","tid":1240084,"uid":65604,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-18T11:02:04.000Z","msg":"我覺得係要宣傳返俾市民聽，係有可行方法將引渡陳返台灣，唔係政府到時實扮晒野話咩正義不能伸張係市民自己做成。"},{"pid":"86c0693ad619dcb6526f13137dd30cc4bb669186","tid":1240084,"uid":81569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-18T11:06:52.000Z","msg":"老實講劉馬車都有用過佢"},{"pid":"3655e52f61d464e91c0c00041cd8e60bcd2130b3","tid":1240084,"uid":181706,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-18T12:43:03.000Z","msg":"佢地搵建制搞 就唔洗我地幫手啦 而且佢地有方法唔做 有咩好討論"},{"pid":"7cc4ff2dce114390f5c46cb8ea34b3add2daa9f8","tid":1240084,"uid":167634,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T03:12:55.000Z","msg":"【第六訴求】解決台灣殺人案<br />\n<br />\n我在早前提出的「域外法權」私人草案，賦權香港法庭審議港人在境外干犯的殺人、誤殺等罪行，偵查、審訊、服刑都在香港，亦沒有追溯期問題，可以立即解決台灣殺人案，為死者和家屬尋求公義。<br />\n「域外法權」草案目前正等候保安局回覆，決定是否涉及政府政策，如是，需要行政長官同意；如否，則由立法會主席決定是否發出書面同意。<br />\n但立法會會期時近尾聲，若要在7月10日最後一次會議提上大會，主席必須在本星期內決定是否願意用此方法把陳同佳案透過香港法庭審理。同時，亦需要政府和建制派合作，讓草案在同一日作首、二、三讀，趕在疑犯出獄前生效！<br />\n<br />\n「域外法權」私人條例草案記者會（25/4/2019）：<a href=\"http://bit.ly/31FGNc1\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2F31FGNc1&d=qLBezvvtP0%2Ff8NIwCarvwtB4iDtRAy51VXy1YCRVmoY%3D&h=522c5a1f\" data-auto-link target=\"_blank\">bit.ly/31FGNc1</a><br />\n<br />\n楊岳橋facebook<br />\n=============<br />\n<br />\n都話左要返返去原本訴求啦diu"}]}