 />"},{"pid":"8376acc1c1dcc75b35af43e20e505901eed150f7","tid":834201,"uid":72054,"like":4,"dislike":11,"score":-7,"citedBy":0,"replyTime":"2018-09-24T04:57:54.000Z","msg":"百里臭"},{"pid":"28a03ca97911a2a7a3e0524247c20897eed1e266","tid":834201,"uid":33359,"like":26,"dislike":6,"score":20,"citedBy":0,"replyTime":"2018-09-24T04:59:46.000Z","msg":"百里香果然無令我失望<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /> <br />\n一切開個番茄就知正 汁水極多 咬落極香極正<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <br />\n雞扒皮煎到焦香 肉質嫩滑 一入口先係淡淡黑椒香味<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> 咬咬下 乳酪香先慢慢滲出黎 好正<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <br />\n著仔沙律調味調得好好<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> 著仔既軟硬度掌握得岩岩好<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> 仲加左d肉腸碎 超正<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"1b23760b1198e5739a1809818162d2a1cdb5d184","tid":834201,"uid":36296,"like":22,"dislike":1,"score":21,"citedBy":0,"replyTime":"2018-09-24T05:00:23.000Z","msg":"我以為係張濕左既紙巾<img src=\"/assets/faces/mf/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/clown.gif\" class=\"hkgmoji\" />"},{"pid":"567bdd8a3958bbfaeed7df50f197642cb371ff85","tid":834201,"uid":143608,"like":3,"dislike":8,"score":-5,"citedBy":3,"replyTime":"2018-09-24T05:01:20.000Z","msg":"頭先12點3去到都爆晒人， 印度仔你年尾加幾多花紅？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\nBTW,頭先食左炸魚薯條，一般般喎，炸漿唔夠香，調味都唔夠<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /> <br />\n<br />\n不過$48又真係幾抵食<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"643ce8bf7ef2a9b137b4eb29eb7ff8219cf96353","tid":834201,"uid":155818,"like":1,"dislike":0,"score":1,"c