5%25BC%25E8%2580%2581%25E9%2597%2586-%25E8%25A2%25AB%25E9%2581%258E%25E6%25A9%258B%25E6%258A%25BD%25E6%259D%25BF%2F&h=0c94b71b\" target=\"_blank\">https://hk.lifestyle.appledaily.com/etw/magazine/article/20190915/3_60040192/-%E9%80%86%E6%AC%8A%E5%B0%8F%E5%BA%97-%E9%BE%8D%E9%96%80%E5%86%B0%E5%AE%A4%E9%AC%A7%E9%9B%99%E8%83%9E-%E5%B1%AF%E9%96%80%E7%9C%9F-%E9%BE%8D%E9%96%80%E5%86%B0%E5%AE%A4%E6%8E%A8%E5%85%8D%E8%B2%BB%E9%A6%99%E6%B8%AF%E4%BA%BA%E5%8A%A0%E6%B2%B9%E9%A4%90-%E5%89%B5%E8%BE%A6%E4%BA%BA%E5%85%BC%E8%80%81%E9%97%86-%E8%A2%AB%E9%81%8E%E6%A9%8B%E6%8A%BD%E6%9D%BF/</a>"},{"pid":"5f3d9b0bfc118ec1099da1b81acc367a353e3e9d","tid":1653160,"uid":266342,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2019-10-14T03:18:16.000Z","msg":"so？唔得閒理佢住<br />\nnext"},{"pid":"2d506d538434cfe286cde6b0ac0cec7a6f87a4ed","tid":1653160,"uid":105888,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2019-10-14T03:18:29.000Z","msg":"1999"},{"pid":"4dcd7f11b83dcde5769cb9e79041281f3cc6920f","tid":1653160,"uid":38109,"like":21,"dislike":0,"score":21,"citedBy":1,"replyTime":"2019-10-14T03:18:39.000Z","msg":"在逆權運動中，北角紅衣人暴力襲擊示威者，引起民憤。因有人拍攝，紅衣人以北角富臨酒樓為基地，分發武器制服，令不少人揚言抵制集團旗下所有餐廳。不過集團旗下的龍門冰室和另一間龍門冰室其實同名同姓，偏偏雙方已無關係，所以被拖累杯葛的龍門冰室上星期就在Facebook發聲明，澄清與富臨無關係。<br />\n<br />\n聲明提及冰室是自家創立和經營，起自屯門龍門居，故有此名，另有尖沙嘴、銅鑼灣、炮台山和紅磡等分店。雖然不少網民留言質疑，但龍門冰室創辦人兼老闆張生上傳所有分店商業登記文件，以作證明。對於冰室被謠傳與富臨有關，老闆張生起初覺得影響不大，直到有傳言指富臨旗下所有餐廳倒閉。「業主問我們是否做不住、有沒有錢交租，我們覺得事態嚴重故發聲明。」<br />\n<br />\n而富臨集團旗下的龍門冰室，就位於屯門海麗和香港仔。兩個集團的冰室之所以撞名，始於一年前，「一年多前，富臨透過中間人聯絡，看好我們餐廳，想與我們合作，問可否用龍門冰室名義開店。」張生首肯後，就合作開了屯門海麗店。<br />\n<br />\n但後來富臨集團卻沒有再和張生聯絡，更自行開了香港仔分店。張生表示﹕「(富臨)沒有再找過我，完全斷絕來往，我覺得有少少過橋抽板。看到周年報表寫「富臨旗下龍門冰室」，真的火都來了。」張生表示，曾聯絡富臨指年報不該這樣寫，但富臨表示龍門冰室名字沒申請註冊商標，人人都可以開。<br />\n<br />\n張生多年前已想為名字註冊，但是「商標註冊處說，註冊名下已經有龍門客棧和龍門酒家。若要取得註冊，要得他們同意，但寫過信給他們都沒有回覆。」今次發聲明後，富臨曾電話聯絡張生，但並非道歉或解釋，而是「叫我唔好亂講嘢。」<br />\n<br />\n人們抵制富臨，真．龍門冰室生意亦輕微下降，他亦理解。「元朗731事件和福建幫打人，根本不能接受。若要抵制與他們有關的商戶，我覺得都合理，但我們就變了殃及池魚，惟有盡量與客人講清楚。」<br />\n<br />\n為支持年輕人，冰室特意推出香港人加油餐。由即日至9月22日，逢星期一至五6點後到五間分店，或星期六日到尖沙嘴及銅鑼灣店，只要出示有效中學或大專學生證，即可免費享用餐蛋麵連飲品一份。「讓他們食飽後，參加集會活動有氣有力，不需擔心在哪裏找食物。」<br />\n<br />\n屯門有兩間龍門冰室，龍門居店屬於張生，海麗店是富臨持有。兩間標誌、餐點、價錢到裝潢有九成相似，但是食物質素不同。常餐一樣由$32至$36，不同時段不同收費。雪菜肉絲米粉表面都有滿滿雪菜，龍門居店的炒蛋白用心炒成厚長方形，海麗店就炒成一灘。葱油雞扒撈丁配餐飲一樣是$43，雞扒都大大塊，不過海麗店的就較乾嚡，亦無附上豉油，撈丁略不夠味。海麗店店員亦認該店屬富臨旗下，與龍門居店是不同老闆，但不清楚抵制富臨事件，及生意有否受影響。<br />\n<br />\n兩店相似程度之高，連日日光顧龍門居店的熟客都分不清，「不知兩間不同，覺得龍門居店的較好吃。不會介意（另一間是富臨），如去到想食都會食。」有客人知道海麗店屬富臨後，揚言罷食，亦有客人指不會理餐廳背景。「新的舊的都試，好食就會再來，不好食就只食一次。不過如果是富臨開，我反而不會去，食過他的中菜覺得一般，冰室都未必好過這間（龍門居店）。」"},{"pid":"8590695f7b2265420737b32cb42de50b364f4d91","tid":1653160,"uid":799,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2019-10-14T03:18:45.000Z","msg":"你拎D證據黎睇下囉, 開個POST 講到似層層有用咩"},{"pid":"ec7db23f43c380bea6d0e81b43665702faa69957","tid":1653160,"uid":105888,"like":3,"dislike":0,"score":3,"quote":{"pid":"97820eae311b0bfbb738cf1d4c601be497e797fd","tid":1653160,"uid":38109,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2019-10-14T03:18:04.000Z","msg":"<a href=\"https://hk.lifestyle.appledaily.com/etw/magazine/article/20190915/3_60040192/-%E9%80%86%E6%AC%8A%E5%B0%8F%E5%BA%97-%E9%BE%8D%E9%96%80%E5%86%B0%E5%AE%A4%E9%AC%A7%E9%9B%99%E8%83%9E-%E5%B1%AF%E9%96%80%E7%9C%9F-%E9%BE%8D%E9%96%80%E5%86%B0%E5%AE%A4%E6%8E%A8%E5%85%8D%E8%B2%BB%E9%A6%99%E6%B8%AF%E4%BA%BA%E5%8A%A0%E6%B2%B9%E9%A4%90-%E5%89%B5%E8%BE%A6%E4%BA%BA%E5%85%BC%E8%80%81%E9%97%86-%E8%A2%AB%E9%81%8E%E6%A9%8B%E6%8A%BD%E6%9D%BF/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.lifestyle.appledaily.com%2Fetw%2Fmagazine%2Farticle%2F20190915%2F3_60040192%2F-%25E9%2580%2586%25E6%25AC%258A%25E5%25B0%258F%25E5%25BA%2597-%25E9%25BE%258D%25E9%2596%2580%25E5%2586%25B0%25E5%25AE%25A4%25E9%25AC%25A7%25E9%259B%2599%25E8%2583%259E-%25E5%25B1%25AF%25E9%2596%2580%25E7%259C%259F-%25E9%25BE%258D%25E9%2596%2580%25E5%2586%25B0%25E5%25AE%25A4%25E6%258E%25A8%25E5%2585%258D%25E8%25B2%25BB%25E9%25A6%2599%25E6%25B8%25AF%25E4%25BA%25BA%25E5%258A%25A0%25E6%25B2%25B9%25E9%25A4%2590-%25E5%2589%25B5%25E8%25BE%25A6%25E4%25BA%25BA%25E5%258