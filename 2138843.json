e7f1935bcb51244b26d5b37ce24","tid":2138843,"uid":79563,"like":2,"dislike":16,"score":-14,"quote":{"pid":"f40091231c7ff68384ed1a8c0c1548af393b587a","tid":2138843,"uid":33868,"like":32,"dislike":2,"score":30,"citedBy":1,"replyTime":"2020-08-04T01:58:43.000Z","msg":"佢意思係叫你唔好一個咁去英國<br />\n因為有d BNO dependent自己去咗，但同行無BNO"},"citedBy":4,"replyTime":"2020-08-04T01:59:08.000Z","msg":"before the Hong Kong BN(O) Visa is available."},"citedBy":0,"replyTime":"2020-08-04T02:00:53.000Z","msg":"together before <br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n嚇鬼呀？"},{"pid":"3b811c2146871d8121f22120efc0c88c660f8717","tid":2138843,"uid":196924,"like":20,"dislike":2,"score":18,"quote":{"pid":"c98b91fd20072e7f1935bcb51244b26d5b37ce24","tid":2138843,"uid":79563,"like":2,"dislike":16,"score":-14,"quote":{"pid":"f40091231c7ff68384ed1a8c0c1548af393b587a","tid":2138843,"uid":33868,"like":32,"dislike":2,"score":30,"citedBy":1,"replyTime":"2020-08-04T01:58:43.000Z","msg":"佢意思係叫你唔好一個咁去英國<br />\n因為有d BNO dependent自己去咗，但同行無BNO"},"citedBy":4,"replyTime":"2020-08-04T01:59:08.000Z","msg":"before the Hong Kong BN(O) Visa is available."},"citedBy":2,"replyTime":"2020-08-04T02:00:55.000Z","msg":"屌你真係唔識字<br />\n佢係話有visa之前就唔該你地一家人一齊去以便處理<br />\n內文<br />\n<br />\nEntering the UK before the Hong Kong BN(O) Visa is available<br />\nIf you&rsquo;re not eligible to enter the UK under an existing immigration route, Border Force Officers may be able to consider granting &lsquo;Leave Outside the Rules&rsquo; at the UK border for a period of 6 months to you and your accompanying dependants.<br />\n<br />\nTo be considered, you&rsquo;ll need to show:<br />\n<br />\nyour identity<br />\nyour BN(O) citizen status<br />\nthat you normally live in Hong Kong<br />\nthat you can accommodate support yourself financially in the UK<br />\nYou&rsquo;ll also need to show evidence of any non-BN(O) dependants&rsquo; family links to you and you should travel together to the UK as a family unit. A dependant is any of the following:<br />\n<br />\nspouse or civil partner<br />\nunmarried partner<br />\nchild (under the age of 18 when they first applied)<br />\nother family members where they can show there is a high level of dependency"},{"pid":"b2dfdeec351cb32a1568582808d4ac162805f5da","tid":2138843,"uid":69157,"like":15,"dislike":0,"score":15,"quote":{"pid":"3b811c2146871d8121f22120efc0c88c660f8717","tid":2138843,"uid":196924,"like":20,"dislike":2,"score":18,"quote":{"pid":"c98b91fd20072e7f1935bcb51244b26d5b37ce24","tid":2138843,"uid":79563,"like":2,"dislike":16,"score":-14,"quote":{"pid":"f40091231c7ff68384ed1a8c0c1548af393b587a","tid":2138843,"uid":33868,"like":32,"dislike":2,"score":30,"citedBy":1,"replyTime":"2020-08-04T01:58:43.000Z","msg":"佢意思係叫你唔好一個咁去英國<br />\n因為有d BNO dependent自己去咗，但同行無BNO"},"citedBy":4,"replyTime":"2020-08-04T01:59:08.000Z","msg":"before the Hong Kong BN(O) Visa is available."},"citedBy":2,"replyTime":"2020-08-04T02:00:55.000Z","msg":"屌你真係唔識字<br />\n佢係話有visa之前就唔該你地一家人一齊去以便處理<br />\n內文<br />\n<br />\nEntering the UK before the Hong Kong BN(O) Visa is available<br />\nIf you&rsquo;re not eligible to enter the UK under an existing immigration route, Border Force Officers may be able to consider granting &lsquo;Leave Outside the Rules&rsquo; at the UK border for a period of 6 months to you and your accompanying dependants.<br />\n<br />\nTo be considered, you&rsquo;ll need to show:<br />\n<br />\nyour identity<br />\nyour BN(O) citizen status<br />\nthat you normally live in Hong Kong<br />\nthat you can accommodate support yourself financially in the UK<br />\nYou&rsquo;ll also need to show evidence of any non-BN(O) dependants&rsquo; family links to you and you should travel together to the UK as a family unit. A dependant is any of the following:<br />\n<br />\nspouse or civil partner<br />\nunmarried partner<br />\nchild (under the age of 18 when they first applied)<br />\nother family members where they can show there is a high level of dependency"},"citedBy":0,"replyTime":"2020-08-04T02:01:22.000Z","msg":"你估樓主真唔知定假唔知<br />\n都係想嚇鬼<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1163a0fbccc485d20d82f39538acd9e749e0a909","tid":2138843,"uid":63830,"like":13,"dislike":1,"score":12,"citedBy":0,"replyTime":"2020-08-04T02:01:39.000Z","msg":"<a href=\"http://web.archive.org/web/20200726114239/https://www.gov.uk/guidance/british-nationals-overseas-in-hong-kong\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fweb.archive.org%2Fweb%2F20200726114239%2Fhttps%3A%2F%2Fwww.gov.uk%2Fguidance%2Fbritish-nationals-overseas-in-hong-kong&d=vyHMe5JNZh87BdTcd5o0O9UsrLV3ynd9sCeqRx8pZcg%3D&h=4d4b643f\" target=\"_blank\">http://web.archive.org/web/20200726114239/https://www.gov.uk/guidance/british-nationals-overseas-in-hong-kong</a><br />\nYou&rsquo;ll also need to show evidence of any non-BN(O) dependants&rsquo; family links to you and <span class=\"red\">you should travel together to the UK as a family unit</span>. A dependant is any of the following:<br />\n<br />\n紅字為新增內容，暫時未需恐慌。"},{"pid":"47573c3a8f66838c46b58ee1daf7f030365935f7","tid":2138843,"uid":48083,"like":6,"dislike":5,"score":1,"quote":{"pid":"e83d0c445690d5df9574cb32697f1a1499b001db","tid":2138843,"uid":296496,"like":17,"dislike":8,"score":9,"citedBy":1,"replyTime":"2020-08-04T01:57:45.000Z","msg":"無端端點走⋯ 走難都要有飛機⋯"},"citedBy":3,"replyTime":"2020-08-04T02:01:46.000Z","msg":"但要走　總要飛 <br />\n道別不可再等你　<br />\n不管有沒有機"},{"pid":"ac59676e6497c08dfc9ab82221ead4a0abfd9904","tid":2138843,"uid":196924,"like":2,"dislike":0,"score":2,"quote":{"pid":"47573c3a8f66838c46b58ee1daf7f030365935f7","tid":2138843,"uid":48083,"like":6,"dislike":5,"score":1,"quote":{"pid":"e83d0c445690d5df9574cb32697f1a1499b001db","tid":2138843,"uid":296496,"like":17,"dislike":8,"score":9,"citedBy":1,"replyTime":"2020-08-04T01:57:45.000Z","msg":"無端端點走⋯ 走難都要有飛機⋯"},"citedBy":3,"replyTime":"2020-08-04T02:01:46.000Z","msg":"但要走　總要飛 <br />\n道別不可再等你　<br />\n不管有沒有機"},"citedBy":0,"replyTime":"2020-08-04T02:02:21.000Z","msg":"唔~"},{"pid":"bb4ecf2316e4f4ed30529837b296f34c96612777","tid":2138843,"uid":37856,"like":11,"dislike":3,"score":8,"citedBy":0,"replyTime":"2020-08-04T02:03:01.000Z","msg":"唔先學好英文又要關心國際事務真係可憐"},{"pid":"bde9a1baced038bbd91c9e317876f4013d601ecb","tid":2138843,"uid":57677,"like":2,"dislike":5,"score":-3,"quote":{"pid":"c98b91fd20072e7f1935bcb51244b26d5b37ce24","tid":2138843,"uid":79563,"like":2,"dislike":16,"score":-14,"quote":{"pid":"f40091231c7ff68384ed1a8c0c1548af393b587a","tid":2138843,"uid":33868,"like":32,"dislike":2,"score":30,"citedBy":1,"replyTime":"2020-08-04T01:58:43.000Z","msg":"佢意思係叫你唔好一個咁去英國<br />\n因為有d BNO dependent自己去咗，但同行無BNO"},"citedBy":4,"replyTime":"2020-08-04T01:59:08.000Z","msg":"before the Hong Kong BN(O) Visa is available."},"citedBy":1,"replyTime":"2020-08-04T02:03:17.000Z","msg":"語帶雙關   要多啲人研究解讀"},{"pid":"b81558f12de20b09f51a8d1ee48f8873da669371","tid":2138843,"uid":141782,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2020-08-04T02:03:22.000Z","msg":"Entering the UK before the Hong Kong BN(O) Visa is available<br />\n<br />\nIf you&rsquo;re not eligible to enter the UK under an existing immigration route, Border Force Officers may be able to consider granting &lsquo;Leave Outside the Rules&rsquo; at the UK border for a period of 6 months to you and your accompanying dependants.<br />\nTo be considered, you&rsquo;ll need to show:<br />\n<br />\nyour identity<br />\n<br />\nyour BN(O) citizen status<br />\n<br />\nthat you normally live in Hong Kong<br />\n<br />\nthat you can accommodate support yourself financially in the UK<br />\n<br />\nYou&rsquo;ll also need to show evidence of any non-BN(O) dependants&rsquo; family links to you and you should travel together to the UK as a family unit. A dependant is any of the following:<br />\n<br />\nspouse or civil partner<br />\n<br />\nunmarried partner<br />\n<br />\nchild (under the age of 18 when they first applied)<br />\n<br />