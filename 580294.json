mbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F04%2F200625_3620d2bed484f3759f37357429c03ed6.png&h=1c299220&s={SIZE}\" />"},{"pid":"ec3d0ef135e0f5e96cc749e46cac3a4d5884b9f1","tid":580294,"uid":30879,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-04T12:07:43.000Z","msg":"食過 不過食得好辛苦同冇咁好食"},{"pid":"27e6a4439613e3702e3cf3a8943956302185d10e","tid":580294,"uid":170998,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-04T12:08:27.000Z","msg":"特辣咁多油 其實食完會唔會好易肚柯。。<br />\n<br />\n利申：最盡只可以食到中辣"},{"pid":"1a069359278db58a70387766d000636683acfeca","tid":580294,"uid":1627,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-04T12:10:56.000Z","msg":"雙特辣都試過，不過其實唔係辣好多，只係麻過特辣<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"bb13888ce690517d2867cb0fab05019548313915","tid":580294,"uid":59996,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-04T12:19:45.000Z","msg":"我覺得一間間個辣度唔同。<br />\n<br />\n試過有次我叫個呀嬋問我&ldquo;特辣？得唔得架你靚仔&ldquo; 點知果間就辣到仆街，但又驚畀人笑，最終夾硬食完個胃痛足半個鐘。"},{"pid":"069917a8644b7c39e9e107440cd82f331ec991af","tid":580294,"uid":39,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-04T12:20:42.000Z","msg":"成日食<br />\n根本食得辣既人雙特辣都唔係咩特別野<br />\n譚仔真係唔算係好辣既野"},{"pid":"7d277736377314490e5e0ae79818fa3f5d191db0","tid":580294,"uid":38983,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-04T12:22:02.000Z","msg":"有個朋友唔知係冇味覺定咩<br />\n由細個食碗仔翅都要落成半枝胡椒粉<br />\n後尾先發現佢真係冇咩味覺<br />\n食譚仔係特辣再成樽辣油加落去<br />\n佢剩係出幾滴汗仲話冇咩覺得辣<br />\n痴撚線個腎"},{"pid":"0cf6361aa99b8e20541971a81abf84a17e73e5df","tid":580294,"uid":10889,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-04T12:52:31.000Z","msg":"渣ga<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}