":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T16:22:26.000Z","msg":"推"},{"pid":"5e9e1d4b49654d1800a94dab8d58769402ecebca","tid":1963964,"uid":160695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T16:22:37.000Z","msg":"推"},{"pid":"adff6fb6833035f8084758248c05376843a33edb","tid":1963964,"uid":160695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T16:22:48.000Z","msg":"推"},{"pid":"0ba474e3036d1d07473e6d13767b64b0cb58bb3a","tid":1963964,"uid":160695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T16:23:03.000Z","msg":"推"},{"pid":"ddd7dad16fd1522019546b9a8e219106ab526e8f","tid":1963964,"uid":324752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-08T18:32:26.000Z","msg":"Push"},{"pid":"6a157f760e37f3d0a272a56690512ebde6cf16ed","tid":1963964,"uid":257779,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-09T11:13:46.000Z","msg":"唉今年考個班大多都p牌仔<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />推唔郁又冇人聽我哋意見<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"316daa2abd08604745846fbf61e6cd92a73dc3fd","tid":1963964,"uid":245670,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-09T13:00:34.000Z","msg":"溫書啦你哋<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"c6e1d3700d214e309470cbbfd3a4166780ecf612","tid":1963964,"uid":105396,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-09T13:04:21.000Z","msg":"講真其實都做唔到啲咩改變佢哋嘅決定<br />\n快啲溫書好過啦<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />裝備好自己唔好蝕抵<br />\n利申：都係今年考dse"},{"pid":"a9af1b52dbc5aed49ea9d62198a062bc261fdda3","tid":1963964,"uid":210165,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-09T13:05:16.000Z","msg":"此回覆已被刪除"},{"pid":"a142e92923f705386a6d43d7784c60429843e7a0","tid":1963964,"uid":186443,"like":0,"dis