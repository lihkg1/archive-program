和委員，全部與政府權貴有千絲萬縷的關係。<br />\n這班人受過港共的恩惠，享受著各式各樣的政治酬庸。<br />\n所謂「上訴」，你還覺得公正嗎？"},{"pid":"4138685ec99db3c8956931b64a4e1e96c275c5e4","tid":1370734,"uid":257319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T07:20:32.000Z","msg":"自推"},{"pid":"89371077ff9478d4c9f115d453160d3ec5c13189","tid":1370734,"uid":277144,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-27T07:20:33.000Z","msg":"光復香港"},{"pid":"0b831102eac14ebae3b3fc2a61fd7673e7b5caf7","tid":1370734,"uid":257319,"like":0,"dislike":0,"score":0,"quote":{"pid":"89371077ff9478d4c9f115d453160d3ec5c13189","tid":1370734,"uid":277144,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-27T07:20:33.000Z","msg":"光復香港"},"citedBy":0,"replyTime":"2019-07-27T07:25:05.000Z","msg":"時代革命<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"212d1a8974868a6afc8d5e121d426b05975b2bfa","tid":1370734,"uid":257319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T07:37:27.000Z","msg":"<img src=\"https://na.cx/i/BayXgm6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBayXgm6.jpg&h=8027205b&s={SIZE}\" />"},{"pid":"d56a091a6cc71d053c70620eb43f3c65a738a478","tid":1370734,"uid":257319,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-27T07:52:03.000Z","msg":"<img src=\"https://na.cx/i/KeurUdD.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKeurUdD.jpg&h=a1215dec&s={SIZE}\" />"},{"pid":"58decc041d54812f8aa8cde5fef394587e763c07","tid":1370734,"uid":136971,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T07:59:07.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"d36e67b9f0871a30b87510a3fbf712e6969fb2cf","tid":1370734,"uid":257319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-27T08:46:27.000Z",