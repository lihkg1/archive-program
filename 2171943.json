assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e7046cd6b29dd21854ce0f1d100bc2ecb2ae8dc8","tid":2171943,"uid":7439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-24T14:15:23.000Z","msg":"<blockquote>陸頌雄議員 ：有些議員快要 &quot;終極冇得做 &quot;，便會在這裏大放厥詞，我們已見怪不怪。</blockquote><br />\n<img src=\"https://i1.hdslb.com/bfs/archive/aa86831900d7dc08234f36219c4a671f57bbf907.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi1.hdslb.com%2Fbfs%2Farchive%2Faa86831900d7dc08234f36219c4a671f57bbf907.png&h=2a76031c&s={SIZE}\" />"},{"pid":"45576e3078a7f49113e090ce7b497012e4205bd5","tid":2171943,"uid":7439,"like":0,"dislike":0,"score":0,"quote":{"pid":"0f850577fcc85a6d908e8f0b459e3817ceffbdb8","tid":2171943,"uid":53127,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-08-24T09:49:11.000Z","msg":"議員工作=自己為先，上次含柒投佢班契弟死十次都唔夠<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-25T04:08:30.000Z","msg":"<img src=\"/assets/faces/lomoji/41.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/41.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/41.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/41.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/41.png\" class=\"hkgmoji\" />"}],"pinned":{"pid":"94721ffafcdeb79a3bcfaea86e30fb6f39ef4e3c","tid":2171943,"uid":29080,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-08-24T10:04:48.000Z","msg":"蟲泰將家庭生活帶入議會<br />\n為議員注入新動力<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"}}