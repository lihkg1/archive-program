{"tid":952752,"cid":7,"subCid":0,"title":"木 村 拓 哉 開 微 博 舞 王 羅 志 祥 秒 關 注！","createTime":"2018-12-23T11:46:09.000Z","updateTime":"2018-12-23T12:19:11.000Z","uid":215823,"like":0,"dislike":25,"uniUserReply":11,"replies":[{"pid":"dd8bc4544a2d8b976a658d7b18a55aae444871be","tid":952752,"uid":215823,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-23T11:46:09.000Z","msg":"木村終於在自己的微博發出第一條問候，他在視頻用中文跟粉絲打招呼：「我是木村拓哉，我開通微博了，請大家關注我！」而木村的超級粉絲「迷弟」羅志祥很快上線，激動留言「啊~」並留下數十個驚恐表情的emoji。不少網友立即留言及點讚，助羅志祥追星，稱「助力偶像追偶像」，又激讚羅志祥是「實力演繹看到說不出話經典場景」。 <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/12/23/194443_6e2e0238d750ece3c12dda98600d5871.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F12%2F23%2F194443_6e2e0238d750ece3c12dda98600d5871.png&h=d0ba8219&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/12/23/194533_65a24c2a767a1442e9d87cdc29bd9508.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F12%2F23%2F194533_65a24c2a767a1442e9d87cdc29bd9508.png&h=8d2112b1&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/12/23/194604_c090acb81efea4430a866436362580ce.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F12%2F23%2F194604_c090acb81efea4430a866436362580ce.png&h=20538558&s={SIZE}\" />"},{"pid":"03d6554c94362b8fe7c23f53c1436d4a3d9987e2","tid":952752,"uid":555,"like":1,"dislike":22,"score":-21,"citedBy":1,"replyTime":"2018-12-23T11:48:02.000Z","msg":"小豬最尾嗰張型過木村好多"},{"pid":"28b6dc87bb7b641f5c32490127f60c0623091063","tid":952752,"uid":215823,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-12-23T11:50:00.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/12/23/194952_db83684281b63960758e303b7fedb906.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F12%2F23%2F194952_db83684281b6396075