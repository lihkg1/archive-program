651,"uid":211461,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-10-24T13:55:18.000Z","msg":"亞視永恆<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"a4db3e48fbbb7d653f6853287099054c9e4dfd9a","tid":2256651,"uid":49336,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-10-24T13:58:48.000Z","msg":"此回覆已被刪除"},{"pid":"4a038680d3a4f3fb842eb8a4d01b2d66a5a07830","tid":2256651,"uid":1086,"like":1,"dislike":10,"score":-9,"citedBy":0,"replyTime":"2020-10-24T14:16:43.000Z","msg":"<p class=\"center\"><strong><span class=\"red\"><span class=\"xx-large\">達哥賣港<br />\n至今仍未對美國大選、中台局勢及泰國示威有任何表態,可恥</span></span></strong></p>"}]}