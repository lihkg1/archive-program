4.jpg&h=63f08456&s={SIZE}\" /><br />\n<img src=\"https://media1.tenor.com/images/c1515d8886faabb4282bed20d07da002/tenor.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia1.tenor.com%2Fimages%2Fc1515d8886faabb4282bed20d07da002%2Ftenor.gif&h=0ac4cf6d&s={SIZE}\" />"},{"pid":"f62ebc3e577e0d943aa1f6497e4173e0977e1e11","tid":1901263,"uid":262146,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-27T17:28:34.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />攬炒"},{"pid":"a5337cc3068062d3e65dc468caaed3fcfbe4bb80","tid":1901263,"uid":66498,"like":2,"dislike":0,"score":2,"quote":{"pid":"df4d1e3ceb6ec6464075496c201936ad5ea26893","tid":1901263,"uid":44437,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-27T17:23:41.000Z","msg":"<img src=\"https://assets.weforum.org/editor/-dQTVXmO7XsYKazm8deiXz5cm4RkvkiNk23CYL_UNWw.PNG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fassets.weforum.org%2Feditor%2F-dQTVXmO7XsYKazm8deiXz5cm4RkvkiNk23CYL_UNWw.PNG&h=57b92ade&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-02-27T17:28:35.000Z","msg":"就咁睇字面意思<br />\nNo evidence that companion animals / pets can be infected with the new coronavirus<br />\n即係佢冇否定寵物受病毒感染嘅可能性？<br />\n只係佢冇証據"},{"pid":"52cf37088770a863c923401e6aaee974e3ea1520","tid":1901263,"uid":202426,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-27T17:29:02.000Z","msg":"<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />"},{"pid":"bb03e5559576ab530361c52bdcad033a5f0a6b02","t