b658ad92ac65e30cde9d5978c21e45195f93c","tid":1305102,"uid":102535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T19:34:45.000Z","msg":"我無野講"},{"pid":"7f87e2d7f5c347746b910ce1893493a7913619b8","tid":1305102,"uid":185092,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T19:35:47.000Z","msg":"一定還拖"},{"pid":"6a863c5df920aab1f2d9fd972682cc1ca446cb2b","tid":1305102,"uid":127085,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T19:40:27.000Z","msg":"Push"},{"pid":"979d78551abed66e0654176450f4167de6a9002d","tid":1305102,"uid":102535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T19:46:13.000Z","msg":"我無野講"},{"pid":"deb56dfbce8b1770de35c43cb1aa3fc420f78c76","tid":1305102,"uid":38154,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-10T19:47:24.000Z","msg":"Push"},{"pid":"11e61fc758ab3c19d99025e72f58aea7255ad0e5","tid":1305102,"uid":102535,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-10T20:00:56.000Z","msg":"<span style=\"color: red;\">For 圍觀人士 但又想幫拖嘅人</span><br />\n最好有片影住個次序<br />\n你幫手制服佢(純粹捉手腳) &gt; 佢襲擊你 &gt;你用同等武力自衛(拳頭還擊)<br />\n最好嘅辦法係<span style=\"font-size: x-large;\"><span style=\"color: red;\">大聲講出嚟</span></span><br />\n「我依家淨係捉住你手腳唔比你再襲擊人」<br />\n「你唔好打埋我，唔係我就自衛還手」<br />\n就算上到法庭<br />\n檢控官係有責任反証自衛的辯護理由不成立<br />\n反証唔到=你係屬於自衛=無罪"},{"pid":"59153746341741c7390e7b66e3f3e17726278e50","tid":1305102,"uid":102535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T00:35:39.000Z","msg":"我無野講"},{"pid":"a9dbc0301a6dd167ee3cebfe837f5266e876faea","tid":1305102,"uid":70888,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-11T00:42:02.000Z","msg":"推"}]}