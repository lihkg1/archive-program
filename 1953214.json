otalonehk/13579</a>"},{"pid":"3400348f7898abf45aea0797d4046bfa6099dd43","tid":1953214,"uid":126066,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T02:27:07.000Z","msg":"Push"},{"pid":"ab64ddac75803f5983daaa110149138f9199ed76","tid":1953214,"uid":114781,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T02:31:40.000Z","msg":"各位分散幫趁啦好冇<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"89eed1c429dab1383bc7cd26c8968e7276057a65","tid":1953214,"uid":53431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T02:41:09.000Z","msg":"Al forno soho啲pizza真心推薦！！！<br />\n中上環返工可以去支持下<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n利申 琴日先食完"},{"pid":"2f7d1ec058b179015981bdc494f515c54abd9864","tid":1953214,"uid":3149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-03T02:54:19.000Z","msg":"Push <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"6ff9d4cc5cfcd97dde0f32893c0eb494825b5a2e","tid":1953214,"uid":94771,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-04-01T05:18:59.000Z","msg":"有條黃色YouTube影片比藍絲dislike，但得400幾個like<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1953128\" data-auto-link target=\"_blank\">https://lih.kg/1953128</a><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=Dgj0xdl9qNk&amp;feature=youtu.be\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DDgj0xdl9qNk%26feature%3Dyoutu.be&d=fPi9TpucIiEDTgLGk%2FOmnXGrSSjb4k8A9Srgfm1924U%3D&h=c2515253\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=Dgj0xdl9qNk&amp;feature=youtu.be</a>"}}