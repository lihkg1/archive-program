9:48.000Z","msg":"做鞋大陸無左優勢好多年啦。。"},{"pid":"6433095c142bc91955b09d1a59e9a80dd731ff93","tid":642153,"uid":44580,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-25T15:40:43.000Z","msg":"咩情況下中國都贏 除左踢波佢地點先會輸？"},{"pid":"9c281d237153effb985e261872976aea706bf668","tid":642153,"uid":35580,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-25T15:41:00.000Z","msg":"厲害了"},{"pid":"6f51e75e6fa2557ae3115fd637e0644021307aec","tid":642153,"uid":10438,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-25T15:41:42.000Z","msg":"安踏食埋啲廠 中國又贏<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f5099db5b24c14d5f066417f703784e017014ff3","tid":642153,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-25T23:09:31.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8454680a5921d74336390b08916b4813ff048492","tid":642153,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"96afb96658e8581d81ea22f79c0de1d6a234e042","tid":642153,"uid":95397,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-04-25T14:24:33.000Z","msg":"厲害了我的國<br />\n可以笑到最後<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-25T23:10:21.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"}]}