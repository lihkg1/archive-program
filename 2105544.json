/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b9fc4b5c979cba98a505f89b57b45ea31107c256","tid":2105544,"uid":45772,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-12T17:10:14.000Z","msg":"樓主幾高幾重？"},{"pid":"6b4c898f98d37c7c2fea2a9dfa9d090e58118233","tid":2105544,"uid":16461,"like":30,"dislike":1,"score":29,"citedBy":1,"replyTime":"2020-07-12T17:11:05.000Z","msg":"認真答<br />\n<br />\n瘦同肥係人嘅自由選擇，每個人都值得被尊重（除左人格有問題）。但他人對妳嘅好感你就沒有辦法去控制，人地直覺對身型偏肥嘅人冇咁大好感，妳咪用其他方面嘅優點去證明妳嘅價值。<br />\n<br />\n如果妳一世都覺得人地唔尊重/唔鍾意妳係只因為妳肥，咁冇人幫到妳，因為連妳自己都認為身型係一個問題<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 我有個女仔朋友係肥+天生外表有缺陷，但佢人際關係十分好，亦唔會覺得自己身型有問題<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"25eb68297a3ebbe8e72899f8a7e1bb8b1f7244b4","tid":2105544,"uid":71632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-12T17:11:43.000Z","msg":"肥都有人屌仲怪人呃蝦條？<img src=\"/assets/faces/dog/stop.gif\" class=\"hkgmoji\" />"},{"pid":"bc0cdbf696f5bef79344b7e5de0e470fb2651617","tid":2105544,"uid":208642,"like":5,"dislike":0,"score":5,"quote":{"pid":"6b4c898f98d37c7c2fea2a9dfa9d090e58118233","tid":2105544,"uid":16461,"like":30,"dislike":1,"score":29,"citedBy":1,"replyTime":"2020-07-12T17:11:05.000Z","msg":"認真答<br />\n<br />\n瘦同肥係人嘅自由選擇，每個人都值得被尊重（除左人格有問題）。但他人對妳嘅好感你就沒有辦法去控制，人地直覺對身型偏肥嘅人冇咁大好感，妳咪用其他方面嘅優點去證明妳嘅價值。<br />\n<br />\n如果妳一世都覺得人地唔尊重/唔鍾意妳係只因為妳肥，咁冇人幫到妳，因為連妳自己都認為身型係一個問題<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 我有個女仔朋友係肥+天生外表有缺陷，但佢人際關係十分好，亦唔會覺得自己身型有問題<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2020-07-12T17:12:13.000Z","msg":"但本身傾得好哋哋 大家有feel 一見面就飯都唔食走咗係點解"},{"pid":"2b98e99d1f9191ad4a5ea76cbb8118b2cfe06153","tid":2105544,"uid":208642,"like":0,"dislike":4,"score":-4,"quote":{"pid":"b9fc4b5c979cba98a505f89b57b45ea31107c256","tid":2105544,"uid":45772,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-12T17:10:14.000Z","msg":"樓主幾高幾重？"},"citedBy":1,"replyTime":"2020-07-12T17:12