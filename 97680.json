06:26.000Z","msg":"文呢?"},{"pid":"cbb967202351575f6823d13ffac33f3d50e81cde","tid":97680,"uid":29236,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T05:10:01.000Z","msg":"出文未呀屌你老母"},{"pid":"70e6bdf4e0537542199dc41d88447198b10d043c","tid":97680,"uid":23544,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-01-28T05:13:28.000Z","msg":"文呢<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"99513f9ca5b2ede6efbad3d8ba04083b8eecc8c9","tid":97680,"uid":4484,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T05:16:30.000Z","msg":"個袋毒品黎"},{"pid":"81ee452e369e3ab6425f3baf71a234a81bec38e7","tid":97680,"uid":4172,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T05:25:12.000Z","msg":"文呢"},{"pid":"ff71300fffc33f6283629d47174e32edfcf4a57b","tid":97680,"uid":21088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T05:29:54.000Z","msg":"樓主比人拉左？"},{"pid":"2fe048d04ad1fe3fd8f06663238fdbe65d04b72b","tid":97680,"uid":56538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T05:45:12.000Z","msg":"年初一要拜年，晏啲再出<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a3ebb054168df169e2b7bb23885b9e6c8390a24e","tid":97680,"uid":9076,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T06:43:51.000Z","msg":"<blockquote>年初一要拜年，晏啲再出<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n屌係老母文呢"},{"pid":"62717b22d0be4b8b3f4213c9ba4742ace604fd97","tid":97680,"uid":56538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T07:37:11.000Z","msg":"欣：「不如食左野先咯，有啲肚餓。」<br />\n<br />\n佢講完之後我都覺得餓餓地，不過我想食左呀欣先多過食野先，話晒岩岩比佢挑逗完，加上佢又靚，唔小心細佬都進下咗升旗禮，好彩著左牛仔褲，表露得無咁明顯。<br />\n<br />\n我：「你想食咩，米線？」<br />\n<br />\n佢點一點頭示意ok，之後我帶左佢去一間老字號，平時食開既米線鋪，係警局隔離。<br />\n<br />\n呀欣一坐底就問我：「你食唔食得辣架？」<br />\n<br />\n其實我平時份人清清淡淡，好少食辣野，辣妹我就食，其他咪搞，始終鍾意原汁原味，所以我既極限只係中辣，仲要食親都要飲成支水，不過為左威比條女睇，老虎蟹都話食得，點知就出事......<br />\n<br />\n呀欣：「我好鍾意食辣野架，但係我又唔係幾食得辣，不如我叫碗大辣既比你啦，我自己叫碗小辣，到時比我試下大辣係點好冇？最多當你滿足到我一個要求。」<br />\n<br />\n佢既然講到咁，咁緊係頂硬上啦。<br />\n<br />\n碗米線黎到之後，聞到陣味已經連眼水都標埋，明明唔食得辣都叫咁辣，依次真係捉蟲。<br />\n<br />\n欣：「試下先，唔，好食喎。」呀欣試完我碗大辣既湯之後面不改容，睇黎佢真係好食得辣......<br />\n<br />\n我食粒賴尿牛丸果陣，都辣到仆街，黎緊仲有一大碗大辣米線，都唔知點搞......<br />\n<br />\n我一路食，一路流哂鼻水眼水，個嘴辣到無哂感覺，好撚辣呀！！！<br />\n<br />\n我望向隔離既呀欣，佢好似無乜野咁，相反我就好大獲野，我好想放棄唔食，因為我真係頂唔順，而且仲要有啲急屎既感覺，睇黎之前睇杜汶澤套戲食辣野食到賴屎係真，希望一陣唔好發生係我身上......"},{"pid":"edc55a9145607e2c3300654ec6a5cb49137a5bbe","tid":97680,"uid":3527,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T07:48:17.000Z","msg":"留名"},{"pid":"b737676fdb751f5904cc1ad384fc2059d90bb7f1","tid":97680,"uid":59679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T08:36:51.000Z","msg":"推"},{"pid":"b3d6cf535e1e7e4def3423e6a159c39d7290c0a4","tid":97680,"uid":49716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T08:41:51.000Z","msg":"留名"},{"pid":"4b3eaf5fd8f58676ac80c38d205da07456dc291b","tid":97680,"uid":51078,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T08:50:04.000Z","msg":"留名"},{"pid":"4f47c075090575236a2497040fb6261190d8aefc","tid":97680,"uid":71960,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T08:59:32.000Z","msg":"樓主有新故 留名<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a0078a4a9cc415a6f4d1dcf0b3e39bc01ceeb4da","tid":97680,"uid":28953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T09:08:26.000Z","msg":"加速啦<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"f4a44930df8d3117300e58625108ad216604f32e","tid":97680,"uid":56538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T09:18:57.000Z","msg":"唔記得講，依個故係訓醒發現上左女神既外傳黎，當中有少少劇情牽連到之前個故仔到，呀妮都會係依個故到出場，同埋出文有啲慢，希望各位巴打絲打多多包容，有咩寫得唔好唔怕講，盡量改，百屌成材<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"d62e407c890ddd2a7b32f725a804508a835eef71","tid":97680,"uid":80169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T09:31:55.000Z","msg":"留名"},{"pid":"0e7b752a9b94b75bc5c013db2d77a54709127764","tid":97680,"uid":28216,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T09:34:10.000Z","msg":"Lm"},{"pid":"b94d5a0080e10044450776e0bb5a23b4d33f845d","tid":97680,"uid":56538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T18:32:37.000Z","msg":"由於碗米線太辣既關係，我已經飲哂支烏龍茶，但碗野仲有成一半......<br />\n<br />\n依一刻我無受到任何刺激，都流哂眼水鼻水口水，未有任何奬勵，都已經咁辛苦，真係問世間辣為何物，直教大辣湯底。<br />\n<br />\n食完碗麵之後，我即刻9秒9埋單，再沖去搵廁所辦一辦大事，呀欣就係店門口到等我，大概幾分鐘後已經我出返去搵呀欣，順便買支凍水解一解辣。<br />\n<br />\n欣：「總算你完成左我一個要求啦，碗野辣唔辣呀？」<br />\n<br />\n我聽完依句發現有啲陰謀，個心寒咗一寒，開始有啲不祥預感，我懷疑條女一早知我唔食得辣。<br />\n<br />\n我：「都幾辣下，下次都係食番清湯算。」<br />\n<br />\n呀欣無理我，繼續向前行，我愈黎愈覺得有啲古怪，直覺話我知條女有啲問題。可惜，愛情係會令人盲目，我唔知點解，我明知條女有古怪，都照繼續陪佢，可能依啲就係犯賤......<br />\n<br />\n行行下呀欣開始同我講下啲電影既劇情，講講下就出事喇。<br />\n<br />\n我同佢唔知點解傾到那些年套戲既劇情，佢忽然間覺得個女主角好幸福，有男主角咁愛佢，咁為佢好，我同佢講戲黎架，唔好諗咁多。之後佢鬧番我無黎幻想，唔識代入喎，慢慢仲嘈起上黎添。<br />\n<br />\n我：「邊得黎咁多依啲愛情故事丫。」<br />\n<br />\n欣：「你份人比啲浪漫得唔得丫，你唔可以代入個角色到架咩，幻想下自己比個男主角背後默默嘅付出有幾幸福。」<br />\n<br />\n我無幻想！？我夠成日幻想av入面個男優係我，幻想自己做六合彩，幻想將你就地正法，幻想呀怡會返黎我既身邊......<br />\n<br />\n我：「算啦，套野都鬼死咁耐，講過第2樣啦」<br />\n<br />\n欣：「唔要呀！我要你做我既柯景騰！」<br />\n<br />\n睇黎佢真係睇套野睇到上哂腦，不過算，同佢玩下角色扮演都無乜所謂。<br />\n<br />\n我：「係既，我既沈佳宜。」<br />\n<br />\n欣：「嘻嘻，不如我地打賭丫。」我感覺到伏味濃...<br />\n<br />\n我：「唔好玩啦...」<br />\n<br />\n欣：「唔得丫，一定要玩，我地玩包剪揼，你輸咗既就要剪光頭，我輸咗既就扎馬尾同你行成日。」<br />\n<br />\n姐係如果佢唔係女既話，我一定話佢on9加白痴，讀過公平理論既都覺得依個規矩好唔公平，你扎馬尾同我行街都算懲罰？不如掉轉丫好冇？<br />\n<br />\n我：「咪玩啦，醫生話我個頭傷咗唔曬得太陽呀，要靠啲頭髮遮住個傷口，你咁做姐係要我死姐。」<br />\n<br />\n當然依啲大話佢聽完都唔會信，完全動搖唔到佢既決心，既然佢玩到咁大，睇黎今日既約會都要終止，我都費事再嘥時間同條女癲。<br />\n<br />\n我諗住求其搵個藉口諗住走咗去，同佢講話屋企伯母比人打擾架，要趕番去拯救我老母，可惜之後既情況發展令我中止咗我既護媽行動......"},{"pid":"19eb5b09e69b713bbebe488d833709d99293c2ad","tid":97680,"uid":56538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T18:35:09.000Z","msg":"好奇問下，我係咪寫得好差？<br />\n<br />\n因為見負評幾多下<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"403bbc8633cee0a9db71f039beb46ee2e442bdd4","tid":97680,"uid":8528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T18:56:24.000Z","msg":"快啦"},{"pid":"402aedc30654ac5af1fb90c0cb8fa3fe32fb27e7","tid":97680,"uid":74728,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T19:06:02.000Z","msg":"幫條女運毒？"},{"pid":"85521d773e2fe8e372237a78abcae77471d4c3fc","tid":97680,"uid":77583,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T19:06:12.000Z","msg":"追得好辛苦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f47296091939d2944339e862ba7cef819b8fa29c","tid":97680,"uid":74728,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T19:08:59.000Z","msg":"<blockquote>好奇問下，我係咪寫得好差？<br />\n<br />\n因為見負評幾多下<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n繼續,追緊"},{"pid":"bd1276513242016c6fbedc540114e173a8f9ea46","tid":97680,"uid":66311,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T19:25:44.000Z","msg":"都幾得意既"},{"pid":"f2763039dd2d01a9bfc57eddd62190cf6b23a01d","tid":97680,"uid":56538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T19:33:33.000Z","msg":"聽朝再出，早抖咁多位<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c39f1fd1df18ccb8854199ea263913bb5a802177","tid":97680,"uid":75540,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T19:34:16.000Z","msg":"此回覆已被刪除"},{"pid":"7d46e5a8513de049123693a4ef93b9160877d3de","tid":97680,"uid":43763,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T19:34:21.000Z","msg":"加速<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"25b1c4aeeb8086c9f7e2c16fd901bbc57b2664bf","tid":97680,"uid":73969,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-28T19:48:48.000Z","msg":"留名"},{"pid":