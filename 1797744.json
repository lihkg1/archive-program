\" />"},{"pid":"6c7c4a42fb2318de26764eab43a7d0b14f734c2f","tid":1797744,"uid":181549,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T02:17:18.000Z","msg":"<img src=\"https://na.cx/i/An66QAo.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAn66QAo.jpg&h=d0222e2f&s={SIZE}\" />"},{"pid":"2488e5578b712244067640dd2fd5a180fe6a5643","tid":1797744,"uid":226594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T02:39:32.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"bbfc93ad00ac8b2a51bf826d1765adccc1b6dc4d","tid":1797744,"uid":226594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T02:43:53.000Z","msg":"<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"476ec40355fa24c50d25f931436d9b68b651f9b6","tid":1797744,"uid":226594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T02:46:24.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"86b5318ae5532ccd7ed3efe41d4f38dbf185082d","tid":1797744,"uid":226594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T03:07:35.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"f3afdae80165ab1b506d41261088586be0e13167","tid":1797744,"uid":226594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T03:14:56.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"58975e5f39a3e9ba590682463878b5ac7743e72e","tid":1797744,"uid":113155,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T03:18:52.000Z","msg":"好出色啊！"},{"pid":"05580fd4c96989e4e734a15caf625d25a853fd6f","tid":1797744,"uid":113155,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T03:23:51.000Z","msg":"好出色喎"},{"pid":"beeca5d9cde04bf615f588d063de55f3b8c39d37","tid":1797744,"uid":234357,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T03:33:36.000Z","msg":"831"},{"pid":"503d9f59c0622da48efce94c5ecdfd01f08762b5","tid":1797744,"uid":300592,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-15T03:44:12.000Z","msg":"今日（15號）12:00-14:00愛丁堡：<br />\n「全民力拒制度暴力、你我堅守程序公義」集會<br />\n日期： 1月15日（星期三）<br />\n時間： 12:00 &ndash; 2:00pm<br />\n地點: 中環愛丁堡廣場<br />\n<br />\n【以下代港大校友關注組發出】<br />\n<br />\n各位校友／教員，<br />\n<br />\n去年4月底香港大學法律系副教授戴耀廷先生因發動「愛與和平佔領中環運動」被判入獄16個月，當時一些針對戴教授的個別人士和團體窮追猛打，要求香港大學立即革除戴教授的教席，不少團體(包括港大校友關注組)當時已通過聯署信等方式呼籲港大校方恪守程序公義原則，在戴教授就控罪提出上訴並完成所有法律程序前不應啟動任何終止戴教授教席的安排。但據悉港大校方已在去年成立了對應的 Committee of Enquiry into Possible Good Cause（&ldquo;Good Cause Committee&rdquo;）去處理此事宜（備註），並在今個月內開會最終確認是否在戴教授完成上訴程序前啟動並審理其個案。<br />\n<br />\n我們對於香港大學校方悍然違反程序公義的做法表示強烈的憤慨，特別是如 Good Cause Committee 給予革除戴耀廷教授教席的裁決後，其控罪稍後又被推翻的話，這種不合理的做法明顯違背香港的核心價值 &ndash; 程序公義。事實上這個元素是香港實行「無罪推定」普通法的基本原則，也是區分香港和中國法制的最重要一環。從反修例事件以來的多月中，我們明顯看到香港政府在不同領域帶頭破壞此核心價值 -- 選舉主任不聽候選人的申辯就隨意取消參選資格、公務員被逮捕後就馬上開展被停職的程序，及私人公司如國泰等單憑社交網站的匿名發言截圖投訴解僱員工等，顯示政權通過此方法去恫嚇持相反政見的巿民，而教育界更是政府和建制派的針對對象，將他們管治失當的責任推卸到老師和學校。早前教育局局長楊潤雄已向中學施加壓力，表示要對所有被逮捕的教師馬上停職，而林鄭月娥近日亦再次重申她絕「不會手軟」，繼續向教育界和公務員團隊打壓，處罰「違規」的教師和公務員。<br />\n<br />\n我們認為政權不單繼續拒絕聽從香港社會的主流意見，從上述舉措更彰顯其不顧破壞香港核心價值也要全力鎮壓的立場，在此我們：<br />\n<br />\n1．呼籲香港大學校方恪守程序公義原則，在戴耀廷教授完成上訴法律程序前停止相關委員會的審理安排。<br />\n<br />\n2．敦促香港各大學管理階層堅持院校自主及學術自由的原則，抵抗政權對教育界的打壓和秋後算賬。<br />\n<br />\n3．希望社會各界團結支援教育界持份者相關組織和公民團體守護程序公義，免受政權的侵害。<br />\n<br />\n我們連同港大學生會評議會大學事務委員會及香港大學教師及職員會將會在明天中午在中環愛丁堡廣場舉行下列集會：<br />\n「全民力拒制度暴力、你我堅守程序公義」集會<br />\n日期： 1月15日（星期三）<br />\n時間： 12:00 &ndash; 2:00pm<br />\n地點: 中環愛丁堡廣場<br />\n<br />\n希望大家能抽空參加此集會，向林鄭政府表達我們不會屈服於它們的壓力和守護程序公義氣的決心和立場！<br />\n<br />\n港大校友關注組 <br />\n2020年1月14日<br />\n<br />\n備註：<a href=\"https://www.universityworldnews.com/post.php?story=20190816103158703\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.universityworldnews.com%2Fpost.php%3Fstory%3D20190816103158703&d=TvOq0m68uPCtaVYdNLQuFDBOARg6NHmmMIcc3tsY8ek%3D&h=8790ed51\" data-auto-link target=\"_blank\">https://www.universityworldnews.com/post.php?story=20190816103158703</a><br />\n<br />\n港大校友關注組 Facebook：<a href=\"http://bit.ly/2QQyt5N\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2F2QQyt5N&d=TvOq0m68uPCtaVYdNLQuFDBOARg6NHmmMIcc3tsY8ek%3D&h=ce2f9f26\" data-auto-link target=\"_blank\">http://bit.ly/2QQyt5N</a>"},{"pid":"b33d0ec51781b398154e28605413ff925c4902b1","tid":1797744,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-16T05:54:26.000Z","msg":"<a href=\"https://hkrev.info/main.php\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhkrev.info%2Fmain.php&d=TvOq0m68uPCtaVYdNLQuFDBOARg6NHmmMIcc3tsY8ek%3D&h=0a972fef\" data-auto-link target=\"_blank\">https://hkrev.info/main.php</a><br />\n感謝整依個網站嘅人<img src=\"/assets/faces/xm/adore.gif\" class=\"hkgmoji\" />"},{"pid":"89d8c7a3c966aff4f9d9bd74823b2e30e1bd5b9c","tid":1797744,"uid":129068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-19T13:28:12.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1a490b95e53dc5262493ee18674aec89e727d3e2","tid":1797744,"uid":129068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-19T13:28:22.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"24c9cbac79df6bfa0bef43ae3692177f1d42419f","tid":1797744,"uid":109918,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-19T13:28:57.000Z","msg":"推"},{"pid":"6c6442614003af8e9cb452de40258fc9c1bf7852","tid":1797744,"uid":129068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-19T13:30:58.000Z","msg":"<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"4c3b9f37a7b0ef34fa0cdb20ed3763fd03875340","tid":1797744,"uid":61690,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-19T14:32:40.000Z","msg":"勁"},{"pid":"5f26ec244899f35a241f04b6732e512d45a39de8","tid":1797744,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-20T06:04:25.000Z","msg":"1月20日 星期一 活動 時間/地點<br />\n<br />\nJanuary 20, 2020<br />\n紅磡:龍門冰室 x 香港人嘅冰室資源分享中心<br />\n黃埔年宵後續．九號水產年宵市集<br />\n12p 中環:香港保險㒰人職工會街站<br />\n2p 荔枝角:香城年宵新年市集<br />\n5:30p 鰂魚涌:白領工會街站<br />\n6p 旺角:和理過年&bull;宵市集<br />\n6p 觀塘:香港檢測及認證職工會街站<br />\n7:30p 元朗區聯署集會- 185/6=721<br />\n8p 九龍灣 小願望 和你寫<br />\n<br />\nRef :<br />\n<a href=\"https://hkrev.info/march.php\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhkrev.info%2Fmarch.php&d=TvOq0m68uPCtaVYdNLQuFDBOARg6NHmmMIcc3tsY8ek%3D&h=41e6866b\" data-auto-link target=\"_blank\">https://hkrev.info/march.php</a>"},{"pid":"510e48d2f4a7da7da39b7c37f081da7080b0efeb","tid":1797744,"uid":25558,"like":0,"dislike":0,"score":0,"quote":{"pid":"8a4b3b1ff43bee52c0ff6ecff4a9507f0418ea97","tid":1797744,"uid":232900,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-14T01:45:09.000Z","msg":"推"},"citedBy":0,"replyTime":"2020-01-22T02:33:21.000Z","msg":"<a href=\"https://hkrev.info/main.php\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhkrev.info%2Fmain.php&d=TvOq0m68uPCtaVYdNLQuFDBOARg6NHmmMIcc3tsY8ek%3D&h=0a972fef\" data-auto-link target=\"_blank\">https://hkrev.info/main.php</a><br />\n感謝整依個網站嘅人<img src=\"/assets/faces/xm/adore.gif\" class=\"hkgmoji\" />"},{"pid":"dc86b12a5555d6192a69d83f42dce6b132fe0675","tid":1797744,"uid":107577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-22T02:45:13.000Z","msg":"推"},{"pid":"83c8c19c13edc0d62dca9189605b9c0253160c59","tid":1797744,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-23T11:14:04.000Z","msg":"<a href=\"https://hkrev.info/main.php\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhkrev.info%2Fmain.php&d=TvOq0m68uPCtaVYdNLQuFDBOARg6NHmmMIcc3tsY8ek%3D&h=0a972fef\" data-auto