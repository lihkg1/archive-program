 />"},{"pid":"2e0a3620a41e96fe8e95e42ab1d53b53339e1899","tid":1797744,"uid":129068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-25T16:45:18.000Z","msg":"<img src=\"/assets/faces/dogxm/beg_connect.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dogxm/give.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"b04a7bae3fec83885e399d02ca754a0412a1d591","tid":1797744,"uid":129068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-25T16:45:34.000Z","msg":"<img src=\"/assets/faces/dogxm/beg_connect.gif\" class=\"hkgmoji\" />"},{"pid":"1ae6735ff00633bfbf74c4a3ebc64ad5365b7612","tid":1797744,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-25T16:47:44.000Z","msg":"推呀,  好嘢嚟<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"8c7b7b0417f8de0e4f7e555b9bf19de021a7609f","tid":1797744,"uid":27993,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-25T16:48:20.000Z","msg":"推到香港重光！"},{"pid":"fcb372efc2a65003729d4ff97c220e62b16cba28","tid":1797744,"uid":334720,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-25T16:50:46.000Z","msg":"<span style=\"color: red;\"><strong><ins>SHOP商場戰略檢討與重點</ins></strong></span> 幫手share<br />\n<br />\n<span style=\"color: red;\"><ins><strong>1) 12點好撤，再留係度攬炒指數低</ins></strong></span><br />\n<span style=\"color: teal;\">咁夜對政權既傷害係邊度? 個撚個都返鳩哂屋企訓教, 車又少。同玩平原戰 自殺有咩分別? 大家要記住個目標係乜野。街上又無其他路人幫你地cover, 過左12點又無車走。好似琴日MK咁, D人又話走唔撚到比狗包圍住。咁唔該你地今日咪撚再要呀寶出動</span><br />\n<br />\n<span style=\"color: red;\"><strong><ins>2) 落閘就目標已達成, 可以轉場</strong></ins></span><br />\n商場落閘基本上都係因為D狗入撚哂黎, 咁達成目標 無需要再屌狗同戀戰<br />\n<br />\n<span style=\"color: red;\"><strong><ins>3) 回馬槍，D狗走個時唔撚好再上前</ins></strong></span><br />\n尤其是商場入面，例如琴日ＹＯＨＯ已經比人回馬槍左起碼3-4次。每次都捉撚左2-3個。屌狗還屌狗, 你地係後面屌就爽, 企前面既街坊就中伏。唔好再做豬隊友<br />\n<br />\n<span style=\"color: red;\"><strong><ins>4) 街坊被捕個時麻煩街坊咪撚係度嘈</ins></strong></span><br />\n琴日已經有幾次係因為街坊太嘈, 個街坊大聲叫都無人聽到佢講乜, 咁樣同害9自己友無分別。一陣無名無姓無資料, 係咪想人地被消失??"},{"pid":"97f64514fd90860e64f368068ecfdeea95670898","tid":1797744,"uid":129068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T03:17:14.000Z","msg":"推"},{"pid":"0393cd4a12c98fa802274dabfa19f8ef82b66241","tid":1797744,"uid":201238,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T03:19:06.000Z","msg":"推"},{"pid":"60985a1b7f9a1eed86a2ec57f2e2400eb17ba6e9","tid":1797744,"uid":129068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T07:00:44.000Z","msg":"推"},{"pid":"7b592d8768a784162fb000e92f56a4183fba3fac","tid":1797744,"uid":129068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T07:27:22.000Z","msg":"推"},{"pid":"1ce20926d1b24f1f167815dba572bfab6429b27c","tid":1797744,"uid":129068,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T07:27:35.000Z","msg":"推"},{"pid":"b6de1c4c7f22bf6cb12464b568d4a816c30f2a31","tid":1797744,"uid":3776,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T07:28:43.000Z","msg":"推到佢地仆街"},{"pid":"ecbfd793ab8c6ca0b15d4f77e4b6e9a121c7f08a","tid":1797744,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T07:28:45.000Z","msg":"好野要推"},{"pid":"b7c2d575fe7ceb1e490f10e3fd4b6115c44a9727","tid":1797744,"uid":19501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T07:28:49.000Z","msg":"<img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" />"},{"pid":"2d8c80fc2676c22d4d39235d8dc273d1a21e1ddd","tid":1797744,"uid":18223,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-26T07:42:09.000Z","msg":"Push"},{"pid":"1d430c76b41602874de470562aab34f8d1dbc23a","tid":17977