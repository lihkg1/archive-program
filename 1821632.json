gmoji\" />"},{"pid":"1c6e19487021ff8d6f7ce7958688c712884e4a05","tid":1821632,"uid":187948,"like":1,"dislike":0,"score":1,"quote":{"pid":"b8892ba322eab7894c95d68d95946d5f316b6180","tid":1821632,"uid":127807,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-12T13:26:17.000Z","msg":"睇行動POST好過"},"citedBy":0,"replyTime":"2020-01-12T13:28:27.000Z","msg":"大敵當前，未對外先對內，難成大器。但不解除內憂、難以聚軍心對外患"},{"pid":"5c0eae7cfef667fe4a3bac61d77b9de219937fa0","tid":1821632,"uid":70897,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T13:29:42.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"f0ad9588e372eabf67c5e2ceffbe73f9545d2294","tid":1821632,"uid":216390,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T13:33:27.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"b43ca08555307a77e447c2b40d8025c39ece9b7c","tid":1821632,"uid":187948,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-12T13:10:26.000Z","msg":"袁紹死後（活動失敗），袁譚（和理非）同袁尚（勇武）內訌，曹操軍官（傻強）就覺得要趁佢病攞佢命，郭嘉（中共軍師）表示：這時去打、二袁必一致對外。最後兩人打到頭破血流，比曹操（中共）輪流收拾，平定河北（香港）"}}