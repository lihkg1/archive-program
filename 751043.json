normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d06e8f7ae0347562def38b3564ac4559f6eeb99a","tid":751043,"uid":1977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-22T05:12:27.000Z","msg":"識貨<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"f5d3c1a0a98b0168135b3c8f95957b5f1b5cebd2","tid":751043,"uid":25771,"like":0,"dislike":0,"score":0,"quote":{"pid":"28fcd05ae0b8b383c0f7b3e1c381073a88d2c623","tid":751043,"uid":85284,"like":1,"dislike":0,"score":1,"quote":{"pid":"562e0acb6c3cc98d3b9ad95cb8813f28236bf4ba","tid":751043,"uid":191926,"like":14,"dislike":1,"score":13,"citedBy":1,"replyTime":"2018-07-21T13:50:31.000Z","msg":"當年係華西 評價好高<br />\n巴塞係皇馬手上搶到 仲放哂煙花<br />\n<br />\n見到2年前 古天奴傳巴 巴post<br />\n仲一堆人覺得古天奴可能廢過高美斯"},"citedBy":1,"replyTime":"2018-07-22T05:06:50.000Z","msg":"我覺得<br />\n而家巴塞嘅陣／打法，係會減低整體型踢法球員嘅表現<br />\n高美斯就係其中一個受害者<br />\n幾年前盛世時巴塞嘅陣／打法，球員間距離較短，而且係高連繫／呼應性<br />\n而家嘅巴塞<br />\n第一，球員相對上係企死位<br />\n第二，球員間嘅距離俾拉遠<br />\n而最大鑊就係佢哋用呢種陣／打法嚟打互傳組織<br />\n睇返高美斯喺華西時<br />\n隊波啲球員好多時係企生位<br />\n咁佢就可以發揮到佢嘅整體型踢法"},"citedBy":1,"replyTime":"2018-07-22T05:40:31.000Z","msg":"咁點解踢國家隊都係咁屎？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"72ab2509778649487f1f36412d9b9f3d21447ca9","tid":751043,"uid":2607,"like":1,"dislike":0,"score":1,"quote":{"pid":"f5d3c1a0a98b0168135b3c8f95957b5f1b5cebd2","tid":751043,"uid":25771,"like":0,"dislike":0,"score":0,"quote":{"pid":"28fcd05ae0b8b383c0f7b3e1c381073a88d2c623","tid":751043,"uid":85284,"like":1,"dislike":0,"score":1,"quote":{"pid":"562e0acb6c3cc98d3b9ad95cb8813f28236bf4ba","tid":751043,"uid":191926,"like":14,"dislike":1,"score":13,"citedBy":1,"replyTime":"2018-07-21T13:50:31.000Z","msg":"當年係華西 評價好高<br />\n巴塞係皇馬手上搶到 仲放哂煙花<br />\n<br />\n見到2年前 古天奴傳巴 巴post<br />\n仲一堆人覺得古天奴可能廢過高美斯"},"citedBy":1,"replyTime":"2018-07-22T05:06:50.000Z","msg":"我覺得<br />\n而家巴塞嘅陣／打法，係會減低整體型踢法球員嘅表現<br />\n高美斯就係其中一個受害者<br />\n幾年前盛世時巴塞嘅陣／打法，球員間距離較短，而且係高連繫／呼應性<br />\n而家嘅巴塞<br />\n第一，球員相對上係企死位<br />\n第二，球員間嘅距離