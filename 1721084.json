2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20181010%2F20518828&d=zfTWtzkQ24d%2FEmJzkWMc69B4iDtRAy51VXy1YCRVmoY%3D&h=06de4b03\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20181010%2F20518828&h=878a6ccb\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20181010/20518828</a>"},{"pid":"6c3784cdd85f01815e67ec3107a84dac704c1e5e","tid":1721084,"uid":149829,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T14:46:59.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/daily/article/20181010/20518828\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20181010%2F20518828&d=zfTWtzkQ24d%2FEmJzkWMc69B4iDtRAy51VXy1YCRVmoY%3D&h=06de4b03\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20181010%2F20518828&h=878a6ccb\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20181010/20518828</a><br />\n<br />\n【本報訊】肖建華案快將開審、范冰冰案殺雞儆猴，涉及都是走資、逃稅，是內地當權者對「有負於黨」的懲罰。那麼黨的領導人又是如何處理自己家族的資產？中共總書記兼國家主席習近平，其家族一直在港有物業，市值達6.4億元。本報取得其家族位於淺水灣的獨立屋部份圖則，內櫳平面圖首次曝光。另外，胡錦濤家族、張高麗家族、賈慶林家族、栗戰書家族、汪洋及萬里家族的資產，資金一樣泊港，由分層豪宅到獨立屋皆有。<br />\n本報檢閱他們的買樓習性，2016年前是掃貨高峯，近年情況有減少迹象。有評論員指因為近年很多大陸政治文化的潛規則已滲入香港，對前度或現任領導人家族來說，「香港也不是他們如魚得水的自由地方，錢放在外國比在香港安全」。"},{"pid":"cb9fc2d85645a6e88bccf0b674fd0f12741fa6cd","tid":1721084,"uid":65212,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2019-11-14T14:48:52.000Z","msg":"<img src=\"https://na.cx/i/3piTsD3.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3piTsD3.png&h=adbe611c&s={SIZE}\" /><br />\n<br />\n11120日前 19890604"},{"pid":"475fc8d7f7ee17913565161ad8444d158b300544","tid":1721084,"uid":91017,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T14:49:55.000Z","msg":"都係個句啦, 傀儡一日在位, 維尼點都要話撐到抵ga la, 你試下公開話唔撐，特府即刻四分五裂la"},{"pid":"d3ddf5f9d2f60df404ced66