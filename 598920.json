3ccbbc431e25b967aac87de6","tid":598920,"uid":39846,"like":0,"dislike":0,"score":0,"quote":{"pid":"60f6c84a96f9c850e0d6ec9105a85758932fc9c5","tid":598920,"uid":2772,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-20T06:01:46.000Z","msg":"講黎講去咪又係支那生意..."},"citedBy":1,"replyTime":"2018-03-20T06:07:13.000Z","msg":"你知唔知乜嘢叫貿易？<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <br />\n<br />\n空運，航運，保險，銀行，轉口貿易都算支那生意？"},"citedBy":1,"replyTime":"2018-03-20T07:37:21.000Z","msg":"靠支那既生意"},"citedBy":1,"replyTime":"2018-03-20T07:58:46.000Z","msg":"即係香港既經濟命脈<img src=\"/assets/faces/fs/chicken.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/bye.gif\" class=\"hkgmoji\" />"},{"pid":"9abde8fd0021e84b624ba2b2791d29b0608af25f","tid":598920,"uid":41818,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-03-20T08:01:03.000Z","msg":"據《彭博》報導，有歐洲官員表示，川普政府正敦促各國與美國結盟，聯合對抗中國的貿易政策，如果能夠配合，將可獲得美國鋼鋁的關稅豁免。<br />\n<br />\n美國的鋼鋁進口關稅將於本周五生效，眾多貿易夥伴國正爭取能夠豁免。美國由貿易代表 Robert Lighthizer 負責，正與各國進行談判。據稱，美國提出了 5 項條件，這些訊息在彭博取到的歐盟委員會內部文件中也已見到。<br />\n<br />\n條件包括：<br />\n<br />\n    一、對美鋼鋁出口不得超過 2017 年的水準；<br />\n    二、積極解決中國各種貿易扭曲的政策；<br />\n    三、在 G20 全球鋼鐵論壇上與美國積極合作；<br />\n    四、與美國合作，在 WTO 申訴中國的貿易做法；<br />\n    五、加強與美國的安全合作。<br />\n<br />\n美國貿易代表辦公室尚未回覆評論請求。<br />\n<br />\n美國目前對即將課徵的鋼鋁關稅，僅給予加拿大及墨西哥豁免，不過川普指出，如果無法談成讓美國滿意的新北美自由貿易協定，他將撤回對兩國的豁免。<br />\n<br />\n此外，川普邀請任何與美國有「安全關係」的國家申請豁免，澳洲總理 Malcolm Turnbull 表示已因此得到豁免，南韓、阿根廷則正尋求類似的待遇。<br />\n<br />\n除了拉攏盟友之外，川普也表示，正考慮對中國實施更廣泛的關稅，其中還可能加入投資與簽證的限制。"},{"pid":"7429224c2c53d7451e45a8cc43e4f4dae2302827","tid":598920,"uid":41818,"like":0,"dislike":0,"score":0,"quote":{"pid":"3954f838cb54fe2b84f823885893f80c30aaca2a","tid":598920,"uid":24140,"like":0,"dislike":0,"score":0,"quote":{"pid":"855f93abcedf0591bc9f9828d8c6acfcf4dcefe5","tid":598920,"uid":2772,"like":0,"dislike":0,"score":0,"quote":{"pid":"3398ac8073eb8e0b3ccbbc431e25b967aac87de6","tid":598920,"uid":39846,"li