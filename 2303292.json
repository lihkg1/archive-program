dn.com%2FlFVbsBoM5LqyM5pzAQLoN44%2FIMG%2FLIHKG_on9%2F337052%2F337052.2_.png&h=16b55125&s={SIZE}\" /><br />\n<br />\n<img src=\"https://filedn.com/lFVbsBoM5LqyM5pzAQLoN44/IMG/LIHKG_on9/337052/337052.3_.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffiledn.com%2FlFVbsBoM5LqyM5pzAQLoN44%2FIMG%2FLIHKG_on9%2F337052%2F337052.3_.png&h=01ce4566&s={SIZE}\" />"},{"pid":"bd999cb44ee51a80b17a858f4b1b72b695cb7f75","tid":2303292,"uid":1886,"like":3,"dislike":2,"score":1,"quote":{"pid":"6848a5b1d83ec4bbbdf423c048469407f9b422e5","tid":2303292,"uid":208323,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2020-11-27T21:01:11.000Z","msg":"1000年內"},"citedBy":0,"replyTime":"2020-11-27T21:03:02.000Z","msg":"<img src=\"https://na.cx/i/U0JFZdR.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FU0JFZdR.png&h=d0e14ab6&s={SIZE}\" />"},{"pid":"7442119a3dcbbe6b01d23bcc7f6b25df7d1f4dc3","tid":2303292,"uid":337052,"like":0,"dislike":7,"score":-7,"citedBy":1,"replyTime":"2020-11-27T21:03:19.000Z","msg":"光復香港<br />\n時代革命"},{"pid":"6b4295382e5f7bb9dc21789f0d7ab16a71171c6a","tid":2303292,"uid":1886,"like":7,"dislike":1,"score":6,"quote":{"pid":"7442119a3dcbbe6b01d23bcc7f6b25df7d1f4dc3","tid":2303292,"uid":337052,"like":0,"dislike":7,"score":-7,"citedBy":1,"replyTime":"2020-11-27T21:03:19.000Z","msg":"光復香港<br />\n時代革命"},"citedBy":0,"replyTime":"2020-11-27T21:04:44.000Z","msg":"一邊聲稱支持香港人<br />\n一邊否定為香港奮鬥的那些人<br />\n只因他們不敢說香港獨立<br />\n<br />\n<img src=\"https://na.cx/i/fKeNJHa.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfKeNJHa.png&h=c224e9f3&s={SIZE}\" /><br />\n<br />\n你敢說就很威嗎<br />\n敢過來香港說嗎<br />\n躲在鍵盤大呼小叫很威很棒唷<br />\n然後就站在道德高地對香港人指指點點<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/itJCmuz.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FitJCmuz.png&h=46a67ec0&s={SIZE}\" />"},{"pid":"46f9d8e5203e4756dce9d76d45237c