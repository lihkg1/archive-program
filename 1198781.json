itedBy":1,"replyTime":"2019-06-10T10:38:16.000Z","msg":"此回覆已被刪除"},{"pid":"a983dba24390c27876c23e47d28fa281e4153e15","tid":1198781,"uid":226126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-10T10:39:59.000Z","msg":"此回覆已被刪除"},{"pid":"ac6791f4b0a64e689bc017df443e9fe496f483dc","tid":1198781,"uid":81845,"like":0,"dislike":0,"score":0,"quote":{"pid":"1b4faa2b978a30c96096a8ebb1724d879d6a9121","tid":1198781,"uid":185045,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-10T10:27:44.000Z","msg":"非洲人都勇敢過香港人<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-10T10:43:03.000Z","msg":"港豬：緊係啦 佢地又唔洗翻工搵食<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n講真 其實香港人都係冇野好輸<br />\n我覺得我地而家生活已經夠shit"},{"pid":"2e90b713503e13167730c25079aa11d8710babd4","tid":1198781,"uid":81845,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-10T10:45:10.000Z","msg":"<img src=\"https://na.cx/i/7pgGoC1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7pgGoC1.png&h=71e19401&s={SIZE}\" />推"},{"pid":"8b59bc9302bfdb59517344d756915d35c8212d63","tid":1198781,"uid":81845,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-10T10:45:46.000Z","msg":"求吓大家救香港<br />\n<img src=\"https://na.cx/i/eDfgcws.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeDfgcws.png&h=6f246bf0&s={SIZE}\" />"},{"pid":"41d183dbb45c78dc86210852cbec529a84f57cd4","tid":1198781,"uid":11454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-10T10:49:39.000Z","msg":"罷工既重點係返工既人<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n真係有心既會自己請假， 冇心既當放日假"},{"pid":"c0513815211810f6b39caa3f26f2808c6ad51eb5","tid":1198781,"uid":226126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-10T12:11:55.000Z","msg":"此回覆已被刪除"},{"pid":"d1084a878af833176f9bc6e692016de2530443d6","tid":1198781,"uid":81845,"like":0,"dislike":0,"score":0,"c