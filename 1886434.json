的公共服務。如有需要，個別部門會就各項服務最新安排，另行作出公布。<br />\n<br />\n  政府發言人亦呼籲其他僱主彈性處理員工上班安排，盡量減少市民之間的接觸。 <br />\n <br />\n完<br />\n2020年2月13日（星期四）<br />\n香港時間11時10分<br />\n<br />\n我柒撚左<img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/superman.gif\" class=\"hkgmoji\" />"},{"pid":"e23b4fa785a418a465917d223fdc102635aaf160","tid":1886434,"uid":127571,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-19T02:07:32.000Z","msg":"而家仲home緊？"},{"pid":"63e5e9b0242a000cd09be0dd5ea8c324a4aa1fe0","tid":1886434,"uid":18210,"like":0,"dislike":0,"score":0,"quote":{"pid":"10c7fd943fa8a84f170edfeae56ed42541172c80","tid":1886434,"uid":224479,"like":10,"dislike":0,"score":10,"citedBy":2,"replyTime":"2020-02-19T02:00:54.000Z","msg":"證明好多公務員都係晒緊大家錢<br />\n冇左佢哋 個社運都運作緊"},"citedBy":0,"replyTime":"2020-02-19T02:16:19.000Z","msg":"好邏輯"},{"pid":"69eadb3ca0ed9c718d916475e309f4022aa830ca","tid":1886434,"uid":49955,"like":0,"dislike":0,"score":0,"quote":{"pid":"5896a94058a1e956252284200582efaf64662231","tid":1886434,"uid":106633,"like":4,"dislike":0,"score":4,"quote":{"pid":"10c7fd943fa8a84f170edfeae56ed42541172c80","tid":1886434,"uid":224479,"like":10,"dislike":0,"score":10,"citedBy":2,"replyTime":"2020-02-19T02:00:54.000Z","msg":"證明好多公務員都係晒緊大家錢<br />\n冇左佢哋 個社運都運作緊"},"citedBy":2,"replyTime":"2020-02-19T02:02:42.000Z","msg":"公務員=社會寄生蟲<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-19T03:04:18.000Z","msg":"<img src=\"/assets/faces/lm2/eating.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},{"pid":"ffed72b71d6c5b693b1d6faf7ed27ae9d01e8243","tid":1886434,"uid":222970,"like":0,"dislike":0,"score":0,"quote":{"pid":"3ada7ebf1dd2a1186b6e2923f45af5a197b5c7ee","tid":1886434,"uid":36494,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2020-02-19T01:53:51.000Z","msg":"公務員fat fat 了"},"citedBy":0,"replyTime":"2020-02-19T03:06:36.000Z","msg":"交稅可以遲d先？"},{"pid":"5f9c18c74754ff