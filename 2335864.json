%2Fx6agUYy.jpg&h=d3dfb81f&s={SIZE}\" /><br />\n<img src=\"/assets/faces/dogxm/run.gif\" class=\"hkgmoji\" />男朋友收到一定好開心<br />\n<br />\n<br />\n本土lego系列  - 玩具帝國<br />\n<img src=\"https://na.cx/i/PwL43SF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPwL43SF.jpg&h=3f014894&s={SIZE}\" /><img src=\"https://na.cx/i/LA2yXcG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLA2yXcG.jpg&h=cfe1eeee&s={SIZE}\" /><img src=\"https://na.cx/i/mUKNhcG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmUKNhcG.jpg&h=3b75dcce&s={SIZE}\" /><img src=\"https://na.cx/i/i6gLOjn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fi6gLOjn.jpg&h=33ac1d72&s={SIZE}\" /><img src=\"https://na.cx/i/KeDioSH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKeDioSH.jpg&h=c154cead&s={SIZE}\" /><br />\n<br />\n好多好特別嘅lego 用黎聖誕抽獎岩晒<img src=\"/assets/faces/dogxm/beg_connect.gif\" class=\"hkgmoji\" /><br />\n仲有爆旋陀螺買夠唔同價錢有折 <br />\n<br />\n送比小朋友系列 - 甲蟲部屋 &amp; 關東店Kanto hobby <br />\n<br />\n甲蟲部屋 黃過爛屎<img src=\"/assets/faces/dogxm/discover.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/gYzJz0V.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgYzJz0V.png&h=e9a5a38a&s={SIZE}\" /><img src=\"https://na.cx/i/VEW71Ga.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVEW71Ga.png&h=3f79d4a4&s={SIZE}\" /><img src=\"https://na.cx/i/v4MjSN2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fv4MjSN2.png&h=62620af0&s={SIZE}\" /><img src=\"https://na.cx/i/k4AwJUP.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fk4AwJUP.png&h=b4a253c2&s={SIZE}\" /><br />\n<br />\nKanto hobby<br />\n<br />\n門口賣啲$20 $10 玩具 勁多c9搶住買 <img src=\"/assets/faces/dogxm/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n留意返 夜晚去可能多人到仆街 除咗玩具帝國平時都無咩人 福利平時成日都要排隊入去<br />\n另外兩間仲要係正玩具街入面<img src=\"/assets/faces/dogxm/scare.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-24T07:49:58.000Z","msg":"正評比隻渣古<img src=\"/assets/faces/pigxm/wine.gif\" class=\"hkgmoji\" />"},{"pid":"b3e4332e6bdffdf49e05f44751ff0032e78a9872","tid":2335864,"uid":287107,"like":0,"dislike":0,"score":0,"quote":{"pid":"416e9ed834b9af1b6bf58dacc8ec4a39c2580df6","tid":2335864,"uid":276723,"like":8,"dislike":0,"score":8,"citedBy":2,"replyTime":"2020-12-22T07:53:15.000Z","msg":"福利應該有成30年歷史，小學時買生日禮物就係係福利買1：100 雙頭龍高達<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-24T07:51:56.000Z","msg":"小學買生日禮物都過百蚊咁貴<img src=\"/assets/faces/pigxm/nope.gif\" class=\"hkgmoji\" />"},{"pid":"0c305979def864ae837f20d0c2988690a8076c6e","tid":2335864,"uid":35330,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc5d2dba0d9ac5434ff025efff22d9a3d05e83c3","tid":2335864,"uid":315376,"like":0,"dislike":0,"score":0,"quote":{"pid":"317104ffa4e469c2301eace7f1d79b157497d1fb","tid":2335864,"uid":35330,"like":0,"dislike":0,"score":0,"quote":{"pid":"473f31d91b03488064c3ef37d65b2177ed54c3d8","tid":2335864,"uid":315376,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-12-23T19:26:06.000Z","msg":"冇就睇下爆米 玩具研究所 肥仔玩具<br />\n 玩具模型倉<br />\n通常行一轉信和應該有<img src=\"/assets/faces/xm/angel.gif\" class=\"hkgmoji\" /><br />\n記得唔好幫襯精品 <img src=\"/assets/faces/xm/wink.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-12-24T04:35:01.000Z","msg":"就係走左轉信和<br />\n最多係紅色音符<br />\n其他最多得1/2款<br />\n無一間有齊<img src=\"/assets/faces/pigxm/wail2.gif\" class=\"hkgmoji\" /><br />\n<br />\n今日收工過深水埗睇"},"citedBy":1,"replyTime":"2020-12-24T07:41:34.000Z","msg":"祝巴打好運<img src=\"/assets/faces/mousexm/tea.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mousexm/tea.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mousexm/tea.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-24T07:53:41.000Z","msg":"去緊ssp<img src=\"/assets/faces/xm/angel.gif