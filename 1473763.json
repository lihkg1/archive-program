138ea9c3","tid":1473763,"uid":54593,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:17:37.000Z","msg":"無限量支持<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"80f10dadcb8884211c0b68994aee8342c980d27f","tid":1473763,"uid":1255,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:18:53.000Z","msg":"會唔會播番黑警做既惡事 <br />\n出面好多比人CUT頭CUT尾"},{"pid":"2f1d061837c70913489ac2da74e64602c55cb69e","tid":1473763,"uid":74888,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:19:23.000Z","msg":"推！"},{"pid":"5d65f23d96aa27a7d4fb7c4e14ae3d1b08b10e3a","tid":1473763,"uid":53349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:20:54.000Z","msg":"<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"9278588172236be5bacbaff2838fc1c6f61ecdc8","tid":1473763,"uid":286792,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:20:54.000Z","msg":"推"},{"pid":"ad402907599bc25c1466402639a2e9b359ef040d","tid":1473763,"uid":156579,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:23:56.000Z","msg":"spin返去721 811呢兩日<br />\n佢地水洗都唔清"},{"pid":"85e3d90b92855c502edbd34c8fc3c3834258da8c","tid":1473763,"uid":13067,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:24:52.000Z","msg":"push"},{"pid":"e28d8ca083d9bfaa1c7906e9febc619efeecbf66","tid":1473763,"uid":265851,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:27:09.000Z","msg":"加油！！<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n個人意見，唔好成日答我地無大台 答你唔到 或 你要問返政府， 睇得出記者感覺問你咩都咁答，已無興趣再問，進而亦好少報道<br />\n<br />\n或者試下講會嘗試收集意見下次回覆？甚至幾位代表講下個人睇法都好？"},{"pid":"ead551699efde0aeac31fbd9011c73028d91d35a","tid":1473763,"uid":301479,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:29:01.000Z","msg":"<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\"> 香港警方=黑社會=恐怖主義組織</span></span></div><br />\n811--黑 警假扮示威者掟磚同火魔法<br />\n811--尖沙咀 6名警察扮示威者 帶隊召黑衫人 帶頭燒警署<br />\n811--銅鑼灣 警察扮示威者射丫叉 混入人群搞事後表露身分制服旁人同時大量防暴增援<br />\n811--以化學武器攻擊葵芳/太古車站內<br />\n811--北角警察無視白衣人攻擊黑衣人及記者<br />\n<span style=\"font-size: large;\"><span style=\"color: green;\"><div style=\"text-align: center;\"> <br />\n<br />\n五大訴求 缺一不可</div></span></span><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: blue;\"><div style=\"text-align: center;\"> 黑警假扮示威者掟磚同火魔法<br />\n香港警察濫用暴力及喬裝成示威者煽動並參與暴力<br />\n記者請日日問</div></span></span>"},{"pid":"5bb3bcd10c01db0eaf0d269917ebf34a7ae797ba","tid":1473763,"uid":301479,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:29:29.000Z","msg":"<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\">721元朗恐襲 </span></span></div><br />\n黑社會無差別襲擊人，警方唔拉黑社會<br />\n警黑合作， 警署落閘， 999唔通，無人被檢控 <br />\n721元朗恐襲第26日: 無人被檢控， 無警停職， 施襲者逍遙法外，市民安全零保障<br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: green;\"><div style=\"text-align: center;\">五大訴求 缺一不可<br />\n林鄭將香港推向一個萬劫不復的深淵!<br />\n </div></span></span><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: blue;\"><div style=\"text-align: center;\"> 香港警方=黑社會， 香港警方=恐怖主義組織<br />\n香港人一世都唔原諒香港警察<br />\n無忘721<br />\n記者請日日問</div></span></span>"},{"pid":"13ff004e0a395460fc2d9c19a6ad511d99e8c249","tid":1473763,"uid":301479,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:29:44.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: blue;\"><div style=\"text-align: center;\">林鄭將香港推向一個萬劫不復的深淵<br />\n林鄭月娥忍心將香港推進粉身碎骨深淵<br />\n記者請日日問<br />\n</div></span></span>"},{"pid":"0601ba2b058b6fe8c9828fd33a4cc8c36431ba04","tid":1473763,"uid":74888,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T03:30:11.000Z","msg":"推呀！！"},{"pid":"e7ab2d007023c670ca72ad181f1336610aa3d6c2","tid":1473763,"uid":74888,"like":0,"dislike":0,"score":0,"citedBy":0,"rep