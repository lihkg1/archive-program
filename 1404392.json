-04T05:34:04.000Z","msg":"push"},{"pid":"424da3e79575cb1b433f3b1bce3f7f820c45629b","tid":1404392,"uid":44460,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T05:34:16.000Z","msg":"push"},{"pid":"aa590ad067bf79d2089b65d0845512c7c7ef3bb2","tid":1404392,"uid":186,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2019-08-04T05:34:28.000Z","msg":"<div style=\"text-align: center;\"><span style=\"font-size: large;\"><strong><br />\n求下你地青年人 唔好再玩火 香港唔值得要你地禁做<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n不犧牲<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />不攬炒<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />不玩火<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n施君龍是2000年香港入境事務大樓縱火案的主犯，<span style=\"color: red;\"><span style=\"font-size: x-large;\"><span style=\"color: red;\">他其後被判處謀殺罪成</span></span></span>，判刑<span style=\"color: red;\"><span style=\"font-size: x-large;\"><strong>終身監禁</strong></span></span>，後來<span style=\"color: red;\"><strong><span style=\"font-size: x-large;\">改判誤殺罪成，判刑監禁8年</span></strong></span>。他於05年獲釋後被即時遣返回中國大陸，於2011年成功申請單程證再來香港，引起香港社會嘩然和部份人士要求改革單程證制度。<br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">唔好玩火。</span></strong></span><br />\n<br />\n[Be fire, my foe] 攬炒戰術？</strong></span><br />\n<br />\n<img src=\"https://na.cx/i/nx22GfM.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fnx22GfM.png&h=e601a00b&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/jwkf1fN.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fjwkf1fN.png&h=c4b0c622&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/xW81WO5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxW81WO5.png&h=e9e3f844&s={SIZE}\" /></div><br />\n<a href=\"https://lih.kg/dvebqS\" target=\"_blank\">https://lih.kg/dvebqS</a>"},{"pid":"dd46406b5781bcef663ab500fd9771933fea5b54","tid":1404392,"uid":47685,"like":2,"dislike":0,"score":2,"quote":{"pid":"98f06ab25179f828e45f7ce1c2f59914cc0e4a96","tid":1404392,"uid":25468,"like":1,"dislike":9,"score":-8,"citedBy":1,"replyTime":"2019-08-04T04:59:05.000Z","msg":"起碼入去噴幾隻字啦"},"citedBy":0,"replyTime":"2019-08-04T05:35:05.000Z","msg":"屌咪撚害人，入面又空礦點避"},{"pid":"9d0f74a7a8bdaf7c11392d587aa226fcf0d08c5a","tid":1404392,"uid":98431,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-04T05:36:51.000Z","msg":"兩個月 對家都進化左<br />\n<br />\n尋日班黑衫黑鬼已經一步一步浮底加印證<br />\n<br />\n仲有好多貼證扮自己人 引人衝呢到 圍果到 塞車廠之類<br />\n<br />\n抽返身出黎 諗下721 728 同尋晚點死<br />\n<br />\n就唔難明點解去到呢一刻仲會有假手足叫人上"},{"pid":"d9e2708a02e0e99ed7313116ca39fa05e1b5baf0","tid":1404392,"uid":252531,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-04T05:36:51.000Z","msg":"此回覆已被刪除"},{"pid":"697191131f177a3483acef0265e2f4f8eb0952e8","tid":1404392,"uid":58883,"like":0,"dislike":0,"score":0,"quote":{"pid":"bab6e91ccd9c23082f17a2a98343d9a22fc8ed63","tid":1404392,"uid":209198,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-08-04T04:18:35.000Z","msg":"講咗好撚多次<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">咪撚入TVB</span></strong></span><br />\n係將軍澳住咗咁撚多年<br />\n老老柒柒 講比你班撚屌知老西咁多次<br />\n叫撚曬你地咪鳩入TVB個位<br />\n一入走唔到等仆街奶袋底<br />\n點知今日一望都仲係有人吹風話要入TVB<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">我T你老母臭化西</span></span></strong><br />\n本人在此宣布<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>除非前線即場決定 否則再鳩帶風向話入TVB者 我立刻馬上第一個同你割席 所有因進入TVB範圍而被拘捕義士全部係你責任</strong></span></span>"},"citedBy":0,"replyTime":"2019-08-04T05:39:56.000Z","msg":"85之後<br />\n<br />\n[參考波蘭成功例子既最佳戰術] 完全剋制政府冷處理 - 罷買 <br />\n一個最有效既長期戰術, 麻煩入去睇睇<br />\n<br />\n1. 週期性罷買係相當可行既一個戰術, 因為更能夠令普通人適應<br />\n2. 罷買影響力可以好大<br />\n3. 政府用冷處理戰術,打算拖至9月,而罷買係開學之後一樣可以實行,可以向社會施加壓力既最好方法<br />\n4. 罷買比遊行, 三罷, 更能夠說服中立派/和理非行動<br />\n<br />\n<a href=\"https://lihkg.com/thread/1397444/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1397444/page/1</a>"},{"pid":"a0f3fad75768c02a52eb9adc6c9aaf1c8ffb4236","tid":1404392,"uid":293477,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T05:41:54.000Z","msg":"推"},{"pid":"a8c5c007b960b6729de383ca27b0e1c887fb21a0","tid":1404392,"uid":116793,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T05:42:09.000Z","msg":"push"},{"pid":"451740bb0fbd7b3770d06b4a58b2f4c321bdc8e8","tid":1404392,"uid":280475,"like":0,"dislike":0,"score":0,"quote":{"pid":"bab6e91ccd9c23082f17a2a98343d9a22fc8ed63","tid":1404392,"uid":209198,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-08-04T04:18:35.000Z","msg":"講咗好撚多次<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">咪撚入TVB</span></strong></span><br />\n係將軍澳住咗咁撚多年<br />\n老老柒柒 講比你班撚屌知老西咁多次<br />\n叫撚曬你地咪鳩入TVB個位<br />\n一入走唔到等仆街奶袋底<br />\n點知今日一望都仲係有人吹風話要入TVB<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">我T你老母臭化西</span></span></strong><br />\n本人在此宣布<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>除非前線即場決定 否則再鳩帶風向話入TVB者 我立刻馬上第一個同你割席 所有因進入TVB範圍而被拘捕義士全部係你責任</strong></span></span>"},"citedBy":0,"replyTime":"2019-08-04T05:45:36.000Z","msg":"Push"},{"pid":"ea420ba0d4d2b246826e7b31058323651e7919b7","tid":1404392,"uid":93874,"like":6,"dislike":0,"score":6,"quote":{"pid":"51c09b7869adcf3f803e0e5c4306d456510cc73e","tid":1404392,"uid":209198,"like":30,"dislike":1,"score":29,"citedBy":3,"replyTime":"2019-08-04T04:19:25.000Z","msg":"同我推<br />\n除非前線開聲<br />\n否則我屌柒所有話入TVB既人老母"},"citedBy":0,"replyTime":"2019-08-04T05:50:01.000Z","msg":"小心有鬼入前線叫人衝tvb"},{"pid":"4fa50f83c607a6b0d21650668b05ea9084f96282","tid":1404392,"uid":211993,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-04T05:50:52.000Z","msg":"推"},{"pid":"6b25c82e7e0f5293b9ad6baa17b46ace9a948f14","tid":140439