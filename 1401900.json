://i.lihkg.com/540/https://na.cx/i/edrbzmP.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%2Fi%2FedrbzmP.png&h=93abf6e5&s={SIZE}\" />"},{"pid":"cde6e58c6505a1c03eba90d768a84b4131f53ad6","tid":1401900,"uid":196536,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-08-03T15:37:37.000Z","msg":"exactly<br />\n同埋唔好比政治潔癖綑綁左自己"},{"pid":"ef96ba918038a07db1612ea2c50ab1b1f32f4e62","tid":1401900,"uid":81518,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2019-08-03T15:37:53.000Z","msg":"此回覆已被刪除"},{"pid":"ea439027a9f53cfac32ffab28346db98c3fc9d08","tid":1401900,"uid":271690,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-03T15:37:57.000Z","msg":"推，有用post<br />\n叫人走既冷氣軍師用下腦教人點走唔係屌人唔走，其實冷氣軍師除左屌人之外可唔可以比啲實用資料，邊到有狗，推進到邊到，邊個位係可以做撤離點，唔好剩係識屌人唔該，實時地圖，警方分佈依啲唔識做？"},{"pid":"1c7b5e4a6907ec53230f228908d4769309bdbdb7","tid":1401900,"uid":269809,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-03T15:39:46.000Z","msg":"推"},{"pid":"7ef0ac5bc942e4dcd92fcc7eb553a1892d391b82","tid":1401900,"uid":16063,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-03T15:40:53.000Z","msg":"真吖 其實之個前線手足講三大走路原則都今日開定POST<br />\n<a href=\"https://lihkg.com/thread/1399285/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1399285/page/1</a><br />\n怕自己水左人死守 叫人自己諗幾時走<br />\n群眾智慧真係好緊要 唔好一味信人話走就走 人地話留就留<br />\n自己MAKE DECISION判斷"},{"pid":"350b8d299dfc923a077dd4fedf3ef17a46bc604a","tid":1401900,"uid":16217,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-03T15:41:16.000Z","msg":"Push"},{"pid":"f25adc4a6d73840e4e20995c06a7d809a4269c3e","tid":1401900,"uid":218570,"like":1,"dislike":0,"score":1,"quote":{"pid":"ef96ba918038a07db1612ea2c50ab1b1f32f4e62","tid":1401900,"uid":81518,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2019-08-03T15:37:53.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-08-03T15:49:08.000Z","msg":"呢幾日一直講緊遊擊hit&amp;run<br />\n有冇倡議過死守？"},{"p