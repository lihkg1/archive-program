2F480x_86400_68beedc543f1ed43c7ed1d89ef5576db%2Fstatic.koreastardaily.com%2F2019-06-02%2F117187-740235.jpg&h=d014e555&s={SIZE}\" /><br />\n另外一套搭配身體鏈的白色連衣裙也彰顯了娜璉的嫵媚，特此附上。<br />\n<img src=\"https://a.ksd-i.com/s/480x_86400_6599c4646d5d3246e873ede51f4a249b/static.koreastardaily.com/2019-06-02/117187-740228.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fa.ksd-i.com%2Fs%2F480x_86400_6599c4646d5d3246e873ede51f4a249b%2Fstatic.koreastardaily.com%2F2019-06-02%2F117187-740228.jpg&h=93b97fac&s={SIZE}\" /><br />\n<img src=\"https://a.ksd-i.com/s/480x_86400_716b845719b53e6ad67791cef8dc90bf/static.koreastardaily.com/2019-06-02/117187-740231.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fa.ksd-i.com%2Fs%2F480x_86400_716b845719b53e6ad67791cef8dc90bf%2Fstatic.koreastardaily.com%2F2019-06-02%2F117187-740231.jpg&h=b945d1ba&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-06-02T08:56:11.000Z","msg":"<span style=\"font-size: xx-large;\">J死人咩</span><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\"