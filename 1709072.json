ces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"5496510c60c28ce8691eb6552f362a7653712ad5","tid":1709072,"uid":235084,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-11T23:00:29.000Z","msg":"塞鐵啊大家"},{"pid":"68e6c2a70f627c96889cc4387865533375a0f4e1","tid":1709072,"uid":274756,"like":22,"dislike":0,"score":22,"citedBy":0,"replyTime":"2019-11-11T23:00:44.000Z","msg":"所以點解話叻哥講野無內容班藍絲都咁撐佢，佢哋讚佢冷靜呀<br />\n<br />\n藍絲基本上係無腦，所以唔需要同佢傾，只要扮到好冷靜咁hea覆佢係好過屌7佢"},{"pid":"5d986ada63285a947c9d4368c51a796ec0197d34","tid":1709072,"uid":206668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:23:07.000Z","msg":"可唔可以推下"},{"pid":"de29ac50c8b55eb12750ecb5001d00251c4b77b9","tid":1709072,"uid":206668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:23:19.000Z","msg":"文宣方向黎"},{"pid":"80d55c3a98800327c97d7921278a9ae14b5bb206","tid":1709072,"uid":206668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:23:29.000Z","msg":"未起身？<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /> 夠鐘塞鐵啦"},{"pid":"6046ab31016760019c28add0f4b7d223bf8e3924","tid":1709072,"uid":206668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:23:43.000Z","msg":"未起身？<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /> 夠鐘塞鐵啦"},{"pid":"94e0c01e1e03fc0febf824c453a08aebb733bc88","tid":1709072,"uid":119751,"like":7,"dislike":1,"score":6,"citedBy":0,"replyTime":"2019-11-11T23:30:20.000Z","msg":"不要讓仇恨蒙蔽眼睛<br />\n我地同對家最大既分別係我地有道德操守同良知<br />\n如果唔係就會成為你最討厭既人<br />\n非左膠 不割席 時刻保持理性思考"},{"pid":"d334982dab7bafb81c8350dc7a832373e90286e4","tid":1709072,"uid":206668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:34:34.000Z","msg":"未起身？<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /> 夠鐘塞鐵啦"},{"pid":"efdea20c974e0292d9bc95d4dab4b49131189b75","tid":1709072,"uid":206668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:34:55.000Z","msg":"未起身？<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /> 夠鐘塞鐵啦"},{"pid":"291226c1c8201241663b2974b3b67706d6cf3fa4","tid":1709072,"uid":206668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:35:20.000Z","msg":"未起身？<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /> 夠鐘塞鐵啦"},{"pid":"b1e73ee4f3a379edbb8632305e6dc055f0d5f222","tid":1709072,"uid":206668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:44:32.000Z","msg":"冇人睇<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"a7ee8343e7b05086d268f9de4f9b6504bbb20541","tid":1709072,"uid":263417,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:51:11.000Z","msg":"P牌想幫推"},{"pid":"d5e5423d32a88ed25df26c5a49696f490b7ebde5","tid":1709072,"uid":271248,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2019-11-11T23:51:33.000Z","msg":"一朝早個個出曬去你就打長文梗係無人回<br />\n出咗嚟幫手先啦<br />\n<br />\n利申睇曬<br />\n但如果樓主係唔罷工嘅<br />\n可以喺公司學校乜都好<br />\n諗下啲乜句子乜樣嘅文宣可以令廢老肯望<br />\n同會令佢地都反政府<br />\n因為我都同意而加好多文宣太圍爐<br />\n同唔夠資訊性<br />\n<br />\n一係就太多字"},{"pid":"c2d8c855fee9775154a9f117351fcd8d75ef41a2","tid":1709072,"uid":258416,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-11T23:51:39.000Z","msg":"同意，但唔到我哋控制前線做乜，我哋可以做就係幫佢哋兜"},{"pid":"6303517d672b3aea9df42b57767e554eb4ab488e","tid":1709072,"uid":161157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:54:04.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"7247717fbb5cf4aa9e26413259de1cd89f8a8255","tid":1709072,"uid":126920,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:57:54.000Z","msg":"推"},{"pid":"011091a739df092f66f8b8189db6614016634965","tid":1709072,"uid":2424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:58:26.000Z","msg":"比人斬果陣記得講唔該<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"24a6c779666dc358eb4b1c544190090585fb54cf","tid":1709072,"uid":62732,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:58:32.000Z","msg":"拎住把刀指住都仲理性對話？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n拎住玻璃樽一嘢扑落黎仲理性對話？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"2d0ea9830a771f6a29a8b0981c332454276d81c2","tid":1709072,"uid":160998,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2019-11-11T23:59:19.000Z","msg":"收皮啦去過前線面對藍絲未啊 冷氣軍師？<br />\n藍絲個種黑人憎程度唔係咁簡單囉只可以講<br />\n講得手停口停個d咪係自撚私囉"},{"pid":"23eebc1c4076c49295b6a48d130152ddce4f3881","tid":1709072,"uid":260296,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-11-11T23:59:54.000Z","msg":"我話你知<br />\n<br />\n黑警入面大把PR <br />\n<br />\n依幾日我見好多場面唔緊張嘅時候 好多速龍會同街坊say sorry 扮好人"},{"pid":"437c7fd256649a21dec77ee79cc1856e1aecad13","tid":1709072,"uid":221846,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-12T00:00:35.000Z","msg":"岩啊 唔認同亂私了 達不到效果仲令我地愈黎愈似黑警"},{"pid":"e57b5e4d1dbe927f1caa44da5befe3026e1643b6","tid":1709072,"uid":221846,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:01:36.000Z","msg":"希望手足睇到"},{"pid":"4643578117282f8c4dd6b2a0abb5a3a9c9c928d5","tid":1709072,"uid":70897,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:03:30.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"cb25493975dafc91df18b299cbe97c0dfb2649aa","tid":1709072,"uid":289480,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:04:05.000Z","msg":"要推的。"},{"pid":"dc60c22fa64ba378c3ba66f09441394cf7cf9612","tid":1709072,"uid":221846,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:04:51.000Z","msg":"推"},{"pid":"7eaf7e0d0e7292434f5d821f6e10e85d4a0e703b","tid":1709072,"uid":221846,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:05:19.000Z","msg":"推"},{"pid":"aaa995c4c625ecb95eb95ba678b388f2a9bb79ca","tid":1709072,"uid":7438,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:06:26.000Z","msg":"第一兩句係要有禮貌<br />\n但好多時講落發現係無藥可救<br />\n就忍唔住屌鳩佢老母"},{"pid":"7cc5aa80eeb993e8bebbfcec7422e1f33524190b","tid":1709072,"uid":54719,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:06:58.000Z","msg":"理性討論係唯一進步方法<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"0aed5424ba37cffcae5a97cb4cd374df48d1679e","tid":1709072,"uid":76395,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:08:26.000Z","msg":"卡住咗過唔到海企到攰，不過欣賞塞鐵黨comeback<br />\n小心"},{"pid":"ea8d8e57c32541ac9ce6e984f91f6379f49c8f92","tid":1709072,"uid":279917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:09:48.000Z","msg":"推"},{"pid":"dc1c566a96f5b418b0ef2887aa084c6a9bae8bb6","tid":1709072,"uid":65261,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:10:51.000Z","msg":"香港人報仇"},{"pid":"2b2abab5b97efb2c45beb8b2040b4f434fbe5e4a","tid":1709072,"uid":276651,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:11:09.000Z","msg":"推"},{"pid":"cec83328bb1ae3e5bc78b931dd6250981d5123a7","tid":1709072,"uid":231015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:12:03.000Z","msg":"push"},{"pid":"e092a9b3513c59f88ccf61314c94cc407e356730","tid":1709072,"uid":266142,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:12:29.000Z","msg":"推"},{"pid":"0db0a21ae60e619d70e3dfcbde2590ea9c98481a","tid":1709072,"uid":122915,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-11-12T00:12:56.000Z","msg":"簡單啲講 同佢地講野唔好諗住說贏佢個pt<br />\n係「係呀我都咁諗」之後就直接講自己嘅野 講到佢無啦啦都認同左就得<br />\n你唔係同人辯論 要明白呢樣野"},{"pid":"7782bdb4527548781732bf2e422852a3b6f4fcce","tid":1709072,"uid":30862,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:13:58.000Z","msg":"推"},{"pid":"8d8d8fd2b023ae656b5a15448bcc5084c70a3bf0","tid":1709072,"uid":57480,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:14:27.000Z","msg":"Push"},{"pid":"e7e425af31306e7bc76999b7108bce13b64745da","tid":1709072,"uid":66247,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:14:43.000Z","msg":"Push<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"709f4de958fe35a4eff359d237c358bd431cf338","tid":1709072,"uid":160841,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:14:52.000Z","msg":"藍絲永遠都係藍絲 就算你唔屌佢 佢既思想都唔會改變"},{"pid":"e08c24f31bae6dc19b46f5596d8b249a07e392d7","tid":1709072,"uid":270856,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:15:15.000Z","msg":"同意<br />\n利申：睇晒<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"a0d7ceae24b4207382530748ceb25c2887853a2f","tid":1709072,"uid":166469,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-12T00:15:34.000Z","msg":"完全同意，但有D特殊情況，例如有籃絲拿刀既話，都要先下手為強"},{"pid":"748858722d68189fc87849468081aad416582fea","tid":1709072,"uid":24853,"like":1,"dislike":0,"score":1,"quote":{"pid":"9135eebd4e136a798f1f1c9d2dcae045807d5282","tid":1709072,"uid":206668,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-11T22:13:25.000Z","msg":"TLDR：你哋對住啲藍絲廢老嘅時候態度可唔可以好少少， 唔好一開波就屌鳩人。文宣組要擺脫同溫層。<br />\n<br />\n今朝塞地鐵 同咗幾個上咗年紀嘅人傾下計<br />\n咁講下佢地講咩啦<br />\n首先呢一個阿叔應該係淺黃：<br />\n佢同我哋講而家我哋要做嘅應該要爭取中間游離分子嘅支持，因為佢見到我哋而家出嚟抗爭嘅人數係越嚟越少。 我哋私了或者係瘋狂同廢老鬧交 都會令到佢哋唔敢企喺示威者呢邊。 咁樣我哋就會多一個敵人， 任何不合作運動嘅阻礙力亦都會大咗。<br />\n<span style=\"color: red;\">而我哋亦有需要擺脫同溫層，做下對家嘅文宣。</span> 因為佢哋睇到嘅就係示威者暴力， 示威者阻人返工，私了好恐怖等等。 而佢哋亦都驚咗佢哋眼中嘅暴徒，所以佢會支持警察止暴制亂。 喺我哋同細廢老鬧交嘅時候， 佢就提醒我哋呢種行為好容易樹立多一個敵人， 叫我哋冷靜沉著應對佢地。 大部分人都知道，警察有幾咁暴力。 但係點解藍絲仍然企喺警察各一方， 就係因為佢哋覺得示威者都同樣暴力。 我唔係話示威者唔可以用武力， 但係文宣組真係要諗辦法說服佢哋， 話畀佢哋知好多示威者都係和理非， 正常情況之下佢哋根本唔會喐手打藍絲。<br />\n佢同時叫我哋<span style=\"color: red;\">對d持相反意見嘅人態度好啲， 話畀佢哋知我哋唔係暴徒， 我哋仍然可以理性同佢哋討論。</span> 同佢講講下嘢，有個藍絲又發癲，我就多口屌咗個藍絲一兩句。 個阿叔就話：咁你又多咗個敵人了。 所以我哋仍然都要保持克制， 尤其是喺不合作運動入面。<br />\n<br />\n<span style=\"color: red;\">我地除咗做文宣，前線都要保持克制， 唔好變成自己最討厭嘅黑警。</span> 如果要私了， 等佢報警影相或者等佢地出咗手先， 如果只係口角之爭就儘量和平理性非暴力。<br />\n去到呢度我諗返起梁天埼嗰兩句：<br />\n<br />\n<img src=\"https://na.cx/i/mPYosB6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmPYosB6.jpg&h=ab553158&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/JmTPoas.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJmTPoas.jpg&h=8107c3ac&s={SIZE}\" /><br />\n<br />\n<br />\n最後佢話佢會將我哋睇到嘅嘢俾嗰班仲支持警察嘅人睇。而我地亦有責任睇下藍絲到底睇啲乜嘢令佢哋仍然支持警察。 大家都睇唔到對方嘅資訊， 先會造成今日對立嘅局面。 而佢一開始都提到希望以和解嘅方式完結呢一個運動， 如果我哋嘅文宣或者我哋嘅行為係更加刺激對立嘅話， 製造出嚟嘅敵人只會更加多， 而我哋亦都有機會輸。<span style=\"font-size: xx-large;\">所以，無論係文宣定係前線，都要檢討下自己。</span><br />\n<br />\n<br />\n<br />\n另外有兩個係藍絲， 我就冇同佢哋有咁深入嘅討論。 只不過都聽到佢哋唔少諗法。<br />\n其中一個就話： 「而家搵食艱難呀你而家咁樣做咪阻住我哋搵食囉。」 冇錯我知呢句難聽過粗口，但請睇埋落去：「 係呀你哋講人權講生活呀好重要呀， <span style=\"color: red;\">我哋呢就只係想生存嘅啫。」</span> 佢講到一個好重要嘅point, 就係只想生存。 要同佢哋做文宣， 冇可能用良知黎做。 佢哋嘅視野好窄，只係為咗喺呢個社會入面養活自己， 唔會理其他唔關自己事嘅嘢。<br />\n我覺得對住佢哋， 如果要做文宣嘅話， 就要解釋 政府點樣令到你哋連生存嘅能力都冇。 相信佢哋嘅經濟環境都唔會好得去邊， <span style=\"color: red;\">所以我哋就要煽動佢哋對政府嘅不滿。 </span>我哋同佢講民生，講點解佢哋做到成隻狗咁仲要捱咁耐 ，仲要掙扎求存。 只有咁樣先至會令到佢哋同我哋一齊對抗呢個政府， 就算爭取嘅嘢唔同，我哋都有共同嘅敵人。<br />\n<br />\n最後一個 藍絲基本上我淨係聽到佢講一句嘢， 我哋一路圍屌佢， 佢一開始都好嬲 ，但係到最後佢係喊曬口咁同我哋講 佢真係手停口停， 返唔到工 佢就養唔活屋企人。 塞鐵嘅手足見到佢喊 都有圍屌變成安慰。 冇錯佢係同我哋處於相反立場， 但係可唔可以對住啲港豬都有少少嘅包容， 因為佢哋都有怒氣同難處。 我都估到會畀人話我係大愛左膠撚， 但真係唔好再樹立太多嘅敵人。 而家唔係講民意 ，係講返屬於我哋香港人嘅公民質素。可唔可以好似8月5號咁樣 塞住地鐵都要講返聲對唔住。<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n呢一篇唔係割蓆文，只係想咁多位手足（包括我）諗下點樣打呢個長期戰<br />\n<br />\n<span style=\"font-size: small;\">ps 多謝今日個淺黃阿叔<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />好耐冇咁樣理性討論了</span><br />\n<br />\n<br />\n光復香港 時代革命 <img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-12T00:16:50.000Z","msg":"而家少左好多長輩圖<br />\n不過大家都攰 <br />\n其他和理非幫手做多啲文宣"},{"pid":"3f47da91f8bbe919847f7a8b96ec3afe156f48f7","tid":1709072,"uid":148355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:17:12.000Z","msg":"又嚟<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"25551ac489fc9d7a19b1bf190b14d5595bad5d98","tid":1709072,"uid":5650,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2019-11-12T00:18:01.000Z","msg":"呢篇文既克制適用於對住得把口既藍屍<br />\n<br />\n對住拎刀既藍屍同拎槍指住你既綠甴就不了<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"c080713bb9d77847572c1d8314d551c4af6a2d2f","tid":1709072,"uid":152568,"like":3,"dislike":0,"score":3,"quote":{"pid":"ca2956ec7da7ff8b02241cccc877fa19f58f6624","tid":1709072,"uid":108571,"like":34,"dislike":0,"score":34,"citedBy":3,"replyTime":"2019-11-11T22:44:03.000Z","msg":"推<br />\n一直都有人講<br />\n但次次都有人話依家係革命抗爭乜乜乜<br />\n唔洗再咁客氣<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n一陣又阻膠又話退一步輸場運動"},"citedBy":0,"replyTime":"2019-11-12T00:18:42.000Z","msg":"呢一篇唔係割蓆文，老一輩習慣左努力專注賺錢就會成功嘅系統，亦都有人真係手停口停。<br />\n如果我地好聲好氣解釋， 多一個朋友好過多一個敵人。 <br />\n所以我覺得可以係: 唔搞事講幾句個d就改變佢地思想，搞事個d就獅鳥。<br />\n<br />\n我地唔左膠，但係我地要改變其他人思想。 我地要更多人反對不滿呢個政府。 而經濟唔只係港共政府春袋，亦都係好多人春袋。如果我地想更多人更顯住地反抗呢個政府，就要改變佢地思想。<br />\n<br />\n我知五個月已經好耐，好多人已經switch side/take a stand。但係如果要贏， 我地唔同層面都要升級。"},{"pid":"1b42c54c57b3d060007740a48cbe418fffa75db8","tid":1709072,"uid":62935,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:19:17.000Z","msg":"永遠記住<br />\n<br />\n「要說服別人，要訴諸佢地的利益，而不是道理。」"},{"pid":"8c5366bd7542be1bc1084560405e624d6675965f","tid":1709072,"uid":180124,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-11-12T00:19:57.000Z","msg":"7月8月果時都咁講既<br />\n依家真係唔想理鳩啲民意撚<br />\n果啲乜楊政賢老母乜支持唔落果啲正仆街黎"},{"pid":"ff2881bfef9c8f745d95a334895283d704e495ae","tid":1709072,"uid":5650,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:20:28.000Z","msg":"「我地除咗做文宣，前線都要保持克制， 唔好變成自己最討厭嘅黑警。 」<br />\n<br />\n保持克制都要睇對象<br />\n對住呀叻呢堆得把口既藍絲<br />\n絕對要保持克制<br />\n<br />\n對住持刀既藍屍同持槍既綠甴<br />\n就唔好比呢句縛住自己"},{"pid":"0102cee9920914523c6a7126eacb701aebfc8728","tid":1709072,"uid":307203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:21:18.000Z","msg":"push"},{"pid":"fe74a8335427cfd7a4d2321578ac24318801d99a","tid":1709072,"uid":280965,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:22:12.000Z","msg":"同意"},{"pid":"bd5c46b517410382c9eecadd3650f5219cea78fb","tid":1709072,"uid":203768,"like":1,"dislike":0,"score":1,"quote":{"pid":"90b3198c52d942262b4b93c7bd9b8bf8989847da","tid":1709072,"uid":133235,"like":3,"dislike":12,"score":-9,"citedBy":1,"replyTime":"2019-11-11T22:51:38.000Z","msg":"呢啲咪姐係阻膠"},"citedBy":0,"replyTime":"2019-11-12T00:22:37.000Z","msg":"知係講緊話要理性討論 要拉攏其他支持者 你直接話佢係左膠其實好唔公平"},{"pid":"d278239837fae3664d33f04b6f089721771780e7","tid":1709072,"uid":213917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:23:22.000Z","msg":"pussh"},{"pid":"ac3c49f1cef759ef50608f3574b38f183aad5e67","tid":1709072,"uid":134244,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:24:34.000Z","msg":"同意 推"},{"pid":"1ab0525a9dda3f80f26e038ad437ee3bca5c5ef7","tid":1709072,"uid":134244,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:24:53.000Z","msg":"推"},{"pid":"5e695e68bf5fe839666f4cd189dfcd74d47f6da1","tid":1709072,"uid":134244,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:25:17.000Z","msg":"推"},{"pid":"f4adb4c6216caa637866aa350d956bd5fcd2fc2a","tid":1709072,"uid":329257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:26:13.000Z","msg":"雖然好攰 但請大家唔好放棄對話"},{"pid":"a0eb10749c45e1fa1249b6f15a76ff05fef3c1e3","tid":1709072,"uid":22195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T00:26:20.000Z","msg":"push"},{"pid":"c80519c05e8691fb4f0e8f177186d7089bd71a6b","tid":1709072,"uid":295442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"20