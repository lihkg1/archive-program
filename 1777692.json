g @protesttoo"},{"pid":"81a2030bd287beb08708ab219fe1b204f64479ab","tid":1777692,"uid":100680,"like":0,"dislike":0,"score":0,"quote":{"pid":"caa0378bc56d68a51a3151dffb821065490ea123","tid":1777692,"uid":177213,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-10T11:41:29.000Z","msg":"五毛"},"citedBy":0,"replyTime":"2019-12-10T11:42:10.000Z","msg":"又唔係假新聞五咩毛<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"b7add64975d5cce15872d3e1373302cde27c0852","tid":1777692,"uid":177213,"like":0,"dislike":0,"score":0,"quote":{"pid":"aa60955adce8d366f36b4afad416b213ca53173c","tid":1777692,"uid":100680,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-10T11:41:46.000Z","msg":"PTT台仔感想<br />\n<a href=\"https://www.ptt.cc/bbs/Gossiping/M.1575958405.A.CDB.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ptt.cc%2Fbbs%2FGossiping%2FM.1575958405.A.CDB.html&d=%2BaoNGjxKkOyNIKnkVXg3cedFAmKeyJhstBKVrdqrVyA%3D&h=74289606\" data-auto-link target=\"_blank\">https://www.ptt.cc/bbs/Gossiping/M.1575958405.A.CDB.html</a>"},"citedBy":0,"replyTime":"2019-12-10T11:42:21.000Z","msg":"PTT好多中共網軍同五毛"},{"pid":"92a98ff06512b42d51ecf351240e546473331a33","tid":1777692,"uid":119271,"like":1,"dislike":0,"score":1,"quote":{"pid":"ccfbcb162a22df58732f60da4142db3b0807c0c5","tid":1777692,"uid":177213,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-12-10T11:41:18.000Z","msg":"<img src=\"https://na.cx/i/02ARJu4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F02ARJu4.png&h=5def7318&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-12-10T11:42:22.000Z","msg":"thanks 拉"},{"pid":"8f6ae609b76e71f21708329022aabb864aa39edb","tid":1777692,"uid":177213,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-10T11:43:51.000Z","msg":"中央社係國民黨黨報"},{"pid":"23121970005603776d03115c97f52794b0b86389","tid":1777692,"uid":177213,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-10T11:44:41.000Z","msg":"樓豬P