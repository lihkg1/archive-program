d":43041,"like":0,"dislike":0,"score":0,"quote":{"pid":"efae6a4dd38bc05b325387f2360531d6ad820ab7","tid":1649820,"uid":95520,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-12T18:58:24.000Z","msg":"推"},"citedBy":0,"replyTime":"2019-10-12T18:58:38.000Z","msg":"拉"},{"pid":"5fe5cd062ea92f716c637828247bbb20386c746b","tid":1649820,"uid":47659,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-12T18:59:09.000Z","msg":"<span style=\"font-size: xx-large;\">終於上熱門 推呢個呀 咁多日得呢篇上到熱門<br />\n<br />\n10.13 18區開花 快啲推喇喂<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/ajRyAcU\" data-auto-link target=\"_blank\">https://lih.kg/ajRyAcU</a></span>"},{"pid":"aa2371840bea8e62bfc5225ffaefa2622b916bb3","tid":1649820,"uid":165107,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-12T18:59:44.000Z","msg":"推"},{"pid":"ce5d3759a3f731d78ce502881cbe0200554450b0","tid":1649820,"uid":28244,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-12T19:00:34.000Z","msg":"推"},{"pid":"e56f77ece45bb0bcb18738a4fe8d9e42396b9156","tid":1649820,"uid":164106,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-12T19:00:47.000Z","msg":"推"},{"pid":"04a1d72a080e983544272f1389beff3cf0ec52bb","tid":1649820,"uid":102535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-12T19:01:01.000Z","msg":"《人手轉載》<br />\n<br />\n希望大家維持嗌五大訴求：<br />\n1.缺一不可本來就有環環相扣既意思，正如林鄭撤回咗條例，都唔會改嗌四大訴求，簡單啲講，呢句野既結果一係5，一係0，冇其他。<br />\n2.解散警隊呢個訴求並唔夠實際同具體，基本上五大訴求達成就已經可以蓋括埋解散警隊既效果，正如一開始第五個訴求係林鄭下台，大家都覺得呢個訴求唔實際，所以改做雙普選，所以，我地係唔需要特登加多一個訴求落去，咁先比到人睇我地一直爭取緊既係具體、可行、實際既訴求。<br />\n解散警隊可以獨立嗌，代表我地對警隊嚴重不滿，但唔好將佢當做第六大訴求。<br />\n3.國際啱啱先開始知到我地爭取緊既係五大訴求而唔係林鄭一句撤回就咁簡單，所以維持五大訴求先比到人一種由始此終都係爭取緊同一樣野既觀感。"},{"pid":"d0707eeeea9ea25c21c370fb11c0e9538548b409","tid":1649820,"uid":142249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-12T19:02:14.000Z","msg":"推"},{"pid":"0383bf626d9f899986fa2bd48fcdfd716c033c69","tid":1649820,"uid":264609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-12T19:03:32.000Z","msg":"唔好比狗帶風向"},{"pid":"ebc6b06a42c04239e0ced7de0f38bf1cacbbefaa","tid":1649820,"uid":43041,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-12T19:03:54.000Z","msg":"拉"},{"pid":"96bab4788a9a2c3e9e5cf50448ca71ec5926bb21","tid":1649820,"uid":290787,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-12T19:05:12.000Z","msg":"唔好俾狗帶風向！！ 專注10.13 十八區開花！！<br />\n<br />\n大局為重！！<br />\n<br />\n不分化不割蓆 唔止係口號！"},{"pid":"111e8079cf8e91184499d07add693a58a4bbed8e","tid":1649820,"uid":43041,"like":0,"dislike":0,"score":0,"quote":{"pid":"96bab4788a9a2c3e9e5cf50448ca71ec5926bb21","tid":1649820,"uid":290787,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-12T19:05:12.000Z","msg":"唔好俾狗帶風向！！ 專注10.13 十八區開花！！<br />\n<br />\n大局為重！！<br />\n<br />\n不分化不割蓆 唔止係口號！"},"citedBy":0,"replyTime":"2019-10-12T19:15:06.000Z","msg":"拉"},{"pid":"cd67bc3ed82f9cfd4b50bd5fed7132e6c3846c0d","tid":1649820,"uid":178933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-12T19:17:55.000Z","msg":"全部同我入黎幫手推明日18區開花post!!無個上到熱門呀<br />\n<a href=\"https://lih.kg/1648720\" data-auto-link target=\"_blank\">https://lih.kg/1648720</a><br />\n- 分享自 LIHKG 討論區"}]}