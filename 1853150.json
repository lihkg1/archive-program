id":35484,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-02-01T07:03:20.000Z","msg":"<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"48c88adfd30d78aac5b3f0c34b540e0e4cec1e12","tid":1853150,"uid":35484,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-02-01T12:52:33.000Z","msg":"<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4b22425ef88e11b907f7edddaf685a4bb1a1b991","tid":1853150,"uid":35484,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-02-01T13:44:28.000Z","msg":"<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f92b8df6c6bbb5bb9fd9da273891353967dc5ccd","tid":1853150,"uid":1224,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-01T14:12:13.000Z","msg":"<a href=\"https://t.me/okjfresh\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fokjfresh&d=7U4Tv3rjd6zAHDU%2B6Dwik4Vo%2BdRg%2Bg8pLLdQ7U%2BHcj8%3D&h=aeea5657\" data-auto-link target=\"_blank\">https://t.me/okjfresh</a><img src=\"/assets/faces/lm2lny/nosee.gif\" class=\"hkgmoji\" />"}]}