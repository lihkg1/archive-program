BA%97%E4%BA%8B%E4%BB%B6\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fevchk.wikia.org%2Fzh%2Fwiki%2F%25E6%25A6%2586%25E6%259E%2597%25E6%259B%25B8%25E5%25BA%2597%25E4%25BA%258B%25E4%25BB%25B6&d=luXbQZY1AauiUI8MFdBmxIE4T4y%2BYV5jPOnVoTo%2FPYs%3D&h=f1f189a4\" data-auto-link target=\"_blank\">https://evchk.wikia.org/zh/wiki/%E6%A6%86%E6%9E%97%E6%9B%B8%E5%BA%97%E4%BA%8B%E4%BB%B6</a><br />\n<br />\n榆林書店事件<br />\n<br />\n<br />\n榆林書店事件，源於同志團體香港彩虹不滿榆林書局拒絕擺放同性戀者心路歷程小冊子《她們的女性印記》，指書店以宗教理由封殺「性傾向平等資訊」。<br />\n<br />\n背景<br />\n<br />\n2005年，同志團體「香港彩虹」制作了小冊子《她們的女性印記》，希望把小冊子於榆林書店擺放，榆林書店方面亦答應要求，但事後有人發現有關小冊子《她們的女性印記》，全部被丟棄於書店後的垃圾桶，因而引起有關組織之不滿，並發起抗議行動。<br />\n<br />\n爭論<br />\n<br />\n事件於很多時事論壇及基版中都有很大的爭論，一方面有人認為榆林書店是私人機構，書店有權選擇擺放甚麼書。另一方面有人認為書店方面並沒有表明其反對同性戀立場，並大方地准許有關小冊子擺放，事後卻不動聲色地把所有小冊子丟到垃圾桶，行為十分卑劣。<br />\n<br />\n回響<br />\n<br />\n事件後許多人才知道榆林書店原來是有基督教背景，並以基督教信仰作為經營理念，有關書店似有歧視同性戀之嫌，於是引起抵制有關書店之呼籲。此外亦引起書店是否屬公共空間、何謂公共領域等討論。"},{"pid":"c202afcd4d21588009500dff8202df66469358e8","tid":2106544,"uid":1886,"like":0,"dislike":0,"score":0,"quote":{"pid":"61ff5d663db78806b73a77b7152c565ff4c878ad","tid":2106544,"uid":53026,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-13T13:48:42.000Z","msg":"<a href=\"https://evchk.wikia.org/zh/wiki/%E6%A6%86%E6%9E%97%E6%9B%B8%E5%BA%97%E4%BA%8B%E4%BB%B6\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fevchk.wikia.org%2Fzh%2Fwiki%2F%25E6%25A6%2586%25E6%259E%2597%25E6%259B%25B8%25E5%25BA%2597%25E4%25BA%258B%25E4%25BB%25B6&d=luXbQZY1AauiUI8MFdBmxIE4T4y%2BYV5jPOnVoTo%2FPYs%3D&h=f1f189a4\" data-auto-link target=\"_blank\">https://evchk.wikia.org/zh/wiki/%E6%A6%86%E6%9E%97%E6%9B%B8%E5%BA%97%E4%BA%8B%E4%BB%B6</a><br />\n<br />\n榆林書店事件<br />\n<br />\n<br />\n榆林書店事件，源於同志團體香港彩虹不滿榆林書局拒絕擺放同性戀者心路歷程小冊子《她們的女性印記》，指書店以宗教理由封殺「性傾向平等資訊」。<br />\n<br />\n背景<br />\n<br />\n2005年，同志團體「香港彩虹」制作了小冊子《她們的女性印記》，希望把小冊子於榆林書店擺放，榆林書店方面亦答應要求，但事後有人發現有關小冊子《她們的女性印記》，全部被丟棄於書店後的垃圾桶，因而引起有關組織之不滿，並發起抗議行動。<br />\n<br />\n爭論<br />\n<br />\n事件於很多時事論壇及基版中都有很大的爭論，一方面有人認為榆林書店是私人機構，書店有權選擇擺放甚麼書。另一方面有人認為書店方面並沒有表明其反對同性戀立場，並大方地准許有關小冊子擺放，事後卻不動聲色地把所有小冊子丟到垃圾桶，行為十分卑劣。<br />\n<br />\n回響<br />\n<br />\n事件後許多人才知道榆林書店原來是有基督教背景，並以基督教信仰作為經營理念，有關書店似有歧視同性戀之嫌，於是引起抵制有關書店之呼籲。此外亦引起書店是否屬公共空間、何謂公共領域等討論。"},"citedBy":1,"replyTime":"2020-07-13T14:04:12.000Z","msg":"咁最後點"},{"pid":"3b83478252917dd08882671ac982df113429ea06","tid":2106544,"uid":53026,"like":1,"dislike":0,"score":1,"quote":{"pid":"c202afcd4d21588009500dff8202df66469358e8","tid":2106544,"uid":1886,"like":0,"dislike":0,"score":0,"quote":{"pid":"61ff5d663db78806b73a77b7152c565ff4c878ad","tid":2106544,"uid":53026,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-13T13:48:42.000Z","msg":"<a href=\"https://evchk.wikia.org/zh/wiki/%E6%A6%86%E6%9E%97%E6%9B%B8%E5%BA%97%E4%BA%8B%E4%BB%B6\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fevchk.wikia.org%2Fzh%2Fwiki%2F%25E6%25A6%2586%25E6%259E%2597%25E6%259B%25B8%25E5%25BA%2597%25E4%25BA%258B%25E4%25BB%25B6&d=luXbQZY1AauiUI8MFdBmxIE4T4y%2BYV5jPOnVoTo%2FPYs%3D&h=f1f189a4\" data-auto-link target=\"_blank\">https://evchk.wikia.org/zh/wiki/%E6%A6%86%E6%9E%97%E6%9B%B8%E5%BA%97%E4%BA%8B%E4%BB%B6</a><br />\n<br />\n榆林書店事件<br />\n<br />\n<br />\n榆林書店事件，源於同志團體香港彩虹不滿榆林書局拒絕擺放同性戀者心路歷程小冊子《她們的女性印記》，指書店以宗教理由封殺「性傾向平等資訊」。<br />\n<br />\n背景<br />\n<br />\n2005年，同志團體「香港彩虹」制作了小冊子《她們的女性印記》，希望把小冊子於榆林書店擺放，榆林書店方面亦答應要求，但事後有人發現有關小冊子《她們的女性印記》，全部被丟棄於書店後的垃圾桶，因而引起有關組織之不滿，並發起抗議行動。<br />\n<br />\n爭論<br />\n<br />\n事件於很多時事論壇及基版中都有很大的爭論，一方面有人認為榆林書店是私人機構，書店有權選擇擺放甚麼書。另一方面有人認為書店方面並沒有表明其反對同性戀立場，並大方地准許有關小冊子擺放，事後卻不動聲色地把所有小冊子丟到垃圾桶，行為十分卑劣。<br />\n<br />\n回響<br />\n<br />\n事件後許多人才知道榆林書店原來是有基督教背景，並以基督教信仰作為經營理念，有關書店似有歧視同性戀之嫌，於是引起抵制有關書店之呼籲。此外亦引起書店是否屬公共空間、何謂公共領域等討論。"},"citedBy":1,"replyTime":"2020-07-13T14:04:12.000Z","msg":"咁最後點"},"citedBy":0,"replyTime":"2020-07-13T14:14:40.000Z","msg":"無聽過有咩後續，不了了之"},{"pid":"5f1f66af19ee352bca335c61d22f8015ccbaf7c8","tid":2106544,"uid":237300,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-13T14:46:56.000Z","msg":"推"},{"pid":"9e0fd07