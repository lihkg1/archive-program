/cry.gif\" class=\"hkgmoji\" />"},{"pid":"d06f17fe2a4d3d05361e695acf31bc53cfcf8699","tid":678601,"uid":34939,"like":0,"dislike":0,"score":0,"quote":{"pid":"47662b78ca84bfb477f8725ea80080892c1da697","tid":678601,"uid":25727,"like":1,"dislike":0,"score":1,"quote":{"pid":"0e5fea7b95c286638025bc719bdc373e3578d9b7","tid":678601,"uid":34939,"like":0,"dislike":0,"score":0,"quote":{"pid":"91c4ed8fd6659e006bb2c65bc97fa930b7afbfc4","tid":678601,"uid":81726,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-26T16:27:27.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-27T03:11:00.000Z","msg":"馮x 傑 兩三年前睇<br />\n睇左個幾月日日食藥就冇再出<br />\nso far 到依家亂食野都冇再出事"},"citedBy":1,"replyTime":"2018-05-27T03:47:48.000Z","msg":"你咁撚樣不如唔好俾名<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-27T04:09:01.000Z","msg":"<a href=\"http://bfy.tw/IK6O\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbfy.tw%2FIK6O&d=epW5akE5sroQ1Eef6JTVggRJEaK469wi7EMLOMkgk88%3D&h=019b868f\" data-auto-link target=\"_blank\">http://bfy.tw/IK6O</a><br />\n<br />\n 喂埋比你 第一個result 就係"},{"pid":"2c70154a850c00c2493ba6692814ae719e05884c","tid":678601,"uid":124283,"like":0,"dislike":0,"score":0,"quote":{"pid":"61cb465101e684a03650b0e3ee651b715fcae9aa","tid":678601,"uid":68595,"like":0,"dislike":0,"score":0,"quote":{"pid":"1365288b7496aa0971db790f9cb10ce54c77480c","tid":678601,"uid":124283,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-05-26T11:11:26.000Z","msg":"戒口戒左半年+睇中醫, 而家亂食野都無事"},"citedBy":1,"replyTime":"2018-05-26T18:32:36.000Z","msg":"你本身係食物敏感引致風癩？<br />\n我都睇咗幾年中醫+針灸，但冇乜起色<br />\n我自己又唔係食錯嘢先出，所以冇戒口"},"citedBy":0,"replyTime":"2018-05-27T16:53:12.000Z","msg":"其實我都唔知, 初頭睇西醫, 食左2個星期藥無料到就轉睇中醫<br />\n<br />\n中醫都轉左2次(睇左3個), keep 住食中藥, 期間食得極清, 半年後然後無啦啦好左, 到而家成年都無乜再發"},{"pid":"93d4e2269bd063a1eaf478276aa2a87ddc029c7b","tid":678601,"uid":136302,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-27T19:52:44.000Z","msg":"日日都出蕁麻疹, 多同少既分別。<br />\n最慘係出係面度, 會眼腫唇腫。<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"45aa5b9ccb5ad0bc8d4fb6eb9ebd86a663897fda","tid":678601,"uid":25846,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-27T20:00:23.000Z","msg":"我十年前發現，初初中藥，唔得。之後戒口，食西藥，敏感就食，之後三四年嚴重之後，就開始慢慢冇野。可以食番其他野。可以試下做敏感測試，避開致敏元加食藥就會慢慢好"},{"pid":"89d8f72a296d3b0096cb92c45d1af00cf51b2efe","tid":678601,"uid":141448,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-27T20:06:13.000Z","msg":"細個曾經唔知接觸定食錯乜野出過一次<br />\n睇醫生食藥 之後一直無事<br />\n<br />\n相隔幾年 有次游水突然見到手踭有<br />\n之後發現太凍嘅時候就會出<br />\n一去番暖嘅地方就會無事<br />\n已經維持左八年<br />\n一直無睇醫生由得佢"},{"pid":"6dfc7472fe203f776f60d81150f10bfa6d576fdb","tid":678601,"uid":104258,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-27T23:24:30.000Z","msg":"似，不過普通科醫生話我汗疹"},{"pid":"0eb97831a5d9cad38a0aa73a7b40eb1029431d16","tid":678601,"uid":85030,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-27T23:33:23.000Z","msg":"朋友蕁痲疹已經斷尾<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n登佢高興<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"77c017382735b6c5a81300a90cf2314f93ca4879","tid":678601,"uid":131955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-27T23:50:20.000Z","msg":"我係食物敏感就會出風癲 平時都會無比滴放袋 一茶就唔會想r"},{"pid":"790a87d5e8eca153f2d69aaab5ac630f46e4b0c7","tid":678601,"uid":53429,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-28T00:27:24.000Z","msg":"吊過鹽水後咩事都無哂"},{"pid":"548b9594f12d2ef42db128851daa715b19b37d2a","tid":678601,"uid":68595,"like":1,"dislike":0,"score":1,"quote":{"pid":"e7a446e33af3b316fa51176d47cff1f49b461d91","tid":678601,"uid":25327,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-05-27T04:02:09.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/05/27/120104_cf2ece1c91316d50f19aaa2b75a25709.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F27%2F120104_cf2ece1c91316d50f19aaa2b75a25709.png&h=ac5dabf2&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/05/27/120117_4053c47d2bfb6d9bb008f40ab7b670bf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F27%2F120117_4053c47d2bfb6d9bb008f40ab7b670bf.png&h=62969df8&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/05/27/120130_05872d93fa5befc84f38157edd3f8903.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F27%2F120130_05872d93fa5befc84f38157edd3f8903.png&h=41875a03&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/05/27/120142_d791f70294524110b8801b5f36e90936.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F27%2F120142_d791f70294524110b8801b5f36e90936.png&h=450b4c01&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/05/27/120152_75123de1e8413c9915f61b732deeed3f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F05%2F27%2F120152_75123de1e8413c9915f61b732deeed3f.png&h=27193aff&s={SIZE}\" /><br />\n<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-28T00:37:54.000Z","msg":"<img src=\"/assets/faces/lomoji/19.png\" class=\"hkgmoji\" /> <br />\n我啲疹仲係紅色，睇落去明顯好多<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},{"pid":"36727c61fa6a5c3aca908ddf03744796449537b7","tid":678601,"uid":162954,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-28T00:43:57.000Z","msg":"我以為得我係咁 我都岀左十年 之前keep住睇中醫都有好左小小 <br />\n而家就幾日食粒抗組織胺藥 平時飲食無理照食 照運動<br />\n不過我都係生係大脾同屎忽多<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n你地食開邊隻抗組織胺藥？我發覺唔同牌子 成份一樣 但keep到藥效時間係有唔同<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"58d3c85fd22a78a1e2f069b0cc1ec3b386310d37","tid":678601,"uid":68595,"like":0,"dislike":0,"score":0,"quote":{"pid":"36727c61fa6a5c3aca908ddf03744796449537b7","tid":678601,"uid":162954,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-28T00:43:57.000Z","msg":"我以為得我係咁 我都岀左十年 之前keep住睇中醫都有好左小小 <br />\n而家就幾日食粒抗組織胺藥 平時飲食無理照食 照運動<br />\n不過我都係生係大脾同屎忽多<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n你地食開邊隻抗組織胺藥？我發覺唔同牌子 成份一樣 但keep到藥效時間係有唔同<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-28T15:32:44.000Z","msg":"我自己冇再食抗組織胺，一來唔知長食有冇副作用，二來只係由啲疹凸出嚟變平咗之外冇咩改善。<br />\n但係將原本退疹嘅時間延長咗<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"efa77953f311700f2e438accdf5fc340516396be","tid":678601,"uid":49643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-28T18:56:16.000Z","msg":"有風癩好多年<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9c21392b3e541d7d113e923852cb80531d5ae39b","tid":678601,"uid":151786,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-05-28T19:38:01.000Z","msg":"我講下我經歷<br />\n大概中二開始有蕁痲疹，原因不明<br />\n上上下堂會出到咀唇都腫埋<br />\n跟住阿媽帶我樓下睇中醫<br />\n中醫主要俾一劑內服，一劑沖涼<br />\n講下沖涼果part，沖完果下好涼（好似有薄荷咁涼浸浸）<br />\n我記憶中啲藥有昆蟲殻咁上下（而家諗返可能係咸竹蜂）<br />\n食完藥沖完涼好返一排，忘記左維持左幾耐<br />\n<br />\n突然有一日復發，即刻要早退，因為成個人都腫哂咁滯，阿媽又帶我去睇返該名中醫，點知他休假！<br />\n跟住即刻去睇另一個，點知果晚食完藥沖完呢個涼，發得更嚴重，立即阿媽俾急用西藥我食，好辛苦咁捱到第二天，帶埋啲藥渣去見原本個醫師，重點黎了，他說我是熱底人，上個醫師開了些熱底唔可以用既藥材，所以我嚴重左。跟著當然就係佢開藥救返我<br />\n又不知道看了幾多次醫生。就完全好返了。<br />\n不過，睇這位中醫的過程，他有說過，我千萬不能食筍，同埋熱毒野也不要吃。希望我經歷對你有用<br />\n<br />\n其實我都不算完全斷尾，因為我大概每兩三年都會唔知原因咁復發一次，但我可以食西藥幾日就無事。<br />\n<br />\n祝你們早日找到良方斷尾！"},{"pid":"073fa38