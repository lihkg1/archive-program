:"a4d9494daf0f5c055f82e73ac4fe85545555193a","tid":2412683,"uid":191060,"like":0,"dislike":0,"score":0,"quote":{"pid":"49a0b3dd5ae4f33b9dbf46826b3015a8067647e1","tid":2412683,"uid":42202,"like":0,"dislike":0,"score":0,"quote":{"pid":"864d2aac65bca2c9dcdd1cabea3e0c1c272cf89c","tid":2412683,"uid":191060,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-18T07:35:32.000Z","msg":"你果陣係咪好快就照返工？<br />\n我仲放梗病假<br />\n諗到要對住個mon咁長時間就好痛苦<img src=\"/assets/faces/lomoji/20.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-18T07:47:58.000Z","msg":"係呀 我訓左一日就返左工了 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-18T07:52:46.000Z","msg":"咁勁<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><br />\n我早幾日連食梗既野都睇唔清楚<br />\n出街好易撞到人<br />\n有時好清有時好矇<br />\n好sad"},"citedBy":0,"replyTime":"2021-02-18T08:02:39.000Z","msg":"有咁嚴重咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n濛係正常既 但出街撞到人就..過份左<br />\n你呢幾日最好臨訓電話都唔好睇就真<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"89cee5999f8b28bdedcf95ab417bd8251b4b9543","tid":2412683,"uid":157953,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-18T08:10:05.000Z","msg":"本人做完2年<br />\n頭三個月係會好易乾 望得耐電話好似有散光咁矇矇地<br />\n但之後就慢慢恢復正常 大約半年就完全冇眼乾問題<br />\nSmile唔似傳統矯視咁好快清晰 而係慢慢越黎越清<br />\n如果唔係醫生技術問題 正常唔會有事既"},{"pid":"588f0bb5ae6c41937541161c837c7b4c25e6dd29","tid":2412683,"uid":110518,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-02-20T02:59:59.000Z","msg":"啱啱做完一日<br />\n基本上視力已經恢復<br />\n但係好霧<br />\n好似平時朝早起身有眼屎嘅感覺<br />\n幾時會好返<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />好驚之後都會咁"},{"pid":"92b70cdb0c45fb919c2c0fe61077479a65263161","tid":2412683,"uid":99172,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-20T12:26:57.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"130ce3acf4862b802a4393be479ceaa75cc81c64","tid":2412683,"uid":193020,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2021-02-24T12:11:07.000Z","msg":"我今日岩岩好做完一個星期<br />\n我都系時清時濛<br />\n起初以為系因為有用手機 電腦所以濛<br />\n但我試過搵日完全唔用電子產品 但時間耐左都開始濛<br />\n<br />\n見好多人都話做完手術第二日就咩8，9成視力..<br />\n我以為我近視深 所以要啲時間<br />\n但手術指引到都有寫 一星期後系有8-9成視力<br />\n所以我開始有啲驚<br />\n<br />\n想搵人add tg傾下隻眼進度既野 求個安心thx<br />\n<a href=\"https://t.me/ruketa226\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fruketa226&d=3nH4Hj8OzEJ%2Fsn4LiTBSOuu9cyR3gY7uP1sO3WVLDIg%3D&h=77139301\" data-auto-link target=\"_blank\">https://t.me/ruketa226</a>"},{"pid":"6fd74f5baaa78ed6364ac886b16d25c3e69033fb","tid":2412683,"uid":93350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-25T02:31:42.000Z","msg":"夜晚會有眩光情況出現<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"f4248eb1875f32399cf39bd5ed71ddd132996e10","tid":2412683,"uid":278219,"like":1,"dislike":0,"score":1,"quote":{"pid":"588f0bb5ae6c41937541161c837c7b4c25e6dd29","tid":2412683,"uid":110518,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-02-20T02:59:59.000Z","msg":"啱啱做完一日<br />\n基本上視力已經恢復<br />\n但係好霧<br />\n好似平時朝早起身有眼屎嘅感覺<br />\n幾時會好返<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />好驚之後都會咁"},"citedBy":0,"replyTime":"2021-02-26T00:45:23.000Z","msg":"我都琴日做完，都矇矇地<br />\n反而我無乜眼乾"}]}