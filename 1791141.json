23號，音樂界！大！罷！工！<br />\n<a href=\"https://lih.kg/1786495\" data-auto-link target=\"_blank\">https://lih.kg/1786495</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"82c9cd7cbe741a0d81bc8b3717b1e8c112326ad7","tid":1791141,"uid":71647,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-20T14:40:16.000Z","msg":"177.6幫你頂"},{"pid":"70f92487b28318443ef3e554a0263cd947f74d6e","tid":1791141,"uid":210756,"like":0,"dislike":1,"score":-1,"quote":{"pid":"82c9cd7cbe741a0d81bc8b3717b1e8c112326ad7","tid":1791141,"uid":71647,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-20T14:40:16.000Z","msg":"177.6幫你頂"},"citedBy":2,"replyTime":"2019-12-20T14:48:09.000Z","msg":"價錢可議！<img src=\"/assets/faces/pigxm/arrested.gif\" class=\"hkgmoji\" />"},{"pid":"82213490d9a0c01af1cab12e64d8cd8c68f20d3e","tid":1791141,"uid":242050,"like":9,"dislike":0,"score":9,"quote":{"pid":"70f92487b28318443ef3e554a0263cd947f74d6e","tid":1791141,"uid":210756,"like":0,"dislike":1,"score":-1,"quote":{"pid":"82c9cd7cbe741a0d81bc8b3717b1e8c112326ad7","tid":1791141,"uid":71647,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-20T14:40:16.000Z","msg":"177.6幫你頂"},"citedBy":2,"replyTime":"2019-12-20T14:48:09.000Z","msg":"價錢可議！<img src=\"/assets/faces/pigxm/arrested.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-20T14:49:18.000Z","msg":"請無飯食嘅小朋友啦"},{"pid":"233f5974752a64af51e6a1a5e3815fc96d7e22ba","tid":1791141,"uid":60279,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-20T14:51:54.000Z","msg":"聽日18區 驚左無得食所以放比人？"},{"pid":"874406670ab911c7119fafc2a1b372d3522ee9bd","tid":1791141,"uid":202889,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-12-20T14:53:22.000Z","msg":"幫你推<img src=\"/assets/faces/pigxm/cook.gif\" class=\"hkgmoji\" />"},{"pid":"de1116eae205eb1c0423b1eb9d047fe1140d4d6f","tid":1791141,"uid":210756,"like":0,"dislike":0,"score":0,"quote":{"pid":"874406670ab911c7119fafc2a1b372d3522ee9bd","tid":1791141,"uid":202889,"like":0,"dislike":0,"score":0,"ci