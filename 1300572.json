{"tid":1300572,"cid":33,"subCid":0,"title":"[預言]好快政府會怪責示者\"政府講完都唔信\",請提醒你身邊朋友做定心理衝擊","createTime":"2019-07-09T11:50:10.000Z","updateTime":"2019-07-09T13:09:18.000Z","uid":8762,"like":7,"dislike":2,"uniUserReply":1,"replies":[{"pid":"6685812817655f12f1c32001d81f9a0bef083cab","tid":1300572,"uid":8762,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-09T11:50:10.000Z","msg":"林鄭錄音機就不在話下，<br />\n今日個單信用制度，政制及內地事務居係明確咁講，唔會係香港落實。<br />\n<br />\n醒目如連登仔當然唔信佢！<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n不過，好快林鄭就可以以此為例，<span style=\"color: blue;\">反指無論政府講到實牙實齒，係市民唔願意相信政府，唔願意俾政府改進。</span><br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: x-large;\">我地要堅持，市民訴求已經非常清晰！政府要和解必須以實際行動落實五大訴求！！ 市民不信任政府係因為過往政府多次食言！政府有責任主動以行動取回市民信用！！！！</span></span><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />沒有盲反港人，只有食言政權！！！<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /></span></span>"},{"pid":"9fae8e3143b764d52f970c4b73cbe72a466039da","tid":1300572,"uid":8762,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-09T11:57:52.000Z","msg":"push"},{"pid":"f772b581fa6f306151ea9db8b50ee1f74753da52","tid":1300572,"uid":8762,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-09T12:26:21.000Z","msg":"push"},{"pid":"bcf357f6f547b725bf670654d6c14464a4bc7da2","tid":1300572,"uid":8762,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-09T13:09:18.000Z","msg":"push"}]}