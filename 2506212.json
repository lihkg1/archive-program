%2581%25E4%25BA%25A4%25E9%2580%259A%25E7%2587%2588-%25E8%25BC%2595%25E5%25BA%25A6%25E6%2599%25BA%25E9%259A%259C%25E5%25B7%25B4%25E7%25B1%258D%25E9%259D%2592%25E5%25B9%25B4%25E9%2582%2584%25E6%258A%25BC%25E7%25AD%2589%25E5%2580%2599%25E5%2588%25A4%25E5%2588%2591%2F&d=1Ie%2FqJFF6iBMyzR%2B2a49oNOI4bCcJ6pqCJTTaBDemLU%3D&h=d076f801\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F%25E8%25AA%258D%25E4%25BC%2581%25E5%259C%2596%25E7%25B8%25B1%25E7%2581%25AB%25E5%2592%258C%25E5%2588%2591%25E6%25AF%2581%25E4%25BA%25A4%25E9%2580%259A%25E7%2587%2588-%25E8%25BC%2595%25E5%25BA%25A6%25E6%2599%25BA%25E9%259A%259C%25E5%25B7%25B4%25E7%25B1%258D%25E9%259D%2592%25E5%25B9%25B4%25E9%2582%2584%25E6%258A%25BC%25E7%25AD%2589%25E5%2580%2599%25E5%2588%25A4%25E5%2588%2591%2F&h=77808131\" data-auto-link target=\"_blank\">https://www.thestandnews.com/court/%E8%AA%8D%E4%BC%81%E5%9C%96%E7%B8%B1%E7%81%AB%E5%92%8C%E5%88%91%E6%AF%81%E4%BA%A4%E9%80%9A%E7%87%88-%E8%BC%95%E5%BA%A6%E6%99%BA%E9%9A%9C%E5%B7%B4%E7%B1%8D%E9%9D%92%E5%B9%B4%E9%82%84%E6%8A%BC%E7%AD%89%E5%80%99%E5%88%A4%E5%88%91/</a>"},{"pid":"28c0d1dd50721afbdcc499df96c3374a4e100351","tid":2506212,"uid":54517,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-27T09:58:06.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"378fb42e7524fe0f222387e6ae93e0669fe6b08b","tid":2506212,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-27T10:26:28.000Z","msg":"<img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" />"},{"pid":"ff55bd0e107041d09fa8265f4de7c33ed0ba823f","tid":2506212,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-27T10:32:13.000Z","msg":"現場附近夾公仔機遺下豬嘴 驗出被告DNA<br />\n<br />\n案情指，示威者於前年9月5日晚上在旺角警署外聚集、叫口號及以雷射筆照射警員，警方則以水馬分隔警署及示威者。當晚9時許，被告身穿黑色衫褲及戴上口罩，與其他示威者現身警署外，並在遮陣掩護下將一個已點燃的膠袋放在警署正門水馬旁邊的金屬大閘上，然後離去，過程被傳媒拍下。未幾警員將跌到地上的已點火膠袋撲滅，大閘沒有損毀。<br />\n<br />\n及後被告又將內有黑色T裇和豬嘴的一個紅色膠袋，放在現場附近的一個夾公仔機上，事後驗出豬嘴上的DNA或是源於被告。<br />\n<a href=\"https://hk.appledaily.com/local/20210427/STJ7EMBGEREB3LDZK67NH4XBB4/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210427%2FSTJ7EMBGEREB3LDZK67NH4XBB4%2F&d=1Ie%2FqJFF6iBMyzR%2B2a49oNOI4bCcJ6pqCJTTaBDemLU%3D&h=4a526697\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210427%2FSTJ7EMBGEREB3LDZK67NH4XBB4%2F&h=f2e8ee93\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20210427/STJ7EMBGEREB3LDZK67NH4XBB4/</a>"},{"pid":"a18774ed8e2ae04d2435ed9ced6aa738e08944f4","tid":2506212,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-27T11:05:18.000Z","msg":"<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"1e5d30d7bcd6ae8b2fa47689212907838de7140d","tid":2506212,"uid":242444,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-27T11:06:19.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"}]}