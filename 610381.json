41bf6581deffa","tid":610381,"uid":47359,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-03-30T01:32:55.000Z","msg":"柒頭樓主<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/03/30/093244_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F30%2F093244_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=d2e7143a&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-03-30T01:34:34.000Z","msg":"真係可憐<br />\n駁唔到就是但貼張圖上來<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n你一直都係用呢招轉轉移視線<br />\n但已經冇用"},"citedBy":1,"replyTime":"2018-03-30T01:37:12.000Z","msg":"自打嘴巴<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-30T01:38:03.000Z","msg":"可笑<br />\n個時未知你咁多分身<br />\n依加都唔知堆五毛係咪你分身啦<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"94978354a89af055c62d5c49febc147701e2222e","tid":610381,"uid":47359,"like":0,"dislike":0,"score":0,"quote":{"pid":"a079416ef6637779dbeac155622fc6372196990a","tid":610381,"uid":38523,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-30T01:36:05.000Z","msg":"踢爆佢放生保皇買中資又變成泛民打手<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-30T01:38:23.000Z","msg":"你都唔係泛民打手我都唔知邊個係<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/03/30/093822_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F30%2F093822_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=64593b34&s={SIZE}\" />"},{"pid":"27b02809747730f29ee7042dadcb36c68212d715","tid":610381,"uid":38523,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-30T01:38:31.000Z","msg":"關狗扮捉五毛就大家都知<br />\n補選時一直屌泛民 放生保皇狗比人踢爆<br />\n一直轉移視線<br />\n之後反對佢既人就會有一堆五毛和應<br />\n之後就會順勢比關狗一齊打<br />\n結果就係反保皇狗既巴打就比佢話係五毛<br />\n今日關狗諗住開分身點知唔記得轉ac<br />\n<a href=\"http://lihkg.com/thread/593631/page/1\" data-auto-link target=\"_blank\">lihkg.com/thread/593631/page/1</a><br />\n雖然佢又話自嘲又成<br />\n係唔係想用分身開真係一睇就知<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n但..一個恐怖既假設就出現<br />\n如果<br />\n果堆著名五毛原來就係佢既分身呢?<br />\n借住打五毛獲得信任<br />\n係補選時用呢點暗助保皇狗<br />\n一有人反保皇狗<br />\n佢就開埋分身去支持<br />\n再用佢關狗打五毛既身份連同反保皇狗既巴打一齊打呢?<br />\n要知道就算佢打一千一萬個五毛<br />\n都唔及影響一個議席來得緊要<br />\n係咪就解得通佢一直口講泛民保皇一樣<br />\n但一直只追屌泛民放生保皇"},{"pid":"ffdce77b2a77c491f47f86a5bc833ce14d30ee5e","tid":610381,"uid":47359,"like":0,"dislike":0,"score":0,"quote":{"pid":"a8945e8eb2e43869ade664ca71c1acb6b00fbb38","tid":610381,"uid":38523,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd7c869f808a166cc30f5e00e5829169d06ef651","tid":610381,"uid":47359,"like":0,"dislike":0,"score":0,"quote":{"pid":"57c133119f5e5ecb2b3f9655b74ed762ddcf7a11","tid":610381,"uid":38523,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-30T01:34:34.000Z","msg":"真係可憐<br />\n駁唔到就是但貼張圖上來<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n你一直都係用呢招轉轉移視線<br />\n但已經冇用"},"citedBy":1,"replyTime":"2018-03-30T01:37:12.000Z","msg":"自打嘴巴<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-30T01:38:03.000Z","msg":"可笑<br />\n個時未知你咁多分身<br />\n依加都唔知堆五毛係咪你分身啦<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-30T01:39:03.000Z","msg":"去站務台投訴囉得個講字<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" />"},{"pid":"31944ef191a8cd1c7f74ee09025a06a4f01e9cb9","tid":610381,"uid":38523,"like":1,"dislike":0,"score":1,"quote":{"pid":"94978354a89af055c62d5c49febc147701e2222e","tid":610381,"uid":47359,"like":0,"dislike":0,"score":0,"quote":{"pid":"a079416ef6637779dbeac155622fc6372196990a","tid":610381,"uid":38523,"li