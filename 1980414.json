/clown.gif\" class=\"hkgmoji\" />"},{"pid":"7b55c0e3ecb6073316ec38274a131cdf8e216833","tid":1980414,"uid":259813,"like":0,"dislike":0,"score":0,"quote":{"pid":"ad1e71ca05dbc4fb8be0007a4f368f6d69f24682","tid":1980414,"uid":169529,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-20T05:51:40.000Z","msg":"佢真係完全唔記得所羅門mon實佢<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-20T05:54:08.000Z","msg":"可能阿姐姐覺得死硬所以豁出去呢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c13820ba6aa19603737d95f87cd382955c522b61","tid":1980414,"uid":55851,"like":0,"dislike":0,"score":0,"quote":{"pid":"733f22105d1ecf01a022ae4550f27c8ee98dee1b","tid":1980414,"uid":32148,"like":0,"dislike":2,"score":-2,"quote":{"pid":"39b1165d155b3061253472ed7264a68d8ccf08d3","tid":1980414,"uid":167469,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-20T05:38:33.000Z","msg":"美國抗疫千瘡百孔（一）<br />\n<br />\n截至4 月14 日，美國新冠肺炎的確診人數累計為586,057，成為「疫情大國」。<strong><span style=\"color: red;\">對素來喜歡認做「一哥」的美國來說，這嚴重損害美國人的自尊心。美國老羞成怒，對未來全球的秩序及政經發展可能有重大的影響。美國因疫情受重創，促使國內兩大鷹派，貿易鷹派（trade hawks）及國安鷹派（national security hawks）合流，中國承受的壓力相信會愈來愈大。</span></strong><br />\n<br />\n<strong><span style=\"color: red;\">美國成為新冠肺炎第一大國，可算是咎由自取。</span></strong>《紐約時報》（The New York Times ）在4 月11 日發表的一篇報道，指特朗普多次忽視公共衛生專家提交的報告，而報告表明這個疫情將會是大流行疫症（pandemic）。《紐約時報》報道，早在2 月21 日已有一名公共衛生專家，做了不同的新型冠狀病毒分析後，指這病毒可能會引致美國1 億1000 萬人感染、770 萬人入院及58 萬6000 人死亡。<strong><span style=\"color: red;\">然而，特朗普不相信專家所言，常常「唱好」美國，指美國百毒不侵，絕對是美國成為最大疫國的主因。</span></strong><br />\n<br />\n在1 月，特朗普在瑞士達沃斯開會時，表示當時的美國只有一宗由中國輸入的個案，於是在1 月31 日宣布禁止所有14 日內曾到訪中國的外國人入境美國。然而，隨着美國全國疫情大爆發，直至3 月16 日，特朗普才向民眾發出社交距離的指引，防疫措施明顯「慢了很多拍」。<strong><span style=\"color: red;\">特朗普這種不科學、不遵從專業意見及只懂「唱好」的領導作風，只會令國民鬆懈，令他們沒有防疫的戒心。有別於香港、台灣及中國內地等經歷過SARS 的地區，美國人的防疫意識一般較低，因此領導者的作風相當重要。中國早在1 月時已向世衛匯報疫情及提交病毒基因排序，特朗普「慢幾拍」的反應，白白浪費了兩個月的抗疫黃金時間。</span></strong>下文再續。<br />\n<br />\n美國抗疫千瘡百孔（一） (撰文 : 葉劉淑儀，原文刊載於明報)<br />\n<a href=\"https://news.mingpao.com/pns/%E4%BD%9C%E5%AE%B6%E5%B0%88%E6%AC%84/article/20200417/s00018/1587062402039/%E7%BE%8E%E5%9C%8B%E6%8A%97%E7%96%AB%E5%8D%83%E7%98%A1%E7%99%BE%E5%AD%94%EF%BC%88%E4%B8%80%EF%BC%89?fbclid=IwAR2xiy3tZYk-SAgspqBgcF3Ej4GvKddLyN_OTLhwrw1Y6dR3GBKXLxtWYK0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2F%25E4%25BD%259C%25E5%25AE%25B6%25E5%25B0%2588%25E6%25AC%2584%2Farticle%2F20200417%2Fs00018%2F1587062402039%2F%25E7%25BE%258E%25E5%259C%258B%25E6%258A%2597%25E7%2596%25AB%25E5%258D%2583%25E7%2598%25A1%25E7%2599%25BE%25E5%25AD%2594%25EF%25BC%2588%25E4%25B8%2580%25EF%25BC%2589%3Ffbclid%3DIwAR2xiy3tZYk-SAgspqBgcF3Ej4GvKddLyN_OTLhwrw1Y6dR3GBKXLxtWYK0&d=Sy1M3c%2BVV8kZ1V6TqBoGPvGl%2B26pDsgLotMYn9d4AWI%3D&h=d9c24f52\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2F%25E4%25BD%259C%25E5%25AE%25B6%25E5%25B0%2588%25E6%25AC%2584%2Farticle%2F20200417%2Fs00018%2F1587062402039%2F%25E7%25BE%258E%25E5%259C%258B%25E6%258A%2597%25E7%2596%25AB%25E5%258D%2583%25E7%2598%25A1%25E7%2599%25BE%25E5%25AD%2594%25EF%25BC%2588%25E4%25B8%2580%25EF%25BC%2589%3Ffbclid%3DIwAR2xiy3tZYk-SAgspqBgcF3Ej4GvKddLyN_OTLhwrw1Y6dR3GBKXLxtWYK0&h=09b7710d\" data-auto-link target=\"_blank\">https://news.mingpao.com/pns/%E4%BD%9C%E5%AE%B6%E5%B0%88%E6%AC%84/article/20200417/s00018/1587062402039/%E7%BE%8E%E5%9C%8B%E6%8A%97%E7%96%AB%E5%8D%83%E7%98%A1%E7%99%BE%E5%AD%94%EF%BC%88%E4%B8%80%EF%BC%89?fbclid=IwAR2xiy3tZYk-SAgspqBgcF3Ej4GvKddLyN_OTLhwrw1Y6dR3GBKXLxtWYK0</a><br />\n<br />\nsource: 葉劉淑儀facebook"},"citedBy":2,"replyTime":"2020-04-20T05:52:42.000Z","msg":"特朗譜柒又真係無講真，二月尾三月頭仲係天真僑上身，當普通流感咁處理<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-20T05:54:50.000Z","msg":"侵侵明顯係撚狗，想發大疫情，等自己有更多籌碼向中國報復"},{"pid":"424fd80ad5e78b13042d77afb1e299a052fa86da","tid":1980414,"uid":11448,"like