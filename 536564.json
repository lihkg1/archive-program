/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /> <br />\n一夠秤就劏豬<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /> <br />\n一啲位都唔俾人入<img src=\"/assets/faces/lomoji/22.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/22.png\" class=\"hkgmoji\" /> <br />\n你老味咁撚絕<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-01-22T02:18:46.000Z","msg":"你確定16歲先劏"},"citedBy":0,"replyTime":"2018-01-22T02:32:46.000Z","msg":"支那法律十四歲就食得啦～～～"},{"pid":"88278bac2c51ffe4bef7c76b66a199a0d6ebb3a7","tid":536564,"uid":61954,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-22T03:54:32.000Z","msg":"光源氏計劃支那版<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"0132f816090683c10a916c63b075e8a9829d381b","tid":536564,"uid":48083,"like":0,"dislike":0,"score":0,"quote":{"pid":"f5bfdbfa327afb06c0237671e4f3ae9a2eacee91","tid":536564,"uid":35080,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-01-22T02:29:48.000Z","msg":"16歲等粉嫩閪呀<img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-22T03:56:24.000Z","msg":"<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},{"pid":"a95e5deff1ae1490517666db4f2e1b599f64cd91","tid":536564,"uid":32934,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-22T04:02:13.000Z","msg":"孫中山後人?"},{"pid":"a7f3532c590d764b82ba554dbecab7d60edfacda","tid":536564,"uid":60057,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime