f3e60e75fcb09f772efbc63b41de2b4b79f","tid":1203331,"uid":29059,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-11T13:13:56.000Z","msg":"已簽，人在哥德堡"},{"pid":"2bdf77cecb6c8f038c0a7ca898fddf60211506ee","tid":1203331,"uid":225798,"like":0,"dislike":1,"score":-1,"quote":{"pid":"fa767f3e60e75fcb09f772efbc63b41de2b4b79f","tid":1203331,"uid":29059,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-11T13:13:56.000Z","msg":"已簽，人在哥德堡"},"citedBy":1,"replyTime":"2019-06-11T13:21:25.000Z","msg":"有無機會見到政府官員"},{"pid":"c25bcd2721034575a2b108f93d3c7b9fdfd04887","tid":1203331,"uid":225798,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-11T13:23:53.000Z","msg":"一人一信比大使館！最後機會！自己改下內容之後send!!!<br />\n<br />\nTemplate:<br />\nDear whom may concern,<br />\n<br />\nI am a Hong Konger. Recently the Hong Kong government have proposed the Extradition Law (ELAB), to handle a murder case in Taiwan. (actually there is an alternative methods but the government insists to propose this law for political purpose) In general many people opposed this law, because the law harms our personal and our assets' safety, also harm our rights and freedom. In June 9, more than 1 million Hong Konger have protested to express their opinion of opposing the law, which is more than one-seventh of Hong Konger. However, our Chief Executive, Carrie Lam, ignore the majority opinion and continue to propose ELAB.<br />\n<br />\nIn this issue, your government have the same stance with us and we are all oppose this law. The consulates and chambers have meet the Hong Kong government, and they are more worried about this law after the meeting. <br />\n<br />\nNordic countries respect people's human right and freedom and support equality. However, the Chinese government consider their power prior to human rights and freedom, and they kidnapped Mr. Gui Menhai, a Swedish citizen in Thailand in 2015. If ELAB passed, China have lower cost of arrest and kidnap people they want and more and more people, Hong Konger and Nordic citizens, will become Mr Gui Menhai. The protest of 9 June already show Hong Konger's opinion and if this law passed, not only our rights will be harmed, the benefits of Nordic countries in Hong Kong will also be harmed. Please keep putting pressure on Hong Kong government before it's too late.<br />\n<br />\nBest Regards,<br />\na Hong Konger"},{"pid":"e2208e17107b7786df4829c34079354f348f0c91","tid":1203331,"uid":225798,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T13:33:24.000Z","msg":"德國版第三段:<br />\n<br />\nThe situation of Hong Kong now is just like West Berlin in 1948. We are surrounded by a dictatorship government and they want full control of Hong Kong and destroy &quot;One Country, Two System&quot;, just like how DDR want full control of Berlin. The East Germans have lived in the DDR period, and living.  under fear is miserable. The protest of 9 June already show Hong Konger's opinion and if this law passed, not only our rights will be harmed, the benefits of Germany in Hong Kong will also be harmed. Please keep putting pressure on Hong Kong government before it's too late."},{"pid":"f547c6e0200148e4a6c5fe6dcaf84d69aa258b02","tid":1203331,"uid":225798,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec434adad16e4c7d3413a8e3ace2d86361e87a90","tid":1203331,"uid":225798,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-11T12:17:24.000Z","msg":"<a href=\"https://docs.google.com/forms/d/e/1FAIpQLSc_GBWh3RWSKGVZhxPq5eE4nhqghKK50EeyMMRpZWKobL6m-A/viewform\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdocs.google.com%2Fforms%2Fd%2Fe%2F1FAIpQLSc_GBWh3RWSKGVZhxPq5eE4nhqghKK50EeyMMRpZWKobL6m-A%2Fviewform&d=%2FodnS2mEGvHoUZPzyf%2FmNWsgcJLaMXzh2FZp7TjlN88%3D&h=aade543c\" data-auto-link target=\"_blank\">https://docs.google.com/forms/d/e/1FAIpQLSc_GBWh3RWSKGVZhxPq5eE4nhqghKK50EeyMMRpZWKobL6m-A/viewform</a><br />\n<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"