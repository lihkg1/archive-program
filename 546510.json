{"tid":546510,"cid":6,"subCid":0,"title":"[信心保證達羅素]二月三日沙田十場草地賽日討論區","createTime":"2018-01-31T15:00:01.000Z","updateTime":"2018-02-01T20:03:52.000Z","uid":2181,"like":0,"dislike":0,"uniUserReply":21,"replies":[{"pid":"e49c68f669743032f265f632cfb244e74bf3851b","tid":546510,"uid":2181,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-31T15:00:01.000Z","msg":"<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"206bb6fa06bf97c69af6789887d217a3ee7eb955","tid":546510,"uid":6566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-31T15:00:26.000Z","msg":"繼續追拉子騎豬王<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"0cd11222898cb780629aa0ddceb4be8523be6765","tid":546510,"uid":110475,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-31T15:00:35.000Z","msg":"lm"},{"pid":"b7db8a901fe1c4e328a0be0f1bb9becb23db3786","tid":546510,"uid":7778,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-31T15:00:50.000Z","msg":"信心保證會唔會又退出架<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3497c3ece7e37de6b1147672c316770682c3a543","tid":546510,"uid":73320,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-31T15:01:14.000Z","msg":"連續輸左幾個賽馬日<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"2ad28538b17a22829ac3bce8e67dfe72e196b21d","tid":546510,"uid":1312,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-01-31T15:01:40.000Z","msg":"樓主同燒家有仇？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"263603cd182b545e0d7706d6e03451851d33d341","tid":546510,"uid":60766,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-01-31T15:04:17.000Z","msg":"差唔多得閒番<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"382b14ff4ae415451c85af07ac924b4ccc5ef32c","tid":546510,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-31