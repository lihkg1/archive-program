a7cd5e162f7cf18e82161d26b36fb5ed3f5","tid":2100462,"uid":53612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-09T15:27:34.000Z","msg":"推初選先 <br />\n不推移民post"},{"pid":"c9152d66ad9f2f2f357d1219350d2c8071ea7f60","tid":2100462,"uid":61974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-09T15:40:22.000Z","msg":"推下啦"},{"pid":"d8c0756b55f392e9a7a4e6e059c6d6c47d170257","tid":2100462,"uid":25945,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-09T15:48:04.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5863f98fcbe91f2a7d9657265ae6144913e9cced","tid":2100462,"uid":133743,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-09T15:56:50.000Z","msg":"投本土呀"}]}