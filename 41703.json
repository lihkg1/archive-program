mg src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"b58fb147e2f3770fc2cb4b6520d6b7f52116fc33","tid":41703,"uid":35964,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-16T07:45:15.000Z","msg":"鬼佬真係好正<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"b700b8bca9379c26edef493155e028f8d059ee7a","tid":41703,"uid":47801,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-16T07:46:12.000Z","msg":"此回覆已被刪除"},{"pid":"ea49e87e2219fd631ad02cab277d45ad12e59006","tid":41703,"uid":39508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-16T08:49:13.000Z","msg":"大鄉里出城嘛<br />\n日日廣告見到d白洋腸高大又輪廓深就以為全部洋腸都係咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n但事實外國柒樣既洋腸係佔大多數"},{"pid":"3decdc713d4808944bbf460469fc4fe3d14e3e97","tid":41703,"uid":49391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-16T10:44:00.000Z","msg":"跨國網上情緣騙案　73港人被騙<br />\n<a href=\"https://hk.news.yahoo.com/%E8%B7%A8%E5%9C%8B%E7%B6%B2%E4%B8%8A%E6%83%85%E7%B7%A3%E9%A8%99%E6%A1%88-73%E6%B8%AF%E4%BA%BA%E8%A2%AB%E9%A8%99-092720063.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.yahoo.com%2F%25E8%25B7%25A8%25E5%259C%258B%25E7%25B6%25B2%25E4%25B8%258A%25E6%2583%2585%25E7%25B7%25A3%25E9%25A8%2599%25E6%25A1%2588-73%25E6%25B8%25AF%25E4%25BA%25BA%25E8%25A2%25AB%25E9%25A8%2599-092720063.html&d=g497ee0v2v%2FLjIX%2FxLisjWN6obqfy%2FNc7jg2IsrTbnE%3D&h=a595209f\" target=\"_blank\">https://hk.news.yahoo.com/%E8%B7%A8%E5%9C%8B%E7%B6%B2%E4%B8%8A%E6%83%85%E7%B7%A3%E9%A8%99%E6%A1%88-73%E6%B8%AF%E4%BA%BA%E8%A2%AB%E9%A8%99-092720063.html</a><br />\n<br />\n【Now新聞台】警方聯同馬來西亞及尼日利亞執法部門，瓦解一個從事網上情緣騙案的跨境犯罪集團，涉及金額約六千萬元。大部分受害人是香港人，最嚴重的一宗，受害人被騙取900萬港元。<br />\n警方與馬來西亞及尼日利亞執法部門採取聯合行動，搗破一個跨境詐騙集團，拘捕14名分別來自尼日利亞、馬來西亞、塞拉利昂和新加坡的疑犯。<br />\n他們共涉及86宗網上情緣騙案，牽涉六千萬港元騙款。其中73名受害人是香港人，涉及5800萬港元，最多的一宗，受害人被騙取900萬港元。<br />\n警方指，<span style=\"color: red;\">騙徒利用歐美白種人照片</span>，在網上社交平台偽造假身分。結識事主後，要求對方匯款到傀儡帳戶。馬來西亞主腦收款後，再把部分騙款匯到尼日利亞等其他國家。<br />\n警方指受害人全是女性，介乎25至73歲，近半是白領人士，大部分擁高學歷和懂英文，亦有家庭主婦和退休人士，他們均未曾與騙徒見面。<br />\n今年首十個月，網上情緣騙案較同期急升1.1倍，警方呼籲市民網上交友時，要提高警惕。<br />\n#要聞"},{"pid":"ae7a999fe47a8347b8d31f00573f3e3684e6ba2d","tid":41703,"uid":56533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-16T10:47:53.000Z","msg":"<blockquote>跨國網上情緣騙案　73港人被騙<br />\n<a href=\"https://hk.news.yahoo.com/%E8%B7%A8%E5%9C%8B%E7%B6%B2%E4%B8%8A%E6%83%85%E7%B7%A3%E9%A8%99%E6%A1%88-73%E6%B8%AF%E4%BA%BA%E8%A2%AB%E9%A8%99-092720063.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.yahoo.com%2F%25E8%25B7%25A8%25E5%259C%258B%25E7%25B6%25B2%25E4%25B8%258A%25E6%2583%2585%25E7%25B7%25A3%25E9%25A8%2599%25E6%25A1%2588-73%25E6%25B8%25AF%25E4%25BA%25BA%25E8%25A2%25AB%25E9%25A8%2599-092720063.html&d=g497ee0v2v%2FLjIX%2FxLisjWN6obqfy%2FNc7jg2IsrTbnE%3D&h=a595209f\" target=\"_blank\">https://hk.news.yahoo.com/%E8%B7%A8%E5%9C%8B%E7%B6%B2%E4%B8%8A%E6%83%85%E7%B7%A3%E9%A8%99%E6%A1%88-73%E6%B8%AF%E4%BA%BA%E8%A2%AB%E9%A8%99-092720063.html</a><br />\n<br />\n【Now新聞台】警方聯同馬來西亞及尼日利亞執法部門，瓦解一個從事網上情緣騙案的跨境犯罪集團，涉及金額約六千萬元。大部分受害人是香港人，最嚴重的一宗，受害人被騙取900萬港元。<br />\n警方與馬來西亞及尼日利亞執法部門採取聯合行動，搗破一個跨境詐騙集團，拘捕14名分別來自尼日利亞、馬來西亞、塞拉利昂和新加坡的疑犯。<br />\n他們共涉及86宗網上情緣騙案，牽涉六千萬港元騙款。其中73名受害人是香港人，涉及5800萬港元，最多的一宗，受害人被騙取900萬港元。<br />\n警方指，<span style=\"color: red;\">騙徒利用歐美白種人照片</span>，在網上社交平台偽造假身分。結識事主後，要求對方匯款到傀儡帳戶。馬來西亞主腦收款後，再把部分騙款匯到尼日利亞等其他國家。<br />\n警方指受害人全是女性，介乎25至<span style=\"color: red;\">73歲</span>，近半是白領人士，大部分擁高學歷和懂英文，亦有家庭主婦和退休人士，他們均未曾與騙徒見面。<br />\n今年首十個月，網上情緣騙案較同期急升1.1倍，警方呼籲市民網上交友時，要提高警惕。<br />\n#要聞</blockquote><br />\n<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"c2d1cdeca2595193d1378d92140fd694b68d5a3f","tid":41703,"uid":49391,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-16T10:51:34.000Z","msg":"<blockquot