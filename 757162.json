ta-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F26%2F233235_61a93e9f747b4b6275ff19cf5fbd0fd9.png&h=57ca5d1a&s={SIZE}\" /><br />\n<br />\n呢舊嘢可愛？"},"citedBy":0,"replyTime":"2018-07-26T15:51:21.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"21a3509bacb77bf7c6325f3a62788d6402442a9a","tid":757162,"uid":22560,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-26T15:52:24.000Z","msg":"咬成點<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"9b18fe43c2e9d57f2a1115bb41773556173ab8bc","tid":757162,"uid":1221,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-26T16:13:15.000Z","msg":"<img src=\"https://topick.hket.com/res/v3/image/content/1440000/1440570/carf0602008_1024.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ftopick.hket.com%2Fres%2Fv3%2Fimage%2Fcontent%2F1440000%2F1440570%2Fcarf0602008_1024.jpg&h=aa33188f&s={SIZE}\" /><br />\n 鹹竹蜂<br />\n<br />\n常聽聞歌星用鹹竹蜂開聲，其實此屬民間偏方，因鹹竹蜂產自南方，多為南方一帶採用。鹹竹蜂來自蜜蜂科昆蟲竹筒蜂的乾燥全體，藥理甘、寒；功效為清熱化痰、袪風定驚。<br />\n<br />\n一般用3至4隻鹹竹蜂，加入中藥胖大海4至5粒和甘草兩片沖水，有助開聲、聲沙和紓緩咽喉痛，有短暫的緩解作用。但要注意是，始終此為偏方，若嚴重至因聲帶有瘜肉引致的聲沙，並無效果。<br />\n<br />\n鹹竹蜂無毒性，需要時飲用並無大礙，但它性寒，體質若本身偏寒，以為藉鹹竹蜂滋潤一下喉嚨，有可能因此寒上加寒，令病情更差。"},{"pid":"7cc323a032fa3e72fb32f3e4eccc0773a8f116c1","tid":757162,"uid":4875,"like":0,"dislike":0,"score":0,"quote":{"pid":"9b18fe43c2e9d57f2a1115bb41773556173ab8bc","tid":757162,"uid":1221,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-26T16:13:15.000Z","msg":"<img src=\"https://topick.hket.com/res/v3/image/content/1440000/1440570/carf0602008_1024.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ftopick.hket.com%2Fres%2Fv3%2Fimage%2Fcontent%2F1440000%2F1440570%2Fcarf0602008_1024.jpg&h=aa33188f&s={SIZE}\" /><br />\n 鹹竹蜂<br />\n<br />\n常聽聞歌星用鹹竹蜂開聲，其實此屬民間偏方，因鹹竹蜂產自南方，多為南方一帶採用。鹹竹蜂來自蜜蜂科昆蟲竹筒蜂的乾燥全體，藥理甘、寒；功效為清熱化痰、袪風定驚。<br />\n<br />\n一般用3至4隻鹹竹蜂，加入中藥胖大海4至5粒和甘草兩片沖水，有助開聲、聲沙和紓緩咽喉痛，有短暫的緩解作用。但要注意是，始終此為偏方，若嚴重至因聲帶有瘜肉引致的聲沙，並無效果。<br />\n<br />\n鹹竹蜂無毒性，需要時飲用並無大礙，但它性寒，體質若本身偏寒，以為藉鹹竹蜂滋潤一下喉嚨，有可能因此寒上加寒，令病情更差。"},"citedBy":0,"replyTime":"2018-07-26T16:15:04.000Z","msg":"上網search又話毒性好勁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />  邊句真"}]}