/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"2504161a56746b1e0526304ad64235ebd3cb0720","tid":547510,"uid":46013,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-02T03:53:59.000Z","msg":"無澳職日職既"},{"pid":"1bdb9dd1cffc1a355a4a6eb27381338b38fbd324","tid":547510,"uid":31151,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-02T03:59:50.000Z","msg":"<blockquote><a href=\"http://www.cabletv.com.hk/file/editor/pdf/5a72ded423b7f.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.cabletv.com.hk%2Ffile%2Feditor%2Fpdf%2F5a72ded423b7f.pdf&d=8SIJ3bEWRS%2FHeheCzVHYaBv1o3X72Fc8dbph17rWX2c%3D&h=d6692664\" target=\"_blank\">http://www.cabletv.com.hk/file/editor/pdf/5a72ded423b7f.pdf</a><br />\n8月31日自動完 半年168 但係on99逼人裝盒 擺到明想你完左之後屈你安排唔到時間收機或者趁你唔記得完左繼續睇再屈鳩你收聲用佢服務<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n似係啦 根本個盒就冇需要裝既<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6c88bf8f179b98674dd28bd35e92661e7b73be31","tid":547510,"uid":57035,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-02-02T03:59:58.000Z","msg":"冇得淨係係電腦電話睇 一定要裝濕鳩解碼器 不了<br />\n<br />\nQ5. 我經「i-CABLE流動版」訂購「168有線體育通行証」，可以唔安裝有線電視解碼器（FANhub） 只在手機觀看可以嗎？<br />\nA5. 「168有線體育通行証」用戶必須於2018年3月15日前成功安裝有線電視解碼器（FANhub），方可繼續享受有線電視所提供<br />\n的跨平台服務（包括電視、手機、平板及電腦）。逾期之用戶將不會安排裝機，到時可繼續享用「168有線體育通行証」服<br />\n務，但只限於手機、 平板及電腦上收睇有線電視節目內容。"},{"pid":"8bc193b349920677e21ba8e1d22756062e7a6714","tid":547510,"uid":129184,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-02T04:04:06.000Z","msg":"唔會中計，永不申請"},{"pid":"e1bfaf9c6af37e2f22c94f760600284ad00f0def","tid":547510,"uid":53790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-02T04:04:35.000Z","msg":"唔用盒睇...用app睇會有delay<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5e90457c190256a0f2ee81cb5