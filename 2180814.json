ke":0,"score":1,"quote":{"pid":"9e0480dfb880bca587b2090f44c039ca67983eb6","tid":2180814,"uid":12034,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2020-08-30T07:53:40.000Z","msg":"on9<br />\n<br />\n不如儲寶可夢同數碼寶貝卡好撚過<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-30T08:14:58.000Z","msg":"Pkm卡當然都儲得過啦<br />\n但覺得on9之前可以先睇下實質個市場規模同埋價格市況先再作定論<br />\n唔好做咗井底之蛙都唔知"},{"pid":"3e784c3a616b49c78c87f4ec0735e677b0dde571","tid":2180814,"uid":147766,"like":0,"dislike":0,"score":0,"quote":{"pid":"0ce30bf0ee98b926d333e83a6087adfb167eba4c","tid":2180814,"uid":299514,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-30T07:20:54.000Z","msg":"我有堆90s嘅籃球卡"},"citedBy":1,"replyTime":"2020-08-30T08:15:42.000Z","msg":"可以去eBay查下價錢 隨時會嚇親"},{"pid":"6bf21db9d09f511d06d2e98a5f28e10d153bd7bf","tid":2180814,"uid":299514,"like":0,"dislike":0,"score":0,"quote":{"pid":"3e784c3a616b49c78c87f4ec0735e677b0dde571","tid":2180814,"uid":147766,"like":0,"dislike":0,"score":0,"quote":{"pid":"0ce30bf0ee98b926d333e83a6087adfb167eba4c","tid":2180814,"uid":299514,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-30T07:20:54.000Z","msg":"我有堆90s嘅籃球卡"},"citedBy":1,"replyTime":"2020-08-30T08:15:42.000Z","msg":"可以去eBay查下價錢 隨時會嚇親"},"citedBy":1,"replyTime":"2020-08-30T08:27:16.000Z","msg":"以前買過啲籃球卡嘅雜誌，入面啲價錢資料睇唔明。<br />\n隨咗ebay仲有冇其他途徑可以知道市價"},{"pid":"fe2b32d425d695959615af9f8de7e765ab94468b","tid":2180814,"uid":147766,"like":0,"dislike":0,"score":0,"quote":{"pid":"6bf21db9d09f511d06d2e98a5f28e10d153bd7bf","tid":2180814,"uid":299514,"like":0,"dislike":0,"score":0,"quote":{"pid":"3e784c3a616b49c78c87f4ec0735e677b0dde571","tid":2180814,"uid":147766,"like":0,"dislike":0,"score":0,"quote":{"pid":"0ce30bf0ee98b926d333e83a6087adfb167eba4c","tid":2180814,"uid":299514,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-30T07:20:54.000Z","msg":"我有堆90s嘅籃球卡"},"citedBy":1,"replyTime":"2020-08-30T08:15:42.000Z","msg":"可以去eBay查下價錢 隨時會嚇親"},"citedBy":1,"replyTime":"2020-08-30T08:27:16.000Z","msg":"以前買過啲籃球卡嘅雜誌，入面啲價錢資料睇唔明。<br />\n隨咗ebay仲有冇其他途徑可以知道市價"},"citedBy":0,"replyTime":"2020-08-30T08:49:55.000Z","msg":"基本上香港市場卡價都係參考eBay成交為主<br />\n係ebay直接search球員名同系列名就會搵到"},{"pid":"b2efa2cbcadf44c4e1be1f305154892fe761d52e","tid":2180814,"uid":6239,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-30T09:28:52.000Z","msg":"Lm"},{"pid":"1bf991b9152c745fbf3c9d71560eab98ab27fa2f","tid":2180814,"uid":15948,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-30T09:33:58.000Z","msg":"可唔可以比d圖介紹下唔同卡包<br />\n邊d適合入門<br />\n買左卡簿但唔知點入手儲好"},{"pid":"93d8d679ed06dc29ba072985aee0632a16333615","tid":2180814,"uid":299514,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-30T12:36:37.000Z","msg":"其實唔會知個市場炒咩風，以前啲新秀卡係無人要。<br />\n十蚊兩三張咁賣，只有大星當打果啲先叫炒得起。"},{"pid":"a1ad504143882b4576f7cd939c3579cf97695624","tid":2180814,"uid":147766,"like":0,"dislike":0,"score":0,"quote":{"pid":"1bf991b9152c745fbf3c9d71560eab98ab27fa2f","tid":2180814,"uid":15948,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-30T09:33:58.000Z","msg":"可唔可以比d圖介紹下唔同卡包<br />\n邊d適合入門<br />\n買左卡簿但唔知點入手儲好"},"citedBy":0,"replyTime":"2020-08-30T13:52:59.000Z","msg":"呢個中文網站有唔同卡盒介紹<br />\n<br />\n<a href=\"https://www.jjcs.com.tw/categories/nba-box\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.jjcs.com.tw%2Fcategories%2Fnba-box&d=XjGeTWWNN7bjI%2BfZ7PvsLDv6TERBNTdTd%2BiGQaA%2FLRg%3D&h=53ac8fe2\" data-auto-link target=\"_blank\">https://www.jjcs.com.tw/categories/nba-box</a><br />\n<br />\n新手建議：Hoops,Revolution, Mosaci 價錢較親民<br />\n然後Prizm,Optic,select都係CP值高而且一般人玩得起"},{"pid":"f684723471117eeb6530da67ced14d2e9f4a005e","tid":2180814,"uid":147766,"like":0,"dislike":0,"score":0,"quote":{"pid":"93d8d679ed06dc29ba072985aee0632a16333615","tid":2180814,"uid":299514,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-30T12:36:37.000Z","msg":"其實唔會知個市場炒咩風，以前啲新秀卡係無人要。<br />\n十蚊兩三張咁賣，只有大星當打果啲先叫炒得起。"},"citedBy":0,"replyTime":"2020-08-30T13:56:25.000Z","msg":"感覺由早年Panini開始代理後市場就唔同咗好多，當初嘅幾十蚊卡，而宜家隨時變4-5位數。仲要講緊嘅唔係簽名/限量卡，所以只能講市場太瘋狂。"},{"pid":"0bf38f60075ab22d3076395980c73669ba8f2898","tid":2180814,"uid":24989,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-29T15:24:58.000Z","msg":"有冇睇「老婆不要看」？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"64daf1399de29de5e49ce47a9839f79200d375ef","tid":2180814,"uid":24989,"like":0,"dislike":0,"score":0,"quote":{"pid":"0ce30bf0ee98b926d333e83a6087adfb167eba4c","tid":2180814,"uid":299514,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-30T07:20:54.000Z","msg":"我有堆90s嘅籃球卡"},"citedBy":0,"replyTime":"2020-09-29T15:25:57.000Z","msg":"如果儲存得好可以好值錢"},{"pid":"594562018f533ea183c0602e0625464886da1882","tid":2180814,"uid":54076,"like":0,"dislike":0,"score":0,"quote":{"pid":"d765658ac775bac96709c008abbeca12cfae9f06","tid":2180814,"uid":55493,"like":2,"dislike":2,"score":0,"citedBy":2,"replyTime":"2020-08-30T07:05:40.000Z","msg":"投資角度？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n中意咪儲下<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n當投資純粹搞笑"},"citedBy":0,"replyTime":"2021-02-13T17:12:38.000Z","msg":"呢半年有好多人揸住籃球卡發咗達<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n有張MJ賣咗70萬USD"}]}