3dzUHiPRQAVEyUYSrU9BM&h=eb7ab18a&s={SIZE}\" /><br />\n<img src=\"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSLP5586kzjVs18qti0aEHPenmoi4gq7wvCtMhLcvXFBO1wvfG5bA\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fencrypted-tbn0.gstatic.com%2Fimages%3Fq%3Dtbn%3AANd9GcSLP5586kzjVs18qti0aEHPenmoi4gq7wvCtMhLcvXFBO1wvfG5bA&h=87219326&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-03-13T02:50:40.000Z","msg":"冷戰時期唔同第一次世界大戰"},"citedBy":1,"replyTime":"2018-03-13T03:11:56.000Z","msg":"香港唔同第一次世界大戰"},{"pid":"342362a8aaf54937e379b783a219f253d55c2bce","tid":589111,"uid":20816,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1fc1411b48072f20f0d73e8e711139f8ade5a54","tid":589111,"uid":683,"like":0,"dislike":0,"score":0,"quote":{"pid":"b4064661ddd5628685676911d474f111ae3ac614","tid":589111,"uid":20816,"like":0,"dislike":0,"score":0,"quote":{"pid":"0fe9ccf9a74fe032fb0c1281c90c6bbe0a7c736b","tid":589111,"uid":683,"like":2,"dislike":2,"score":0,"citedBy":1,"replyTime":"2018-03-12T12:13:21.000Z","msg":"<img src=\"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTKR2ezzYv302_nSr17gUCr4sArBb73dzUHiPRQAVEyUYSrU9BM\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fencrypted-tbn0.gstatic.com%2Fimages%3Fq%3Dtbn%3AANd9GcTKR2ezzYv302_nSr17gUCr4sArBb73dzUHiPRQAVEyUYSrU9BM&h=eb7ab18a&s={SIZE}\" /><br />\n<img src=\"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSLP5586kzjVs18qti0aEHPenmoi4gq7wvCtMhLcvXFBO1wvfG5bA\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fencrypted-tbn0.gstatic.com%2Fimages%3Fq%3Dtbn%3AANd9GcSLP5586kzjVs18qti0aEHPenmoi4gq7wvCtMhLcvXFBO1wvfG5bA&h=87219326&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-03-13T02:50:40.000Z","msg":"冷戰時期唔同第一次世界大戰"},"citedBy":1,"replyTime":"2018-03-13T03:11:56.000Z","msg":"香港唔同第一次世界大戰"},"citedBy":0,"replyTime":"2018-03-13T03:26:14.000Z","msg":"《議事規則》修訂通過前一星期，公民黨黨魁楊岳橋「小登科」設酒會宴客，部分網民批評他邀請支持修訂的建制派議員出席，與他們高興合照，質疑楊在議事堂批評「敵人」時有多真心？楊岳橋反駁，邀請議員同事出席是基於禮貌，自己一言一行也代表公民黨，不能「小器」：「唔通我黑著面對著人咩？到你自己結婚嗰一天，你會明白。」<br />\n<br />\n記者 姚國雄<br />\n楊岳橋指，曾結婚宴客的人也清楚，邀請賓客出席自己婚宴是出於禮節、傳統，故未必每位賓客也是自己很想宴請的人，同時礙於自己身份，有些人一定要請：「有時有啲三姑六婆你唔想請，你都要請，我喺呢方面係比較傳統，同時我係公民黨黨魁，我做嘅嘢有時係會比人算喺公民黨頭上，我唔能夠太小器&hellip;出席你婚禮嘅人，未必個個都係你自細長大嘅好朋友。」<br />\n<span style=\"color: red;\"> 他就此打個比喻，「喺第一次世界大戰，1915年嘅聖誕節，德軍與英軍都會停火，雙方士兵踢咗場波，連兵戎相見，都尚可以停火，踢番場友誼波，更可況我哋（立法會）？」</span><br />\n有人堅持議會內外，也要敵我分明，劍拔弩張，楊形容這反映過去五年，社會撕裂遺禍至今，但凡反對自己意見的人，便抱不共戴天的仇恨：「你唔係同我一齊，你就係我嘅敵人，到今日呢個情況都冇咁容易化解到，但我不會怪人，不過我覺得做人要有基本禮貌。」  <br />\n<br />\n<a href=\"https://hk.news.appledaily.com/local/realtime/article/20171219/57599014\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20171219%2F57599014&d=ZU%2BVxSsGslah%2F71SpSkvf8mB%2BETtKD6oVAJ%2Bxq8xWyI%3D&h=fd51639e\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20171219%2F57599014&h=8a990ced\" target=\"_blank\">https://hk.news.appledaily.com/local/realtime/article/20171219/57599014</a>"},{"pid":"4ec18e3968f7c6827490aec59544a543e1de7f84","tid":589111,"uid":20816,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-13T12:44:00.000Z","msg":"<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"305594a5767a3da619dfde490204500bc7fe2f97","tid":589111,"uid":20816,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-13T14:50:32.000Z","msg":"<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"b4fc36aa10a234ded8eb666e1ddb8ebf110965f1","tid":589111,"uid":20816,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-15T08:15:29.000Z","msg":"<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"}]}