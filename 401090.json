https%3A%2F%2Fi.imag.cx%2FhBXlI.jpg&h=32290e7c&s={SIZE}\" /><br />\n<img src=\"https://i.imag.cx/vHoXA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FvHoXA.jpg&h=1fb87b30&s={SIZE}\" /><br />\n下面呢個係隨便台Official LINE群,有咩突發消息,開台通知,我都會係呢度公布<br />\n<img src=\"http://qr-official.line.me/L/aqio2VXZLo.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fqr-official.line.me%2FL%2Faqio2VXZLo.png&h=03fd5638&s={SIZE}\" />"},{"pid":"bb28c03a835c33b9cbf629045bc57c291e3b4d47","tid":401090,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-15T10:47:28.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"579cddf72566988e294bd02025fd89476045b2ed","tid":401090,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-15T11:09:28.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5117704436902c8253c4c2aeff77352930f3102e","tid":401090,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-15T11:47:27.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d91818c086018ff9de28169df6a74fc2b41ebb78","tid":401090,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-15T11:56:22.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f043b9da2c6fbbbef88588d292e114dd9d713ba5","tid":401090,"uid":89382,"like":0,"dislike