,"tid":2368663,"uid":171786,"like":2,"dislike":0,"score":2,"quote":{"pid":"4ed0c064c2c586760797dc246dbf52de3a4590f4","tid":2368663,"uid":214173,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-16T12:34:51.000Z","msg":"越封越多人知<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-16T12:46:53.000Z","msg":"我之前真係唔知，而家知道原來有咁多嘢睇<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"a371bfae19eaa14d1da40fc06e45d98828ae41fe","tid":2368663,"uid":286792,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-16T12:49:20.000Z","msg":"推"},{"pid":"b22c33084a53ff8e6423423a3cb105a9a58c4e5f","tid":2368663,"uid":49329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-16T12:53:02.000Z","msg":"<img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"}]}