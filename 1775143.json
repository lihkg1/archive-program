=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-12-10T15:00:21.000Z","msg":"係！！！！！！！無錯！！！<br />\n我之前都baby fat但臉啲肉係好彈可以拉到變<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />咁<br />\n但依家啲肉真係好實<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />我日日都會推下佢<br />\n側面睇真係同麵包超人一樣<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />蘋果肌嗰個位勁突<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我食咗個零兩個月啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />唔知仲要食幾類<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n絲打咩病？"},{"pid":"df7447ccc8522738ed4847b84492ef485af0b0a1","tid":1775143,"uid":71085,"like":0,"dislike":0,"score":0,"quote":{"pid":"e55285dfbab6e34d796d7418cf8e25a958d85026","tid":1775143,"uid":47462,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d36078211e9e4e3a42bba38b36291067f4746ae","tid":1775143,"uid":2679,"like":0,"dislike":0,"score":0,"quote":{"pid":"eda12b2dc75fd6ee5f370c1934ad37babf3b5638","tid":1775143,"uid":71085,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-08T16:41:38.000Z","msg":"停藥之後幾耐瘦番<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />？"},"citedBy":1,"replyTime":"2019-12-09T00:20:38.000Z","msg":"都幾年先發現自己塊臉無咁月亮feel<br />\n你當一年幾啦"},"citedBy":1,"replyTime":"2019-12-09T03:14:36.000Z","msg":"有排都未停得藥<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-12-10T15:01:12.000Z","msg":"你依家又食番？<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我都有排未停得<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"fa897cf9e0492c56b02eb4c22094dae3db65166b","tid":1775143,"uid":47462,"like":0,"dislike":0,"score":0,"quote":{"pid":"df7447ccc8522738ed4847b84492ef485af0b0a1","tid":1775143,"uid":71085,"like":0,"dislike":0,"score"