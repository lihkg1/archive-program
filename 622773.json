F2018%2F04%2F10%2F194228_6a6c53ad5c1c246369975d774e581583.JPG&h=c48bf8a3&s={SIZE}\" /><br />\n/<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/194250_f74dccaafc9ac6cb7df8fc28872b566c.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F194250_f74dccaafc9ac6cb7df8fc28872b566c.JPG&h=326b26a6&s={SIZE}\" /><br />\n<br />\n<br />\n行完之後, 約咗一個巴打食飯<br />\n先去寶華路搵出名的陳添記魚皮<br />\n條街好多人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/194522_4f8d853a0a22b0a14b12b7824c64a573.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F194522_4f8d853a0a22b0a14b12b7824c64a573.jpg&h=0ac262dc&s={SIZE}\" /><br />\n<br />\n好多人排隊<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/202421_1bda1f257b85595d83ef4402722ff3f8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F202421_1bda1f257b85595d83ef4402722ff3f8.jpg&h=5c642552&s={SIZE}\" /><br />\n/<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/202544_5c38e075fc9952bee87b3e95be7c0abd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F202544_5c38e075fc9952bee87b3e95be7c0abd.jpg&h=726d148c&s={SIZE}\" /><br />\n/<br />\n有D鼓油+麻油, 幾香, 魚皮好爽<br />\n值得一試<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/202605_ae6c0c57660760a84e5139591a43d8e8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F202605_ae6c0c57660760a84e5139591a43d8e8.jpg&h=c582c57d&s={SIZE}\" />"},{"pid":"b943b2ad16b7367a43f6c0d19158ab83c7845f6f","tid":622773,"uid":53254,"like":4,"dislike":5,"score":-1,"citedBy":1,"replyTime":"2018-04-10T12:30:30.000Z","msg":"寧願去離島"},{"pid":"26f5833b7152a76ccaa4c3b9da482559d85e47e8","tid":622773,"uid":78571,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-04-10T12:40:46.000Z","msg":"跟住上咗廣州賓館, 個fd 親戚話個度頂樓間酒樓出名<br />\n但去到發覺間野唔同咗<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n無野落肚, 不過收獲一張羊城日落<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/203126_e08dc635d6b561e20dc03b31d5440fab.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F203126_e08dc635d6b561e20dc03b31d5440fab.JPG&h=021f83b1&s={SIZE}\" /><br />\n<br />\n最後去咗北京路某商場食酸菜魚<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/203601_1264f55c736e1cecd8da5ecb532592d6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F203601_1264f55c736e1cecd8da5ecb532592d6.jpg&h=6a3b3443&s={SIZE}\" /><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/203309_6138404d5c725b62a4bbead0ce4be102.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F203309_6138404d5c725b62a4bbead0ce4be102.jpg&h=91166347&s={SIZE}\" /><br />\n<br />\n無記錯好似係98 人仔<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/203412_bf6164142ee056802f6acc3238e460c0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F203412_bf6164142ee056802f6acc3238e460c0.jpg&h=b4293445&s={SIZE}\" /><br />\n<br />\n食完飯, 尋找廣州夜生活---太古倉 <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/203639_8a958a0f5883d28109b4ad522952af8b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F10%2F203639_8a958a0f5883d28109b4ad522952af8b.jpg&h=a0141191&s={SIZE}\" /><br />\n/<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/10/203706_d8b07fd4c4d9dca9a907f7d2