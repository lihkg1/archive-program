il?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F11%2F203556_2b0b584f3eaf45ec81b1fea30b481c49.JPG&h=5a56afe9&s={SIZE}\" /><br />\n/<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/11/203604_d054143d7a52b02d6d7d55cc49839b8e.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F11%2F203604_d054143d7a52b02d6d7d55cc49839b8e.JPG&h=7f28c5fa&s={SIZE}\" /><br />\n/<br />\n南信, 好撚多人<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/11/203912_b934f9a2098cc36e3cd1d40d3ab18510.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F11%2F203912_b934f9a2098cc36e3cd1d40d3ab18510.JPG&h=810f00c2&s={SIZE}\" /><br />\n<br />\n<br />\n食雙皮奶, $14, 唔夠香, 無咩奶味<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/11/203646_4545ec1a4e6d5935d6e1a53eea4e0c96.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F11%2F203646_4545ec1a4e6d5935d6e1a53eea4e0c96.jpg&h=0fb39cc8&s={SIZE}\" /><br />\n<br />\n雲吞面, 好重鷄粉味, 面唔夠爽<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/11/203710_8465980e61ec6c0663f0144d853a5141.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F11%2F203710_8465980e61ec6c0663f0144d853a5141.jpg&h=9e07bd97&s={SIZE}\" />"},{"pid":"19d3d5f2d77f554f7d57923734e609ead3bdabd9","tid":622773,"uid":78571,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d634638c9c55f448b3336f88c3b867517961f17","tid":622773,"uid":91068,"like":0,"dislike":0,"score":0,"quote":{"pid":"817f104ca09fec0b9c8e2afa0a7004ed69d13bf5","tid":622773,"uid":78571,"like":0,"dislike":0,"score":0,"quote":{"pid":"104cddb1291666ab865d0f1707fcbe1def8f4886","tid":622773,"uid":91068,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-10T13:30:17.000Z","msg":"同你差唔多去左武漢hea左4日"},"citedBy":1,"replyTime":"2018-04-10T13:49:17.000Z","msg":"武漢有咩玩<