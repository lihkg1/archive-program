{"tid":1195011,"cid":1,"subCid":0,"title":"［捷徑］金鐘海富卡死，入政總天橋逼爆，點入政總，路線提供","createTime":"2019-06-09T13:29:17.000Z","updateTime":"2019-06-09T13:42:48.000Z","uid":234337,"like":6,"dislike":0,"uniUserReply":2,"replies":[{"pid":"9e88341ca7654330ab469ca43af744274959fb0e","tid":1195011,"uid":234337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-09T13:29:17.000Z","msg":"<img src=\"https://na.cx/i/ytoUBv1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FytoUBv1.jpg&h=687452f1&s={SIZE}\" /><br />\n天橋有個位右邊有扶手提落地下，天橋段路入政總塞爆，我搵到有條路係天橋轉右入金鐘停車場公園，落樓梯唔係扶手梯，沿左手邊直行轉左上天橋，過對面行車線左轉屈返入政總，歡迎補充<br />\n<br />\n簡單嚟講，啲人係邊岀嚟，你就係邊入去<br />\n<br />\n<img src=\"https://na.cx/i/ZZ5sb51.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZZ5sb51.jpg&h=80ce835c&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/nVWnLq2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnVWnLq2.jpg&h=5560ecd8&s={SIZE}\" />"},{"pid":"3b9b709022f82217c2df3805f7c1df072cc16d56","tid":1195011,"uid":234337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-09T13:40:37.000Z","msg":"push"},{"pid":"cb7bc0144469c8ed0e381f689c3e718a850e9ac8","tid":1195011,"uid":234337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-09T13:40:47.000Z","msg":"pish"},{"pid":"52604bf0ae69b010b0bc2d6768dea28376504f3c","tid":1195011,"uid":214830,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-09T13:42:48.000Z","msg":"help push"}]}