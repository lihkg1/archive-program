ets/faces/lm2lny/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2lny/yipes.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2lny/yipes.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-01T16:57:00.000Z","msg":"molamola"},{"pid":"069566cf8d7371491a531877f04e2389a53f05db","tid":1856573,"uid":106,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-01T16:57:14.000Z","msg":"嘩 屌 唔撚係掛<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"42a14da6b1338085d7a2fcac0a749e1e2d5b6d2c","tid":1856573,"uid":29093,"like":23,"dislike":1,"score":22,"citedBy":0,"replyTime":"2020-02-01T16:58:17.000Z","msg":"19日咳嗽未必係中左既<br />\n<br />\n可能係20 號搭郵輪  輪上有蝗蟈人惹到就真 <br />\n因為佢19 日咳嗽， 即係抵抗力下降， 就喺郵輪上傳染<br />\n<br />\n20日碼頭中左都唔出奇"},{"pid":"f54ff4e1e64e9371052c8ca61d1b917d9860f764","tid":1856573,"uid":4964,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-02-01T16:58:41.000Z","msg":"亞洲區嘅郵輪航線好撚多中國人"},{"pid":"57015c92bb17f2afb039596b1078bd59e0de59d3","tid":1856573,"uid":30868,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2020-02-01T16:58:58.000Z","msg":"今次實社區大爆發， 玩撚完"},{"pid":"5c87a0f96eadc37e3b9fc6d43bd40af850e8c49d","tid":1856573,"uid":24660,"like":22,"dislike":0,"score":22,"quote":{"pid":"ad233584678582a0c873a17b6e6195f73a64dec8","tid":1856573,"uid":49316,"like":4,"dislike":0,"score":4,"quote":{"pid":"e4e6ff0f965f4f4db5d251ea87e7e51a5e5b9b7c","tid":1856573,"uid":161374,"like":85,"dislike":1,"score":84,"citedBy":2,"replyTime":"2020-02-01T16:50:36.000Z","msg":"咁其實船上有中國人都唔定<br />\n船都幾危險"},"citedBy":1,"replyTime":"2020-02-01T16:56:25.000Z","msg":"十九才子之前唔係坐郵輪<img src=\"/assets/faces/lny/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2020-02-01T16:59:17.000Z","msg":"<img src=\"/assets/faces/lny/shocking.gif\" class=\"hkgmoji\" /><br />\n<br />\n上郵輪之前，要做功課，了解乘客成份。「鑽石公主」號以日本中產為主，西洋客若干，香港遊客少量，見此Profiling，可知文明指數有保障，噪音在可控範圍，放下心頭大石。<br />\n<br />\n東京去鹿兒島，航程竟要兩日。船上食物，由日本供應，牛肉豚肉都勝過歐洲航線。一出公海，網絡訊號消失，武肺的訊息，連同那許多呼天搶地的恐慌喧嘩，通通都不見了。<br />\n<br />\n見不到，聽不見，不就等同不存在了嗎？「鑽石公主」號在暮色中航行。沒有手提電話，原來日子是如此的潔淨太平、寧靜美好。<br />\n<br />\n<a href=\"https://hk.lifestyle.appledaily.com/lifestyle/columnist/%E9%99%B6%E5%82%91/daily/article/20200123/20848552/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.lifestyle.appledaily.com%2Flifestyle%2Fcolumnist%2F%25E9%2599%25B6%25E5%2582%2591%2Fdaily%2Farticle%2F20200123%2F20848552%2F&d=ANzGKs6Ysw%2B%2BKy1wioRXtzk5r7V16zLonem%2BWgH46Yg%3D&h=9941b31e\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.lifestyle.appledaily.com%2Flifestyle%2Fcolumnist%2F%25E9%2599%25B6%25E5%2582%2591%2Fdaily%2Farticle%2F20200123%2F20848552%2F&h=81724d1f\" target=\"_blank\">https://hk.lifestyle.appledaily.com/lifestyle/columnist/%E9%99%B6%E5%82%91/daily/article/20200123/20848552/</a>"},{"pid":"74bb8e4fe5fdfae4b30f2a57be78a30b815106ee","tid":1856573,"uid":273218,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2020-02-01T16:59:20.000Z","msg":"唔封關，根本追查唔到源頭<br />\n已經本地爆左2，3單無差別"},{"pid":"6ad36df17e601eb91373e2e4912cd3956733dba7","tid":1856573,"uid":63154,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-02-01T16:59:47.000Z","msg":"假設佢10號中招，19號先咳，30號先發燒？要成20日？應該冇咁耐掛"},{"pid":"fb3ad801714c63a67688d6a8642f41b37496db28","tid":1856573,"uid":261913,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-01T16:59:50.000Z","msg":"19<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"75744614cc3c21b242f8ee6c16a1a312b79ad002","tid":1856573,"uid":248299,"like":0,"dislike":0,"score":0,"quote":{"pid":"6ad36df17e601eb91373e2e4912cd3956733dba7","tid":1856573,"uid":63154,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-02-01T16:59:47.000Z","msg":"假設佢10號中招，19號先咳，30號先發燒？要成20日？應該冇咁耐掛"},"citedBy":1,"replyTime":"2020-02-01T17:00:04.000Z","msg":"應該係郵輪中招"},{"pid":"54753ed354c7cab0f22f1987f21769e5f986d655","tid":1856573,"uid":82640,"like":0,"dislike":0,"score":0,"ci