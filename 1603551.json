-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fecxir6c.jpg&h=16d5f71e&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-09-29T17:10:18.000Z","msg":"屌同步<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-29T17:10:57.000Z","msg":"大家都想進步<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"21ed3e7db3ba818f0d396bf247b397d5af9ce827","tid":1603551,"uid":247905,"like":0,"dislike":0,"score":0,"quote":{"pid":"a0adeb905b95c6da26d47423311295f5e73e828f","tid":1603551,"uid":39796,"like":0,"dislike":0,"score":0,"quote":{"pid":"466f626be2f4a1335bc80c765d47f6e09a7ea8f4","tid":1603551,"uid":294,"like":1,"dislike":0,"score":1,"quote":{"pid":"caea1792ad9f790b6952a3809401dac3d6306393","tid":1603551,"uid":39796,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-29T17:10:08.000Z","msg":"再升級<br />\n<br />\n<img src=\"https://na.cx/i/ecxir6c.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fecxir6c.jpg&h=16d5f71e&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-09-29T17:10:18.000Z","msg":"屌同步<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-29T17:10:57.000Z","msg":"大家都想進步<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-29T17:11:56.000Z","msg":"只要有樽，人人都可以係火魔法師"},{"pid":"bdd3ab31690f145d4d0fba20a46188aeb889b18f","tid":1603551,"uid":13586,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T17:13:20.000Z","msg":"仲有一樣！資訊流通呀！<br />\n<br />\n由be water，到Hit and run，到而家獅鳥召喚，最後原來都仲停留喺<span style=\"color: gold;\"><strong>走走走，見人走我就走，full gear都走</strong></span>，後面半gear同和理非嚇到雞飛狗走都唔知咩事，搞到走散哂，前線好易缺人！<br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\"><br />\n要退眼望前<br />\n不說走走走，試說急步行<br />\n不說跑呀衝緊埋黎，試說一二一二<br />\n</span></span></strong><br />\n<br />\n<br />\n<br />\n<br />\n仲有！<br />\n<span style=\"font-size: large;\"><strong>邊度嗰邊！防暴便衣定速龍！數量！</strong></span><br />\n咁模糊嘅資訊好難叫大家部署，然後又係一味走<br />\n<strong><span style=\"color: gold;\">我要時地人一句過！<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /></span></strong><br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>不說嗰邊有狗，試說鵝頸橋五十防暴<br />\n不說呢邊有狗，試說海富橋四十速龍</strong></span></span><br />\n<br />\n<br />\n<br />\n<br />\n仲有明明好多時我哋人多佢哋人少，係10：1嗰隻<br />\n都係一味叫走<br />\n<strong><span style=\"color: gold;\">都冇人獅鳥冇人踢波<br />\n十月一號仲點樣賀佢老母呀，得把口</span></strong><br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">不說有狗走呀，試說有冇人踢波</span></strong></span>"},{"pid":"908410ed1463704202f2ac1c03c374355743b615","tid":1603551,"uid":273886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T17:13:58.000Z","msg":"push"},{"pid":"e4b84692b823f0bdac8209477f8fa90faf021a45","tid":1603551,"uid":84147,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-29T17:14:56.000Z","msg":"<a href=\"https://lihkg.com/thread/1603520/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1603520/page/1</a><br />\n(神獸上裝) 10月1日1人1支燒烤叉燒野食!!!!"},{"pid":"2ce7b9ab67f5593d25d7447c9b932cc9c34d57ce","tid":1603551,"uid":142249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T17:15:09.000Z","msg":"推！"},{"pid":"2cf76f3bf86b4bd85f69dc925c33966df00779c9","tid":1603551,"uid":123274,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-29T17:15:31.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"487e54e686c50997ba3dac2179b54988cc355cd3","tid":1603551,"uid":247905,"like":0,"dislike":0,"score":0,"quote":{"pid":"e4b84692b823f0bdac8209477f8fa90faf021a45","tid":1603551,"uid":84147,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-29T17:14:56.000Z","msg":"<a href=\"https://lihkg.com/thread/1603520/page/1\" data-au