2/oh.gif\" class=\"hkgmoji\" />"},{"pid":"8d0baa4547d04a44c551aa9a2e3d4060caae210b","tid":1960471,"uid":2837,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-04-06T08:54:18.000Z","msg":"個女俾人殺咗 記得揾建制派"},{"pid":"5c1472a90987d9a0bfcfb2fcd99f339d11301f78","tid":1960471,"uid":81052,"like":0,"dislike":0,"score":0,"quote":{"pid":"14554f005de5f3f58692d49e627c32fe104cd007","tid":1960471,"uid":183515,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-04-06T08:38:30.000Z","msg":"湯文亮：「純粹虛構！」"},"citedBy":0,"replyTime":"2020-04-06T08:56:04.000Z","msg":"一陣又有人聽佢講中伏<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ea7ef117656123560417ca1e4d61564d05eebf76","tid":1960471,"uid":49609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T08:57:50.000Z","msg":"我BNO洗閪揾班保皇垃圾<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"cee7d5fc92268466dc274ddce19e7c37691766eb","tid":1960471,"uid":17232,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-04-06T09:02:25.000Z","msg":"Ceciliabb蘇麗珊：就算他自己在海外有事，都會要求泛民幫手，老闆問那位客人是什麼顏色，答案竟然是深藍，無他嘅，識時務者為俊傑。"},{"pid":"1d6fc981e28a0f46d539b1a973bdf7ea5c95c3eb","tid":1960471,"uid":54371,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:05:15.000Z","msg":"成功需姐幹"},{"pid":"acd94400e3ac4bf074f9a72e0ad42ce3959371ab","tid":1960471,"uid":141668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:16:08.000Z","msg":"搵保皇黨幫手最終撻Q，湯文亮為此解畫：「純粹虛構故事。」<img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" />"},{"pid":"c60145a21c31ef685071942b10e7e1d53dcdd805","tid":1960471,"uid":6297,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:18:20.000Z","msg":"以上情節純粹虛構"},{"pid":"9110234d44b64e9d8389dc9187879316bf138fca","tid":1960471,"uid":4728,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:19:10.000Z","msg":"此回覆已被刪除"},{"pid":"25e170a156d7533fe268c836f14854518b646048","tid":1960471,"uid":997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:20:33.000Z","msg":"呢個係咪又虛構???"},{"pid":"88f6791c13dfd5bcf54a592f8b8b1cd92556caa9","tid":1960471,"uid":241804,"like":0,"dislike":0,"score":0,"quote":{"pid":"bb05a0b96875b6a97239fedf255bd3df0e78a23e","tid":1960471,"uid":167289,"like":0,"dislike":3,"score":-3,"quote":{"pid":"cfa977eddbdba5e1c76fd6541ebe2ee0068fbe0b","tid":1960471,"uid":241804,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-04-06T08:11:19.000Z","msg":"我親戚係藍都話依條友on9無藥醫<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-06T08:21:47.000Z","msg":"湯係偏黃<br />\n深藍親戚就梗係咁講啦"},"citedBy":0,"replyTime":"2020-04-06T09:22:33.000Z","msg":"但係條友講野好似買兩邊玩大包圍咁，兩邊都唔討好"},{"pid":"e6d1a2bbe16af86ac77d0f58ae393f0cd5ffb2dc","tid":1960471,"uid":309001,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:23:59.000Z","msg":"OKAY<br />\n係外國有事<br />\n唔好搵中國領事館<br />\n去英國領事館<br />\n<br />\n<img src=\"/assets/faces/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"827a32d54c8bf02f008dda46f87ac5580f32afc3","tid":1960471,"uid":266635,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:26:12.000Z","msg":"零分，叫佢重作啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1c4216e18a454683a96cb6684b147521a15bdecd","tid":1960471,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:28:08.000Z","msg":"<img src=\"https://i.postimg.cc/MG16r8dt/1200.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.postimg.cc%2FMG16r8dt%2F1200.jpg&h=e6b49c32&s={SIZE}\" />"},{"pid":"c672707a05af24401bf98822b0ec8e01ab74890f","tid":1960471,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:28:26.000Z","msg":"<img src=\"https://whatsnew2day.b-cdn.net/wp-content/uploads/2020/03/Passengers-burst-into-applause-when-British-Airways-repatriation-flight-from.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwhatsnew2day.b-cdn.net%2Fwp-content%2Fuploads%2F2020%2F03%2FPassengers-burst-into-applause-when-British-Airways-repatriation-flight-from.jpg&h=c3b7184f&s={SIZE}\" /><br />\n<br />\n我是BNO。<br />\n<br />\n今次秘魯能成功回港，感謝英國政府。<br />\n<br />\n本人同太太去秘魯旅行，不幸遇上武漢肺炎，四周一片混亂。雖然我們趕上機場，不幸我們所乘坐的中國航空取消了航班。<br />\n<br />\n我們感到傍徨無助，因為身上乾糧不多，可能斷水斷糧。<br />\n<br />\n一個小時後，手機竟收到英國大使館短訊，所有英國國民，包括BNO，可在候機大堂集合，英國政府已派專機接走國民。<br />\n<br />\n五個小時後我已成功登上英國航空，上機時只作了登記，到現在還未收我機票錢，我地是第一批離開利馬的人。<br />\n<br />\n我知道其他國家包括支那及香港遊客都走不了，因為利馬機場得一條跑道，優先給了英國航空、維珍航空等<br />\n<br />\n此時此刻特別想說，作為英國人，就算是爛船都有三斤釘的BNO也好，特別特別的幸福！<br />\n<br />\n在此希望滞溜在秘魯遊客大家平安，順利撤出。<br />\n<br />\nDanny<br />\n31/3/2020<br />\n<br />\n<strong><span style=\"color: red;\">[以上是支那潮文改編, 純粹虛構。]</span></strong>"},{"pid":"a8cf3b202871d9f83854a999ade47640b857e6eb","tid":1960471,"uid":19693,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:29:43.000Z","msg":"佢個滙豐friend呢"},{"pid":"b7ae18ca8f75656853d9bdf03ff3681561ffd0ee","tid":1960471,"uid":219340,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-06T09:36:03.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />湯文亮<img src=\"https://na.cx/i/orqLdtb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2ForqLdtb.jpg&h=d16f916e&s={SIZE}\" />"},{"pid":"14ce4bdd776524ad8804d7c4d6509dddbee3753f","tid":1960471,"uid":39777,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-06T09:37:34.000Z","msg":"海外最緊要係有BNO呀<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"fe4175f3d5645fe2e5ea3669bf74b22461a05016","tid":1960471,"uid":271516,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-06T09:37:47.000Z","msg":"<img src=\"https://static01-proxy.hket.com/res/