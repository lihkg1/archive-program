ji\" />"},{"pid":"5a43cb444312738053cbb47d9e60449018755192","tid":2315694,"uid":3223,"like":30,"dislike":0,"score":30,"citedBy":0,"replyTime":"2020-12-07T11:04:36.000Z","msg":"你嗰個係正確<br />\n<br />\n佢嗰個係免責<br />\n<br />\n就係咁on9<br />\n<br />\n<br />\n<br />\n<br />\n新式就一次解決晒，但政府就係死都唔肯換快啲"},{"pid":"17baf17eebcd1941e795467c14c5870c13939e67","tid":2315694,"uid":124382,"like":0,"dislike":17,"score":-17,"citedBy":1,"replyTime":"2020-12-07T11:07:47.000Z","msg":"我都係外圈L, 因為係立於不敗之地。"},{"pid":"6bbddcf8487b71038624e67e74db0f1621a901b2","tid":2315694,"uid":51349,"like":9,"dislike":0,"score":9,"quote":{"pid":"3ced20c8d4327df0973beb542b573d5269aac7d6","tid":2315694,"uid":260328,"like":0,"dislike":0,"score":0,"quote":{"pid":"a133e3601e54c53a64de5489286238d009e1cc8e","tid":2315694,"uid":15811,"like":13,"dislike":0,"score":13,"citedBy":1,"replyTime":"2020-12-07T11:03:07.000Z","msg":"新式都咁行法你個「朋友」就賠撚死囉<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-07T11:04:04.000Z","msg":"舊式點行？<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-07T11:12:07.000Z","msg":"舊式咪你朋友咁講冇錯,新式你外圈 下個路口就一定要出,根本冇得你選擇<br />\n如果好大個種回旋處(3個出口以上),<br />\n我係第二個出口出都係行外線,3個或以上就行內線<br />\n<br />\n講就會被人屌自私,<br />\n現實係你過完第一個出口之後 好多車唔讓/車流量好大<br />\n你先CUT返外線 好多時都唔會有2秒安全距離,咁咪撞,撞左咪你錯"},{"pid":"e1967ee5a444ea8bd56e53d2176dac4839f9cfbc","tid":2315694,"uid":4519,"like":17,"dislike":0,"score":17,"citedBy":1,"replyTime":"2020-12-07T11:15:38.000Z","msg":"舊式永世外圈立於不敗之地<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n內圈幾正確都好，上到庭都係你輸"},{"pid":"18391824852360c894a95faa7b7287340363abfb","tid":2315694,"uid":116696,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2020-12-07T11:20:39.000Z","msg":"睇咩環境塞車一定做外圈撚如果唔係都幾難出到去<br />\n正常情況除左第一個出口出之外其他一律行內圈<br />\n臨出前cut返出外圈再走"},{"pid":"bf6c0f73813cc7fdee5261c613ed70ced0db6e46","tid":2315694,"uid":60412,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-07T11:58:23.000Z","msg":"舊式行外圈<br />\n新式咪跟新式"},{"pid":"8efee3f477d5ca513c8d5c226212ea2671b91f10","tid":2315694,"uid":119408,"like":11,"dislike":1,"score":10,"citedBy":0,"replyTime":"2020-12-07T13:21:27.000Z","msg":"睇返呢份運輸署指引<br />\n<a href=\"https://www.td.gov.hk/tc/road_safety/road_users_code/index/chapter_5_for_all_drivers/roundabouts_/index.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.td.gov.hk%2Ftc%2Froad_safety%2Froad_users_code%2Findex%2Fchapter_5_for_all_drivers%2Froundabouts_%2Findex.html&d=MiI%2Ba6G9rqdq%2F0stJtUYTg1nSF4GOVyTVdrqrZ1TEh8%3D&h=c4ecea7b\" target=\"_blank\">https://www.td.gov.hk/tc/road_safety/road_users_code/index/chapter_5_for_all_drivers/roundabouts_/index.html</a><br />\n舊式外圈贏哂<br />\n新式唔係<br />\n<br />\n轉左先打左燈<br />\n一定要左線入<br />\n新舊式都係外圈入 外圈出唔使cut線<br />\n喺9點鐘方向離開<br />\n<br />\n直行嘅話唔使打燈<br />\n左右線入都得<br />\n左線入就外圈入外圈出<br />\n舊式全程唔使cut線 新式喺9點鐘方向冇出繼續向前嗰下當cut線 要讓內線9點鐘方向想出嘅車(傳統外圈撚蝕底嘅地方)<br />\n右線入就先cut入內圈 <br />\n最後到12點鐘方向離開嗰陣<br />\n舊式要cut出外圈離開<br />\n新式係正線 唔使cut (傳統外圈撚蝕底嘅地方)<br />\n<br />\n轉右/掉頭嘅話先打右燈<br />\n一定要右線入<br />\n都係要先cut入內圈 最後到3點鐘或者6點鐘方向嘅時候舊式要cut出外圈 新式係正線唔使cut (傳統外圈撚蝕底嘅地方)<br />\n<br />\n理論上大家都跟規矩行嘅效率係最高<br />\n不過舊式迴旋處數量仲係主導嘅時候(新式只佔4%)<br />\n守唔守呢個規矩就變咗囚徒困境<br />\n因為舊式外圈撚離開時唔使cut線永遠唔蝕 好多直行 右轉 掉頭嘅人都揀行外圈嘅話 外圈多咗車嘅話<br />\n守規矩行內圈嘅人更加難出<br />\n兼且cut線一方 一撞就理虧<br />\n外圈撚增加 會令迴旋處生態變差<br />\n陷入令外圈撚更加有藉口唔行內圈嘅惡性循環<br />\n<br />\n樓主係有道理<br />\n但樓主朋友喺舊式迴旋處的確係立於不敗之地嘅做法<br />\n雖然唔太道德但的確精明<br />\n<br />\n將迴旋處由舊式變新式的確可以遏止外圈撚<br />\n<a href=\"https://www.td.gov.hk/filemanager/en/content_182/rs_bulletin_30.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.td.gov.hk%2Ffilemanager%2Fen%2Fcontent_182%2Frs_bulletin_30.pdf&d=MiI%2Ba6G9rqdq%2F0stJtUYTg1nSF4GOVyTVdrqrZ1TEh8%3D&h=5b272f49\" target=\"_blank\">https://www.td.gov.hk/filemanager/en/content_182/rs_bulletin_30.pdf</a><br />\n不過一改嗰下就會瘋狂撞車<br />\n睇下香港運輸系統承唔承受到呢d陣痛<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"364fc1af4a814cc38d65b95ca9f5219d6016ac2d","tid":2315694,"uid":25727,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2020-12-07T13:32:00.000Z","msg":"塞車：淨係睇一條線容易啲入&rarr;行外圈<br />\n冇車：秉承如非超車靠左行原則&rarr;行外圈<br />\n撞車：舊式迴旋處外圈有絕對優先權&rarr;行外圈<br />\n<br />\n總結 永世行外圈<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"50128800973f67a278e100b9b8348310eaedfd0d","tid":2315694,"uid":36981,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-07T13:34:00.000Z","msg":"算 <br />\n迴旋處睇得準<br />\n行乜線都無問題<br />\n行外圈距離同轉彎幅度會多/大左"},{"pid":"2d31b9aa8e94808380414151ab4888f547e7041f","tid":2315694,"uid":196924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-07T13:34:43.000Z","msg":"其實法庭就只會同你睇地下條線, 邊個cut線邊個輸<br />\n新式外圈撚要cut線先可以一直行外圈<br />\n舊式外圈唔洗cut線就可以輸晒成個圈出任何出口，必勝<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c1fb0d8f377da5120cfa179a58275fa2e7cdb609","tid":2315694,"uid":38405,"like":11,"dislike":0,"score":11,"citedBy":1,"replyTime":"2020-12-07T13:39:48.000Z","msg":"內圈出唔到咪兜多個圈囉<br />\n行多個圈慘過殺咗佢咁<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><br />\n<br />\n香港地渣車真係on撚鳩，<br />\n慢線有鬼<br />\n快線有金執<br />\n<br />\n入迴旋處就架架排慢線，一入到去就長係外圈等出口。<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><br />\n結果迴旋處就塞埋呢啲無謂原因，真係on9<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d0267630a03dbd6241360fa776dc5a6d3c6243b6","tid":2315694,"uid":194482,"like":4,"dislike":0,"score":4,"quote":{"pid":"c1fb0d8f377da5120cfa179a58275fa2e