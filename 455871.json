service-hk.net%2Fupload%2F2017%2F11%2F04%2F192912_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=dec0740e&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2017/11/04/193006_234c50d755a7bdf4dd5b45bf9ebe228a.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F04%2F193006_234c50d755a7bdf4dd5b45bf9ebe228a.jpeg&h=64956a0f&s={SIZE}\" /><br />\n我傻定你傻？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n算撚數啦變哂色</blockquote><br />\n你鍾意啦<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> 你啲泥咪一樣變度屎咁既色<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /></blockquote><br />\n屌你老母邊有人會信你<br />\n搵柒人識你邊有人會信up乜鳩<br />\n張相懷疑做過手腳既<br />\n屌你老母肉眼見咁色影撚返出黎好似有罪<br />\n用你假色王死黑富士昆鳩自己啦<br />\n唔好撚執相添呀富士執相變柒色呀屌你老母</blockquote><br />\n個個用富士/對索尼無咩好感既老母都要比你屌幾下感你精力都幾旺盛喔師兄<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> 你又知我影果陣d色唔系感<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 同埋我張圖只係想證明死黑係技術問題唔係機問題好無<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 你都係繼續做索尼死忠啦到到都見到你<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 你有你唯愛索尼無人阻你<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 但好心唔好死周圍貶低其他牌子黎抬高索尼<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 感樣搞到人仲反感<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 索尼真係多得你唔少啦有個感倒米法既槍手<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"250aa69bcebf2a1c95636a17a1bac017c2b8b661","tid":455871,"uid":71341,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2017-11-04T16:08:17.000Z","msg":"此回覆已被刪除"},{"pid":"c863eee42fb656cb3403e79418600e6f088963ef","tid":455871,"uid":36157,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2017-11-04T16:10:57.000Z","msg":"<blockquote><br />\n個個用富士/對索尼無咩好感既老母都要比你屌幾下感你精力都幾旺盛喔師兄<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> 你又知我影果陣d色唔系感<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 同埋我張圖只係想證明死黑係技術問題唔係機問題好無<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 你都係繼續做索尼死忠啦到到都見到你<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 你有你唯愛索尼無人阻你<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 但好心唔好死周圍貶低其他牌子黎抬高索尼<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 感樣搞到人仲反感<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 索尼真係多得你唔少啦有個感倒米法既槍手<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<br />\n巴打好有心, 不過你洗乜同個廢人咁認真,反正我見到SONY班阿叔就係D咁嘅人, &quot;總之你唔用SONY, 你一世都只會係廢人, 點都唔夠佢地影得靚&quot; (對住堆女相係度打飛機).<br />\n<br />\n(班叔父又係講唔岩佢聽/唔用SONY冇學識嘅影相仔=冇女影嘅毒L就淨係識屌)<br />\n<br />\n佢只係其中一個鍾意出位而聲稱又大把女排住隊等佢影嘅阿叔.<br />\n<br />\n<br />\n你都唔係咁嘅人, 又何必要同佢地比較?<br />\n到有一日你都變成咁果日先再比都未遲啦."},{"pid":"957f58f26be0dc8c74977a71a029897f4e23eb7c","tid":455871,"uid":104387,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-04T16:18:15.000Z","msg":"貓蛇有冇係河口位見到紅咀鷗<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"b2debde3fcbc0bb12ea798e6ee8bd1cd024ce219","tid":455871,"uid":67042,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-11-04T16:30:39.000Z","msg":"以為買機送技術的on9 8bit 大師<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <br />\n我屌撚埋你老豆呀七頭廢老<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"d13cc87408f378ef399780ddd52bb2cecf6ea044","tid":455871,"uid":71341,"like":0,"dislike":5,"score":-5,"citedBy":0,"replyTime":"2017-11-04T17:55:44.000Z","msg":"此回覆已被刪除"},{"pid":"9e394faac44020b06d94114fc141b944189e949a","tid":455871,"uid":71341,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2017-11-04T18:12:52.000Z","msg":"此回覆已被刪除"},{"pid":"1dfe987fbad165d51abc5dd7c2d94681f055901b","tid":455871,"uid":71341,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2017-11-05T07:22:13.000Z","msg":"此回覆已被刪除"},{"pid":"0a8b68b4935b68a03c74fe3780eb2820c36a8e16","tid":455871,"uid":67042,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2017-11-05T08:58:47.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/11/05/165607_980bd78fe5f95b121b1466e7644e40a5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F05%2F165607_980bd78fe5f95b121b1466e7644e40a5.jpg&h=fb7e1b88&s={SIZE}\" /><br />\n<br />\n8bit高清無乜detail <br />\n<img src=\"/assets/faces/lomoji/07.png\" class=\"hkgmoji\" /> <br />\n大師即係中師<br />\n即時cap張LM 學野<br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/11/05/165713_d2dc4ced9db05b15474d073f475592b6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F05%2F165713_d2dc4ced9db05b15474d073f475592b6.jpg&h=0a15a5b9&s={SIZE}\" /><br />\n<br />\nManu定manual 定Menu<br />\n拋書包都要讀下書<br />\n咪做何君妖之流<br />\n<br />\n不過大師喎，Manu又點<br />\n學野大聲夾幾句粗口咪一樣一聲<br />\n我屌你老豆<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"/assets/faces/lomoji/11.png\" class=\"hkgmoji\" />"},{"pid":"ceb95fa6dbf628a380222dc01f4d0336fa26afb6","tid":455871,"uid":117044,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-11-05T09:02:47.000Z","msg":"此回覆已被刪除"},{"pid":"24502aaf60c7454222f4d2c5d225427fad907ec8","tid":455871,"uid":71341,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2017-11-05T09:29:05.000Z","msg":"此回覆已被刪除"},{"pid":"07ef1a9a50002e135948bebcd86a715a4c69439c","tid":455871,"uid":67042,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-11-05T09:36:10.000Z","msg":"<blockquote><blockquote><img src=\"https://img.eservice-hk.net/upload/2017/11/05/165607_980bd78fe5f95b121b1466e7644e40a5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F05%2F165607_980bd78fe5f95b121b1466e7644e40a5.jpg&h=fb7e1b88&s={SIZE}\" /><br />\n<br />\n8bit高清無乜detail <br />\n<img src=\"/assets/faces/lomoji/07.png\" class=\"hkgmoji\" /> <br />\n大師即係中師<br />\n即時cap張LM 學野<br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/11/05/165713_d2dc4ced9db05b15474d073f475592b6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F05%2F165713_d2dc4ced9db05b15474d073f475592b6.jpg&h=0a15a5b9&s={SIZE}\" /><br />\n<br />\nManu定manual 定Menu<br />\n拋書包都要讀下書<br />\n咪做何君妖之流<br />\n<br />\n不過大師喎，Manu又點<br />\n學野大聲夾幾句粗口咪一樣一聲<br />\n我屌你老豆<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"/assets/faces/lomoji/11.png\" class=\"hkgmoji\" /></blockquote><br />\n屌極老母仍然笑而不語重要繼續笑鳩人<br />\n果然天下第一高手<br />\n富士假狗色崇拜者確然不同</blockquote><br />\n講撚左十萬次我用Sony 啦on9 狗"},{"pid":"ab415ff8bfb57348c5326585a3b15f46c064a24a","tid":455871,"uid":71341,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-11-05T09:37:13.000Z","msg":"此回覆已被刪除"},{"pid":"c9f0371fbad50face6ee61392cfa795b5bd9bb14","tid":455871,"uid":67042,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-11-05T09:39:59.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/11/05/173726_41aedb91c3550cdb89d7bdcc48b2c88e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F05%2F173726_41aedb91c3550cdb89d7bdcc48b2c88e.jpg&h=3ffbd7d8&s={SIZE}\" /><br />\n<br />\n每樣器材都有最靚既點都有最差既點<br />\n<br />\n不過可以將一套器材最差既地方影晒出黎究竟係喵既玩法<img src=\"/assets/faces/lomoji/17.png\" class=\"hkgmoji\" /> <br />\n<br />\n要cap低lm等大師指點下<img src=\"/assets/faces/lomoji/13.png\" class=\"hkgmoji\" /> <br />\n<br />\n大師大師<br />\n除左屌老母，麻煩解釋下啦<img src=\"/assets/faces/lomoji/14.png\" class=\"hkgmoji\" />"},{"pid":"e1993c73f9c53694744767f3a729d20fc9514737","tid":455871,"uid":67042,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-11-05T09:41:19.000Z","msg":"<blockquote><blockquote><img src=\"https://img.eservice-hk.net/upload/2017/11/05/165607_980bd78fe5f95b121b1466e7644e40a5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F05%2F165607_980bd78fe5f95b121b1466e7644e40a5.jpg&h=fb7e1b88&s={SIZE}\" /><br />\n<br />\n8bit高清無乜detail <br />\n<img src=\"/assets/faces/lomoji/07.png\" class=\"hkgmoji\" /> <br />\n大師即係中師<br />\n即時cap張LM 學野<br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/11/05/165713_d2dc4ced9db05b15474d073f475592b6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F05%2F165713_d2dc4ced9db05b15474d073f475592b6.jpg&h=0a15a5b9&s={SIZE}\" /><br />\n<br />\nManu定manual 定Menu<br />\n拋書包都要讀下書<br />\n咪做何君妖之流<br />\n<br />\n不過大師喎，Manu又點<br />\n學野大聲夾幾句粗口咪一樣一聲<br />\n我屌你老豆<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"/assets/faces/lomoji/11.png\" class=\"hkgmoji\" /></blockquote><br />\n最撚好笑俾人屌老母仍然笑而不語<br />\n繼續冇相出假狗色死黑相都冇<br />\n用部富士抹noise機話人冇detail又一絕</blockquote><br />\n<br />\n收皮啦8bit怪<br />\n我最差部7s都11+7bit啦<br />\n用部14bit a9學人玩8bit直出，出撚到一pat屎咁<br />\n<br />\n8bit 狗<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"0c017d005462cd597b2f6a3de37aac30deae23f4","tid":455871,"uid":67042,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-11-05T09:44:52.000Z","msg":"<blockquote><blockquote><img src=\"https://img.eservice-hk.net/upload/2017/11/05/165607_980bd78fe5f95b121b1466e7644e40a5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F05%2F165607_980bd78fe5f95b121b1466e7644e40a5.jpg&h=fb7e1b88&s={SIZE}\" /><br />\n<br />\n8bit高清無乜detail <br />\n<img src=\"/assets/faces/lomoji/07.png\" class=\"hkgmoji