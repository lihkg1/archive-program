uf.daum.net/original/245CE93C55A8D0250EF684\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcfile248.uf.daum.net%2Foriginal%2F245CE93C55A8D0250EF684&h=525e66c5&s={SIZE}\" /></div><br />\n<br />\n<br />\n<div style=\"text-align: center;\"><img src=\"http://cfile269.uf.daum.net/original/2628FF4654AAA6A734B2D2\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcfile269.uf.daum.net%2Foriginal%2F2628FF4654AAA6A734B2D2&h=95c897b0&s={SIZE}\" /></div><br />\n<br />\n<br />\n<div style=\"text-align: center;\"><img src=\"https://gfriendofficial.jp/common/images/top/main.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fgfriendofficial.jp%2Fcommon%2Fimages%2Ftop%2Fmain.jpg&h=ee9110aa&s={SIZE}\" /></div><br />\n<br />\n<br />\n<div style=\"text-align: center;\">GFRIEND（여자친구）是Source Music於2015年推出的韓國六人女子音樂組合，<br />\n<br />\n成員包括Sowon、Yerin、Eunha、Yuju、SinB和Umji。</div><br />\n<br />\n <br />\n<br />\n<div style=\"text-align: center;\">2014年10月30日，Source Music公開將於11月推出6人女團。<br />\n<br />\n同日，官網介紹4位成員: Sowon、Yerin、SinB、Umji。<br />\n<br />\nGFRIEND出道延遲至2015年。<br />\n<br />\n2015年1月5日，Source Music通過官網公布GFRIEND出道日，<br />\n<br />\n並公開成員Eunha和Yuju。11日後的1月16日正式出道。<br />\n<br />\n2016年1月25日，公布粉絲名稱為Buddy(Buddies)。<br />\n<br />\n2017年3月15日，公開官方應援棒為「GLASS MARBLE STICK」。<br />\n<br />\n2017年7月16日第一次舉行香港迷你演唱會。<br />\n<br />\n2018年4月26日，公開官方應援色為「PANTONE 11-4201 Cloud Dancer」、<br />\n<br />\n「PANTONE 16-4725 Scuba Blue」和「PANTONE 18-3838 Ultra Violet」。</div><br />\n<br />\n<br />\n<div style=\"text-align: center;\"><img src=\"http://cfile294.uf.daum.net/original/996527335AE08D2C05453C\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcfile294.uf.daum.net%2Foriginal%2F996527335AE08D2C05453C&h=2f479d16&s={SIZE}\" /></div><br />\n<br />\n <br />\n<br />\n<div style=\"text-align: center;\"><img src=\"https://33.media.tumblr.com/d7e1467bf3074848431efd344b9327ba/tumblr_nmxh6dJZXF1ro5y21o1_500.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2F33.media.tumblr.com%2Fd7e1467bf3074848431efd344b9327ba%2Ftumblr_nmxh6dJZXF1ro5y21o1_500.gif&h=ce619b54&s={SIZE}\" /></div><br />\n<br />\n<br />\n<div style=\"text-align: center;\"><a href=\"https://www.youtube.com/watch?v=cFCjpyA_AdM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DcFCjpyA_AdM&d=p%2FQ8YAx%2B9tWhUHJpvOtT89tKgwQIhJBw7VlnLihElrQ%3D&h=c6860390\" target=\"_blank\">https://www.youtube.com/watch?v=cFCjpyA_AdM</a><br />\n<br />\n170716 GFRIEND 여자친구1st Mini Concert in Hong Kong 香港應援影片 </div><br />\n<br />\n<br />\n<div style=\"text-align: center;\"><span style=\"color: navy;\"><span style=\"font-size: x-large;\"><strong>你和我，畢地與女朋友</strong></span></span><img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> </div>"},{"pid":"e728fd45c0cc508e247b49a030b660a2c318734f","tid":663880,"uid":7837,"like":0,"dislike":13,"score":-13,"citedBy":1,"replyTime":"2018-05-13T15:54:00.000Z","msg":"Lm"},{"pid":"2b502c1316f9b5fd74fa9163a4fe987f781811de","tid":663880,"uid":75538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-13T15:54:14.000Z","msg":"#2.1<br />\n<br />\n <br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\"><strong>成員資料：</strong></span></span><br />\n<br />\n<br />\n<span style=\"font-size: large;\"><strong>So Won</strong></span><br />\n<br />\n<br />\n<img src=\"http://cfile261.uf.daum.net/original/99DCB84D5AE1EC620F3483\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcfile261.uf.daum.net%2Foriginal%2F99DCB84D5AE1EC620F3483&h=965cf3e6&s={SIZE}\" /><br />\n<br />\n<img src=\"http://cfile297.uf.daum.net/original/99632C3359A6D10835EA50\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcfile297.uf.daum.net%2Foriginal%2F99632C3359A6D10835EA50&h=9b09e67a&s={SIZE}\" /><br />\n<br />\n<img src=\"http://cfile280.uf.daum.net/original/275D3E335978A958137EEE\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcfile2