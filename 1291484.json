2,"like":0,"dislike":0,"score":0,"quote":{"pid":"a42f8c071f80626ad7be2207cfe4c95528d0051f","tid":1291484,"uid":8722,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-07-09T19:00:10.000Z","msg":"如果真係無人要 我可以要"},"citedBy":1,"replyTime":"2019-07-10T02:53:46.000Z","msg":"你有冇養開龜?"},"citedBy":3,"replyTime":"2019-07-10T05:12:30.000Z","msg":"有啊<img src=\"https://na.cx/i/VC0cMdN.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVC0cMdN.png&h=7c6e8bd2&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-07-10T06:05:34.000Z","msg":"好得意<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"4f3f1ca4484a1e38e33d43bf6914958e929e6bb0","tid":1291484,"uid":35620,"like":1,"dislike":0,"score":1,"quote":{"pid":"803ff3eecfcd702619bd7390307ac406a9386587","tid":1291484,"uid":204591,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-07-07T10:42:57.000Z","msg":"盾臂龜黎 好乖架 唔會咬人 如果fb冇人認返（龜真係好難走失<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />） 真心希望樓主照顧佢<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 佢要大隻至少5年 屋企清理下空位 比佢周屋爬都養得到架  因為有好多仆街 唔識養又扲去養/扲去賣 <br />\n<br />\n你扲隻龜返去 證明你好有愛心 要養佢地唔算難架 （當然起初，糧食+設備要哂1千蚊度 ）<br />\n佢食素的<br />\n去街市買菜心比佢食住先<br />\n因為菜心最易買<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />  食得既有桑葉，蕃薯葉之類<br />\n記住大部分菜，葉都唔食得 eg油墨菜，西芹，通菜<br />\n<br />\n你搵個盆比佢住先（屋有陽光入 就比個個位佢曬）+搵另一個盆比佢浸下暖水 水位去到過過佢隻腳 目的比佢飲下水/幫佢呵屎，尿（白色，一舊舊都係 稱為尿酸）浸3-4個字換一次水 浸2-3次就可以<br />\n<br />\n利申：養緊 屋企都細 但清空雜物夠養到佢 養佢地每日搞半個鐘就得<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />知識既量算好多下 但實際要做既野好少"},"citedBy":0,"replyTime":"2019-07-10T06:05:48.000Z","msg":"油麥菜係食得"},{"pid":"c7fe2b2f42b553a1420653f7bc3f41914f723284","tid":1291484,"uid":237542,"like":0,"dislike":0,"score":0,"quote":{"pid":"0d372980129d05293b3284816a5b2d36fad0851f","tid":1291484,"uid":256316,"like":0,"dislike":0,"sco