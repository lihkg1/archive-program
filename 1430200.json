/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n唔係會唔夠人！！<br />\n<br />\n<img src=\"https://na.cx/i/hmQcRzv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhmQcRzv.jpg&h=7f5efe94&s={SIZE}\" /><img src=\"https://na.cx/i/s8rvDew.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fs8rvDew.jpg&h=671c6067&s={SIZE}\" /><img src=\"https://na.cx/i/RAYFf1c.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRAYFf1c.jpg&h=d7384709&s={SIZE}\" />"},{"pid":"3d3714bcee350374bb1777d4f47b60d7b7fc276f","tid":1430200,"uid":124113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T16:41:04.000Z","msg":"push"},{"pid":"424a5e75fa4c278372de262e9cab80770c13b3e1","tid":1430200,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T17:29:59.000Z","msg":"支持<br />\npush<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"822d141772765584e597a75728fb5959a8932f16","tid":1430200,"uid":1806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T17:34:56.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"410a339b2351d8dbb76f10d2b87deac9c5bea9d9","tid":1430200,"uid":54181,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T18:40:25.000Z","msg":"此回覆已被刪除"},{"pid":"e151d9e6abff7035fbab37cd379c894c9ad036eb","tid":1430200,"uid":233614,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T18:57:34.000Z","msg":"Done"},{"pid":"d3040e80bb39482788e79b6b577370d9e54584a3","tid":1430200,"uid":291233,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T19:35:01.000Z","msg":"Done"},{"pid":"e49ccf5859193ff7802cde65fe59e233ffbb5c9e","tid":1430200,"uid":265354,"like":0,"dislike":0