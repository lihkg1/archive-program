ces/cat/sneeze.gif\" class=\"hkgmoji\" />"},{"pid":"e5ed601b3ddcaef431b095ab27ee966c2ee5d066","tid":1857123,"uid":243437,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T07:42:41.000Z","msg":"推<img src=\"/assets/faces/mouse/solution.gif\" class=\"hkgmoji\" />"},{"pid":"1dd01ad99fe49be949a59144780e1ad54d12d997","tid":1857123,"uid":83060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T07:55:01.000Z","msg":"香港今日搞成咁<br />\n係因為半年前有人將五大訴求中嘅林鄭下台<br />\n偷偷改咗做要求真普選<br />\n<br />\n理由係林鄭弱勢容易妥協<br />\n二來係林鄭乞人憎令港人團結<br />\n<br />\n<br />\n<br />\n當日我多次响兩登指出呢個陰謀<br />\n話要求真普選可以同任何一個人傾<br />\n因為邊個做特首有無普選都係習近平話事<br />\n所以應該要林鄭下台找咗修例條數先<br />\n再者你有真普選訴求可以加上去<br />\n變六大訴求或七大訴求<br />\n而唔係加一減一<br />\n刪咗人地嘅林鄭下台訴求<br />\n<br />\n同時我指出作為反對派一定樂於同弱勢特首交手<br />\n所以泛民一定會全力保住林鄭做到任期<br />\n<br />\n結果就係而家咁<br />\n<br />\n<br />\n泛民唔會承認<br />\n左膠唔會承認<br />\n當日有份同我理論嘅人都唔會承認<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"2e3d70dea69e8569f7a7c405f4021f39beb4e155","tid":1857123,"uid":172192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T11:21:02.000Z","msg":"9/10"},{"pid":"d459392f2243eeb400e81c7c61818526b3b25008","tid":1857123,"uid":196701,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-02T11:35:46.000Z","msg":"口號嚟㗎啫"},{"pid":"827a091c8e015790bf013968fe49137d7f28c5cd","tid":1857123,"uid":172192,"like":0,"dislike":0,"score":0,"quote":{"pid":"d459392f2243eeb400e81c7c61818526b3b25008","tid":1857123,"uid":196701,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-02T11:35:46.000Z","msg":"口號嚟㗎啫"},"citedBy":0,"replyTime":"2020-02-02T11:37:36.000Z","msg":"<img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" />"},{"pid":"c98abc15f790fc3612997e5205d38f22f4696088","tid":1857123,"uid":172192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-02T15:16:56.000Z","msg":"10/10 完<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b1b42ccab28e2bf9ab53e6262d5ae6871b86c52