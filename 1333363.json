 src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"c0a36ac8b0d9aca2d31b9d05637327cc3a8e5ef0","tid":1333363,"uid":36157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:50:47.000Z","msg":"<strong><span style=\"font-size: x-large;\">傀儡派</span></strong>"},{"pid":"9b020a4be242499406b89bb00dc9a3cc4dc0c140","tid":1333363,"uid":36157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:50:57.000Z","msg":"<strong><span style=\"font-size: x-large;\">傀儡派</span></strong>"},{"pid":"5a93b0dfdff8f16e228ca5b0248d2ffa2c689025","tid":1333363,"uid":240534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:51:15.000Z","msg":"推"},{"pid":"e9c18dd54caf075b936eb894b9ddfda5933662cb","tid":1333363,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:51:42.000Z","msg":"推到泛民見到"},{"pid":"416c8e06e947a2dc907d344b8274a3fcccc6557b","tid":1333363,"uid":14941,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-20T03:52:35.000Z","msg":"不如叫有錢派<br />\n<br />\n有錢派vs 無錢派"},{"pid":"82d2b1268cab415f6be65d858467f7dc8e37e5cf","tid":1333363,"uid":49812,"like":0,"dislike":4,"score":-4,"quote":{"pid":"e845f4f2b748b516d7821757581652efd2fefd2b","tid":1333363,"uid":54303,"like":18,"dislike":0,"score":18,"citedBy":1,"replyTime":"2019-07-19T16:10:49.000Z","msg":"咁改口對於而家局勢有冇幫助？有！<br />\n改稱「權貴派」可以：<br />\n1. 減弱敵方政治動員能力<br />\n2. 增加我方正當性<br />\n3. 鼓勵一般市民去連儂牆吸收訊息 有利遍地開花"},"citedBy":0,"replyTime":"2019-07-20T03:53:43.000Z","msg":"我就話「欠制派」算啦，班土共貪得就貪，根本欠缺自制（貪錢）能力、市儈冷血、得個講字"},{"pid":"257992488982fedf8e970a91bc1748c3f6595783","tid":1333363,"uid":28252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:53:51.000Z","msg":"支持"},{"pid":"b6506f36b5ced4c459778434839b3cdc0cfd58c2","tid":1333363,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:55:01.000Z","msg":"推"},{"pid":"ea63c45feb2914597ea8477ebb5eb382b056d899","tid":1333363,"uid":36157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:55:42.000Z","msg":"<strong>傀儡派<br />\n<br />\n傀儡派議員<br />\n偽政府</strong>"},{"pid":"29c4f1c9deb660b929fbd6eb38010188e75a4e66","tid":1333363,"uid":8301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:55:44.000Z","msg":"不嬲叫奶共狗"},{"pid":"56a0017d99834aa0b517c83c35096c096e831e1c","tid":1333363,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:57:07.000Z","msg":"分化藍絲人人有責<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"50a0c9cb5293764dd389b7b42d0e2f347d9dae6f","tid":1333363,"uid":268537,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:57:31.000Z","msg":"推"},{"pid":"5d8c489f7bf65a5ec2eb5e5164744c8783b83117","tid":1333363,"uid":75664,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:57:59.000Z","msg":"721 我無野講<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6738987f965de5b335053b50b424bfd909cfcb74","tid":1333363,"uid":79085,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T03:59:48.000Z","msg":"港共呀"},{"pid":"19ea634239653da065414505bb386cc628571e4f","tid":1333363,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T04:01:46.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"21561206d58aca81e46617edfef7bff984ce27bb","tid":1333363,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-20T04:13:25.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\nbtw各位手足去沙田行下街啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ee39b77617dda1e03293f7af18bdaa02bc4effcf","tid":1333363,"uid":284195,"like":0,"dislike":0,"score":0,"quote":{"pid":"21561206d58aca81e46617edfef7bff984ce27bb","tid":1333363,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-20T04:13:25.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\nbtw各位手足去沙田行下街啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-20T04:15:01.000Z","msg":"叫賣國派"},{"pid":"9ef9e8758a6030f4e46b3d9f28006c8ad486759e","tid":1333363,"uid":284195,"like":0,"dislike":0,"score":0,"quote":{"pid":"a64ef34a06fa7e33a61c12906b74292febbdec0d","tid":1333363,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-19T16:05:55.000Z","msg":"點評時下局勢<br />\n<a href=\"https://lih.kg/1332538\" data-auto-link target=\"_blank\">https://lih.kg/1332538</a><br />\n- 分享自 LIHKG 討論區<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n受呢位巴打既post啟發<br />\n佢成篇文都好高質 <br />\n有一點我覺得尤其重要而值得特別講<br />\n就係要幫「權貴派」正名<br />\n<br />\n<br />\n拿 自由黨唔洗講啦<br />\n民建聯扮到好關心民生 <br />\n實際上咪又係利益輸送既仆街<br />\n成日支持起大白象 同以各種名目攞政府funding<br />\n其實蛇齋餅糭比起佢地貪番黎既錢<br />\n簡直係微不足道<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n叫佢地做「權貴派」有咩好處呢？<br />\n第一係分化 我地要令民建聯果班窮撚支持者猶豫<br />\n覺得自己冇被充分代表<br />\n第二係政治啟蒙 因為當市民接受左呢個名 就自自然然會想知民建聯點樣「親權貴」<br />\n慢慢就會知道有幾多賣港議案通過左<br />\n第三 我地改口無成本架！<br />\n而當我地日日講 選舉講 不停講<br />\n佢地「權貴派」要花好多資源去做形象工程<br />\n（咁當然非權貴派都要努力宣傳同做地區工作啦）<br />\n<br />\n<br />\n大家一齊講<br />\n屌你老母奶共權貴派！唔要送中！立即普選！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-20T04:17:18.000Z","msg":"叫「賣港派」，「極權派」，「西環派」"},{"pid":"27a26dd10ef10e22bac899b1818d893d080fbb13","tid":1333363,"uid":51023,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-20T04:19:31.000Z","msg":"721"},{"pid":"9e5a