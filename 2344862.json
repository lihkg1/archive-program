islike":1,"score":-1,"quote":{"pid":"7ef843e46f10579c0fe9deb959bfe7eaaac80600","tid":2344862,"uid":77717,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-12-29T06:01:27.000Z","msg":"黃店？"},"citedBy":1,"replyTime":"2020-12-29T06:17:16.000Z","msg":"唔知 但值得支持"},"citedBy":1,"replyTime":"2020-12-29T10:29:38.000Z","msg":"佢講到明自己唔識政治<br />\n之前hocc去佢都唔知乜水<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n亦冇趕佢走"}]}