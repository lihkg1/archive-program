f54a2e34b5e8ab2e6934625f0a8ee82c","tid":1715524,"uid":198113,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-11-13T06:21:14.000Z","msg":"Fake news 拉"},{"pid":"359498edc3be3e78fdc8530f39c48ddafabfaa51","tid":1715524,"uid":300814,"like":0,"dislike":0,"score":0,"quote":{"pid":"01e1a8e6f54a2e34b5e8ab2e6934625f0a8ee82c","tid":1715524,"uid":198113,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2019-11-13T06:21:14.000Z","msg":"Fake news 拉"},"citedBy":0,"replyTime":"2019-11-13T06:22:08.000Z","msg":"你自己睇下nowtv"},{"pid":"95943df69790261b3a142cf14b51b8fa3e9ae770","tid":1715524,"uid":156767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T06:23:11.000Z","msg":"教育局特別宣布（二）<br />\n＊＊＊＊＊＊＊＊＊＊<br />\n  因應當前及可預計的交通狀況，以及全港學校的整體匯報，全港學校（包括幼稚園、小學、中學及特殊學校）將於明日（十一月十四日）停課，以策安全。<br />\n<br />\n  教育局發言人今日（十一月十三日）表示，局方一直以學生的安全及福祉為首要考慮。在停課期間，各學校必須保持校舍開放，並安排教職員在安全情況下回校照顧學生，如果家長有需要送子女返回學校，可繼續送子女返校，並在途中注意安全，以及與學校保持溝通。<br />\n<br />\n  發言人續說，社會連日受到暴力示威者廣泛破壞，除製造危險的路面情況外，更有保姆車遭受惡意破壞，亦有學校遭受不同程度的威嚇，情況令人齒冷。教育局強烈譴責此等故意危害學童安全、剝奪學生學習基本權利的行為。<br />\n<br />\n  教育局強烈呼籲示威者立即停止所有暴力行為，盡快令社會回復秩序，讓學童安全上學。對於有教師工會不但不譴責暴力示威者，甚至將責任只推卸給警方，教育局認為有關言論實在有違教育工作者應有的專業態度。<br />\n<br />\n  教育局再次呼籲，學童留在家中，不要在街上流連，遠離危險，更切勿參加違法活動。<br />\n<br />\n  教育局會繼續跟進明日及往後的最新發展，適時為學校提供進一步指引及支援。局方再次感謝所有緊守崗位的教育工作者。<br />\n <br />\n完<br />\n2019年11月13日（星期三）<br />\n香港時間14時10分"},{"pid":"30b8a3b59db125fb087130a3d2377c54310a4161","tid":1715524,"uid":306664,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T06:24:58.000Z","msg":"借個位<br />\n<a href=\"https://www.kaercher.com/hk-zh/home-garden/mobile-cleaning/oc-3-gb-16800050.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.kaercher.com%2Fhk-zh%2Fhome-garden%2Fmobile-cleaning%2Foc-3-gb-16800050.html&d=lZ7jQHZQyV3jEURUmMbLaQsTF5hDypdTwPi8eTnvKzQ%3D&h=a432a5b2\" data-auto-link target=\"_blank\">https://www.kaercher.com/hk-zh/home-garden/mobile-cleaning/oc-3-gb-16800050.html</a><br />\n<img src=\"https://na.cx/i/6mUK7Ws.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6mUK7Ws.jpg&h=a00791c0&s={SIZE}\" /><br />\n<br />\n我知道大家鐘意用魔法裝修<br />\n<br />\n所以建議帶備以上工具以防玩大左<br />\n<br />\n利申  mon popo 狗千祈唔好對號入座  真係為左救火"},{"pid":"a78a03ac6a74af381ebc69f50437876060029a1f","tid":1715524,"uid":25424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T06:25:34.000Z","msg":"今次林鄭又中計<br />\n<br />\n既然明日停課，放學就上山幫中大守城<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}