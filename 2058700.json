ormal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"cb5824353b9ceefabef8b1d7df534dac5edec16e","tid":2058700,"uid":66965,"like":0,"dislike":0,"score":0,"quote":{"pid":"3ce487975290f7d1a2a36d7d7ee354f673547407","tid":2058700,"uid":289449,"like":1,"dislike":144,"score":-143,"citedBy":15,"replyTime":"2020-06-10T11:19:00.000Z","msg":"PHP 係server side , Node.js係client side。兩樣唔同既野黎，背後既programming logic同埋寫法都好唔同，所以兩者冇乜關係。不過香港老細係比較鍾情node.js多過php，所以都係自學nodejs啦"},"citedBy":0,"replyTime":"2020-06-11T13:16:23.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d31834ccb371136cd8c6475e32d34026947935ce","tid":2058700,"uid":89476,"like":0,"dislike":0,"score":0,"quote":{"pid":"993fe400bce11d9711594370bab3c9d647b64c8f","tid":2058700,"uid":125976,"like":6,"dislike":6,"score":0,"citedBy":2,"replyTime":"2020-06-11T02:02:44.000Z","msg":"識乜 language 根本唔係重點，重點係你用唔用得熟嗰套 language 同 framework 寫到啲勁嘢出嚟<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n連登都係用 php，Facebook 當年都係用 php<br />\n<br />\n如果唔介意 php syntax 核突，其實 Laravel 都寫到大嘢<br />\n<br />\nNode.js 反而冇乜完整 framework，好難做大嘢，吓吓都要自己砌，暫時睇落 Nest.js 最似 Java Spring。但其實 node.js 咁嘅零散特點反而做 Serverless 仲好<br />\n<br />\n至於你話 performance 問題，其實唔係一開始考慮嘅因素。RoR 一樣慢，但大把鬼頭嘢一樣 launch 到出街"},"citedBy":0,"replyTime":"2020-06-11T13:24:06.000Z","msg":"agger"},{"pid":"92c5cf61252e1e7bb5ed20dd90ba99a3db014f8b","tid":2058700,"uid":162421,"like":1,"dislike":1,"score":0,"quote":{"pid":"3ce487975290f7d1a2a36d7d7ee354f673547407","tid":2058700,"uid":289449,"like":1,"dislike":144,"score":-143,"citedBy":15,"replyTime":"2020-06-10T11:19:00.000Z","msg":"PHP 係server side , Node.js係client side。兩樣唔同既野黎，背後既programming logic同埋寫法都好唔同，所以兩者冇乜關係。不過香港老細係比較鍾情node.js多過php，所以都係自學nodejs啦"},"citedBy":0,"replyTime":"2020-06-11T13:36:41.000Z","msg":"走啦屌你<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}