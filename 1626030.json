3a292431db8c2e1","tid":1626030,"uid":155079,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T09:40:02.000Z","msg":"就好似鶳咁<br />\n一開頭就當然戰術上正確<br />\n<br />\n但去到現在, 班廢老都淆唒底<br />\n對住空手嘅其實玩用索帶綁手制服會好好多<br />\n琴晚拎斧頭嗰個就當然要教訓<br />\n<br />\n大家唔好比武力蒙蔽自己<br />\n要記住係「以武制暴」"},{"pid":"29d00b8e733d648763272d70e0d4d9e9121392dc","tid":1626030,"uid":129622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T09:41:01.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"3aacbec1e4ab3affcf5ab4558b77323ab2a34d64","tid":1626030,"uid":129622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T09:43:46.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"e1a92cf467d9e2ff91bc067521a9cb7ebb4aa236","tid":1626030,"uid":182802,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T09:44:39.000Z","msg":"推"},{"pid":"8295c201522617d9114818fab3a0efa5db22afff","tid":1626030,"uid":129622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T10:10:39.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"5b218f2cd606c8e09de12e95db64ebb1ffc2fdcb","tid":1626030,"uid":129622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T10:51:52.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"8f29ac8bf6cc8c7a82f08ae9ae19a6cbad266f7b","tid":1626030,"uid":129622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T11:00:30.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"989a276928cd103f29842a11e6adec3e1c980afb","tid":1626030,"uid":129622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:42:54.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"1f2707585bbc9821949682063bbb229b74fb7093","tid":1626030,"uid":129622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime"