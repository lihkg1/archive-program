/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"28bda59e1b65f637007e910d4104b0272948164d","tid":2274740,"uid":14983,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-07T02:16:48.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"805dd41d704211b41f45549babc47d7ad5192cb5","tid":2274740,"uid":17335,"like":0,"dislike":0,"score":0,"quote":{"pid":"bca6f7e39b492431c60a4133fdf154cfb0390f9c","tid":2274740,"uid":336932,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-06T18:34:45.000Z","msg":"Push"},"citedBy":0,"replyTime":"2020-11-07T05:39:17.000Z","msg":"Push push push<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"698cc1401f72a08390d821e147da596c227ea66c","tid":2274740,"uid":98795,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-07T07:28:00.000Z","msg":"留名，食完 tea慢慢睇<img src=\"/assets/faces/cat/mask.gif\" class=\"hkgmoji\" />"},{"pid":"1ba45abf5bc3fd4eeca4bdd12a3abb80abd5056e","tid":2274740,"uid":83874,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-08T20:53:13.000Z","msg":"如果有任何一個人，任何一本書，告訴你有一種固定的方法詮釋所有文學作品<br />\n<br />\n佢應該係九成無知，一成大你。<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"3e8f82eff9355e9feec2f4fff2097f3609a24ffa","tid":2274740,"uid":83874,"like":0,"dislike":0,"score":0,"quote":{"pid":"1ba45abf5bc3fd4eeca4bdd12a3abb80abd5056e","tid":2274740,"uid":83874,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-08T20:53:13.000Z","msg":"如果有任何一個人，任何一本書，告訴你有一種固定的方法詮釋所有文學作品<br />\n<br />\n佢應該係九成無知，一成大你。<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-08T20:55:18.000Z","msg":"但有九成人會被大到。<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"}]}