/faces/lm2/yo.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-16T07:30:11.000Z","msg":"我細個成日攪亂左21條同23條<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"83aa4f729d9ca1052f56aa78686a4ef5409083fd","tid":1974360,"uid":282118,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-04-16T07:33:33.000Z","msg":"神聖羅馬帝國同羅馬帝國係有關係"},{"pid":"f825e2ab6ebfb243cda5165dc3491686d31fb801","tid":1974360,"uid":70596,"like":0,"dislike":1,"score":-1,"quote":{"pid":"2259c8140a1e7a192537c82c6cbba8585388f2e4","tid":1974360,"uid":54344,"like":3,"dislike":0,"score":3,"quote":{"pid":"b4d801bfd9d3c983b8806fcc3300dc8961d20357","tid":1974360,"uid":130568,"like":1,"dislike":13,"score":-12,"quote":{"pid":"2377cf65b79d0e756d2484a95bfaf8bfe231bb2b","tid":1974360,"uid":54930,"like":5,"dislike":13,"score":-8,"citedBy":1,"replyTime":"2020-04-15T20:29:12.000Z","msg":"唔方便講"},"citedBy":1,"replyTime":"2020-04-15T20:31:43.000Z","msg":"合法野都唔方便講，定巴打你畀狗咬過？<br />\n太古廣場咪響金鐘站對面"},"citedBy":2,"replyTime":"2020-04-15T23:22:26.000Z","msg":"呢啲洗唔洗自貼身份證擺上黎同狗講啊on9 醒少少啦"},"citedBy":0,"replyTime":"2020-04-16T07:35:54.000Z","msg":"低能，合法遊行有乜驚？"},{"pid":"9c421e33b51a993802ab789f65c0eb7a58ea6552","tid":1974360,"uid":228143,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-16T07:38:38.000Z","msg":"岳飛唔係常勝軍  都好專制<br />\n德蘭修女係有錢女"},{"pid":"863fd3e5b78c311eda88b731127bca49be485053","tid":1974360,"uid":244876,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-16T07:38:43.000Z","msg":"<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />細個以為神聖羅馬帝國係一個國家<br />\n<br />\n拿破侖係矮仔<br />\n<br />\n中國有四大發明好把炮<br />\n<br />\n拜占庭同東羅馬係唔同國家<br />\n<br />\n百年戰爭打左8年<br />\n<br />\n<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3ccd5e791880acdef7bfd81df7431f7026563ffc","tid":1974360,"uid":244876,"like":0,"dislike":0,"score":0,"quote":{"pid":"4580bf2209994138c0e6120270014b99679724fa","tid":1974360,"uid":237962,"like":18,"dislike":4,"score":14,"citedBy":4,"replyTime":"2020-04-15T21:01:46.000Z","msg":"巴西首都唔係里約熱內盧，係巴西利亞<br />\n<br />\n土耳其首都唔係伊斯坦堡，係安卡拉<br />\n<br />\n澳洲首都唔係悉尼，係坎培拉<br />\n<br />\n美國首都唔係紐約，係華盛頓DC<br />\n<br />\n美國有兩個華盛頓，一個係DC，一個係華盛頓州<br />\n<br />\n八國聯軍嘅奧唔係奧地利，而係奧匈帝國<br />\n<br />\n都柏林唔關德國事<br />\n<br />\n原來希臘同土耳其係世仇（好似日韓咁）<br />\n<br />\n非洲同歐洲其實好近<br />\n<br />\n澳洲同紐西蘭並非歸納於亞洲而係大洋洲<br />\n<br />\n摩洛哥同摩納哥係兩個唔同嘅國家黎<br />\n<br />\n佛教原本唔係中國嘢而係印度嘢<br />\n<br />\n荷蘭正式唔叫Holland而係Netherland，Holland只係其中一個地區<br />\n<br />\n聖公會嘅誕生只係為左幫英王拋棄妻子娶後生靚女<br />\n<br />\n台灣嘅舊稱「福爾摩沙」係地球上其實有好多個<br />\n<br />\n台灣正式名稱中華民國英文係Republic of China，同中共國比只差一個People&rsquo;s<br />\n<br />\n元朝清朝其實唔係中國朝代，當初因為要建立民國維穩所以先「五族共和」依家就因為民族自卑感所以「被中國人」<br />\n<br />\n香港從開埠時間開始，如果用年齡黎計，係老過中共國同中華民國<br />\n<br />\n然後澳門開埠比香港早<br />\n<br />\n三國時期無大刀<br />\n<br />\n高順嘅陷陣營其實係以步兵為主<br />\n<br />\n北極無企鵝<br />\n<br />\n瑞士同瑞典無任何關係<br />\n<br />\n瑞士無加入歐盟<br />\n<br />\n挪威都無加入歐盟<br />\n<br />\n古代日本忍者主要負責情報收集、後方破壞、暗殺、綁架等等，面對面戰鬥並唔係佢地嘅工作<br />\n<br />\n古代日本有d流鶯會揹住蓆周圍去招攬恩客，成為「蓆女」，部份會係蓆上刺探軍情，其實係忍者嘅一種<br />\n<br />\n古代日本有d賣藥郎中會受各城主邀請入城治理受傷官兵，部份郎中會趁機刺探軍情，其實都係忍者嘅一種<br />\n<br />\npizza原本係貧民食品，因為無錢買碗碟所以將送菜直接擺係麵餅上面食<br />\n<br />\n義大利出名貪污<br />\n<br />\n係印度包住頭嘅男人其實係錫克教徒<br />\n<br />\nacg經常出現嘅所謂「妖刀」村正，係古時嘅日本其實係量產貨，因為本身平均質素高所以好多人都有用。會變成妖刀係因為德川家好多家族成員都死係村正之下，所以認為佢不詳。其實唔關事，只係因為太多人用+巧合<br />\n<br />\n滿清對戰英法聯軍時，其實裝備比對方精良<br />\n<br />\n霍元甲其實係垃圾<br />\n<br />\n被納粹屠殺嘅猶太人自發建國以色列，打仗基本上無輸過<br />\n<br />\n鴉片戰爭係現代中史課綱經常被形容為「揭開中國苦難嘅一頁」但實情係外國軍隊進入中國，中國民眾夾道歡迎，送食物送水，甚至幫手攻打紫禁城<br />\n<br />\n孫中山雖然被譽為「國父」但革命初期佢被滿清政府定性為罪犯、暴徒、恐怖份子、危害國家安全<br />\n<br />\n紀念五四運動時經常提到「德先生」同「賽先生」，但其實仲有另外兩位經常被人有意無意忽略，就係「莫姑娘」&mdash; moral 道德、同埋「費小姐」&mdash; freedom 自由"},"citedBy":0,"replyTime":"2020-04-16T07:40:57.000Z","msg":"以色列係中東戰爭係好唔簡單<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"f692f736d6663b1cb513a4d5e2ab0dc84062823e","tid":1974360,"uid":5919,"like":1,"dislike":0,"score":1,"quote":{"pid":"cdc976218870fd61276df9132a605899cba4b6f3","tid":1974360,"uid":228894,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-04-16T03:53:54.000Z","msg":"一直以為河南實里係地名黎.....<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-16T09:24:21.000Z","msg":"我都以為迪麗熱巴係球星<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"4580bf2209994138c0e6120270014b99679724fa","tid":1974360,"uid":237962,"like":18,"dislike":4,"score":14,"citedBy":4,"replyTime":"2020-04-15T21:01:46.000Z","msg":"巴西首都唔係里約熱內盧，係巴西利亞<br />\n<br />\n土耳其首都唔係伊斯坦堡，係安卡拉<br />\n<br />\n澳洲首都唔係悉尼，係坎培拉<br />\n<br />\n美國首都唔係紐約，係華盛頓DC<br />\n<br />\n美國有兩個華盛頓，一個係DC，一個係華盛頓州<br />\n<br />\n八國聯軍嘅奧唔係奧地利，而係奧匈帝國<br />\n<br />\n都柏林唔關德國事<br />\n<br />\n原來希臘同土耳其係世仇（好似日韓咁）<br />\n<br />\n非洲同歐洲其實好近<br />\n<br />\n澳洲同紐西蘭並非歸納於亞洲而係大洋洲<br />\n<br />\n摩洛哥同摩納哥係兩個唔同嘅國家黎<br />\n<br />\n佛教原本唔係中國嘢而係印度嘢<br />\n<br />\n荷蘭正式唔叫Holland而係Netherland，Holland只係其中一個地區<br />\n<br />\n聖公會嘅誕生只係為左幫英王拋棄妻子娶後生靚女<br />\n<br />\n台灣嘅舊稱「福爾摩沙」係地球上其實有好多個<br />\n<br />\n台灣正式名稱中華民國英文係Republic of China，同中共國比只差一個People&rsquo;s<br />\n<br />\n元朝清朝其實唔係中國朝代，當初因為要建立民國維穩所以先「五族共和」依家就因為民族自卑感所以「被中國人」<br />\n<br />\n香港從開埠時間開始，如果用年齡黎計，係老過中共國同中華民國<br />\n<br />\n然後澳門開埠比香港早<br />\n<br />\n三國時期無大刀<br />\n<br />\n高順嘅陷陣營其實係以步兵為主<br />\n<br />\n北極無企鵝<br />\n<br />\n瑞士同瑞典無任何關係<br />\n<br />\n瑞士無加入歐盟<br />\n<br />\n挪威都無加入歐盟<br />\n<br />\n古代日本忍者主要負責情報收集、後方破壞、暗殺、綁架等等，面對面戰鬥並唔係佢地嘅工作<br />\n<br />\n古代日本有d流鶯會揹住蓆周圍去招攬恩客，成為「蓆女」，部份會係蓆上刺探軍情，其實係忍者嘅一種<br />\n<br />\n古代日本有d賣藥郎中會受各城主邀請入城治理受傷官兵，部份郎中會趁機刺探軍情，其實都係忍者嘅一種<br />\n<br />\npizza原本係貧民食品，因為無錢買碗碟所以將送菜直接擺係麵餅上面食<br />\n<br />\n義大利出名貪污<br />\n<br />\n係印度包住頭嘅男人其實係錫克教徒<br />\n<br />\nacg經常出現嘅所謂「妖刀」村正，係古時嘅日本其實係量產貨，因為本身平均質素高所以好多人都有用。會變成妖刀係因為德川家好多家族成員都死係村正之下，所以認為佢不詳。其實唔關事，只係因為太多人用+巧合<br />\n<br />\n滿清對戰英法聯軍時，其實