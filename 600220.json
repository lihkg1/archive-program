/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"2cfa2e6fab16b4f5c5a9ff742b18016e47757142","tid":600220,"uid":77393,"like":1,"dislike":0,"score":1,"quote":{"pid":"88443562d19ab7ac769dc95f2d076c7664a354e5","tid":600220,"uid":110973,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-03-26T05:46:48.000Z","msg":"10無得輸 rpg個人育成<br />\n做將軍謀士主公咩都得<br />\n技能多到數唔哂 要專精哂都要慢慢儲經<br />\n戰鬥舌戰攻城戰各有特色<br />\n重有得娶老婆生囝<br />\n<br />\n會出重製版整靚啲畫面就正<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <br />\n<br />\n<span style=\"font-size: x-small;\">攻城有bug 用投石器玩撚哂</span>"},"citedBy":0,"replyTime":"2018-03-26T12:52:52.000Z","msg":"元戎弩兵配井欄冇得輸<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"76dc0562f35b205d2bd0806b5826541373b08234","tid":600220,"uid":60838,"like":0,"dislike":0,"score":0,"quote":{"pid":"11acfad79645b879a613c577ad1015b4b07a3fd3","tid":600220,"uid":37735,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2018-03-21T06:29:15.000Z","msg":"9 10 11 12 果隻幾抵玩<br />\n<br />\n如果你無咩玩過<br />\n<br />\n一隻理論上都玩到一個月<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-26T13:00:24.000Z","msg":"12是垃圾中嘅垃圾"},{"pid":"9db9c51bd50f8c472a0aa7fc1c6aa11afe963a4f","tid":600220,"uid":60838,"like":0,"dislike":0,"score":0,"quote":{"pid":"d08a4d4521c0ff4e8568ff5828a8af42023847d8","tid":600220,"uid":5502,"like":0,"dislike":0,"score":0,"quote":{"pid":"c85bcddcb38a36288250470cc3b65d38a6df3ff6","tid":600220,"uid":13466,"like":0,"dislike":0,"score":0,"quote":{"pid":"da3b73c1e19572d2b39738e6e2aed024d5ddba95","tid":600220,"uid":54684,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2018-03-21T09:04:41.000Z","msg":"建議可玩︰<br />\n<br />\n第7/8代   個人修練．育成．學技<br />\n第9代   口碑佳．勢力管理．陣法．異民族<br />\n第11代  建施起城外，日式町鎮feel唔合理，但連登仔至愛<br />\n<br />\n其餘可直接無視<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-21T09:21:34.000Z","msg":"其餘可以無視？<br />\n至少數漏第5代同第6代啦。<br />\n<br />\n第五代個陣法系統可謂歷代三國志中最有心思嘅系統，只係唔明點解之後無再出；<br />\n第六代個半即時戰略同單挑模式，我會話係歷代三國志中最正。<br />\n<br />\n如要將11代排次序（我由三國志4開始玩，所以1-3代評唔到），三國志六會係最好玩嘅一隻。"},"citedBy":2,"replyTime":"2018-03-21T09:25:41.000Z","msg":"5代bgm好正，過左咁多年仲記得"},"citedBy":0,"replyTime":"2018-03-26T13:01:55.000Z","msg":"早年無線劇都有用三國5 bgm, 唔知係俾左錢定偷"},{"pid":"a337ce69f83b59ae4430f9bb07b3c79b86dbb750","tid":600220,"uid":97465,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T13:07:19.000Z","msg":"11啦，缺點係AI有啲豬"},{"pid":"1988ff9abadb70255878f4955d6846f828a7ef08","tid":600220,"uid":24104,"like":0,"dislike":0,"score":0,"quote":{"pid":"a337ce69f83b59ae4430f9bb07b3c79b86dbb750","tid":600220,"uid":97465,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T13:07:19.000Z","msg":"11啦，缺點係AI有啲豬"},"citedBy":0,"replyTime":"2018-03-26T13:10:28.000Z","msg":"集集都係㗎啦"},{"pid":"670583dffe480ae9daabe372efaddbad5eff2a3e","tid":600220,"uid":162977,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T13:13:24.000Z","msg":"11啦，玩啲小勢力，殫精竭慮終於破到局果下好爽<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"1a6ce9901921fe1fbf39b3bc6b27206e2bfcdcd9","tid":600220,"uid":63113,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-26T13:30:28.000Z","msg":"三國志8/9呢兩代玩幾年都唔會厭<br />\n<br />\n8主打武將制 自由度有番咁上行 動可以去城門指令用行動力搶隔離縣啲糧油 <br />\n<br />\n靜可以匿埋自己結婚生仔 禁下城周圍行啲老人家細路撚化下佢地(試過盪失路問我幫唔幫，答no扣我民心)，周不時都會有應節對話，甚至江南打風，東北有瘟疫個城亦會有唔同境況你睇&hellip;<br />\n<br />\n至於9行君主制，正宗主打六國大封相。地圖一覽無遺之餘，啲武將兵法更加五花百門，武官攻城野戰有一套，文官隨軍出擊又有一套玩法。比人打可以用計謀暗算返轉頭，剩係玩外交，玩政治過安穩日子又一種玩法。用流言搞臭外族同敵對勢力等狗咬狗坐收漁人之利&hellip;又一種玩法，一句講哂，襟玩。"},{"pid":"393733abe7908efa244887ec705e893923e6169a","tid":600220,"uid":36995,"like":0,"dislike":0,"score":0,"quote":{"pid":"670583dffe480ae9daabe372efaddbad5eff2a3e","tid":600220,"uid":162977,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T13:13:24.000Z","msg":"11啦，玩啲小勢力，殫精竭慮終於破到局果下好爽<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-26T14:11:53.000Z","msg":"三國11有個AI問題<br />\n打到後期 多數係同孫堅/孫權 變到最強<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ec49a67bded5c9136a42871fea7b808f1e22d567","tid":600220,"uid":54684,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-26T14:12:58.000Z","msg":"樓主，唔好兩頭望喇<br />\n<br />\n個個巴打都有心頭好<br />\n<br />\n嗱，跟我話法<br />\n<br />\n開始玩 三國志9．威力加強版 啦<br />\n<br />\n你可以負評 三國志7, 8, 10<br />\n<br />\n但第9代，真係好難負評佢<br />\n<br />\n你唔會後悔<br />\n<br />\n<img src=\"http://i0.sinaimg.cn/gm/2011/0107/U1782P115DT20110107171541.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi0.sinaimg.cn%2Fgm%2F2011%2F0107%2FU1782P115DT20110107171541.jpg&h=b9e93264&s={SIZE}\" />"},{"pid":"d2799b494ecfa9d2eb04a5c706a3010ab7026ef5","tid":600220,"uid":162977,"like":0,"dislike":0,"score":0,"quote":{"pid":"393733abe7908efa244887ec705e893923e6169a","tid":600220,"uid":36995,"like":0,"dislike":0,"score":0,"quote":{"pid":"670583dffe480ae9daabe372efaddbad5eff2a3e","tid":600220,"uid":162977,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T13:13:24.000Z","msg":"11啦，玩啲小勢力，殫精竭慮終於破到局果下好爽<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-26T14:11:53.000Z","msg":"三國11有個AI問題<br />\n打到後期 多數係同孫堅/孫權 變到最強<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-26T14:33:45.000Z","msg":"Ching玩邊個劇本多？<br />\n好似話有啲角色做君主/都督會特別強勢，例如曹操同劉備咁，孫家可能係本身屬於強勢id，加上地理位置問題，有好多時間去發展<br />\n但都唔係永遠咁勁，好似251咁，孫堅成日被袁術拖死<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"4be8c58909783e97d6b95d513c6f0aedc2c72bfa","tid":600220,"uid":166054,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-26T14:51:21.000Z","msg":"我中一狂玩三國志9，嗰陣新出<br />\n今日我仲玩緊<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n所以最襟玩一定係9<br />\n<br />\n畫面嚟講一定係11打後，因為係3D，但最好玩嘅一定係9代或之前<br />\n<br />\n9係君主模式，只可以控制曹操，劉備、孫權、袁紹嗰啲，重嘅係戰略、謀略、外交、內政，而唔包武將嘅生活。9畫面係大地圖制，打仗係半即時戰略，佢係每10日下指令（內政+作戰），中間嘅10日過渡時間就係執行嘅時候，因為冇得即時控制作戰過程，有時體現到「將在外，君令有所不受」，幾真實。有唔同打仗戰法。單挑冇得控制武將。有外族，成日會打你煩你，幾真實。<br />\n<br />\n如果想玩武將模式，即係想玩埋關羽張飛諸葛亮夏侯惇嗰啲，就建議玩8，8係歷代三國志武將制嘅經典嘅一代，都好好玩。玩法同9好唔同，因為重武將個人成長，可以自己鍛練武力、智力、政治、魅力，練到幾勁都得。又可以不斷爭功績，一路由九品官升到一品官，同時一路升上去做太守、軍師、軍團長，權力愈來愈大，滿足感好大。8畫面係城市制，內政同打仗有各自畫面。冇外族，冇咗外患。係類似戰棋式，有唔同戰法，但節奏較慢，打一場仗起碼要20分鐘。單挑有得控制武將。<br />\n<br />\n利申：玩過6、7、8、9、10、11"},{"pid":"4606c1eaf48abef8563f94c938c9f471c12679f0","tid":600220,"uid":110973,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2799b494ecfa9d2eb04a5c706a3010ab7026ef5","tid":600220,"uid":162977,"like":0,"dislike":0,"score":0,"quote":{"pid":"393733abe7908efa244887ec705e893923e6169a","tid":600220,"uid":36995,"like":0,"dislike":0,"score":0,"quote":{"pid":"670583dffe480ae9daabe372efaddbad5eff2a3e","tid":600220,"uid":162977,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T13:13:24.000Z","msg":"11啦，玩啲小勢力，殫精竭慮終於破到局果下好爽<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-26T14:11:53.000Z","msg":"三國11有個AI問題<br />\n打到後期 多數係同孫堅/孫權 變到最強<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-26T14:33:45.000Z","msg":"Ching玩邊個劇本多？<br />\n好似話有啲角色做君主/都督會特別強勢，例如曹操同劉備咁，孫家可能係本身屬於強勢id，加上地理位置問題，有好多時間去發展<br />\n但都唔係永遠咁勁，好似251咁，孫堅成日被袁術拖死<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-26T14:54:40.000Z","msg":"Agger, 地理位置本身響隻驚呢個已經差唔多係最重要因素<br />\n順住個勢向一個方向發展勢力，基本上後期就贏梗"},{"pid":"2b26164f1b1289c255d20e49161c120fe26e06c7","tid":600220,"uid":11314,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-26T15:10:14.000Z","msg":"以前三國群英傳正d"},{"pid":"0a76faf41328d2cb5644f7c9d62e7b72baed54fa","tid":600220,"uid":12911,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T15:15:33.000Z","msg":"<blockquote><blockquote>三國志11仲有咩selling point</blockquote>11太多套路野<br />\n當你唔熟就會玩得好辛苦<br />\n一熟左隻game就好單調好冇癮<br />\n大陸果面係有好多人限自己唔準用套路 / 小技巧咁玩</blockquote><br />\n越城 封1條路 出少兵放火 多到數唔哂"},{"pid":"810d73b1d2b4f324e4fc68317f73ef832a0c1ff1","tid":600220,"uid":118379,"like":0,"dislike":0,"score":0,"quote":{"pid":"0a76faf41328d2cb5644f7c9d62e7b72baed54fa","tid":600220,"uid":12911,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T15:15:33.000Z","msg":"<blockquote><blockquote>三國志11仲有咩selling point</blockquote>11太多套路野<br />\n當你唔熟就會玩得好辛苦<br />\n一熟左隻game就好單調好冇癮<br />\n大陸果面係有好多人限自己唔準用套路 / 小技巧咁玩</blockquote><br />\n越城 封1條路 出少兵放火 多到數唔哂"},"citedBy":1,"replyTime":"2018-03-27T16:54:48.000Z","msg":"願聞其詳<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"db6e467ba109d8e88a3dda37177ceeed451eb686","tid":600220,"uid":63843,"like":2,"dislike":0,"score":2,"quote":{"pid":"810d73b1d2b4f324e4fc68317f73ef832a0c1ff1","tid":600220,"uid":118379,"like":0,"dislike":0,"score":0,"quote":{"pid":"0a76faf41328d2cb5644f7c9d62e7b72baed54fa","tid":600220,"uid":12911,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-26T15:15:33.000Z","msg":"<blockquote><blockquote>三國志11仲有咩selling point</blockquote>11太多套路野<br />\n當你唔熟就會玩得好辛苦<br />\n一熟左隻game就好單調好冇癮<br />\n大陸果面係有好多人限自己唔準用套路 / 小技巧咁玩</blockquote><br />\n越城 封1條路 出少兵放火 多到數唔哂"},"citedBy":1,"replyTime":"2018-03-27T16:54:48.000Z","msg":"願聞其詳<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-27T18:51:48.000Z","msg":"1兵單挑 放計謀 運輸 引兵<br />\n火計 火矢<br />\n門口暈人頂位<br />\n死守用戟兵尾刀捉哂對面全國人<br />\n論客打天下<br />\n封路逼AI行爛地<br />\n<br />\n基本上你係有無限種花式黎玩鳩AI<br />\n班AI淨係得資源全方面作弊 光榮咁多年都係整唔到好既AI<br />\n所以一係玩家自己食屎 一係逼AI食屎 冇中間<br />\n<br />\n同埋無論用咩人起手都好 中期目標都係係咁捉班一線武將<br />\n姐係話你去到後面用黎用去都係果班人"},{"pid":"bff085856b4cbb050f4ec63769c4ed066d3b496f","tid":600220,"uid":105552,"like":0,"dislike":0,"score":0,"quote":{"pid":"76dc0562f35b205d2bd0806b5826541373b08234","tid":600220,"uid":60838,"like":0,"dislike":0,"score":0,"quote":{"pid":"11acfad79645b879a613c577ad1015b4b07a3fd3","tid":600220,"uid":37735,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2018-03-21T06:29:15.000Z","msg":"9 10 11 12 果隻幾抵玩<br />\n<br />\n如果你無咩玩過<br />\n<br />\n一隻理論上都玩到一個月<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-26T13:00:24.000Z","msg":"12是垃圾中嘅垃圾"},"citedBy":1,"replyTime":"2018-03-27T23:15:09.000Z","msg":"12岩岩出個陣我以為係網頁遊戲<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n後尾玩PK版先叫做完整"}]}