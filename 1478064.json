":1478064,"uid":258999,"like":0,"dislike":0,"score":0,"quote":{"pid":"e218323d2fed734b9014e93eacba55c607013f79","tid":1478064,"uid":3775,"like":1,"dislike":0,"score":1,"quote":{"pid":"28cb2dc1d0a90c061ffe804664b9f6138ef3f645","tid":1478064,"uid":178332,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-08-16T11:11:36.000Z","msg":"人地小學學歷<br />\n佢又小學學歷<br />\n點解佢可以有文化咁多<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-16T11:21:22.000Z","msg":"因為識用人有個中文主任<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n賢明之舉"},"citedBy":0,"replyTime":"2019-08-16T11:24:52.000Z","msg":"唔係架，睇下佢平時d對答，有文膽都幫唔晒，佢d中文有d料到架。"},{"pid":"861bd4fd2e57836b09c3c2fe5dc9add8e3ec2e0a","tid":1478064,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T11:31:16.000Z","msg":"推"},{"pid":"bd79b62483b6cdfce1013966ccbc9e35c53a9033","tid":1478064,"uid":231408,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:54:20.000Z","msg":"推到我好似誠哥咁有錢"},{"pid":"a63529a2a14ed84a04938829e2014cb96a47ecbe","tid":1478064,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T15:58:32.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"80d9fcf0d1f0985b7ffa01798004ed4d17e86745","tid":1478064,"uid":277702,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-08-16T16:04:42.000Z","msg":"正一老而不，九廿幾歳人表達唔清唔楚但懶係有智慧，含意無寧兩可幾邊都可以各自表述。結果更加混亂呢啲老而不真係唔死都冇用<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"}]}