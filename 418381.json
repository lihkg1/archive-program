ass=\"hkgmoji\" /> <br />\n樓主坐左幾耐"},{"pid":"59c70319f3f7b3b9dca86b6fd17a731d6a53799f","tid":418381,"uid":22701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-29T13:50:34.000Z","msg":"重諗緊咩LV 七千幾咁平 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"21a22ed456c78478efb8f434e1e3f43d3604e929","tid":418381,"uid":3189,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-09-29T13:51:34.000Z","msg":"回帶<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"e95ec557383ae633b2907e9cc9f1c2675ed134b3","tid":418381,"uid":67786,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-29T15:21:55.000Z","msg":"<img src=\"/assets/faces/lomoji/36.png\" class=\"hkgmoji\" />"},{"pid":"8116299837dc05309016baa94d71500a76b4c6e4","tid":418381,"uid":13149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-30T02:49:51.000Z","msg":"考古？"},{"pid":"646a1e05c49fb27a865a23aa42577f5facf0be06","tid":418381,"uid":89709,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-30T02:51:20.000Z","msg":"一睇到張相 啲車咩年代啊<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"51492cbe3b77dd041a0293cc148f1b97cc0ab272","tid":418381,"uid":115270,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-30T02:54:59.000Z","msg":"條女今年都41歲"},{"pid":"5355780128d6d0bdf6530370d4d5171af960ead9","tid":418381,"uid":88029,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-30T02:59:03.000Z","msg":"此回覆已被刪除"},{"pid":"4a97dd9297c3e675af6a0d0e0631aa01c1d69770","tid":418381,"uid":67786,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-16T11:31:23.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"0d27f20ec0e186a2178041230cd6de5a9af15f86","tid":418381,"uid":61748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-16T11:33:51.000Z","msg":"此回覆已被刪除"}]}