,"tid":549862,"uid":92178,"like":3,"dislike":9,"score":-6,"citedBy":0,"replyTime":"2018-02-04T19:12:01.000Z","msg":"此回覆已被刪除"},{"pid":"b4e8fd6c6da3660d4e64791e5f3e92411cad386a","tid":549862,"uid":92178,"like":7,"dislike":6,"score":1,"citedBy":0,"replyTime":"2018-02-04T19:14:51.000Z","msg":"此回覆已被刪除"},{"pid":"23831d9c16ac8bec92dc044fa466b2bdc2fae23a","tid":549862,"uid":92178,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2018-02-04T20:15:13.000Z","msg":"此回覆已被刪除"},{"pid":"06858f14c638c1616c3ed760c67fb19b6f0c1dc3","tid":549862,"uid":91146,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-02-05T00:37:44.000Z","msg":"小草呢"},{"pid":"5e6f16323b857fa32d640b7dbdf54ed7b37a93ed","tid":549862,"uid":131064,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-02-05T00:50:10.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>擺明肥婆</strong></span></span>"},{"pid":"e66a0773c18973c5b350666c197d3c5393a0b820","tid":549862,"uid":71770,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-02-05T01:08:18.000Z","msg":"識玩緊係出書出自傳<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"bba5edf1c437258af88df0d2c31e2567e57c8d50","tid":549862,"uid":37758,"like":13,"dislike":1,"score":12,"citedBy":1,"replyTime":"2018-02-05T01:10:40.000Z","msg":"如果佢欣宜咁既樣<br />\n呢個post仲會唔會有咁多有人性既留言？"},{"pid":"07e01074698e5a7a2d5607ff72dbbb96f68d5aa1","tid":549862,"uid":58359,"like":1,"dislike":5,"score":-4,"citedBy":0,"replyTime":"2018-02-05T01:12:19.000Z","msg":"佢個妹係我小學同學"},{"pid":"a840a1ef4edc9c309f57062f7500f12e585bbe02","tid":549862,"uid":111372,"like":28,"dislike":3,"score":25,"citedBy":0,"replyTime":"2018-02-05T01:45:03.000Z","msg":"本身是死者同居女友的易女，外表清純，在家人及老師眼中，是一名沉默寡言的乖乖女<br />\n<br />\n易女早於唸中二時已認識死者，其後發展成情侶，更珠胎暗結，但家人一直不知情，易女一直懷着身孕上學，直至產女後，繼續學業至中六，與死者共同照顧女兒。<br />\n<br />\n死者發現易女與其他男人外出而起爭執，於是向她揮拳襲擊，她隨手拿起一把生果刀亂舞，結果刺向死者，但死者未有罷手，她於是再取鐵錘還撃，終把死者殺害。<br />\n<br />\n父母的不幸遭遇亦禍延下一代，死者與易女所育的女兒，失去父母後，先被送入孤兒院，後被寄養家庭收養，直至15歲離開寄養家庭後誤交損友，於2015年因販毒被捕。<br />\n<br />\n咁樣都被人叫臭閪出臭草，有時登仔唔好怪點解香港咁多仆街，人地成個人生都已經係不幸，都可以咁惡毒咁詛咒，真係咩人種自己應該知，仲諗住自己企係道德高地。"},{"pid":"b7d1f870e5e0912af9831838b8e38da98593da62","tid":549862,"uid":11067,"like":2,"dislike":1,"score":1,"quote":{"pid":"e66a0773c18973c5b350666c197d3c5393a0b820","tid":549862,"uid":71770,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-02-05T01:08:18.000Z","msg":"識玩緊係出書出自傳<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-05T01:45:53.000Z","msg":"20後的自白？"},{"pid":"51f67202c16b23a05d2231c0166dea32296a92d5","tid":549862,"uid":21871,"like":0,"dislike":1,"score":-1,"quote":{"pid":"97082c3ff7ec9ebdf38e2ef693277c213d581d5a","tid":549862,"uid":85168,"like":7,"dislike":6,"score":1,"citedBy":1,"replyTime":"2018-02-04T08:49:42.000Z","msg":"小草呢？"},"citedBy":0,"replyTime":"2018-02-05T01:46:09.000Z","msg":"冇告佢"},{"pid":"b84a394f1b02f01eced8552ad8a9c4683cf613ef","tid":549862,"uid":32906,"like":1,"dislike":3,"score":-2,"citedBy":0,"replyTime":"2018-02-05T01:59:17.000Z","msg":"佢個女幾歲比人破處<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"}]}