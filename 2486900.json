"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"64c5495b541ab5ccc20e35a866a75c2c2913651c","tid":2486900,"uid":85659,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-26T07:20:20.000Z","msg":"換過塊版"},{"pid":"4003d401ab2a2a29d5fd32de6a2ea1673f171993","tid":2486900,"uid":58882,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-26T07:40:43.000Z","msg":"試吓先bios reset default <img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><br />\n<br />\nMB Bios &amp; chipset 更新<br />\n<br />\nNv driver 重裝<br />\n<br />\n唔好搞CTR 果D先"},{"pid":"9c76fdd5d28da08953754ffa72f56463e338e2ea","tid":2486900,"uid":85659,"like":0,"dislike":0,"score":0,"quote":{"pid":"4003d401ab2a2a29d5fd32de6a2ea1673f171993","tid":2486900,"uid":58882,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-26T07:40:43.000Z","msg":"試吓先bios reset default <img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><br />\n<br />\nMB Bios &amp; chipset 更新<br />\n<br />\nNv driver 重裝<br />\n<br />\n唔好搞CTR 果D先"},"citedBy":0,"replyTime":"2021-04-26T08:40:48.000Z","msg":"<img src=\"/assets/faces/cow/sosad.gif\" class=\"hkgmoji\" />13日後先入黎幫<br />\n懷疑被follow<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/sorry.gif\" class=\"hkgmoji\" />"},{"pid":"702576b187b2e8f513832b192c6e7de6ec47de9a","tid":2486900,"uid":173121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-26T08:42:42.000Z","msg":"你係咪冇裝driver <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"74a88fc42c3cee7d18a317a6ef2905ec93ddec7e","tid":2486900,"uid":260335,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-26T08:48:08.000Z","msg":"Amd問題 <br />\n解決唔到 <br />\n唔用intel 抵撚死<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c9f4080dad28a5894c457b5f63821087425e243b","tid":2486900,"uid":335003,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-26T09:37:03.000Z","msg":"隻火牛用咗幾耐?<br />\n<br />\n試過有個case 好頂癮係火牛內部積塵，然後 display card 上高耗電時因為火牛過熱俾唔到咁多電而彈game 。<br />\n<br />\n拆開隻火牛(過保)底底面面清完一次塵之後無事，原本係想清完塵祼機試火牛啲電路電壓有無問題。"}]}