刃或尖端則從拳頭指縫間突出<br />\n<br />\n至於槍，只要槍口動能唔過2j 就唔可以當火器"},{"pid":"bc672f0903df2abb1b83451ca7ab6b5a34420a15","tid":1083960,"uid":241249,"like":0,"dislike":0,"score":0,"quote":{"pid":"00fcb1c6c3ce3456d493259852ca59e3b20f9e2a","tid":1083960,"uid":250915,"like":1,"dislike":0,"score":1,"quote":{"pid":"add91b0dfe5bf3b03e138b17aa2e3744106930c0","tid":1083960,"uid":57410,"like":0,"dislike":0,"score":0,"quote":{"pid":"46dfbb0780ab625de2431d1e76c69ee3b16179b0","tid":1083960,"uid":205469,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-04-28T04:55:40.000Z","msg":"如果上網買刀洗唔洗申報海關？<br />\n想上網買把美軍m9刺刀"},"citedBy":2,"replyTime":"2019-04-28T04:58:20.000Z","msg":"其實擁有刀槍犯唔犯法"},"citedBy":1,"replyTime":"2019-04-28T05:00:53.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-04-28T05:19:20.000Z","msg":"開鋒都唔會"},{"pid":"de71f3250825e278d0cde0bba252ea35149fa777","tid":1083960,"uid":176303,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc672f0903df2abb1b83451ca7ab6b5a34420a15","tid":1083960,"uid":241249,"like":0,"dislike":0,"score":0,"quote":{"pid":"00fcb1c6c3ce3456d493259852ca59e3b20f9e2a","tid":1083960,"uid":250915,"like":1,"dislike":0,"score":1,"quote":{"pid":"add91b0dfe5bf3b03e138b17aa2e3744106930c0","tid":1083960,"uid":57410,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-04-28T04:58:20.000Z","msg":"其實擁有刀槍犯唔犯法"},"citedBy":1,"replyTime":"2019-04-28T05:00:53.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-04-28T05:19:20.000Z","msg":"開鋒都唔會"},"citedBy":1,"replyTime":"2019-05-07T02:59:03.000Z","msg":"點解釋?  買黎當菜刀?"},{"pid":"3a65dda8eb3bcade2a829c81a3eb824830befc85","tid":1083960,"uid":241249,"like":0,"dislike":0,"score":0,"quote":{"pid":"de71f3250825e278d0cde0bba252ea35149fa777","tid":1083960,"uid":176303,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc672f0903df2abb1b83451ca7ab6b5a34420a15","tid":1083960,"uid":241249,"like":0,"dislike":0,"score":0,"quote":{"pid":"00fcb1c6c3ce3456d493259852ca59e3b20f9e2a","tid":1083960,"uid":250915,"like":1,"dislike":0,"score":1,"ci