class=\"hkgmoji\" />"},{"pid":"0bfcc9a5166587058964b5161a947e79f61786e6","tid":1674280,"uid":127216,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-25T16:55:30.000Z","msg":"邊間"},{"pid":"6bbd7bd5477ebfccbadcee8a30728e483169ea25","tid":1674280,"uid":284485,"like":0,"dislike":0,"score":0,"quote":{"pid":"0bfcc9a5166587058964b5161a947e79f61786e6","tid":1674280,"uid":127216,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-25T16:55:30.000Z","msg":"邊間"},"citedBy":0,"replyTime":"2019-10-26T01:01:38.000Z","msg":"新德里<br />\n好多人排隊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}