sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Ftheumbrellaunion.org%2Fwe-connect-campaign&d=NMuDHS38lj0XaiXuPCYWR%2FtobIAPz7vP9zHpdy2ENqg%3D&h=f9e72717\" data-auto-link target=\"_blank\">theumbrellaunion.org/we-connect-campaign</a>"},{"pid":"5a6b6f0de65c4ab601289308cc94ca962ea748fe","tid":1944501,"uid":137109,"like":0,"dislike":0,"score":0,"quote":{"pid":"b6ce3196bd9168a54e524e9dbb22db257cb5c1f3","tid":1944501,"uid":44358,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-03-26T12:22:27.000Z","msg":"有冇link 課金<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-26T12:30:02.000Z","msg":"多謝巴打<br />\npin 咗，有餘力可以幫幫手"},{"pid":"ae33b007a3fa36f8cb8d15ed8eefcd20493d1489","tid":1944501,"uid":137109,"like":0,"dislike":0,"score":0,"quote":{"pid":"3a65c1973bf7d54ac5909949ceb2073bb42d60d0","tid":1944501,"uid":287422,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-03-26T12:16:33.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />點課？<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-26T12:30:20.000Z","msg":"啱啱pin咗，多謝巴打"},{"pid":"e2f0a433525c2f9dfb1067800db49e848691461b","tid":1944501,"uid":146737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-26T12:30:39.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"e4bbe79b6cceb7bc15ff6abb4849ab5228843923","tid":1944501,"uid":146737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-26T12:31:56.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"1b2db5bbcd0067803bf7ff40bb0f62feabaec2ea","tid":1944501,"uid":36088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-26T12:34:06.000Z","msg":"up"},{"pid":"496ab85fdbaf3eb7cda2038f41fb8bab45f22380","tid":1944501,"uid":36088,"like":0,"di