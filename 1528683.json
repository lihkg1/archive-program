src=\"/assets/faces/mf/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a88b8601d12cb5e4f1006222dd001e1a91c1e209","tid":1528683,"uid":84058,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T11:38:50.000Z","msg":"推"},{"pid":"4e1a795be3d6398ed1e8ee7306f0c1bdbbba9815","tid":1528683,"uid":20723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T11:39:00.000Z","msg":"<blockquote><img src=\"https://na.cx/i/RAABnFb.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRAABnFb.png&h=5bd749e1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/caLar6x.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcaLar6x.png&h=7febc0be&s={SIZE}\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">土共你今日還錢味啊？</span></span></strong><br />\n<br />\n<a href=\"https://petitions.whitehouse.gov/petition/request-communist-china-government-redeem-imperial-dynasty-s-bond\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Frequest-communist-china-government-redeem-imperial-dynasty-s-bond&d=3Z9ZeYaQzwHPi2iIp4702Ou9cyR3gY7uP1sO3WVLDIg%3D&h=450b9e38\" target=\"_blank\">https://petitions.whitehouse.gov/petition/request-communist-china-government-redeem-imperial-dynasty-s-bond</a><br />\n<br />\n<span style=\"font-size: x-large;\"><strong>記得Check verify email</strong></span><br />\n<br />\n任何國際之間既債務都有繼承義務<br />\n慈禧簽果條辛丑條約 一戰果時民國繼續還<br />\n仲要還到1938年因爲打二戰窮到pk<br />\n去求條約國唔追辛丑賠款先可以停<br />\n既然中共自稱滿清正統承繼人<br />\n呢張債券自然本利點都要還<br />\n唔還既佢講乜差野要用南京條約去收番香港<br />\n而且美國政府係未同中共追還錢<br />\n<br />\n<img src=\"https://na.cx/i/wjpU2AG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwjpU2AG.jpg&h=45a46f02&s={SIZE}\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\">緊係侵侵啦！</span></strong><br />\n<br />\n<img src=\"/assets/faces/mf/special.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/special2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/special3.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"a4db3103cc7fa216a62fc8c5363db23c6a360ea0","tid":1528683,"uid":98431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T11:39:14.000Z","msg":"<img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" />"},{"pid":"717cde3f7a1ca672e8d9419ceff346d1f25784d7","tid":1528683,"uid":254381,"like":0,"dislike":0,"score":0,"quote":{"pid":"409f94fc5ef2e5e005316a24ee3b47e397cd0f76","tid":1528683,"uid":185022,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-09-15T11:37:07.000Z","msg":"但地址邊道有?"},"citedBy":0,"replyTime":"2019-09-15T11:40:29.000Z","msg":"好多公司地址網上都搵到"},{"pid":"ac0a116f5a46eafe3e94d422b9a2d785b60bc8f6","tid":1528683,"uid":107686,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T11:40:51.000Z","msg":"<img src=\"/assets/faces/mf/good.png\" class=\"hkgmoji\" />"},{"pid":"93f3e1c7170fb4819537b7a10af6ac8a22c1962e","tid":1528683,"uid":12440,"like":0,"dislike":0,"score":0,"quote":{"pid":"409f94fc5ef2e5e005316a24ee3b47e397cd0f76","tid":1528683,"uid":185022,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-09-15T11:37:07.000Z","msg":"但地址邊道有?"},"citedBy":0,"replyTime":"2019-09-15T11:44:10.000Z","msg":"用成交搵地址<br />\n<br />\n<a href=\"https://m.fang.com/zf/zz/?adap=auto\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.fang.com%2Fzf%2Fzz%2F%3Fadap%3Dauto&d=3Z9ZeYaQzwHPi2iIp4702Ou9cyR3gY7uP1sO3WVLDIg%3D&h=c4ae0e67\" data-auto-link target=\"_blank\">https://m.fang.com/zf/zz/?adap=auto</a><br />\n<br />\n去好旺角 買平價郵票"},{"pid":"d29875b099df6d6ce7a260bcf6c54057c9fe32ce","tid":1528683,"uid":12440,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T11:47:13.000Z","msg":"寄空郵好平 <br />\n係未有信內容"},{"pid":"19dda76bd875e683d9b0396045af2ba948ba1970","tid":1528683,"uid":185022,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T12:43:35.000Z","msg":"好似好正"},{"pid":"613f7575d9de62c430e0d35129523a01251c6c06","ti