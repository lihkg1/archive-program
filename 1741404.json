":"4dcfffb7ad7918d5ac125de1d467c1e7a81243a7","tid":1741404,"uid":55198,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T16:07:06.000Z","msg":"<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/31tQxcQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F31tQxcQ.jpg&h=df66d227&s={SIZE}\" />"},{"pid":"7e0c5d907112412ab5e71d8d39df71ca09312d9f","tid":1741404,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T16:08:23.000Z","msg":"推"},{"pid":"30320de1e4a5e828ec9c8b1c88cb907c3ae3bed9","tid":1741404,"uid":13281,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-29T14:27:13.000Z","msg":"一場運動就撕開晒呢個社會既假面具<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n淨底既自求多福 香港人比你地呃夠了"}]}