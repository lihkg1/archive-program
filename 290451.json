25f0f1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F20%2F115852_0bf0de20d3a085496ab73dbb0425f0f1.jpg&h=60ee8341&s={SIZE}\" /></blockquote><br />\n垃圾<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"099d9e33d7dad2c34ea29ef72bc72eb66853921c","tid":290451,"uid":5319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-20T17:07:59.000Z","msg":"鬆腿 同埋 按摩依家幾多錢落樓？有無房過夜"},{"pid":"01e295eefaffe0a3a09b28de8eb68d3aac0b23ff","tid":290451,"uid":9769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-20T17:17:33.000Z","msg":"<blockquote>鬆腿 同埋 按摩依家幾多錢落樓？有無房過夜</blockquote><br />\n普通按摩198 2粒鐘左右，不過你要過夜條rule好複雜，要睇入場時間，要睇星期幾，但如果你一次消費夠300-400人仔既，應該都會有房比你過夜。<br />\n<br />\n我就⋯⋯⋯⋯⋯<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/06/21/011730_3185be3b92527e0342461b604dc94fe1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F21%2F011730_3185be3b92527e0342461b604dc94fe1.jpg&h=97df0df2&s={SIZE}\" />"},{"pid":"b76401ced0bfa70675de07b0c54c3425d8e377cb","tid":290451,"uid":9769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-20T17:22:42.000Z","msg":"<img src=\"http://img.eservice-hk.net/upload/2017/06/21/011854_09c7cce3aa1b55f686b7d3c48d934f9c.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F21%2F011854_09c7cce3aa1b55f686b7d3c48d934f9c.jpg&h=edc88c88&s={SIZE}\" /><br />\n<br />\n房間環境<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/06/21/011855_593043007b76954d38c4f02b7b7c1463.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F21%2F011855_593043007b76954d38c4f02b7b7c1463.jpg&h=ab520cbc&s={SIZE}\" /><br />\n<br />\n房間內告示牌<br />\n<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/06/21/011857_e3b613c811a2192839df98b672ee0985.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F21%2F011857_e3b613c811a2192839df98b672ee0985.jpg&h=5a5d79f8&s={SIZE}\" /><br />\n<br />\n會有人幫我着襪，我係腳趾襪，要一隻一隻腳趾咁著，會有2個人托住我2飯腳咁，先用毛巾幫我抹乾隻腳，係一隻一隻腳趾咁抺，然後先幫我着襪！"},{"pid":"2c16e08cf7b31582d4e3aa87393f43d547083701","tid":290451,"uid":9450,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-20T17:44:29.000Z","msg":"我記得呢位巴打好似成日上去<br />\nD咸濕post實有佢<img src=\"/assets/faces/lomoji/25.png\" class=\"hkgmoji\" />"},{"pid":"e0fe8ecff14d3c87f9c19e6d78469dc6b66e7b22","tid":290451,"uid":9769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-20T18:11:28.000Z","msg":"<blockquote>我記得呢位巴打好似成日上去<br />\nD咸濕post實有佢<img src=\"/assets/faces/lomoji/25.png\" class=\"hkgmoji\" /></blockquote><br />\n關咩事<img src=\"/assets/faces/lomoji/16.png\" class=\"hkgmoji\" />"},{"pid":"44dd13b9df9365c1a23db4b11f934fdd114f0c05","tid":290451,"uid":27970,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-21T20:40:46.000Z","msg":"屌1314仔，係香港按好過<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"dacb860496ca9841ff21b901ae16b3bfbcd227f3","tid":290451,"uid":42735,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-21T20:45:13.000Z","msg":"千鳩幾蚊起埋機架"},{"pid":"c22dc4a220c1997ee627d92187a85bf747163510","tid":290451,"uid":88663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-22T04:39:21.000Z","msg":"睇落蝦餃個size都OK喎<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"201e309d0e0e38fc96c1e31a44f434f16b388d23","tid":290451,"uid":27970,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-22T20:01:44.000Z","msg":"<blockquote>睇落蝦餃個size都OK喎<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /></blockquote><br />\n垃圾<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}