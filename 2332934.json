https://na.cx/i/E1hF4Ff.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FE1hF4Ff.jpg&h=80fc2147&s={SIZE}\" /><br />\n<br />\n這款Blanc面罩仍在正籌備階段，預計售價為美元$149（約港幣$1155），雖然價格不菲，研發團隊表示，若平日每4小時更換一次口罩，每年將花費超過500美元（約港幣$4000）買口罩，相比之下Blanc面罩更為划算。如果確定推出，大家又會不會買？"},{"pid":"fe682722544429f054747f8f48d5c18f5afff2c2","tid":2332934,"uid":99700,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-12-20T04:35:50.000Z","msg":"柒"},{"pid":"51fcf5bb642f3090d142cdb222cd4a6648d687d4","tid":2332934,"uid":25676,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-12-20T04:43:52.000Z","msg":"四眼仔四眼妹點用<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"d7bcbca03807bcf305361d3e2688fd9bb095d21a","tid":2332934,"uid":266467,"like":0,"dislike":1,"score":-1,"quote":{"pid":"fe682722544429f054747f8f48d5c18f5afff2c2","tid":2332934,"uid":99700,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-12-20T04:35:50.000Z","msg":"柒"},"citedBy":0,"replyTime":"2020-12-20T06:19:13.000Z","msg":"型"}]}