faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1f51cf1ed220dc17d3b53566ca3759dc78505901","tid":852401,"uid":51076,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-08T03:16:50.000Z","msg":"加咁少息，唔計<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /> <br />\n<br />\n市場開始化淡加息影響，樓市糕糕糕"}]}