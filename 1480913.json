ji\" />"},{"pid":"396714676856554f757bae2defa38720daa82f7a","tid":1480913,"uid":162409,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-25T12:04:11.000Z","msg":"喊位係?"},{"pid":"f77bd4ba088293a2ac107cc7435d055b52f7909a","tid":1480913,"uid":7840,"like":3,"dislike":8,"score":-5,"citedBy":1,"replyTime":"2019-08-25T12:14:51.000Z","msg":"此回覆已被刪除"},{"pid":"6de4a04fb7722a52923a9fa4196b2e87e368fb70","tid":1480913,"uid":162409,"like":2,"dislike":0,"score":2,"quote":{"pid":"f77bd4ba088293a2ac107cc7435d055b52f7909a","tid":1480913,"uid":7840,"like":3,"dislike":8,"score":-5,"quote":{"pid":"396714676856554f757bae2defa38720daa82f7a","tid":1480913,"uid":162409,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-25T12:04:11.000Z","msg":"喊位係?"},"citedBy":1,"replyTime":"2019-08-25T12:14:51.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-08-25T12:17:16.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"203e0e914d8583f6e5524e367cbe8610070baa85","tid":1480913,"uid":7840,"like":0,"dislike":1,"score":-1,"citedBy":3,"replyTime":"2019-08-25T12:34:02.000Z","msg":"此回覆已被刪除"},{"pid":"c0b10bfec8bf5533f425a86b45c0c57def8a9516","tid":1480913,"uid":49995,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-25T12:47:17.000Z","msg":"我都喊左 點解我成日食老麥都識唔到囡<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"d0cf27be0826ef148c0c42af1fc72aea90ab41fc","tid":1480913,"uid":53000,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-26T01:15:32.000Z","msg":"其實我覺得 grand escape 嘅歌詞仲 match<br />\n<br />\n行こう <br />\nもう少しで運命の向こう <br />\nもう少しで文明の向こう <br />\n行こう <br />\nもう少しで運命の向こう <br />\nもう少しで <br />\n<br />\n　▍出發吧<br />\n　▍還差一點就能到命運的另一端<br />\n　▍還差一點就能到文明的另一端<br />\n　▍出發吧<br />\n　▍還差一點就能到命運的另一端<br />\n　▍還差一點<br />\n<br />\n夢に僕らで　帆を張って <br />\n来るべき日のために　夜を越え <br />\nいざ期待だけ　満タンで <br />\nあとは　どうにかなるさと <br />\n肩を組んだ <br />\n<br />\n　▍在夢裡的我們揚起了船帆<br />\n　▍為了那即將到來的日子　越過了黑夜<br />\n　▍僅憑藉著滿懷的期待　加滿了油<br />\n　▍說著「剩下的總會有辦法的」　<br />\n　▍便搭起了彼此的肩<br />\n<br />\n怖くないわけない <br />\nでも止まんない <br />\nピンチの先回りしたって <br />\n僕らじゃしょうがない <br />\n<br />\n　▍逐夢之路不可能無所畏懼<br />\n　▍但記得無論如何都不要停下腳步<br />\n　▍若在這途中真遇上了什麼變數<br />\n　▍那也是僅憑我們所無能為力的事"},{"pid":"520d0a0d90b109a147174a299a28291e99dde257","tid":1480913,"uid":51753,"like":0,"dislike":0,"score":0,"quote":{"pid":"203e0e914d8583f6e5524e367cbe8610070baa85","tid":1480913,"uid":7840,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6de4a04fb7722a52923a9fa4196b2e87e368fb70","tid":1480913,"uid":162409,"like":2,"dislike":0,"score":2,"quote":{"pid":"f77bd4ba088293a2ac107cc7435d055b52f7909a","tid":1480913,"uid":7840,"like":3,"dislike":8,"score":-5,"citedBy":1,"replyTime":"2019-08-25T12:14:51.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-08-25T12:17:16.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2019-08-25T12:34:02.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-08-26T17:37:00.000Z","msg":"夏庵 呢鋪 又靠你啦<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" /><br />\n<br />\n你的名字佢改到好正 睇到我馬眼 淚流不止"},{"pid":"93d87efacf44c7b9f5809e0437def838f31af254","tid":1480913,"uid":67292,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T17:38:07.000Z","msg":"推"},{"pid":"f808f01e7c94bed8f73a3a82522b7be56606d49d","tid":1480913,"uid":201266,"like":12,"dislike":0,"score":12,"citedBy":0,"replyTime":"2019-08-26T18:42:55.000Z","msg":"好癲 最尾男主角話啲大人完全唔知發生咩事<br />\n根本就係香港嘅實況<br />\n要由後生仔拯救<br />\n<br />\nbtw 係天上跌落嚟嗰幕好震撼 起曬雞皮"},{"pid":"25d880e4604f5b7173163bd64cc572b536b7eb33","tid":1480913,"uid":102611,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2019-08-28T06:37:30.000Z","msg":"我覺得呢套好睇過你的名字 雖然男朋友覺得你的名字好睇d <br />\n可能因為本身鐘意呢種熱血少少既劇情 加上好似依家香港既情況咁<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />睇完成晚都抽離唔到<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />radwimps 