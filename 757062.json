5bb1d2b877308100707d991822e2","tid":757062,"uid":46943,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-07-27T12:01:48.000Z","msg":"訓晏覺就是爽<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"a080654a4500acfc25b90d7227a38d2ee95128dd","tid":757062,"uid":47160,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-27T12:09:23.000Z","msg":"本身香港人已經夠長命<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"e6c186d386c1919859645fce671b03897902a68f","tid":757062,"uid":152047,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-28T09:51:14.000Z","msg":"之前又話訓得少會長命啲<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7876dff71081dbd332afa096706587e71e9436f3","tid":757062,"uid":57513,"like":0,"dislike":0,"score":0,"quote":{"pid":"142ab4218bf4fe8fb557d383317eea8ab50d44a3","tid":757062,"uid":21255,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-07-26T22:59:15.000Z","msg":"訓多過五小時就唔洗死？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-28T09:52:54.000Z","msg":"文盲<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a9676e459522b40e8f524e3e2673f864ef7f7804","tid":757062,"uid":48579,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-28T09:55:24.000Z","msg":"痴線 根本就唔關事 <br />\n香港人訓得少 做到隻積咁咪又係世界最長命"}]}