":"81d2525619e60b302225d3ccbff5168f36863686","tid":1139430,"uid":73887,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-05T10:17:02.000Z","msg":"想知你問左咩高質問題<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"82292181787a7dba9f110e52a3b998f95c8fd867","tid":1139430,"uid":235911,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-05T10:22:52.000Z","msg":"問佢邊個plan 佢食最少佣，買果個就得"},{"pid":"93ab7414afea284c290cf2ea4996c0b40c28fe02","tid":1139430,"uid":84585,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-05-05T10:25:42.000Z","msg":"此回覆已被刪除"},{"pid":"91a3e04ba664bddd1002d5f64e440844374195cb","tid":1139430,"uid":156145,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-05-05T10:28:50.000Z","msg":"好出色<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 成班快錢黨 哂9氣"},{"pid":"e78b9622a01ac79fb0cc16a252668464a0809652","tid":1139430,"uid":250094,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-05T10:32:46.000Z","msg":"可以走入去比人sell嘅<br />\n應該係中人壽?"},{"pid":"8ffa88e2f435bb8e2b15eb0a2712e54187b1427d","tid":1139430,"uid":6389,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2019-05-05T10:33:44.000Z","msg":"巴打有冇諗過買自願醫保？好似間間都一樣同埋又有得check 保費邊間抵"},{"pid":"70c8ffaa056498dfcac06ef266930920d8287644","tid":1139430,"uid":123961,"like":0,"dislike":0,"score":0,"quote":{"pid":"8ffa88e2f435bb8e2b15eb0a2712e54187b1427d","tid":1139430,"uid":6389,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2019-05-05T10:33:44.000Z","msg":"巴打有冇諗過買自願醫保？好似間間都一樣同埋又有得check 保費邊間抵"},"citedBy":1,"replyTime":"2019-05-05T11:29:13.000Z","msg":"自願醫保只係有政府認可<br />\n政府果份template有寫既條款保險公司一定要跟<br />\n例如一定要保到一百歲咁 仲有個未知已有疾病一定要保咁<br />\n<br />\n但基本計劃包嘅野未必夠<br />\n多數諗靈活計劃<br />\n靈活計劃就係保險公司自己加野上去間間唔同<br />\n<strong>所以到最後都係要自己一間間睇細節冇懶戈包直接睇價錢比較</strong><br />\n真係standard product就唔會間間掙住出仲一大堆優惠等你落搭啦<br />\n冇肉食嘅野保險公司點會做"},{"pid":"ba2e13a8725db93799576f32bbd75133a3083854","tid":1139430,"uid":8854,"like":0,"dislike":4,"score":-4,"cite