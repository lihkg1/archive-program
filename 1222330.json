2b1fee9f6e980c2cb6f28fd7dbee","tid":1222330,"uid":12991,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T09:07:40.000Z","msg":"依個推"},{"pid":"902c1f0e1f5b3588430a2b1630d2a99ddad75d56","tid":1222330,"uid":241151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T09:35:37.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2988ae0dcc3ea5ff687d653c90fe89fe4a24f276","tid":1222330,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T09:38:09.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"23a7d96b3d00114ecf1296bfa12c3f1827068f03","tid":1222330,"uid":137506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T09:38:11.000Z","msg":"push"},{"pid":"1cb844f837cd3dd2b842c82e0d644c38d9a51abb","tid":1222330,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T09:48:44.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"8799988b2fcc5524f13424ccbdea3c38525950a8","tid":1222330,"uid":7948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T09:52:03.000Z","msg":"ok"},{"pid":"eb8f23969aa377d8c0d5f0a2b379c3fc5aaeed1b","tid":1222330,"uid":241151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T09:52:42.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3f4da8155cf962fdc9e8eb47b1724ab67f3a1a38","tid":1222330,"uid":33878,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T09:55:50.000Z","msg":"真 救自己救義士<br />\n救得一個就一個"},{"pid":"2ca29416a574c285500411f14c89e49371a2ac25","tid":1222330,"uid":131171,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-15T10:01:10.000Z","msg":"Cheng Chung Tai<br />\n13 June at 09:55<br />\n#6月13號逃犯修例第二日<br />\n<br />\n昨日有人權觀察組織稱，約400人被警方逮捕；官方則稱被捕人數將近200人。<br />\n<br />\n昨晚清晨已陸續有一些朋友搵我幫手，指其家人、子女、朋友遭到拘捕。初步得悉，有部分被捕人士有泛民律師幫手跟進，但亦因人數太多，有一些未能聯絡上。<br />\n<br />\n另外，差佬已經講明會在今日起上被捕人士家門搜查取證。<br />\n<br />\n若果大家有需要協助，特別是未知如何做多一點保障被捕朋友的話，請隨時與我聯絡 6540-4949 或 65531930。<br />\n<br />\n大家好好保重。<br />\n<br />\n整合：被捕須知<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1200715\" data-auto-link target=\"_blank\">https://lih.kg/1200715</a><br />\n<br />\n【被捕須知】 by PassionTimes 熱血時報<br />\n<br />\n「我冇嘢想講」<br />\nI HAVE THE RIGHT TO REMAIN SILENT<br />\n我有拒絕作答及保持沉默的權利<br />\n<br />\nREAD THIS NOW<br />\n01 被捕時大聲高呼中文全名及拘捕理由，方便安排支援。<br />\n02 你有權拒絕提供電話解鎖密碼。<br />\n03 你有權要求與家人、朋友或律師聯絡；聯絡時務必提供全名、身份證號碼及所在警署，以便安排支援。<br />\n04 被捕後所有說話均可被列為口供，不要與警方閒聊，切勿相信「只是循例、控罪很輕，合作可以快點離開」<br />\n05 不要回應警方任何分析案情，任何資訊都可能變相方便檢控，影響案件。<br />\n06 落口供過程中，只需不斷重申「我冇嘢講」，更有權拒絕攝錄。<br />\n07 除非警方出示搜查令，你有權拒絕任何入屋搜查。即使是合法的入屋搜查，你亦有權拒絕過程中的任何查問，例如物件位置、如何使用或屬於誰人等。<br />\n08 如遭警方暴力對待，應即時投訴、要求記錄及提出驗傷。<br />\n09 你有權要求見醫生、驗傷，亦可要求休息、飲水、三餐食物、毛毯。<br />\n10 如要求被拒絕，你有權不斷要求，直至成功爭取權利為止。<br />\n11 小心閱讀所有文件，如未有律師在場，不要隨便簽署任何文件。<br />\n12 法律容許警方拘留的最長時間為48小時，但並非可以隨便拘留盡48小時。如你懷疑警方拖延，例如長時間不處理、無合理解釋，你有權提出投訴並留下紀錄。<br />\n13 盡量保持冷靜，記下所有不合理對待、提問等的時間地點，可能有助案情。<br />\n0<br />\n0"},{"pid":"e50fc66eb421fa581dd0585e599e8b2d9f2eb353","tid":1222330,"uid":241151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T10:04:45.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"8c8b13ff11fbc780d2c20a05c043583ecf5e54a7","tid":1222330,"uid":241151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T10:38:04.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"95d14307dbf5782beca22f1e425c15ca0354f22e","tid":1222330,"uid":241151,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T17:36:58.000Z","msg":"post返d有用既題好過"},{"pid":"06aa640ae745ef6f16227a2f07f247a2db7c7daa","tid":1222330,"uid":9116,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ca29416a574c285500411f14c89e49371a2ac25","tid"