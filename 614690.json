03:33.000Z","msg":"佢同ex分咗幾耐先"},{"pid":"4232fc5b4d01e29b3e1c891a8b8315a0e988d14a","tid":614690,"uid":59465,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-03T04:05:03.000Z","msg":"兩個月學人扮灑脫叫春<br />\n呸"},{"pid":"39808fc530bc119dad1b09964b116d328e95ad18","tid":614690,"uid":52512,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-03T04:25:21.000Z","msg":"說白了都係唔夠鍾意你<br />\n未放得低都係藉口<br />\n下個喇<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />"}]}