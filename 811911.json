B%E5%B1%8E%E8%83%BD%E9%98%B2%E8%9B%80%E7%89%99-%E5%A2%9E%E5%BC%B7%E5%85%8D%E7%96%AB%E5%8A%9B\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E5%258D%25B3%25E6%2599%2582%25E5%259C%258B%25E9%259A%259B%2F89273%2F%25E9%25A3%259F%25E9%25BC%25BB%25E5%25B1%258E%25E6%259C%2589%25E7%259B%258A%25E5%2581%25A5%25E5%25BA%25B7-mit%25E5%258F%258A%25E5%2593%2588%25E4%25BD%259B%25E5%25B0%2588%25E5%25AE%25B6%25E7%2599%25BC%25E7%258F%25BE%25E9%25BC%25BB%25E5%25B1%258E%25E8%2583%25BD%25E9%2598%25B2%25E8%259B%2580%25E7%2589%2599-%25E5%25A2%259E%25E5%25BC%25B7%25E5%2585%258D%25E7%2596%25AB%25E5%258A%259B&d=SuDdN0eGUOeRjBjatkZNKcmB%2BETtKD6oVAJ%2Bxq8xWyI%3D&h=5a713081\" data-auto-link target=\"_blank\">https://www.hk01.com/%E5%8D%B3%E6%99%82%E5%9C%8B%E9%9A%9B/89273/%E9%A3%9F%E9%BC%BB%E5%B1%8E%E6%9C%89%E7%9B%8A%E5%81%A5%E5%BA%B7-mit%E5%8F%8A%E5%93%88%E4%BD%9B%E5%B0%88%E5%AE%B6%E7%99%BC%E7%8F%BE%E9%BC%BB%E5%B1%8E%E8%83%BD%E9%98%B2%E8%9B%80%E7%89%99-%E5%A2%9E%E5%BC%B7%E5%85%8D%E7%96%AB%E5%8A%9B</a><br />\n<br />\n一群來自麻省理工學院（Massachusetts Institute of Technology，MIT）與哈佛大學（Harvard University）的研究學者，在最一期《美國微生物學會期刊》（American Society for Microbiology Journal）中發表文章，指出「吃鼻屎有益健康」。<br />\n<br />\n研究發現「鼻屎」能預防呼吸道感染，對抗愛滋病病毒，鼻屎附帶的鼻水亦可阻止細菌黏附在牙齒上造成蛀牙，而吞下鼻水甚至有預防胃潰瘍的功效。有研究正嘗試分離「鼻屎」中的有益成份，製成牙膏或香口膠，用作防止蛀牙。<br />\n<br />\n研究人員亦指出，由於鼻屎本身因混有細菌，當進入消化道就能啟動免疫系統發揮作用，增進腸道健康。"},{"pid":"e4dfeb1171d0745c14c9337c1604ba8c68bc2286","tid":811911,"uid":178962,"like":0,"dislike":19,"score":-19,"citedBy":0,"replyTime":"2018-09-09T08:50:36.000Z","msg":"其實系咪病態尼<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"fd2aa45905a3b8b38fa5f239e560e9647ce853b6","tid":811911,"uid":131299,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-09T13:17:42.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"19ea19f03c8104ef3986f1f5b3d78223ebd90777","tid":811911,"uid":131299,"like":4,"dislike":1,