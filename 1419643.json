{"tid":1419643,"cid":1,"subCid":0,"title":"(請廣傳) 有人漏低左個銀包","createTime":"2019-08-06T02:07:41.000Z","updateTime":"2019-08-06T04:55:01.000Z","uid":225652,"like":5,"dislike":1,"uniUserReply":10,"replies":[{"pid":"48d78d0c91e66fa874d385fb63d87cb6f8ec0636","tid":1419643,"uid":225652,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T02:07:41.000Z","msg":"請廣傳<br />\n2019年8月5號<br />\n琴晚執咗個銀包 (大約時間係2000-2200漏左個銀包)<br />\n位置大約係葵興地鐵站 興盛小館附近<br />\n如有遺失<br />\n歡迎向我攞番<br />\n但要講出五大特徵<br />\n要講得出身分證號碼，名，生日，性別，讀邊間學校<br />\n否則銀包會壽終正寢<br />\nThe wallet is dead.<br />\n<br />\n五大訴求，缺一不可<br />\n光復香港，時代革命<br />\n不割蓆不譴責不篤灰<br />\n香港人加油<br />\ntelegram user name：@fung312<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/KaeQqp1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKaeQqp1.png&h=5c49146d&s={SIZE}\" /><img src=\"https://na.cx/i/cry9FYo.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fcry9FYo.png&h=ac6d23da&s={SIZE}\" />"},{"pid":"f9d763f7a4e780b11b88f0653612c20a5f244143","tid":1419643,"uid":225652,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T02:22:15.000Z","msg":"自推"},{"pid":"be0ad520ec87288e3cca59688d5d31d8fb3b2fd6","tid":1419643,"uid":225652,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T02:22:26.000Z","msg":"自推"},{"pid":"c06af367d7ee82209890a9340bb856a2697f7638","tid":1419643,"uid":225652,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T02:22:39.000Z","msg":"自推"},{"pid":"5c265e9554d3812b6e9653206e922d7d080c38c1","tid":1419643,"uid":298442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T02:31:08.000Z","msg":"推"},{"pid":"38ab2e59b579619c17873c2a4caf517c26777e23","tid":1419643,"uid":223865,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-06T02:31:49.000Z","msg":"Push"},{"pid":"31cb8e4bd229691e43a2c82d3809f82ea9470bde","tid":1419643,"uid":32087,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-