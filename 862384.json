ts/faces/lomoji/26.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"41fedf2a7d5f1cb06d6880a013f53e5fb7ea56c3","tid":862384,"uid":109462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-14T20:08:19.000Z","msg":"瞓前再推一推，自己個人要叉叉電先<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},{"pid":"61dbb97c5b6254ba2961003532922f373d1eaac1","tid":862384,"uid":17510,"like":9,"dislike":1,"score":8,"citedBy":0,"replyTime":"2018-10-14T20:11:52.000Z","msg":"所以話<br />\n泛民一日唔全滅一日都唔洗旨意爭取到啲乜野"},{"pid":"a4ba456fbaaa66a32dfce69835b06b09506ec46e","tid":862384,"uid":43309,"like":13,"dislike":1,"score":12,"citedBy":0,"replyTime":"2018-10-14T20:20:53.000Z","msg":"加上今日戰線分開咗兩邊，<br />\n有大部分巴打都去咗美領個邊。<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n今日冇陪到你地講聲對唔住。<br />\n下次prepare同present返好啲就得<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n多謝你地嘅付出，記得唔好因為人地誤會而遭到嘅指罵而唔開心。<br />\n好少事嫁咋!!!!!!!!<br />\n<br />\n今日好開心見到好多巴打都有去，<br />\n即使左膠遊行真係好鳩，但都唔好灰心，<br />\n因為再冇分裂嘅本錢，大家都係命運共同體嘅一部分，<br />\n只係一少步一少步慢慢地舖上去，<br />\n我相信有一日香港獨立一定會發生<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"965dccdd824f1724a71fc816e6e38aee94cd283b","tid":862384,"uid":65858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-14T20:29:29.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"ae50335daaceba21188804209fa42d731434c4cd","tid":862384,"uid":34047,"like":8,"dislike":1,"score":7,"quote":{"pid":"624437618fe64bf3a34db7e8d8731deadec84014","tid":862384,"uid":109435,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2018-10-14T19:52:57.000Z","msg":"同樓主一樣，睇到晒成件事<br />\n好同意個論壇搞得幾差下，唔知係發起既組織冇經驗定點，主持又麻麻地，成日都接唔到嘉賓/觀眾既說話。明明召集到一大班人去遊行，但去到公民廣場就留唔住班人，去到後段現場已經有大量空位<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 雖然佢地講既有幾個pt都幾好，但同想像中差太遠<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n係我都打算早走既時候就出現左騷動，佢地係後面突然出現又戴晒口罩其實姚松炎嚇親唔俾咪都好正常<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 支持佢地呼籲，但咁做惹嚟反後果都好正常<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n不過其他人鬧佢地戴口罩真係好無奈，又叫囂意圖蓋過佢地班聲<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-14T20:32:01.000Z","msg":"我冇響現場 可能巴打們做法未係最好<br />\n但其實就算再做得好 泛民班人都會諗方法抹黑到你係鬼咁 <br />\n因為佢地只接受到參與既人聽哂佢地話<br />\n用佢地既方式去反抗<br />\n唔會接受到有其他聲音或意見<br />\n雨傘時見識過"},{"pid":"02992cf52834c14d7d7fbdf5194ec93d7e29c637","tid":862384,"uid":22692,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-10-14T20:35:15.000Z","msg":"想問下遊行之後搭個大台咁？定平地咁講野冇人搭台"},{"pid":"ae9661fbfcfacebd70edba380d65a58f8ed44423","tid":862384,"uid":78300,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-14T20:37:19.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"e4498aa93ab5c2a00bfdd5b8c997e3bcda8be84c","tid":862384,"uid":109435,"like":0,"dislike":0,"score":0,"quote":{"pid":"02992cf52834c14d7d7fbdf5194ec93d7e29c637","tid":862384,"uid":22692,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-10-14T20:35:15.000Z","msg":"想問下遊行之後搭個大台咁？定平地咁講野冇人搭台"},"citedBy":0,"replyTime":"2018-10-14T20:39:56.000Z","msg":"平地，冇台"},{"pid":"20d636ff357f9a4f36181bd3884c9848bd18119f","tid":862384,"uid":109462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-14T22:30:51.000Z","msg":"瞓醒自推<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},{"pid":"73cea0d8ef308cfdc327b473ea6deedf1efc6612","tid":862384,"uid":111253,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-14T22:44:12.000Z","msg":"見識過雨傘金鐘人就知左膠大台幾恐怖"},{"pid":"380d2a71809c6fedcb40bd49b8736cc633532ae2","tid":862384,"uid":2429,"like":1,"dislike":3,"score":-2,"quote":{"pid":"8ba47568bfe618bd16bcd3dd183e725a459d3baf","tid":862384,"uid":28181,"like":0,"dislike":3,"score":-3,"quote":{"pid":"7a85ee7fa1fddcfe9e7c527ce6f3cb658dcfe405","tid":862384,"uid":109462,"like":8,"dislike":1,"score":7,"quote":{"pid":"d8a40252253a6beafaf11213b8401cd6a951dbd4","tid":862384,"uid":28181,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-14T19:57:43.000Z","msg":"其實佢地係個鳥籠到圍爐，個咪細聲到係閘就聽唔到中間up乜9，點解要咁在意佢地講咩~"},"citedBy":1,"replyTime":"2018-10-14T20:02:01.000Z","msg":"今次群情洶湧，可以講係機會難得；由得佢哋大發膠論，只會白白浪費機會，坐視群眾流失，咁不如搏一搏睇下帶唔帶得返起成件事，奈何功敗垂成，但至少有嘗試過先<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-14T20:07:08.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-14T22:51:24.000Z","msg":"平時叫你哋讀多啲書搵多啲錢好似害撚咗你哋咁，咁既質素想獨立，左膠都未贏到呀！<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"358c7d9c6373a48f5d7a2b91833d320a647bf303","tid":862384,"uid":117200,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-10-14T22:54:48.000Z","msg":"大台，毒果都係暗紅，有咩關建時刻就會轉軚/曲線散場"},{"pid":"bbbf46c2457892548a92a1ac73be29712717ede4","tid":862384,"uid":109462,"like":1,"dislike":0,"score":1,"quote":{"pid":"380d2a71809c6fedcb40bd49b8736cc633532ae2","tid":862384,"uid":2429,"like":1,"dislike":3,"score":-2,"quote":{"pid":"8ba47568bfe618bd16bcd3dd183e725a459d3baf","tid":862384,"uid":28181,"like":0,"dislike":3,"score":-3,"quote":{"pid":"7a85ee7fa1fddcfe9e7c527ce6f3cb658dcfe405","tid":862384,"uid":109462,"like":8,"dislike":1,"score":7,"citedBy":1,"replyTime":"2018-10-14T20:02:01.000Z","msg":"今次群情洶湧，可