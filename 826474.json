ote":{"pid":"7cd49e9f1432667a7c62dd8646016d957bb952a7","tid":826474,"uid":188282,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2018-09-18T09:31:05.000Z","msg":"根本d樹一早冧左架喇。巴士跳樓啫。"},"citedBy":0,"replyTime":"2018-09-18T10:42:19.000Z","msg":"記住係墮樓<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"7a2c1dc3ff4f4207e72c86669db5f46abfb13fa5","tid":826474,"uid":28831,"like":3,"dislike":0,"score":3,"quote":{"pid":"a1b8b2e68ad5a23b72088e7a8016ce4e3a6879c6","tid":826474,"uid":64345,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-18T10:39:01.000Z","msg":"唔到有人死林鄭都唔會道歉"},"citedBy":0,"replyTime":"2018-09-18T10:46:10.000Z","msg":"你幾時有錯覺死左人就會道歉？<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"6c89dcf14c7d76b024cd6786130d2e6458bd78a6","tid":826474,"uid":78349,"like":2,"dislike":0,"score":2,"quote":{"pid":"1be56a48153f343d85174682530ca2066ad9f217","tid":826474,"uid":34023,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2018-09-18T09:37:39.000Z","msg":"黃小姐以為是剛才發生的事，車長不知情，於是通知車長。不料車長反應冷淡，繼續行車。黃小姐感到奇怪，只是見沒有乘客受傷，她到油麻地眾坊街便落車。<br />\n<br />\n做乜鳩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-18T10:58:04.000Z","msg":"司機：返工返工！沒事兒！"},{"pid":"7e201fc0d64506f88bf0cee9075a856b1c33db73","tid":826474,"uid":45368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-18T11:11:05.000Z","msg":"成個香港咁有末日feelm"},{"pid":"3a34323e2b757b678f0fc99c3face2ac6e204e5c","tid":826474,"uid":6347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-18T11:15:49.000Z","msg":"特區政府，世界第一"},{"pid":"d9c6bc903373eb0f3bfcb50dbabbfac76ba769dd","tid":826474,"uid":10064,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-18T11:34:36.000Z","msg":"泊架巴士去林鄭屋企啦"}]}