s/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"6f926a4cfd22ce2c1706281523c7a89187ec6282","tid":1559094,"uid":90704,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-11T00:13:20.000Z","msg":"<img src=\"https://na.cx/i/H4w08y1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FH4w08y1.jpg&h=f6651d60&s={SIZE}\" /><br />\n<br />\n推"},{"pid":"cf44361d22d2135599578177d81fae877b08e711","tid":1559094,"uid":42431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T00:19:03.000Z","msg":"辛苦晒旗手們默默做<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"c0cf829c25ff090d3dac548bbd963e26b9d25ccc","tid":1559094,"uid":264797,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-11T00:22:03.000Z","msg":"<img src=\"https://na.cx/i/C3BsOBL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FC3BsOBL.jpg&h=88aa5a80&s={SIZE}\" /> <img src=\"https://na.cx/i/Q1n7OBL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQ1n7OBL.jpg&h=1480eb1e&s={SIZE}\" /> <br />\n好LA好LA,今次比佢地舉英國旗好嗎?"},{"pid":"bce3e9c6940ab37f4eb06f0e297da2bf638449a6","tid":1559094,"uid":284264,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-09-11T00:23:56.000Z","msg":"皇天<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"1e7f6191f530b860da14b9b7e3f5b91751657fbd","tid":1559094,"uid":231435,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T03:30:16.000Z","msg":"我推<br />\n依家為舉旗 屌嚟屌你<br />\n又搞分化都乜撚野"},{"pid":"b6db504bb293637fe02aea4d4e3507f1d1a99e22","tid":1559094,"uid":7686,"like":0,"dislike":0,"score":0,"quote":{"pid":"922d9b26ac7c3015231b350310dfd15982be5372","tid":1559094,"uid":133680,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-10T16:24:15.000Z","msg":"【旗手感言（一）】<br />\n<br />\n我是在 8.5 旺角集會中被毛孟靜干擾和大會糾察搶旗（<a href=\"https://www.youtube.com/watch?v=NUjJTfDlksg）的美國旗手。自從\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DNUjJTfDlksg%EF%BC%89%E7%9A%84%E7%BE%8E%E5%9C%8B%E6%97%97%E6%89%8B%E3%80%82%E8%87%AA%E5%BE%9E&d=3A5iQKMTOMHlOvaIjHeRel3VpWtqcNNCzs9YdIyDBYU%3D&h=e5562626\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=NUjJTfDlksg）的美國旗手。自從</a> 7.14 沙田大遊行開始，我便響應 HKAA 的呼籲在各大遊行集會中高舉美國國旗，請求特朗普總統光復香港，以及美國國會 通過《香港人權與民主法案 2019》，協助香港成功爭取 2020 年普選立法會，最終達至自治。 <br />\n<br />\n7.14 沙田大遊行、7.21 港鳥東大遊行、7.27 光復元朗、8.3 旺角遊行、8.4 將軍澳遊行、8.5 三罷旺角集會、8.10 大埔遊行、8.11 東區遊行、8.12 機場集會、8.25 荃葵青遊行、8.31 灣仔修頓集會遊行、9.2 罷課中大集會以及 9.8 遮打集會遊行，以上集會遊行，我全部都有在場高舉美國國旗，試問何來騎劫？<br />\n<br />\n由最初戰戰兢兢擔心美國國旗不被大眾接納，到後來小心翼翼為免再被搶旗，使美國國旗受辱影響運動成效；由開始只有一支細旗，到現在有四支大旗一支細旗；由開始躍躍欲試，到現在盡量交給其他同道，保留體力。舉美國國旗的行動，從來也不是為了個人榮辱和利益，只是不忍心看見無數香港義士的鮮血白流，白白犠牲卻無功而還。<br />\n<br />\n我是一個生於香港、長於香港的香港人，不是毛孟靜議員所指的五毛。<br />\n<br />\n祈求皇天保佑香港義民！ <br />\n<br />\n旗手 Joe Lau字<br />\n<br />\n驅逐共黨，光復香港 <br />\nResist Beijing, Liberate Hong Kong<br />\n<br />\n#LiberateHK<br />\n#香港憲法保衛戰"},"citedBy":0,"replyTime":"2019-09-11T04:20:23.000Z","msg":"push!!!!"},{"pid":"87223cb681df8fa2c48d9412ae1c53621b231aa7","tid":1559094,"uid":71140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T04:24:44.000Z","msg":"此回覆已被刪除"},{"pid":"5b21089d140c7e30465d0966fb5974763656869d","tid":1559094,"uid":277093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T07:39:34.000Z","msg":"推，加油"},{"pid":"0ad3e220cdd7facab76ccdeb56a1959addbef76c","tid":1559094,"uid":123264,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-09-11T11:54:03.000Z","msg":"大家唔好推呢個POST<br />\nHKAA打手既POST一律無視<br />\n狂推LEADER個POST就得"},{"pid":"06c20eed4a9296eda8bb8e4af1d76ba7a3c5f07e","tid":1559094,"uid":141833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-11T11:54:36.000Z","msg":"<img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" />"},{"pid":"5d73d5583cfca603b76fa3bcd31dba8a162dec2b","tid":1559094,"uid":133680,"like":2,"dislike":0,"score":2,"quote":{"pid":"0ad3e220cdd7facab76ccdeb56a19