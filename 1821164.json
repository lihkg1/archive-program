faces/pig/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"8bb9f91b53a2cc26d924a85cbcba5222f6790aec","tid":1821164,"uid":303498,"like":14,"dislike":0,"score":14,"quote":{"pid":"1d0fed12d8881b1b00152b347e19cb525f001cf1","tid":1821164,"uid":8014,"like":2,"dislike":0,"score":2,"citedBy":5,"replyTime":"2020-01-12T05:24:50.000Z","msg":"有無中文翻譯下<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2020-01-12T05:33:42.000Z","msg":"大致講陳巧文年代每年七一只係行完就算，泛民同抗爭者割蓆，堅持和理非，而家示威激烈好多。<br />\n西方國家的人問做咩咁暴力，佢同西方國家的人講，因為警暴，舉咗周梓樂，同埋交通狗撞人做例子"},{"pid":"313cb631496bfd30c43a8d67e5707f3ca232b84a","tid":1821164,"uid":68896,"like":6,"dislike":0,"score":6,"quote":{"pid":"c7b22cfeda7a831b5f88fe53b11b2c239cb2e006","tid":1821164,"uid":176991,"like":7,"dislike":0,"score":7,"quote":{"pid":"68c084d848814ab64aade22eb81ae388e2b60857","tid":1821164,"uid":470,"like":5,"dislike":1,"score":4,"citedBy":3,"replyTime":"2020-01-12T05:20:09.000Z","msg":"無講佢去左邊<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-01-12T05:30:39.000Z","msg":"<a href=\"https://www.hongkongfp.com/2020/01/12/2020-vision-post-80s-movement-water-hongkongers-eyes-now-wide-open/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hongkongfp.com%2F2020%2F01%2F12%2F2020-vision-post-80s-movement-water-hongkongers-eyes-now-wide-open%2F&d=uClJ75VMDgyJ2T8QnpTVXUBo7c%2BYFxEppcXi0rJe94o%3D&h=01971399\" target=\"_blank\">https://www.hongkongfp.com/2020/01/12/2020-vision-post-80s-movement-water-hongkongers-eyes-now-wide-open/</a><br />\n原文左邊有佢近照同自介，佢淨係話自己lives in exile"},"citedBy":1,"replyTime":"2020-01-12T05:34:53.000Z","msg":"完全唔同左樣<br />\n係咪一路比中共追殺<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"3573314f26fd1927c5ae3170316d6fa1adb2f445","tid":1821164,"uid":470,"like":13,"dislike":0,"score":13,"quote":{"pid":"c7b22cfeda7a831b5f88fe53b11b2c239cb2e006","tid":1821164,"uid":176991,"like":7,"dislike":0,"score":7,"quote":{"pid":"68c084d848814ab64aade22eb81ae388e2b60857","tid":1821164,"uid":470,"like":5,"dislike":1,"score":4,"citedBy":3,"replyTime":"2020-01-12T05:20:09.000Z","msg":"無講佢去左邊<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-01-12T05:30:39.000Z","msg":"<a href=\"https://www.hongkongfp.com/2020/01/12/2020-vision-post-80s-movement-water-hongkongers-eyes-now-wide-open/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hongkongfp.com%2F2020%2F01%2F12%2F2020-vision-post-80s-movement-water-hongkongers-eyes-now-wide-open%2F&d=uClJ75VMDgyJ2T8QnpTVXUBo7c%2BYFxEppcXi0rJe94o%3D&h=01971399\" target=\"_blank\">https://www.hongkongfp.com/2020/01/12/2020-vision-post-80s-movement-water-hongkongers-eyes-now-wide-open/</a><br />\n原文左邊有佢近照同自介，佢淨係話自己lives in exile"},"citedBy":5,"replyTime":"2020-01-12T05:35:08.000Z","msg":"用手機睇要撳佢個名<br />\n張相...........<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"2d39653dad1159ffc0a944c31ae32e46103fe267","tid":1821164,"uid":269125,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-01-12T05:36:14.000Z","msg":"唉，佢走得太前<br />\n想星當年覺得佢係膠既自己兩巴<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"37c6a318879e7aa745ff93e31892c9bd59c22e23","tid":1821164,"uid":2638,"like":10,"dislike":1,"score":9,"citedBy":0,"replyTime":"2020-01-12T05:39:35.000Z","msg":"作為八十後<br />\n你真係大師級<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"d778956ed9dcf41592b992a5278d06c0903ca1a9","tid":1821164,"uid":261773,"like":6,"dislike":3,"score":3,"citedBy":0,"replyTime":"2020-01-12T05:40:48.000Z","msg":"at least 睇得出佢冇對香港失望 <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n利申：慚愧當年有份笑佢"},{"pid":"5ce76fd83a0758ca98534c2b47e3107974e96d15","tid":1821164,"uid":177510,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-12T05:40:50.000Z","msg":"<img src=\"/assets/faces/normal/cry.gi