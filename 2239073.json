assets/faces/big/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"186377575abf025e26fd97c3e57029da2d2533cd","tid":2239073,"uid":176282,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-12T01:16:01.000Z","msg":"跳唔到1cm<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"946221eb99768b58aa45139f80d984893070ddc0","tid":2239073,"uid":358542,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-10-12T01:23:40.000Z","msg":"深蹲、弓箭步呢啲係基本<br />\n同埋拉多啲筋<br />\n睇你係幾嚴重，但後生應該好得番"},{"pid":"d14c7714ab561f1072e9e93d53b411f488f4bccf","tid":2239073,"uid":112845,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-12T01:32:40.000Z","msg":"<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},{"pid":"1a6943c4fffd43ecd9657f7f9a9d76211b98a395","tid":2239073,"uid":210755,"like":0,"dislike":0,"score":0,"quote":{"pid":"9a2be4edcb5776ff5007cd86e2e146c8811c1e37","tid":2239073,"uid":63154,"like":6,"dislike":0,"score":6,"quote":{"pid":"16c145734d1ad8f2d4758df74f001d1eee6f38d3","tid":2239073,"uid":53105,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-11T15:35:35.000Z","msg":"食supplement有無用"},"citedBy":1,"replyTime":"2020-10-11T16:08:56.000Z","msg":"科學上係有文獻支持，但其實作用不大，因為效果太輕微，唔夠練肌肉去保護佢實際"},"citedBy":2,"replyTime":"2020-10-12T01:40:27.000Z","msg":"<img src=\"https://na.cx/i/CVDW2NO.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCVDW2NO.png&h=549f98b9&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/Dxysp09.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDxysp09.jpg&h=7185e150&s={SIZE}\" /><br />\n我個情況，髕骨軟骨磨蝕 幾年前膝頭開刀 <br />\n軟骨補充品, 好似我傷個位咁&quot;入面&quot; 無血管到,無得運啲營養入去修復,無左就係無, 唔同外面啲軟骨咁  不過我覺得均衡飲食+肌肉保養+休息 更更重要"},{"pid":"f42f54a9a79f5990bd329778bfe810053f4d58dd","tid":2239073,"uid":210755,"like":0,"dislike":0,"score":0,"quote":{"pid":"d18a17979ab9100952fda07a0f22aeaac766192a","tid":2239073,"uid":307195,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-11T20:16:22.000Z","msg":"點先知道/做啲咩會感受到蝕左<br />\n以前玩開長跑 你咁講驚驚地"},"citedBy":0,"replyTime":"2020-10-12T01:43:45.000Z","msg":"開頭,痛,發炎, 熱熱地 好似好緊咁,無耐消炎返又無野<br />\n但最尾磨到底 就跪一跪,feel到&quot;仆街 奶撻了&quot; <br />\n要睇軟組織有無咩訊號唔同左,要照MRI"},{"pid":"bc99b77591ee496c6ec581cd5cb91203c96137a1","tid":2239073,"uid":210755,"like":0,"dislike":0,"score":0,"quote":{"pid":"d18a17979ab9100952fda07a0f22aeaac766192a","tid":2239073,"uid":307195,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-11T20:16:22.000Z","msg":"點先知道/做啲咩會感受到蝕左<br />\n以前玩開長跑 你咁講驚驚地"},"citedBy":1,"replyTime":"2020-10-12T02:13:47.000Z","msg":"仲有 膝蓋受力會痛。<br />\n例如落樓梯 跑步.膝頭120度角,哩啲俯沖落膝蓋嘅動作,會明顯好多；<br />\n負重Leg extension 勾腳尖踢 喺gym哩個動作做唔到 會超痛；<br />\n四頭肌撐板 做到, 有點磨擦 但個角度用到大腿受力 膝蓋唔痛<br />\n耐左,膝部肌肉神經反射 會自動波避開膝蓋直接受力嘅動作 大腿肌肉會縮<br />\nps. 個人體驗"},{"pid":"9aa14fc2aac8d85f73d9ce9a9608a8ec386a045d","tid":2239073,"uid":37719,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-12T02:16:32.000Z","msg":"其實練肌肉保護係練邊舊？"},{"pid":"ebb3796d0ea8444453aac228925353af8cfd0471","tid":2239073,"uid":212274,"like":0,"dislike":0,"score":0,"quote":{"pid":"9aa14fc2aac8d85f73d9ce9a9608a8ec386a045d","tid":2239073,"uid":37719,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-12T02:16:32.000Z","msg":"其實練肌肉保護係練邊舊？"},"citedBy":0,"replyTime":"2020-10-12T02:20:52.000Z","msg":"同問"},{"pid":"83285a46f0d66d35d54ec7a2ed2ae6d415441c35","tid":2239073,"uid":210755,"like":0,"dislike":0,"score":0,"quote":{"pid":"9aa14fc2aac8d85f73d9ce9a9608a8ec386a045d","tid":2239073,"uid":37719,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-12T02:16:32.000Z","msg":"其實練肌肉保護係練邊舊？"},"citedBy":0,"replyTime":"2020-10-12T08:10:45.000Z","msg":"膝蓋周邊啲肌肉, 即係成隻腳<br />\n大致分3部份嘅大肌群<br />\n-股四頭肌 即大腿前面<br />\n-股二頭  即大腿後則<br />\n-比目魚肌 即小腿"},{"pid":"d25a6d6362376271f909374e3b9b442b2daac190","tid":2239073,"uid":75193,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-12T08:13:22.000Z","msg":"咁去gym應該練咩同避免練咩？"},{"pid":"53ae9085f9852c0ecf723b71fffde13e6d24d972","tid":2239073,"uid":210755,"like":0,"dislike":0,"score":0,"quote":{"pid":"d25a6d6362376271f909374e3b9b442b2daac190","tid":2239073,"uid":75193,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-12T08:13:22.000Z","msg":"咁去gym應該練咩同避免練咩？"},"citedBy":2,"replyTime":"2020-10-12T12:57:09.000Z","msg":"健身應全面,不該局限某組肌肉, <br />\n概括黎講<br />\n推動作-身體前(胸)<br />\n拉-身體後(背)<br />\n大腿前&amp;後 <br />\n小腿<br />\n做完腿部休息,第2日做上身,對各部位增肌&amp;體態都有幫助<br />\n<br />\n避免做咩動作 視乎你有無傷勢/舊患會影響到你；做負重運動, 記住循序漸進，用較輕重量 慢慢做岩啲動作+比肌肉感受下收縮為主，之後再量力而為加重量<br />\n<br />\n做完記得拉筋伸展, 唔拉筋嘅話 會對關節負荷大左, 一般人唔會發覺 但傷過嘅就feel到問題"},{"pid":"c76fe4788bcf79289d1ed759fb94a4574988f80b","tid":2239073,"uid":49138,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-12T13:11:50.000Z","msg":"想睇私家去照一照, 再問有啲咩運動啱做同suppliment啱食<br />\n去邊度好? 私家醫院定私人診所好?"},{"pid":"d8ae26ec948c337f04ac44879ff36a2ed1f8e5aa","tid":2239073,"uid":75193,"like":0,"dislike":0,"score":0,"quote":{"pid":"53ae9085f9852c0ecf723b71fffde13e6d24d972","tid":2239073,"uid":210755,"like":0,"dislike":0,"score":0,"quote":{"pid":"d25a6d6362376271f909374e3b9b442b2daac190","tid":2239073,"uid":75193,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-12T08:13:22.000Z","msg":"咁去gym應該練咩同避免練咩？"},"citedBy":2,"replyTime":"2020-10-12T12:57:09.000Z","msg":"健身應全面,不該局限某組肌肉, <br />\n概括黎講<br />\n推動作-身體前(胸)<br />\n拉-身體後(背)<br />\n大腿前&amp;後 <br />\n小腿<br />\n做完腿部休息,第2日做上身,對各部位增肌&amp;體態都有幫助<br />\n<br />\n避免做咩動作 視乎你有無傷勢/舊患會影響到你；做負重運動, 記住循序漸進，用較輕重量 慢慢做岩啲動作+比肌肉感受下收縮為主，之後再量力而為加重量<br />\n<br />\n做完記得拉筋伸展, 唔拉筋嘅話 會對關節負荷大左, 一般人唔會發覺 但傷過嘅就feel到問題"},"citedBy":0,"replyTime":"2020-10-12T13:18:58.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />遲啲會跟住做 <br />\n前排拉傷+武漢肺炎停左"},{"pid":"767433e3171a494720d0374e8ab7d8b16d71c4b4","tid":2239073,"uid":210755,"like":0,"dislike":0,"score":0,"quote":{"pid":"c76fe4788b