/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"2ec72c20af730fbf5b148128f4e6fab8f2593e0e","tid":1541114,"uid":172465,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T14:57:59.000Z","msg":"9月8 美領見"},{"pid":"5389bb9c02ded8c95eb6e155f7d733122511f865","tid":1541114,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T15:24:07.000Z","msg":"推"},{"pid":"d2412e5e6a90a123b4d1119c4482643f1e449fc3","tid":1541114,"uid":72800,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T16:20:08.000Z","msg":"<div style=\"text-align: center;\"><blockquote><em>我們成長為自由人。 沒人可讓一個自由的人下跪。<br />\nWe grew up as free people. No one can make a free person kneel.</em><br />\n<span style=\"color: navy;\"><strong>《HONG KONG BE WATER》</strong></span></blockquote></div><br />\n<br />\n<div style=\"text-align: center;\"><span style=\"color: red;\">港共企圖以<strong>錄音、撤回、學季開始</strong><br />\n轉移<strong><span style=\"font-size: x-large;\">太子地鐵傷亡、<br />\n六警壓脊椎休克 <span style=\"color: teal;\">至今嚴重昏迷</span>、<br />\n新屋嶺、<span style=\"color: violet;\">民主人權法案</span>、<br />\n臥底實彈、武警滲透、<span style=\"color: green;\">清朝債 主權問題</span><br />\n</span></strong></span>連串<span style=\"font-size: xx-large;\"><strong>核彈</strong></span><span style=\"color: red;\">事件焦點<br />\n提防 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /> <span style=\"font-size: xx-large;\">政府帶風向</span><br />\n背後繼續大清算 入獄 利刑 一年後被失蹤</span></div><br />\n<br />\n<br />\n<pre><code data-type=\"\">林鄭錄音：事件現時已經上升至「國家主權及國家安全的層次，\n加上世界兩大經濟體前所未有的張力」，她可以做的已經非常少。</code></pre><br />\n<br />\n<div style=\"text-align: right;\"><blockquote><strong><span style=\"color: orange;\"><span style=\"font-size: large;\">英、美、德領事館請願 大遊行</span></span></strong><br />\n審視中英聯合聲明 法定性<br />\n中共正統性<br />\n中共毀約 無視國際社會<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: blue;\">請求國際介入香港前途</span></span></strong> <br />\n<strong><span style=\"font-size: large;\"><span style=\"color: blue;\">施壓制裁港府 還港人雙普選 <br />\n協助制定民主進程</span></span></strong><br />\n香港人道災難 高壓滅聲 白色恐怖 <br />\n執法機器無法無天 受命中共 <br />\n<span style=\"font-size: large;\">港府管治班子失去自治權 聽命中央</span><br />\n實彈恐怖 威嚇扼殺<span style=\"font-size: x-large;\">民主自由</span>現代普世價值<br />\n<strong>人權民主法案 事在必行</strong></blockquote></div><br />\n<br />\n<div style=\"text-align: center;\"><strong>這不單是 反修例活動<br />\n這是屬於香港人的<span style=\"font-size: xx-large;\">時代革命</span></strong></div><br />\n<div style=\"text-align: center;\"><strong><span style=\"font-size: xx-large;\"><ins>流水革命 元年</ins></span></strong></div>"},{"pid":"c2e17f7ba63be5b8603dbec384fdfed47407bcce","tid":1541114,"uid":203723,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T19:43:39.000Z","msg":"推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"aa376ea015f43fb957ecdce6918295840bb63d8d","tid":1541114,"uid":43082,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T21:45:06.000Z","msg":"推"},{"pid":"21ea7e34a329469df3547113b9231c9f8900de7a","tid":1541114,"uid":212182,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T22:22:20.000Z","msg":"推"},{"pid":"10353f513f977a32975169c576e47f8e63bf2cee","tid":1541114,"uid":262557,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T22:27:01.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"e8a99a1de86595a4f529bc18246bff61869976af","tid":1541114,"uid":163435,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T02:11:14.000Z","msg":"推呀"},{"pid":"a7f4d55338492f72caf7598f87b7bb7dbb1f2b8a","tid":1541114,"uid":65747,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T02:15:17.000Z","msg":"一定要去"},{"pid":"f0d83ab26f8a9486125e24c9d58c41ade5b723ce","tid":1541114,"uid":138092,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T02:16:00.000Z","msg":"大大力！<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /><i