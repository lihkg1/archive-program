0b0bfd9ec7fe7f78594cf4501c54ad77579b","tid":1845851,"uid":46404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T11:22:38.000Z","msg":"推到無力"},{"pid":"c8b77d98aaa970431804fc10ed5219223d19d80a","tid":1845851,"uid":46404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T11:22:57.000Z","msg":"係咪我垃雜"},{"pid":"396a65b05fd87371a74b53ca8f59b245dd23b37c","tid":1845851,"uid":46404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T11:23:09.000Z","msg":"<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/clown2.gif\" class=\"hkgmoji\" />"},{"pid":"7587f424d1650d459659a5f7c6e86230fa088066","tid":1845851,"uid":46404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T11:23:34.000Z","msg":"單機咁"},{"pid":"a4bef797401eb9c82be1addf2e4d561509212904","tid":1845851,"uid":344033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T11:23:34.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: purple;\"><span style=\"color: purple;\"><span style=\"color: violet;\">請廣傳 </span></span></span></span><br />\n<br />\n<a href=\"https://www.facebook.com/112357283631796/posts/117867026414155/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F117867026414155%2F%3Fd%3Dn&d=FyFnEhDp3tEmtF3AT420Rm0Q%2Fwx8zutUsTDhO6XOofs%3D&h=4d16680e\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/117867026414155/?d=n</a><br />\n<br />\n手足裝備抗沙士：護目鏡<br />\n整體分析：<a href=\"https://www.facebook.com/112357283631796/posts/116690396531818/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F116690396531818%2F%3Fd%3Dn&d=FyFnEhDp3tEmtF3AT420Rm0Q%2Fwx8zutUsTDhO6XOofs%3D&h=97f7145b\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/116690396531818/?d=n</a><br />\n<br />\n首選：Sellstrom S80225/S80226 Wildland Fire Goggles （戴眼鏡都用得）<br />\n<a href=\"https://www.amazon.com/Sellstrom-Wildland-Goggles-Non-Vented-Anti-Fog/dp/B07DJVPL9Q\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.amazon.com%2FSellstrom-Wildland-Goggles-Non-Vented-Anti-Fog%2Fdp%2FB07DJVPL9Q&d=FyFnEhDp3tEmtF3AT420Rm0Q%2Fwx8zutUsTDhO6XOofs%3D&h=65bc7b2f\" data-auto-link target=\"_blank\">https://www.amazon.com/Sellstrom-Wildland-Goggles-Non-Vented-Anti-Fog/dp/B07DJVPL9Q</a><br />\n<br />\nSellstrom 依款眼罩，上年九月果陣，已經係前線手足標準裝備，有手足認證，包保放心！其中，依款眼罩有兩大特點。<br />\n<br />\n第一，依款眼罩寫明係 non-vented，即係氣密。戴左之後，基本上就阻隔左外面嘅空氣進入眼罩，所以擋到TG，亦都擋到帶病毒嘅飛沫同空氣，乜春都入唔到眼。依個亦都係佢可以俾美國消防員救山火果陣用嘅原因。氣密係眼罩第一重要條件，如果唔係氣密，病毒同TG都可以經眼罩邊位入眼，大陸衛健委都講明病毒傳染性不斷上升，美國有教授都講左武漢沙士嘅reproductive rate 高過曬佢見過佢嘅病毒，證明今次係非常嚴重，必須要用高規格嘅產品保護自己！<br />\n<br />\n第二，依款眼罩經過 ANSI Z87+ 嘅驗證，保護性極高！<br />\nANSI Z87+嘅定義如下：<br />\n&lsquo;Each product must go through rigorous third-party testing which simulates hazards such as impact by flying objects and debris, high mass impact, and sharp object penetration. In each testing scenario, the lenses and frame must stay intact to pass&rsquo;<br />\n根據網上一個對ANSI Z87+ 眼罩嘅測試，散彈槍都射佢唔穿，所以ANSI Z87+ 嘅standard 係非常高，亦都只有依種眼罩嘅保護性先可以保護前線免受橡膠子彈同布袋彈威脅。<br />\n<br />\n次選：Pyramex CAPSTONE (G504DT或其他型號）<br />\n<a href=\"https://www.amazon.com/Pyramex-Capstone-Direct-Indirect-Anti-Fog/dp/B003UUEW88\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.amazon.com%2FPyramex-Capstone-Direct-Indirect-Anti-Fog%2Fdp%2FB003UUEW88&d=FyFnEhDp3tEmtF3AT420Rm0Q%2Fwx8zutUsTDhO6XOofs%3D&h=7e472491\" data-auto-link target=\"_blank\">https://www.amazon.com/Pyramex-Capstone-Direct-Indirect-Anti-Fog/dp/B003UUEW88</a><br />\n<br />\n第一，依款眼罩有氣密帽，應該同樣做到氣密效果，但係因為佢嘅氣密帽可以拆卸，多左個連接位，所以氣密保護性會低小小（始終多個連接位就多個出錯機會）。<br />\n第二，依款眼罩經過D3 測試，證實可以防水滴同化學劑嘅飛淺，理論上有足夠防水性能。<br />\n第三，依款眼罩經過MIL-PRF 32432 美軍標準測試，對子彈衝擊力有一定防禦。<br />\n<br />\n最後選擇：泳鏡（仲易買過平光鏡）<br />\n<br />\n泳鏡顧名思義，就係for 遊水，氣密效果有一定嘅保證，同埋求其一間運動鋪都可以買到，買近視鏡嘅話眼睛都唔洗戴，幾十蚊就有，保護性一定好過平光鏡，不過如果係講嘢都要除口罩，放屁要除褲，戴左帽可能腦都用唔到嘅人，可能佢戴左就會睇唔野。<br />\n<br />\n大家幫幫手，like &amp; share 等多啲人睇到！<br />\n<br />\n#屠龍 #藍絲 #藍屍 #黃色經濟圈 #黃店 #裝備 #口罩 #武漢肺炎 #武漢 #P95 #文宣 #N95 #肺炎 #沙士 #香港 #支那人 #高鐵 #眼罩 #tg #lihkg #連登 #高登 #d100 #黑警"},{"pid":"42598302ace9fbe583c77f4b2ef4e24400b93e0b","tid":1845851,"uid":46404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T11:25:29.000Z","msg":"咁揾人推下"}]}