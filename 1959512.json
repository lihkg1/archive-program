ji\" />"},{"pid":"75ae201ba69db6d31f65bd92a7ac1cbf2c05afb1","tid":1959512,"uid":79516,"like":0,"dislike":0,"score":0,"quote":{"pid":"896969e9395357782f4e8d57787b21910eb08c9b","tid":1959512,"uid":315070,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-05T13:55:34.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-05T14:05:11.000Z","msg":"識人讀先修部。佢地講過比我聽係比啲中文唔好或自己想入唧大學個人申請同聯招(唔知係咪咁叫)冇offer，先去讀一年僑大(即先修部)，想用呢個成績去報當當地大學。<br />\n但先修部位置係新北市林口區，林口係山上，長年非常潮濕，時不時有大霧，勁到你揸車會睇唔到前面架車。<br />\n<br />\n利申: 住過林口2年"},{"pid":"0eb9c1c641f97d6239e92322079a54701c6dcc89","tid":1959512,"uid":315070,"like":0,"dislike":0,"score":0,"quote":{"pid":"75ae201ba69db6d31f65bd92a7ac1cbf2c05afb1","tid":1959512,"uid":79516,"like":0,"dislike":0,"score":0,"quote":{"pid":"896969e9395357782f4e8d57787b21910eb08c9b","tid":1959512,"uid":315070,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-05T13:55:34.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-05T14:05:11.000Z","msg":"識人讀先修部。佢地講過比我聽係比啲中文唔好或自己想入唧大學個人申請同聯招(唔知係咪咁叫)冇offer，先去讀一年僑大(即先修部)，想用呢個成績去報當當地大學。<br />\n但先修部位置係新北市林口區，林口係山上，長年非常潮濕，時不時有大霧，勁到你揸車會睇唔到前面架車。<br />\n<br />\n利申: 住過林口2年"},"citedBy":1,"replyTime":"2020-04-05T14:21:39.000Z","msg":"<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" />"},{"pid":"1c3375f54d14a9ad54c7e7ea5c08524107453670","tid":1959512,"uid":79516,"like":0,"dislike":0,"score":0,"quote":{"pid":"0eb9c1c641f97d6239e92322079a54701c6dcc89","tid":1959512,"uid":315070,"like":0,"dislike":0,"score":0,"quote":{"pid":"75ae201ba69db6d31f65bd92a7ac1cbf2c05afb1","tid":1959512,"uid":79516,"like":0,"dislike":0,"score":0,"quote":{"pid":"896969e9395357782f4e8d57787b21910eb08c9b","tid":1959512,"uid":315070,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-05T13:55:34.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-05T14:05:11.000Z","msg":"識人讀先修部。佢地講過比我聽係比啲中文唔好或自己想入唧大學個人申請同聯招(唔知係咪咁叫)冇offer，先去讀一年僑大(即先修部)，想用呢個成績去報當當地大學。<br />\n但先修部位置係新北市林口區，林口係山上，長年非常潮濕，時不時有大霧，勁到你揸車會睇唔到前面架車。<br />\n<br />\n利申: 住過林口2年"},"citedBy":1,"replyTime":"2020-04-05T14:21:39.000Z","msg":"<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-05T16:22:56.000Z","msg":"我認為唔好讀先修部，因為真係好浪費時間。去到第度讀書，好多引誘，唔會想讀書，當然睇人，我係咁。<br />\n同埋，你如果唸住係個邊做野先讀，當然要睇你咩科咩大學，但有個大問題係好多老闆唔會想幫你搞工作證，手續好麻煩。香港又唔可台灣啲大學學位，要多個步驟去考個咩資歷架構處定乜，你查下，先至認可。<br />\n所以，除非你有啲野好想學，好有理想，否則唔好浪費時間。"},{"pid":"a3f0a8fd976de5ffd36f9e2802c6ef034a52b8f7","tid":1959512,"uid":315070,"like":0,"dislike":0,"score":0,"quote":{"pid":"1c3375f54d14a9ad54c7e7ea5c08524107453670","tid":1959512,"uid":79516,"like":0,"dislike":0,"score":0,"quote":{"pid":"0eb9c1c641f97d6239e92322079a54701c6dcc89","tid":1959512,"uid":315070,"like":0,"dislike":0,"score":0,"quote":{"pid":"75ae201ba69db6d31f65bd92a7ac1cbf2c05afb1","tid":1959512,"uid":79516,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-05T14:05:11.000Z","msg":"識人讀先修部。佢地講過比我聽係比啲中文唔好或自己想入唧大學個人申請同聯招(唔知係咪咁叫)冇offer，先去讀一年僑大(即先修部)，想用呢個成績去報當當地大學。<br />\n但先修部位置係新北市林口區，林口係山上，長年非常潮濕，時不時有大霧，勁到你揸車會睇唔到前面架車。<br />\n<br />\n利申: 住過林口2年"},"citedBy":1,"replyTime":"2020-04-05T14:21:39.000Z","msg":"<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-05T16:22:56.000Z","msg":"我認為唔好讀先修部，因為真係好浪費時間。去到第度讀書，好多引誘，唔會想讀書，當然睇人，我係咁。<br />\n同埋，你如果唸住係個邊做野先讀，當然要睇你咩科咩大學，但有個大問題係好多老闆唔會想幫你搞工作證，手續好麻煩。香港又唔可台灣啲大學學位，要多個步驟去考個咩資歷架構處定乜，你查下，先至認可。<br />\n所以，除非你有啲野好想學，好有理想，否則唔好浪費時間。"},"citedBy":0,"replyTime":"2020-04-05T16:25:24.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"c3979d184f61128c122e38d10253e9d327c28ce8","tid":1959512,"uid":67822,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-06T00:24:51.000Z","msg":"<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"73f540ec2de01444f7856c