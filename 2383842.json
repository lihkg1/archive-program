r8fgKgIv0=/1329x886/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/MWKJYFQ2JBERDP5SHQFT3CU3DE.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FaZ5Tqv0Rnj_eOB7zspr8fgKgIv0%3D%2F1329x886%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FMWKJYFQ2JBERDP5SHQFT3CU3DE.JPG&h=dcbf98f6&s={SIZE}\" />"}]}