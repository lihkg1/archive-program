ets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d342e4f2aba9e7b7b3cf3532b48cc6f213afa745","tid":1630591,"uid":201031,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T13:06:30.000Z","msg":"鬼叫有班柒頭死都要搞咩時間表<br />\n完全唔畀人停手"},{"pid":"af76eb59b991739a80adcb1df37242f5ea6d0207","tid":1630591,"uid":283668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T13:08:59.000Z","msg":"<span style=\"color: gold;\"><span style=\"font-size: xx-large;\">兄弟！一齊拆！</span></span><br />\n因為個宣言第一段有中共味道呀<br />\n中777同習圈套呀<br />\n<br />\n幫手report<br />\n<img src=\"https://na.cx/i/0tfwXea.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0tfwXea.png&h=49b8c28a&s={SIZE}\" /><br />\n<a href=\"https://twitter.com/ParliamentHK\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2FParliamentHK&d=5qKB33MXKEG0NT2XrWEv6s0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=d2a5346a\" data-auto-link target=\"_blank\">https://twitter.com/ParliamentHK</a><br />\n<br />\n對家已起底，見一個report 一個<br />\n見圖<br />\n<img src=\"https://na.cx/i/mcqdrbw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fmcqdrbw.jpg&h=a4feb115&s={SIZE}\" /><br />\n<br />\n陳雲：共產黨玩嘢，香港人領嘢。咁都領嘢？枉為香港人。香港人不聽陳雲的話，犯上政治錯誤，犧牲幾多人都是被共產黨收割，之後糟蹋。<br />\n如果你識字，就知道第一句是共產黨的意識形態。破舊立新，而且強調歷史發展的必然性。<br />\n香港人昨晚十八區，宣讀共產主義宣言，而且宣言隻字不提美國為香港人權立法監護香港的貢獻，美國的有識之士被香港人激死了。<br />\n<a href=\"https://www.facebook.com/589657224/posts/10157462752772225?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F589657224%2Fposts%2F10157462752772225%3Fsfns%3Dmo&d=5qKB33MXKEG0NT2XrWEv6s0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=ecaa1d6c\" data-auto-link target=\"_blank\">https://www.facebook.com/589657224/posts/10157462752772225?sfns=mo</a><br />\n<br />\n<br />\n同時有香港獨立黨出聲明攻擊香港人權及民主法、又有臨時議會成立、又有臨時政府成立、又有連登「我有個讀政治的朋友」寫了香港憲法？同時又有練乙燈出文再提港獨？全部舉動幾日內急急推出，全部都是指向推翻美國「人權及民主法」的保障香港自治的立法前設？全部都是港共用了緊急法之後才忽然出現？<br />\n<a href=\"https://www.facebook.com/100002094159071/posts/2498430470236734?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F100002094159071%2Fposts%2F2498430470236734%3Fsfns%3Dmo&d=5qKB33MXKEG0NT2XrWEv6s0oCCb%2BFWW1Qd8KXu5iEc8%3D&h=03abb543\" data-auto-link target=\"_blank\">https://www.facebook.com/100002094159071/posts/2498430470236734?sfns=mo</a>"},{"pid":"19c441184cac7836e509f046e14c670a79f346e7","tid":1630591,"uid":28970,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-06T13:10:50.000Z","msg":"推"},{"pid":"4dc49c98a25b4840aa4df3661997a0eb69f07a3b","tid":1630591,"uid":28970,"like":0,"dislike":0,"score":0,"quote":{"pid":"c315a17daad8cee865173d43e589adeb74b2ddf4","tid":1630591,"uid":119277,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T13:05:22.000Z","msg":"起碼仲有幾個星期先過喎"},"citedBy":1,"replyTime":"2019-10-06T13:11:03.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />下"},{"pid":"1e5326018bc93b2a4a081e95f5a1d5de1bc27c07","tid":1630591,"uid":258696,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-06T13:11:18.000Z","msg":"<span style=\"font-size: x-large;\"><span style=\"color: red;\">大家 呢幾日都係行動日<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><br />\n但連登都無比大陸DDos攻擊<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><br />\n<br />\n就證明左係大量五毛做緊野 <img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><br />\n又分化又風向<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" /><br />\n</span></span><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: blue;\">我地係時候要醒下<br />\n<br />\n不分化 不割蓆 不篤灰</span></span></strong><br />\n<br />\n<span style=\"color: gold;\">跟住就係開始做正經野：<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><br />\n<br />\n1. 推紅色的士撞人單野<br />\n<br />\n2.推黑警又當街踢人單野<br />\n<br />\n3.九龍塘軍營入面有綠色防暴警既片<br />\n<br />\n4.解釋返裝修既原因比外國知<br />\n<br />\n5.宣傳黑紅藍黃既概念</span><br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />光復香港，時代革命！<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /></strong><br />\n<br />\n<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />我地唔好再比五毛搞爆連登<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /></span>"},{"pid":"4f9941d8cb209b8b5591d968811dd72032841bae","tid":1630591,"uid":53026,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-06T13:12:08.000Z","msg":"而且匪政權有籍口取消區議會選舉"},{"pid":"da954855c66b9f7fcde21da059ee6bd2bf7eb46f","tid":1630591,"uid":28970,"like":0,"dislike":0,"score":0,"quote":{"pid":"d6eb768c38918519893da020b0511ba04aa756aa","tid":1630591,"uid":81273,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T13:05:39.000Z","msg":"11月<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-10-06T13:12:28.000Z","msg":"睇新聞又話10月14嘅<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />屌"},{"pid":"528fafbe2bcb2bb8500d3a48f5dc43ab69d83461","tid":1630591,"uid":288900,"like":0,"dislike":0,"score":0,"quote":{"pid":"9e2749e18f249c235abe5b383372428144ff6c85","tid":1630591,"uid":28970,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-06T12:58:51.000Z","msg":"大家捱左3個月 唔爭在得多個令星期<br />\n依加連登中門大開5毛 Mon post狗 風向分化撚齊集<br />\n咁大行動都冇DDOS大家諗諗 淋奠落咁大賭注一定想大家一獲熟<br />\n<br />\n忍下手等過左再清算再準備下一波行動<br />\n<br />\n<img src=\"https://na.cx/i/AWhCSPc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAWhCSPc.jpg&h=e2102d0b&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/5Z2WoVT.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F5Z2WoVT.jpg&h=10413557&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-10-06T13:13:05.000Z","msg":"贊成,我地真係要智取....唔好俾仇恨蓋住理性!!!! 等左咁多年,美國人權法係唔可以有任何變數!!!!"},{"pid":"c85c0f968af169910e261d5f0484ab1a6c0d3df2","tid":1630591,"uid":249794,"like":0,"disl