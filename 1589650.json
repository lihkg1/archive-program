Fi%2FqS9jQCv.jpg&h=769335de&s={SIZE}\" /><img src=\"https://na.cx/i/Hqy41Ka.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHqy41Ka.jpg&h=a6dbaf1c&s={SIZE}\" /><img src=\"https://na.cx/i/WJQZQCw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWJQZQCw.jpg&h=ba39fbf6&s={SIZE}\" />"},{"pid":"2a59ac270f54b34378513bf98a2e02ee6441d37c","tid":1589650,"uid":321345,"like":0,"dislike":0,"score":0,"quote":{"pid":"03aa6fccc0b87ff204711cf8f0d7d4d3ee9687ae","tid":1589650,"uid":70493,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-09-23T11:18:32.000Z","msg":"<a href=\"https://www.youtube.com/watch?v=5iJcglMDv0c\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D5iJcglMDv0c&d=%2B%2BEjZc3BRqGg7MXYxMXK6wAFq6fDUSnvy6go1IBd1q0%3D&h=bde0eddb\" target=\"_blank\">https://www.youtube.com/watch?v=5iJcglMDv0c</a><br />\n紙皮塞水 - 豬咁蠢 - 戇鳩鳩"},"citedBy":0,"replyTime":"2019-09-23T11:58:29.000Z","msg":"阿叔係先知<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"1d8e0fd004edea2a7350009472c734d9173e6cb2","tid":1589650,"uid":172345,"like":0,"dislike":0,"score":0,"quote":{"pid":"8bdaa2f13c02f88f3b8074d15492a509fd143781","tid":1589650,"uid":142433,"like":0,"dislike":0,"score":0,"quote":{"pid":"3790817eeb9684d4b8881dfc613b7fc616fffccf","tid":1589650,"uid":289775,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-09-23T11:49:05.000Z","msg":"最記得有條片班警察陰濕捉單車，<br />\n<br />\n串個靚仔，頭耷耷，眼濕濕，下巴有滴汁<br />\n笑死人了<br />\n<br />\n其實極醜惡畀人起咗底依家全世界都知佢係邊個啦， 佢依家響度關注緊啲流浪狗page，日日畀人屌緊。"},"citedBy":1,"replyTime":"2019-09-23T11:55:14.000Z","msg":"佢日日報漁農捉狗 <br />\n仲攞野食引狗 之後扮比狗咬"},"citedBy":0,"replyTime":"2019-09-23T12:06:12.000Z","msg":"有冇link<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"1a0e60363c415d396ec6113e3dce0e081e41de35","tid":1589650,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-23T13:21:46.000Z","msg":"但佢見到黑警會笠水。。。"},{"p