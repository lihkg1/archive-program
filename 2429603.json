g src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />唔係我屌撚到你老母個閪都爛<img src=\"/assets/faces/mouse/fuck.gif\" class=\"hkgmoji\" /><br />\n講緊你呀柒頭<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />做咩死撚左去對面馬路啊<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /></del></blockquote>"},{"pid":"20b65e7f9519ffce56ad18387aaf8eba31aa12c3","tid":2429603,"uid":355915,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e83b7bed6b5d55652f426094ebaf9e158685f56f","tid":2429603,"uid":74751,"like":1,"dislike":1,"score":0,"quote":{"pid":"17303de86906bcc0ea4ce333d04eda7a08f43e10","tid":2429603,"uid":355915,"like":0,"dislike":5,"score":-5,"quote":{"pid":"30c55d400a267740c1cd632db60244e1b911e5f3","tid":2429603,"uid":127610,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-02T12:29:26.000Z","msg":"其實你地做登記的係咩職位？<br />\n文員？護士？"},"citedBy":2,"replyTime":"2021-03-02T12:31:15.000Z","msg":"我果日既position係係door疏導人流同幫人填form入去登記"},"citedBy":1,"replyTime":"2021-03-02T13:42:48.000Z","msg":"又中又英 講野都唔柒識"},"citedBy":0,"replyTime":"2021-03-02T15:28:47.000Z","msg":"中英夾雜有問題？"}],"pinned":{"pid":"82c669b9762098885c70e868c13dad3542c8d9d4","tid":2429603,"uid":355915,"like":11,"dislike":7,"score":4,"citedBy":2,"replyTime":"2021-03-02T12:21:56.000Z","msg":"遇到閪客必須毫不留情地屌佢老母<img src=\"/assets/faces/mouse/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cow/power.gif\" class=\"hkgmoji\" />"}}