95%E6%B2%BB%E6%84%88%E7%B3%96%E5%B0%BF%E7%97%85.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh-hant.hotbak.net%2Fkey%2F%25E7%25BE%258E%25E5%259C%258B%25E5%25BE%25B9%25E5%25BA%2595%25E6%25B2%25BB%25E6%2584%2588%25E7%25B3%2596%25E5%25B0%25BF%25E7%2597%2585.html&d=FyOxfEvlGqeE3CGJWKQQl3XW3JPDzH8o%2FFP8rJ6jlcg%3D&h=86933188\" data-auto-link target=\"_blank\">https://zh-hant.hotbak.net/key/%E7%BE%8E%E5%9C%8B%E5%BE%B9%E5%BA%95%E6%B2%BB%E6%84%88%E7%B3%96%E5%B0%BF%E7%97%85.html</a>"},"citedBy":0,"replyTime":"2021-02-01T14:59:41.000Z","msg":"Content farm<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n而且就咁睇篇野都寫到明未做人體測試<br />\n重要成篇都係到吹捧中国<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"bd6bb12dfee541d7dc17a0e3ac8b2ca4c31c3560","tid":2390430,"uid":2114,"like":2,"dislike":0,"score":2,"quote":{"pid":"bd4e5ccf1975ba53989f2c7492addf8e1d004a93","tid":2390430,"uid":267918,"like":0,"dislike":2,"score":-2,"quote":{"pid":"ed4b396c5a8369b6b119914cfaa1dd82945e5850","tid":2390430,"uid":28031,"like":1,"dislike":0,"score":1,"quote":{"pid":"6ff27b435af9630835058d9256f7d3fb57b61aa8","tid":2390430,"uid":267918,"like":0,"dislike":4,"score":-4,"citedBy":2,"replyTime":"2021-02-01T14:51:42.000Z","msg":"食屎啦護士仔<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />好多教授論文都有講斷食對身體好"},"citedBy":1,"replyTime":"2021-02-01T14:52:25.000Z","msg":"邊篇論文教糖尿病人斷食呀傻閪"},"citedBy":2,"replyTime":"2021-02-01T14:54:40.000Z","msg":"<a href=\"https://zh-hant.hotbak.net/key/%E7%BE%8E%E5%9C%8B%E5%BE%B9%E5%BA%95%E6%B2%BB%E6%84%88%E7%B3%96%E5%B0%BF%E7%97%85.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh-hant.hotbak.net%2Fkey%2F%25E7%25BE%258E%25E5%259C%258B%25E5%25BE%25B9%25E5%25BA%2595%25E6%25B2%25BB%25E6%2584%2588%25E7%25B3%2596%25E5%25B0%25BF%25E7%2597%2585.html&d=FyOxfEvlGqeE3CGJWKQQl3XW3JPDzH8o%2FFP8rJ6jlcg%3D&h=86933188\" data-auto-link target=\"_blank\">https://zh-hant.hotbak.net/key/%E7%BE%8E%E5%9C%8B%E5%BE%B9%E5%BA%95%E6%B2%BB%E6%84%88%E7%B3%96%E5%B0%BF%E7%97%85.html</a>"},"citedBy":0,"replyTime":"2021-02-01T15:00:47.000Z","msg":"<a href=\"https://www.ncbi.nlm.nih.gov/pmc/articles/PMC6521152/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ncbi.nlm.nih.gov%2Fpmc%2Farticles%2FPMC6521152%2F&d=FyOxfEvlGqeE3CGJWKQQl3XW3JPDzH8o%2FFP8rJ6jlcg%3D&h=a47afd90\" target=\"_blank\">https://www.ncbi.nlm.nih.gov/pmc/articles/PMC6521152/</a><br />\n<br />\nTLDR<br />\n睇下conclusion 講乜<br />\n<br />\nIntermittent fasting, when undertaken for health reasons in patients with diabetes mellitus, both types 1 and 2, has been shown in a few small human studies to induce weight loss and reduce insulin requirements. While these findings are exciting and have captured the imagination of many people, a wise approach to implementing fasting regimens and using them in the long term among this specific population is required. Much of the hype surrounding fasting arises from animal studies, which only suggest what human research should be conducted; implementation of human interventions should not be based on animal research.<br />\n<br />\nLong-term benefits of fasting, including cardiovascular risk reduction, remain to be fully studied and elucidated, especially in humans. Clinicians should temper the enthusiasm for fasting with the reality that the benefits and risks in humans remain largely unexplored and the benefits may take months to years to appear or be fully realized. Good evidence from epidemiologic studies, pilot interventional trials, and a few randomized trials does suggest that the benefits of fasting outweigh the potential harms in the average individual. People with diabetes, however, are not the average individual, and their personal needs require more careful consideration at the beginning of and during the use of a fasting regimen. With proper medication adjustment and self-monitoring of blood glucose levels though, intermittent fasting can be encouraged and safely implemented among people with diabetes."},{"pid":"851c3eab77bdfc26ee69300b2a228cf7e8b606e7","tid":2390430,"uid":198389,"like":0,"dislike":0,"score":0,"quote":{"pid":"15de155d6fc68ae7e0fc32e1517a50d2df7eff6f","tid":2390430,"uid":28031,"like":8,"dislike":1,"score":7,"quote":{"pid":"d0419edc25cab0918f352f68bd8fbaf0b5edecce","tid":2390430,"uid":267918,"like":0,"dislike":7,"score":-7,"quote":{"pid":"9d1e02e7de297f8ae5ba91f86b6c69b29c1e9af4","tid":2390430,"uid":28031,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2021-02-01T14:42:17.000Z","msg":"屌你老母唔識就唔好出黎鳩噏弱智少陣啦 <br />\n打左insulin/食左降血糖藥唔食野會hypoglycaemia架<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-02-01T14:45:13.000Z","msg":"糖尿病控制得好可以唔洗食藥<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" />食藥會愈食愈多傻閪"},"citedBy":2,"replyTime":"2021-02-01T14:49:35.000Z","msg":"屌你老母你真係弱智閪嚟柒左就認啦<br />\n少食係為左你個血糖唔好因為食得多而一下升太高<br />\n多餐係因為要維持血糖係正常水平防止hypogly<br />\n你去邊到睇醫生佢都係咁樣教你 唔好上網睇兩篇野教斷食教168就以為自己大師啦<br />\n<br />\n利申：傻閪護士仔"},"citedBy":0,"replyTime":"2021-02-01T15:04:52.000Z","msg":"唔係食親嘢就會升高血糖<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n只要食啱就算一餐1000kcal血糖都可以唔升"},{"pid":"0d95e5982361b4fceb5ffd8fdf7e6104b2e4b72d","tid":2390430,"uid":251688,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-02-01T15:16:16.000Z","msg":"無醫療背景真係唔好鳩up<br />\n<br />\n少食多餐本身係無錯<br />\n原意係要病人唔好一次食太多野(先唔計食咩先)<br />\n避免血糖突然爆升<br />\n咁每餐份量少左照計就要分開多幾次食補返條數<br />\n<br />\n而一日一餐/168就似係玩鳩病人多d<br />\n先唔講老人家病人一日食一餐點頂得順<br />\n<br />\n168而又要控糖對一般老人家有幾大負擔<br />\n而咁做又為左咩野？<br />\n修身減肥？咪玩我啦<br />\n<br />\n當然，如果有恒心耐性可以試下低糖甚至生胴飲食<br />\n但呢d正常後生先適合玩<br />\n唔好咁搞老人家"}]}