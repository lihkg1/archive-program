林鄭月娥與食物及衞生局局長陳肇始今日快閃天水圍。<br />\n<br />\n有連登網民發現林鄭月娥中午約12時15分，現身天水圍天秀路公園，食物及衞生局局長陳肇始亦有陪伴在側。"},{"pid":"194f123484f8f0b4aa146e257645439874ca6802","tid":1426994,"uid":124655,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T05:08:12.000Z","msg":"推"},{"pid":"024af75e6018492fc3d6847abb403b53f2596e4a","tid":1426994,"uid":124655,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2019-08-07T05:09:24.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://na.cx/i/cs6Low7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%2Fi%2Fcs6Low7.jpg&h=1a481670&s={SIZE}\" />"},{"pid":"61647c3782993fd46988220ca64cb053775a855b","tid":1426994,"uid":124655,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T05:09:38.000Z","msg":"有冇人要買餸"},{"pid":"20021cbd33d65fa1598844629c2460cc8134612f","tid":1426994,"uid":216276,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T05:11:43.000Z","msg":"<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"ca97dacbe4792b3cfb9d3fac282a479ceb99c2bd","tid":1426994,"uid":154460,"like":2,"dislike":0,"score":2,"quote":{"pid":"024af75e6018492fc3d6847abb403b53f2596e4a","tid":1426994,"uid":124655,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2019-08-07T05:09:24.000Z","msg":"<img src=\"https://i.lihkg.com/540/https://na.cx/i/cs6Low7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%2Fi%2Fcs6Low7.jpg&h=1a481670&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-08-07T05:13:17.000Z","msg":"Dllm行街市有撚用咩<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"f0afe701c9887464209980a89e5280686bf3c493","tid":1426994,"uid":36543,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T05:14:02.000Z","msg":"見到佢既巴打麻煩大大聲屌尻佢賣港賊<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"8eebfd966