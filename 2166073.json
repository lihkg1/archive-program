ig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"a815df29f1b9c190b227b97bf93a34b1d37e1810","tid":2166073,"uid":223407,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-20T08:09:27.000Z","msg":"9.7<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" />"},{"pid":"6515b46b17d1b5630f43ddab18a35bde6185088d","tid":2166073,"uid":223407,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-20T08:09:40.000Z","msg":"9.8<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"535adbbbfc62fb09b534ba7bbb4e61737baee851","tid":2166073,"uid":223407,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-20T08:09:55.000Z","msg":"9.9<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" />"},{"pid":"0000c3f818f071fed85e8f70d9690e8af121c95a","tid":2166073,"uid":223407,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-20T08:10:24.000Z","msg":"9.91... <img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cheerup.gif\" class=\"hkgmoji\" />"},{"pid":"f48174c426c57ce82d2f9ccadec6add80d05357b","tid":2166073,"uid":205469,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-20T08:10:33.000Z","msg":"1）人哋下議院係有法律效力。而家呢個民間議會一啲法律效力都冇。<br />\n<br />\n咁初選都冇法律效力<br />\n<br />\n依家有2條路<br />\n<br />\n一係全部總辭，留返4個被DQ嘅喺度篤眼篤鼻<br />\n一係2級議會，由初選勝出者主導泛民嘅行動同投票意向"},{"pid":"da6ac160a543d3db3c40da4062561832e9739d8c","tid":2166073,"uid":223407,"like":0,"dislike":0,"score":0,"quote":{"pid":"f48174c426c57ce82d2f9ccadec6add80d05357b","tid":2166073,"uid":205469,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-20T08:10:33.000Z","msg":"1）人哋下議院係有法律效力。而家呢個民間議會一啲法律效力都冇。<br />\n<br />\n咁初選都冇法律效力<br />\n<br />\n依家有2條路<br />\n<br />\n一係全部總辭，留返4個被DQ嘅喺度篤眼篤鼻<br />\n一係2級議會，由初選勝出者主導泛民嘅行動同投票意向"},"citedBy":1,"replyTime":"2020-08-20T08:14:48.000Z","msg":"人哋下級議會可以影響上級議會唔單止投票咁簡單，仲有否決權。<br />\n<br />\n我哋講民間議會唔能夠控制到泛民不特止，就算控制到泛民，依然冇否決政府惡法嘅能力。<br />\n<br />\n仲要再加上破壞一國兩制。<br />\n<br />\n咁多唔好處點解仲要繼續行落去？<br />\n<br />\n<br />\n香港已經嚟到呢一日，點解仲走去行原本舊有政制嘅路線，而且仲要俾佢差落去（違憲）？"}],"pinned":{"pid":"b474a51cf831237344313ffc33a248e31c0b6f58","tid":2166073,"uid":223407,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-20T08:24:40.000Z","msg":"班泛民連逃犯條例都阻止唔到，只要幾個保安就搞掂你嘅所謂搗亂。<br />\n<br />\n依家需要係政制改革，唔係呢啲象徵式袋住先。已經有外國咁支持，呢個時候唔出聲（總辭）+香港已經輸到呢個程度仲繼續退讓，（都唔好講呢個時候仲好意思接受中共委任但係收納稅人嘅錢），仲要輸到幾時？"}}