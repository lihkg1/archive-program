me":"2020-09-26T05:24:41.000Z","msg":"上得位就知咩事"},{"pid":"089c85f8a2507082c385fc0100940fe7ae287da7","tid":2218061,"uid":70786,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-09-26T05:26:03.000Z","msg":"<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"d3ad4f0bcd8a233b87a61669e167815adc428ccd","tid":2218061,"uid":232237,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-09-26T05:28:21.000Z","msg":"<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"}]}