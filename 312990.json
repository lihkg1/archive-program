mg src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"c26d623e41e60ddfb3bf4726a3fb30fcd654d659","tid":312990,"uid":5547,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-09T02:59:56.000Z","msg":"<blockquote><blockquote>樓主已經柒左</blockquote><br />\n點樣柒法<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n<br />\n根本冇講過美國船冇生銹 比人屈跟住幾件和應<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n平心而論實際用咗唔夠人哋五分一 生銹都嚴重過人<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n反還反<br />\n你柒少陣好唔好？<br />\n隻Belfast係博物館船黎<br />\n一會再行而且用好撚多錢去保養同保持新淨<br />\n你唔講埋入去佢engine room睇下？ <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1fb60925769d94151505385fb9c537713cce592a","tid":312990,"uid":4493,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-07-09T03:22:10.000Z","msg":"<blockquote><blockquote><blockquote>樓主已經柒左</blockquote><br />\n點樣柒法<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n<br />\n根本冇講過美國船冇生銹 比人屈跟住幾件和應<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n平心而論實際用咗唔夠人哋五分一 生銹都嚴重過人<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n反還反<br />\n你柒少陣好唔好？<br />\n隻Belfast係博物館船黎<br />\n一會再行而且用好撚多錢去保養同保持新淨<br />\n你唔講埋入去佢engine room睇下？ <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n遼寧號大部份時間泊喺港口 本身就接近博物館船<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <br />\n<br />\n舊年11月去完 我記得入場費成1X-20磅<br />\n機房大約咁嘅狀態<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 好過天星小輪少少<br />\n張相google唔係我影 果次影左幾百張相費事搵<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/07/09/111330_705d3d1e7bc8999cc73efb1c15cdd036.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F09%2F111330_705d3d1e7bc8999cc73efb1c15cdd036.jpg&h=608f1062&s={SIZE}\" /><br />\n<br />\n公平起見搵埋俄羅斯同級艦比較 呢一張上面油漆開始曬到甩色 應該唔係啱啱修好<br />\n水線下生銹情況都係差好遠囉<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"http://img.eservice-hk.net/upload/2017/07/09/111839_c2bba58423da44496ca04a1aed402467.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F07%2F09%2F111839_c2bba58423da44496ca04a1aed402467.jpg&h=a65dbbfe&s={SIZE}\" />"},{"pid":"2318b3ec05cd84ecaf1f50b38b806698a673c2f2","tid":312990,"uid":4493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-09T03:24:52.000Z","msg":"順便一提上次去英國<br />\n去左成10個軍事博物館 包括Bovington Tank Museum<br />\n共產國家做嘅嘢就係粗糙 T-34好多門根本合埋有空隙<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"53e89b915ec44ce0789f49d55e517c2d1d478a74","tid":312990,"uid":29804,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-09T04:32:11.000Z","msg":"<blockquote><blockquote>樓主已經柒左</blockquote><br />\n點樣柒法<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n<br />\n根本冇講過美國船冇生銹 比人屈跟住幾件和應<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n平心而論實際用咗唔夠人哋五分一 生銹都嚴重過人<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n蘋果都刪左新聞"},{"pid":"8325cf8b14dd553ba1f78510093b087014d89c62","tid":312990,"uid":4493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-09T04:33:35.000Z","msg":"<blockquote><blockquote><blockquote>樓主已經柒左</blockquote><br />\n點樣柒法<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n<br />\n根本冇講過美國船冇生銹 比人屈跟住幾件和應<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n平心而論實際用咗唔夠人哋五分一 生銹都嚴重過人<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n蘋果都刪左新聞</blockquote><br />\n佢嘅做法一向係咁"}]}