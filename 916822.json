oji\" />"},{"pid":"9b457bc313d1a53af89fb1d0bd1a73af7771b496","tid":916822,"uid":40932,"like":0,"dislike":0,"score":0,"quote":{"pid":"744b024f183f698b0092480d6fbee3f2f8222d53","tid":916822,"uid":95520,"like":37,"dislike":1,"score":36,"citedBy":1,"replyTime":"2018-11-26T03:33:49.000Z","msg":"敵人係中國<br />\n泛民係愛(中)國者<br />\n所以泛民係敵人"},"citedBy":0,"replyTime":"2018-11-26T05:35:55.000Z","msg":"得平民唔係敵人<br />\n但係又鍾意up圖上fb互相批鬥<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cccdbb5d23c724fe5e08ea66d27c454930bdf82f","tid":916822,"uid":35430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-26T05:40:10.000Z","msg":"<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/point2.gif\" class=\"hkgmoji\" />"},{"pid":"d587ca67318177558ec09bebc0c803fab51135f7","tid":916822,"uid":35430,"like":0,"dislike":0,"score":0,"quote":{"pid":"39952470e5134822b04613fe1318c5d167a9293f","tid":916822,"uid":47359,"like":37,"dislike":3,"score":34,"citedBy":2,"replyTime":"2018-11-26T03:43:10.000Z","msg":"借隔籬post<br />\n去投票又係唔係咁難?<br />\n<br />\n2017年6月17日，沙中線8.47億追加撥款以6票之差獲得通過，10名泛民議員缺席未有投票。<br />\n<a href=\"http://www.vjmedia.com.hk/articles/2017/06/17/162225\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.vjmedia.com.hk%2Farticles%2F2017%2F06%2F17%2F162225&d=dqKSpZxk9nt8wP7CWeVsBYzZXVCnaYNE8CBFJ%2F%2FgXXY%3D&h=62393026\" data-auto-link target=\"_blank\">http://www.vjmedia.com.hk/articles/2017/06/17/162225</a><br />\n<br />\n2018年3月22日，立法會審議 1131億臨時撥款，在全體泛民議員缺席下，議案只花兩分鐘，由不足十名建制派議員在不記名投票下贊成通過。<br />\n<a href=\"http://hk.on.cc/hk/bkn/cnt/news/20180322/bkn-20180322090338992-0322_00822_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20180322%2Fbkn-20180322090338992-0322_00822_001.html&d=dqKSpZxk9nt8wP7CWeVsBYzZXVCnaYNE8CBFJ%2F%2FgXXY%3D&h=375d7ffd\" data-auto-link target=\"_blank\">http://hk.on.cc/hk/bkn/cnt/news/20180322/bkn-20180322090338992-0322_00822_001.html</a><br />\n<br />\n2018年5月26日，工務小組審議17.85億元朗行人天橋撥款，議案以3票之差獲得通過，5名泛民議員缺席未有投票。<br />\n<a href=\"https://www.legco.gov.hk/yr17-18/chinese/fc/pwsc/results/v201805261.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr17-18%2Fchinese%2Ffc%2Fpwsc%2Fresults%2Fv201805261.pdf&d=dqKSpZxk9nt8wP7CWeVsBYzZXVCnaYNE8CBFJ%2F%2FgXXY%3D&h=5bb4d70c\" data-auto-link target=\"_blank\">https://www.legco.gov.hk/yr17-18/chinese/fc/pwsc/results/v201805261.pdf</a><br />\n<br />\n2018年5月25日，林卓廷提出就「升降機維修保養對市民安全進行辯論議案」以6票之差未獲通過，7名泛民議員缺席未有投票。<br />\n<a href=\"https://www.legco.gov.hk/yr17-18/chinese/hc/voting/hc20180525-voting-ec.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr17-18%2Fchinese%2Fhc%2Fvoting%2Fhc20180525-voting-ec.pdf&d=dqKSpZxk9nt8wP7CWeVsBYzZXVCnaYNE8CBFJ%2F%2FgXXY%3D&h=03177f1b\" data-auto-link target=\"_blank\">https://www.legco.gov.hk/yr17-18/chinese/hc/voting/hc20180525-voting-ec.pdf</a><br />\n<br />\n2018年5月31日，建制派「共建粵港澳大灣區」動議順利通過，地方選區輸2票，2名泛民議員缺席未有投票。<br />\n<a href=\"https://www.legco.gov.hk/yr17-18/chinese/counmtg/voting/v20180530.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.legco.gov.hk%2Fyr17-18%2Fchinese%2Fcounmtg%2Fvoting%2Fv20180530.pdf&d=dqKSpZxk9nt8wP7CWeVsBYzZXVCnaYNE8CBFJ%2F%2FgXXY%3D&h=90d3d03f\" data-auto-link target=\"_blank\">https://www.legco.gov.hk/yr17-18/chinese/counmtg/voting/v20180530.pdf</a>"},"citedBy":1,"replyTime":"2018-11-26T05:40:54.000Z","msg":"應該要印海報企街舉牌<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e4e5776d822b81feba28a58b735b950f2ea98d85","tid":916822,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-26T06:00:52.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a363900910686a3426830c62629bfe5c3b3e2836","tid":916822,"uid":192068,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-26T06:19:45.000Z","msg":"中国呢個龐大嘅專制國家一日仲存在, 香港都冇得獨善其身<br />\n呢個炸彈遲早要拆, 因為中国接受唔到自己鄰居有民主,