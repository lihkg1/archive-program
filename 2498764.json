HeyqgQsCZvTSqET?filename=XdOuh8J.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXdOuh8J.jpg&h=ada0ffe0&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmdDQhZXAJoaC3TZ9tXRi3zcj7MHfkJF3vysjNwyQFcgVq?filename=K7teufo.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FK7teufo.jpg&h=112817a7&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmR9LhinvDdwrkvm7RuAdRTZJNcXvN1o2PB8hBLDobMHFt?filename=BLpM4OK.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBLpM4OK.jpg&h=ff0c4ae7&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmR6JNR7v2LGxwrp9jFwHfUikbjhj45AXgVjwHywAHJe4B?filename=cXyuh8K.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcXyuh8K.jpg&h=e3334717&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmU4BRoB7zAfDqvBremHGKkopcyVGS5aW68EQyvPNFFC23?filename=PmjJnAq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPmjJnAq.jpg&h=abd5b2ee&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmXC9ZTcZf7BVTmLyc1VgnhYp9CJC1fkEJEJJMEUHnZ9xF?filename=WjE1TG6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWjE1TG6.jpg&h=2b5e2fc7&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n見盡離離合合，到最後依然堅守落嚟嘅，就只有佢一個。雖然好多都被標籤為二五仔，但喺佢地心目中，仍然視爺爺為恩師。<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmPrRFeFnuvArBXp52JHSE4eempLXdBjpabskSR5DQgAqA?filename=kT892Ar.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FkT892Ar.jpg&h=55f0bb34&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmPt8etyQtqpU1RnHSg6RMHZvhMRZ9HMczeVkF2rfqEZRe?filename=C9fDVVH.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FC9fDVVH.jpg&h=064e351b&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmXJoDkAhv17DdrWzbNgRx9MTenhHkTjCypQoV3E6YPcLh?filename=uBgjFm7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuBgjFm7.jpg&h=b9924d5b&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmTp67rabZnocd8iYY7fV6wFeSxaPVbNKe666287UPxu1W?filename=npWGTG7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnpWGTG7.jpg&h=9a98bf82&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmYKE4ZegrxX72JZDRiMhmZfbZXstj7DsAnFEPVqUCU8jU?filename=BrLXr18.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBrLXr18.jpg&h=450b41a7&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmcNg96mQpK2LAxFijQbGLtts6xfQj3zM6CXRGvZkE4wqz?filename=iAUpRtO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiAUpRtO.jpg&h=adc7e79d&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmWKnZhfinNuuVrvnMWmy2nsranA6Ekey8uCx6omx5uYFM?filename=jHoBHAu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjHoBHAu.jpg&h=980c3f1f&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmdz3r8D3PUhirZf894Lp67wvtG1DjXQqfSh9iBA9pgxPo?filename=VcNF9fu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVcNF9fu.jpg&h=81cefb09&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmPkVmfGiFZ6PnyY5UbtprGAPGmifbdqCvfp4Wiu4LWQAB?filename=WwetyHa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWwetyHa.jpg&h=5da23a58&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmSgN9oGy2py83nc3aovMMc8AinEvaia3KzjMmGym9LP4X?filename=w5P5AVw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fw5P5AVw.jpg&h=73a982d8&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmZzGvpGfLoqwnbgNKpBqNka5buMRTW7TQzWqqNsufMGwk?filename=DnTx0nb.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDnTx0nb.jpg&h=ecbeb7d1&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmQGKmCbH5QDbs6rxnhvs9MTA5X9Gg7uvvTTxaC9jNKe27?filename=bGqAdHc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbGqAdHc.jpg&h=b3f8c156&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmd271bXTKnKpmpehFg6mpn3NrXLYtUMUFUE6pdTGkDAch?filename=HhQMknc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHhQMknc.jpg&h=2a6e144e&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n雖然臨尾十年俾人鬧到痴線，幾乎係完全不被尊重咁被自家球迷趕走，但佢帶來嘅改革同獎盃，足以令佢成為球會史上最偉大嘅領隊。<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmPTFh5CJrn4AakMw5J2yXnTR5tv1h7znqtNPGimAjpzni?filename=fK7u2Ay.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfK7u2Ay.jpg&h=82d1b08f&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmNkty9EJ8tSp27wrgCY3chExeYdWhrtHQLoG56PZXREyz?filename=Ljao62d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLjao62d.jpg&h=4b0e988f&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmVNuGAf3WVsiaHey2mobYs1jU1i1FRf7vwcRdLB9xLJYi?filename=FWXnC8U.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFWXnC8U.jpg&h=5d4b8bb1&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmd5VPm6NR14QwW59F3dXuwnkxRZ8jonNZPWLUvj78i5Y5?filename=yS5gHAA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyS5gHAA.jpg&h=f111f3ae&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmZphpEsVkNPR8PkrDXUEMqyjbFVSPReWpJ2D16XakdBPm?filename=8DRS0nf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8DRS0nf.jpg&h=6bcf1be3&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmRf35RZSyKhznrQWyFzsERyBuhQv2rYBvEqASNGaGVq6i?filename=9G0sPfB.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F9G0sPfB.jpg&h=1efc21df&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmSYRkiJUgbfSwVNzfRknNrbaryUmFG36yUvwLKxJRetJj?filename=Tk2rkng.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTk2rkng.jpg&h=bbf7da19&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmcmy4E2aW85HWLY78FV9j55PVCGPQw8Sz5v12f9sS5MuR?filename=6BrcfVC.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6BrcfVC.jpg&h=a09ff9ad&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmNrxFHifJ4qs6W2koJMzPC4345DiZ4ep1y1gyZ51jy9V6?filename=WPCSfVC.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWPCSfVC.jpg&h=c2f0b514&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmWq56f6EkUKHTX3vEP91zMQ13ht3e7mtMnCpq8DA8jDe8?filename=0HM362i.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0HM362i.jpg&h=ac2c8812&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n除咗帶來獎盃，仲有無數經典收購。一係點石成金、一係轟動一時。<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmWrqX9uRSx9fVj5z7zLXXocYYTWKHZMKH6oz3HQg8b99c?filename=cGBGTHi.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcGBGTHi.jpg&h=5cc69067&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qme6pNrTzaT2hdjxH7GsNhiozjFUPBhtnDmauMNDhWoyJG?filename=is3J62j.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fis3J62j.jpg&h=035ad73c&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmabui9UyC1zzuaSdnGgbDimoGb6EWxFQFcAm3k2jHmBV2?filename=1WA4RtZ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1WA4RtZ.jpg&h=f0a3c890&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmQ1r5bgHpuVSoHUtYKL84pgtdWHWb5BQ5i7VcYSo2mZYZ?filename=aSOVdHk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaSOVdHk.jpg&h=12170726&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmZ7sYVSWoy7Mfpd6dCoAnHT4EbPAhqfmAL34KkWV3pYH5?filename=hqWS0nk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhqWS0nk.jpg&h=5534ec83&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmavN4QtBqgDCUtzHgqT7f7wSNHC1hbPD9tdu9a1tCy1Bp?filename=O7y6knm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FO7y6knm.jpg&h=b7ed3649&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmbSUws2KKVbKbC22zGoSiBDi6Qz6j5RGkbahs1YUjHjcg?filename=EkLMknm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEkLMknm.jpg&h=a763f6fb&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmeErgY46sxTGqHiNVbsURTFjbtCtaFXHb8WUP2xznc9jY?filename=T0wfX83.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FT0wfX83.jpg&h=b0bbd999&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmatEXQiiNDbqPoUzN1anfVq7fsb7hZhi1nsi9FxMcMuc4?filename=h8fsPfK.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fh8fsPfK.jpg&h=f5754642&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmNahSBdmnF3NuyASp7GzChJroCHADqFuA5sEPv9JLiaHJ?filename=xebDbt5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxebDbt5.jpg&h=88dcf391&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmR7WCzsVz4VrHPLibcVhm6mJ4rndXW7jbpxnmL4zq6MTo?filename=fY8x0nq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfY8x0nq.jpg&h=65d2f792&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n仲有每次都一式一樣，但百看不厭嘅慶祝動作。無可否認嘅係，佢真係好愛呢隊波。<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmQe61WQ7a12iY3p5eNf9FGzLioLLyKxQraSLVbBTHztgD?filename=pAtuh87.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpAtuh87.jpg&h=af2277a3&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmbYv3piFSPGz2NmMVvjPS71E9hRDYnRCJe3akn5KV2AJ1?filename=3sUtyHs.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3sUtyHs.jpg&h=22dd50ae&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmTxZw7Rq5GQQLtucxRZtTJqq1wzxfoMqTVAGjifMJ7Acn?filename=jKbDbt8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjKbDbt8.jpg&h=dd9d59c4&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmNdLCfD7GJMJ37xus2chRppvzfpNCQTy1D7X2atdZ9cic?filename=Lk58yHt.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLk58yHt.jpg&h=8ee7cc93&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmTwa2Uo8TyKu7aCa2g8c89MfdeXJ3b2kJ6EBRvLgmRVMg?filename=T41jFnu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FT41jFnu.jpg&h=729b7115&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmb1qQ9qfwW7X7f86QtCGDAf1c8E9JgaULxenka2VFSXgM?filename=50qHC89.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F50qHC89.jpg&h=d430d020&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmRauMENZ9967p2pztPEa8LdDqQmBRT3SXSVNrGjRdz3KT?filename=8q7ZFnv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8q7ZFnv.jpg&h=3dc9a4b6&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmR4unF14TmHnhqLtrSWAF7KEAcpExKdtDrsxu7iwHVMxM?filename=4KhOyHw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4KhOyHw.jpg&h=1fed3164&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmRjSHVhSeccsqhUA9BGz7jWpeAr9NJyaFpuMXXBQLEapG?filename=iUhOyHx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiUhOyHx.jpg&h=18dd3264&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n當然，更少不了一座酋長球場。<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmdZ2oA7WF9fFKFKFVxzNwEF94nd6PNdiZNwuHL6XD2r2k?filename=CfTuh86.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCfTuh86.jpg&h=62038007&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmNrNLSeHoQ35kdGgoeS9LYKntDzgG1YRPaiW6KiTq9Fsc?filename=eJwvM2o.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeJwvM2o.jpg&h=fe1f8489&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n咁就三年，仲記得當日睇到新聞嘅感受。好掛住佢！<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmbBB73dMPchTP4yQVtxnBKFs6GkZTcokYbXUn9P68FfuT?filename=F8o6knr.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FF8o6knr.jpg&h=787577a7&s={SIZE}\" />"},{"pid":"298c390999912198d60f38a49efe942ae6d890a2","tid":2498764,"uid":234509,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2021-04-21T11:32:36.000Z","msg":"浪費網絡資源 拉爆"},{"pid":"2a1c8cc7f15b4143ac38a5fcc522d4360a8bae9d","tid":2498764,"uid":166262,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-21T11:32:54.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"a6fda76abfc66283f53d0edd7c88666de7cf01d6","tid":2498764,"uid":232575,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2021-04-21T11:33:07.000Z","msg":"利迷路過，忍單住留言<br />\n雲家值得一尊銅像"},{"pid":"6b70afd7b004d384ec5a70699299f26ee05d2538","tid":2498764,"uid":243526,"like":1,"dislike":0,"score":1,"quote":{"pid":"298c390999912198d60f38a49efe942ae6d890a2","tid":2498764,"uid":234509,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2021-04-21T11:32:36.000Z","msg":"浪費網絡資源 拉爆"},"citedBy":0,"replyTime":"2021-04-21T11:33:37.000Z","msg":"好 唯有係咁"},{"pid":"a046865c117658ad139c4fde90f8bfcb36959767","tid":2498764,"uid":176282,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-21T11:34:31.000Z","msg":"respect<img src=\"/assets/faces/mouse/pray.gif\" class=\"hkgmoji\" />"},{"pid":"54d51c1b61532f7346984d0d5ccfd87788bad8b1","tid":2498764,"uid":325684,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-04-21T11:35:17.000Z","msg":"爺爺<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"9b5127edef711096d3d6919ba0dace2cbdbd8235","tid":2498764,"uid":165817,"like":0,"dislike":0,"score":0,"quote":{"pid":"a6fda76abfc66283f53d0edd7c88666de7cf01d6","tid":2498764,"uid":232575,"