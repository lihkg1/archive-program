pid":"f434c3513bce2d5a31fe671827a1b5cd93924a81","tid":48651,"uid":408,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T10:30:22.000Z","msg":"<blockquote>幾十歲人打<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> 𡃁妹</blockquote><br />\n<br />\n揸人屎忽被人揭發,<br />\n老羞成怒打𡃁妺,<br />\n真係肉鳩酸<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"7af4b5c3771d4c3471886fe15c7a58ad8e203e5c","tid":48651,"uid":408,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T10:32:25.000Z","msg":"<blockquote><img src=\"http://static.apple.nextmedia.com/images/e-paper/20161221/large/1482306369_11d2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fe-paper%2F20161221%2Flarge%2F1482306369_11d2.jpg&h=bde84b65&s={SIZE}\" /><br />\n<br />\n3名休班警涉嫌酒後在街頭與3名少女毆鬥，事後全部人被捕。事發於凌晨3時半左右，3名由31-40歲的休班警員，在旺角夜店消遣後帶醉離開，至旺角道28號對開，疑與3名同為22歲的少女踫撞後，一名少女感覺被人觸摸臀部，大怒與3警爭執，雙方繼而大打出手，眾人均手部受傷。警方接報到場調查，以涉嫌在公眾地方打架將6人拘捕，<span style=\"color: red;\">全部人事後被送廣華醫院治理</span>。<br />\n<br />\n據悉，3名被捕休班警員為毒品調查科探員，其中一人為警長。案件交由旺角警區重案組跟進。警方表示，警隊非常重視人員的操守，任何人員干犯違法行為，警隊絕不容忍和姑息，定必嚴正處理，進行刑事調查及紀律覆檢。</blockquote><br />\n<br />\n仲要入埋院<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"08cb5bc7251dd330ae0619cf604497fdf6e91fb1","tid":48651,"uid":48093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T10:43:05.000Z","msg":"<blockquote><blockquote><img src=\"http://static.apple.nextmedia.com/images/e-paper/20161221/large/1482306369_11d2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fe-paper%2F20161221%2Flarge%2F1482306369_11d2.jpg&h=bde84b65&s={SIZE}\" /><br />\n<br />\n3名休班警涉嫌酒後在街頭與3名少女毆鬥，事後全部人被捕。事發於凌晨3時半左右，3名由31-40歲的休班警員，在旺角夜店消遣後帶醉離開，至旺角道28號對開，疑與3名同為22歲的少女踫撞後，一名少女感覺被人觸摸臀部，大怒與3警爭執，雙方繼而大打出手，眾人均手部受傷。警方接報到場調查，以涉嫌在公眾地方打架將6人拘捕，<span style=\"color: red;\">全部人事後被送廣華醫院治理</span>。<br />\n<br />\n據悉，3名被捕休班警員為毒品調查科探員，其中一人為警長。案件交由旺角警區重案組跟進。警方表示，警隊非常重視人員的操守，任何人員干犯違法行為，警隊絕不容忍和姑息，定必嚴正處理，進行刑事調查及紀律覆檢。</blockquote><br />\n<br />\n仲要入埋院<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n差佬唔夠打"},{"pid":"245574c3bd0a4b2045305c6e30981c5b8b6f9a46","tid":48651,"uid":55913,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T10:57:15.000Z","msg":"香港休班警犯罪聯盟"},{"pid":"ba6e15e3ea7ecada68a57d7725d7162c5a11f3ca","tid":48651,"uid":31637,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T11:13:38.000Z","msg":"正垃圾<br />\n<br />\n見到南亞人就淆撚晒青咁<br />\n見到細路女就敢打"},{"pid":"294f1669c8406426799846825c0da268011d9f04","tid":48651,"uid":40818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T12:20:38.000Z","msg":"<blockquote>一定係d女用個胸攻擊佢地先<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /></blockquote><br />\n三個都藏有攻擊性武器<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"6bf658003f46593c48377e97252d56a79615d974","tid":48651,"uid":13250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T12:32:51.000Z","msg":"如果當緊班有鎗咪會開鎗射佢<img src=\"/assets/faces/lomoji/24.png\" class=\"hkgmoji\" />"},{"pid":"370141a76fc9b91e4eb99b087949bd0085b4953c","tid":48651,"uid":25494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T12:35:58.000Z","msg":"有無人計下平均一年休班警既犯罪率有幾多<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"74e7e3c116969a7d6bbd5c05e80bd47dcfdfea10","tid":48651,"uid":41266,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-21T12:36:52.000Z","msg":"黑警死全家"}]}