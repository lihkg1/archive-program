d":"c44e974c32999d2c32d5882466c19a3fce4ece1a","tid":407073,"uid":18704,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:17:34.000Z","msg":"冇乜事嘅 飲多啲水啦巴打<br />\n我有時都有 但如果飲多啲水就冇泡<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5b91d9b325c322ea449ec426c98958f92d5e9041","tid":407073,"uid":52013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:18:55.000Z","msg":"<blockquote>冇乜事嘅 飲多啲水啦巴打<br />\n我有時都有 但如果飲多啲水就冇泡<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n但願如此<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\nthx"},{"pid":"41a9e67ace02194e9c5bd0dad9a5179e244c1d2b","tid":407073,"uid":41205,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:22:16.000Z","msg":"腎衰竭<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"954333debad981bb1dd4778648f64f2bfd81933c","tid":407073,"uid":52013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:22:29.000Z","msg":"<blockquote>腎衰竭<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n有機會"},{"pid":"7060765b1e7b281d37637202de1144fce89535da","tid":407073,"uid":58005,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:24:23.000Z","msg":"打完丁之後個篤尿太快去就會有"},{"pid":"40a5708ce736b99a84ed221acaac8fd05bc1a477","tid":407073,"uid":52013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:26:49.000Z","msg":"<blockquote>打完丁之後個篤尿太快去就會有</blockquote><br />\n<br />\n已戒丁"},{"pid":"0e7673231f226d17f053b1a723a3d2872ed7741a","tid":407073,"uid":123790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:27:11.000Z","msg":"打多d 飛機"},{"pid":"4257db74e9c14cca64ccee56251149f9ed0a911c","tid":407073,"uid":70688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:28:01.000Z","msg":"<blockquote><blockquote><br />\n<br />\n係多泡定蛋白尿<br />\n你睇清楚未</blockquote><br />\n<br />\n澄明返先<br />\n<br />\n點解我會覺得自己個d係病性蛋白尿而非泡又或者假性蛋白<br />\n<br />\n我由9月8號開始觀察緊自己身體狀況<br />\n平均日飲3000毫升兼盡量保持飲食清淡<br />\n每日晨早既尿 正如咁多位巴打所講 有泡係正常<br />\n但係泡沫停留既時間都幾撚長下<br />\n起碼超過一分鐘 我都廢撚到慢慢睇佢幾耐先會散直接沖走<br />\n而平時屙尿既泡沫都會因我既飲食而有所改變<br />\n例如我某一日燒烤 打邊爐 瘋狂食肉<br />\n起泡既情況都會激增而且一分鐘都唔會散<br />\n<br />\n就咁平時飲食 我依家都盡量進行低蛋白飲食<br />\n去調節一下自己身體<br />\n泡沫數量情況係有改善 有時屙尿重會無泡<br />\n所以我得出一個比較冒昧既結論<br />\n就係我既腎臟功能受損令到我有蛋白尿既情況<br />\n<br />\n<br />\n<br />\n利申：有2個月 服用藥物既紀錄</blockquote><br />\n咁唔係正常咩？3粒鍾身體大約可以吸收30g protein,咁你狂食肉，過剩protein咪會隨尿液排出。 當你食唔夠咁多protein,情況就改善。<br />\n <br />\n<br />\n利申 鳩up"},{"pid":"eb35e77d968d5a7c8f3b4aa05aa566e2105ac6d3","tid":407073,"uid":31752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:34:39.000Z","msg":"一次半次有泡唔正常咩<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n飲完啤酒/飲得少水隔一晚訓醒都係又黃又臭又多泡"},{"pid":"43f21e51975d16d8dc0bdff8ccfa6a42a3e1b391","tid":407073,"uid":52013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:36:05.000Z","msg":"<blockquote><br />\n咁唔係正常咩？3粒鍾身體大約可以吸收30g protein,咁你狂食肉，過剩protein咪會隨尿液排出。 當你食唔夠咁多protein,情況就改善。<br />\n <br />\n<br />\n利申 鳩up</blockquote><br />\n<br />\n當然 多餘既蛋白質會流失<br />\n但係流失情況唔會太多<br />\n一定有部份會keep係腎臟個到經由血液會比返你各器官/肌肉<br />\n其實我都係引證返 我腎臟個過瀘系統好似出現左少少問題<br />\n之後我進行返低蛋白飲食都係有蛋白尿問題<br />\n<br />\n利申 都係鳩up"},{"pid":"2ae804e617fbc305e64b06710d18aefebce4733b","tid":407073,"uid":52013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:36:22.000Z","msg":"<blockquote>一次半次有泡唔正常咩<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n飲完啤酒/飲得少水隔一晚訓醒都係又黃又臭又多泡</blockquote><br />\n<br />\n並非一次半次<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"80e1f0416c429a61c435facf1e3ef9d46a6a2b7d","tid":407073,"uid":76098,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:37:15.000Z","msg":"<blockquote><blockquote><blockquote>睇醫生<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n如果10月尾之前無好轉既話就睇</blockquote><br />\n<br />\n<br />\n早上第一篤尿多唔多泡？<br />\n<br />\n多數腎有事<br />\n<br />\n自己search下慢性腎病最後會點<br />\n<br />\nBtw<br />\n<br />\n即刻睇醫生</blockquote><br />\n<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"475cc0798dab617affdedd95c4dd00d0910d6ca2","tid":407073,"uid":78971,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:48:12.000Z","msg":"<blockquote>我起身去廁所多泡，平時會不停飲水，飲得多去得多反而冇事，然後loop</blockquote><br />\n<br />\n一樣<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"d2c733d98803a30255bba583832e89594984e6ce","tid":407073,"uid":88739,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:48:27.000Z","msg":"<blockquote><blockquote>打少D飛機就無事</blockquote><br />\n<br />\n由8月25號已經停左打丁</blockquote><br />\n咁都記得<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"5e112a9b8ded5f3625c2ff424f9594997defea5b","tid":407073,"uid":52013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:49:15.000Z","msg":"<blockquote><blockquote><blockquote>打少D飛機就無事</blockquote><br />\n<br />\n由8月25號已經停左打丁</blockquote><br />\n咁都記得<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n....有得紀錄數據"},{"pid":"6272d4ca64f975ca16103951e92741b56d9fb837","tid":407073,"uid":88739,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T09:50:37.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>打少D飛機就無事</blockquote><br />\n<br />\n由8月25號已經停左打丁</blockquote><br />\n咁都記得<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n....有得紀錄數據</blockquote><br />\n除左打飛機之外仲有咩會紀錄<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> ？"},{"pid":"3c430dde3667c4e30309eeaf68596eef3c951c4b","tid":407073,"uid":33874,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T10:01:00.000Z","msg":"乜都好，唔好睇醫生"},{"pid":"dd819722e5e74cf042a6ee82ad2480fc9495ae8c","tid":407073,"uid":52013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T10:14:25.000Z","msg":"<blockquote><br />\n<br />\n除左打飛機之外仲有咩會紀錄<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> ？</blockquote><br />\n<br />\n每日食左幾多克食物<br />\n幾多卡 蛋白質 有咩維他命個d 雜項"},{"pid":"c8205c46347c9f7dcba9a81911ea21b58ec88ade","tid":407073,"uid":52013,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T10:14:48.000Z","msg":"<blockquote>乜都好，唔好睇醫生</blockquote><br />\n<br />\n係既<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> 月底情況無改善即睇"},{"pid":"33f8aef3207de6462e4a31a69e6e8b69bb4b144c","tid":407073,"uid":58005,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T11:54:00.000Z","msg":"多泡係點？好似啤酒咁多泡？"},{"pid":"76accecc476ae690ed07fc966ecf54da8dfb6a4e","tid":407073,"uid":41643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T11:57:33.000Z","msg":"上連登得永生<br />\n醫生都唔洗睇<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"6e935b3def9621cbf78699d1714d27d6ecec7406","tid":407073,"uid":1291,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T12:05:13.000Z","msg":"唔好撚on9 你食再多蛋白質都唔會經尿屙出黎<br />\n個腎過濾血ge時候會擋曬大部分ge蛋白質<br />\n剩低ge小部分唔會屙到蛋白尿<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e149b71e20957be07fc423c03db3de8519a7c683","tid":407073,"uid":127325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T12:32:54.000Z","msg":"<blockquote><blockquote>最好快d睇啊巴打<br />\n我以為無乜事睇完醫生結果係凝血症<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> <br />\n塞住左個腎嘅血管搞到個功能唔work(好似係<br />\n你都係快d睇下醫生一陣唔知關其他乜野事<br />\n遲左就好難搞<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" /></blockquote><br />\n巴打呢個病食咩藥</blockquote><br />\n<br />\n食緊好多藥 主要有食華法林(薄血藥<br />\n仲有好多立立雜雜控制病情嘅藥<br />\n<br />\n利申：絲"},{"pid":"02fc4972d8086b577a0f458e4da65dfdcaa39f3c","tid":407073,"uid":127325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T12:33:54.000Z","msg":"<blockquote>多泡係點？好似啤酒咁多泡？</blockquote><br />\n會似架嚴重嘅時候"},{"pid":"613da043bd8d8818d53f19971ba55acbd6c1a503","tid":407073,"uid":127325,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-20T12:35:46.000Z","msg":"<blockquote><blockquote>多泡係點？好似啤酒咁多泡？</blockquote><br />\n會似架嚴重嘅時候</blockquote><br />\n不過唔係成層岩岩針嗰隻 少d咁"}]}