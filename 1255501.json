ilymail.co.uk/1s/2019/06/21/19/15095936-7168131-image-a-3_1561140507899.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.dailymail.co.uk%2F1s%2F2019%2F06%2F21%2F19%2F15095936-7168131-image-a-3_1561140507899.jpg&h=5b6013f0&s={SIZE}\" /><br />\n Protesters are pictured creating a barricade to block the police headquarters in Hong Kong on Friday. An ex-pat police officer said it was very easy to put negative images out about what they were doing but that viewers 'needed to see the content'<br />\n<br />\n<img src=\"https://i.dailymail.co.uk/1s/2019/06/21/19/15095934-7168131-image-a-4_1561140511372.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.dailymail.co.uk%2F1s%2F2019%2F06%2F21%2F19%2F15095934-7168131-image-a-4_1561140511372.jpg&h=a519b560&s={SIZE}\" /><br />\n Protesters raise their phones in protest as they gather outside the police headquarters in Hong Kong today<br />\n<br />\n<a href=\"https://videos.dailymail.co.uk/video/mol/2019/06/21/5643684540325972717/1024x576_MP4_5643684540325972717.mp4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fvideos.dailymail.co.uk%2Fvideo%2Fmol%2F2019%2F06%2F21%2F5643684540325972717%2F1024x576_MP4_5643684540325972717.mp4&d=%2Fh6QBFvJ2171tI4HayrYRvtobIAPz7vP9zHpdy2ENqg%3D&h=213c10f6\" target=\"_blank\">https://videos.dailymail.co.uk/video/mol/2019/06/21/5643684540325972717/1024x576_MP4_5643684540325972717.mp4</a><br />\n<br />\nsource:<a href=\"https://www.dailymail.co.uk/news/article-7168131/Shocking-moment-British-ex-pat-police-chief-orders-tear-gas-blasted-politician-protester.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.dailymail.co.uk%2Fnews%2Farticle-7168131%2FShocking-moment-British-ex-pat-police-chief-orders-tear-gas-blasted-politician-protester.html&d=%2Fh6QBFvJ2171tI4HayrYRvtobIAPz7vP9zHpdy2ENqg%3D&h=72f320fb\" target=\"_blank\">https://www.dailymail.co.uk/news/article-7168131/Shocking-moment-British-ex-pat-police-chief-orders-tear-gas-blasted-