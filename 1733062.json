51.000Z","msg":"<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"3aad44e17d807ca5a431c8200f2cb172fda17fca","tid":1733062,"uid":261873,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-11-18T06:55:45.000Z","msg":"叫長毛去開路<br />\n<br />\n<a href=\"https://hk.news.appledaily.com/local/daily/article/20141003/18887821/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20141003%2F18887821%2F&d=uhXF1s3LJRzyxl6IDZpy2YWZOtE43EI%2FqUWggxD1P9E%3D&h=7ca16b2e\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20141003%2F18887821%2F&h=d42467e4\" target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20141003/18887821/</a><br />\n<br />\n學生團體及巿民前晚凌晨突襲圍堵特首辦，昨上午警方向身在現場的立法會議員梁國雄表示，有警員心臟病發，要求巿民開路讓救護車進入，巿民答允，但同時有兩架消防車尾隨，現場警員拒絕解釋原因。其後警方以運送食物、警員換班等理由，要求示威者開路，示威者照做。<br />\n<br />\n梁國雄再次呼籲現場巿民開路，以免傷及貼近牆邊的警員，巿民開路後，有警員陸續自添華路走出，但更多警員帶同物資進入，他們分別乘坐警車和旅遊巴到達，像苦力一樣抬入各種「物資」，包括過百袋寫上「SUP TW」的藍色尼龍袋、20支警告旗幟、盾牌、咖啡色圓桶的橡膠子彈、灰色圓桶和鐵箱的催淚彈、寫上5.56mm的彈藥、放置長槍的藍色木箱，和滅火筒裝胡椒噴霧。巿民知道受騙，但無法阻截警方前進，看大批裝備入政府總部。"},{"pid":"2283ccebb1e227e6bcb1f9f804c43826474f09bc","tid":1733062,"uid":56381,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T07:12:14.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"f4b3da12ecc6678ba29bce3d694e1affc9207a4e","tid":1733062,"uid":227637,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T07:14:39.000Z","msg":"推"},{"pid":"c29902b87fc05722e8643d22fe40e37948a4f259","tid":1733062,"uid":115248,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T07:16:50.000Z","msg":"投石器 射入去"},{"pid":"580e7ff07951c90a5c05ac308ae2696836dc7c67","tid":1733062,"uid":60648,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-18T07:21:54.000Z","msg":"點解警察唔會頂好耐<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\nd 狗有專人安排輪更同後勤<br />\n<br />\n仲有成