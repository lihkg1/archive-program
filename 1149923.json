rmal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"17e7bdc74a1d13b09477501ac0acbdbe165ab95a","tid":1149923,"uid":15477,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-14T19:17:36.000Z","msg":"套用喺動物身上都係咁<br />\n點解鍾意動物先叫有愛心？<br />\n<br />\n利申 唔鍾意動物但都唔憎 只係冇乜感覺"},{"pid":"4f5c161b161ddc54171f946dd8e677c0057d3669","tid":1149923,"uid":251510,"like":0,"dislike":0,"score":0,"quote":{"pid":"17e7bdc74a1d13b09477501ac0acbdbe165ab95a","tid":1149923,"uid":15477,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-14T19:17:36.000Z","msg":"套用喺動物身上都係咁<br />\n點解鍾意動物先叫有愛心？<br />\n<br />\n利申 唔鍾意動物但都唔憎 只係冇乜感覺"},"citedBy":0,"replyTime":"2019-05-15T06:06:02.000Z","msg":"鍾意動物同愛心都未必係等號。<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7b2bbe5e04041f58dbbbc7c1bcf609f649f7962e","tid":1149923,"uid":251510,"like":0,"dislike":0,"score":0,"quote":{"pid":"a0c428fc5996f0fee7494fa3193664461d67926f","tid":1149923,"uid":105678,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-14T18:29:47.000Z","msg":"以前親耳係鐵路車廂入面聽幾個後生嘅日本女仔安慰個喊到勁大聲嘅細路：「趁依加細個，你仲可以任性多啲架。 」（日文唔係幾好，但意思係咁，當時架車冇人大聲鬧個細路，只係對細路個阿媽點頭微笑） <br />\n<br />\n日本仔會包容小朋友係公眾地方嘈，佢地個心態係大人要面對世界嘅殘酷，所以由得啲細路可以任性嘅時候就任性。<br />\n<br />\n成日話啲細路嘈，講到你地細就唔會嘈嘅到人咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n姐係包容又好乜都好，事實就係啲細路點都會喊，人天生就曉喊，同家教根本冇乜關係（bb餓就會喊，唔通永遠唔帶佢出街？），啲細路點會識諗嘈到人、公德心etc，不如換個心態，畀少少包容啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-15T06:14:14.000Z","msg":"係咩？我反而睇過一篇文章，類似講話喺日本有個BB喺地鐵大喊然後畀人用唔友善嘅眼光望住。"},{"pid":"51db7a2df0d9c796c8bb2995c2e8f6c6af910769","tid":1149923,"uid":130466,"like":0,"dislike":0,"score":0,"quote":{"pid":"c0bf3f1bc7e64d257617ac9d35034a4da8cdc1f3","tid":1149923,"uid":251510,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-05-11T12:56:30.000Z","msg":"相反，唔鍾意小朋友=冇愛心。<br />\n<br />\n我見有唔少人會喺fb、ig post同細路仔、BB攬攬錫錫嘅相，有部份人甚至講到明「我超鍾意小朋友」，強調自己有幾咁鍾意啲小朋友，小朋友又有幾咁鍾意佢。然後就會有留言讚佢哋有愛心。<br />\n<br />\n到底點解鍾