搜尋= 賬單號碼<br />\n<br />\n4.去繳付賬單就搞掂..可以幫大家慳唔少時間."},{"pid":"a8e8f36cefd418b286e751afefea0a36154179d1","tid":1656262,"uid":52459,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-16T06:13:06.000Z","msg":"Leon<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a87a5a66e0f58fceb7e1d37fbb960a6dd3b9f9c7","tid":1656262,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-16T07:37:29.000Z","msg":"推"},{"pid":"8030db4ee81c45d1eef7ad543e2dc3be0a070d46","tid":1656262,"uid":234944,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-16T11:00:48.000Z","msg":"set好晒d野, 想請問點run?<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"2f1b4d6ca48470c5c49aef7fd0a0f3e6f80daf4d","tid":1656262,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-16T11:02:44.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"90fde993b6bfe6660c4494d8a6caaa6a0f93cacb","tid":1656262,"uid":264865,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-16T11:06:29.000Z","msg":"推啦！！"},{"pid":"ae238524e337d3b10e1e7ea5315fb6e046d9ad04","tid":1656262,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-16T11:09:15.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"a385d51d3c00ce26ecc0689340d2187e7af6fe75","tid":1656262,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-16T11:09:44.000Z","msg":"交差餉 水 稅<br />\n可以用"},{"pid":"0b5052c067e5ac25127f2467969f0a64066345ca","tid":1656262,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-16T11:49:03.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"18ef8d71c8c1816219eca810d21e0833fb3c3665","tid":1656262,"uid":85030,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-16T11:53:10.000Z","msg":"Push"},{"pid":