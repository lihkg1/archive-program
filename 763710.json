rge Simpson's hair."},{"pid":"9f6735247d7c4a1df7b5cfad61b40dc38b9a4d6c","tid":763710,"uid":31215,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-08-02T02:04:50.000Z","msg":"海賊王叫乜<br />\n寵物小精靈又叫乜"},{"pid":"4887013e7709265ce74a2fbbe1423fbfbdf47134","tid":763710,"uid":33999,"like":17,"dislike":1,"score":16,"citedBy":1,"replyTime":"2018-08-02T02:06:34.000Z","msg":"咁認真去區分<br />\n根本現實係無人會care 呢班毒撚點諗<br />\n咪由得佢地嬲"},{"pid":"c5958c5197b71a8a4d9251739510971c3b5531a5","tid":763710,"uid":14941,"like":0,"dislike":4,"score":-4,"citedBy":2,"replyTime":"2018-08-02T03:10:45.000Z","msg":"叫開動通"},{"pid":"8a4a5f431a14eb9a31fdccf8a6221e7067398345","tid":763710,"uid":35857,"like":1,"dislike":0,"score":1,"quote":{"pid":"c5958c5197b71a8a4d9251739510971c3b5531a5","tid":763710,"uid":14941,"like":0,"dislike":4,"score":-4,"citedBy":2,"replyTime":"2018-08-02T03:10:45.000Z","msg":"叫開動通"},"citedBy":0,"replyTime":"2018-08-02T03:13:38.000Z","msg":"funny<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"c27687a465c5b2d1a69bddcae3eea80451fe3386","tid":763710,"uid":24814,"like":8,"dislike":8,"score":0,"quote":{"pid":"4887013e7709265ce74a2fbbe1423fbfbdf47134","tid":763710,"uid":33999,"like":17,"dislike":1,"score":16,"citedBy":1,"replyTime":"2018-08-02T02:06:34.000Z","msg":"咁認真去區分<br />\n根本現實係無人會care 呢班毒撚點諗<br />\n咪由得佢地嬲"},"citedBy":1,"replyTime":"2018-08-02T03:24:56.000Z","msg":"咁認真去區分中國人定香港人<br />\n根本現實係無人會care 呢班撚樣點諗<br />\n咪由得佢地嬲"},{"pid":"20b40abae37dcad0fd012cf77afe768f70de4505","tid":763710,"uid":33999,"like":5,"dislike":4,"score":1,"quote":{"pid":"c27687a465c5b2d1a69bddcae3eea80451fe3386","tid":763710,"uid":24814,"like":8,"dislike":8,"score":0,"quote":{"pid":"4887013e7709265ce74a2fbbe1423fbfbdf47134","tid":763710,"uid":33999,"like":17,"dislike":1,"score":16,"citedBy":1,"replyTime":"2018-08-02T02:06:34.000Z","msg":"咁認真去區分<br />\n根本現實係無人會care 呢班毒撚點諗<br />\n咪由得佢地嬲"},"citedBy":1,"replyTime":"2018-08-02