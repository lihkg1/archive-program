sg":"最頂中間嗰行係<br />\n按照上下埃及國王賽提一世的說話<br />\n<br />\n左邊最低我懷疑係<br />\n她的女兒"},{"pid":"f853f34b8c557e5a1659b9db6c5df617a0a9fd69","tid":2383273,"uid":302951,"like":0,"dislike":0,"score":0,"quote":{"pid":"9bf5694602c5e49cadbf2dfdca76c4d66725f972","tid":2383273,"uid":336645,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-03T13:51:39.000Z","msg":"<img src=\"https://na.cx/i/joTXuZ4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjoTXuZ4.jpg&h=294c6ba0&s={SIZE}\" /><br />\n<br />\n<br />\n求翻譯"},"citedBy":0,"replyTime":"2021-02-03T14:49:06.000Z","msg":"遊戲王<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n佢上面係參照埃及文字咁畫咋"}]}