sets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-21T10:41:49.000Z","msg":"快d佔領香港<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"184a35f348fc8a1f28bc5e3cdd87278ac556b2ef","tid":2073440,"uid":289946,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-06-21T10:43:25.000Z","msg":"<img src=\"https://na.cx/i/fEtWQJ5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfEtWQJ5.png&h=5a10113b&s={SIZE}\" />"},{"pid":"9eebeab5078898685c1b1fe9c8a46518faae7bb8","tid":2073440,"uid":266342,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-21T10:43:25.000Z","msg":"支持日本<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"65987112be6c717da5f00480a1ae985b39282c91","tid":2073440,"uid":3873,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-21T10:43:47.000Z","msg":"<a href=\"https://news.sina.com.tw/article/20200621/35536148.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.sina.com.tw%2Farticle%2F20200621%2F35536148.html&d=CgUtGs1XjGBKDnLe79D2Y8dEKmWGZzYthIwftZf8Bt0%3D&h=2d35b76e\" data-auto-link target=\"_blank\">https://news.sina.com.tw/article/20200621/35536148.html</a><br />\n<br />\n外媒稱，多名相關人士19日透露，鑒於陸基「宙斯盾」系統部署計劃停止，日本政府已開始朝著修改國家安全保障戰略的方向進行探討。國家安全保障會議從夏季開始將以三個領域為中心進行討論，分別是新的導彈防禦應有方式、經濟安保以及新冠疫情平息後的國際規則框架。<br />\n<br />\n報導稱，從2013年開始，日本首相安倍晉三就表達了希望擁有攻擊敵方基地能力的相關意願，但由於當時的美國<span style=\"font-size: xx-large;\"><span style=\"color: red;\">奧巴馬政府</span></span>表示關切，此事未能實現。<br />\n<br />\n日本宣布停止部署陸基「宙斯盾」系統的第二天，日本前防衛大臣小野寺五典在自民黨的會議上稱，「為了擁有遏制力，應該具備反擊能力」，強調有必要擁有對敵方基地的攻擊能力。"},{"pid":"e0a2caa75ba89c38a000c366272fb9e789c1c734","tid":2073440,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2dca4cef3e06bdd6bd8a7af7a47d664a5a4b3b9","tid":2073440,"uid":123175,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-06-21T10:37:38.000Z","msg":"主攻型自衛<br />\n美國畀就ok㗎啦"},"citedBy":0,"replyTime":"2020-06-21T10:45:14.000Z","msg":"到時打仗要幫手<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"04a348014931574dac1fc56efc30c0edda6691e0","tid":2073440,"uid":58552,"like":3,"dislike":0,"score":3,"quote":{"pid":"d7f884063a165142a61ee8d81d74112ea8f9794d","tid":2073440,"uid":40267,"like":1,"dislike":2,"score":-1,"citedBy":4,"replyTime":"2020-06-21T10:32:28.000Z","msg":"美國：家下你話事咩<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-21T10:45:46.000Z","msg":"美國就係要日本再軍事化<br />\n幫手"},{"pid":"f0a7e6b77600e34c9dbfb040315e4d35b4b523e4","tid":2073440,"uid":47356,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2dca4cef3e06bdd6bd8a7af7a47d664a5a4b3b9","tid":2073440,"uid":123175,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-06-21T10:37:38.000Z","msg":"主攻型自衛<br />\n美國畀就ok㗎啦"},"citedBy":0,"replyTime":"2020-06-21T10:45:59.000Z","msg":"進攻就是最強的防禦 (請自行翻譯日文) <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a95b6cb66f2c24586a1958243ae9a831ee2d9075","tid":2073440,"uid":310461,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-21T10:54:25.000Z","msg":"Will Japan by any chance take advantage of this opportunity to get  MORE AGGRESSIVE on military and political ambition??"},{"pid":"cdfec2a7fc6491bdbd24fc8de3b860c6a1a9eee0","tid":2073440,"uid":9348,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-21T10:56:13.000Z","msg":"<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" />"},{"pid":"a40e655e688e60c11fab5952240f3a6df61cce42","tid":2073440,"uid":31637,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-21T10:56:32.000Z","msg":"支持<br />\n只有日本武裝起黎, 亞州先有民主國家可以同D濕鳩獨裁國家抗衡"},{"pid":"c9052cd1bbc955cf956c044550fa6c58f001e79c","tid":207