unimap.wingzero.tw/uniform-hk/kowloon_w/htc/599c82a3fb56a83233dbdaf369da272a.jpg?w=640\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi1.wp.com%2Funimap.wingzero.tw%2Funiform-hk%2Fkowloon_w%2Fhtc%2F599c82a3fb56a83233dbdaf369da272a.jpg%3Fw%3D640&h=1d576cca&s={SIZE}\" /><br />\n<img src=\"https://i0.wp.com/unimap.wingzero.tw/uniform-hk/new_e/nyss/9dc91206fee9fd8866daac65eb891ccf.jpg?w=640\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi0.wp.com%2Funimap.wingzero.tw%2Funiform-hk%2Fnew_e%2Fnyss%2F9dc91206fee9fd8866daac65eb891ccf.jpg%3Fw%3D640&h=c77ee8db&s={SIZE}\" /><br />\n<img src=\"https://i2.wp.com/unimap.wingzero.tw/uniform-hk/new_w/tcss/004.jpg?w=640\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi2.wp.com%2Funimap.wingzero.tw%2Funiform-hk%2Fnew_w%2Ftcss%2F004.jpg%3Fw%3D640&h=b01ed17a&s={SIZE}\" /><br />\n<br />\n又係好似日本妹咁既格仔裙西裝款校服都有, 而且仲colourful過日本校服, 不過美中不足既係日本妹要攝恤衫, 香港唔使, 令到著上去望落肥咗, 同埋日本d西裝校褸slim好多, 香港就好多都又厚又肥, 或者用風褸<br />\n<img src=\"https://i1.wp.com/unimap.wingzero.tw/uniform-hk/hongkong/ssgc/003.jpg?w=640\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi1.wp.com%2Funimap.wingzero.tw%2Funiform-hk%2Fhongkong%2Fssgc%2F003.jpg%3Fw%3D640&h=8a39694e&s={SIZE}\" /><br />\n<img src=\"https://i1.wp.com/uniform.wingzero.tw/blog/wp-content/uploads/2015/07/41625965.jpg?w=400\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi1.wp.com%2Funiform.wingzero.tw%2Fblog%2Fwp-content%2Fuploads%2F2015%2F07%2F41625965.jpg%3Fw%3D400&h=5ec443fa&s={SIZE}\" /><br />\n我覺得聖家套校服隻色襯得好靚, 再加上學生妹着粉紅色真係更加青春同sweet<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"http://pic.pimg.tw/jlas300/1346324984-1378165310_n.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fpic.pimg.tw%2Fjlas300%2F1346324984-1378165310_n.jpg&h=7923f98f&s={SIZE}\" /><br />\n<img src=\"http://www.sundaykiss.com/wp-content/uploads/2015/02/14.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.sundaykiss.com%2Fwp-content%2Fuploads%2F2015%2F02%2F14.jpg&h=505ee721&s={SIZE}\" /><br />\n仲有paul con同藍田st paul既格仔裙, 佢地對鞋都非常特別<br />\n<img src=\"http://unimap.wingzero.tw/uniform-hk/kowloon_w/mcs/8997d399f432d91569adbfc635462f7b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Funimap.wingzero.tw%2Funiform-hk%2Fkowloon_w%2Fmcs%2F8997d399f432d91569adbfc635462f7b.jpg&h=1c6f9f04&s={SIZE}\" /><br />\n<img src=\"http://unimap.wingzero.tw/uniform-hk/new_e/tic/71f63565292fa02635842e1d25a335b5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Funimap.wingzero.tw%2Funiform-hk%2Fnew_e%2Ftic%2F71f63565292fa02635842e1d25a335b5.jpg&h=7ccfde93&s={SIZE}\" /><br />\n好似呢兩套咁既淺藍色同上面既淺綠, 日本d校服好少可會用啲咁淺既顏色<br />\n<br />\n香港仲有全世界獨有既長衫校服<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"https://i0.wp.com/unimap.wingzero.tw/uniform-hk/hongkong/ywgs/002.jpg?w=640\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi0.wp.com%2Funimap.wingzero.tw%2Funiform-hk%2Fhongkong%2Fywgs%2F002.jpg%3Fw%3D640&h=634b4b0e&s={SIZE}\" /><br />\n<img src=\"http://pic.pimg.tw/jlas300/1371134984-3912650373_n.jpg?v=1371134988\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fpic.pimg.tw%2Fjlas300%2F1371134984-3912650373_n.jpg%3Fv%3D1371134988&h=487ed706&s={SIZE}\" /><br />\n<img src=\"https://i.na.cx/E22327.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.na.cx%2FE22327.jpg&h=bebca3ff&s={SIZE}\" /><br />\n<br />\n不過係香港始終大部份校服夏天都係白色連身裙, 冬天就背心裙入面著件恤衫咁.......<br />\n但係其實日本都有呢啲校服, 尤其係冬季既背心裙, 佢地有唔少學校都係呢隻款, 但白色連身裙就少之又少啦<br />\n<img src=\"http://unimap.wingzero.tw/uniform-jp/hyogo-ken/shoin-jhs/56e31081f5f6a64e6ecfa93163733300.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Funimap.wingzero.tw%2Funiform-jp%2Fhyogo-ken%2Fshoin-jhs%2F56e31081f5f6a64e6ecfa93163733300.jpg&h=d5340315&s={SIZE}\" /><br />\n<img src=\"http://blog.so-net.ne.jp/_images/blog/_0c0/school-uniform/m_3379.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fblog.so-net.ne.jp%2F_images%2Fblog%2F_0c0%2Fschool-uniform%2Fm_3379.jpg&h=939c0be0&s={SIZE}\" /><br />\n呢個款係日本實在係太罕有, 所以佢地覺得好靚, 但我覺得好核突<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"http://fgmeisei.net/files/3312/8346/7547/high_w.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Ffgmeisei.net%2Ffiles%2F3312%2F8346%2F7547%2Fhigh_w.jpg&h=827d78cb&s={SIZE}\" /><br />\n<img src=\"http://seireihs.seto-seirei-js.ed.jp/assets_c/2014/09/slider_06-thumb-1015xauto-7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fseireihs.seto-seirei-js.ed.jp%2Fassets_c%2F2014%2F09%2Fslider_06-thumb-1015xauto-7.jpg&h=46ec10f1&s={SIZE}\" /><br />\n<img src=\"http://www.san-yu.net/landl/burusera/k_school/k_others/3112x.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.san-yu.net%2Flandl%2Fburusera%2Fk_school%2Fk_others%2F3112x.jpg&h=a860c888&s={SIZE}\" /><br />\n呢套件校褸同頂帽都好特別, 我覺得好靚<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"http://www.seisen-h.ed.jp/sp/albums/abm00000094.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.seisen-h.ed.jp%2Fsp%2Falbums%2Fabm00000094.jpg&h=785211b8&s={SIZE}\" /><br />\n<img src=\"http://www.sugiyama-u.ac.jp/high/assets_c/2015/01/life_uniform04-thumb-362x460-1213.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.sugiyama-u.ac.jp%2Fhigh%2Fassets_c%2F2015%2F01%2Flife_uniform04-thumb-362x460-1213.jpg&h=4866882b&s={SIZE}\" /><br />\n日本都一樣有呢啲校服架<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"}]}