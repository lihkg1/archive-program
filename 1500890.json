h"},{"pid":"c9bb1695a8473433e06491e8a05021ed219111da","tid":1500890,"uid":136737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T20:06:24.000Z","msg":"push"},{"pid":"bf8d56ea11c8292f49d66e8c7e70d133b7a8378e","tid":1500890,"uid":136737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T06:36:51.000Z","msg":"push"},{"pid":"0c23aaca81c944880d4116502f9f9544bfc83b3c","tid":1500890,"uid":136737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T08:21:55.000Z","msg":"push"},{"pid":"fff9536f6cc560894d6a45cf461c016aa4335281","tid":1500890,"uid":136737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T10:12:18.000Z","msg":"push"},{"pid":"96d6ea98da6fde2092c0b6c6a6b808049c4dc847","tid":1500890,"uid":153901,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-25T13:10:51.000Z","msg":"Pc?"},{"pid":"2553981517f4f8a792ccb09c5c5805ff4c4cf481","tid":1500890,"uid":246499,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-25T13:14:45.000Z","msg":"點down mod玩"},{"pid":"7de2a4c23c481e163b8f28bcb1aeede645ae1ead","tid":1500890,"uid":136737,"like":0,"dislike":0,"score":0,"quote":{"pid":"96d6ea98da6fde2092c0b6c6a6b808049c4dc847","tid":1500890,"uid":153901,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-25T13:10:51.000Z","msg":"Pc?"},"citedBy":0,"replyTime":"2019-08-25T15:44:53.000Z","msg":"yes"},{"pid":"d15b1332aa3dc9b60655918428eb90aa21ca7aa0","tid":1500890,"uid":136737,"like":0,"dislike":0,"score":0,"quote":{"pid":"2553981517f4f8a792ccb09c5c5805ff4c4cf481","tid":1500890,"uid":246499,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-25T13:14:45.000Z","msg":"點down mod玩"},"citedBy":0,"replyTime":"2019-08-25T16:04:43.000Z","msg":"預載咗係server 你入ser會自動下載"},{"pid":"9bd00944a99035274d725133532ea87788f5badb","tid":1500890,"uid":136737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T18:20:28.000Z","msg":"push"}]}