頭。<a href=\"https://www.thestandnews.com/court/9-21-%E5%B1%AF%E9%96%80-19-%E6%AD%B2%E5%AD%B8%E7%94%9F%E8%A2%AB%E6%8E%A7%E6%9A%B4%E5%8B%95%E7%BD%AA%E5%8F%97%E5%AF%A9-%E6%8E%A7%E6%96%B9-%E7%9D%A3%E5%AF%9F%E5%88%B6%E6%9C%8D%E8%A2%AB%E5%91%8A%E6%99%82-%E9%81%AD%E7%A4%BA%E5%A8%81%E8%80%85%E5%9C%8D%E6%AF%86/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F9-21-%25E5%25B1%25AF%25E9%2596%2580-19-%25E6%25AD%25B2%25E5%25AD%25B8%25E7%2594%259F%25E8%25A2%25AB%25E6%258E%25A7%25E6%259A%25B4%25E5%258B%2595%25E7%25BD%25AA%25E5%258F%2597%25E5%25AF%25A9-%25E6%258E%25A7%25E6%2596%25B9-%25E7%259D%25A3%25E5%25AF%259F%25E5%2588%25B6%25E6%259C%258D%25E8%25A2%25AB%25E5%2591%258A%25E6%2599%2582-%25E9%2581%25AD%25E7%25A4%25BA%25E5%25A8%2581%25E8%2580%2585%25E5%259C%258D%25E6%25AF%2586%2F&d=FWesCxf%2Fx1R8NKF8yEGh3RZ9qy%2BOiqBAJcOKDokr%2FlY%3D&h=9bdc13bb\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F9-21-%25E5%25B1%25AF%25E9%2596%2580-19-%25E6%25AD%25B2%25E5%25AD%25B8%25E7%2594%259F%25E8%25A2%25AB%25E6%258E%25A7%25E6%259A%25B4%25E5%258B%2595%25E7%25BD%25AA%25E5%258F%2597%25E5%25AF%25A9-%25E6%258E%25A7%25E6%2596%25B9-%25E7%259D%25A3%25E5%25AF%259F%25E5%2588%25B6%25E6%259C%258D%25E8%25A2%25AB%25E5%2591%258A%25E6%2599%2582-%25E9%2581%25AD%25E7%25A4%25BA%25E5%25A8%2581%25E8%2580%2585%25E5%259C%258D%25E6%25AF%2586%2F&h=f3328039\" data-auto-link target=\"_blank\">https://www.thestandnews.com/court/9-21-%E5%B1%AF%E9%96%80-19-%E6%AD%B2%E5%AD%B8%E7%94%9F%E8%A2%AB%E6%8E%A7%E6%9A%B4%E5%8B%95%E7%BD%AA%E5%8F%97%E5%AF%A9-%E6%8E%A7%E6%96%B9-%E7%9D%A3%E5%AF%9F%E5%88%B6%E6%9C%8D%E8%A2%AB%E5%91%8A%E6%99%82-%E9%81%AD%E7%A4%BA%E5%A8%81%E8%80%85%E5%9C%8D%E6%AF%86/</a>"}]}