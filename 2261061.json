%2FphpMP014N.png&h=ac6fe0ed&s={SIZE}\" />"},{"pid":"6599d85373bf93a0b57cf13893fd78784050b33b","tid":2261061,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-28T11:08:09.000Z","msg":"台海緊張升高 台灣擴大「戰備週」 全國兵力大演練"},{"pid":"71807caee36b5a04887f57d0cc2762fb298d8c56","tid":2261061,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"6599d85373bf93a0b57cf13893fd78784050b33b","tid":2261061,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-28T11:08:09.000Z","msg":"台海緊張升高 台灣擴大「戰備週」 全國兵力大演練"},"citedBy":0,"replyTime":"2020-10-28T11:11:54.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"}]}