ih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fcis%2F5e0edf23b66f770df1c1d410.jpg%2Ffmglfd4JvRlrfid8FPvW-Ki_Bo6ajH7x5HSKRuR0ikY&h=24a2f2fe&s={SIZE}\" /><br />\n<img src=\"https://cdn.hk01.com/di/media/images/cis/5e0edf23fd5cc31c9c2b8a72.jpg/l_0wxH8IMCL_-SAp9uqXRDuZSkCUUiSu0Ewd1tBMHdY\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fcis%2F5e0edf23fd5cc31c9c2b8a72.jpg%2Fl_0wxH8IMCL_-SAp9uqXRDuZSkCUUiSu0Ewd1tBMHdY&h=7794df81&s={SIZE}\" /><br />\n<img src=\"https://cdn.hk01.com/di/media/images/cis/5e0edf23b66f770df1c1d412.jpg/f6Uo-DLyaQe2_WyLQW05MH-Rdz_ECSVTdT-bUnU_m1I\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fcis%2F5e0edf23b66f770df1c1d412.jpg%2Ff6Uo-DLyaQe2_WyLQW05MH-Rdz_ECSVTdT-bUnU_m1I&h=e79385d1&s={SIZE}\" /><br />\n<img src=\"https://cdn.hk01.com/di/media/images/cis/5e0edf2323ab170deb421900.jpg/9Ar778WfLg9J7DmkgVMRjlGIk98pjsEzj6K9m4-ivZs\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fcis%2F5e0edf2323ab170deb421900.jpg%2F9Ar778WfLg9J7DmkgVMRjlGIk98pjsEzj6K9m4-ivZs&h=78f3d351&s={SIZE}\" /><br />\n<img src=\"https://cdn.hk01.com/di/media/images/cis/5e0edf23b66f770df1c1d413.jpg/OgJPOdexxa9uCNHpKwIjZ3wnqkSlIBynVdXr4lXV6-I\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fcis%2F5e0edf23b66f770df1c1d413.jpg%2FOgJPOdexxa9uCNHpKwIjZ3wnqkSlIBynVdXr4lXV6-I&h=d3c8d2c2&s={SIZE}\" /><br />\n<img src=\"https://cdn.hk01.com/di/media/images/cis/5e0edf2313d12b1ca2b90819.jpg/ZsrSPh2FbDt3Q5Viu3U2a0IalmlX64aGCY_c9gmP3PY\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fcis%2F5e0edf2313d12b1ca2b90819.jpg%2FZsrSPh2FbDt3Q5Viu3U2a0IalmlX64aGCY_c9gmP3PY&h=5bc7bcac&s={SIZE}\" /><br />\n<br />\n《港詭實錄》（原名《牛一》）是一款以香港都市傳說為題材的第一人稱恐怖冒險遊戲。故事講述一群年輕人為了錄製靈異節目「逃出靈界點」來到九龍城寨遺址，然而這次的錄製卻因為一些突發事件變得詭異起來。節目組員陸續失蹤、女主持人嘉慧的行為變得十分古怪，深陷其中的男主角阿樂開始懷疑是否觸碰到了某些禁忌，面對一連串的恐怖與謎團，他滿腦子想的就是趕快找到嘉慧立刻逃出這裡。<br />\n<br />\n遊戲融合大量香港本地的都市傳說，能夠從中體驗到許多獨特的本地文化與民俗習慣，此外遊戲還原了唐樓、粵劇戲棚、港式屋邨等極具中國地方文化特色的建築，玩家可以在其中自由探索，感受濃厚的香港氛圍。玩家需要在九龍城寨遺址中尋找解開謎團的線索，努力還原整個世界的真相，途中將會出現恐怖的敵人，要一邊躲避它們的追擊並找出逃離的道路。對香港的都市傳說感興趣或喜愛恐怖遊戲的玩家不妨在遊戲正式推出後來感受獨特恐怖氣氛的《港詭實錄》吧。<br />\n<br />\n<a href=\"https://www.youtube.com/watch?time_continue=37&amp;v=lUGpivp94IQ&amp;feature=emb_logo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Ftime_continue%3D37%26v%3DlUGpivp94IQ%26feature%3Demb_logo&d=4MF4O%2Bfy8eJNXT4C%2FvKi1ZmjxQ%2Bt9FMRZQKIc78GZWw%3D&h=324a5544\" target=\"_blank\">https://www.youtube.com/watch?time_continue=37&amp;v=lUGpivp94IQ&amp;feature=emb_logo</a>"},"citedBy":0,"replyTime":"2020-01-05T15:59:29.000Z","msg":"【香港2020設立立法會普選】正式成為美國法律，點解無人提？立即整次遊行向美國領事及國會提交2020普選立法會細節啊！！<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/eJBqGS\" data-auto-link target=\"_blank\">https://lih.kg/eJBqGS</a>"},{"pid":"7451944b411b11a2091675913c6dd39b55f6a3a4","tid":1812371,"uid":30924,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-05T16:33:43.000Z","msg":"支持盜版!"},{"pid":"6776aacec54f91fd0ebd673a4346e71a8c34f4d9","tid":1812371,"uid":52483,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-01-05T16:38:27.000Z","msg":"中国香港，不了<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"68050fd07cfb30ad67f4a7b65811daac989060d0","tid":1812371,"uid":27660,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2020-01-05T16:45:48.000Z","msg":"同還願差幾皮 摺埋啦柒頭"},{"pid":"79ea7d94f8c0a6ccf633e89cef7a6ac283a3de9c","tid":1812371,"uid":15626,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-01-05T17:10:33.000Z","msg":"垃圾 拉"},{"pid":"f836beb1dbc316820f7e2a4a8f5081d7b036d5b8","tid":1812371,"uid":33601,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-01-05T17:11:35.000Z","msg":"垃圾<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dea