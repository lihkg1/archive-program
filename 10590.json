3dS25JBA%2BUsIbL4fERhwM0ZRx9Zc9p0%3D&h=b56783f8\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=NxQsFEO1AGE</a> <br />\n<br />\nED5 &quot;Good Morning My Dream&quot; <br />\n<a href=\"https://www.youtube.com/watch?v=7ARAwvomxjw\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D7ARAwvomxjw&d=WTugOjWmLb2R3dS25JBA%2BUsIbL4fERhwM0ZRx9Zc9p0%3D&h=cc039953\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=7ARAwvomxjw</a><br />\n<br />\nAikatsu Stars！<br />\n<br />\n這是努力不懈的少女們以頂級偶像為目標，偶像活動！的成功故事。「偶像活動STARS！」偶像學校中的四星級學園。 校園中頂級偶像的4人以S4稱之，偶像界成功的象徵！ 新入學的新生們，都以S4為目標，在偶像活動中不斷努力。 讓閃爍的「偶像活動！卡片」大發光芒！ 為了讓自己大放異彩而親自製作！ 率直地變得更加明亮！ 唱歌也好，跳舞也好，時裝也好！ 女孩子的憧憬全部串連起來，嶄新的偶像活動開始了。 向著偶像的第一顆星，邁向夢想的開端！！<br />\n<br />\n<img src=\"http://cdn.myanimelist.net/images/anime/12/78658l.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcdn.myanimelist.net%2Fimages%2Fanime%2F12%2F78658l.jpg&h=1d6c2878&s={SIZE}\" /><br />\n<br />\nSTAFF<br />\n企劃、原作：BN Pictures<br />\n監　　督：佐藤照雄<br />\n系列構成：柿原優子<br />\n角色設計：愛敬由紀子<br />\n音響監督：菊田浩巳<br />\n音　　樂：onetrap<br />\n動畫製作：BN Pictures<br />\n<br />\nCAST<br />\n虹野夢　　：富田美憂<br />\n櫻庭蘿拉　：朝井彩加<br />\n七倉小春　：山口愛<br />\n早乙女亞子：村上奈津實<br />\n白鳥姬　　：津田美波<br />\n如月翼　　：諸星堇<br />\n二階堂柚子：田所梓<br />\n香澄夜空　：大橋彩香<br />\n<br />\n直播星期4約下午5時25分(即17:25)<br />\n<a href=\"http://mov3.co/tvtokyo/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fmov3.co%2Ftvtokyo%2F&d=WTugOjWmLb2R3dS25JBA%2BUsIbL4fERhwM0ZRx9Zc9p0%3D&h=982c8452\" data-auto-link target=\"_blank\">http://mov3.co/tvtokyo/</a> <br />\n<a href=\"http://vaughnlive.tv/sherming3333\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fvaughnlive.tv%2Fsherming3333&d=WTugOjWmLb2R3dS25JBA%2BUsIbL4fERhwM0ZRx9Zc9p0%3D&h=b6275b4e\" data-auto-link target=\"_blank\">http://vaughnlive.tv/sherming3333</a>"},{"pid":"7cdc613f5f4eaf678e3120721987d5ec8295e2bf","tid":10590,"uid":38308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-11-29T04:28:00.000Z","msg":"新手基本知識 #1 <br />\n一般操作 <br />\n<br />\nQ：舞台寫真係玩咩? <br />\nA：係人都知係一隻節奏音樂打丁GAME啦，問下電器街的本屋(userid=370627)啦： <br />\n<a href=\"http://youtu.be/_-lNhMR6T3Q\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fyoutu.be%2F_-lNhMR6T3Q&d=WTugOjWmLb2R3dS25JBA%2BUsIbL4fERhwM0ZRx9Zc9p0%3D&h=6ad9f515\" data-auto-link target=\"_blank\">http://youtu.be/_-lNhMR6T3Q</a> <br />\n<br />\n<br />\nQ：依隻GAME 有咩咁好勁? <br />\nA：拿，你知啦，都係Bandai 南夢宮營運，依隻GAME同THE IDOLM@STER　STARLIGHT STAGE個系統相似（目前無房間、ポテンシャル解放ect.） <br />\n<br />\n活動時間誤差應為大約1日　目前手遊3個活動方式會對應SLS的3個活動方式 分別在於細節位 自己試下就知 <br />\n<br />\n<br />\nQ：重複左既SR、SSR有咩用?\t<br />\nA：一係技UP，否則可以直接賣走出去用嚟儲綠寶石兌換PR/SR<br />\n<br />\n<br />\nQ：N卡R卡又有咩用? 係咪可以食晒佢?\t<br />\nA：食滿佢 進化前後各3星 強烈建議先處理一般N/R卡(因為目前沒有改動) <br />\n<br />\n<br />\nQ：D卡點食架？ <br />\nA：技UP下基本有&rdquo;大成功 X50% 特大成功 X100%&rdquo; <br />\n<br />\n<br />\nQ：見到起始畫面有Jonny動L緊？ <br />\nA：//簡單D講即係打肥，每日有3段時間會特別易出肥料卡(TRAINER)，跟素材時段每人唔同\t// <br />\n<br />\n<br />\nQ：點樣開新歌? <br />\nA：解STORY：1/1.5話1星，3/3.5話2星，5/5.5話3星，7/7.5話5星 <br />\n<br />\n<br />\nQ：點玩任務？ <br />\nA：基本上打日替材料／標誌已經OK，新黎既可以唔洗睇呢項 <br />\n<br />\n<br />\nQ：特訓材料點有？ <br />\nA：方邊啲咪：星期一到星期四係材料卡和稀有度標誌，五係刷錢，六/日肥料 <br />\n<br />\n<br />\nQ：打極都唔順手有咩SETTING可以較?\t<br />\nA：去紫色制－＞右一－＞各種調整，上面係設定譜速，下面係設定判定範圍 <br />\n<br />\n<br />\nQ：邊個最公廁?\t<br />\nA：高登巴打高海千歌 <br />\n<br />\n<br />\nQ：點樣先抽到PR? <br />\nA：&quot;根本就抽唔能到&quot; - 籬笆園的細野(userid=484726)<br />\n<br />\nQ：Explain the definition of Fan Club.(10 Marks)<br />\nA：你當呢個係玩絆點就得啦，但係呢個絆點都係用排名戰結算。。。<br />\n首次加入免費，以後加入為每個100萬心"},{"pid":"f430b891906ded642928525f2522adb13c82aa17","tid":10590,"uid":38308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-11-29T04:42:48.000Z","msg":"留名"},{"pid":"4f8d30bf27eb1dc0e7d66fe2b2d4e8540b0131a2","tid":10590,"uid":39181,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-11-29T06:58:04.000Z","msg":"on9"},{"pid":"1c91a14506bfea3887aa69963081de53f7620a99","tid":10590,"uid":41076,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2