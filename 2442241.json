":2442241,"uid":38189,"like":0,"dislike":0,"score":0,"quote":{"pid":"e3ccfe6e025f24cf5a2b9c3e329a458f74fa3d00","tid":2442241,"uid":73381,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2021-03-11T08:54:42.000Z","msg":"樓主點睇莫哥哥(莫生)？<br />\n<br />\n<img src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcSaW5ax.gif&amp;h=20957aa3&amp;s=540\" /><br />\n<br />\n<br />\n<img src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcSaW5ax.gif&amp;h=20957aa3&amp;s=540\" /><br />\n<br />\n<br />\n<img src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcSaW5ax.gif&amp;h=20957aa3&amp;s=540\" /><br />\n<br />\n<br />\n<img src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcSaW5ax.gif&amp;h=20957aa3&amp;s=540\" /><br />\n<br />\n<br />\n<img src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcSaW5ax.gif&amp;h=20957aa3&amp;s=540\" /><br />\n<br />\n<img src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcSaW5ax.gif&amp;h=20957aa3&amp;s=540\" />"},"citedBy":0,"replyTime":"2021-03-11T09:56:19.000Z","msg":"乜水；"},{"pid":"d66b190e5e3b83fc74540d10faeb0a36118391ec","tid":2442241,"uid":43861,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-11T11:13:30.000Z","msg":"白人版盧卡古fail"},{"pid":"7fcfe58bec3120ceb6850860c51f6b4c44c4797e","tid":2442241,"uid":34990,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-11T12:14:51.000Z","msg":"姐係控球波要十米？"}]}