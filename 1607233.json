a72a276d55f698c","tid":1607233,"uid":259088,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-30T18:45:12.000Z","msg":"大佬 係振軍心 唔係震散軍心<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-30T18:47:37.000Z","msg":"我冇打錯<br />\n睇完真係震軍心"},{"pid":"340cd7ce68316096332120ba98a7210c7404c0d3","tid":1607233,"uid":180114,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T18:47:55.000Z","msg":"加油"},{"pid":"2958754459f8e1116abfa2be366786dab8a65c3a","tid":1607233,"uid":294,"like":0,"dislike":0,"score":0,"quote":{"pid":"0b6fa3651275b7e39f97409ba9a65cec5d5bbe7e","tid":1607233,"uid":57786,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-30T18:38:28.000Z","msg":"<a href=\"https://youtu.be/UagswxGXNBY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FUagswxGXNBY&d=Cf%2FvPHDuk0dzuxx%2BuF7CddmOP5%2FvN4RyP%2Fy1e26q30o%3D&h=28222edc\" target=\"_blank\">https://youtu.be/UagswxGXNBY</a><br />\n<br />\n重點收看<br />\n<a href=\"https://youtu.be/Yd-eJS6Ur4w\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FYd-eJS6Ur4w&d=Cf%2FvPHDuk0dzuxx%2BuF7CddmOP5%2FvN4RyP%2Fy1e26q30o%3D&h=e23bd584\" target=\"_blank\">https://youtu.be/Yd-eJS6Ur4w</a><br />\n<br />\npopo下場<br />\n<a href=\"https://youtu.be/Td2n4KwXy7U\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FTd2n4KwXy7U&d=Cf%2FvPHDuk0dzuxx%2BuF7CddmOP5%2FvN4RyP%2Fy1e26q30o%3D&h=d2a7f0b8\" target=\"_blank\">https://youtu.be/Td2n4KwXy7U</a><br />\n<br />\n<br />\n有必死嘅覺悟<br />\n四十年後<br />\n應有人幫各位平反"},"citedBy":0,"replyTime":"2019-09-30T18:48:01.000Z","msg":"呢個channel good"},{"pid":"3751768e90131660a91c5903749aa1d811ab484d","tid":1607233,"uid":29979,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T18:48:18.000Z","msg":"大家聽日要有目標！唔好再賽跑啦！記得保護自己保護手足<br />\n<br />\n《終極軍師》勇武請入，十一「六區佔領政府部門」<br />\n<a href=\"https://lih.kg/1605991\" data-auto-link target=\"_blank\">https://lih.kg/1605991</a><br />\n- 分享自 