，又入黎波台呀？<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"ee964b42c61a897af90c2e4c995179b3cf70d188","tid":775121,"uid":196751,"like":4,"dislike":1,"score":3,"quote":{"pid":"474665d4791084980cc9618aa4d1d5fb68cb61c1","tid":775121,"uid":62020,"like":54,"dislike":0,"score":54,"citedBy":1,"replyTime":"2018-08-11T01:45:33.000Z","msg":"佢條褲放地下<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-11T01:57:51.000Z","msg":"睇佢可以就咁坐廁板就知唔正常"},{"pid":"653048fcf4712e3f060a2e8e465d68363bd4813a","tid":775121,"uid":44285,"like":15,"dislike":2,"score":13,"quote":{"pid":"eb3118f0bbc5f9a524e5462903fe1cb505e82a49","tid":775121,"uid":29093,"like":12,"dislike":11,"score":1,"citedBy":2,"replyTime":"2018-08-11T01:38:02.000Z","msg":"土地問題"},"citedBy":0,"replyTime":"2018-08-11T01:58:28.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/11/095811_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F11%2F095811_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=d9dbb33b&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/11/095813_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F11%2F095813_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=d2859438&s={SIZE}\" /><br />\n挫