82,"uid":307203,"like":0,"dislike":0,"score":0,"quote":{"pid":"94b57e01f818107e1ebd73eadbf8eea343d9f50b","tid":1932182,"uid":92110,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-18T16:16:58.000Z","msg":"完全推唔起<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-18T16:32:57.000Z","msg":"係咁㗎啦<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n如果唔做標題黨、屌人、唔上熱門等於連登已死或者某啲重要嘅大事出現咗，大家急需行動post 先上到"},{"pid":"b51d0ad098ed4f276236cf445f094003d80e5eaf","tid":1932182,"uid":174676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:02:56.000Z","msg":"Push"},{"pid":"e74e1248d2eb9ffe80dae984bb4a1b5ac96d66b2","tid":1932182,"uid":99558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:09:18.000Z","msg":"Push<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"5df37819830b5d6d13c90306f7c6ce206d35a4f5","tid":1932182,"uid":207462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:13:00.000Z","msg":"推"},{"pid":"5c681c83549c84c455662a5893b3791a07227d5c","tid":1932182,"uid":151313,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:23:06.000Z","msg":"推"},{"pid":"dca6d99a3e450f6b6356ff8362c9a685a8e7be80","tid":1932182,"uid":332969,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:25:17.000Z","msg":"push"},{"pid":"731f78a502cb511a0b3973e7578ea46b7d104bcf","tid":1932182,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:31:47.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0b09dc68ffbf2eba9b69830bd0b94952e7036610","tid":1932182,"uid":113545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:42:17.000Z","msg":"<img src=\"/