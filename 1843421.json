" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/sneeze.gif\" class=\"hkgmoji\" />"},{"pid":"55341f66bfe58c443379f320a9ceff51e5d73987","tid":1843421,"uid":8007,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-26T08:34:27.000Z","msg":"<a href=\"http://bit.ly/2Gq55NO\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fbit.ly%2F2Gq55NO&d=1bJdDSIrk6tBa%2BBM68SGesjT01h1KCp2%2Bw2KB0oDRGE%3D&h=cfc89c91\" data-auto-link target=\"_blank\">http://bit.ly/2Gq55NO</a><br />\n<br />\n武漢新型冠狀病毒肺炎疫情持續蔓延，有公立醫院醫護人員向《立場新聞》透露，本港出現第六宗確診個案，現時在灣仔律敦治醫院留醫，將轉送瑪嘉烈醫院。有醫護人員指，病人從武漢返港，早前因報稱被狗咬，往律敦治醫院急症室求醫，當時並沒有出現呼吸道感染徵狀，亦沒有出現發燒。<br />\n<br />\n醫護人員續指，病人起初到急症室求醫時，並沒有表示早前從武漢回港，直至為病人治療時，病人報稱自己曾到武漢，醫護人員隨即為病人進行病毒測試，初步對新型冠狀病毒呈陽性反應。<br />\n<br />\n但《南華早報》今日（26日）下午報道指，病人為香港人，早前曾赴武漢後有發燒跡象，經高鐵回港，現時未知他是何時從內地回港，是第二名確診的香港居民。"},{"pid":"2d5db0d2a2e8eedc526c2897ca0502352419b5ad","tid":1843421,"uid":120918,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-01-26T08:34:52.000Z","msg":"<img src=\"https://na.cx/i/oadnp7U.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Foadnp7U.jpg&h=d4bbb3b4&s={SIZE}\" />"},{"pid":"d5098d5f0c802efb4f12d4b636ff46b6a9560bb9","tid":1843421,"uid":226562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-26T08:35:09.000Z","msg":"pish"},{"pid":"5d95c38a9616beca1da6655dae941377a129f9ef","tid":1843421,"uid":254196,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-01-26T08:36:41.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d95150fb8844b0780d3dbd6ecd4f963fd97a5dea","tid":1843421,"uid":68111,"like":0,"dislike":0,"score":0,"quote":{"pid":"5d95c38a9616beca1da6655dae941377a129f9ef","tid":1843421,"uid":254196,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-01-26T08:36:41.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-26T08:37:02.000Z