,"dislike":0,"score":0,"quote":{"pid":"87f9e6750bceac9db912ece76d7e80b215d7f5aa","tid":915583,"uid":206726,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-04T13:33:00.000Z","msg":"尤其係爭鮮<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-04T13:34:18.000Z","msg":"有同感呀屌你<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"d0c49e7d2931541d27023ecadaf52d05b402a866","tid":915583,"uid":46042,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-04T13:36:16.000Z","msg":"唔讀書係做呢啲㗎啦<br />\n<br />\n大學生讀書咁辛苦就係唔想做呢啲<br />\n<br />\n<br />\n唔通人哋讀左四五年書辛苦完 又再做呢啲工辛苦咩"},{"pid":"70c1007f1c53a87aaf5980b83a2c5251c4274848","tid":915583,"uid":221490,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-04T13:40:07.000Z","msg":"我做飲食果幾年未試餓親<br />\n頂唔順叫水吧比塊包頂住先"}]}