{"tid":315923,"cid":9,"subCid":0,"title":"(2018韓國出) 瑪奇 Mobile","createTime":"2017-07-10T11:14:51.000Z","updateTime":"2017-07-11T17:46:25.000Z","uid":623,"like":3,"dislike":0,"uniUserReply":0,"replies":[{"pid":"326058ec89d0bd71a57e93671fbd497ca622059c","tid":315923,"uid":623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-10T11:14:51.000Z","msg":"<img src=\"https://blog.files.qoo-app.com/wp-content/uploads/2017/07/17071009005136.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fblog.files.qoo-app.com%2Fwp-content%2Fuploads%2F2017%2F07%2F17071009005136.jpg&h=dd64ce5b&s={SIZE}\" /><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=_dQQf2YIgV4#action=share\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D_dQQf2YIgV4%23action%3Dshare&d=Q4DHlrE7E8M427wnwqbRS6WGW%2FHqnCni%2B1xW1zXhD2s%3D&h=83ef7cc5\" target=\"_blank\">https://www.youtube.com/watch?v=_dQQf2YIgV4#action=share</a><br />\n<br />\n一聽到首音樂已經喊出來<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />  <br />\n<br />\nNEXON 今日（7月10日）宣佈，由 NEXON Korea Corporation 基於 PC 多人線上遊戲《瑪奇》開發的新作手機 MMORPG 《瑪奇 Mobile》將於2018年在韓國推出。<br />\n<br />\n於7月9日在韓國舉辦的《瑪奇》玩家線下活動上，NEXON 最先公佈了這個消息，並在會場上公開了遊戲首部宣傳片。據悉，遊戲由 NEXON Korea Corporation 的 devCAT Studio 工作室開發，從宣傳片來看本作似乎比較注重玩家的社交。<br />\n<br />\n<a href=\"https://news.qoo-app.com/96552/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.qoo-app.com%2F96552%2F&d=Q4DHlrE7E8M427wnwqbRS6WGW%2FHqnCni%2B1xW1zXhD2s%3D&h=c440c70f\" target=\"_blank\">https://news.qoo-app.com/96552/</a>"},{"pid":"27c82c68d0f6a67e57c6b8b5314e60048cd20c3d","tid":315923,"uid":623,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-10T11:38:23.000Z","msg":"推"},{"pid":"909eaec26edef7cb23ee1929121309b870209e27","tid":315923,"uid":24559,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-10T11:39:46.000Z","msg":"掛羊頭"},{"pid":"cf42c426e5803615826d08e433aff1d1921cf1b8","tid":315923,"uid":24163,"like":0,"