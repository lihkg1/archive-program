ef7b9084ac6a5f51dd9d10b2f3d9d","tid":1467612,"uid":296341,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-14T01:13:34.000Z","msg":"此回覆已被刪除"},{"pid":"b3f5b9c54195237901ad54af42d98f6db79fe2d1","tid":1467612,"uid":292131,"like":0,"dislike":0,"score":0,"quote":{"pid":"18be037ed75ef7b9084ac6a5f51dd9d10b2f3d9d","tid":1467612,"uid":296341,"like":0,"dislike":0,"score":0,"quote":{"pid":"d408dc88f78653883cadb5f641dc815974b769db","tid":1467612,"uid":292131,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-13T23:26:31.000Z","msg":"機管局唔比人check-in 又照飛 <br />\n呢個係政府行政失當所致<br />\n就算追討損失 可以搵邊個示威者追討？<br />\n<br />\n道歉 唔係一句就算<br />\n唔係形式化 口交部 係要有實質嘅道歉<br />\n要承擔之後嘅責任 賠錢 你賠到幾多個<br />\n<br />\n如果要道歉<br />\n不如就有催淚彈入民居都道埋歉？<br />\n<br />\n最後要選擇道歉嘅 無人會阻止大家嘅行動<br />\n<br />\n不分化 不割蓆<br />\n光復香港時代革命"},"citedBy":1,"replyTime":"2019-08-14T01:13:34.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-08-14T01:16:27.000Z","msg":"機場停飛又係關示威者事咩<br />\n幾個手足噤大權可以叫停機場<br />\n無嘅話噤就咩要對歉?"},{"pid":"a481d5a28222a9186f79a6410ad36bf2e770b18a","tid":1467612,"uid":116105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T01:20:09.000Z","msg":"推"},{"pid":"93d0fea808cb2799758835e90238c4334772f0df","tid":1467612,"uid":296341,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T01:22:07.000Z","msg":"此回覆已被刪除"},{"pid":"8757502903d89c3e36d5ce95d09af15e23391a43","tid":1467612,"uid":292131,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T01:36:30.000Z","msg":"攔路搞到清場果D 咪示威者<br />\n道歉個方向都要岩<br />\n唔係為停運輸而係令居民有bad experience 而道歉<br />\n<br />\n屌，射催淚彈關我地撚事，但係打擾到居民就真心關事<br />\n<br />\n理性討論"},{"pid":"c2076c7e83f08f8d17de847e5d20316536c30d92","tid":1467612,"uid":32505,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T02:36:46.000Z","msg":"推呀<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"a26cbc82475d0a4198f21b02511ecccc4999c235","tid":1467612,"uid":291426,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T02:40:16.000Z","msg":"海外文宣寫左封對遊客嘅道歉信<br />\n<a href=\"https://lih.kg/1468990\" data-auto-link target=\"_blank\">https://lih.kg/1468990</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"5a83c9dc30e0882cdd253deee7e7b0105ee6dc61","tid":1467612,"uid":90692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T03:01:08.000Z","msg":"推"},{"pid":"328c570dea5b368c88c3dd27a5df7bb26281f4db","tid":1467612,"uid":105995,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T03:02:01.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"d8ec8a81867b5f756c97f28917fd87eb55b0b840","tid":1467612,"uid":90692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T03:02:31.000Z","msg":"小心有鬼，不過我相信和理非會理性。<br />\n見到啲鬼， 由佢自己一個激動自己行開。<br />\n同一時間和理非都要大膽小小， 見到搞事嘅人要開聲。"},{"pid":"2340765ffffe8a20ea3c822df0ba29faa6153afa","tid":1467612,"uid":7738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T03:05:02.000Z","msg":"點解要道歉<br />\n其實就好似 Good cop bad cop 咁<br />\n一個打完一個拉走話唔好意思"},{"pid":"46d5cdd50419a59276079068bb9116fbe4b4be66","tid":1467612,"uid":105995,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T03:24:17.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"57233b792db0674c763877476e8892f739e68c79","tid":1467612,"uid":199911,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T03:25:53.000Z","msg":"可愛的香港人&hellip; 唔好俾憤怒蒙敝理智 勿忘初衷<br />\n我地爭取嘅五大訴求 為咁多位義士討回公道<br />\n捉鬼黎打 阻住救護 真係無補於事<br />\n但話咗不分化 都不割蓆 <br />\n每次都有吸取到嘅經驗 我地下次做得更好!<br />\n加油<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"857beabcb8adaeae6689071e0bc46b5f27f811de","tid":1467612,"uid":252510,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T03:31:35.000Z","msg":"推"},{"pid":"8f3f1302517f05ba478499ed429cd4b179745020","tid":1467612,"uid":269428,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T04:55:20.000Z","msg":"Push<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d7363cd7b19c883789425cf11d5c02375055a313","tid":1467612,"uid":14494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T04:59:45.000Z","msg":"呢步點睇<br />\n今日一定要入機場幫啲旅客追究航班假取消 暫時唔洗玩癱瘓住<br />\n<a href=\"https://lih.kg/1470272\" data-auto-link target=\"_blank\">https://lih.kg/1470272</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"b41ca3c1dee20535778f4ca6e52cbdf9350ac121","tid":1467612,"uid":46534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:00:44.000Z","msg":"<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2764be93ca3430137da2951cabdb02f25639723a","tid":1467612,"uid":35776,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:03:17.000Z","msg":"唔洗道歉呀，最盡同私下旅客講聲多謝耐心等候就得，所有公司都係多謝人等候，旅客唔係市民嘅客仔唔需要道歉"},{"pid":"d2b7ab752114fa834317de1b44e359f355d73d6b","tid":1467612,"uid":241844,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:03:54.000Z","msg":"道歉對象純粹係旅客，係旅客<br />\n<br />\n打警察打公安我無意見  大家開緊戰無誰對誰錯<br />\n但搞到旅客肯定係無辜，<br />\n阻人返屋但回講都唔通"},{"pid":"6f24ad31db72437afef071855e80b7ac03e49238","tid":1467612,"uid":241844,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:06:09.000Z","msg":"道歉一樣最緊要人多先顯得有誠意。求下大家放工去"},{"pid":"dac878d2eaa425c47c3fc63d9a8017acc026e9fe","tid":1467612,"uid":144787,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:08:25.000Z","msg":"推, 話左各有各做<br />\n咁琴日塞完今日咪道歉, 比人睇我地有自省係好形象<br />\n我地而家係唔完美!但可接受!可改善!<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><br />\n<br />\n加油各位手足<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"3b762176a418efd902b0a3f3a317f0d0540cf291","tid":1467612,"uid":267959,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:10:08.000Z","msg":"推"},{"pid":"c47831b74238a2ad1159c39cb1a8bc93c13e3516","tid":1467612,"uid":267959,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:34:51.000Z","msg":"推"},{"pid":"60ac6b46b300e2aa3facd8b9e47acc6c9edd412e","tid":1467612,"uid":60740,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:42:05.000Z","msg":"及時道歉嘅威力可以好強<br />\n林鄭民怨咁大其中一個因素就係死撐唔道歉<br />\n好後期先出黎道歉<br />\n以退為進做下公關show冇咩問題"},{"pid":"b2f9b1d2475e3f8f13af6fd487352b731be2318e","tid":1467612,"uid":264564,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:43:39.000Z","msg":"支持！"},{"pid":"3e771e81a6d4dd23d545498ddffe7a04c691d26c","tid":1467612,"uid":33984,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:44:43.000Z","msg":"推"},{"pid":"4e80430f7e71ba6ca4da208aea26b6d2ae05a23c","tid":1467612,"uid":37894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:45:46.000Z","msg":"我地應該每星期搵一日，同一個時間一齊搭車入機場<br />\n<a href=\"https://lih.kg/1468945\" data-auto-link target=\"_blank\">https://lih.kg/1468945</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"a615e2f150319c66790fc5ab76e53dfc7fdc7963","tid":1467612,"uid":207826,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:45:59.000Z","msg":"push"},{"pid":"8c29c81cf7c4877e995fb9d07f7485266873b620","tid":1467612,"uid":270506,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:47:58.000Z","msg":"陳雲：機場的事，絕對不要道歉！同大家講下謠言戰術，rumour tactics。因為謠言需要用民間文學和民間藝術形態，故此是民俗學的學術研究題目，我在德國讀書的時候，研究過二次大戰的謠言戰術，納粹集團及英美盟軍也用。<br />\n示威者在機場犯錯，滋擾旅客，拘禁北京記者，阻礙警方救援，是否要道歉呢，甚至要做圖道歉呢？<br />\n你以為你的對手是無權力任你說有食藥、無食藥而恆久寬恕你的學者陳雲嗎？你的對手是謠言高手中國共產黨，殘酷狡猾的獨裁蘇維埃政府。你的一個錯誤的舉動，足以引發共產黨派武警團進入機場維持國際航班的秩序&mdash;&mdash;在香港警方的邀請及授權之下，香港警方可以將中共的武警納入香港臨時編制的。中共的武警團將文明禮貌處事，國際旅客也會諒解。一旦武警團進入香港警察編制，香港就進入烏克蘭模式，但我們不是烏克蘭人！這個要知己知彼。我們很多人準備放棄香港移民的，也有外國護照在手。<br />\n中共造謠沒問題，他們自己人也不信的，只是服從淫威。香港示威者的道歉，就是自己承認錯誤，不打自招，給了中共堅實的材料來做宣傳，那麼不單止大陸人會信、香港人也會信、國際社會也會信。你水洗都不清，因為你往自己身上潑污水！<br />\n好彩機管局裡面有聰明人，昨晚懂得申請法庭禁制令，救了示威者。請停止機場的無聊滋擾行為，改為在市區球場公園做和平集會和展覽，請外國領事做監護，遇到中共特務滋擾就散去，由得他們在外國人的親見之下破壞展品。領事走了你就散去，不要佔領，不要過夜。出事的。"},{"pid":"6082a5a71a18e19a4bc075fbfd2ed8b9f1714bbc","tid":1467612,"uid":285632,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T05:49:22.000Z","msg":"推"},{"pid":"7aa1beebe88b510178e1d0490e9a48514cd38d02","tid":1467612,"uid":300554,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-14T05:51:32.000Z","msg":"<img src=\"/assets/faces/lomoji/18.png\" class=\"hkgmoji\" /><br />\n<br />\n［高手請入］在情在理，唔需要道歉，只需要國際級文宣洗白<br />\n<a href=\"https://lih.kg/1470244\" data-auto-link target=\"_blank\">https://lih.kg/1470244</a><br />\n- 分享自 LIHKG 討論區"}]}