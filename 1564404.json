%2F2riOQwO.jpg&h=074cd595&s={SIZE}\" /><img src=\"https://na.cx/i/uCaEXbO.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuCaEXbO.jpg&h=0736be80&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/shojk9N.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fshojk9N.jpg&h=e87f4f61&s={SIZE}\" /><img src=\"https://na.cx/i/u72wcgs.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fu72wcgs.jpg&h=4e7ea801&s={SIZE}\" /><img src=\"https://na.cx/i/hdRT928.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhdRT928.jpg&h=fe5ef654&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/KCfhVw9.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKCfhVw9.jpg&h=cc4a2b71&s={SIZE}\" /><img src=\"https://na.cx/i/F6BpAxa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FF6BpAxa.jpg&h=4f61ec87&s={SIZE}\" /><img src=\"https://na.cx/i/SRYWrDQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSRYWrDQ.jpg&h=7f1b8468&s={SIZE}\" /><img src=\"https://na.cx/i/G1orOSa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FG1orOSa.jpg&h=6f8244b3&s={SIZE}\" /><img src=\"https://na.cx/i/iOobZYR.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiOobZYR.jpg&h=d87249b8&s={SIZE}\" /><br />\n@期望連仔幫手壓制fake news <br />\n@上連登要用多用腦！<br />\n預備大型商場不合作運動：<br />\n齋睇唔買，儲多d錢；人多自然塞<br />\n連儂牆戰線不能倒！修建連儂，有你有我<br />\n<br />\n<ins>考驗毅力與堅持</ins><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><span style=\"color: red;\">做更具價值嘅野</span><br />\n#離開同溫層，接觸各種人，理解佢地嘅想法，將不支持我們的人轉為支持我們！這是成功的方法！<br />\n<br />\n<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" />抗爭/革命搞十年八載唔出奇<br />\n<span style=\"font-size: small;\">衛城革命，生活抗爭；拖垮邪惡、打倒腐敗；</span><br />\n<em>每日任務：</em><br />\n1. 優先<span style=\"color: red;\">幫襯</span>良心商店<br />\n2. <span style=\"color: red;\">抵制</span>「邪惡」「無良」的商戶，例如cctvb廣告、黨鐵商埸、黑社會、打壓員工的店鋪，減少淘寶<br />\n3. <span style=\"color: red;\">免費港鐵</span>（注意安全）；二人同遊，一人免費；買平飛；長者八達通<br />\n4. 夜晚<span style=\"color: red;\">十點咆哮</span>！（改9點會少好多人）<br />\n5. <span style=\"color: red;\">健身+運動</span>，身體健康，鬥長命<br />\n6. <span style=\"color: red;\">每日一post</span>，社交媒體戰（Twitter, IG, Facebook, Reddit) #HongKongProtest #Chinazi<br />\n#FreeHongKong #HongKongProtests <br />\nTwitter 共識頻道 <a href=\"https://t.me/twittermansyunzou\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Ftwittermansyunzou&d=m%2FBV6vIUiVByATU953YnmAwUjfZSuDKj7BL2vQxkRkA%3D&h=ddaac854\" target=\"_blank\">https://t.me/twittermansyunzou</a><br />\n7. 不要說推，試著copy and paste呢段嘢<br />\n8. 保持<span style=\"color: red;\">獨立思考</span>，分析能力level up，<strong><span style=\"color: red;\">冷處理fake news/ rumour</span></strong> 、五毛分化post<br />\n<br />\n<em>每星期任務：</em><br />\n1. <span style=\"color: red;\">低消費</span>，高儲蓄；罷買Bye Buy Day：星期日、星期五(唔買非必需品）<br />\n2. <span style=\"color: red;\">做孝子救港</span>，關心下老母老豆老人家，自己老母自己救<br />\n3. 去<span style=\"color: red;\">連儂牆</span>貼3張文宣，輸出革命思想<br />\n<br />\n<em>每月任務：</em><br />\n1. 出糧換美金、買美股，MPF轉美國<br />\n2. 搵多一個人參與<br />\n3. 關心社會、陪審員、派傳單、放映會<br />\n或者做唔足，但我會堅持到尾；Best effort，你呢？<br />\nVersion 2019.09.14"},{"pid":"22756817eb63da688fb01598b918e4873d35141d","tid":1564404,"uid":255313,"like":0,"dislike":0,"score":0,"quote":{"pid":"534b91d98b2ec64d76bd3272318ab3ed64e3e017","tid":1564404,"uid":291405,"like":0,"dislike":0,"score":0,"quote":{"pid":"b9e164f9e94bbf17f20d9fa1d1f130874e5fb36e","tid":1564404,"uid":141435,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-12T18:01:12.000Z","msg":"胡椒粉，縮骨遮，口罩，電筒。<br />\n<br />\n帶齊先好出街，除非你手停口停。<br />\n<br />\n唔想再見到啲跳閘post 有人話見到手足畀人捉咗去罰錢。然後話sor9ry自己趕時間or 冇能力幫到手，但又有本事上黎開post。<br />\n<br />\n啲藍絲恰學生post 又係，學生畀藍絲捉住，你可以胡椒粉灑佢 開電筒射鳩佢。而唔係上黎開post<br />\n<br />\n四項日常裝備又唔係重 又唔犯法，旁身總好過你有事赤手空拳 / 淨係可以拍片。"},"citedBy":2,"replyTime":"2019-09-16T14:42:30.000Z","msg":"電筒還是 laser pen