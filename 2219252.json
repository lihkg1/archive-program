{"tid":2219252,"cid":5,"subCid":11,"title":"蘋果A1: 公安呈請逮捕12名港人 警循組織跨境犯罪查 家屬斥變相認非法禁錮","createTime":"2020-09-26T17:52:59.000Z","updateTime":"2020-09-27T06:21:20.000Z","uid":240362,"like":25,"dislike":2,"uniUserReply":35,"replies":[{"pid":"065ff284a72be8b2760d0609fbf6122fb7c3d7eb","tid":2219252,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-26T17:52:59.000Z","msg":"<img src=\"https://scontent-hkt1-1.xx.fbcdn.net/v/t1.0-9/120236198_10159482158627448_2574960008357242863_o.jpg?_nc_cat=110&amp;_nc_sid=8bfeb9&amp;_nc_ohc=m3OrkeMOMNsAX-k0Lio&amp;_nc_ht=scontent-hkt1-1.xx&amp;oh=10f433cc0259afc19a47888f55c0686c&amp;oe=5F96A3FE\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkt1-1.xx.fbcdn.net%2Fv%2Ft1.0-9%2F120236198_10159482158627448_2574960008357242863_o.jpg%3F_nc_cat%3D110%26_nc_sid%3D8bfeb9%26_nc_ohc%3Dm3OrkeMOMNsAX-k0Lio%26_nc_ht%3Dscontent-hkt1-1.xx%26oh%3D10f433cc0259afc19a47888f55c0686c%26oe%3D5F96A3FE&h=70e65ac4&s={SIZE}\" /><br />\n<br />\n香港蘋果日報<br />\n【A1頭條】12港人被指「越國」遭內地拘留，一直冷待事件的警方昨晚突然發表新聞稿，引述廣東省公安廳表示，深圳市公安局鹽田分局稍後會向法院申請批准逮捕12名港人，香港警方則循是否有人組織及策劃跨境犯罪的方向調查。有港人家屬要求政府公開事發時的雷達報告及完整的資訊紀錄；有港人家屬委託的律師估計，內地警方亦希望港警擴大案件偵查範圍。<br />\n<br />\n<a href=\"https://www.facebook.com/hk.nextmedia/photos/a.10150161306277448/10159482158622448\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fhk.nextmedia%2Fphotos%2Fa.10150161306277448%2F10159482158622448&d=31jm0GaxjznMjcF0xOQh0nvcSryOYOd41eK7VOq09cM%3D&h=e351a99a\" data-auto-link target=\"_blank\">https://www.facebook.com/hk.nextmedia/photos/a.10150161306277448/10159482158622448</a>"},{"pid":"36f78eea482c39cb9cd00572d5ca9899a5282911","tid":2219252,"uid":284432,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-09-26T17:54:35.000Z","msg":"此回覆已被刪除"},{"pid":"d8aaa9eed40aaced7cb19299dca67bb2fdc145c0","tid":2219252,"uid":240362,"like":0,"dislike":1,"score":-1,"quote":{"pid":"36f78eea482c39cb9cd00572d5ca9899a5282911","tid":2219252,"uid":284432,"like":1