=\"/assets/faces/pigxm/argue.gif\" class=\"hkgmoji\" />"},{"pid":"90ff87be243dabdc34b8f7f8168e52e310b441c9","tid":1803973,"uid":103981,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-12-30T16:06:19.000Z","msg":"湯文亮好似好多時都燈燈地"},{"pid":"d885e657fbbfc982a9fc5d4f5f85196e94fdd13d","tid":1803973,"uid":137569,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-12-31T01:32:40.000Z","msg":"唉<br />\n加快睇樓要"},{"pid":"2e4ab0a53ee9fbcd30080b7f7e26118675a24fbe","tid":1803973,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-31T02:17:51.000Z","msg":"垃圾藍絲 連登淡友既偶像"},{"pid":"a5b99226b6cb319578536ee8337d117e6cb596dc","tid":1803973,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-31T02:18:42.000Z","msg":"房屋台有冇人好欣賞湯文亮,亮亮??<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1760225\" data-auto-link target=\"_blank\">https://lih.kg/1760225</a>"},{"pid":"0357febdfe7342bb4e37d8a77f1ef9e088c89602","tid":1803973,"uid":18395,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-12-31T09:03:47.000Z","msg":"睇吓天水圍個垃圾盤收成4千票<br />\n就知暴動都唔會影響樓市<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"235db37072e1e7632826ef649f043810b1f6a6b4","tid":1803973,"uid":76363,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-31T09:05:53.000Z","msg":"條友正垃圾<br />\n一路唱淡一唔入貨"},{"pid":"991db2205bbae309e4bd3da663b7eb9e089d5e95","tid":1803973,"uid":316048,"like":1,"dislike":0,"score":1,"quote":{"pid":"235db37072e1e7632826ef649f043810b1f6a6b4","tid":1803973,"uid":76363,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-31T09:05:53.000Z","msg":"條友正垃圾<br />\n一路唱淡一唔入貨"},"citedBy":1,"replyTime":"2019-12-31T09:20:27.000Z","msg":"之臨跌前買左陽明山莊，佢話自住驚閪"},{"pid":"6655352087c79dae87d638fb6bf3ee1a5d5be40d","tid":1803973,"uid":76363,"like":0,"dislike":0,"score":0,"quote":{"pid":"991db2205bbae309e4bd3da663b7eb9e089d5e95","tid":1803973,"uid":316048,"like":1,"dislike":0,"score":1,"quote":{"pid":"235db37072e