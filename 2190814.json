 src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1c70ce062654edb6675e803e8fea387fbb34fa9a","tid":2190814,"uid":223256,"like":0,"dislike":10,"score":-10,"quote":{"pid":"56cbbd4a14fd7c583765f714b28a0f6357150d4f","tid":2190814,"uid":34444,"like":13,"dislike":0,"score":13,"citedBy":1,"replyTime":"2020-09-06T04:42:02.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />覺得樓主有啲過分放大<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />呢本野撚有人會睇咩"},"citedBy":0,"replyTime":"2020-09-06T04:44:53.000Z","msg":"日本人做生意講誠信講老實<br />\n你係用機器就光明正大地講<br />\n我唔信因為咁d人會唔食你<br />\n但呢套漫畫宣傳手法<br />\n真係令我覺得壽司郎同大陸公司無乜分別<br />\n同爭鮮用紅鱒魚當三文魚無分別<br />\n爭鮮都唔會講明係三文魚架<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"3917521be47dd0ff0cb6f9bc348f8446013accb4","tid":2190814,"uid":18484,"like":9,"dislike":0,"score":9,"quote":{"pid":"c0ad1a1f693f782e329d4352e77d99b34c8436d7","tid":2190814,"uid":223256,"like":1,"dislike":16,"score":-15,"quote":{"pid":"61f176443f1246df237a6a4a7c64c12e6e299c3d","tid":2190814,"uid":65933,"like":2,"dislike":0,"score":2,"quote":{"pid":"9431ef5a1c890c2f5f7c2f4048959c7981d5accb","tid":2190814,"uid":223256,"like":4,"dislike":43,"score":-39,"citedBy":3,"replyTime":"2020-09-06T04:35:30.000Z","msg":"你用機器整壽司無問題<br />\n你用漫畫方法都無問題<br />\n但你用(漫畫情節)講到壽司郎比人迫害<br />\n焗住用機器整壽司就大有問題<br />\n因為現實無人迫害壽司郎<br />\n只係因為經營原因咁做<br />\n你仲要話機器整得好食過人手<br />\n你唔係侮辱傳統壽司店係乜?<br />\n<br />\n爭鮮同元氣都會用機器<br />\n無人會怪壽司郎你都用<br />\n但你搵將太的壽司司個作者去老作劇情係合理發機器壽司就係卑鄙行為<br />\n點解唔光明正大去宣傳?<br />\n要用下三流既手段?<br />\n你唔止整臭壽司郎<br />\n仲整臭埋寺尺大介呀屌你<br />\n<br />\n將太的壽司幾時有講過機器好過人手呀屌你老母"},"citedBy":1,"replyTime":"2020-09-06T04:39:17.000Z","msg":"故事都唔得？<img src=\"/assets/faces/normal/sosad.gif\" c