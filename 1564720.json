src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FvT4RM4L.jpg&h=df76b23e&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/rzGAuh5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrzGAuh5.png&h=ca4279a5&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/rNqtPh5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrNqtPh5.jpg&h=7b424a2c&s={SIZE}\" />"},{"pid":"2b88e7831ee1ffa5710eb53febc671afe0dfd901","tid":1564720,"uid":36788,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T01:35:06.000Z","msg":"<img src=\"/assets/faces/mf/good.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/kiss.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/tongue.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/oh.png\" class=\"hkgmoji\" />"},{"pid":"e73d4685aef218c648a14627d868c6c2a92a68e9","tid":1564720,"uid":36788,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T01:35:26.000Z","msg":"<img src=\"/assets/faces/mf/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/flowerface.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/slick.gif\" class=\"hkgmoji\" />"},{"pid":"aca783abd5f062562a4f2d64245e09d40c38d0c8","tid":1564720,"uid":36788,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-13T01:41:27.000Z","msg":"國歌洗youtube<img src=\"/assets/faces/mf/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"9dd1de02ec8524151412045db3a9245a616adaed","tid":1564720,"uid":199739,"like":2,"dislike":0,"score":2,"quote":{"pid":"be57f86c8a430289a9fe7f283cc338ee6d5d520b","tid":1564720,"uid":60716,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-09-13T01:24:26.000Z","msg":"管弦樂MV 呢個係原創者？"},"citedBy":1,"replyTime":"2019-09-13T01:43:50.000Z","msg":"係呢條 好多偷片<br />\n<a href=\"https://youtu.be/oUIDL4SB60g\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FoUIDL4SB60g&d=m%2FBV6vIUiVByATU953YnmI6aL69TDc1SPHZju%2B%2BXLiQ%3D&h=94a91ed1\" data-auto-link target=\"_blank\">https://youtu.be/oUIDL4SB60g</a>"},{"pid":"b5e1255aa31e810380fd5f23ee80c61af8a6c68c","tid":1564720,"uid":138594,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T01:44:43.000Z","msg":"推<img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" /><br />\n各位中秋節快樂"},{"pid":"bcddd79e4b2513dac57fd937e65fc51918e5101f","tid":1564720,"uid":36788,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-13T01:53:10.000Z","msg":"大家要係youtube多留言<br />\n藍絲留得多過你地，香港人要自己幫"},{"pid":"4a54f76e5ab3da1a260ac3e30400381dabad7442","tid":1564720,"uid":269498,"like":0,"dislike":0,"score":0,"quote":{"pid":"9dd1de02ec8524151412045db3a9245a616adaed","tid":1564720,"uid":199739,"like":2,"dislike":0,"score":2,"quote":{"pid":"be57f86c8a430289a9fe7f283cc338ee6d5d520b","tid":1564720,"uid":60716,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-09-13T01:24:26.000Z","msg":"管弦樂MV 呢個係原創者？"},"citedBy":1,"replyTime":"2019-09-13T01:43:50.000Z","msg":"係呢條 好多偷片<br />\n<a href=\"https://youtu.be/oUIDL4SB60g\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FoUIDL4SB60g&d=m%2FBV6vIUiVByATU953YnmI6aL69TDc1SPHZju%2B%2BXLiQ%3D&h=94a91ed1\" data-auto-link target=\"_blank\">https://youtu.be/oUIDL4SB60g</a>"},"citedBy":0,"replyTime":"2019-09-13T01:57:48.000Z","msg":"由佢<br />\n<br />\n當宣傳<br />\n<br />\n話時話 sosad公仔比藍屍偷左去整燈籠賣<br />\n仲話甲由收錢燒政府 以燈籠做記認<br />\n大家今晚見到有廢中癲雞/痴線佬記得即刻同佢割席<br />\n<br />\n依家藍屍每日開3個假page屈市民 大家見到記得report<br />\n以下為3單較多人講既假新聞<br />\n-加拿大派了5000億指示香港市民上街<br />\n-2百萬人遊行後能夠與歌手明星上床<br />\n-9成中小學生是美國安排在港的間諜"},{"pid":"f931984fd6eaea47c1e8f032201c4e00f65c2450","tid":1564720,"uid":36788,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T02:05:22.000Z","msg":"我地一定要比班藍絲努力<br />\n香港係我地的"},{"pid":"471457b0738cce4a6e8776cd7d550aff205c1fba","tid":1564720,"uid":61280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T02:07:29.000Z","msg":"<blockquote><a href=\"https://www.facebook.com/857598264603806/photos/a.857685191261780/912801689083463/?type=3&amp;theater\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F857598264603806%2Fphotos%2Fa.857685191261780%2F912801689083463%2F%3Ftype%3D3%26theater&d=m%2FBV6vIUiVByATU953YnmI6aL69TDc1SPHZju%2B%2BXLiQ%3D&h=31ff5164\" data-auto-link target=\"_blank\">https://www.facebook.com/857598264603806/photos/a.857685191261780/912801689083463/?type=3&amp;theater</a><br />\n<br />\n【為甚麼害怕獨立調查 － 論警隊制度的崩壞】<br />\n<br />\n路透社有一專題報導，題目是 &ldquo;From &lsquo;Asia&rsquo;s finest&rsquo; to &lsquo;black dog&rsquo;, Hong Kong police under pressure&rdquo;，此題目也是我一個最近不斷思考的問題，究竟為什麼香港警隊可以墮落至此，從「亞洲最佳」淪落到「警犬」的層次？昨天跟一個退休警官的一席話，讓我恍然大悟。<br />\n<br />\n這位退休警官在警隊工作超過30年，目睹警隊回歸前到回歸後的變化。<span style=\"color: red;\">對於警隊濫用暴力，他認為「冰封三尺，非一日之寒」，其實在十至十五年前，警隊制度已經開始崩壞</span>。<br />\n<br />\n首先，是<span style=\"color: red;\">領導層的劣化</span>。雖然警隊的表面制度是沒有太大改變，但從回歸後換高層開始，腐敗的風氣已經形成。他們曲解良好的機制，建立了一種包庇下屬的文化。警隊有一機制是 supervisory accountability，即是說<strong><span style=\"color: red;\">如果下屬犯錯，上司也要負責。但中高層為了不想因下屬犯錯而受罰，於是積極為下屬掩飾錯誤。久而久之，前線警員得到的信息是：就算我犯錯，上司也會幫我補救。這種反其道而行的態度，讓警員覺得他們可以肆無忌憚地做事</span></strong>。朱經緯就是一個好例子，上法庭的時候，警隊的反應不是承認有管理上的責任，而是用盡方法幫他打嬴官司。為什麼這樣做？因為朱經緯不能犯錯，如果他犯錯，他的上司也要負責。<span style=\"color: red;\">這種有例不依的腐敗風氣，從上至下傳開，讓警員無視法律規矩，包庇自己人</span>，發展成山頭主義。警察跟元朗白衣人有講有笑，正正反映了警隊這種荒謬的文化。<br />\n<br />\n其次，是由小至大的失職。該退休警官告訴我，不少前線警員在應該巡邏的時候，其實都是去了酒樓開了間私人房吃點心。更令人驚訝的是，不單止是前線警員這樣做，他們的上司也會跟他們一起飲茶。<span style=\"color: red;\"><strong>這些小小的失職沒有被追究，反而被鼓勵，讓警員覺得可以有情況不依規矩辦事。之後當然是骨牌效應，小小的失職沒事，他們就嘗試大一點的失職，沒事嗎？再試大一點的。久而久之，他們就完全無視現行制度，從偷懶到濫權到貪污，無一不做了</strong></span>。況且，像剛才所說，<span style=\"color: red;\">就算他們被揭發，也會有上司幫他們補救</span>，所以他們真的能做到 acting without consequences！近來警隊人員逃稅的比率比一般市民還要高，實在是不意外。<br />\n<br />\n然後，在回歸之後，管理層換班子，態度從「努力辦事」，變得「避免犯錯」。近兩年，店舖盜竊的案件少了很多，不是因為竊匪少了，而是很多以前會被視為「店舖盜竊」的案件，現在被算進「遺失物件」中，所以「店舖盜竊」當然少了。為什麼要這樣做呢？因為政府想見到罪案率減低，但<span style=\"color: red;\"><strong>警隊管理層不想多做多錯，不想嘗試以新辦法防止罪案發生，所以出此下策，刪改數據，以求在避免犯錯的情況下迎合高層</strong></span>。後果呢？是整個警隊變得得過且過，全無專業可言。（不過聽此退休警官說，也有少數的部門還會做實事減低罪案率，如禁毒處。）<br />\n<br />\n最後，也是最直接的一點，是防暴警察的運作模式。雖然學堂有教怎樣適當行駛武力，但實際操作的時候，<span style=\"color: red;\"><strong>高層卻鼓勵使用更大武力，打的最兇的那一個通常升級最快，而且，最暴力的成員會被邀請成學堂導師，教導新成員怎樣行駛「適當武力</strong></span>」。明顯地，合理的規矩機制都在，但是實際操作呢？遵守規矩的人得不到嘉許，無視規矩的人卻能獲得獎勵。<br />\n<br />\n從以上幾個觀察，看到了警隊一個重點問題：機制良好，風氣腐敗。而這亦是為什麼警隊從「亞洲最佳」淪落到成「警犬」的原因。<br />\n<br />\n警隊雖然有從回歸前多年辛苦建立的專業機制，但無論是領導層或是前線警員都視之如無物，腐敗不堪。警隊代表在記者會上再三強調他們有專業的機制，並沒有錯，但他們沒有告訴你的是，實際上，警員從上到下，整個系統都在無視此機制，任意妄為，而可以不受譴責。最要命的，是上司高層帶頭破壞規矩，讓整個團隊從上而下崩壞。最後，納稅人付錢，養了一班「有牌爛仔」。<br />\n<br />\n政府警隊想你相信，就算有「黑警」，也只是佔隊伍中的少數。但現實呢？當你看到警察集體不佩戴委任證而警隊沒有人指責；當你看到防暴警察亂棍毆打已經制服在地上的市民，他們的領隊不但沒有阻止，還加入毆打；其實不難看出，<span style=\"color: red;\">有問題的不是幾個警察，而是整個警隊，和他們系統性的腐敗</span>。<br />\n<br />\n<span style=\"color: red;\"><strong>所以，警隊害怕獨立調查委員會，因為委員會將會揭露的，不是某些前線警員犯錯，而是這些現象背後的，整個警隊系統的腐敗</strong></span>。<br />\n<br />\n後話：1993年，19歲的青年 Stephen Lawrence 在倫敦被殺害，警察雖然捉到了五個疑犯，但最後都沒有落案控告他們。公眾開始質疑警察無所作為是因為死者是黑人，倫敦警察廳當然矢口否認，還極力反對政府為警方對此案的處理展開獨立調查，事件拉鋸了五年，終於在公眾與國會施壓下，政府成立獨立調查委員會。委員會發現，整個倫敦警察廳的系統運作是根本地歧視黑人，對於黑人作為被害者的調查，是得過且過，及處理從寬。<br />\n<br />\n相信，現在的香港警隊跟當時的倫敦警察廳一樣，也是害怕獨立調查委員會將會揭發警察暴力底下的骯髒事實吧。</blockquote><br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\">其實冇外力，又點會腐爛得咁快？？<br />\n<br />\n<br />\n<br />\n所以我不嬲屌大愛支戲子党涂議員，你坐係保安事務Panel阿一阿二十鳩幾年，除左出糧拉票拉關係，監察過乜？？</span></span></span></strong><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">旺區兼狗竇前面搶犯？？？就算俾你搶到，去得邊呀仆街？？？！！！</span></strong></span></span><img src=\"/assets/faces/big/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/donno.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>為左殤台個牌為左碗飯，童星老監馮生都要做奶共狗鳥！！！<br />\n<br />\n為紀念燒死林彬而起嘅18樓C座，狗馮既係老監亦負責主要角色，啱啱居然勁做維撚狗，幫狗政Spin話831死人只係街邊八婆鳩吹出黎，又吹香港咁大城市死幾個人點會遮得到！！！<br />\n<br />\n<br />\n嘩嘩嘩！！我愈聽愈以為轉左俾Mei西監製添！！！<img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /></strong></span></span></span><br />\n<br />\n<br />\n<blockquote><span style=\"font-size: x-large;\"><span style=\"color: gold;\"><strong><ins>疑點1: </ins></strong></span></span><br />\n<br />\n光明正大點解要cap圖唔直接放片？<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: gold;\"><ins><strong>疑點2: </strong></ins></span></span><br />\n<br />\n點解Cap既所有圖都唔見畜聾打人，直播又會見到？<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: gold;\"><ins><strong>疑點3: </strong></ins></span></span><br />\n<br />\n咁撚簡單既事點解要封站兩日？<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: gold;\"><ins><strong>疑點4: </strong></ins></span></span><br />\n<br />\n連721都唔會4個部門一齊見記者，點解831會？<br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: orange;\">我依家信太子有無辜市民被殺害了</span></strong></span><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/yipes.gif\" class=\"hkgmoji\" /></blockquote><br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\">一句到尾啦，係支共命令&quot;止暴制亂&quot;之下，明知一日拖一日尤其頭七都唔交出足本只會愈拖愈亂，咁都唔交你地話點解呢？？？？</span></span></span></strong><br />\n<br />\n<blockquote><blockquote><strong><span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\">加埋依家毛EE爆料，831事件冇人死？？？<br />\n<br />\n<strong></strong><br />\n<br />\n<br />\nFYI，當晚現場傳第一消息：有人打死人，但唔係香港警察，你話係邊個呢<img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" />？？？！！！</span></span></span></strong></blockquote></blockquote>"},{"pid":"c6d7d8355d122d79b34df64ce83650b3391a2323","tid":1564720,"uid":251083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T02:16:27.000Z","msg":"推"},{"pid":"d7e272c795088aac68feeaf9ea06e7916877d709","tid":1564720,"uid":208452,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T03:05:16.000Z","msg":"有野想捐可以FB/TG搵我地香港自由之書阿<br />\n<br />\n<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n[澄清]國難五金課金問題&mdash;照舊課！<br />\n<a href=\"https://lihkg.com/thread/1521564/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1521564/page/1</a><br />\n<br />\n國難五金專訪 [開鋪事直請留意國難五金FB]<br />\n<a href=\"https://lihkg.com/thread/1521301/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1521301/page/1</a><br />\n<br />\n【眾籌】 已集合超過1000名巴絲感想 香港編年史<br />\n<a href=\"https://lihkg.com/thread/1379634/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1379634/page/1</a><br />\n<br />\nFB: 國難五金, 香港自由之書"},{"pid":"7a58cb97f3a84ccfe92e09da5bb1e30593b35d26","tid":1564720,"uid":36788,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T08:38:01.000Z","msg":"<img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" />"},{"pid":"27ec3fa214b68ec940b9f1dda44ba4264e9019d6","tid":1564720,"uid":49812,"like":0,"dislike":0,"score":0,"quote":{"pid":"aca783abd5f062562a4f2d64245e09d40c38d0c8","tid":1564720,"uid":36788,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-13T01:41:27.000Z","msg":"國歌洗youtube<img src=\"/assets/faces/mf/chicken.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-13T08:39:22.000Z","msg":"<a href=\"https://petitions.whitehouse.gov/petition/demand-chinese-government-remove-great-firewall-restriction-0\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fdemand-chinese-government-remove-great-firewall-restriction-0&d=m%2FBV6vIUiVByATU953YnmI6aL69TDc1SPHZju%2B%2BXLiQ%3D&h=bc552aea\" target=\"_blank\">https://petitions.whitehouse.gov/petition/demand-chinese-government-remove-great-firewall-restriction-0</a>"},{"pid":"db4928ed1e26c2b4fc7df54db426b9475d5bfbb4","tid":1564720,"uid":36788,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T09:10:19.000Z","msg":"每星期都要搞好文宣youtube，大家最好係黃多留言like襯下"},{"pid":"fc4cd99b277d1632760ffbad46497b09868d6990","tid":1564720,"uid":41998,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-13T10:25:14.000Z","msg":"點撚解偷片嗰個上咗熱門，原創過百萬上唔到<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"}]}