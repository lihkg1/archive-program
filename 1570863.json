{"tid":1570863,"cid":5,"subCid":0,"title":"港鐵冇零件喇 - 港鐵部分設施零件短缺　延長復修時間","createTime":"2019-09-15T09:08:46.000Z","updateTime":"2019-09-15T09:28:29.000Z","uid":49784,"like":22,"dislike":0,"uniUserReply":21,"replies":[{"pid":"2ef4b358809da9532590b8d270bc6317ed828ef0","tid":1570863,"uid":49784,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T09:08:46.000Z","msg":"<a href=\"http://news.now.com/home/local/player?newsId=362808&amp;refer=Share\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D362808%26refer%3DShare&d=xWOcOck8MQRdM6xM79L4mJriIWEbfV0cuvPRs67P9cA%3D&h=5813727f\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D362808%26refer%3DShare&h=dea11491\" target=\"_blank\">http://news.now.com/home/local/player?newsId=362808&amp;refer=Share</a><br />\n<br />\n【Now新聞台】鐵路工會聯合會主席林偉強出席電台節目時指，港鐵增聘尼泊爾籍人士監察有否乘客「逃票」，他不擔心會有衝突。<br />\n<br />\n另外，多個港鐵站遭破壞仍未全部復修，林偉強解釋除人手不足問題，零件亦短缺，如入閘機有部份零件倉庫存量不足，需由其他車站調配，強調職員已盡力搶修。"},{"pid":"0138dd1075d06425058e8602b26ca1f96e79fa6f","tid":1570863,"uid":49784,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T09:08:55.000Z","msg":"<img src=\"/assets/faces/lomoji/24.png\" class=\"hkgmoji\" />"},{"pid":"a536edb48938ac73fa99e56f137d2ccf75b04e1c","tid":1570863,"uid":214502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-15T09:09:17.000Z","msg":"<img src=\"/assets/faces/mf/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"22a577539fc39dd6bbf6d876c07f8d945f20f027","tid":1570863,"uid":36845,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-09-15T09:09:52.000Z","msg":"陰公豬囉<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" />"},{"pid":"687b33f1bacf63154af1206d675e088e5c7437bc","tid":1570863,"uid":49784,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-15T09: