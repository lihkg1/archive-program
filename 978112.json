=https%3A%2F%2Fi2.kknews.cc%2FSIG%3D2upeta6%2Fctp-vzntr%2F1529036199751nrr6no2165.jpg&h=869752f0&s={SIZE}\" /><br />\n<br />\n<img src=\"http://github.tiankonguse.com/images/2018/06/20180618224922.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fgithub.tiankonguse.com%2Fimages%2F2018%2F06%2F20180618224922.png&h=9539eb58&s={SIZE}\" />"},{"pid":"1e9d22000b6f2c689b40d1d1cb4e8877a10ae8e5","tid":978112,"uid":145277,"like":1,"dislike":0,"score":1,"quote":{"pid":"ee42c5dea72df75cbfe3addf3637c24a81fc67ad","tid":978112,"uid":146427,"like":20,"dislike":2,"score":18,"citedBy":3,"replyTime":"2019-01-11T15:59:03.000Z","msg":"中國經濟好，香港得權貴享受最大利益<br />\n中國仆街，香港所有人一齊仆街<br />\n咁我揀一齊仆街，呢個時勢攬炒MODE 先可以對付極權社會"},"citedBy":0,"replyTime":"2019-01-12T03:18:02.000Z","msg":"其實一個entity PK先會促進大洗牌，財富重新分配，因為PK唔係永遠，資金/資源都係喺度，只係去左邊個度"}]}