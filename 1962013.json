assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"83469215781497c29ea449a3fc627220afe1c20e","tid":1962013,"uid":107297,"like":1,"dislike":1,"score":0,"quote":{"pid":"9056aa7b44d12f7fc64fdbb5ec9449bf860e2e42","tid":1962013,"uid":1069,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-04-07T07:55:04.000Z","msg":"好多年後，研究返香港歷史，參考文獻就係呢本書<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-07T08:05:14.000Z","msg":"我地應該出返本"},{"pid":"032d17312cc192944c4679b3163eaa368a05aae4","tid":1962013,"uid":306664,"like":0,"dislike":1,"score":-1,"quote":{"pid":"44ca5b6fe25fb54b02ca8bfbdcaa89601c9bb20c","tid":1962013,"uid":226548,"like":0,"dislike":1,"score":-1,"quote":{"pid":"d046d32b801cedd6d4cf67ced679627201140e39","tid":1962013,"uid":306664,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-07T07:42:14.000Z","msg":"立場係咩<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-04-07T07:43:13.000Z","msg":"分享對 粵方言 傳承的觀點"},"citedBy":0,"replyTime":"2020-04-07T08:26:06.000Z","msg":"sorry 我指藍屍定黃屍"},{"pid":"f22af1e46e59c8cfe21e75e3964e4e2cc562f505","tid":1962013,"uid":274870,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-04-07T08:41:28.000Z","msg":"未睇晒本書,<br />\n但係就咁睇介紹都覺得佢哋玻璃心得好嚴重,<br />\n剩係識將情感投放喺啲物件上面,<br />\n可能因為死物唔會背叛自己掛<img src=\"/assets/faces/lm2/think.gif\" class=\"hkgmoji\" />"},{"pid":"aa18b859de1f3086d395471b88dcfc82c404a079","tid":1962013,"uid":20867,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-04-07T10:23:11.000Z","msg":"幾好奇在港中國人點睇我地香港人既抗爭運動<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"306bee331430d442c9ca544e28aac228ecbd438c","tid":1962013,"uid":150483,"like":0,"dislike":1,"score":-1,"quote":{"pid":"aa18b859de1f3086d395471b88dcfc82c404a079","tid":1962013,"uid":20867,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-04-07T10:23:11.000Z","msg":"幾好奇在港中國人點睇我地香港人既抗爭運動<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-07T10:28:56.000Z","msg":"平行時空<br />\n<br />\n連登仔日日講支爆，事實點爆都好，支共每日都發動大外宣，滲透分化"},{"pid":"cd84cab8287ccf195fddbb8cca1b3f82c15b4f20","tid":1962013,"uid":20689,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-07T10:29:59.000Z","msg":"港漂？<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">漂你老母！</span></span>"},{"pid":"fc7d6e20a16d06e53ef9d86918941bf2691cfd2c","tid":1962013,"uid":64953,"like":0,"dislike":0,"score":0,"quote":{"pid":"8bb76da70fe69d3e7d3acd4ced3bfef9edab9026","tid":1962013,"uid":48083,"like":3,"dislike":2,"score":1,"citedBy":4,"replyTime":"2020-04-07T07:37:05.000Z","msg":"香港抗爭者仲未有人出本書做紀錄真係失策<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n俾共諜體系佔哂先機<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />（哩本同周顯嗰幾本）<br />\n<br />\n反而台灣有出一本"},"citedBy":1,"replyTime":"2020-04-07T10:31:01.000Z","msg":"台灣你講邊本<br />\n自由6月定烈火黑朝"}]}