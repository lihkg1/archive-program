pid":"70175ea2302d035fb04ab955cc48d65d15a1a51c","tid":632064,"uid":53687,"like":4,"dislike":0,"score":4,"quote":{"pid":"934623dcd13658c2f5f3d1f382794173a00eb78b","tid":632064,"uid":166785,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-17T05:24:41.000Z","msg":"唔計樓，唔計未來自由收緊，仲有咩討論<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-17T05:28:55.000Z","msg":"唔計人權、文明、污染&hellip;&hellip;，中國都係唔錯嘅地方<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a0fc18dd11110691cc7e887d4ed79e021b25a12f","tid":632064,"uid":59641,"like":2,"dislike":0,"score":2,"quote":{"pid":"c00b6af8567d857de638c387e2e1623dc78b0818","tid":632064,"uid":53687,"like":37,"dislike":2,"score":35,"citedBy":4,"replyTime":"2018-04-17T05:19:07.000Z","msg":"點解要撇除樓價？衣食住行係必需品<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-17T05:29:16.000Z","msg":"因為鬼佬喺度只係過客，租屋就得冇必要長住，而且過得嚟大部份都高薪啲，咪唔駛諗樓價<br />\n<br />\n從來香港唔駛諗住係正㗎，不過一個住已經令人趕住走咋嘛"},{"pid":"4d3beca76d3b5a4fcac371bdad13ae69ec782324","tid":632064,"uid":166785,"like":8,"dislike":0,"score":8,"quote":{"pid":"70175ea2302d035fb04ab955cc48d65d15a1a51c","tid":632064,"uid":53687,"like":4,"dislike":0,"score":4,"quote":{"pid":"934623dcd13658c2f5f3d1f382794173a00eb78b","tid":632064,"uid":166785,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-17T05:24:41.000Z","msg":"唔計樓，唔計未來自由收緊，仲有咩討論<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-17T05:28:55.000Z","msg":"唔計人權、文明、污染&hellip;&hellip;，中國都係唔錯嘅地方<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-17T05:30:50.000Z","msg":"除左唔好的地方，中國都好好<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b5197843eeb663bb36cdec910799df449120e752","tid":632064,"uid":57705,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2018-04-17T05:31:26.000Z","msg":"此回覆已被刪除"},{"pid":"5ebc043c9ed11edc8ca60ce9b931a385bf5278e4","tid":632064,"uid":44559,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-04-17T05:31:33.000Z","msg":"外國人係得香港做野，本身收入一定高<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e7922cd5f9789763f00fa16f70ba9f4190ef6aa3","tid":632064,"uid":87428,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-17T05:32:01.000Z","msg":"Sj 係邊個 steve kobs"},{"pid":"ce85d39461eb75c4a1f5bb5ee7aadb03fc481723","tid":632064,"uid":45847,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2018-04-17T05:33:04.000Z","msg":"一小時生活圈？新界嗰啲全部唔係生活？唔係人？<br />\n我屌柒你老母啊"},{"pid":"59b8727b0532060e03041490fbe3e7502de71f3e","tid":632064,"uid":155883,"like":0,"dislike":0,"score":0,"quote":{"pid":"793fd1b1a4e675644a2c09f81cbd2a1582301d79","tid":632064,"uid":103127,"like":3,"dislike":0,"score":3,"citedBy":3,"replyTime":"2018-04-17T05:25:18.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-04-17T05:33:49.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"9679a37b01703818d6a640b90450e117cd82f9ac","tid":632064,"uid":20241,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-04-17T05:37:41.000Z","msg":"班鬼佬都唔會係度長住<br />\n搵夠就番去住花園大屋架啦<br />\n又有港女俾佢地任屌<br />\n梗係平衡架<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"47c1b276331b1f0ee701e54e5e88cf9f50fefbea","tid":632064,"uid":94167,"like":0,"dislike":0,"score":0,"quote":{"pid":"ce85d39461eb75c4a1f5bb5ee7aadb03fc481723","tid":632064,"uid":45847,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2018-04-17T05:33:04.000Z","msg":"一小時生活圈？新界嗰啲全部唔係生活？唔係人？<br />\n我屌柒你老母啊"},"citedBy":0,"replyTime":"2018-04-17T05:38:35.000Z","msg":"撞次車2-3個鐘起跳<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f5d73da0ee59526fbad2c854f47a85c7f5787f3d","tid":632064,"uid":13724,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2018-04-17T05:38:57.000Z","msg":"寫條友白痴？expat 不嬲人工高啲，啲鬼本身人工數字計都高過香港，嚟到會再高一截。我開頭以為篇文係叫香港人去做expat"},{"pid":"15c0d5cffd028bf1a7797b20d02f7a636bc44663","tid":632064,"uid":35648,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-04-17T05:40:46.000Z","msg":"鬼佬有幾多要養老豆老母<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"981544dfb185638037145aea1d77433550485388","tid":632064,"uid":58852,"like":1,"dislike":4,"score":-3,"citedBy":0,"replyTime":"2018-04-17T05:40:52.000Z","msg":"講到底有能力嘅人去邊都過得好，好似班expat<br />\n冇能力去邊都只會抱怨，唔止香港，歐美日本都大把呢種乞兒<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"c9a432cfc50f6d4dbe230b2f8107ec0bbab7813d","tid":632064,"uid":76063,"like":11,"dislike":1,"score":10,"citedBy":0,"replyTime":"2018-04-17T05:41:19.000Z","msg":"個社會愈黎愈差 然之後你打埋D飛機文去讚剩番既好野<br />\n咁撚不思進取既 有冇諗過剩番既好野 可能好快都消失埋"},{"pid":"c05a1013d46bdaf67ea60108804cd3ff8377750a","tid":632064,"uid":60635,"like":0,"dislike":0,"score":0,"quote":{"pid":"15c0d5cffd028bf1a7797b20d02f7a636bc44663","tid":632064,"uid":35648,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-04-17T05:40:46.000Z","msg":"鬼佬有幾多要養老豆老母<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-17T05:46:18.000Z","msg":"你問下嚟香港ｗｈ班外國人，有邊個唔屌鬼。expat公司包食住當然爽歪歪<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"9f28fd1ea05fedd6f0ff6cd8ce566cbec2d72ed7","tid":632064,"uid":38071,"like":1,"dislike":0,"score":1,"quote":{"pid":"59b8727b0532060e03041490fbe3e7502de71f3e","tid":632064,"uid":155883,"like":0,"dislike":0,"score":0,"quote":{"pid":"793fd1b1a4e675644a2c09f81cbd2a1582301d79","tid":632064,"uid":10