 />\n<a href=\"https://news.mingpao.com/ins/instantnews/web_tc/article/20180614/s00005/1528959442905\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.mingpao.com%2Fins%2Finstantnews%2Fweb_tc%2Farticle%2F20180614%2Fs00005%2F1528959442905&d=4QFUcMGHpN3Zj9TGzmZjhr%2BnoHux5cIPnxEj5ZZbdh4%3D&h=00c39963\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.mingpao.com%2Fins%2Finstantnews%2Fweb_tc%2Farticle%2F20180614%2Fs00005%2F1528959442905&h=b3e4f288\" target=\"_blank\">https://news.mingpao.com/ins/instantnews/web_tc/article/20180614/s00005/1528959442905</a><br />\n<br />\n其他圖係條link入邊<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-06-14T23:50:14.000Z","msg":"食自己點唔道德法"},"citedBy":2,"replyTime":"2018-06-15T00:01:30.000Z","msg":"食自己犯法㗎喎"},"citedBy":0,"replyTime":"2018-06-15T01:37:54.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 有聲 逃學威龍"},{"pid":"7d3c799054e4bda2b97aa5d81df3b959a5a21c97","tid":702360,"uid":67500,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-15T01:49:17.000Z","msg":"支那人食人肉食得多啦，大躍進，民革"},{"pid":"0866dbb3c3cd3c6cf040fa43493f9d068787a8e8","tid":702360,"uid":67500,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-15T01:49:32.000Z","msg":"<blockquote>支那人食人肉食得多啦，大躍進，文革</blockquote>"},{"pid":"2828e51cd9bb62ba0533697431933ae4c791b5cb","tid":702360,"uid":15084,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-15T03:42:46.000Z","msg":"wow"},{"pid":"9511bf2378b68e1e22f4e7ef6e35a0f2ecdbba01","tid":702360,"uid":113626,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-15T03:43:38.000Z","msg":"間醫院比佢拎返屋企先有問題<br />\n一舊充滿細菌既野"},{"pid":"20208467d96595bc8fe725af8a4de28f1e627df5","tid":702360,"uid":51753,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-15T04:14:50.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}