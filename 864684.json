ces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"0269baf64ca6a3cc370856fdf8833deed8011d54","tid":864684,"uid":14055,"like":0,"dislike":0,"score":0,"quote":{"pid":"077ad4cae9fe9200b0107d25ff400fe75ef0211e","tid":864684,"uid":116330,"like":118,"dislike":0,"score":118,"citedBy":1,"replyTime":"2018-10-16T11:38:00.000Z","msg":"原來係你<br />\n你頂到我都扯扯地"},"citedBy":0,"replyTime":"2018-10-16T12:37:11.000Z","msg":"你應該認錯咗我隔離車卡嗰個暗瘡油頭毒男，唔阻你同佢上演纏綿遊戲啦<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"aaa67263d4ca7137c305557276151140afbf98b1","tid":864684,"uid":14055,"like":1,"dislike":6,"score":-5,"quote":{"pid":"7129d833076dda9df9d292e8726f892421d20268","tid":864684,"uid":59920,"like":128,"dislike":6,"score":122,"citedBy":1,"replyTime":"2018-10-16T11:40:07.000Z","msg":"圖呢？<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n我真係忍唔撚住喇屌你老母，先用3隻手指室入你老母閪度撩呀撩，啲閪水就爸把聲咁流出黎，唔知係你老母閪太污糟，流出黎啲白帶仲濁撚過忌廉湯，不過為左屌你老母都無辦法，用我30cm長既巨龍一野隊入去，由於係用狗仔式既關係，條巨龍一下就頂到入子宮，即係當初佢陀住你果度，我一路推你老母就好似隻奇行種咁爬下爬下，由大埔推撚到去港島，由於驚塞車所以我決定行西隧，推撚到去瑪麗醫院樓下就岩岩好中出!!!射撚晒入去，我仲好有心扶埋你老母入醫院睇婦科!!!10個月後就可以生個細妹比你撚，記得湊好你細妹，大個女之後再比我屌!!!"},"citedBy":0,"replyTime":"2018-10-16T12:38:03.000Z","msg":"先生請你冷靜啲<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"518dada30c6d9e97cbdfc1ef75a3ceabbd93c5fd","tid":864684,"uid":14055,"like":0,"dislike":3,"score":-3,"quote":{"pid":"912c03836c3233a7426a6c8ceccf94bf7182f57f","tid":864684,"uid":172297,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-10-16T11:41:45.000Z","msg":"0/10"},"citedBy":1,"replyTime":"2018-10-16T12:38:45.000Z","msg":"真人真事，今早發生"},{"pid":"2f4870b269098b7083dc8a6181932795245ddca8","tid":864684,"uid":14055,"like":0,"dislike":1,"score":-1,"quote":{"pid":"88e3077754e6dd46584dd46712e8f37f902c9e08","tid":864684,"uid":25952,"like":51,"dislike":1,"score":50,"citedBy":1,"replyTime":"2018-10