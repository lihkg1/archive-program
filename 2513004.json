2513004,"uid":74339,"like":3,"dislike":2,"score":1,"quote":{"pid":"0e5b923b26977144e789c8377eae370f445741c2","tid":2513004,"uid":10670,"like":2,"dislike":3,"score":-1,"citedBy":1,"replyTime":"2021-05-02T07:39:22.000Z","msg":"立場姐姐係pr<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-05-02T07:39:57.000Z","msg":"冷嘲熱諷嘅請你離開"},"citedBy":2,"replyTime":"2021-05-02T07:42:53.000Z","msg":"呢度你睇場？"},"citedBy":0,"replyTime":"2021-05-02T08:14:10.000Z","msg":"走啦你<br />\n呢度唔需要你"},{"pid":"424eb66c5d98b496372b1339e761a7e36f500d2d","tid":2513004,"uid":74339,"like":1,"dislike":0,"score":1,"quote":{"pid":"a490e4a7a2fd9068883d25ccf5cd83d4f7a3961f","tid":2513004,"uid":34295,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-05-02T08:08:43.000Z","msg":"立場姐姐 思考能力 風骨 <br />\n都高過泛民班友好多<br />\n<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-05-02T08:21:10.000Z","msg":"第一句同意 第二句多咗"}]}