assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-23T08:55:33.000Z","msg":"<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />"},{"pid":"b2f710fd4c59e213103eb7a4ed679ae8e6b9fc8c","tid":1893344,"uid":66528,"like":0,"dislike":0,"score":0,"quote":{"pid":"1a2d4a7093ef2004ee0b173f51ed5ff131a572d6","tid":1893344,"uid":54291,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-23T08:44:36.000Z","msg":"維穩手段之一<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-23T08:58:12.000Z","msg":"林鄭/港共最中意耍嘅語言偽術"},{"pid":"63d68c91abc8dec43b99983cb6b169904ab75b94","tid":1893344,"uid":14298,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-23T08:59:15.000Z","msg":"22-02-2020：<br />\n本港今日新增1宗確診個案及3宗初步確診，其中東區醫院的96歲女病人晚上確診，患者居於北角，無外遊紀錄，病發前曾到過北角美倫大廈福慧精舍。而今日東區醫院亦有兩宗初步確診個案，分別是居於柴灣的80歲女病人，同樣未有外遊紀錄，曾到訪福慧精舍；另一位76歲女病人，居於北角美倫大廈，最近亦曾到過福慧精舍。另外，早前從日本返港的一名68歲鑽石公主號乘客，今日亦初步確診，經測試他的痰及喉嚨分泌物樣本都呈陽性反應，已由駿洋邨隔離營送往伊利沙伯醫院。<br />\n<a href=\"https://hk.appledaily.com/local/20200222/KBIAFV6GKW7U2PC2T6QLFGH4NI\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200222%2FKBIAFV6GKW7U2PC2T6QLFGH4NI&d=c0FEOXRBadflfKsXjMdAyjUBvjVF43IiJLn9vI4Fxnk%3D&h=79cbaa50\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200222%2FKBIAFV6GKW7U2PC2T6QLFGH4NI&h=e34cccbf\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20200222/KBIAFV6GKW7U2PC2T6QLFGH4NI</a><br />\n<br />\n今日：<br />\n本港今日（23日）新增2宗初步確診個案，分別為聯合醫院62歲無外遊紀錄的男子，以及屯門醫院35歲男子，其中後者在2月8日政府實施「強制檢疫」前去過深圳，近日在屯門醫院急症室被檢驗深喉唾液樣本，經測試後呈初步陽性，令本港累計確診個案或增至75宗。<br />\n<a href=\"https://hk.appledaily.com/local/20200223/EOAY2KNCGQN6JTDXIJ45FZ2NY4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200223%2FEOAY2KNCGQN6JTDXIJ45FZ2NY4&d=c0FEOXRBadflfKsXjMdAyjUBvjVF43IiJLn9vI4Fxnk%3D&h=dd2f2170\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2