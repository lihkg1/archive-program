58:54.000Z","msg":"直接講"},{"pid":"5bf72965af970f478d5bc40092f04bd5e6c14e10","tid":2268683,"uid":345520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-03T04:59:09.000Z","msg":"認真答你，真係要割，上網自己搵大把資料"},{"pid":"20c14d713f0e661e1cd5f60492156d129f6469c1","tid":2268683,"uid":311499,"like":1,"dislike":0,"score":1,"quote":{"pid":"c2b76970a7d719a1a1f69538f0fcb0576052dde1","tid":2268683,"uid":346704,"like":0,"dislike":0,"score":0,"citedBy":6,"replyTime":"2020-11-03T03:43:53.000Z","msg":"佢扯左都係包住左個頭<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />已經建議左佢去割<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />但又唔知佢會唔會真係去<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />上網睇過長會收左啲污糟野係入面<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />卜野可能會搞到有陰道炎個啲<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />所以有啲驚<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />點同佢講好<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-03T05:00:55.000Z","msg":"既然佢係有需要，建議割包皮，割包皮除咗個人衛生外，亦可有效預防HIV感染，未/沒有割包皮uncut penis /uncircumcised 男性，由於包皮可拉下露出龜頭而不割，但他們在勃起時，龜冠位置會有大範圍面積皮膚好薄(連血管也顯露)，呢個位置較有機會被HIV入侵<br />\n<br />\n相反，割咗包皮男性cut penis / circumcised ，呢個位置會被較厚皮膚覆蓋，有較強保護"},{"pid":"2488d8ce16fe29cac3bbd1eff6143030b024e988","tid":2268683,"uid":112747,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-03T05:01:09.000Z","msg":"見過有人包皮長到fingfing吓<br />\n真係想知反唔反到<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"001cfcb710d62d1c3ed491ac2f246495cc9428ab","tid":2268683,"uid":20454,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-11-03T05:02:21.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"b11129750348829d9c192cbd8ee1dcca3bea4525","tid":2268683,"uid":345520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-03T05:02:49.000Z","msg":"印象中好多人都係用激光去割"},{"pid":"ab1da85a19e0c65a1eabcdde33c4fe60