ike":0,"dislike":1,"score":-1,"quote":{"pid":"79efc9b84ed9833fe9d515f8528e9001acc85552","tid":998241,"uid":195364,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-27T23:44:08.000Z","msg":"炒場都有得叫師架？<br />\n九唔搭八"},"citedBy":0,"replyTime":"2019-01-28T03:38:02.000Z","msg":"請尊重<img src=\"/assets/faces/lomoji/40.png\" class=\"hkgmoji\" />"},{"pid":"1e9beeda3eca807b52a3b48427118b127d10aba5","tid":998241,"uid":134997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-28T03:39:35.000Z","msg":"<img src=\"/assets/faces/lomoji/40.png\" class=\"hkgmoji\" />"},{"pid":"873493a54e8ebf448c0b81c0c5865bc733ff66c7","tid":998241,"uid":134997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-28T03:39:47.000Z","msg":"<img src=\"/assets/faces/lomoji/40.png\" class=\"hkgmoji\" />"},{"pid":"23984e4b71cc3ed4fbbf0a6b3b847b73347de58e","tid":998241,"uid":134997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-28T03:40:01.000Z","msg":"<img src=\"/assets/faces/lomoji/40.png\" class=\"hkgmoji\" />"},{"pid":"4d720d99590cd9e8a75ee672ddeafe079e2a22e3","tid":998241,"uid":134997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-28T03:40:23.000Z","msg":"<img src=\"/assets/faces/lomoji/40.png\" class=\"hkgmoji\" />"}]}