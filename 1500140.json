g src=\"https://na.cx/i/P6kCgEB.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FP6kCgEB.png&h=72586e90&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-08-24T03:12:11.000Z","msg":"巴士封路，狗鐵停駛，不合作助攻，觀塘兵家死地走唔到，去機場，捉緊春袋"},{"pid":"e1069832090cc3c1ad3d4f1f7999eb4f13f063c3","tid":1500140,"uid":56381,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T03:12:33.000Z","msg":"<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"0aaef36056c5c5ecbe8140266d3a8dd67d57c0d1","tid":1500140,"uid":186,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T03:13:33.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"497419e6f8dbf3a76112483d018f32587e85dee7","tid":1500140,"uid":186,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T03:14:34.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"33f5151042995946c1eb2a3370f3d4e4b608e25c","tid":1500140,"uid":219128,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T03:15:06.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"46840e028c2cf113d04b72097ce1c5ea859b6123","tid":1500140,"uid":186,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-24T03:15:43.000Z","msg":"香港鐵路附例<br />\n<a href=\"http://www.mtr.com.hk/ch/customer/main/mtr_by_laws.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.mtr.com.hk%2Fch%2Fcustomer%2Fmain%2Fmtr_by_laws.html&d=LRWPp57H9HH2b7ruXTkGLjyMEfxyOVmMxalVp7jK43I%3D&h=1ce7584d\" target=\"_blank\">http://www.mtr.com.hk/ch/customer/main/mtr_by_laws.html</a>"},{"pid":"077e48a400102d2ec9c8e4198da5ddb2ddcb2f03","tid":1500140,"uid":186,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-24T03:16:10.000Z","msg":"允許進入<br />\n<br />\n(1) 港鐵公司保留在任何時間拒絕允許任何人進入鐵路處所或其任何部分的權利。<br />\n(2) 港鐵公司可在其認為適宜的時間開放或關閉任何車站或月台或已付車費區域的任何部分或鐵路處所的任何其他部分的任何出入口，而無須為因此而引致(不論如何引致)的損失或損害而招致對任何人負有的法律責任。"},{"pid":"8d0616a5f16098363990072087de21f2531d9bdd","tid":1500140,"uid":60545,"like":0,"dislike":0,"score":0,"quote":{"pid":"e4286c37c5ec8b1aba4acabf78a0271d3e81e3b7","tid":1500140,"uid":81921,"like":4,"dislike":2,"score":2,"quote":{"pid":"60f86c8d7cecc2b8d0dd41e4e9a2a2e71f01d35b","tid":1500140,"uid":186,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-24T03:10:33.000Z","msg":"指引寫明港鐵要點處理意外事故，公然違反處理意外事故指引<br />\n<br />\n處理意外事故指引<br />\n如發生意外事故，員工須要跟據以下指引，儘快控制情況：<br />\n-在整個意外事故中保持鎮定<br />\n（緊張的員工只會令情況更壞，相反，保持鎮定和有自信的員工懂得處理混亂情況及安撫受驚的乘客。）<br />\n-有條理地思考及按正確步驟控制情況<br />\n-報告負責人或事發地方之業主有關事故情況及給予協助<br />\n-發生意外事故時，無可避免會引致恐慌，儘量安撫乘客及告知情況已受控制<br />\n-防止群眾圍觀<br />\n<strong><span style=\"color: red;\">-儘快指引群眾去到安全地方<br />\n-協助列車服務儘快回復正常，減低對乘客造成不便</span></strong><br />\n<br />\n<a href=\"https://aes.mtr.com.hk/Content/images/MTR.AES/HTMLContent/WEB_REFERENCE_MATERIALS/bbb9d308-d9c4-4d95-a0dd-193dd5730428/fdc12022-030b-47fb-b500-dcfee62624c4.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Faes.mtr.com.hk%2FContent%2Fimages%2FMTR.AES%2FHTMLContent%2FWEB_REFERENCE_MATERIALS%2Fbbb9d308-d9c4-4d95-a0dd-193dd5730428%2Ffdc12022-030b-47fb-b500-dcfee62624c4.pdf&d=LRWPp57H9HH2b7ruXTkGLjyMEfxyOVmMxalVp7jK43I%3D&h=26c2ab47\" target=\"_blank\">https://aes.mtr.com.hk/Content/images/MTR.AES/HTMLContent/WEB_REFERENCE_MATERIALS/bbb9d308-d9c4-4d95-a0dd-193dd5730428/fdc12022-030b-47fb-b500-dcfee62624c4.pdf</a><br />\n<img src=\"https://na.cx/i/P6kCgEB.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FP6kCgEB.png&h=72586e90&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-08-24T03:12:11.000Z","msg":"巴士封路，狗鐵停駛，不合作助攻，觀塘兵家死地走唔到，去機場，捉緊春袋"},"citedBy":0,"replyTime":"2019-08-24T03:16:17.000Z","msg":"機場仲易封<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5074e42db9fe7fabba70615b60a0820372a42ebb","tid":1500140,"uid":12662,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T03:17:19.000Z","msg":"<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"8fa9e1ddd8e60fae7ceeb219cdad6a36a66bd27d","tid":1500140,"uid":17646,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T03:17:27.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"17cb8f9f9b8bc5afab4c3ddbfa93a10df5acd468","tid":1500140,"uid":186,"like":0,"dislike":0,"score":0,"quote":{"pid":"077e48a400102d2ec9c8e4198da5ddb2ddcb2f03","tid":1500140,"uid":186,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-24T03:16:10.000Z","msg":"允許進入<br />\n<br />\n(1) 港鐵公司保留在任何時間拒絕允許任何人進入鐵路處所或其任何部分的權利。<br />\n(2) 港鐵公司可在其認為適宜的時間開放或關閉任何車站或月台或已付車費區域的任何部分或鐵路處所的任何其他部分的任何出入口，而無須為因此而引致(不論如何引致)的損失或損害而招致對任何人負有的法律責任。"},"citedBy":0,"replyTime":"2019-08-24T03:18:10.000Z","msg":"但係留係入面<br />\n佢係無權力趕走<br />\n<br />\n第IX部 強制執行及罰則<br />\n<br />\n42. 將人移離鐵路處所<br />\n<br />\n(1) 如任何人在鐵路處所的任何部分之內或之上被人員合理地懷疑觸犯或企圖觸犯本附例，則在該人員提出要求時，該人須─<br />\n(a) 向該人員提供其姓名及地址及其電話號碼(如有的話)的真實和正確詳情，並出示該等詳情的證明以供查閱；及<br />\n(b) 向該人員出示身分證明以供查閱。<br />\n(1A) 任何人─<br />\n(a) 不得故意不遵守第(1)款所指的規定；或<br />\n(b) 在遵守或企圖遵守第(1)(a)款所指的規定時，不得故意提供其姓名、地址或電話號碼的虛假詳情，亦不得故意提供在要項上有誤導性的其姓名、地址或電話號碼的詳情。<br />\n(2) 每名人員有權將他合理地懷疑已觸犯或正企圖觸犯本附例的人移離鐵路處所(如有需要可使用合理武力)。凡觸犯事項是本附例所訂的罪行，在不損害按照本附例施加的任何處罰或附加費的原則下，該人員有權扣留該人，直至交由警務人員羈押以便依法處理為止。"},{"pid":"1a84c91c62c376c38758759d4cbc3fc522858a08","tid":1500140,"uid":186,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T03:1