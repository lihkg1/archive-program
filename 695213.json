ke":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T18:20:48.000Z","msg":"吹咩<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"c90ec2ab4b3524a06b254af576ebc2bcdbd38c26","tid":695213,"uid":117048,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-06-09T18:25:33.000Z","msg":"此回覆已被刪除"},{"pid":"5a3918d52b318d85d7d430099300e4a32b1cf38e","tid":695213,"uid":71092,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-09T18:35:16.000Z","msg":"關我撚事"},{"pid":"79555afa16d93ca474a2b10bed1fb203ed673dd8","tid":695213,"uid":41818,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-09T18:45:43.000Z","msg":"office<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"a49f1d11e7ad4d10890cdcbb3e6594a2ea788888","tid":695213,"uid":77143,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-06-09T18:47:28.000Z","msg":"who cares<br />\n有錢咪用，我做乜關你撚事"}]}