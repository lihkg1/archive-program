06_a064336a869290c4a85c50e2c5342faf.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F08%2F14%2F141106_a064336a869290c4a85c50e2c5342faf.jpeg&h=42d70b2e&s={SIZE}\" />"},{"pid":"265672dec993847dafc58d1d1edc85cbda0a05c0","tid":1472181,"uid":89898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T13:20:53.000Z","msg":"<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"2bc8386a8e9866c9c36d371279cbebcfc194cd3b","tid":1472181,"uid":89898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T13:21:04.000Z","msg":"<img src=\"/assets/faces/pig/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/bye.gif\" class=\"hkgmoji\" />"},{"pid":"f95ad3783f838d5a651b05acf58cb2631971e1c1","tid":1472181,"uid":89898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T13:21:16.000Z","msg":"<img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"900591250b2c76df78d2d06ac5fe99f97f63982e","tid":1472181,"uid":89898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T13:21:28.000Z","msg":"<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"50461d6e296ca05e8f5997840b6d74b53f9289e9","tid":1472181,"uid":89898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-14T13:21:44.000Z","msg":"<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/pointing.gif\" class=\"hk