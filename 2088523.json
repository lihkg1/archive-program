normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-01T07:42:53.000Z","msg":"嘩 好有用啊<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"3c5fbf56fdcbb81c073090a43f1821138cff1384","tid":2088523,"uid":63464,"like":3,"dislike":184,"score":-181,"citedBy":0,"replyTime":"2020-07-01T07:48:14.000Z","msg":"<img src=\"https://na.cx/i/Mgp07xe.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FMgp07xe.jpg&h=850273cf&s={SIZE}\" /> <br />\n類似依種玩法"},{"pid":"3a5c1f40d0aded3ea806167896d47baf37a8d50d","tid":2088523,"uid":126099,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-01T07:50:01.000Z","msg":"<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"b195009153f4b986936eebdedaabe8b0f634638f","tid":2088523,"uid":26405,"like":5,"dislike":57,"score":-52,"citedBy":1,"replyTime":"2020-07-01T07:52:57.000Z","msg":"🖖呢個?<br />\n<br />\n瓦肯舉手禮，是一種源自美國著名科幻題材《星空奇遇記》中瓦肯人用於問好的手禮。該手勢的具體做法為將中指與食指併攏，再將無名指與小指併攏，最後將大拇指儘可能的張開。瓦肯人在使用此手禮時，通常還會說著名的瓦肯祝詞 <span style=\"color: red;\">Live long and prosper </span>，按字面翻譯為「活長久和繁榮」，不過在中文稍改為「<span style=\"color: red;\">生生不息，繁榮昌盛</span>」或「健康長壽&middot;繁榮昌盛」[1]。<br />\n<br />\n而且仲有分開嘅意思<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"a27a5cf1d107cd56d0fbfaafd941500d7a1415cf","tid":2088523,"uid":23094,"like":27,"dislike":3,"score":24,"citedBy":1,"replyTime":"2020-07-01T07:53:57.000Z","msg":"其實你睇返国安法啲條文寫得咁具體<br />\n變相係限制咗佢哋釋法嘅空間<br />\n揮旗、嗌口號，呢啲因為涉及語言，有明確表達嘅意思<br />\n但係手勢係一種象徵，灰色地帶比揮旗、嗌口號更闊<br />\n而且佢要拉你嘅話，未有国安法都拉得<br />\n<br />\n講咗成年Be water<br />\n到時如果真係舉手勢都可以定罪<br />\n先至再諗其他方法<br />\n香港人有嘅係智慧同勇氣<br />\n<br />\n你真正要恐懼嘅係「恐懼」本身<br />\n唔好俾未知嘅嘢限制咗你嘅思考"},{"pid":"fec672095862ebccb0170b2203453323d375010e","tid":2088523,"uid":10207,"like":11,"dislike":15,"score":-4,"citedBy":3,"replyTime":"2020-07-01T07:56:29.000Z","msg":"兩個V手勢。two countries two systems"},{"pid":"ea43afb420da6b7ca6b6628a0ed0f21b59f48aef","tid":2088523,"uid":175036,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-07-01T07:58:38.000Z","msg":"等佢禁埋手語囉<br />\n一係膽搏膽禁都做<br />\n一係搵其他方法做<br />\n最睇唔起上面嗰啲「乜都冇用」撚<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n你冇用唔等如冇野做到<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"ce07897a748530db52ce38fcdaabaed4da777a1a","tid":2088523,"uid":23094,"like":15,"dislike":1,"score":14,"quote":{"pid":"b195009153f4b986936eebdedaabe8b0f634638f","tid":2088523,"uid":26405,"like":5,"dislike":57,"score":-52,"citedBy":1,"replyTime":"2020-07-01T07:52:57.000Z","msg":"🖖呢個?<br />\n<br />\n瓦肯舉手禮，是一種源自美國著名科幻題材《星空奇遇記》中瓦肯人用於問好的手禮。該手勢的具體做法為將中指與食指併攏，再將無名指與小指併攏，最後將大拇指儘可能的張開。瓦肯人在使用此手禮時，通常還會說著名的瓦肯祝詞 <span style=\"color: red;\">Live long and prosper </span>，按字面翻譯為「活長久和繁榮」，不過在中文稍改為「<span style=\"color: red;\">生生不息，繁榮昌盛</span>」或「健康長壽&middot;繁榮昌盛」[1]。<br />\n<br />\n而且仲有分開嘅意思<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-07-01T08:00:25.000Z","msg":"唔係人人做到呢個手勢"},{"pid":"85a25f49bdeb1fefa5fa55b9cb5217c8f0f34332","tid":2088523,"uid":23094,"like":0,"dislike":0,"score":0,"quote":{"pid":"ea43afb420da6b7ca6b6628a0ed0f21b59f48aef","tid":2088523,"uid":175036,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2020-07-01T07:58:38.000Z","msg":"等佢禁埋手語囉<br />\n一係膽搏膽禁都做<br />\n一係搵其他方法做<br />\n最睇唔起上面嗰啲「乜都冇用」撚<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n你冇用唔等如冇野做到<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-01T08:00:43.000Z","msg":"態度正確"},{"pid":"3d91b383a343470ff6c00b62e2856758a5a36b9e","tid":2088523,"uid":27530,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2020-07-01T08:01:09.000Z","msg":"不如話五一比人騎劫左仲好"},{"pid":"ab40b049bbc708eb4e513e4455f304ed9279df57","ti