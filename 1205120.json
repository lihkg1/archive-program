所謂嘅大聯署，連中國外交部都引用嘅大聯署，居然係假嘅，絕對係<span style=\"color: red;\">震撼彈</span><br />\n<br />\n<a href=\"https://lihkg.com/thread/1201533/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1201533/page/1</a>"},{"pid":"807a74c40bebec38e1dd1af47eca80c16aeefc3a","tid":1205120,"uid":63017,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-11T19:01:16.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">請廣傳</span></span><br />\n<br />\n希望無論大家去邊，甚至返工，不了<br />\n都想大家連日常生活都黑衫黑褲口罩笠帽加黑鞋<br />\n令到平時條街見到全黑既人唔再係特徵反而係大多數<br />\n最好個個用現金，咁買飛個個就唔係做突出個一個<br />\n<br />\n全民 BLACK BLOCK<br />\n<a href=\"https://lih.kg/1203119\" data-auto-link target=\"_blank\">https://lih.kg/1203119</a><br />\n- 分享自 LIHKG 討論區<br />\n<img src=\"https://na.cx/i/Fzjteoo.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFzjteoo.png&h=20b28c6d&s={SIZE}\" />"},{"pid":"31ed450e5c8d7a39cfda51dbe6b247efe6132e8f","tid":1205120,"uid":19278,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d8f08f59ad20ac0a2dd8164210d207b1616d975","tid":1205120,"uid":232082,"like":438,"dislike":2,"score":436,"quote":{"pid":"c94ff549a39c4ce2f5fe47eea8a6fbfe66275a70","tid":1205120,"uid":145347,"like":0,"dislike":0,"score":0,"citedBy":9,"replyTime":"2019-06-11T17:07:48.000Z","msg":"屋企人話如果我去，就唔認我做女"},"citedBy":1,"replyTime":"2019-06-11T17:08:45.000Z","msg":"你唔比我去我唔認你做老母"},"citedBy":0,"replyTime":"2019-06-11T19:03:32.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8ae0de5dfb1881ed5344222ae10d163ed9255d1d","tid":1205120,"uid":197716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T19:03:34.000Z","msg":"大個女喇"},{"pid":"c8efaf5ce823db95497c11e6589d63b9870ae8ea","tid":1205120,"uid":34229,"like":15,"dislike":2,"score":13,"citedBy":2,"replyTime":"2019-06-11T19:04:53.000Z","msg":"6月9號我有出去,,反到屋企<br />\n<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />:我     <img src=\"/assets/faces/pig/smile.gif\" class=