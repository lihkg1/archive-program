有時。<br />\n3) 人數壓勝，人多就安全<br />\n4) 唔好羊群心態見到狗就跑，跟大隊唔好落單。<br />\n<br />\n香城Online<br />\n<a href=\"https://t.me/HKOnline2\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FHKOnline2&d=Vmg9VhgMmKCDk1oLDtgP7kyCzF7GSvQxQofikz39bzk%3D&h=188b7feb\" data-auto-link target=\"_blank\">https://t.me/HKOnline2</a>"},{"pid":"478e0b2365e71e5b5ee0d1d671f3664f63879cce","tid":2024662,"uid":258937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T19:47:59.000Z","msg":"自推十連"},{"pid":"e9ebf3d12907e6e98f3248d726ba4bfce71e19cc","tid":2024662,"uid":258937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T19:48:12.000Z","msg":"自推十連"},{"pid":"74fba9c64e719ba64eac1c3b535c9ff48a90b019","tid":2024662,"uid":258937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T19:48:27.000Z","msg":"自推十連"},{"pid":"0c4cb045f93c988a16c702a267ebce68bbb53f95","tid":2024662,"uid":258937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T19:48:45.000Z","msg":"自推十連"},{"pid":"b257be7fb06426278e3d6ec128d1e410d9cd1c2a","tid":2024662,"uid":258937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T19:48:58.000Z","msg":"自推十連"},{"pid":"31314dbcc25f9a743cb36fea41970057ab3c8d3a","tid":2024662,"uid":258937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T19:49:14.000Z","msg":"自推十連"},{"pid":"d1bef3e3ba66088114aa1bebcee98c168387bc8a","tid":2024662,"uid":235316,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T19:51:18.000Z","msg":"推"},{"pid":"1304307cd0c1b80fc24ce03ab4dbe8f05610662c","tid":2024662,"uid":235316,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-05-19T19:51:42.000Z","msg":"<img src=\"https://na.cx/i/Sc9eH6R.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSc9eH6R.png&h=af36d848&s={SIZE}\" />"},{"pid":"37e1a97353c0ebbea7ecf36c96066be2dc9d2dac","tid":2024662,"uid":204750,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-19T19:52:02