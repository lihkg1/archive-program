:52:53.000Z","msg":"Push"},{"pid":"66118942aef5848245f3013c94c14e7bec0eb736","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T18:53:05.000Z","msg":"Push"},{"pid":"791b13fb4cbb4c42642a9ee927a088604e04a750","tid":1441904,"uid":251001,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T18:54:50.000Z","msg":"⚠️<strong>時刻保持警覺 獨立思考</strong>⚠️<br />\n<br />\n<span style=\"font-size: large;\"><strong>凡事抱有懷疑態度！不輕信他人！</strong></span><br />\n<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />          <img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />          <img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/lihkg.gif\" class=\"hkgmoji\" />"},{"pid":"91abe01006d1832c0bd57f8ee4f4aea3fd0948e5","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T18:59:04.000Z","msg":"推"},{"pid":"01f39d76d828ab5f6dc65952009d30bb4091c376","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T18:59:14.000Z","msg":"推"},{"pid":"65f960d7306ce1631370a224afa048d204066aea","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T18:59:25.000Z","msg":"推"},{"pid":"0a58a47ac93e1c517bd064b29de9371545d4a8db","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T18:59:37.000Z","msg":"推"},{"pid":"64699a2f7aeb133d9c88228a338015cd50891dce","tid":1441904,"uid":226955,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-10T18:59:38.000Z","msg":"推<br />\n<br />\n<br />\n#我怕只要林鄭一話撤回+成立調查委員會，就有好多人收貨，而忘記其餘三個訴求，為避免運動將來可能分裂，凝聚民間對於「五大訴求缺一不可」嘅共識，係文宣重中之重嘅長期目標<br />\n<br />\n<span style=\"color: gold;\">#毋忘葉虎事件！（疑似中聯辦指揮黑社會打人）大家可以幫推，甚至可以做埋社區文宣煲大佢，絕對唔可以比呢單野不了了之！</span><br />\n［緊急］點解葉虎單嘢可以不了了之？<br />\n<a href=\"https://lih.kg/1382778\" target=\"_blank\">https://lih.kg/1382778</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<span style=\"color: red;\">#仲有84比海綿子彈爆頭暈倒義士、83有義士比狗圍住唔比食哮喘藥結果腦缺氧暈倒，728上環比橡膠子彈爆頭暈倒義士，希望你地可以平安萬全</span>"},{"pid":"06f28bab83fb5df2e88a386dee3075cd6db46669","tid":1441904,"uid":12412,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-10T19:00:37.000Z","msg":"白衫黑社會已經特赦咗啦"},{"pid":"f03443ff07881d73c9111a9e47164478345d56a2","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:00:47.000Z","msg":"推"},{"pid":"07887c5a10edab82c6747b9cce84aafa2e469b62","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:01:10.000Z","msg":"Pish"},{"pid":"8f013eab7b0e50b280f483b97c89617ea1217d2f","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:01:21.000Z","msg":"Pish"},{"pid":"70b5d3b008fb3e1496c2633a2e623410c9481d6a","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:01:38.000Z","msg":"Pish"},{"pid":"09af3560a7a265b4d45793daace703b9ebe627eb","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:01:48.000Z","msg":"Pish"},{"pid":"3950dbf27bf0f85581f6cb133eb42eee6ed52601","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:01:58.000Z","msg":"Push"},{"pid":"f3120f3ed74b0179b81a97e923cc629473d45c16","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:02:12.000Z","msg":"Push"},{"pid":"93abafcd6d9c9f1587f99aeddb3d64223ca3c3f6","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:02:31.000Z","msg":"Push"},{"pid":"7684e56651d190535b1ea94acf1f4b06a8881b30","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:02:48.000Z","msg":"Push"},{"pid":"0c4426a3793acbeec6d0271da56df1ef7a3aa4d4","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:02:58.000Z","msg":"Push"},{"pid":"eefa5e181a631f2caad9d51250f70e16b2624936","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:03:09.000Z","msg":"推"},{"pid":"e511dd1a33e0bf3ae52243d8435623dc2c7442c5","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:03:19.000Z","msg":"推"},{"pid":"1c6d2045531b0dfbf9f346887c29863fd0bd669d","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:03:34.000Z","msg":"Push"},{"pid":"f7c3311d443e7ece0fda29c1841769059ea3f827","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:03:44.000Z","msg":"推"},{"pid":"e2c96a97e34c3a586845e11f3de34f4a1eb4d3e4","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:04:20.000Z","msg":"推"},{"pid":"f3e305f7645c209a71ad61ebe3ac97ece0d353a4","tid":1441904,"uid":281806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:07:16.000Z","msg":"Push <img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"86fb21885affdf20ba985b6afaaf38ee364f2567","tid":1441904,"uid":160348,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-10T19:17:20.000Z","msg":"每次藍絲屌我特赦唔合理，我就叫佢哋睇吓1977年10月尊貴嘅警察們做嘅好事"},{"pid":"878f14c1d90acee4e95899a3886b96adc06d11ec","tid":1441904,"uid":92353,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:28:24.000Z","msg":"胡仙 梁愛詩"},{"pid":"91a3f6a53f4864ce98b1ac88ef88b06401aecfc2","tid":1441904,"uid":74954,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:31:37.000Z","msg":"好簡單回應 <br />\n政府做錯野 <br />\n警察濫權濫捕亂打<br />\n作為公職人員難道無人要負上責任?<br />\n唔跟香港既問責制<br />\n法治又盪然何存?"},{"pid":"47742728fbf59cb8bcd3584e750d1dd58dd7c4c8","tid":1441904,"uid":59242,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-10T19:41:07.000Z","msg":"白衣人冇一個起訴，仲同我講法治？"},{"pid":"821215760c354b9a26001714cdf490c531f5331d","tid":1441904,"uid":263806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:44:09.000Z","msg":"香港政府 同港府兵 全港最暴"},{"pid":"f3405e879d5462da69423efa00d44a274f910d0b","tid":1441904,"uid":280752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T19:48:48.000Z","msg":"家下都仲係藍屍既話理佢都多鳩餘, 成班on9成日都倒果為因, 成個制度都失曬衡, 佢地就話你可以按機制爭取, 爭佢老母, 就係失曬衡點爭取? 按機制咪係幾十萬市民既票比你當廢物 DQ 曬民選議員囉, 按機制咪係連ICAC都變曬質囉, 按機制咪係連想投訴黑警濫權連個黑警編號都問唔到囉. 按機制? 按你老母."},{"pid":"49a1f809f827360b5b491af42bd9197984da80ac","tid":1441904,"uid":299702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T20:04:44.000Z","msg":"其實藍絲係得幾個Point：<br />\n1. 廢青暴力搞事, 破壞社會安寧<br />\n2. 廢青想搞亂香港經濟<br />\n3. 廢青想搞港獨, 自立為王<br />\n4. 收左錢, 外國勢力介入<br />\n5. 放暑假太得閒, 冇錢又唔做返工, 係度阻住地球轉<br />\n<br />\n可以見到佢地已經對逃犯條例完全唔在意，當初佢地撐既防止香港變成逃犯天堂理據盡失。"},{"pid":"3b621ae138dad7530213cba2b9abb00920edc370","tid":1441904,"uid":263098,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-10T20:13:04.000Z","msg":"其實我覺得仲有個point<br />\n警察濫捕，扑穿街坊頭，路過都落案起訴非法集結/暴動<br />\n是否有足夠理由控告？<br />\n是否砌生豬肉製造白色恐怖？<br />\n是否合乎法治精神？<br />\n警隊明顯帶歧視執法，是否可信？"},{"pid":"5a9f773cce00ba55c6e347b3b3cf1cac683a4a80","tid":1441904,"uid":299881,"like":0,"dislike":0,"score":0,"quote":{"pid":"f582844e2034bdc92699b7e2c8f3c762c5547308","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-10T18:41:04.000Z","msg":"<strong><ins>策略+學術po</ins></strong><br />\n<strong><span style=\"color: purple;\">吹水台沉咗底，喺時事台到再po過<img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" />麻煩幫推個</span></strong><br />\n<img src=\"/assets/faces/big/angel.gif\" class=\"hkgmoji\" /><span style=\"color: red;\">大家好，以上嘅謬論相信大多經常都會喺班藍絲口中聽到。但除咗澄清「學生不是暴徒 義士無罪」之外，我哋仲可以點駁斥呢？小弟歸納出三點（因為傾向學術分析，所以言辭唔會大激昂）<br />\n</span><br />\n<span style=\"color: orange;\">1.政治層面：現屆政府作的任何決定已完全缺乏公信力</span><br />\n喺六月九日一百萬人大遊行後，政府宣佈如期立法，當中明顯包括本來政治冷漠嘅人，但政府即日宣佈如期立法。縱使一個星期後政府話「暫緩」，以至後來嘅「壽終正寢」，只要留意政府喺百萬市民上街後漠視民意照上街而照推惡法呢一點，唔單止睇到林鄭嘅跋扈,仲見到佢嘅無能，因為一個城市中有七分之一嘅人俾政府無視，佢哋因憤懣帶來嘅動盪必然非同小可。果然，六月十二日，行動升級，多人受傷。呢啲都係林鄭一手造成！<strong>而呢個時候，林鄭完全無諗過點拆彈，而只係譴責譴責同譴責！<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /></strong><br />\n所以到而家八月先仍然有咁多後生出嚟！<span style=\"color: blue;\"><strong><img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />呢啲同班藍絲講就最啱。而家唔係同你講淨係同你講政治倫理咁簡單，係話緊你林鄭月娥，一開始唔鳩理人反對，之後就派班差佬出嚟打人。人哋義憤，你就淨係識哩喺禮賓府出口術，西口西面咁屌人！</strong></span>鬼唔知依家香港亂咩，但歸根究底都係因為你唔聽人講嘢哎嘛！當年班警衝icac，MacLehose都要特赦啦。點解今日反對聲音比當年更大,涉事疑犯又少得多，你就死都唔肯特赦呢？引用班藍絲一句：「柒婆你係咪要搞到香港亂哂先安樂？」<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: orange;\">2.法理層面</span><br />\n《公安條例》喺1967年醖釀，1970年立法，針對嘅係1967暴徒嗰啲放土製菠蘿、殺害弱小嘅真暴行<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />。先唔好講今日示威者只係針對濫用公權力嘅人，再講，法例裏好多條文模糊不清，例如究竟點樣分辨「非法集會」同「暴動罪」呢？如後者的定義是「嚴重妨礙公眾安全」，咁唔通元朗無差別恐襲仲未夠嚴重？<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />點解DOJ只係告非法集會？故此，根本係無定義，<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />亦都講唔通！再講，連前宗主國英國（《公安條例》推手）自己都廢除埋呢條例，足見法例過時。而翻查LegCo文件，當年法例能夠通過嘅其中一個原因係政府保證唔濫用。時代會進歩，我哋係咪仍然要沿用殖民地嗰種維穩思維，又係咪要向政府搖尾乞憐，<img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" />祈求佢唔好㩜捕㩜控呢？所以，一句講曬，公安條例就算唔被廢除都應該取消，因為定義模糊，違反法治。今日，既然我哋承認呢點，就應該特赦所有牽涉在內嘅人，唔單止係還呢班人公道，更加係為修正《公安條例》奠下基石。<span style=\"color: green;\">PS至於特首無權特赦一說更加係不值一駁，因為不論《基本法》及《刑事訴訟條例》都賦予特首赦免權！</span><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: orange;\">3.倫理方面：展現人性</span><br />\n多名義士以死相搏，以至數名烈士以死明志，皆為港共政權無惡不為所致。眾示威者無權無勢、裝備與警相比更是見拙。眾人無意以殘殺忠良無辜為樂。由示威者仗義救婦人、老嫗、記者於催淚彈橫飛的亂局便可見之。社會宜體諒示威者，亦適合藉特赦免這群孩子（或各有志之士)受牢獄之災。<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-10T20:15:05.000Z","msg":"Push"},{"pid":"55d845591b3682fab07da6063144a9f2824e0be9","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"quote":{"pid":"3b621ae138dad7530213cba2b9abb00920edc370","tid":1441904,"uid":263098,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-10T20:13:04.000Z","msg":"其實我覺得仲有個point<br />\n警察濫捕，扑穿街坊頭，路過都落案起訴非法集結/暴動<br />\n是否有足夠理由控告？<br />\n是否砌生豬肉製造白色恐怖？<br />\n是否合乎法治精神？<br />\n警隊明顯帶歧視執法，是否可信？"},"citedBy":0,"replyTime":"2019-08-10T20:15:19.000Z","msg":"講得啱，「證據不足」係一個好強嘅理由<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"43fc9e1e96770093e80ede7282813f22492226de","tid":1441904,"uid":19062,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-10T20:29:41.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />老老實實 政苦自己認左錯<br />\n點解係會要指出政府有錯既人受罪<br />\n但做錯事果d 反而無事<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n至於之後果d 就另一個case"},{"pid":"f3369c9f176451016af347439942fdb0efbaa366","tid":1441904,"uid":194588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T20:31:15.000Z","msg":"推"},{"pid":"32899e65185c2566d24c03d435d27f3d6e03de4d","tid":1441904,"uid":194588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T20:31:25.000Z","msg":"推"},{"pid":"5c86e25f3c2489eb4ffa6ba5503b100d225921ec","tid":1441904,"uid":262522,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T20:33:06.000Z","msg":"<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"1c4eccd74acef42552cebdb87e3a17af15c773da","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T20:35:51.000Z","msg":"推"},{"pid":"515645d14d2d735ca01b974ee18e64c45ecae65f","tid":1441904,"uid":303577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T20:36:02.000Z","msg":"推"},{"pid":"1a423619ea416eea7eeb