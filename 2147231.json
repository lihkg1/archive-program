方陣，該黨作為西班牙執政黨及唯一的合法政黨直至1977年被取締。"},{"pid":"ece792588e5c2bd75a20350bf48f1cd6ac3a0d92","tid":2147231,"uid":148017,"like":5,"dislike":2,"score":3,"quote":{"pid":"488313e815ec18051422b29a843f715ce672d97e","tid":2147231,"uid":192409,"like":77,"dislike":9,"score":68,"citedBy":10,"replyTime":"2020-08-09T06:11:45.000Z","msg":"泛民學下啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-09T07:20:39.000Z","msg":"<img src=\"https://na.cx/i/ewsfW9Q.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FewsfW9Q.png&h=4cb930c1&s={SIZE}\" />"},{"pid":"dcaf60b9e377589c8f33c00c6f19fca27731a063","tid":2147231,"uid":44483,"like":1,"dislike":0,"score":1,"quote":{"pid":"b8789e294045a665f16b9659b56ddccaabfe86a5","tid":2147231,"uid":95138,"like":0,"dislike":0,"score":0,"quote":{"pid":"dec6d2578bcc2fbe464ec9e60870a995fe8a877c","tid":2147231,"uid":141469,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-08-09T07:06:23.000Z","msg":"泛民：總辭成效不大 要留有用之身<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-09T07:07:07.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-08-09T07:20:41.000Z","msg":"蟲泰份糧fat fat <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"028381cc52ba046e3a0bc8b213aa666a8da4c571","tid":2147231,"uid":295230,"like":3,"dislike":0,"score":3,"quote":{"pid":"8e92ce180b223c9a9e3ed7967a1946bbe43ff905","tid":2147231,"uid":172627,"like":0,"dislike":0,"score":0,"quote":{"pid":"914b7e25c2c6bae6bfdb949b9a277470f1a62de2","tid":2147231,"uid":295230,"like":1,"dislike":2,"score":-1,"quote":{"pid":"609bf3c570a27eade05865847a416471f70d6b87","tid":2147231,"uid":297045,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-08-09T06:34:50.000Z","msg":"個黨名幾型<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-09T06:39:23.000Z","msg":"但長槍黨呢個名係歷史上一D都唔好<img src=\"/assets/faces/normal/clown.gif\" class=\"