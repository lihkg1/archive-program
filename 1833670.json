/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"814ebc100c019de44e5e7f8366738bf93aedb103","tid":1833670,"uid":32655,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-22T04:23:23.000Z","msg":"<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"967ac61346161b98d857228ec62ac2737acac257","tid":1833670,"uid":92188,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-22T04:24:53.000Z","msg":"推"},{"pid":"20d799457cf2be6fe64f6b6b3ed8b2344e90dcbc","tid":1833670,"uid":146737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-22T04:28:18.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"088aee0c613be72bccdbbfc6f73e4f12fcb4bd99","tid":1833670,"uid":148203,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-22T05:02:17.000Z","msg":"牆紙<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" />"},{"pid":"17fdc7fcbd2b58fa97a63645e411462a8f3975ee","tid":1833670,"uid":146737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-22T05:20:07.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"9de2f44ccc185b75e60d0c7713709b5f8f9ef29c","tid":1833670,"uid":83661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-22T05:29:36.000Z","msg":"push"},{"pid":"16a0072c42147ac17d259b89cb567e5c630e0db3","tid":1833670,"uid":146737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-22T05:55:26.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"957389add370fd1347d7962860afffd3a280628e","tid":1833670,"uid":58160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-22T08:09:13.000Z","msg":"推"},{"pid":"0325f566f6f2a17e2bda6fc081b15e9607007926","tid":1833670,"uid":325953,"like":3,"dislike":0,"score":3,"quote":{"pid":"a5b3c7ee239604af85f3e7d35010222b3617d11b","tid":1833670,"uid":253119,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-22T04:13:21.000Z","msg":"