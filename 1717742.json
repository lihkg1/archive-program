{"tid":1717742,"cid":5,"subCid":0,"title":"【正式宣佈】11.14 曙光行動 繼續罷 ! 繼續塞 !","createTime":"2019-11-13T16:31:33.000Z","updateTime":"2019-11-13T22:05:05.000Z","uid":198990,"like":67,"dislike":0,"uniUserReply":34,"replies":[{"pid":"edca9706adf3418261748fa791494040d8943356","tid":1717742,"uid":198990,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-13T16:31:33.000Z","msg":"<img src=\"https://na.cx/i/74gJHrw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F74gJHrw.jpg&h=c1e52d77&s={SIZE}\" /><br />\n<br />\n今日我地有一位手足犧牲左<br />\n我地要呢個香港政府 <span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">還命!</span></strong></span><br />\n<br />\n11.14 6:30 香港人！<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">報仇！！</span></strong></span><br />\n<br />\n<img src=\"https://na.cx/i/9uVB2rF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F9uVB2rF.jpg&h=f726ed45&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/kOu7pE3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FkOu7pE3.jpg&h=d8107bb7&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n林鄭政府再三強調話「宣佈停課」係墜入「暴徒」嘅圈套<br />\n要市民冒著食殘留TG同比曱甴逗嘅危險返工返學<br />\n就連十個月大嘅BB都唔放過！<br />\n<br />\n仲有下令射頭但都狡辯話係射「上半身」嘅曱甴<br />\n<br />\n為政治而犧牲市民生命<br />\n呢個冷血無情、謊話連篇嘅政權！<br />\n我地仲需要妥協咩？！<br />\n<br />\n另外中大申請禁制令一事<br />\n法庭最後認同曱甴「可以以適當武力進入非公眾地方」<br />\n所以唔批出臨時禁制令<br />\n甚至仲即時拒絕上訴！<br />\n<br />\n<br />\n相信喺嗰一刻<br />\n好多香港人都覺得香港法治已死！<br />\n<br />\n咁樣既法庭同政權<br />\n係咪仲值得我哋擁護？！<br />\n<br />\n諗下中大受傷嘅手足！<br />\n荃灣離我哋而去嘅手足！<br />\n天水圍頭部中TG而昏迷嘅手足！<br />\n<br />\n記住！<br />\n停課嘅就出街行下！<br />\n返工遲咗嗰啲記得留意下邊度少人就話比其他人知<br />\n等佢哋都有路返工！"},{"pid":"dcb8309f52dc3cff3dc06c90413772364bd6faeb","tid":1717742,"uid":326463,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T16:31:58.000Z","msg":"11.14 曙光行動 繼續三罷<br />\n<a href=\"https://lih.kg/1714238\" data-auto-link target=\"_blank\">https://lih.kg/1714238</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"f756f64f29982b32ea901fd3f90d7bcc054ed5b3","tid":1717742,"uid":198990,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T16:32:20.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"84d9b1f7ef420b7fc2f0c92379789d63eaa67a0e","tid":1717742,"uid":43033,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-13T16:32:32.000Z","msg":"塞到 五大訴求 缺一不可。"},{"pid":"8dcd6381cbf69b86e1724f2b2372d662f4ce722f","tid":1717742,"uid":198990,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T16:36:10.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"8b9b3d2c87a68a6c175825162e024640c0187dd7","tid":1717742,"uid":90328,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T16:36:27.000Z","msg":"推"},{"pid":"8b4f46c0f014c9a086de75c628fe2b20a29e3d9f","tid":1717742,"uid":266503,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T16:37:57.000Z","msg":"日頭抗爭 夜晚返屋企 避免黑社會伏擊"},{"pid":"93b8483376c7ac8d0634619bb0ebb6ee75507288","tid":1717742,"uid":261345,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T16:38:59.000Z","msg":"推"},{"pid":"c630dbbdbdaab5bf39d95220ef78f2606dcddfd6","tid":1717742,"uid":207641,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-13T16:43:01.000Z","msg":"塞到黑警自焚"},{"pid":"1741ef9b3d5f71d4852d3e4cb52bbd031f983b8f","tid":1717742,"uid":125168,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T16:49:00.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"eb79ef385ac28b6cfd4b71d3713684c1015309ba","tid":1717742,"uid":27993,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T16:55:09.000Z","msg":"推！"},{"pid":"efcf943339acac9a37d1394252d1d6a7587d5a79","tid":1717742,"uid":179283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-13T16:57:27.000Z","msg":"幫手塞大圍九龍塘 成個新東可以收皮"},{"pid":"1775706f226981233006932db6af4d