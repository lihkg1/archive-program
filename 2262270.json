ass=\"red\">裁判官認為盧綺敏在場目的為嚇退事主、欺負她，盧亦非單獨行事，因此裁定她非法集結罪名成立。</span><br />\n<br />\n<a href=\"https://www.thestandnews.com/court/%E8%A2%AB%E6%8C%87%E6%B6%89%E6%97%BA%E8%A7%92-%E7%A7%81%E4%BA%86-%E6%B8%85%E8%B7%AF%E9%9A%9C%E5%A5%B3%E8%AD%B7-%E4%B8%80%E4%BA%BA%E9%9D%9E%E6%B3%95%E9%9B%86%E7%B5%90%E7%BD%AA%E6%88%90%E9%82%84%E6%8A%BC%E5%80%99%E5%88%A4-%E5%8F%A6%E4%B8%80%E4%BA%BA%E8%84%AB%E7%BD%AA/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F%25E8%25A2%25AB%25E6%258C%2587%25E6%25B6%2589%25E6%2597%25BA%25E8%25A7%2592-%25E7%25A7%2581%25E4%25BA%2586-%25E6%25B8%2585%25E8%25B7%25AF%25E9%259A%259C%25E5%25A5%25B3%25E8%25AD%25B7-%25E4%25B8%2580%25E4%25BA%25BA%25E9%259D%259E%25E6%25B3%2595%25E9%259B%2586%25E7%25B5%2590%25E7%25BD%25AA%25E6%2588%2590%25E9%2582%2584%25E6%258A%25BC%25E5%2580%2599%25E5%2588%25A4-%25E5%258F%25A6%25E4%25B8%2580%25E4%25BA%25BA%25E8%2584%25AB%25E7%25BD%25AA%2F&d=2u41qa%2Bce9Gslgrzp%2F5KivjlBAU1VhUdv3lOLHlSYeE%3D&h=f000635a\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fcourt%2F%25E8%25A2%25AB%25E6%258C%2587%25E6%25B6%2589%25E6%2597%25BA%25E8%25A7%2592-%25E7%25A7%2581%25E4%25BA%2586-%25E6%25B8%2585%25E8%25B7%25AF%25E9%259A%259C%25E5%25A5%25B3%25E8%25AD%25B7-%25E4%25B8%2580%25E4%25BA%25BA%25E9%259D%259E%25E6%25B3%2595%25E9%259B%2586%25E7%25B5%2590%25E7%25BD%25AA%25E6%2588%2590%25E9%2582%2584%25E6%258A%25BC%25E5%2580%2599%25E5%2588%25A4-%25E5%258F%25A6%25E4%25B8%2580%25E4%25BA%25BA%25E8%2584%25AB%25E7%25BD%25AA%2F&h=ce297ad3\" data-auto-link target=\"_blank\">https://www.thestandnews.com/court/%E8%A2%AB%E6%8C%87%E6%B6%89%E6%97%BA%E8%A7%92-%E7%A7%81%E4%BA%86-%E6%B8%85%E8%B7%AF%E9%9A%9C%E5%A5%B3%E8%AD%B7-%E4%B8%80%E4%BA%BA%E9%9D%9E%E6%B3%95%E9%9B%86%E7%B5%90%E7%BD%AA%E6%88%90%E9%82%84%E6%8A%BC%E5%80%99%E5%88%A4-%E5%8F%A6%E4%B8%80%E4%BA%BA%E8%84%AB%E7%BD%AA/</a>"},{"pid":"d4f913b110e901bc7c1b137f6e6ce284a8cb30dc","tid":2262270,"uid":21028,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTi