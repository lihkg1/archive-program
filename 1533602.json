ike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T18:26:16.000Z","msg":"17"},{"pid":"16584fd32563a26be6f896698f84d4b6f3e0fa6f","tid":1533602,"uid":291321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T18:26:26.000Z","msg":"18"},{"pid":"fac3716c1ac9379b1f8d5e617c410849588975e6","tid":1533602,"uid":291321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T18:26:36.000Z","msg":"19"},{"pid":"8610de1301c73403e432a0e071de3228ec0336fd","tid":1533602,"uid":291321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T18:26:46.000Z","msg":"20"},{"pid":"b6990aaf9534f2e6024bedfa966f9f882c54b0ea","tid":1533602,"uid":269119,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T18:44:55.000Z","msg":"CCP = <a href=\"https://en.wikipedia.org/wiki/Antisocial_personality_disorder\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fen.wikipedia.org%2Fwiki%2FAntisocial_personality_disorder&d=7ie9SmB3qTQYrTFhvLfIgW9V2ZI%2FeZCj2RMa6yNZ9LM%3D&h=991e4fb6\" data-auto-link target=\"_blank\">https://en.wikipedia.org/wiki/Antisocial_personality_disorder</a><br />\n<blockquote>1. 不能符合社會一般規範對守法的要求，表現於一再作出侵犯法律或社會規範的違法行為。<br />\n2. 狡詐虛偽，表現於一再說謊、使用化名、或為自己的利益或娛樂而詐欺、欺騙、哄騙愚弄他人。<br />\n3. 做事衝動或不能事先計畫。<br />\n4. 易怒且好攻擊，表現於一再打架或攻擊他人身體。<br />\n5. 行事魯莽，不在意自己及他人安危。<br />\n6. 經久的無責任感，表現於一再無法維持經久的工作或信守財務上的義務。<br />\n7. 缺乏悔恨，羞恥和內疚感，表現於無動於衷或合理化對他人的傷害、虐待或偷竊。</blockquote><br />\nHong Kong is being abused.<br />\n香港正在被虐待。"}]}