ttps://na.cx/i/3p4mi1m.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3p4mi1m.png&h=96593928&s={SIZE}\" /><br />\n<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"6599dfc0a9a9604ebb1051f3d63911a5ffb798b8","tid":890094,"uid":294,"like":3,"dislike":1,"score":2,"quote":{"pid":"ddaed68a5432a2359fd0df2c131d4db57ff4894a","tid":890094,"uid":19789,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-05T05:51:40.000Z","msg":"宇宙漿巧令囡<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-05T05:55:03.000Z","msg":"真<br />\n<br />\n<img src=\"http://the-sun.on.cc/cnt/entertainment/20101218/photo/1218-00470-055b4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fthe-sun.on.cc%2Fcnt%2Fentertainment%2F20101218%2Fphoto%2F1218-00470-055b4.jpg&h=3a647e57&s={SIZE}\" />"},{"pid":"f80704f9a7076e4d9a074d45c6fb7acd7cb137d6","tid":890094,"uid":2033,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-05T07:08:32.000Z","msg":"牙gem真係好尾機<br />\n平時睇光年之外個mv都睇到我想噴精<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"279c689944a95966a9b1786ebafc49051c39a4cf","tid":890094,"uid":294,"like":0,"dislike":0,"score":0,"quote":{"pid":"f80704f9a7076e4d9a074d45c6fb7acd7cb137d6","tid":890094,"uid":2033,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-05T07:08:32.000Z","msg":"牙gem真係好尾機<br />\n平時睇光年之外個mv都睇到我想噴精<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-05T07:16:24.000Z","msg":"真<br />\n又大波又白又滑<br />\n唱歌又好聽 <img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"b9f344110c2ed1636aed3fcf3ea19ad4a9591b6e","tid":890094,"uid":83012,"like":0,"dislike":0,"sc