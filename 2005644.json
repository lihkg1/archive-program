ttps%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fdw%2F20200506%2F334814843326566400.jpeg%2FBP9BNEm7b-L4xdJW7BzQtl8qRKpLtcV6eOIURXjiFEU&h=27a79aa8&s={SIZE}\" /><img src=\"https://cdn.hk01.com/di/media/images/dw/20200506/334814846380019712.jpeg/V-ucMGUVxBz_BSjIICoTy9ljeEe_MFJGbSf5m20n-Zs\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2Fdw%2F20200506%2F334814846380019712.jpeg%2FV-ucMGUVxBz_BSjIICoTy9ljeEe_MFJGbSf5m20n-Zs&h=2bf07ac7&s={SIZE}\" />"},"citedBy":1,"replyTime":"2020-05-07T12:33:31.000Z","msg":"八達通可以借書？"},"citedBy":0,"replyTime":"2020-05-07T15:42:20.000Z","msg":"係LO<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"}]}