=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f19c566dee7357b4030ea1b1715256d5fe083de8","tid":2034792,"uid":323720,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-25T13:40:33.000Z","msg":"而家黃店應該率先同時接受美金同港紙"},{"pid":"2d9ba2e8600897c084a678ae1691b08428670ceb","tid":2034792,"uid":286792,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-25T13:45:38.000Z","msg":"推"},{"pid":"0f338fe03ff0877fc24ccebab0b27287a25ceb2d","tid":2034792,"uid":77803,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-25T15:55:16.000Z","msg":"唱美金自保就得，唔好諗住唱得爆香港<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />實在太多錢"},{"pid":"76b145294ab8e782af017251b9cbd6ad29efc38e","tid":2034792,"uid":293673,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-05-25T16:31:19.000Z","msg":"此回覆已被刪除"},{"pid":"9d41f3e5c7b56913aa8d76c91eb881d0a6dd68fa","tid":2034792,"uid":326037,"like":0,"dislike":0,"score":0,"quote":{"pid":"884c6b8268d468d7536f567c6bd1566f565cdcac","tid":2034792,"uid":143499,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-25T12:47:31.000Z","msg":"<img src=\"https://na.cx/i/OmpWdaA.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOmpWdaA.png&h=753dff2c&s={SIZE}\" /><br />\n<br />\n唔理派膠定乜嘢好，呢半日突然之間見到好多post話戇鳩仔先信連登仔，然後又話換美金係熱狗先會做嘅嘢<br />\n<br />\n好明顯就係想spin換美金呢件事係錯<br />\n<br />\n<br />\n阿叔喺度解釋多次點解而家換美金係極低成本可以話冇得輸嘅選項<br />\n<br />\n首先第一個重點我從來冇話過你要全副身家換曬美金現金我係講緊你可以換美金現金自己儲蓄或者開離岸戶口而且我從來冇講過要換曬<span style=\"font-size: xx-large;\"><span style=\"color: red;\">全副身家</span></span><br />\n<br />\n<br />\n第二開始有啲人造鳩換美金，一定要用美金嚟黃色經濟圈消費<br />\n<br />\n可能有手足曾經提議過呢樣嘢，不過香港法例規定港元係法定貨幣唔可以唔收， 當然有冇黃店願意收美金呢個係另一個問題，雖然我覺得唔可行<br />\n<br />\n但係黃色經濟圈用美金同埋你副身家換一大部分做美金係完全兩回事兩者唔抵觸<br />\n<br />\n所以好明顯有啲人別有用心想偷換概念不斷底為換美金嘅行動係錯"},"citedBy":0,"replyTime":"2020-05-26T12:02:07.000Z","msg":"<img src=\"https://na.cx/i/E4u7sBZ.png\" data-thumbnail-src=\"