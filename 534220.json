ormal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"2fe09269862042d91292ea064d447f1c71fd7add","tid":534220,"uid":129739,"like":23,"dislike":2,"score":21,"citedBy":0,"replyTime":"2018-01-19T15:38:48.000Z","msg":"蔡生原文係話日本傳統刺身店係冇三文魚刺生呢道菜，因為三文魚可以生食有因於好現代既科技<br />\r，用急凍技術殺死左三文魚體內既寄生蟲同細菌。<br />\n所以識食地道日本菜既人唔會食三文魚同日本人平時會食三文魚係冇衝突。"},{"pid":"e4d304c6d398cc151afb2804acd2d2f66d863b0d","tid":534220,"uid":59832,"like":5,"dislike":4,"score":1,"quote":{"pid":"fe039107bef969d870f659777a3718dd3a54843d","tid":534220,"uid":79711,"like":1,"dislike":37,"score":-36,"citedBy":6,"replyTime":"2018-01-19T15:05:09.000Z","msg":"香港三文魚供應源頭大多數都係大陸"},"citedBy":0,"replyTime":"2018-01-19T16:42:31.000Z","msg":"挪威呀叻唔切<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"7c61a38a0010d58a56a523f0bdf793bf018843f1","tid":534220,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-19T20:04:18.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"782d9bd70782a59e95c428d3921f0dbaff0ff52c","tid":534220,"uid":144466,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-19T20:07:11.000Z","msg":"蔡生出黎講兩句"},{"pid":"2a084cbf94dabe5d4484fc116dfc6a8a8199449a","tid":534220,"uid":60665,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-01-19T20:10:35.000Z","msg":"一早知啦<br />\n直情係日本食過三文魚壽司"},{"pid":"d7e15c8f1069a162f91fa4638630949fb9ee4755","tid":534220,"uid":42949,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-19T20:45:01.000Z","msg":"最易入口既魚生<br />\n你話有冇可能唔食<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"689f332c40315a91ab583463e34dbf11703f4360","tid":534220,"uid":44898,"like":1,"dislike":0,"score":1,"quote":{"pid":"fe039107bef969d870f659777a3718dd3a54843d","tid":534220,"uid":79711,"like":1,"dislike":37,"score":-36,"citedBy":6,"replyTime":"2018-01-19T1