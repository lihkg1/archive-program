{"tid":1433762,"cid":5,"subCid":0,"title":"（狂賀）東區警犬成功爭取全港非醫護食醫院正價大家樂","createTime":"2019-08-08T14:40:49.000Z","updateTime":"2019-08-08T14:44:18.000Z","uid":50658,"like":9,"dislike":0,"uniUserReply":3,"replies":[{"pid":"d9900f2fad0246e7751a49db83c252c29d7315aa","tid":1433762,"uid":50658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-08T14:40:49.000Z","msg":"<img src=\"https://na.cx/i/jhP5zGu.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjhP5zGu.jpg&h=85cab160&s={SIZE}\" /><br />\n<br />\n東區尤德醫院警犬投訴<br />\n搞到連碼嘉烈葵涌醫院(或更多)嘅大家樂都要揸正嚟做<br />\n平時做醫院嘅朋友都知非繁忙時間啲餐廳姐姐都係側側膊<br />\n東區成日都有師奶入去食平飯坐起度hea一晝<br />\n依家人地聲明話就話淨係警犬<br />\n但係短期內啲姐姐都係會全部揸正嚟做<br />\n<br />\n藍絲下次冇平飯食𠴱陣，記得多謝阿Sir啦<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"2147a3a22364636472f656ee1ad36f14eae7d22d","tid":1433762,"uid":50658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-08T14:41:54.000Z","msg":"<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"56d3bee6e18fef8b4b763c8f5d1daa9f62389afc","tid":1433762,"uid":142007,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-08T14:43:23.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ed86f0910b37efb499f58947d58e3dec036b3d91","tid":1433762,"uid":298034,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-08-08T14:44:18.000Z","msg":"點解email係網址<img src=\"/assets/faces/lm2/think.gif\" class=\"hkgmoji\" />"}]}