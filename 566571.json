an style=\"font-size: xx-large;\"><span style=\"color: red;\">屌你老母錦戶亮</span></span>"},{"pid":"6ef3061eebd84009f90e94ba7503266c60d04d6c","tid":566571,"uid":49391,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-02-20T06:25:14.000Z","msg":"又唔係自爆鍾意玩didlo,唔算好黑暗啫<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ad74b3afd43624f5932ef58b7f65c4d0be9b2907","tid":566571,"uid":5123,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-02-20T06:29:49.000Z","msg":"入黎就係為左睇朱千雪<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"29316a4e348f54a5c10b39a11712dc322c3b9ba4","tid":566571,"uid":9286,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-02-20T06:35:21.000Z","msg":"如果錦戶亮唔係衰口多, 點止8個月<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"e23c72a7b124d71d0e33d1c37b522de0394675e1","tid":566571,"uid":135265,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-20T08:32:20.000Z","msg":"冇睇user name就入咗嚟<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/offtopic.png\" class=\"hkgmoji\" />"},{"pid":"900dbb8bd765735047027e1b1795265059edfd02","tid":566571,"uid":116289,"like":0,"dislike":0,"score":0,"quote":{"pid":"6ef3061eebd84009f90e94ba7503266c60d04d6c","tid":566571,"uid":49391,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-02-20T06:25:14.000Z","msg":"又唔係自爆鍾意玩didlo,唔算好黑暗啫<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-20T09:04:35.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9cb4d7b38766287a00d37912a3a46c4b785934ba","tid":566571,"uid":63113,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2018-02-20T12:34:18.000Z","msg":"錦戶亮即棄餐具 慘情"}]}