idEXTr.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCidEXTr.gif&h=6f9195fd&s={SIZE}\" />"},{"pid":"4ed96052b37c8f6bfb36294172c9b5af1d33aec9","tid":2292074,"uid":96170,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d1b07b7628d358ee46d27dc67d4c5f4c1c8396e","tid":2292074,"uid":236991,"like":0,"dislike":0,"score":0,"quote":{"pid":"02f10e9c12fbd5c4e7dfe6698c3cc058d4af4926","tid":2292074,"uid":322234,"like":1,"dislike":0,"score":1,"quote":{"pid":"864dc4a1888a4a1439355eb81d4a08c8c5be36cb","tid":2292074,"uid":236991,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2020-11-19T09:37:33.000Z","msg":"好高深啊<br />\n咁我應該點做"},"citedBy":1,"replyTime":"2020-11-19T11:51:59.000Z","msg":"除左個3.遙控, 其他1.2.4.唔好亂咁攪 唔識好易電撚死<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n盡量解釋一下<br />\n1. 總開關 - 就係係你屋企個總電箱裏面其中一條比冷條既fuse,<br />\n2. 房入面個冷氣開關 - 就係個開關電制但有粒燈，開左電會著燈，有時分體機未必會裝哩個開關，齋用遙控開關<br />\n4. 接線蘇 - 有個白色方型既有蓋電位（含fuse在內）出條線比部室內機<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-11-19T14:41:29.000Z","msg":"有#2的開關制喺冷氣隔離，我關了"},"citedBy":1,"replyTime":"2020-11-19T14:52:13.000Z","msg":"我又覺得係三壞喎，或者係本身部室內機裏面嘅電子版有問題，因為照道理就算你開咗個燈曲制，有電通到部機，但係佢都唔會幫你自動開着嘅，一定係有啲嘢觸動到佢開機嗰個signal，佢先至會開機。<br />\n<br />\n又或者係個遙控傻傻地，自動發射啲signal去部機度開着。我覺得簡單安全嘅方法，就係首先搵啲膠紙痴住個接收器，冷氣機同遙控都係。如果咁都出現問題嘅話，應該係塊電子版有問題<br />\n<br />\n本身一開始唔排除隔離屋開冷氣，佢個訊號射左去你部冷氣機，連同你部冷氣機都開着埋<br />\n<br />\nBtw,呢部機係咩牌子？"},{"pid":"0ecf2d8bab03fb80b90f0a8e3cd023ac71c09dbf","tid":2292074,"uid":60432,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-11-19T14:52:45.000Z","msg":"鬼"},{"pid":"6e67aade240efdd99c124c98e2bc6262a0c2bcf3","tid":2292074,"uid":236991,"like":0,"dislike":0,"score":0,"quote":{"pid":"454a0c385b4889525d8d37b2a83307771ed2f8a4