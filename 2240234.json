2eb1a61cc7d9de1550a6","tid":2240234,"uid":137569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-13T06:14:35.000Z","msg":"佢個frd 當奴嚟嘅<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"f38b048056c9c47c276401367872675b2dd16bcf","tid":2240234,"uid":331421,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-13T06:17:58.000Z","msg":"蝙蝠俠：整臭我個朵"},{"pid":"d9d2eb9e71e64a958ebbe713a59f513ac84a2a52","tid":2240234,"uid":270889,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-10-13T06:20:28.000Z","msg":"more links here<br />\n上去屌賓仔 撐餐廳畫家<br />\n<br />\n菲律賓fashion blogger覺得諷刺習大畫作係racist<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/ghpvBS\" data-auto-link target=\"_blank\">https://lih.kg/ghpvBS</a>"},{"pid":"60d500b4ddf1b0a2391fdedaf57d21218335cfc2","tid":2240234,"uid":270889,"like":0,"dislike":0,"score":0,"quote":{"pid":"ca90da1dd773edd5ac931ab3779b6617236dadce","tid":2240234,"uid":358086,"like":1,"dislike":0,"score":1,"quote":{"pid":"f0feaeaf4d4dca7e2a6928190a0044c3c9901a74","tid":2240234,"uid":295230,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-12T14:06:11.000Z","msg":"大家仲入唔入到條on9既ig?"},"citedBy":2,"replyTime":"2020-10-12T14:08:10.000Z","msg":"仲入到<br />\n<img src=\"https://na.cx/i/fGVOdDY.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfGVOdDY.png&h=1b2fe383&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-10-13T06:20:50.000Z","msg":"自爆??"},{"pid":"6ab7af583fa4c4e09679898e62e8217ab0b70d9e","tid":2240234,"uid":365791,"like":0,"dislike":0,"score":0,"quote":{"pid":"98c5c09b8858dd9826fc1c0346e1612ff7f2e860","tid":2240234,"uid":358086,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-12T13:37:16.000Z","msg":"<img src=\"https://na.cx/i/a7uLfE4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fa7uLfE4.jpg&h=17a623c4&s={SIZE}\" /><br />\n<br />\n曾任《全美超模大賽》主持、菲律賓著名時裝blogger Bryanboy日前於ig上發文，指佢喺瑞典斯德哥爾摩一間餐廳食飯嘅時候，發現餐廳貼滿「畫到塊面好黃、有蝙蝠耳仔」嘅習近平海報，上面寫住「BAT MAN」字眼。Bryanboy表示當時餐廳裡面只有佢同朋友2個係亞裔，雖然已經嗌咗嘢食但都好想馬上離開餐廳，又提出武肺以來令佢同好多朋友都飽受歧視。<br />\n<br />\n海報創作者「ironartworks」得悉後亦隨即喺ig發文，再三慎重向所有因為呢張poster而受冒犯嘅人致歉，並解釋佢一直以來嘅創作都係以諷刺極權者為重點，今次亦只係想諷刺中共同習近平引致武肺爆發，無意製造種族歧視嘅言論。而餐廳亦對張貼作品令人不安致歉，並將海報撤走。<br />\n<br />\n根據BBC訪問，Bryanboy就對「ironartworks」嘅回應就感到不滿，覺得對方並非道歉，指責佢唔知自己嘅作品會引發啲咩效應係一種「無知」；而海報設計者則表示認為今次事件係「取消文化」嘅例子，意指知名人士因某啲被指冒犯嘅行為而受到公眾抵制，因為呢張海報已經喺當地展示咗幾個月，喺餐廳內亦張貼咗一個月，從未收到有關投訴，認為呢種「取消文化」對社會嘅影響遠比藝術創作帶來嘅影響更加大。<br />\n<br />\n資料來源：100毛<br />\n<br />\nBBC | IG/Bryanboy、ironartworks<br />\n<br />\n<br />\n<span class=\"red\"><strong><span class=\"x-large\">個愛支菲律賓人係IG同Twitter不斷del走香港人留言</span></strong></span><br />\n<br />\n<a href=\"https://mobile.twitter.com/bryanboy/status/1314990170605850625?s=20\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmobile.twitter.com%2Fbryanboy%2Fstatus%2F1314990170605850625%3Fs%3D20&d=W9k3bdIekjUozLnTtmc2Vy%2B7EDXmwg1SXj7S5MqlT1o%3D&h=624030a0\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fmobile.twitter.com%2Fbryanboy%2Fstatus%2F1314990170605850625%3Fs%3D20&h=38ed30e1\" data-auto-link target=\"_blank\">https://mobile.twitter.com/bryanboy/status/1314990170605850625?s=20</a><br />\n<br />\n<a href=\"https://www.instagram.com/p/CGLA7lPBLwB/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fp%2FCGLA7lPBLwB%2F&d=W9k3bdIekjUozLnTtmc2Vy%2B7EDXmwg1SXj7S5MqlT1o%3D&h=319cc0f6\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.instagram.com%2Fp%2FCGLA7lPBLwB%2F&h=4c850319\" data-auto-link target=\"_blank\">https://www.instagram.com/p/CGLA7lPBLwB/</a>"},"citedBy":0,"replyTime":"2020-10-13T06:32:05.000Z","msg":"直接click哩到可以留言俾條支那"},{"pid":"9b8ede4d0bcf72ee4f526ea1538eb11f8efcb968","tid":2240234,"uid":365791,"like":0,"dislike":0,"score":0,"quote":{"pid":"f0feaeaf4d4dca7e2a6928190a0044c3c9901a74","tid":2240234,"uid":295230,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-12T14:06:11.000Z","msg":"大家仲入唔入到條on9既ig?"},"citedBy":0,"replyT