i\" />"},{"pid":"31f5a88628d0a38c810dfe3133b3eab423d5b91c","tid":1511843,"uid":305839,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-28T21:25:44.000Z","msg":"我明<br />\n<br />\n個種感覺好無力 日日都唔想做人 覺得好辛苦 但係又怕死<br />\n<br />\n但係 唔好放棄<br />\n加油啦。"}]}