kg.com/link?u=https%3A%2F%2Fwww.cbc.ca%2Fnews%2Fpolitics%2Fchina-canada-huawei-snc-lavalin-1.5038640&d=u7xsq8u58TeopDPyjGw7C7tFVp6nBI01qSlVibQweWg%3D&h=77d4cdf2\" target=\"_blank\">https://www.cbc.ca/news/politics/china-canada-huawei-snc-lavalin-1.5038640</a>"},{"pid":"b55cbfa10aeb070c4a1e1112d556ac7cc5f98369","tid":1042780,"uid":131423,"like":33,"dislike":0,"score":33,"quote":{"pid":"0cef4bf98439daacb14f8430ee4548adedff8659","tid":1042780,"uid":35790,"like":3,"dislike":1,"score":2,"quote":{"pid":"9df302b40f1dcc533f2afc3831a7aabd07e0d88c","tid":1042780,"uid":131423,"like":148,"dislike":0,"score":148,"quote":{"pid":"a3e63778a6293d049b19ea46210431f38e33f930","tid":1042780,"uid":35790,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2019-03-01T19:15:04.000Z","msg":"source?"},"citedBy":5,"replyTime":"2019-03-01T19:19:52.000Z","msg":"<a href=\"https://www.cnbc.com/2019/03/01/canadian-government-allows-extradition-of-huawei-cfo-to-the-us.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.cnbc.com%2F2019%2F03%2F01%2Fcanadian-government-allows-extradition-of-huawei-cfo-to-the-us.html&d=u7xsq8u58TeopDPyjGw7C7tFVp6nBI01qSlVibQweWg%3D&h=5877215c\" target=\"_blank\">https://www.cnbc.com/2019/03/01/canadian-government-allows-extradition-of-huawei-cfo-to-the-us.html</a><br />\n出哂新聞，睇黎堅了<br />\n佢會唔會即刻衝入中國大使館<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-03-01T19:23:31.000Z","msg":"It's the first step in what's likely to be a lengthy and revealing legal process."},"citedBy":0,"replyTime":"2019-03-01T19:25:53.000Z","msg":"The Department is satisfied that the requirements set out by the Extradition Act for the issuance of an Authority to Proceed have been met and there is sufficient evidence to be put before an extradition judge for decision.<br />\n下一步，3月6上court <br />\n法治社會當然要慢慢黎<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"2b40b1636d0cc72e3b02edf868c2d8f4a6adea07","tid":1042780,"uid":16344,"like":56,"dislike":0,"score":56,"citedBy":0,"replyTime":"2019-03-01T20:20:18.000Z","msg":"正義得到彰顯"},{"pid":"244db81ecc1b1bae0a3430746e4e19a05af23207","tid":1042780,"uid":33432,"like":51,"dislike":0,"score":51,"citedBy":0,"replyTime":"2019-03-01T20:24:35.000Z","msg":"孟：召喚吳京"},{"pid":"34f219b54e366f4759dcd678a366054c993313d9","tid":1042780,"uid":47259,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2019-03-01T20:32:58.000Z","msg":"狸貓換太子又即將上演喇<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"c4ccb23da69e6f7121bd3e331df349245107865d","tid":1042780,"uid":78143,"like":165,"dislike":1,"score":164,"citedBy":1,"replyTime":"2019-03-01T20:32:58.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2019/03/02/043257_ca3fd43b72ccdde3e71776007054af42.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F03%2F02%2F043257_ca3fd43b72ccdde3e71776007054af42.jpg&h=8226c96d&s={SIZE}\" />"},{"pid":"d379df413673c45ca1d932458f253d7ae4b6bd4c","tid":1042780,"uid":37699,"like":61,"dislike":0,"score":61,"citedBy":1,"replyTime":"2019-03-01T21:32:08.000Z","msg":"係「批准引渡聆訊」。<br />\n<br />\n加拿大司法部周五下午宣布，批准華為副董事長孟晚舟引渡聆訊。<br />\n<br />\n司法部周五批准就引渡孟晚舟進行法庭聆訊，法官可聽取有關是否批准美國引渡孟晚舟到美國受審判的論點，該案件於下周三會返回卑詩省最高法院出席聆訊。<br />\n<br />\n加拿大司法部的聲明指出，有足夠證據讓法院決定是否符合兩國之間的引渡協議，強調聆訊並不是要裁定孟晚舟是否有罪。<br />\n<br />\n法庭有引導判決後，司法部長 David Lametti 最終必須決定孟是否被引渡。"},{"pid":"6f6b4dc1cf676103f7fbd8241add9ac660d84ea9","tid":1042780,"uid":55913,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-03-01T22:38:35.000Z","msg":"快d去加拿大賣新聞頭版<br />\n加拿大無晚晚J等於支那人無隨街痾屎<img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d497e950c6b3b4e379ca706e7d64baec54343607","tid":1042780,"uid":117679,"like":0,"dislike":0,"score":0,"quote":{"pid":"242d2558242d7a926f6246918b69dfa6a972a362","tid":1042780,"uid":70786,"like":6,"dislike":0,"score":6,"quote":{"pid":"9df302b40f1dcc533f2