uot;Yes&quot; Then\n                Worksheets(&quot;Sheet1&quot;).Cells(j, 5) = &quot;Yes&quot;\n            End If\n        End If\n    Next j\n    If ExistColD = False Then\n        Worksheets(&quot;Sheet1&quot;).Cells(ColDCount + 1, 4) = Worksheets(&quot;Sheet1&quot;).Cells(i, 1)\n        Worksheets(&quot;Sheet1&quot;).Cells(ColDCount + 1, 5) = Worksheets(&quot;Sheet1&quot;).Cells(i, 2)\n    End If\nNext i\nEnd Sub</code></pre><br />\n<br />\n如果完全唔識點用VBA，可以由依條片第35秒開始睇。<br />\n<a href=\"https://youtu.be/GOPNlVrcVW8?list=PLHguOF-Fnm4xZmDj4Kc5ZSGQOo0R44Ek-&amp;t=36\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FGOPNlVrcVW8%3Flist%3DPLHguOF-Fnm4xZmDj4Kc5ZSGQOo0R44Ek-%26t%3D36&d=CSzjam5d59%2B0TSQi2Kgm6g5Iyec62GFiithg4eFnous%3D&h=f19b6e78\" target=\"_blank\">https://youtu.be/GOPNlVrcVW8?list=PLHguOF-Fnm4xZmDj4Kc5ZSGQOo0R44Ek-&amp;t=36</a>"},"citedBy":0,"replyTime":"2019-12-18T15:22:06.000Z","msg":"有料<img src=\"/assets/faces/pigxm/cook.gif\" class=\"hkgmoji\" />"},{"pid":"8f7e73581ce3815ab79daa0aeebde7c30a79801f","tid":1788262,"uid":111246,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec72305edb4dd0858faca1ac42b4c31b535ff299","tid":1788262,"uid":71237,"like":1,"dislike":0,"score":1,"quote":{"pid":"fdf97b4224c3551cdc664995b6f4f1095d1250bb","tid":1788262,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-18T14:26:24.000Z","msg":"首先用for loop由A2掃落A16<br />\n檢查如果人名無喺Column D出現過就抄value去Column D, E<br />\n如果出現過就再加多一個if, 如果Column B係Yes就出Yes"},"citedBy":3,"replyTime":"2019-12-18T15:20:06.000Z","msg":"我已經寫完，測試過無問題。<br />\n<br />\n<pre><code data-type=\"\">Sub lihkg()\nColACount = Worksheets(&quot;Sheet1&quot;).Cells(1048575, 1).End(xlUp).Row\n\nFor i = 2 To ColACount\n    ColDCount = Worksheets(&quot;Sheet1&quot;).Cells(1048575, 4).End(xlUp).Row\n    ExistColD = False\n    For j = 2 To ColDCount\n        If Worksheets(&quot;Sheet1&quot;).Cells(i, 1) = Worksheets(&quot;Sheet1&quot;).Cells(j, 4) Then\n            ExistColD = True\n            If Worksheets(&quot;Sheet1&quot;).Cells(i, 2) = &quot;Yes&quot; Then\n                Worksheets(&quot;Sheet1&quot;).Cells(j, 5) = &quot;Yes&quot;\n            End If\n        End If\n    Next j\n    If ExistColD = False Then\n        Worksheets(&quot;Sheet1&quot;).Cells(ColDCount + 1, 4) = Worksheets(&quot;Sheet1&quot;).Cells(i, 1)\n        Worksheets(&quot;Sheet1&quot;).Cells(ColDCount + 1, 5) = Worksheets(&quot;Sheet1&quot;).Cells(i, 2)\n    End If\nNext i\nEnd Sub</code></pre><br />\n<br />\n如果完全唔識點用VBA，可以由依條片第35秒開始睇。<br />\n<a href=\"https://youtu.be/GOPNlVrcVW8?list=PLHguOF-Fnm4xZmDj4Kc5ZSGQOo0R44Ek-&amp;t=36\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FGOPNlVrcVW8%3Flist%3DPLHguOF-Fnm4xZmDj4Kc5ZSGQOo0R44Ek-%26t%3D36&d=CSzjam5d59%2B0TSQi2Kgm6g5Iyec62GFiithg4eFnous%3D&h=f19b6e78\" target=\"_blank\">https://youtu.be/GOPNlVrcVW8?list=PLHguOF-Fnm4xZmDj4Kc5ZSGQOo0R44Ek-&amp;t=36</a>"},"citedBy":0,"replyTime":"2019-12-18T15:33:23.000Z","msg":"Ching真係好勁<img src=\"/assets/faces/pigxm/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/dance2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"eff8c30dfd789b0028f565c211ef1995f85a3369","tid":1788262,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-18T15:35:21.000Z","msg":"其實唔勁<br />\n你認真學嘅話一日內可能都100%理解到上面段code"},{"pid":"3c0a3e600839a464093e0da2e3913a617e2c2f3c","tid":1788262,"uid":130568,"like":1,"dislike":0,"score":1,"quote":{"pid":"36ca67b7daf8912a3cc05d368b1c164613f0a149","tid":1788262,"uid":59623,"like":1,"dislike":0,"score":1,"quote":{"pid":"e4c1e513e1de936cc74c8adcef58350374b89044","tid":1788262,"uid":130568,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-12-18T14:34:00.000Z","msg":"<img src=\"https://na.cx/i/UjPcOqY.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUjPcOqY.png&h=886a6c2d&s={SIZE}\" /><br />\nUnique Name, D2=UNIQUE(A2:A)<br />\nBabies?