=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e49734480275eba1e577a8ff7a04fc67d721d0ac","tid":656321,"uid":32665,"like":1,"dislike":17,"score":-16,"quote":{"pid":"dd57ce735992beeb90ec377057161f32044e125c","tid":656321,"uid":181801,"like":2,"dislike":9,"score":-7,"quote":{"pid":"32dd76c978b12f54bf6ae4e30dbcae75dbc54011","tid":656321,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-07T07:00:02.000Z","msg":"<a href=\"http://star.ettoday.net/news/1160332\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fstar.ettoday.net%2Fnews%2F1160332&d=PipUh5SrMdnZYIP%2FzYps9MPrXSGIZiPsBFv3mRhlVuk%3D&h=b887da79\" target=\"_blank\">http://star.ettoday.net/news/1160332</a><br />\n<br />\n2018年04月30日 14:30<br />\n「乙武洋匡GG超大」AV天王清水健一摸嚇呆！　網服了：難怪能劈50女<br />\n<br />\n記者田暐瑋／綜合報導<br />\n<br />\n《五體不滿足》日本作家乙武洋匡才爆出5段婚外情，又在外偷吃50名女子，和妻子離婚後，熱戀20歲的混血女大生，女人緣旺到不行。近日他出席活動，遇上AV男優清水健，兩人一拍即合、狂開黃腔，當清水健一摸到他的下體，頓時露出驚訝表情，驚喊：「他那根好大！」<br />\n<br />\n乙武洋匡日前出席日本影音網站Niconico活動，接受清水健的一連串訪問，對方好奇問他：「會不會看A片？」他自嘲四肢不健全，看了也沒辦法解決生理需求，所以不是很常看，接著又被問到最近一次什麼時候發生性關係？他則是大方回應：「今天早上。」但隨後急忙澄清：「開玩笑的啦～」<br />\n<br />\n最後清水健要求實際觸摸乙武洋匡的身體，對方也欣然答應，當他一路往下摸，摸到乙武洋匡的下體時，露出震驚的表情大喊：「好厲害！！」乙武洋匡繼續開玩笑說：「因為腳沒辦法走，所以營養都留在『正中間』了。」事後清水健在推特PO出摸下體照片，親口認證：「他GG真的很大！」<br />\n<br />\n乙武洋匡離婚後馬上交到新女友，女方出生於1995年6月，父親是日本人、母親是捷克人，有著170公分的高挑身材，長相神似平昌冬奧女子花式滑冰項目金牌選手、俄羅斯運動員薩奇夫娃（Alina Zagitova）。除了外表亮眼外，這位混血女大生才華洋溢，精通5種語言，且擁有自己的公司，是教育機構行業的社長。<br />\n<br />\n<br />\n關於混血女大生的名字，有網友肉搜出本名為「岩澤直美」，還搜遍推特所有貼文內容，發現岩澤直美早已與乙武洋匡有互動。目前也有部分日本媒體將乙武洋匡「新戀人」和「岩澤直美」畫上等號，但仍未獲得證實。<br />\n<br />\n相關人士透露，乙武洋匡在3年前參加朋友介紹的學習會，並且認識到這位混血女大生，最後關係越來越親密。另外這位相關人士還提到，乙武洋匡正在和混血女大生同居中，女方雙親好像已經承認了兩人的關係。"},"citedBy":1,"replyTime":"2018-05-07T07:07:21.000Z","msg":"女方雙親好像已經承認了兩人的關係<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-07T09:23:07.000Z","msg":"屌你老母 唔洗quot哂成段野呀嗎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"69bc272355f5f454c3386f84b9a316005369e8b1","tid":656321,"uid":62815,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-05-07T09:24:14.000Z","msg":"仲幫佢賣廣告<br />\n千人斬都嚟喇<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"98373e6928e4555381bbdf2f2b7cb11520b16770","tid":656321,"uid":23445,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-05-07T09:30:52.000Z","msg":"<blockquote>仲幫佢賣廣告<br />\n千人斬都嚟喇<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n見到都唔開胃"},{"pid":"e67f2e2bde367b644b8ed10c75d1d13bbd5475e7","tid":656321,"uid":157894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-07T09:33:04.000Z","msg":"有幾大先?"},{"pid":"335fe2d6ae6ca65605e65b038326489a1df4a575","tid":656321,"uid":3189,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-05-07T09:33:45.000Z","msg":"我都想試下佢碌巨根<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"3f40ae2cf1da4ed734598f0cad6a046926ded54d","tid":656321,"uid":98099,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-05-07T09:38:33.000Z","msg":"人棍usb<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n啲女一定係出於好奇同憐憫跟住就<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img 