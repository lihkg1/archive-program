d1f18da585a8717a04f1787b06d497dcc1a8e58","tid":1234471,"uid":9526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T02:47:43.000Z","msg":"推"},{"pid":"ca5d578876a578733ac4e02751cfeb585b33e860","tid":1234471,"uid":9526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T02:51:09.000Z","msg":"推"},{"pid":"a1ed2b16341dc135a60f4e5b919e17a3835d63c5","tid":1234471,"uid":9526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T02:54:33.000Z","msg":"推呀"},{"pid":"525af1d454bd9a9e10d43533d1710d60d4fd5c66","tid":1234471,"uid":9526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T03:07:02.000Z","msg":"推推推"},{"pid":"8fda77af960142f2139183091d9cef809b351ca1","tid":1234471,"uid":51361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T03:11:29.000Z","msg":"Let&rsquo;s think!!"},{"pid":"acebff3a3451eb761e6f711e27c16595ac8879c7","tid":1234471,"uid":9526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T03:20:28.000Z","msg":"大家可以轉貼一啲似事而非既POST係呢度<br />\n大家一齊分析下<br />\n<br />\n例如到今時今日都仲屌緊達哥唔表態呢啲咁撚ON9既POST<br />\n達狗只係一個普通人 佢反唔反應支唔支持關你撚事咩香港人"},{"pid":"8f44f8763a862df8d7eedd955c460e936d1f45a6","tid":1234471,"uid":9526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T03:34:27.000Z","msg":"仲有例子就係依家出面和理非同勇武爭吵<br />\n我想講其實尋日出到黎已經大和解左<br />\n大部份仲係度互相爭議既POST 都有機會係鬼黎 亦好大機會係<br />\n我唔敢講100%呢類POST都係鬼 但至少有一半以上係<br />\n然後另一半係比佢地講多兩句就出黎開POST<br />\n<br />\n大家最好睇番開呢類POST / 引發呢啲討論既人 佢之前開過咩POST 善用起底"},{"pid":"ad7293a10d2fc64f0893d0ec798b5f994a7d4da2","tid":1234471,"uid":172627,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T03:51:52.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"cdce7d33a645d1930bce2fc85a17e9ebc770f882","tid":1234471,"uid":9526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T04:09:29.000Z","msg":"推"},{"pid":"e4a386fab9ac72c283b7c5e3ca37510a651196e6","tid":1234471,"uid":9526,"like":0,"dislike":0,"s