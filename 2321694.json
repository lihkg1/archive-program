own.gif\" class=\"hkgmoji\" />"},{"pid":"e0c94d206efb54fc68395a0f3e00a4e20a1524f2","tid":2321694,"uid":323234,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-11T17:50:36.000Z","msg":"控制用腹式呼吸  瞓定一個姿勢唔好郁 會易瞓得着d"},{"pid":"6be455056920b20c4c4cf15e7a51f85b5f875d9a","tid":2321694,"uid":62755,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-11T17:52:47.000Z","msg":"工作/讀書"},{"pid":"db3ef128d1fe0e0c5765ca5d35fb87410205c587","tid":2321694,"uid":221401,"like":0,"dislike":0,"score":0,"quote":{"pid":"1110d455409274077fdbff5cf262e599a37c34f4","tid":2321694,"uid":367811,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-12-11T17:26:20.000Z","msg":"<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-12-11T17:54:11.000Z","msg":"上年可能有情緒困擾嗰陣時晚晚都喊，結果瞓得好好<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n喊完個人易啲訓。<br />\n但今年就冇乜情緒起伏，唔會話好開心，但都冇話好negative<img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /> 即係如果開心個感覺係10分，今年都維持到56分的"},{"pid":"13dd04a6f272061ac79a680e43528525b1a9361c","tid":2321694,"uid":221401,"like":0,"dislike":0,"score":0,"quote":{"pid":"a2798ee3e222b5db0f9af55ede992793d5a4ea1b","tid":2321694,"uid":18040,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2020-12-11T17:28:07.000Z","msg":"melatonin"},"citedBy":2,"replyTime":"2020-12-11T17:55:51.000Z","msg":"邊個牌子？同埋你平時食開幾多mg?"},{"pid":"885286a455adfdeea9555d004e7372df772c974b","tid":2321694,"uid":221401,"like":0,"dislike":0,"score":0,"quote":{"pid":"5bd7debbde357afc3d358cd9a60c828d09f9f91d","tid":2321694,"uid":58002,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-11T17:31:08.000Z","msg":"運動"},"citedBy":0,"replyTime":"2020-12-11T17:57:28.000Z","msg":"有做呀<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4738e0ec0d996bf3be6dcbd1a3634d648a905afb","tid":2321694,"uid":221401,"like":0,"dislike":0,"score":0,"quote":{"pid":"be27401af1c071296283a4e8e638b074e431e555","tid":2321694,"u