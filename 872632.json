pid":"2e8df0ac84768e60939e361d52b4f690ab2d8e60","tid":872632,"uid":8543,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-23T00:57:54.000Z","msg":"<a href=\"https://youtu.be/5qPne-5NsAM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F5qPne-5NsAM&d=HDdcVWKqnhaKed%2FWU9HMkDOU%2Fspzl0GStOx2So8CiJ8%3D&h=705c8193\" target=\"_blank\">https://youtu.be/5qPne-5NsAM</a><br />\n<br />\n<a href=\"https://www.hk01.com/%E5%8D%B3%E6%99%82%E5%A8%9B%E6%A8%82/248526/%E5%AB%81%E5%88%B0%E9%80%99%E4%B8%96%E7%95%8C%E9%82%8A%E7%AB%AF2-%E7%B5%95%E5%AF%86%E7%89%87%E6%AE%B5-%E9%A6%99%E6%B8%AF%E5%A4%A7%E5%8F%94%E4%BB%A5%E8%89%B2%E5%88%97%E6%90%B5%E5%88%9D%E6%88%80-%E7%9C%9F%E4%BF%82%E5%A5%BD%E9%9D%9A?utm_medium=Social&amp;utm_source=yt&amp;utm_campaign=mama\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E5%258D%25B3%25E6%2599%2582%25E5%25A8%259B%25E6%25A8%2582%2F248526%2F%25E5%25AB%2581%25E5%2588%25B0%25E9%2580%2599%25E4%25B8%2596%25E7%2595%258C%25E9%2582%258A%25E7%25AB%25AF2-%25E7%25B5%2595%25E5%25AF%2586%25E7%2589%2587%25E6%25AE%25B5-%25E9%25A6%2599%25E6%25B8%25AF%25E5%25A4%25A7%25E5%258F%2594%25E4%25BB%25A5%25E8%2589%25B2%25E5%2588%2597%25E6%2590%25B5%25E5%2588%259D%25E6%2588%2580-%25E7%259C%259F%25E4%25BF%2582%25E5%25A5%25BD%25E9%259D%259A%3Futm_medium%3DSocial%26utm_source%3Dyt%26utm_campaign%3Dmama&d=HDdcVWKqnhaKed%2FWU9HMkDOU%2Fspzl0GStOx2So8CiJ8%3D&h=350d32f5\" target=\"_blank\">https://www.hk01.com/%E5%8D%B3%E6%99%82%E5%A8%9B%E6%A8%82/248526/%E5%AB%81%E5%88%B0%E9%80%99%E4%B8%96%E7%95%8C%E9%82%8A%E7%AB%AF2-%E7%B5%95%E5%AF%86%E7%89%87%E6%AE%B5-%E9%A6%99%E6%B8%AF%E5%A4%A7%E5%8F%94%E4%BB%A5%E8%89%B2%E5%88%97%E6%90%B5%E5%88%9D%E6%88%80-%E7%9C%9F%E4%BF%82%E5%A5%BD%E9%9D%9A?utm_medium=Social&amp;utm_source=yt&amp;utm_campaign=mama</a><br />\n<br />\n雖然以色列男人優點多多，但其實港男一點也不輸蝕。《嫁到這世界邊端2》攝製隊在當地採訪期間，就發現有三位香港大叔為了另一半，搬到以色列生活，實行「娶到這世界邊端」！<br />\n<br />\n編導黃俊輝透露，攝製隊在以色列一間中餐廳遇到他們，分別是Tony哥、雞叔和Ming哥。問到以色列女人的吸引之處，Ming哥表示：「有一度好，就係唔洗聘金、唔要彩禮，更加唔要車唔要樓，呢樣嘢已經喺中國搵唔到。」他們更稱以色列女人很美，笑言：「無論係黑過炭甚至白過雪都有！」Tony哥透露當地人觀念很開放，<span style=\"color: red;\">無論你是哪個國家的人、做什麼職業，大家都很包容。而以色列女人更不會要求男人一定要有樓先嫁，總之感覺對就會在一起。<br />\n</span><br />\n當中Ming哥就稱自己在港36年，都未曾一嚐戀愛滋味，但來到以色列就十分受歡迎。他笑稱：「因為我夠吸引力，佢搵我。（香港男人好搶手？）都係唔係，緣份。（老婆係你初戀？）係呀！」而Tony哥就稱自己最喜愛以色列的生活：「生活冇咁急促，空氣清新而且住獨立屋又大。」他們更強調在以色列生活一點也不危險，很喜歡這個國家。"},"citedBy":1,"replyTime":"2018-10-23T09:40:35.000Z","msg":"娶到這世界的邊端<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-23T11:05:17.000Z","msg":"支持VIUTV開拍"},{"pid":"af070cd2a372c615dab0d43a32b11c6a444039c4","tid":872632,"uid":126769,"like":3,"dislike":0,"score":3,"quote":{"pid":"e7edcf733330fedab39da4ee2c25d3575cfaa16b","tid":872632,"uid":76747,"like":75,"dislike":6,"score":69,"quote":{"pid":"2cbfff780861cd837ed6d5e82b3a3595679a603d","tid":872632,"uid":216553,"like":182,"dislike":3,"score":179,"citedBy":7,"replyTime":"2018-10-23T07:57:26.000Z","msg":"香港男外國搵女 連登仔: <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n香港女外國搵男 連登仔: 臭雞<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-23T08:03:03.000Z","msg":"連登仔外國搵女:為港男出氣<br />\n港女食洋腸:貪錢臭G"},"citedBy":1,"replyTime":"2018-10-23T11:12:03.000Z","msg":"睇隔離po嫁到世界邊端就知啦<br />\n啲港男嬲撚到呢"},{"pid":"a34db91086f2aa9a9f9d351bb394e73741e265ca","tid":872632,"uid":93479,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2018-10-23T11:22:57.000Z","msg":"堅<br />\n<br />\n以色列真係求其入間餐廳，個侍應都係靚，仲要友善好笑容<br />\n<br />\n當下一刻，港女真係賤過泥"},{"pid":"d382cbea0dcfc05f481bbde8e4ff9048cf04fb08","tid":872632,"uid":57378,"like":0,"dislike":0,"score":0,"quote":{"pid":"2cbfff780861cd837ed6d5e82b3a3595679a603d","tid":872632,"uid":216553,"like":182,"dislike":3,"score":179,"citedBy":7,"replyTime":"2018-10-23T07:57:26.000Z","msg":"香港男外國搵女 連登仔: <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n香港女外國搵男 連登仔: 臭雞<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-