{"tid":2198261,"cid":5,"subCid":10,"title":"聖嘉勒、羅陳楚思兩中學　被指強制學生唱《義勇軍進行曲》交功課","createTime":"2020-09-11T08:27:56.000Z","updateTime":"2020-09-12T09:57:13.000Z","uid":39464,"like":3,"dislike":23,"uniUserReply":22,"replies":[{"pid":"e28c76711218bc0c56a89d44ab086143444cede8","tid":2198261,"uid":39464,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-11T08:27:56.000Z","msg":"最少兩間中學強制學生在音樂科誦唱國歌，作為科目功課。中西區聖嘉勒女書院、位於九龍灣的仁濟醫院羅陳楚思中學，前者要求中二、三學生唱國歌作為功課，後者則要求中一至中四級學生唱國歌交功課，有兩校學生表示，學校以往從不設類似功課，音樂課多數可以自由選曲，或者不設功課，認為校方有意強行灌輸愛國思想，要求學生「尊重國歌」。<br />\n<br />\n《立場》已向聖嘉勒女書院、仁濟醫院羅陳楚思中學查詢，目前等候回覆。<br />\n<br />\n<a href=\"https://www.thestandnews.com/politics/%E6%84%9B%E5%9C%8B%E6%95%99%E8%82%B2-%E8%81%96%E5%98%89%E5%8B%92-%E7%BE%85%E9%99%B3%E6%A5%9A%E6%80%9D%E5%85%A9%E4%B8%AD%E5%AD%B8-%E8%A2%AB%E6%8C%87%E5%BC%B7%E5%88%B6%E5%AD%B8%E7%94%9F%E5%94%B1-%E7%BE%A9%E5%8B%87%E8%BB%8D%E9%80%B2%E8%A1%8C%E6%9B%B2-%E4%BA%A4%E5%8A%9F%E8%AA%B2/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E6%2584%259B%25E5%259C%258B%25E6%2595%2599%25E8%2582%25B2-%25E8%2581%2596%25E5%2598%2589%25E5%258B%2592-%25E7%25BE%2585%25E9%2599%25B3%25E6%25A5%259A%25E6%2580%259D%25E5%2585%25A9%25E4%25B8%25AD%25E5%25AD%25B8-%25E8%25A2%25AB%25E6%258C%2587%25E5%25BC%25B7%25E5%2588%25B6%25E5%25AD%25B8%25E7%2594%259F%25E5%2594%25B1-%25E7%25BE%25A9%25E5%258B%2587%25E8%25BB%258D%25E9%2580%25B2%25E8%25A1%258C%25E6%259B%25B2-%25E4%25BA%25A4%25E5%258A%259F%25E8%25AA%25B2%2F&d=lPOaXpfFeUboYNX3auI3fj%2BdFj26OgxneTHruUJDv9o%3D&h=a26c2e3d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E6%2584%259B%25E5%259C%258B%25E6%2595%2599%25E8%2582%25B2-%25E8%2581%2596%25E5%2598%2589%25E5%258B%2592-%25E7%25BE%2585%25E9%2599%25B3%25E6%25A5%259A%25E6%2580%259D%25E5%2585%25A9%25E4%25B8%25AD%25E5%25AD%25B8-%25E8%25A2%25AB%25E6%258C%2587%25E5%25BC%25B7%25E5%2588%25B6%25E5%25AD%25B8%25E7%2594%259F%25E5%2594%25B1-%25E7%25BE%25A9%25E5%258B%2587%25E8%25BB%258D%