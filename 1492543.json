:"2019-08-21T01:28:08.000Z","msg":"3"},{"pid":"e65b1eeca77e457b275f6b6869eb50bf42ab4186","tid":1492543,"uid":252840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:28:43.000Z","msg":"2"},{"pid":"2f20e175981837d3a5aa198018d3da02cb4a687a","tid":1492543,"uid":252840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:29:52.000Z","msg":"1"},{"pid":"b87d19f6c8715815aeb8b8906d20de4064e58ebb","tid":1492543,"uid":252840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:30:28.000Z","msg":"請幫推"},{"pid":"9513070c2ca3dc750bc7f502d2441aa3ddbea4b0","tid":1492543,"uid":10503,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:30:34.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />值得尊重"},{"pid":"81760bda613674dd03592f488119aa5441d47caf","tid":1492543,"uid":252840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:32:02.000Z","msg":"請幫推"},{"pid":"0d72d50f8dad540e43e0340343cda98650513b9f","tid":1492543,"uid":5822,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:34:51.000Z","msg":"G持<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /> 我係中國人"},{"pid":"f0bbf5929aadd7741540cfe2b28479425b14b9b9","tid":1492543,"uid":17331,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:36:44.000Z","msg":"良知"},{"pid":"f096fa706a283a90b269ae5533f4b7f8a10111ab","tid":1492543,"uid":90743,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-08-21T01:37:00.000Z","msg":"見到有人讚佢 之後有個留言話:<br />\n我用逻辑去想，他没有深入警方阵营，不够了解正方态度，但是与反方聊了挺多，然后说出了&rdquo;打枪的警察,拿棍子的白衣人&rdquo;这种话，我不能说我的想法中立，中国是我的国家我不可能中立，但他的确不够立场中立，看他的视频指向性过于明显了。<br />\n好多大陸人根本就on99 岩自己聽既野先叫中立 唔岩聽既你講得幾好幾合理都無用 所以我唔認為向大陸文宣係有用"},{"pid":"3a6d56f6ca4a0175a3a33f99cba14a3e3d2c1ee0","tid":1492543,"uid":209468,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:37:56.000Z","msg":"我只是希望佢返到大陸安全無事已經足夠<br />\n<br />\n我諗最低限度既罰可能係將來限制出境 沒收護照"},{"pid":"ef57e045e97c3283b779f35974f55bfe90906fdd","tid":1492543,"uid":50745,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T01:38:00.000Z","msg":"呢個名, 我會記一世<br />\n希望有朝可以拜會佢"}]}