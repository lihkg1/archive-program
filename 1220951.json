=\"/assets/faces/lm2/dislike.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-14T06:10:53.000Z","msg":"憑<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />打錯"},{"pid":"99971bd075d62d96a06efbe630203aac6de45463","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec670f5f28373c7406c6041d60247dc781e00408","tid":1220951,"uid":61357,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-06-14T06:10:24.000Z","msg":"人係馮良知 馮良心判斷做人<br />\n馮命令做人 同畜生有咩分別<img src=\"/assets/faces/lm2/dislike.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-14T06:11:32.000Z","msg":"切勿盲目跟從"},{"pid":"b888c20d3a23b896e27b96ccaf096ebde7a771f4","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"quote":{"pid":"25fcbe4cec8c1465a6bf2ebde6405d73b0a3b050","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"quote":{"pid":"59b3828a0d4402f7eedd953234c32ecbb72fc470","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"quote":{"pid":"0f0248eb950538ba3ce7cd2cd47055bad44d7ad6","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-14T06:10:11.000Z","msg":"推"},"citedBy":1,"replyTime":"2019-06-14T06:10:23.000Z","msg":"推"},"citedBy":1,"replyTime":"2019-06-14T06:10:33.000Z","msg":"推"},"citedBy":1,"replyTime":"2019-06-14T06:12:10.000Z","msg":"推"},{"pid":"6d680a603bec3ad7abd5088eed39d490a0486855","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"quote":{"pid":"b888c20d3a23b896e27b96ccaf096ebde7a771f4","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"quote":{"pid":"25fcbe4cec8c1465a6bf2ebde6405d73b0a3b050","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"quote":{"pid":"59b3828a0d4402f7eedd953234c32ecbb72fc470","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-14T06:10:23.000Z","msg":"推"},"citedBy":1,"replyTime":"2019-06-14T06:10:33.000Z","msg":"推"},"citedBy":1,"replyTime":"2019-06-14T06:12:10.000Z","msg":"推"},"citedBy":1,"replyTime":"2019-06-14T06:12:20.000Z","msg":"推"},{"pid":"11da08eb9452e33bb0dd1b38da9cd373c34cd314","tid":1220951,"uid":228915,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-14T06:12:48.000Z","msg":"柏林圍牆被推倒前的一個冬夜，剛滿20歲的克利斯和他的朋友高定，一起偷偷爬上了柏林圍牆，準備逃往西德。幾聲槍響，一顆子彈由克利斯的前胸穿入，高定的腳踝也被另一顆子彈擊中。<br />\n<br />\n克利斯很快就斷了氣。射殺他的東德士兵，叫英格・亨里奇。英格・亨里奇也沒想到，柏林圍牆被推倒之後，自己最終會站在法庭上，因為殺人罪而接受審判。<br />\n<br />\n柏林法庭最終的判決是：判處開槍射殺克利斯的士兵英格・亨里奇3年半徒刑，不予假釋。英格・亨里奇的律師辯稱「他們僅僅是執行命令的人，根本沒有選擇的權利，罪不在己」。<br />\n<br />\n法官當庭指出：「東德的命令要你殺人，可是你明明知道這些逃亡者是無辜的，明知無辜而殺他，就是有罪。作為警察，不執行上級命令是有罪的，但是打不準是無罪的。作為一個心智健全的人，此時此刻，你有把槍口抬高一公分的選擇，這是你應主動承擔的良心義務。」"},{"pid":"73d790fa9a1b7876985262f90fcd7949c594c81a","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d680a603bec3ad7abd5088eed39d490a0486855","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"quote":{"pid":"b888c20d3a23b896e27b96ccaf096ebde7a771f4","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"quote":{"pid":"25fcbe4cec8c1465a6bf2ebde6405d73b0a3b050","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-14T06:10:33.000Z","msg":"推"},"citedBy":1,"replyTime":"2019-06-14T06:12:10.000Z","msg":"推"},"citedBy":1,"replyTime":"2019-06-14T06:12:20.000Z","msg":"推"},"citedBy":0,"replyTime":"2019-06-14T06:13:33.000Z","msg":"推"},{"pid":"47571f4647c592650e49bb6db451b9e24789eb0d","tid":1220951,"uid":261044,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T06:15:27.000Z","msg":"紐倫堡原則<br />\n原則四規定：「依據政府或其上級命令行事的人，假如他能夠進行道德選擇的話，不能免除其國際法上的責任。」<br />\n這一原則也可闡釋為：「『我只是服從上級命令』並不是正當理由。」"},{"pid":"806f8b353a7eaf62e2691b743c480aae6573ed16","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T06:17:38.000Z","msg":"推"},{"pid":"296e5bbed1657b7ca7b6ea3c855783d28c746fc6","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T06:17:53.000Z","msg":"推"},{"pid":"f333ab52dc825efdb1ba74824bb5911ffb057a6e","tid":1220951,"uid":157015,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T06:18:38.000Z","msg":"推"}]}