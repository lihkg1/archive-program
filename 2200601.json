src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"1af6c5a4cd3cdded8a6f69b7bf4b0f53869cd9e3","tid":2200601,"uid":25571,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-13T12:49:20.000Z","msg":"推<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"270866da614c858c2aea1fc99fb31ca2f9d23657","tid":2200601,"uid":322642,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9744fb5d9a88d482f4e0ecde4c5c4b532f4d351","tid":2200601,"uid":300592,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-13T10:09:08.000Z","msg":"蒙古人︰強"},"citedBy":0,"replyTime":"2020-09-13T12:57:17.000Z","msg":"成吉思汗後裔<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"cea30c9393b884cf1a265cd5ada7d9359896c6d2","tid":2200601,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-14T17:58:55.000Z","msg":"Push"},{"pid":"983116bbb8ce500a2ecd641672a2e2f73313a8d5","tid":2200601,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-14T18:00:41.000Z","msg":"Push"},{"pid":"da751c7862aa122f10339b506c427e0df3bbb203","tid":2200601,"uid":86699,"like":0,"dislike":0,"score":0,"quote":{"pid":"5375689fc6de2950f28f631820940c79c664fb77","tid":2200601,"uid":322642,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-13T05:47:21.000Z","msg":"<span class=\"violet\">為抗議中國取消蒙古語教學政策，內蒙嘅蒙古人繼續非暴力公民抗命。為咗打壓罷課運動，當局開始禁錮學生強逼佢哋上堂，有蒙古學生不惜爬3米鐵絲網參與罷課。</span>9月9號喺錫林郭勒盟就有超過30名蒙古中二、中三學生逃離正藍旗中學。<br />\n<br />\n根據父母同目擊者嘅記錄，<span class=\"violet\">呢批蒙古學生都係政府官員、中共黨員同老師嘅小朋友，</span>正因為咁先俾人強行捉入學校。經過當地警察、學校同家長全面搜查後，先喺班納首府附近嘅一座山發現佢哋。<span class=\"violet\">有位家長感歎話 :「佢哋連三米高嘅鐵絲網都諗辦法爬上去走甩。學生有自己嘅思想，圍欄係唔會令佢哋放棄抵抗！」</span><br />\n<br />\n<img src=\"https://i2.wp.com/gongjyuhok.hk/wp-content/uploads/2020/09/%E6%9C%AA%E5%91%BD%E5%90%8D-1-3.png?resize=1024%2C555&amp;ssl=1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi2.wp.com%2Fgongjyuhok.hk%2Fwp-content%2Fuploads%2F2020%2F09%2F%25E6%259C%25AA%25E5%2591%25BD%25E5%2590%258D-1-3.png%3Fresize%3D1024%252C555%26ssl%3D1&h=1d3c9975&s={SIZE}\" /><br />\n<br />\n另一個家長喺錄音話：<span class=\"violet\">「有啲被強迫返學嘅小一學生唔肯同父母傾偈，由朝喊到晚，表現得好憂鬱。唔該教育部同學校一定要停止虐待呢啲年輕嘅心靈同諗法，佢哋受緊嘅心理創傷會困擾佢哋成世！」</span><br />\n<br />\n<span class=\"violet\">當局「停職、解僱、中止福利」嘅手段威脅唔到蒙古公務員，但都繼續一次又一次咁通告解僱嘅蒙古公務員同老師嘅名單，只係因為佢哋唔肯送小朋友去返學。</span>同來進行恐嚇無效，但當局仍在發布官方通告，一次又一次地公佈被解僱的蒙古官員，公務員和教師的姓名和頭銜。因為他們拒絕把孩子送回學校。<br />\n<br />\n為咗盡力招收學生，內蒙政府臨時請咗大批社工，說服父母將孩子送回學校。因為恐嚇已經冇用，有啲官員仲拎啲禮物同少少錢出嚟氹啲家長送小朋友返學。有蒙古家長就一路拍片一路鬧呢班社工「離開我屋企，唔好再過來！我哋係唔會收。」佢拒絕咗社工意圖送畀佢嘅所有嘢。另一個家長拍片話：「佢哋收緊簽名，又送番梘同洗衣粉，諗住可以搵多啲人簽。」<br />\n<br />\n仲有啲片段話蒙古人嘅簽名俾人剪剪貼貼，因為當地官員要呃上面話新嘅教育政策都有蒙古人支持。<span class=\"violet\">「你睇到我哋請願抗議新教育政策嘅簽名，居然會俾人剪貼做送去中央政府嘅文件，變成蒙古人支持新『雙語教育』嘅證據！」有啲學校入面已經俾人清走蒙古語嘅指示牌同標語牌。</span>儘管蒙古語仍然係兩種官方語言之一，但蒙古語喺巴士嘅標誌被剷走，蒙古特色嘅路邊畫被刪除。<br />\n<br />\n<span class=\"violet\"><span class=\"x-large\">雖然當局用逮捕、拘留、監禁、停職、炒魷、將子女列入黑名單、削減社會福利甚至沒收財產嘅手段威脅蒙古人，但最近仍然有好多片證明蒙古學校仍然空無一人&mdash;&mdash;罷課依然繼續緊。</span></span><br />\n<br />\n<span class=\"red\"><span class=\"x-large\">世界各地嘅蒙古人仲更加團結起來捍衛母語。兩日之內，超過50,000人喺白宮簽署「We People」請願書，敦促特朗普政府更加關注呢一場文化清洗</span></span><br />\n<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<span class=\"xx-large\"><span class=\"red\">立即聯署</span></span> <span class=\"x-large\">仲差11000人</span><br />\n<a href=\"https://petitions.whitehouse.gov/petition/stop-ccps-cultural-genocide-inner-mongolia\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fstop-ccps-cultural-genocide-inner-mongolia&d=O8bnHDCsQiwN1SoPxP513UzlOXIvf7DEkQzrkg%2FJo1w%3D&h=cc9eff92\" data-auto-link target=\"_blank\">https://petitions.whitehouse.gov/petition/stop-ccps-cultural-genocide-inner-mongolia</a><br />\n<br />\n(source)<br />\n<a href=\"https://gongjyuhok.hk/articles/4530\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgongjyuhok.hk%2Farticles%2F4530&d=O8bnHDCsQiwN1SoPxP513UzlOXIvf7DEkQzrkg%2FJo1w%3D&h=6c80409d\" data-auto-link target=\"_blank\">https://gongjyuhok.hk/articles/4530</a>"},"citedBy":1,"replyTime":"2020-09-14T18:10:25.000Z","msg":"Respect"}],"pinned":{"pid":"d3fba64e5892d9ad2039dc121b84795182e3d81c","tid":2200601,"uid":322642,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-13T12:05:52.000Z","msg":"聯署未達標㗎<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"}}