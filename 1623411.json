i\" />"},{"pid":"7dcc370a554e478a1b90373a915f642331c9d1c1","tid":1623411,"uid":185935,"like":0,"dislike":0,"score":0,"quote":{"pid":"8b82b06738e20df65c50a2c8512688599707c06a","tid":1623411,"uid":237528,"like":0,"dislike":0,"score":0,"quote":{"pid":"775632f3d5c9da3a44aee455e769ed6dd101107d","tid":1623411,"uid":201027,"like":1,"dislike":3,"score":-2,"citedBy":3,"replyTime":"2019-10-04T21:12:57.000Z","msg":"加泰喺國際上冇香港咁重要"},"citedBy":1,"replyTime":"2019-10-05T04:30:07.000Z","msg":"台灣都無得獨立<br />\n台灣個軍事地理地置重要過香港啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-05T04:56:05.000Z","msg":"的確<br />\n台灣係個好例子<br />\n<br />\n因為打仗留落嚟嘅關係而到宜家有總統，但其實國際上仲未完全被承認就知咩事。<br />\n<br />\n<br />\n宜家就講臨時政府真係好易令自己斷後路<br />\n<br />\n<br />\n真係要加強同美英關係先有希望"},{"pid":"169ac009162f2556e41bc94fdf3c02f8ea855612","tid":1623411,"uid":185935,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T05:16:08.000Z","msg":"推"}]}