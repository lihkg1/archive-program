ji\" />"},{"pid":"7e47b3877557bd278821540517d8035f0b36625e","tid":907733,"uid":20134,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-19T05:04:50.000Z","msg":"樓豬平時係咪手腳好冰凍？"},{"pid":"928f2c678c8541b48869dec6f9ad6f435d636e8c","tid":907733,"uid":30172,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-19T05:06:36.000Z","msg":"我都有一樣既經歷，大概一年一次。<br />\n頭好痛，無啦啦好痛，真係痛到嘔。但嘔完就無事"},{"pid":"a31b4459c35f6916c0a3790a18082487728209ac","tid":907733,"uid":201367,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-19T05:07:08.000Z","msg":"親戚係咁 痛到嘔 發現有膠質瘤 無得醫既 夾硬做手術 拖多一年命就無左 先廿三歲"},{"pid":"bdf945dcee73529ee462fbffeb7e88d4b94438cb","tid":907733,"uid":61271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-19T05:07:32.000Z","msg":"去急症室就得"},{"pid":"dd70580641efa803b64fbd47a2aae7af394484ac","tid":907733,"uid":1550,"like":0,"dislike":0,"score":0,"quote":{"pid":"42ddf712a1b0b937d793b9bd8fbe557add4a4879","tid":907733,"uid":122116,"like":0,"dislike":0,"score":0,"quote":{"pid":"111a1661416f47afea66bf31901d7bd3c3a5a454","tid":907733,"uid":1550,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-11-19T04:59:03.000Z","msg":"頭痛到嘔都唔入急症<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-19T05:02:16.000Z","msg":"以為只係食錯野<br />\n依家搵緊醫院去check下了<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-19T05:09:12.000Z","msg":"窮撚就是但搵間急症室睇左先<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d5b256e52d2e531e14aabca424f72a69db308626","tid":907733,"uid":18635,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-19T05:12:04.000Z","msg":"去急症室講你呢個情況 <br />\n正常會拿拿臨幫你照左CT先既<br />\n到時真係有野會再叫你照MRI 先搵私家照啦"},{"pid":"20ce89f63c9a2fec668c73ea9cccb7b1ccab8428","tid":907733,"uid":209274,"like":0,"dislike":0,"score":0,"quote":{"pid":"928f2c678c8541b48869dec6f9ad6f435d636e8c","tid":907733,"uid":30172,"like":0,"dislike":0,"score":0,"citedBy":