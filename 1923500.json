d":1923500,"uid":256393,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-13T06:16:18.000Z","msg":"報狗"},{"pid":"b1911560d8b15a9ec68839bbf33c1ca5aaaa82cc","tid":1923500,"uid":14075,"like":0,"dislike":0,"score":0,"quote":{"pid":"d6d4e926d5172027f578e817ce34bb2faf3c10d7","tid":1923500,"uid":103325,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-13T06:15:20.000Z","msg":"甩咗翼呢飛蟻？"},"citedBy":0,"replyTime":"2020-03-13T06:16:26.000Z","msg":"有開叉尾喎"},{"pid":"9c629a0d7fd188b579262508987a3bb44d8d0e23","tid":1923500,"uid":208598,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-13T06:35:54.000Z","msg":"<a href=\"https://zh.m.wikipedia.org/zh-hant/蠼螋\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.m.wikipedia.org%2Fzh-hant%2F%E8%A0%BC%E8%9E%8B&d=Tw47yvsTxhso6q9O6ySnCSq0XD4M5CHb8byFtBYuAsM%3D&h=bd599ab8\" data-auto-link target=\"_blank\">https://zh.m.wikipedia.org/zh-hant/蠼螋</a><br />\n<br />\n蠼螋與人類關係並不是十分密切，偶爾會危害花卉、果品等等，有的種類是<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">蝙蝠和鼠</span></span></strong>的體外寄生者<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />。 它們一般喜歡夜間活動，白天常隱藏在土壤、石塊、枯枝和垃圾下。 蠼螋喜好狹窄的空間，有人相信它們會爬入人耳中，對人體造成傷害，但其實並不是這樣的。"},{"pid":"672489f0b2ebacf4e3d42cfea4392740fc6c57f8","tid":1923500,"uid":333570,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-14T10:52:29.000Z","msg":"呢間嘢好那渣，好耐之前尖沙嘴食過一次啲食物入面有頭髮後唔敢再幫襯 <img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />"}]}