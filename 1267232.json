52ed7ceffc885d64b7a21b168c59c689e5","tid":1267232,"uid":43197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-29T19:22:23.000Z","msg":"加油<br />\n攰就休息一下<br />\n試下抽離 <br />\n唔好上連登 Facebook 一排<br />\n睇下有無改善"},{"pid":"67c74fbe9a9ffe9731e50d8b0548f173073d04a4","tid":1267232,"uid":131122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-29T19:23:59.000Z","msg":"頂住！！！我愛你！！！！！"},{"pid":"c44e3b4650115f60093043d571b78249deeb68fe","tid":1267232,"uid":83602,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-29T19:30:40.000Z","msg":"我男人老狗見到佢兩個最終行到呢一步都流晒馬尿 你地唔好再咁<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"db00f84f4d484dbbc4f4ff121dea4cb7c511f728","tid":1267232,"uid":181703,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-29T19:35:51.000Z","msg":"我地仲未放棄 你唔好掉低我地 陪我地一齊成功好冇?"},{"pid":"b89ddb20a61add7837f7b30fc65aaaf881d639b3","tid":1267232,"uid":264696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-29T19:38:55.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"ab2a2dad3ad3f56a748ae295868bd4ddca6f286a","tid":1267232,"uid":82725,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-29T19:51:26.000Z","msg":"對唔住，我知我唔應該呢個時候開呢啲post。香港人，加油。<br />\n<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" />"},{"pid":"7c9ebb699d3e6af5dbdbbc42a99c33c860f4560a","tid":1267232,"uid":185048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-29T19:55:58.000Z","msg":"加油 一齊面對"},{"pid":"77ee953fe4f5e125705e29dabdf6de5bbe618d61","tid":1267232,"uid":232157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-29T20:06:55.000Z","msg":"唔好放棄住！依家仲未算輸，呢場仗一齊頂住打落去！我地仲好需要你嘅力量！"}]}