t1&quot;).Cells(i + 1, 3) '第一款生果\n    Else\n        FruitName = FruitName &amp; &quot;, &quot; &amp; Worksheets(&quot;Sheet1&quot;).Cells(i + 1, 3) '由第二款生果開始，前面要有comma同space\n    End If\n        \nNext i\n\nWorksheets(&quot;Sheet1&quot;).Cells(2, 5) = &quot;Fruits: &quot; &amp; FruitName '在E2顯示結果\n\nEnd Sub\n\n</code></pre>"},"citedBy":1,"replyTime":"2018-10-12T07:29:29.000Z","msg":"蠢在你點知去到C10完？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n如果一定C2開始用.End(xldown)啦<br />\n同埋放入個array，再while loop個array直到empty就停"},{"pid":"792b1485bd1948e19b972b39c4173d7303e975cf","tid":857193,"uid":199016,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-12T09:25:48.000Z","msg":"此回覆已被刪除"}]}