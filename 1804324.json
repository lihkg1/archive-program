c2e3266bcee38c2e7e74fc","tid":1804324,"uid":48631,"like":10,"dislike":3,"score":7,"citedBy":2,"replyTime":"2019-12-31T02:19:02.000Z","msg":"好滾動，睇到咸左=.=<br />\nBtw牙進邊撚到進"},"citedBy":3,"replyTime":"2019-12-31T02:25:50.000Z","msg":"毅進"},"citedBy":0,"replyTime":"2019-12-31T02:29:25.000Z","msg":"駁唔到🤣"},{"pid":"d595adaa10456362b41e5f66a63cad4df6c33cc5","tid":1804324,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-31T02:30:00.000Z","msg":"明報."},{"pid":"f9ad32ec42ff7d7b314b3b01612ebb258b918488","tid":1804324,"uid":19552,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-12-31T02:31:01.000Z","msg":"明報而家同大公文匯一樣樣 日日係度虛構人物"},{"pid":"a793cbdfb29fe3d6428165d8272a87610e8f74d6","tid":1804324,"uid":44358,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-31T02:32:59.000Z","msg":"哈哈哈<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e9cbe9e06a7a20c37110b7bb8d8d413e010d3f1c","tid":1804324,"uid":55256,"like":7,"dislike":1,"score":6,"citedBy":1,"replyTime":"2019-12-31T02:34:12.000Z","msg":"28歲公務員阿毅<br />\n<br />\n「腥風血雨，社會太多流血事件，不只是示威者，我覺得是『警察』問題，他們挑起很多衝突。若果純粹說示威者有什麼手法做得不好，我覺得可以用理性和平方法講出來，不要說示威者不聽，其實是有聽的。說到修例風波，中間已有很多不同和平示威，並不是有些人說完全不和平，卻仍然用這樣暴力的方法濫權，我覺得『唔係咁嘅』（不是太正確）。<br />\n<br />\n我相信示威者是有人做得不好，我同意的，但我不覺得這是一個藉口，令其他一般執法人員可以繼續去做錯，因為別人做得不正確，我們不應該以暴易暴，至少要堅守自己當日學堂的信念：要維持社會的法治而出來，而不是為破壞法治而出來。」"},{"pid":"fed002826c6f6463475ea91f389919548c801620","tid":1804324,"uid":293543,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-12-31T02:35:21.000Z","msg":"係咪即係要打去1823呀，on9"},{"pid":"832c26784bcf63eff691fab2b0fd208f16e23b66","tid":1804324,"uid":335434,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2019-12-31T02:38:02.000Z","msg":"好多狗依家都鍾意用「公務員」黎稱呼自已<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"6fff36680d811ef11bf7af35cd98348f2ca798c7","tid":1804324,"uid":158888,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-12-31T02:40:58.000Z","msg":"屌俾錯正皮<br />\n依條乜野公務員呀<br />\n而家唔係有多定少黑警做錯<br />\n而係佢地凌駕咗法律<br />\n即係做錯野無法律制裁<br />\n攪到咁政棍同黑警都要負責"},{"pid":"176bb998878d8bbe3ca14f1f70c0461ed57f5575","tid":1804324,"uid":212168,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2019-12-31T02:48:28.000Z","msg":"公墓園  即係狗啦屌你老母<img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" /><br />\n黑警死全家啊"},{"pid":"a17d30b55ab326ae8858d21f497594933707b5b4","tid":1804324,"uid":156579,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-12-31T02:48:41.000Z","msg":"要揾支持政府既公務員實揾到嫁<br />\n最易揾30000隻狗<br />\n加大量藍腦弱智既紀錄部隊"},{"pid":"8b159871de20b058d7da578f90bf00184f0a3831","tid":1804324,"uid":301820,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-12-31T02:51:46.000Z","msg":"邏輯謬誤，<br />\n政府會聽會改，但要強行落實<span style=\"font-size: x-small;\">o</span><br />\n暴力解決不到問題，而政府想和平解決問題，<br />\n派防暴打柒人，咁樣叫和平解決問題？<br />\n<br />\n被人打唔還手，而法律偏幫施虐者，<br />\n次撚次係個別事件，沒辦法沒關係，<br />\n再叫人要理性討論，容忍制度暴力、施虐者暴力，<br />\n政府需要時間去做野，真係會改架，一定會架，<br />\n一講講撚左十幾年<img src=\"/assets/faces/pigxm/mock.gif\" class=\"hkgmoji\" /><br />\n如果你還手就屌柒你破壞法治<img src=\"/assets/faces/pigxm/snowhat.gif\" class=\"hkgmoji\" />"},{"pid":"6cf27fd4e4fff105ab2f56ef518a9595d50ae765","tid":1804324,"uid":158270,"like":1,"dislike":0,"score":1,"quote":{"pid":"77dba40ede56a315e50a641f2e2abbfcb4a4ecc3","tid":1804324,"uid":137440,"like":28,"dislike":0,"score":28,"citedBy":2,"replyTime":"2019-12-31T02:16:32.000Z","msg":"<img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" /><br />\n問題係我哋唔係要你修改<br />\n我哋係唔想要<br />\n<br />\n正如我哋唔想食屎<br />\n無論你舊屎改到幾香幾臭<br />\n我哋唔想食就係唔想食"},"citedBy":0,"replyTime":"2019-12-31T02:56:37.000Z","msg":"形式上嘅讓步唔係實際讓步嚟"},{"pid":"1bb9bc0de8b392dfe066e009432e1bec3645a624","tid":1804324,"uid":100273,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-12-31T02:59:37.000Z","msg":"修例係有改，咪幫商人囉，大劉一開始自己食到應就出面屌，政府咪聽囉，之係改到佢單案無事，咁就靜番唔出聲<br />\n法治社會？唔做逃犯天堂？大劉表示一早已經係啦，大富豪犯左法照係香港嘆世界<br />\n<br />\n仲有乜野係聽？成日話有聽，唔係話耳膜受到聲波振動就係叫聽左民意，政府施政如果無反映到市民訴求ge核心，咁有聽同無聽有咩分別<br />\n反修例核心係對中共ge完全不信任，你改d引渡控罪根本同個核心無關，桂民海都係被人告撞死人啦，所以係個社會過半數人對中共不信任底下根本唔應該修例<br />\n呢d係政棍煽動？唔洗政棍，求其拎李波自由出入境呢單野已經無人會信支那共產黨<br />\n<br />\n公務員阿進，進？邊撚度進呀？半年啦，唔係表達意見呀，係抗戰，係施壓。"},{"pid":"84215c321ec02a4a3925e5a1f055e6729ba45cb8","tid":1804324,"uid":14449,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-12-31T03:00:34.000Z","msg":"最仆街係<br />\n香港最撚多係呢種撚屌"},{"pid":"c54d15405abea675e6dbf32107d393248626a830","tid":1804324,"uid":48234,"like":2,"dislike":0,"score":2,"quote":{"pid":"d3f52a03cbd9256dca304c9e758a0105364055dc","tid":1804324,"uid":305852,"like":8,"dislike":0,"score":8,"quote":{"pid":"2164cfe5d312e5ab17c2e3266bcee38c2e7e74fc","tid":1804324,"uid":48631,"like":10,"dislike":3,"score":7,"citedBy":2,"replyTime":"2019-12-31T02:19:02.000Z","msg":"好滾動，睇到咸左=.=<br />\nBtw牙進邊撚到進"},"citedBy":3,"replyTime":"2019-12-31T02:25:50.000Z","msg":"毅進"},"citedBy":0,"replyTime":"2019-12-31T03:01:53.000Z","msg":"屌<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"25c533df0d48163d42f50dff709484efe971d007","tid":1804324,"uid":25213,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-12-31T03:02:16.000Z","msg":"你叫我唔好強姦你，但係我已經修改左，已經唔內射，你仲係到激烈反抗，擺明係你既錯"},{"pid":"2e68775b8ada6ae484b8fe027f6b62ff5ae07f34","tid":1804324,"uid":5649,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-12-31T03:03:12.000Z","msg":"公務員=警犬<br />\n阿進=毅進"},{"pid":"9c862a14da311dc895cab8c7d736bcf10a4ba451","tid":1804324,"uid":95181,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-31T03:03:23.000Z","msg":"德國聯署：要求德國減少依賴中国<br />\n<br />\n1月1日截止，尚欠25,000個簽名，要儲齊5萬簽名！！<br />\n<a href=\"https://epetitionen.bundestag.de/petitionen/_2019/_09/_01/Petition_98731.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fepetitionen.bundestag.de%2Fpetitionen%2F_2019%2F_09%2F_01%2FPetition_98731.html&d=BC5i8YeQzBb8hGTgU6tpJv%2FZYLwdGiEzwb2OZuYF8yg%3D&h=d8a0bad1\" data-auto-link ta