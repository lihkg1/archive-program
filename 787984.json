7984,"uid":109984,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-21T07:06:06.000Z","msg":"不如睇戲"},{"pid":"2312482abc3ec44a8ff391b6e2f2b38c9ffc31ec","tid":787984,"uid":82482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-21T07:11:40.000Z","msg":"褲穿腳痕  留浪到街角"},{"pid":"6025285df88928195649f6055571b43914f04679","tid":787984,"uid":60109,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-21T07:12:48.000Z","msg":"細個"},{"pid":"d7753a55ac62f0fed18e5a245347037e111d30e2","tid":787984,"uid":60109,"like":0,"dislike":0,"score":0,"quote":{"pid":"b08e2f549cf31ee85a4c51fda4ab0650fbea833d","tid":787984,"uid":109984,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-21T07:06:06.000Z","msg":"不如睇戲"},"citedBy":0,"replyTime":"2018-08-21T07:13:38.000Z","msg":"你咁驚悶"},{"pid":"40d740e80322a240dec41295e7e6194128c4e05e","tid":787984,"uid":82482,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-21T07:14:14.000Z","msg":"*流浪"}]}