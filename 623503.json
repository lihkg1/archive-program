assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2b1c91542e4d67b2c7335a9027309722a1ce43f6","tid":623503,"uid":132478,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-10T06:15:02.000Z","msg":"要互相尊重"},{"pid":"072bf5a25a5ee184b733f7dce89ef87e2152ab91","tid":623503,"uid":57835,"like":1,"dislike":0,"score":1,"quote":{"pid":"2b1c91542e4d67b2c7335a9027309722a1ce43f6","tid":623503,"uid":132478,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-10T06:15:02.000Z","msg":"要互相尊重"},"citedBy":0,"replyTime":"2018-04-10T06:17:50.000Z","msg":"岩，不過父母唔尊你你都可以唔尊重佢"},{"pid":"4eb2005f11366f554738a15a2064c5ef220e5f46","tid":623503,"uid":155137,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-04-10T06:32:17.000Z","msg":"無人話一定要<br />\n君君臣臣 父父子子<br />\n幾千年前都有講"},{"pid":"ff95f250e199d0190aca6cbb4205e052ade37ace","tid":623503,"uid":143407,"like":2,"dislike":3,"score":-1,"citedBy":3,"replyTime":"2018-04-10T07:09:40.000Z","msg":"無錯父母生你係冇問過你<br />\n但你去死都唔使問準父母<br />\n樓主既然咁唔去出生係呢個世上<br />\n點解唔死撚左佢"},{"pid":"e6a7d6f34b1146531375e2d23ab690f4a3a5a15a","tid":623503,"uid":52595,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-10T07:10:41.000Z","msg":"此回覆已被刪除"},{"pid":"1bc0a5930bade1fbe8dbb786340520a1e7486cb7","tid":623503,"uid":114725,"like":0,"dislike":0,"score":0,"quote":{"pid":"dc5fc0dc6ffde3a5d17d7f276dbece2b54272e55","tid":623503,"uid":57835,"like":0,"dislike":0,"score":0,"quote":{"pid":"acf6074e2b8231311a41dbf6215316ddf5b60866","tid":623503,"uid":114725,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2018-04-10T05:06:18.000Z","msg":"睇晒地球所有生物，搵唔到一種會反哺父母，呢樣係大自然法則<br />\n<br />\n利申：我孝順父母"},"citedBy":1,"replyTime":"2018-04-10T05:29:37.000Z","msg":"Sorry係真係有"},"citedBy":1,"replyTime":"2018-04-10T07:25:19.000Z","msg":"唔好同我講慈烏反哺<br />\n以證實係假<br />\n<br />\n舉到其他例子，我叫你契弟"},{"pid":"920109933e1d9f27d9c960aa67ecb68b5237299f","tid":623503,"uid":73750,"like":1,"dislike":