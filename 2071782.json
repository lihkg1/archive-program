ass=\"hkgmoji\" />"},{"pid":"89c6ae0e65ed46710b5aa18f2a4525a3b6ca27b5","tid":2071782,"uid":34293,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T07:52:34.000Z","msg":"推"},{"pid":"c239ea2db920e9218b1633e6cd7f2dd103b7a641","tid":2071782,"uid":70487,"like":0,"dislike":0,"score":0,"quote":{"pid":"7c98ad3c9157319d37af027fb34b1dfaa6eb9da3","tid":2071782,"uid":345733,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-20T06:51:23.000Z","msg":"好仆街<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-20T07:52:58.000Z","msg":"<div style=\"text-align: right;\"><span style=\"font-size: medium;\">[&darr;&darr;港獨強心針&darr;&darr;]</span><br />\n<span style=\"font-size: small;\">香港最強力盟友USA : <br />\n國際反共 形勢大好<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/pAcortX\" data-auto-link target=\"_blank\">https://lih.kg/pAcortX</a></span></div>"},{"pid":"7f5340c0f2781519191f3ace564433b00fcbdb47","tid":2071782,"uid":205927,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T07:54:00.000Z","msg":"咁都有花生"},{"pid":"d902950acbc8c44885e1f66ed08b82683fb2a2f9","tid":2071782,"uid":207596,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T07:56:32.000Z","msg":"push"},{"pid":"8254e19af2ca97b6e6f188b3bb6347f9ee61dfdd","tid":2071782,"uid":36543,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T07:57:08.000Z","msg":"講左條友共謀黎"},{"pid":"45b71a0fa714262aa17c0badc4fa672357e85c53","tid":2071782,"uid":31510,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T07:57:44.000Z","msg":"垃圾白頭佬<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"b2500b98bbbdad23246fdbfac614e90060af6d11","tid":2071782,"uid":319512,"like":0,"dislike":0,"score":0,"quote":{"pid":"5044766d984200002730320f2959c2491967b30b","tid":2071782,"uid":323538,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-06-20T05:53:00.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">血淚實錄<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />：就係個白頭佬+新西肥仔搞散咗我人生第一次工潮!!!!!!!!!!!!!</span></span><br />\n<br />\n是咁的，我係港航受害員工，港航無錢然後炒撚左一班員工，我地搞左一場好撚失敗既工潮，由幾百人、上晒新聞既行動，變成得番廿條人、無人知發生咩事既「工潮」。<br />\n<br />\n嗱，<span style=\"font-size: x-large;\"><span style=\"color: blue;\">話晒係航空業，梗係搵吳敏兒同譚文豪</span><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />[size=5]，但係有同事好撚堅持要搵埋<strong><span style=\"font-size: xx-large;\">街工<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /></span></strong>，又<strong><span style=\"font-size: xx-large;\">大讚白頭佬👨🏻&zwj;🦳</span></strong><br />\n<br />\n <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />算啦，諗住多個幫手都好，但咁就high high左😭😭😭<br />\n<br />\n但有個叫Tracy既同事成鳩日話要搵白頭佬，又安排大家去葵芳街工聽意見。<br />\n<br />\n開頭都幾有聲勢既，一心諗住會唔會爭取到好既成果，但點知搞搞下好唔對路，Core發言人唔見左，吳敏兒同譚文豪都唔見埋，得返街工人，屌，就係嗰條新西肥仔。原來Tracy就係新西肥仔條女，個八婆日鳩日屌鳩話譚文豪、吳敏兒離棄咗大家。我地成班友勁燥，以為真係被背叛。點知原來係街工同條八婆合謀，所有野都唔通知譚、吳，自把自為、自以為是，趕撚走晒啲做得野既人。<br />\n<br />\n其實中間whatsapp group出現咗一輪罵戰，有同事質疑點解無啦啦唔見咗吳敏兒同譚文豪，質疑係咪tracy佢哋玩排擠，所以比較親職工盟既人都唔見晒⋯<br />\n<br />\n有人提出質疑，但原來唔係core team就表達吓疑問都會比人屌返轉頭⋯咁後來都好無癮，又有啲好似工潮大勢已去咁⋯過多排又話白頭佬安排咗去勞工處，搞搞吓總之訴求就最後全部落空⋯<br />\n<br />\n本來都已經搵到工、工潮玩撚完，放棄咗，[size=5]<span style=\"color: red;\">點知尋日睇街工記招，參選名單排第一竟然又係個仆街肥仔盧藝賢+白頭⋯</span></span><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: blue;\">真相大白，為選舉插手港航工潮，我哋輸到渣都冇，你地就贏左我哋啲相做你哋既競選政績呀👍🏻</span></span><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: green;\">做勞工運動出賣勞工</span></span>、<span style=\"font-size: x-large;\"><span style=\"color: blue;\">做議員就讓位俾建制</span></span>、<span style=\"font-size: xx-large;\"><span style=\"color: red;\">做民主運動就率先放棄初選</span></span>，真係屌晒你地老母含家0👎🏻<br />\n<br />\n留名睇所有參選人被DQ，賣港街工四席全入🤗<br />\n<br />\n<img src=\"https://na.cx/i/K3Lqzqe.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FK3Lqzqe.jpg&h=75f1e27f&s={SIZE}\" /> <br />\nCaption：最初行動有吳敏兒譚文豪<br />\n<br />\n<img src=\"https://na.cx/i/euD7NLp.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FeuD7NLp.jpg&h=dcaa1e8b&s={SIZE}\" /><br />\nCaption：右一就係「梁耀忠右轉世靈童」<br />\n<br />\n<img src=\"https://na.cx/i/Ag4Oxcq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAg4Oxcq.jpg&h=489d7708&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/boGJk5K.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FboGJk5K.jpg&h=58c44b82&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/71AaLxr.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F71AaLxr.jpg&h=5a5ecc6f&s={SIZE}\" /> <br />\n<img src=\"https://na.cx/i/RFd0oi5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRFd0oi5.jpg&h=908cdcee&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-06-20T08:00:22.000Z","msg":"push <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"27c534959bdb89e780578047aa3a0ce7fb42a142","tid":2071782,"uid":27797,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T08:00:49.000Z","msg":"推"},{"pid":"9777152357ab468fb925f9d1753bb6c0e3e61538","tid":2071782,"uid":39468,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-20T08:01:59.000Z","msg":"白頭佬 我屌你老母呀 你老母比狗屌"},{"pid":"410e905639dc497ace3e4044d806cd46ac560663","tid":2071782,"uid":7350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T08:07:47.000Z","msg":"屌!<br />\n推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"adc2e235e8dc5b7d07ca5e6195b02a590734c8f1","tid":2071782,"uid":234457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T08:08:11.000Z","msg":"點都唔投佢<img src=\"/assets/faces/dog/bye.gif\" class=\"hkgmoji\" />"},{"pid":"3ef406acb6502b71b79b7426c24a6b34b545f997","tid":2071782,"uid":138212,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T08:08:50.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"009b343331db9e3dc9d4250f14fdd6329cfe359f","tid":2071782,"uid":249705,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T08:09:48.000Z","msg":"Push"},{"pid":"6aa693810385dd8de0d7d415584795b78d62a3ac","tid":2071782,"uid":271686,"like":0,"dislike":0,"score":0,"quote":{"pid":"a49199d821c694b7d4cf72342c35538e0329d8fe","tid":2071782,"uid":143747,"like":4,"dislike":0,"score":4,"quote":{"pid":"bf957d58983ef31738166a45e5d7bc207e030be4","tid":2071782,"uid":64337,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-06-20T07:44:00.000Z","msg":"街工一定要整死佢<br />\n利申 超區投過白頭佬<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2020-06-20T07:49:55.000Z","msg":"新界西 投左鄭蟲太