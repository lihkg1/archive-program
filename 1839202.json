ime":"2020-01-24T10:32:13.000Z","msg":"佢心諗<br />\n又話香港睇醫生唔使俾錢先既<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"34f99285178019e8af2951b21b575d5cd711f6d5","tid":1839202,"uid":140687,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T10:32:45.000Z","msg":"屌佢老母 累人累物"},{"pid":"64b4ba667913afcd9808485edd9009d3d502faf2","tid":1839202,"uid":200165,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T10:33:37.000Z","msg":"又多2單啦"},{"pid":"92acf2a81c7f0a68d305c96dbd146c8d91c1593c","tid":1839202,"uid":280469,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-24T10:34:11.000Z","msg":"唔撚比錢直接火葬"},{"pid":"d1d356ee1e4361d32b87be5ee9969ff1798ab158","tid":1839202,"uid":200165,"like":0,"dislike":0,"score":0,"quote":{"pid":"92acf2a81c7f0a68d305c96dbd146c8d91c1593c","tid":1839202,"uid":280469,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-24T10:34:11.000Z","msg":"唔撚比錢直接火葬"},"citedBy":0,"replyTime":"2020-01-24T10:35:05.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"64a854a6d6b503507653411a5790ea5cad95d2f8","tid":1839202,"uid":38109,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T10:38:50.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"461f2a4d7f979613b98916dbc6b5a44bc57b8d70","tid":1839202,"uid":290883,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T10:46:16.000Z","msg":"死返大陸！！"},{"pid":"a8e30a064f74bc44b97d0c5acd2d33ebc8cfc812","tid":1839202,"uid":60449,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-24T10:46:31.000Z","msg":"賤種黑警 對社會負貢獻 <br />\n第日病死街頭唔好怨"},{"pid":"78b5a7018d98c24fac8a47d542a7b6c6e0da9918","tid":1