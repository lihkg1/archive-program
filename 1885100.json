\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />"},{"pid":"0cdecf0cb8638a98c537c4a226937d40c33d6223","tid":1885100,"uid":84354,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T05:30:57.000Z","msg":"點解雀都會掟落街死？<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"938ec8a07937cbc9bf32ef157413cdc5f16bc331","tid":1885100,"uid":227815,"like":0,"dislike":0,"score":0,"quote":{"pid":"0cdecf0cb8638a98c537c4a226937d40c33d6223","tid":1885100,"uid":84354,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T05:30:57.000Z","msg":"點解雀都會掟落街死？<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-18T05:37:32.000Z","msg":"綁住或者搵野痴住對翼"},{"pid":"cf782f3647b6ff0f70e28e523df4d96215c8fa4d","tid":1885100,"uid":25973,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-18T05:38:49.000Z","msg":"其實呢d虐畜狂徒好多無人理就會變殺人犯"},{"pid":"0826b8bd058efc52f600799b715731f2227b4b0e","tid":1885100,"uid":25973,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-18T05:39:14.000Z","msg":"建議捉入青山 永久隔離"},{"pid":"9586849b701a287d03f8bdba44bd765bb8e23874","tid":1885100,"uid":301666,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T05:43:41.000Z","msg":"未必判好重<img src=\"/assets/faces/cat/stare.gif\" class=\"hkgmoji\" /><br />\n<br />\n一般而言，就非商業環境發生的殘酷對待動物罪行，加重刑責的因素包括：<br />\n<br />\n(1)   長時間殘酷對待受害動物；<br />\n<br />\n(2)   使用極端暴力；<br />\n<br />\n(3)   使用武器；<br />\n<br />\n(4)   對受害動物造成嚴重、劇烈或持續的生理或心理的傷害或痛苦；<br />\n<br />\n(5)   犯案手法加大或旨在加大或延長受害動物所受的驚嚇或折磨；<br />\n<br />\n(6)   有預謀犯案；<br />\n<br />\n(7)   以變態的方式或扭曲心態對受害動物造成嚴重痛楚或痛苦，從而得到變態的快感；<br />\n<br />\n(8)   違反對受害動物信託的責任或濫用職權；<br />\n<br />\n(9)   罪案影響第三者，如目擊犯案過程或結果的公眾人士；<br />\n<br />\n(10)   利用科技，如互聯網的社交平台播放犯案經過，以宣傳或鼓吹殘酷對待動物；<br />\n<br />\n(11)   重覆犯案。<br />\n<br />\n<a href=\"https://legalref.judiciary.hk/lrs/common/ju/ju_frame.jsp?DIS=121214\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Flegalref.judiciary.hk%2Flrs%2Fcommon%2Fju%2Fju_frame.jsp%3FDIS%3D121214&d=aTFRN7Q3AKWWv%2B0RVwuGmhnxOJLX742lx1SCoot1iYY%3D&h=1c940484\" target=\"_blank\">https://legalref.judiciary.hk/lrs/common/ju/ju_frame.jsp?DIS=121214</a>"},{"pid":"6be6bbb41f988f3922ab38d3f6a6facb39f7450d","tid":1885100,"uid":19287,"like":1,"dislike":0,"score":1,"quote":{"pid":"cad1374234c9a01bdccc7ec68fcf821ddcbe080d","tid":1885100,"uid":263349,"like":1,"dislike":0,"score":1,"quote":{"pid":"f1aacbaccbc3325f0c59778a80c0060552d058d8","tid":1885100,"uid":176447,"like":1,"dislike":0,"score":1,"citedBy":3,"replyTime":"2020-02-18T05:18:25.000Z","msg":"據悉，葉在荃灣警署內被捕<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-18T05:27:56.000Z","msg":"係咪果3萬隻野犬 其中一隻<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-18T05:56:26.000Z","msg":"好似係自首"}]}