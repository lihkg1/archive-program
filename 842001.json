img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-30T03:32:44.000Z","msg":"班黑鬼無腦"},{"pid":"907dc0e3f6b312174a29955a1d753773a4a9f297","tid":842001,"uid":119778,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-09-30T03:33:27.000Z","msg":"唔好呀屌<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"7e3d0524cf94e0940df597b6d2bfb63665468bf6","tid":842001,"uid":144464,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-09-30T03:36:09.000Z","msg":"曼聯又輸一場"},{"pid":"bb9331e7451068e61c2db41a0110ef6e0282858c","tid":842001,"uid":20473,"like":18,"dislike":0,"score":18,"quote":{"pid":"09f147944f85cf247f531d065f39e5790934e608","tid":842001,"uid":4440,"like":6,"dislike":0,"score":6,"citedBy":2,"replyTime":"2018-09-30T03:21:53.000Z","msg":"仲有冇球會肯請daddy<img src=\"/assets/faces/mf/cry.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-09-30T03:37:18.000Z","msg":"國米仲當佢神咁拜 而家成績都麻麻<br />\n不過再得罪埋國米真係走投無路<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b06596d1096529eeb6ad08b7b1c3c0508e7e5184","tid":842001,"uid":32028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-30T03:38:23.000Z","msg":"大贏家係廢蛇，佢退休之後曼就無好過"},{"pid":"83b83f3a949d3115b903149363116b72e3becdd7","tid":842001,"uid":132082,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-09-30T03:50:56.000Z","msg":"此回覆已被刪除"},{"pid":"cf6242410312e77e8ee347d57ad3c6f0e401c524","tid":842001,"uid":56467,"like":1,"dislike":0,"score":1,"quote":{"pid":"bb9331e7451068e61c2db41a0110ef6e0282858c","tid":842001,"uid":20473,"like":18,"dislike":0,"score":18,"quote":{"pid":"09f147944f85cf247f531d065f39e5790934e608","tid":842001,"uid":4440,"like":6,"dislike":0,"score":6,"citedBy":2,"replyTime":"2018-09-30T03:21:53.000Z","msg":"仲有冇球會肯請daddy<img src=\"/assets/faces/mf/cry.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-09-30T03:37:18.000Z","msg":"國米仲當佢神咁拜 而家成績都麻麻<br />\n不過再得罪埋國米真係走投無路<img src=\"/assets/faces/