.gif\" class=\"hkgmoji\" />"},{"pid":"eff50517a2704ea6f90f1bf941f0ff50356d3aba","tid":971924,"uid":66324,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2019-01-07T08:12:16.000Z","msg":"pish"},{"pid":"f0a26f3400c55cedfb00aab3603f2f5de124e398","tid":971924,"uid":66324,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2019-01-07T11:15:09.000Z","msg":"pish"},{"pid":"177bd0cf1ef5adedab93e6d0909b26a14204c192","tid":971924,"uid":69765,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-01-07T11:21:01.000Z","msg":"就算要讀都出國讀 唔好留係香港<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"}]}