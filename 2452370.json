r-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FGDdddVjTF-s&d=Ip59BN4yZo1XWf66eFhBSoPST22DtV%2BdF%2FIIxhOvvTQ%3D&h=e8f66bb9\" target=\"_blank\">https://youtu.be/GDdddVjTF-s</a><br />\n<br />\n<a href=\"https://youtu.be/ymihNUBCTgo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FymihNUBCTgo&d=Ip59BN4yZo1XWf66eFhBSoPST22DtV%2BdF%2FIIxhOvvTQ%3D&h=a774c0bf\" target=\"_blank\">https://youtu.be/ymihNUBCTgo</a><br />\n<br />\n<a href=\"https://youtu.be/YPUTMjDlJDY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FYPUTMjDlJDY&d=Ip59BN4yZo1XWf66eFhBSoPST22DtV%2BdF%2FIIxhOvvTQ%3D&h=0b411800\" target=\"_blank\">https://youtu.be/YPUTMjDlJDY</a><br />\n<br />\n<a href=\"https://youtu.be/S7K-nr8v6aY\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FS7K-nr8v6aY&d=Ip59BN4yZo1XWf66eFhBSoPST22DtV%2BdF%2FIIxhOvvTQ%3D&h=d387fab8\" target=\"_blank\">https://youtu.be/S7K-nr8v6aY</a><br />\n<br />\n唔啱就自己再搵下邊隻啱feel嘅啦 情況可以有好多變化 之後可以再調整其他脈輪 不過我係無神輪照練 <br />\n開頭可能夢到奇怪野添 個啲係更加要釋放嘅嘢黎<br />\nGood luck"},{"pid":"3a3d9a5b81c7191b17a19c282653a5f3272dc8ee","tid":2452370,"uid":113178,"like":0,"dislike":0,"score":0,"quote":{"pid":"2fada3465f1b17eddd77a3ad03150c5bd3d44899","tid":2452370,"uid":392196,"like":4,"dislike":0,"score":4,"quote":{"pid":"07ba024f798ac64b7a70a566c4c24dc2430724d2","tid":2452370,"uid":344609,"like":0,"dislike":1,"score":-1,"quote":{"pid":"5d850ff3a1b614e91e9bb3ef31213cfc8be28ea6","tid":2452370,"uid":113178,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-03-18T20:29:43.000Z","msg":"Meditation"},"citedBy":1,"replyTime":"2021-03-18T20:41:38.000Z","msg":"Meditate for how long? Until you fall asleep or just 15-30mins a day?"},"citedBy":1,"replyTime":"2021-03-18T23:03:29.000Z","msg":"<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-19T02:58:07.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n個節目係一個叫headspace 嘅app 整，樓主有興趣可以d