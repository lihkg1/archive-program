ss=\"hkgmoji\" />"},{"pid":"a69bd62be4066c5c576ee78e19d53781a4554a71","tid":905080,"uid":161098,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-17T02:30:49.000Z","msg":"樓主南亞裔？"},{"pid":"39fffcde2fcec1c64f5be2522cf19f90c1ad83fa","tid":905080,"uid":192068,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d9bd3b934f13586605e995ea43d3668eeea8ada","tid":905080,"uid":35790,"like":40,"dislike":1,"score":39,"citedBy":3,"replyTime":"2018-11-17T01:05:12.000Z","msg":"印尼撤BNO免簽<br />\n<br />\n<span style=\"color: red;\">2004-02-04</span><br />\n<br />\n港 聞<br />\n <br />\n印尼總領事館表示撤銷BNO免簽是該國政府決定。<br />\n<br />\n【本報訊】印尼政府在沒有說明具體原因的情況下，由本月一日起撤銷英國國民（海外）護照（簡稱BNO）的免簽證待遇，持BNO護照的旅客需於出發前申領簽證，但特區護照持有人仍享有印尼入境免簽證待遇。 <br />\n英國駐港總領事館發言人表示，昨正式獲英國駐印尼大使館證實，印尼撤銷BNO護照免簽證待遇，但該國仍在了解印尼突撤銷有關免簽待遇的原因。<br />\n<br />\n三港人被拒入境 <br />\n印尼駐港總領事館發言人指出，今次撤銷BNO護照免簽證待遇是該國政府的決定，領事館並不知有關具體原因。領事館職員稱，凡持有BNO護照的人士均需先辦理簽證手續，費用為二百八十元，需時三個工作天。 <br />\n該發言人又證實，三名港人本周日持BNO入境印尼時被拒，領事館稱，上月中已將有關撤銷BNO免簽待遇的消息正式知會港府及旅行業界。這三名港人後來向入境處求助，經協助下前日已順利抵達印尼。<br />\n&lt;蘋果&gt;"},"citedBy":1,"replyTime":"2018-11-17T02:32:43.000Z","msg":"直線抽擊"},{"pid":"95c82018c63408852eb80d4e5de5489a2bc371c9","tid":905080,"uid":92178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-17T02:33:52.000Z","msg":"此回覆已被刪除"},{"pid":"60f8fc7c949419e2ca0aaef9b0160782f1fa5bc1","tid":905080,"uid":25858,"like":1,"dislike":0,"score":1,"quote":{"pid":"9f7b184d8903d292c5016b7b6f35a7f6374a4fc6","tid":905080,"uid":42188,"like":193,"dislike":2,"score":191,"citedBy":1,"replyTime":"2018-11-17T00:43:44.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">印尼呢啲垃圾國家去唔去都冇所謂</span></span>"},"citedBy":0,"replyTime":"2018-11-17T02:39:07.000Z","msg":"<img src=\"/assets/faces/lm2/yo.gif\" class=\"hkgmoji\" />"},{"pid":"8bc551e49e8401cf838f5cad5ffadc752a58f7a7","tid":905080,"uid":9564,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-17T02:43:13.000Z","msg":"黃細柒又柒<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoj