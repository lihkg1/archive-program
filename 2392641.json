pig/dying.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-03T10:04:38.000Z","msg":"5星服務(對外)<br />\n1星服務(對內)<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6da77a3f7d7e02a66b5beff42d07ca01f1e62955","tid":2392641,"uid":84275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-03T10:07:49.000Z","msg":"柯梗屎覆你<br />\n<br />\n坐得太耐有d腳痺，諗住坐多陣先出返去<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2c01dd7c14cdf6fab677bab317d6e812a91f6ad3","tid":2392641,"uid":236505,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2021-02-03T10:07:52.000Z","msg":"老細自己都成日去廁所痾屎<br />\n仲會大大聲講 &quot;痾個令屎先!&quot;<br />\n佢好著重每個人既腸道健康<br />\n叫我地千祈唔好忍屎<br />\n同埋一定要痾清痾淨<br />\n<br />\n利申 一日兩次 每次半個鐘"},{"pid":"d0c664f674a3013c2d5b65f98e693a6e16b822ed","tid":2392641,"uid":38030,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-03T10:10:15.000Z","msg":"有得屙屎長短週vs冇得屙屎返五日<br />\n你又點揀<img src=\"/assets/faces/mouse/medicine.gif\" class=\"hkgmoji\" />"},{"pid":"7e9f34086d0963806fdf1434812a1babb1475c72","tid":2392641,"uid":74012,"like":0,"dislike":0,"score":0,"quote":{"pid":"13026568d14ee88ec2178f9dc1fb6a0b4987201b","tid":2392641,"uid":236505,"like":0,"dislike":0,"score":0,"quote":{"pid":"2007a697aac8334901c07590de399ce4ce0a17c7","tid":2392641,"uid":353380,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-02-03T02:49:15.000Z","msg":"試過返5星酒店<br />\n成間酒店得一個員工廁所咁大把<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><br />\n廁格長期爆要排隊等痾屎<br />\n然後上一手d廢老又成日吐痰唔沖廁 <img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-02-03T10:04:38.000Z","msg":"5星服務(對外)<br />\n1星服務(對內)<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoj