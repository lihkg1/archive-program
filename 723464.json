hkg.com/link?u=http%3A%2F%2Fmens-staff.jp&d=Clv51i9CFE68NckJGaYwZzPUa9iY%2BpOmOVTB4fMSqaQ%3D&h=1e6b0d80\" data-auto-link target=\"_blank\">mens-staff.jp</a> (東京） &ndash; 大隻佬專門店，玩法同上面差不多，但可以用Line 預約，我幫趁過一次。<br />\n<br />\n-------------------------------------------------------------------------------------<br />\n<br />\n<img src=\"https://sogayhk01.files.wordpress.com/2016/08/e89ea2e5b995e5bfabe785a7-2016-08-18-17-18-13.png?w=700\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fsogayhk01.files.wordpress.com%2F2016%2F08%2Fe89ea2e5b995e5bfabe785a7-2016-08-18-17-18-13.png%3Fw%3D700&h=27b4624d&s={SIZE}\" /><br />\n<br />\n3. <a href=\"http://www.dgdgdg.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.dgdgdg.com&d=Clv51i9CFE68NckJGaYwZzPUa9iY%2BpOmOVTB4fMSqaQ%3D&h=cc8b0f24\" target=\"_blank\">http://www.dgdgdg.com</a> &ndash; 著名嘅「男子學園」，全日本都有分店，我幫趁過大阪分店。呢間係同某GV制片商合作，間中有GV男優駐場，我上次就係同某男優玩，不過唔係太靚仔。可以email用英文預約。<br />\n<br />\n<a href=\"https://sogayhk01.wordpress.com/2016/08/18/%E7%B6%B2%E5%8F%8B%E6%8E%A8%E4%BB%8B-%E6%97%A5%E6%9C%AC%E4%B8%89%E5%A4%A7%E5%90%8C%E5%BF%97%E6%8C%89%E6%91%A9/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fsogayhk01.wordpress.com%2F2016%2F08%2F18%2F%25E7%25B6%25B2%25E5%258F%258B%25E6%258E%25A8%25E4%25BB%258B-%25E6%2597%25A5%25E6%259C%25AC%25E4%25B8%2589%25E5%25A4%25A7%25E5%2590%258C%25E5%25BF%2597%25E6%258C%2589%25E6%2591%25A9%2F&d=Clv51i9CFE68NckJGaYwZzPUa9iY%2BpOmOVTB4fMSqaQ%3D&h=5d7c005c\" target=\"_blank\">https://sogayhk01.wordpress.com/2016/08/18/%E7%B6%B2%E5%8F%8B%E6%8E%A8%E4%BB%8B-%E6%97%A5%E6%9C%AC%E4%B8%89%E5%A4%A7%E5%90%8C%E5%BF%97%E6%8C%89%E6%91%A9/</a>"},{"pid":"ca0b0d1be4600368f1130d27af0317fafa7242fb","tid":723464,"uid":76115,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-30T12:04:54.000Z","msg":"香港可以邊到睇?<br />\n利申:幫朋友問"},{"pid":"fd35e3999258f4be942e5887494098c00dd235bf","tid":723464,"uid":21423,"like":22,"dislike":0,"score":22,"citedBy":2,"replyTime":"2018-06-30T12:07:40.000