mbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20200331%2Flarge%2F1585635639_5d91.jpg&h=0a9400e2&s={SIZE}\" /><br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20200331/large/1585635639_36df.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20200331%2Flarge%2F1585635639_36df.jpg&h=833ec02a&s={SIZE}\" /><br />\n<a href=\"https://hk.news.appledaily.com/china/20200331/ZDIUQ6LZIVPOB473I2DJBLO5LI/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Fchina%2F20200331%2FZDIUQ6LZIVPOB473I2DJBLO5LI%2F&d=C7qEe2dSMr%2BabA5wG5krtH%2B3Qbouwy6U%2BTFwRHAqvaY%3D&h=9f20e845\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Fchina%2F20200331%2FZDIUQ6LZIVPOB473I2DJBLO5LI%2F&h=531b06b6\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/china/20200331/ZDIUQ6LZIVPOB473I2DJBLO5LI/</a>"},"citedBy":0,"replyTime":"2020-04-04T01:07:33.000Z","msg":"係慘嘅<br />\n不過有更多慘過佢嘅人<br />\nbtw無啦啦做乜訪問呢個人"},{"pid":"2ce6f22f008ad117bd94bf535a29b8b3bee015cc","tid":1951862,"uid":181655,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-04T01:10:12.000Z","msg":"食洋腸的下場<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"d4991b98a474a47f39c8235be00b1f615ae5c9ec","tid":1951862,"uid":29514,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-04T01:17:10.000Z","msg":"英國抗疫幾成功，扮佛系成功趕走左幾多人<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />大大減少醫療負擔"},{"pid":"4d3b2f518dba556e6e7eb4496bd9b86d1110db81","tid":1951862,"uid":63154,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-04T01:26:06.000Z","msg":"咁唔捱得苦，仲有成世人流流長呀陰公<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1cafa5fa9cf1242e95bc87189c95a6ed26c1d091","tid":1951862,"uid":291526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-04T01:59:19.000Z","msg":"咁都有得好抱怨<br />\n咩垃圾人同垃圾新聞<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"18199faae1d8973dcfeb51556694e0fd33638c84","tid":1951862,"uid":263183,"like":0,"dislike":0,"score":0,"quote":{"pid":"d99778a246705bc2ed68caa82d357c92ddb36b57","tid":1951862,"uid":214036,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-31T08:54:41.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-04-04T02:18:03.000Z","msg":"唔係話飛機乾淨咩"}]}