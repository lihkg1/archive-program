0.000Z","msg":"黑松露<br />\n一蘭拉麵"},{"pid":"3ea517000a648edd77ef9826a03d5c2da81a0b09","tid":458293,"uid":74302,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-07T07:41:22.000Z","msg":"<blockquote>納豆</blockquote><br />\n唔係講笑,<br />\n以前係日本成班人係房打牌<br />\n買左sushi放係度打開左<br />\n過左陣我問邊撚個未沖涼, 咁撚臭既<br />\n<br />\n大家好不解, 因為都沖哂<br />\n<br />\n原來陣味<br />\n<br />\n係納豆壽司傳出來<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"966b964a18ce7052273e13947ce456065c25887c","tid":458293,"uid":52148,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-07T07:51:09.000Z","msg":"一定係芫茜"},{"pid":"6b98243d301f6db7cf5cb222bb4cb8a6c0c204eb","tid":458293,"uid":555,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-07T07:51:50.000Z","msg":"花尖餅"},{"pid":"a5056aee6bedff5b198a15997e93e235e87383de","tid":458293,"uid":106211,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-07T07:59:27.000Z","msg":"蚵仔煎"},{"pid":"ae9256405819902c696a2db043db6730908143af","tid":458293,"uid":50801,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-07T08:04:44.000Z","msg":"台灣既臭豆腐<br />\n香港聞係臭，食落去唔臭<br />\n台灣臭豆腐食落去係酸酸叔叔<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"e75dbe2ea8298da9699fd15559c9e79f44790236","tid":458293,"uid":619,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-07T08:11:58.000Z","msg":"<blockquote><blockquote><blockquote>甘草糖 甘草雪糕</blockquote><br />\n甘草陣味真係好難頂<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/11/05/043248_5fd47d7475015d8ab6cbe81897f89154.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F05%2F043248_5fd47d7475015d8ab6cbe81897f89154.jpg&h=d9050c2c&s={SIZE}\" /><br />\n<br />\n想當年買過返黎做手信，真係十個食完十個吐。</blockquote><br />\n<img src=\"http://www.hollandforyou.com/images/stories/virtuemart/category/resized/jumbo-eige