d1e5bc420b6cb516cfa963c0ad95","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:17:33.000Z","msg":"推撚到你班仆街醒！！"},{"pid":"26d212d8cdf0cf88da4372309991a29a448a6e6e","tid":1467182,"uid":3448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:18:34.000Z","msg":"幫推"},{"pid":"2c83c2a9b77e36a103fb03654aa9164c560abe7e","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:18:36.000Z","msg":"推撚到你班仆街醒！！"},{"pid":"e3411f56551146cd1715469b741ade2ffa5dfc22","tid":1467182,"uid":203619,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:18:45.000Z","msg":"我只推 正常POST<br />\n<img src=\"https://i.lihkg.com/540/https://na.cx/i/RfNfTgW.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.lihkg.com%2F540%2Fhttps%3A%2F%2Fna.cx%2Fi%2FRfNfTgW.png&h=52691539&s={SIZE}\" /><br />\n今日我留意到最大單係警察係機場用槍指嚇市民<br />\n你地又留意到咩呢?<br />\n希望大家理性啲 幫手推返正常POST<br />\n<br />\n一句講哂<br />\n鬼係捉唔哂，大局為重"},{"pid":"63af6efbf56172ebe2f9bbc487b4d81898bb1b5c","tid":1467182,"uid":2764,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:18:52.000Z","msg":"不分化 不割蓆"},{"pid":"ca9947b6a349b4a3f525dabd568d12bd1d7389be","tid":1467182,"uid":81183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:19:58.000Z","msg":"場運動未完架<br />\n唔好比3毛帶風向話輸<br />\n其實唔係好大件事，個大陸佬擺明挑釁，引你地出手架喇<br />\n最多係蠢左但錯唔晒<br />\n<br />\n退幾步講，就算真係行錯一步咁又點，咪行番岩佢囉！<br />\n政府錯左十幾廿步都未跪低認輸，我地做乜要咁灰？"},{"pid":"54bc03de127a30d94e79988bd1b764926564d32b","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:21:28.000Z","msg":"推撚到你班仆街醒！！"},{"pid":"357cdfbd4dffca93bdd168695b1d0aeab7f55174","tid":1467182,"uid":810,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:21:46.000Z","msg":"警察亂棍打女遊客同上實彈<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"40443858449e522db099ab6c692089aa1f7bc878","tid":1467182,"uid":292067,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:21:58.000Z","msg":"我係何妖實恥笑<br />\n我由頭到尾無割過 無被割 無被指責<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n你地班撚樣 少少野都割又分化互屌互指責 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n---------<br />\n記住 反對/屌人時 比埋建議 咁就<img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8e6ec832ea0220e2025b4c750754f5f9c7806c81","tid":1467182,"uid":69212,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:21:58.000Z","msg":"<span style=\"color: orange;\">請停止任何失敗主義及分化行為</span><br />\n<br />\n<span style=\"color: orange;\">善用不推post功能</span><br />\n<br />\n<span style=\"color: orange;\"><span style=\"font-size: xx-large;\">不分化 不割蓆</span></span>"},{"pid":"19f6d339a1860fdbd0f890f3e2e89266d228190f","tid":1467182,"uid":297071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:22:00.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">【安心又偷食】仲有冇人記得許志安，黃心穎？</span></span><br />\n<a href=\"https://lih.kg/1466951\" data-auto-link target=\"_blank\">https://lih.kg/1466951</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"c9bf5ca2fe6b2a33c4ae9a630ee357059e797070","tid":1467182,"uid":14087,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:22:16.000Z","msg":"警世文 機場一戰之我見<br />\n<a href=\"https://lih.kg/1465840\" target=\"_blank\">https://lih.kg/1465840</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<span style=\"color: red;\">我地唔靠外國靠自己？</span>攬炒巴登報無？共和黨無？人權法無？侵侵無？澳洲無？聯合國無？人權組織無？如果無外國 一早派軍隊殺撚哂我地啦 <span style=\"color: red;\">我地個焦土係要靠外國架？無外國制裁我地一早死撚哂啦</span> 咪撚咁低能啦 你依家咁做未又係搞9旅客想等外國出聲，但咁搞無人會想幫我地 <span style=\"color: green;\">我想贏呀，唔想發左二個月夢白費呀屌</span><br />\n<br />\n咁你依家去夾住班旅客，唔俾佢地走，直至外國肯幫拖，<span style=\"color: red;\">咁你照下鏡，果一刻你係香港人，定係變成一個暴徒？</span>你真係覺得咁樣對個運動有幫助？平心而論，我唔該您<span style=\"color: green;\">跳出深黃框框用普通入角度去睇呢件事，外國唔係深黃，我地一直係自己個框框去睇，好難贏，我地要多角度思考，去就自己爭取最大既勝算</span><br />\n<br />\n依家係<span style=\"color: red;\">林鄭擺到明放人入機場帶頭搞事 想抹黑我地 點解我地要中計.</span>.. <span style=\"color: gold;\">我知我地點都唔割 我都係</span> 但<span style=\"color: green;\">對個運動毫無利益 </span>外國知道既資訊無我地自己人咁清楚 佢地只會覺得我地係搞事 你係機場衝，除左肉酸有乜撚野用，記唔記得點解我地去機場？係因為想宣揚我地個情況係全世界旅客知，我問你，我地依家似乜野？？？我地依家就係肉撚酸，連旅客都反感，咁<span style=\"color: green;\">我地當初去機場為乜呀？</span><br />\n<br />\n借問聲 咁樣連<span style=\"color: green;\">全世界遊客都對我地反感 我地仲係咪當初既香港人 為自由去爭取</span>？咁樣橫蠻無理法只會令我地<span style=\"color: red;\">立場惡化，對我地既抗爭有咩幫助</span>？機管局自己取消航班我地先叫有用，咁樣自己阻人上機 有咩意義？機管局會因為你阻住果幾個遊客而取消航班？個遊客未無辜硬食哂，再加<span style=\"color: red;\">傳媒抹黑，我地未輸哂囉 </span>，依家搞到我地變到神憎鬼厭咁 仲點樣贏 ?<span style=\"color: green;\">醒下啦，唔好俾憤怒沖昏頭腦，我地係要贏，唔係要發洩，咁搞對件事無幫助，琴日機管局警察咁搞，世界矛頭直指政府，但今日呢？直接我地呀，理智呀手足,我地要贏!!!!!!放下仇恨，智取，唔好俾林鄭得逞...機場戰線應該係繼續文宣和你飛好嗎， <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />不分化不割席，但真係想贏，唔想一子錯滿盤階落索<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></span><br />\n<br />\n記住我地香港人係點<br />\n<img src=\"https://na.cx/i/gLG04ac.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgLG04ac.png&h=fef1b4e1&s={SIZE}\" />"},{"pid":"348cfcabb225d51d5c248c60b5ff9e06e85f814a","tid":1467182,"uid":33000,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:22:29.000Z","msg":"無輸到 無人投降"},{"pid":"b176300c51f4f54b48c211c49bae3f0f5562c768","tid":1467182,"uid":43939,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:22:44.000Z","msg":"屌你咁撚易輸我地就唔會捱到今日！<br />\n大家要記住第一日我地係為咩行出黎！"},{"pid":"18f4469a539dbc76a41fbe8e74668a8e4051a9ff","tid":1467182,"uid":119135,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:23:02.000Z","msg":"1環球日報記者派藍衫<br />\n2藍衫喺荃灣冇差別打人傷人<br />\n3合理懷疑 行使101拘捕令"},{"pid":"7f2ee1570a935118a7221076a4eff9a597fe0777","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:23:28.000Z","msg":"推撚到你班仆街醒！！<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"5d491bbe6c3d3675bcdd189fa7a8985c27476288","tid":1467182,"uid":266735,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:23:53.000Z","msg":"只要我地唔投降，我地就唔會輸"},{"pid":"291ba9d4e5d0126b685b02b205e7e049ca47fb65","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:24:44.000Z","msg":"推撚到你班仆街醒！！<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"b8821d38d4ae7ecd0add733a0645b306584af38f","tid":1467182,"uid":283428,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:25:15.000Z","msg":"<a href=\"https://lihkg.com/thread/1464481/page/1\" target=\"_blank\">https://lihkg.com/thread/1464481/page/1</a><br />\n同意就幫手屌醒佢地"},{"pid":"b2b75af6de99a0436cb4b8f4f437e72a3afcd174","tid":1467182,"uid":72301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:25:24.000Z","msg":"班藍絲無論你做咩 <br />\n佢地都會幫你煲到最大<br />\n<br />\n所以今次做大左都唔怕 <br />\n因為今次只會同佢地平時嘅文宣一樣係最大程度<br />\n連藍絲都會睇到麻木<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4a069d221e0b599f3d12bacb768e1616d011f71c","tid":1467182,"uid":147053,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:25:41.000Z","msg":"如果因為一次做得唔好就收皮既話，政府一早收咗皮啦<br />\n唔洗即刻開post 屌曬鬼既<br />\n討論點做返好先實際<img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" />"},{"pid":"abed1748fa67078181285da71144cdffba5b10e6","tid":1467182,"uid":111694,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:26:22.000Z","msg":"雨革我都有去 就係輸左先要而家14歲都走出黎 <br />\n<strong><span style=\"font-size: x-large;\">我地要贏</span></strong><br />\n<br />\n［中計撚入］唔好成日話輸民心啦<br />\n<a href=\"https://lih.kg/1466381\" data-auto-link target=\"_blank\">https://lih.kg/1466381</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"a4392d4e5d8d1c6374ccac789d7bbc3e8b9c26d0","tid":1467182,"uid":94824,"like":0,"dislike":0,"score":0,"quote":{"pid":"bf7eebe50adc5aa77d6845d5835b2d8f54e31523","tid":1467182,"uid":48275,"like":3,"dislike":0,"score":3,"quote":{"pid":"e13576b40d6200eea578f5b53a878e19a5e75272","tid":1467182,"uid":94824,"like":1,"dislike":3,"score":-2,"quote":{"pid":"b227dc1d0b4076464ea00d0cf9ece2031f96f57e","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-13T17:08:30.000Z","msg":"出面見到10個Post有9個都帶撚哂風向<br />\n又話咩輸鳩硬 又話今晚機場大鳩獲<br />\n<br />\n係啊 輸撚哂啊 輸在你地自己係到動搖<br />\n口口聲聲不分化 自己就係到屌鳩同路人<br />\n話鳩左可以屌但唔可以割<br />\n<br />\n係啊 出面好撚多鬼啊 <br />\n人地前線捉鬼 你班冷氣軍師又話鳩人地中計<br />\n人地和理非勸交 你班前線又屌鳩人口口聲聲黑警還眼但屌自己人暴力 屌自己人豬隊友比人做文章<br />\n<br />\n咁你地個初衷呢？<br />\n當年雨革輸咩你地一晚就唔撚記得 <br />\n一晚你地就做翻分化撚<br />\n我地目標一致 對準政權<br />\n點解呢場運動會輸？<br />\n因為又比人做文章 驚民意逆轉？<br />\n定因為你地自己已經放棄左？<br />\n<br />\n運動至今 有良知 有智慧既人一早已經揀好左<br />\n所謂既民意逆轉係咪真係想像中咁可怕？<br />\n可怕到都未撚出現你地自己已經逆轉？<br />\n<br />\n唔該大家花幾分鐘諗清諗楚<br />\n諗好之後請跟我大叫一聲<br />\n<br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: gold;\">光復香港<br />\n時代革命</span></strong></span>"},"citedBy":2,"replyTime":"2019-08-13T17:12:22.000Z","msg":"輸撚哂啦<br />\n<br />\n經濟輸<br />\n民意輸<br />\n勇武輸<br />\n中立輸<br />\n外國文宣輸<br />\n<br />\n我嬲撚到訓唔到 2個月努力俾<span style=\"color: red;\"><span style=\"font-size: xx-large;\">仇恨</span></span>摧毀左<br />\n<br />\n你打黑警贏左啲咩？5大訴求邊樣達到左？<br />\n民主係呢一晚已經徹底同香港割左席<br />\n<br />\n好自為之"},"citedBy":1,"replyTime":"2019-08-13T17:15:08.000Z","msg":"只有你自己投降 先係真正既輸<br />\n我地係未贏 但係都唔輸 請繼續行落去<br />\n<br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: gold;\">光復香港<br />\n時代革命</span></strong></span>"},"citedBy":0,"replyTime":"2019-08-13T17:26:32.000Z","msg":"我唔想割 但係都好支力<br />\n聽日再搞離境、200萬+1真係會變番200萬"},{"pid":"3aef23b077e5548132f42443eb54c3da4c14f50e","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:27:55.000Z","msg":"<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"34b435daa421201b6e43d4cde411a6bb69ec821e","tid":1467182,"uid":13173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:28:43.000Z","msg":"推！"},{"pid":"de50c4eed29075f124a6a5720babe5706055f0a0","tid":1467182,"uid":4964,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:28:49.000Z","msg":"香港史第一次,冇人有經驗<br />\n蝦碌係合乎常理<br />\n檢討,繼續前行<br />\n<br />\n每日都講一次:<br />\n意志力就係贏輸嘅關鍵,鬥智又鬥力,和理非勇武彈出彈入,團結就是力量<br />\n戰略上藐視敵人 戰術上重視敵人"},{"pid":"76f8a40c00bd613e6b435ab8fab5d192bdc956a3","tid":1467182,"uid":80389,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:28:56.000Z","msg":"推"},{"pid":"935d8780cb115664b821d943b80589964b867d48","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:29:30.000Z","msg":"<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"c55d47aa0c394ef4688c60e273605446588d9082","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:31:05.000Z","msg":"<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"53464bba72cf5ecf181961c92fa61496dd543f22","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:34:45.000Z","msg":"<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"1d56641ff99264a88813684ab9db893c574de258","tid":1467182,"uid":252999,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:35:36.000Z","msg":"輸一下唔係問題<br />\n重點係我地唔可以認輸<br />\n諗下班狗呢三日搞咁撚多野<br />\n811武力鎮壓，襯我地話核彈都唔割就放鬼出嚟亂軍心<br />\n搞到812人心惶惶，消息爆發，引我地自亂陣腳<br />\n然後813等我地鬆懈，前線手足又攰又燥，然後嚟個局就搞撚到大家互鬥<br />\n呢三日設成個局就係想我地自己內亂<br />\n內亂只會不攻自破<br />\n唔可俾班狗俾個垃圾政府得逞<br />\n吸取教訓，起身再嚟過"},{"pid":"6725d1a51d5bbfa9090cc74526385911cf7ba083","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:39:45.000Z","msg":"推撚到你班仆街醒！！"},{"pid":"33ac829a82b5fbc82523ccc2613d1a7f5f001ac9","tid":1467182,"uid":35155,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:45:08.000Z","msg":"其實好撚小事<br />\n大家熄一熄個連燈app<br />\n抖一抖"},{"pid":"2cce17c46ee1b865a353bd0d7152f676d7d23ee7","tid":1467182,"uid":52574,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:46:26.000Z","msg":"從來都唔係【癱唔癱】既問題，而係【如何癱】既問題<br />\n<a href=\"https://lih.kg/1464999\" data-auto-link target=\"_blank\">https://lih.kg/1464999</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n求大家睇下同投個票<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n今晚係轉捩點<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"889595f01195f5f3389f647df19eaf761fc7b4a9","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:47:35.000Z","msg":"<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"32e3bde149208e2544d714b55ba285bb0cc958a1","tid":1467182,"uid":48275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T17:59:00.000Z","msg":"<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgm