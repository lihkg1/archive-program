s/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"8e713465521a222c9ea66503524ab7f247c50ed4","tid":1758334,"uid":213877,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-11-27T03:51:56.000Z","msg":"一齊唱到佢個仔無得去台讀書啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0ca7517bd38648b11ae666bc8fa919107bb72a4c","tid":1758334,"uid":213877,"like":0,"dislike":0,"score":0,"quote":{"pid":"7896ab67d4070ead5a8e667ed9153844cb7599c2","tid":1758334,"uid":33099,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-27T03:49:46.000Z","msg":"向台灣國安舉報佢"},"citedBy":0,"replyTime":"2019-11-27T03:52:06.000Z","msg":"無錯<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6f20d82038104448a6a7a11e6295857326504e0c","tid":1758334,"uid":22796,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-27T04:48:37.000Z","msg":"影選票單嘢不了了之？"},{"pid":"15262a5b0d678c62afb5ebff832dff881daf874b","tid":1758334,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-27T05:05:57.000Z","msg":"陳小春遭爆全家來台住 Jasper「小二降級讀幼稚園」<br />\n<br />\n港星陳小春2017年帶著兒子Jasper上「爸爸去哪兒5」後人氣大漲，Jasper在節目中乖巧懂事的暖男形象更獲得許多網友喜愛。近日，有媒體爆料，陳小春一家人似乎已來台短暫定居，還被直擊應采兒帶著Jasper上台灣貴族幼稚園的畫面。<br />\n<br />\n據《鏡週刊》報導，陳小春一家人日前帶著6歲的Jasper來台短暫定居，並安排暫時就讀台北市某間貴族學校，據悉該學校一個學期學費就要價10萬以上。不過，報導中也指出，Jasper原先在香港是就讀國小二年級，會來台就讀該幼稚園是由於應采兒是該校校友，加上香港近來情勢不穩定，因而決定先暫時居住在應采兒的故鄉台灣。<br />\n<br />\n報導中也指出，陳小春一家人預計將在台停留至12月初，待陳小春12月7日於林口演唱會結束。<br />\n<a href=\"https://stars.udn.com/star/story/10088/4189809\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fstars.udn.com%2Fstar%2Fstory%2F10088%2F4189809&d=CdC2hxDFSK2eX8E0jz8mRDMRYSN2ZvgGkER1Jhb0l7M%3D&h=a0069ae5\" data-auto-link target=\"_blank\">https://stars.udn.com/star/story/10088/4189809</a>"},{"pid":"aa72c1e9339d7169e6d4bbe2a2fad6fe9560e4ef","tid":1758334,"uid":246314,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-27T05:14:07.000Z","msg":"屌佢老母啦 唔撚返大灣區做個貼愛國人<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8b8856681adcb0b67ae1d64a81a48f20e7140574","tid":1758334,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"7896ab67d4070ead5a8e667ed9153844cb7599c2","tid":1758334,"uid":33099,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-27T03:49:46.000Z","msg":"向台灣國安舉報佢"},"citedBy":0,"replyTime":"2019-11-27T05:19:53.000Z","msg":"國安局 - 國家安全局<br />\n舉報專線<br />\n<a href=\"https://www.nsb.gov.tw/index01.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.nsb.gov.tw%2Findex01.html&d=CdC2hxDFSK2eX8E0jz8mRDMRYSN2ZvgGkER1Jhb0l7M%3D&h=1488f4dd\" data-auto-link target=\"_blank\">https://www.nsb.gov.tw/index01.html</a>"},{"pid":"e8b320349fb232993847b040dce0934e8cfe0bd6","tid":1758334,"uid":51612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-27T05:28:21.000Z","msg":"仲有佢老婆係美國人<br />\n<br />\n三面間碟"}]}