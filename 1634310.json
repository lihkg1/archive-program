lass=\"hkgmoji\" />"},{"pid":"33e96fa9a37469cb7f52c4b8b9021f013160871a","tid":1634310,"uid":21678,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T08:31:11.000Z","msg":"推"},{"pid":"08defaf331652bbecec1c7f9cd78cd241fa7d52f","tid":1634310,"uid":116474,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T08:31:58.000Z","msg":"推"},{"pid":"632a09c95b9b76cc5d73474ae086a20158d25df3","tid":1634310,"uid":207553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T08:32:19.000Z","msg":"We are temporarily using live channel直播台as english channel<br />\n<a href=\"https://lih.kg/1634498\" data-auto-link target=\"_blank\">https://lih.kg/1634498</a>"},{"pid":"ddb16df3b7a4b7b160e4f27bd224483dfd1c6141","tid":1634310,"uid":15259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T08:32:29.000Z","msg":"剛柔並用 和勇合一 不割不分<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n有時唔洗下下硬打既，轉個方式抗爭都得<br />\n比勇武叉叉電 比文宣組做下野<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /><br />\n呢場抗爭要贏一定要學識剛柔並用<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1631757\" data-auto-link target=\"_blank\">https://lih.kg/1631757</a>"},{"pid":"40935f610133c6e632c61a25b672d33538b40801","tid":1634310,"uid":98431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T08:32:31.000Z","msg":"連登需要更多分析PO"},{"pid":"d5437f623d6f9964a1e54e3259b5f638fab695ff","tid":1634310,"uid":21678,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T09:14:40.000Z","msg":"推"},{"pid":"ee9261a38dfcfbf608e53ba1171259a05c565695","tid":1634310,"uid":146737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T09:15:23.000Z","msg":"［第八期牆紙］抗爭之餘，還請好好活著<br />\n<a href=\"https://lihkg.com/thread/1631856/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1631856/page/1</a><br />\nTG CHANNEL :<a href=\"https://t.me/WallPaperENews\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FWallPaperENews&d=fuRTyfFj%2BaUlIJflnhZSn6C2H8C9v%2BSdTXBEGJsevNE%3D&h=10ad623b\" data-auto-link target=\"_blank\">https://t.me/WallPaperENews</a><br />\n歡迎投稿 : <a href=\"https://padlet.com/lennonnewshk/6g5yp3tllkxx\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpadlet.com%2Flennonnewshk%2F6g5yp3tllkxx&d=fuRTyfFj%2BaUlIJflnhZSn6C2H8C9v%2BSdTXBEGJsevNE%3D&h=9c1a403a\" data-auto-link target=\"_blank\">https://padlet.com/lennonnewshk/6g5yp3tllkxx</a>"},{"pid":"1531cc6554997b4779268eb31a585468c473b7ed","tid":1634310,"uid":52855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T09:18:17.000Z","msg":"香港人要醒下，今日我地要出來抗爭係反映過去二十幾年和平抗爭既失敗，我地香港人要做既只有三件事。<br />\n<br />\n1. 無論如何，唔可以同前線切割，一切割佢地必死，我地係一體，勇武犯錯即係我地犯錯，大家共同承擔。<br />\n<br />\n2.要記住前線唔係無差別破壞，一定要做好文宣，打擊中資先對中央有用 <br />\n<br />\n3.堅定抗爭，遊行一定要參與，保護我地班細路，來緊經濟可以會好差，我地甚致有好多利益受損，可能有段日子要捱，但凡事要成功就有代價，我地一定要堅持，一輸我地同下一代就會入集中營。<br />\n<br />\n政府圈套就係想你係佢定立既規則入面玩，唔好相信佢地，即使你玩贏，佢都可以定第二啲規則，我地要既係規則由我地定，要不斷向始作俑者同當權者施壓，打擊佢地係香港既利益，當佢地付出既代價大於比真普選我地時，香港人先會贏。"}]}