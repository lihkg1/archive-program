x%2Fi%2FsGaZXqr.jpg&h=89c697b5&s={SIZE}\" />"},{"pid":"c178043585e1cb3617e0e3d7de5f7e4fb72e5715","tid":1785670,"uid":266617,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:07:31.000Z","msg":"done"},{"pid":"f9b827486c3f592dc7b082501dbec5d2e4d90b6f","tid":1785670,"uid":188685,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:07:51.000Z","msg":"推"},{"pid":"bcce0fe0d88f67d0cf1e2e2e4b665fe564745b8e","tid":1785670,"uid":172617,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:07:56.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"120ba10b732e0848886736adfa447f3f520550cc","tid":1785670,"uid":167554,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:12:47.000Z","msg":"推"},{"pid":"cf8d397aa32ba009ae3d63ef078148adae92f814","tid":1785670,"uid":164752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:12:54.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"01a4237fbc708248fbcdbe6505a5e0a38f078c93","tid":1785670,"uid":164752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:13:04.000Z","msg":"<img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/drum.gif\" class=\"hkgmoji\" />"},{"pid":"f8204a56f3097c545134a661309025e4bc45248b","tid":1785670,"uid":164752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:13:27.000Z","msg":"<img src=\"/assets/faces/pigxm/pointing.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/pointing.gif\" class=\"hkgmoji\" />"},{"pid":"a1ba9c7c1140f9b4f98cea2fba057371cca5bcd0","tid":1785670,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:15:47.000Z","msg":"推"},{"pid":"9d16a7ba7e0fb7d2bcd000d1cde1df312a4c3216","tid":1785670,"uid":185121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:22:58.000Z","msg":"志願者係做乜<img src=\"/assets/faces/dogxm/escape.gif\" class=\"hkgmoji\" />"},{"pid":"041f40daeeb5c1fe12ba6078b1687ead62d0aeaa","tid":1785670,"uid":223643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-16T16:25:23.000Z","msg":"<img src=\"/assets/faces/pigxm/argue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/argue.gif\" class=\"hkgmoji\" />"},{"pid":"582cd6b84787bdcc5cbfef5d6f596b3544f0a424","tid":1785670,"uid":263648,"like":0,"dislike":0,"score":0,"quote":{"pid":"0059a8a3ae875aa33b8c3aa9753385ec15d50c79","tid":1785670,"uid":37971,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-16T14:22:52.000Z","msg":"<img src=\"https://na.cx/i/epu4op7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fepu4op7.jpg&h=9c29212e&s={SIZE}\" /><br />\n<br />\n<br />\n是咁的，小弟識人之前有幫手搞823同1018嘅人鏈<br />\n今次我都會落埋去幫手搞<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><br />\n<br />\n但係，好地地做乜無啦啦要出問卷?<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><br />\n<br />\n因為一班搞手分析過前兩次人鏈嘅概況：<br />\n823搞得咁成功，係因為組人鏈期間只有紅藍綠三線，手足就夠集中<img src=\"/assets/faces/dogxm/hehe.gif\" class=\"hkgmoji\" /><br />\n但去到1018，紅藍綠三線有啲駁唔埋之餘，仲要縮咗水<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n撇除文宣不足<br />\n三線以外同時有更多支線，都係一個因素<br />\n再加上前兩次係平日搞<br />\n但今次係除夕搞，日子唔同<br />\n而且又係831四個月<br />\n當然，我哋會度一度時間畀手足去太子<br />\n<br />\n雖然我哋已經初步定好路線<br />\n但係我哋目前仍然難以掌握有幾多人參加<br />\n人流會集中喺邊區<br />\n所以仲未決定到最終路線會喺邊段同會有幾長<br />\n<br />\n但問題係，<span style=\"color: red;\">問卷依家嚴重唔夠人</span><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n所以希望一眾巴絲可以幫手填一填<br />\n<a href=\"https://forms.gle/sv2jFbAEx9TfksW99\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2Fsv2jFbAEx9TfksW99&d=dVEf9brN%2BTtwApumOSMW7qpJ2kzo9njAZIZZFH2Kh%2FI%3D&h=e303819a\" data-auto-link target=\"_blank\">https://forms.gle/sv2jFbAEx9TfksW99</a><br />\n我哋作為搞手，都想搞得好啲畀大家參與㗎<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n最後，我想講多少少<br />\n有人話人鏈無用，集氣無用，唔好再搞<br />\n但係<br />\n<span style=\"color: gold;\">大家記唔記得元旦見?<br />\n大家仲想唔想keep住時代革命嗰團火?<br />\n如果想嘅，we need to do something<br />\n畀和勇知道，畀香港人知道<br />\n<span style=\"color: red;\">抗爭仍然未降溫，我哋仲抗爭緊呀</span><br />\n如果元旦見係需要士氣嘅<br />\n咁1231，<span style=\"color: red;\">就等我哋幫大家打響頭炮，揭開除夕嘅序幕啦</span><br />\n好嗎?</span><br />\n<br />\n順帶一提<br />\n義工繼續招人<br />\n<img src=\"https://na.cx/i/5XRVu6Y.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F5XRVu6Y.jpg&h=6e2bb680&s={SIZE}\" /><br />\n有興趣嘅，可以去我哋嘅tg channel同我哋聯絡<br />\n<br />\n12.31除夕夜之路channel<br />\n<a href=\"http://www.t.me/HKconnectchannel1231\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.t.me%2FHKconnectchannel1231&d=dVEf9brN%2BTtwApumOSMW7qpJ2kzo9njAZIZZFH2Kh%2FI%3D&h=d5f8a479\" data-auto-link target=\"_blank\">http://www.t.me/HKconnectchannel1231</a><br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: xx-large;\">光復香港<br />\n時代革命<br />\n和勇不分<br />\n齊上齊落</span></span>"},"citedBy":0,"replyTime":"2019-12-16T16:29:21.000Z","msg":"<img src=\"/assets/faces/pigxm/snowhat.gif\" class=\"hkgmoji\" />"}]}