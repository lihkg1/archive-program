3321/%E4%B8%8A%E6%B0%B4-%E5%8D%83%E8%90%AC%E5%85%83%E5%85%AC%E5%BB%81-%E6%9C%89%E5%B9%BE%E5%B7%B4%E9%96%89-%E7%94%A8%E5%AE%B6%E9%BB%9E%E8%A9%95-%E6%8A%BD%E9%A2%A8%E5%B7%AE-%E9%9A%94%E7%B1%AC%E5%B1%99%E7%B7%8A%E5%A5%BD%E8%87%AD\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E7%25A4%25BE%25E5%258D%2580%25E5%25B0%2588%25E9%25A1%258C%2F93321%2F%25E4%25B8%258A%25E6%25B0%25B4-%25E5%258D%2583%25E8%2590%25AC%25E5%2585%2583%25E5%2585%25AC%25E5%25BB%2581-%25E6%259C%2589%25E5%25B9%25BE%25E5%25B7%25B4%25E9%2596%2589-%25E7%2594%25A8%25E5%25AE%25B6%25E9%25BB%259E%25E8%25A9%2595-%25E6%258A%25BD%25E9%25A2%25A8%25E5%25B7%25AE-%25E9%259A%2594%25E7%25B1%25AC%25E5%25B1%2599%25E7%25B7%258A%25E5%25A5%25BD%25E8%2587%25AD&d=ZahK9au6JYDyKCuDEpipf3jCBy0DQDxxpn8JrxrWeYE%3D&h=ed6a720a\" data-auto-link target=\"_blank\">https://www.hk01.com/%E7%A4%BE%E5%8D%80%E5%B0%88%E9%A1%8C/93321/%E4%B8%8A%E6%B0%B4-%E5%8D%83%E8%90%AC%E5%85%83%E5%85%AC%E5%BB%81-%E6%9C%89%E5%B9%BE%E5%B7%B4%E9%96%89-%E7%94%A8%E5%AE%B6%E9%BB%9E%E8%A9%95-%E6%8A%BD%E9%A2%A8%E5%B7%AE-%E9%9A%94%E7%B1%AC%E5%B1%99%E7%B7%8A%E5%A5%BD%E8%87%AD</a><br />\n你就明白保皇黨幾9顛<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fd924b0394a1dc8f991bd7cf2eea0910f67a5b95","tid":1763572,"uid":289708,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-30T12:53:24.000Z","msg":"cap水cap到如入無人之境"},{"pid":"664abf80604761c652effe4efeac7f770fcb0373","tid":1763572,"uid":120955,"like":5,"dislike":2,"score":3,"citedBy":1,"replyTime":"2019-11-30T12:53:39.000Z","msg":"維修保養清潔42萬預算差唔多<br />\n正常男女兩個清潔都三十萬  雖然判上判唔知去咗邊<br />\n工程維修預算每月一萬好合理"},{"pid":"b5a97d2909d75e9f850f6a5425803e09d5270110","tid":1763572,"uid":193217,"like":11,"dislike":0,"score":11,"quote":{"pid":"611d30e707fd369271540529b2118c49edeb6e4a","tid":1763572,"uid":47256,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-11-30T12:52:00.000Z","msg":"裏面鑲鑽石？<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-30T12:53:52.000Z","msg":"走到正門，乍看與普通公廁無疑，新淨，淡黃和淺綠色的色調與旁邊的涼亭相配，但沒有鑲金。女廁有4個廁格；男廁為3個尿兜、2個廁格，各有一更衣室。男女廁中間有一間傷殘人士廁所和清潔房。入內，廁格配以潔白紅外線感應馬桶，兩旁各一扶手。另外，設計圖顯示有入牆式皂液器，紅外線感應水龍頭，女廁更有嬰兒軟墊。<br />\n<br />\n網民：用料差 如廁不舒暢<br />\n<br />\n用家又有何評價呢？有滿心期待的網民指享用「千萬公廁」時，以為會使用TOTO（日本第一衛浴品牌，有温水洗淨功能座廁就係佢發明！），翻查發現馬桶、尿兜、 洗手盆牌子均為RENE，原產地為中國。另，水喉出水「好慢，洗兩下又停水」，扶手的塑膠質差，易鬆。抹布雖為著名本土牌子「祝君早安」，網民仍形容「以為去咗赤柱探監」。網民要求太腌臢？事實上，同為上水，單車匯合中心公廁潔具全均使用日本牌子TOTO。<br />\n<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"11acd5a7db4bc2bfb456c9eab38c3d26c6231495","tid":1763572,"uid":193217,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-30T12:55:44.000Z","msg":"男網民繼續點評：「只得兩格屙屎，隔音好差，冇抽風，冇冷氣，隔離屙緊我好臭......無得沖涼， 點值一千萬？50萬差不多。」<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"07eaea86823051aca1766a936a27c91f3278d3d7","tid":1763572,"uid":111751,"like":2,"dislike":1,"score":1,"citedBy":2,"replyTime":"2019-11-30T13:04:11.000Z","msg":"可能係scheduled area<br />\n支莊成百9幾米深"},{"pid":"aef8968bb52ac5fc4e6e7f2efcee81e802b78292","tid":1763572,"uid":151324,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-30T13:06:59.000Z","msg":"周生3隻字都值400萬"},{"pid":"2880b814070fbe48a873cd53a00135659d072a04","tid":1763572,"uid":61494,"like":1,"dislike":0,"score":1,"quote":{"pid":"07eaea86823051aca1766a936a27c91f3278d3d7","tid":1763572,"uid":111751,"like":2,"dislike":1,"score":1,"citedBy":2,"replyTime":"2019-11-30T13:04:11.000Z","msg":"可能係scheduled area<br />\n支莊成百9幾米深"},"citedBy":0,"replyTime":"2019-11-30T13:08:11.000Z","ms