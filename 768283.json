ac23bfe11e86c2","tid":768283,"uid":189695,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-05T12:03:42.000Z","msg":"一定有人考唔到政府，私人既洗乜驚<br />\n<br />\n如果驚既，私人公司要反省下點解。工時，錢，前途<br />\n<br />\n有d私人公司/大公司好刻薄"},{"pid":"edff4252f5c7904a8bc5bd2de1859b909d389f5c","tid":768283,"uid":170173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-05T12:10:21.000Z","msg":"全民政府工"},{"pid":"b432f9616223536268080c0732dd48160f9a92f1","tid":768283,"uid":130298,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-08-05T12:17:31.000Z","msg":"點解你會覺人人考政府工？世界唔係得連登"},{"pid":"93c57a78647e8c5792da4811e635bb2b2ab10e9d","tid":768283,"uid":29497,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-05T12:19:12.000Z","msg":"做乜都係講際遇姐"},{"pid":"4f480105a4a7e114b8252d87345eed9bcd212390","tid":768283,"uid":29497,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-05T12:21:17.000Z","msg":"有個紀律部隊散仔入左去 同我講你唔入黎 人生就會係失敗<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <br />\n心諗你只係一個著住制服既保安<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 0技能0技術<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f50b12ee563f0ae936a8c3d30a7fb94d08b22c70","tid":768283,"uid":59283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-05T12:26:58.000Z","msg":"1.內地專才<br />\n2.總有人頂唔順走返出黎私人市場"}]}