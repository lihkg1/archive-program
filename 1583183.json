叫美國唔好干預香港但自己叫美國修改法案<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"89d77ca57c08ca40094850013942a5211ffb8669","tid":1583183,"uid":83052,"like":0,"dislike":0,"score":0,"quote":{"pid":"c6ad51d85dcff5469663a977a6fc307d513846f5","tid":1583183,"uid":37528,"like":60,"dislike":0,"score":60,"citedBy":2,"replyTime":"2019-09-20T13:06:38.000Z","msg":"可以改變你既現狀就足夠了<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-20T13:17:46.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"2df6ec775475ac1bd571e6dd670cc82a7c9b1b78","tid":1583183,"uid":74182,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-20T13:17:50.000Z","msg":"呢排日日都見佢吠<img src=\"/assets/faces/mf/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4293465f8aa0b0a3dd2cce394dfe28f45918fd2d","tid":1583183,"uid":130382,"like":2,"dislike":0,"score":2,"quote":{"pid":"fba7bfab88520b22d6f1374d9c5ffc2de1ce70a9","tid":1583183,"uid":78947,"like":6,"dislike":0,"score":6,"quote":{"pid":"f7351987e0165e50016d3cc9f64de497967c497b","tid":1583183,"uid":48083,"like":59,"dislike":0,"score":59,"citedBy":3,"replyTime":"2019-09-20T13:05:54.000Z","msg":"<img src=\"https://na.cx/i/g58XdKW.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fg58XdKW.png&h=d0157887&s={SIZE}\" />"},"citedBy":2,"replyTime":"2019-09-20T13:09:36.000Z","msg":"隔空罵戰<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-20T13:18:08.000Z","msg":"罵戰？<br />\n你太睇得起希師奶....."},{"pid":"1fea668618258d33e017ed3b07fbd0a4ba119975","tid":1583183,"uid":130382,"like":1,"dislike":0,"score":1,"quote":{"pid":"a9fd043d7c405c915ae76ab53d3b0f387e14932c","tid":1583183,"