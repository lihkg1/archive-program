e311f7b46b519633c8b4788049392ade881f795","tid":1593254,"uid":74412,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T11:03:50.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"8d2cf0641904a143e338b14beb9bc4dc0079ace3","tid":1593254,"uid":82920,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T17:32:13.000Z","msg":"幫推<img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f45b624c529789bedbd5bafdf747ff6b732646bf","tid":1593254,"uid":88503,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T17:38:02.000Z","msg":"感激"},{"pid":"c6c4277278794bed595c5b4f96793edc39cad8b4","tid":1593254,"uid":201678,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T17:39:11.000Z","msg":"一人一磚係要個震攝力<br />\n<br />\n羅馬野史 一人一磚 護己救人 口號同死線同樣重要<br />\n<a href=\"https://lih.kg/1603717\" data-auto-link target=\"_blank\">https://lih.kg/1603717</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"e62ebf5bdeba8592eede19a006d3203d02822a82","tid":1593254,"uid":261478,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T17:40:15.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"9fe6a44b98a3bdf839aa4885b9e85eb80644a6c2","tid":1593254,"uid":867,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T18:02:35.000Z","msg":"巴打好野！"},{"pid":"49ff96621b402b81ab6f949b2a7f1477b2e3912d","tid":1593254,"uid":867,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T18:02:47.000Z","msg":"聽日見啦大家！"},{"pid":"4cd3bf10c04f20702ba58ce64ca2120eb0e2e01a","tid":1593254,"uid":12929,"like":0,"dislike":0,"score":0,"quote":{"pid":"46d08485fea4f580f986ecc7f116efcfdcbee3a1","tid":1593254,"uid":116953,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-09-25T03:53:44.000Z","msg":"<a href=\"https://www.pinterest.com/hongkongProtesters/boards/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.pinterest.com%2FhongkongProtesters%2Fboards%2F&d=ZBayvnjX3omFcj6xyood9Cbpne3YAKjwmabJhOlqIzs%3D&h=dbe73904\" data-auto-link target=\"_blank\">https://www.pinterest.com/hongkongProtesters/boards/</a><br />\n由於越來越多文宣圖既關係<br />\n我將整個board拆散再分類方便大家搵圖<br />\n<img src=\"https://na.cx/i/EwGZi4X.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEwGZi4X.png&h=2cb8d24e&s={SIZE}\" /><br />\n因為係文宣我就依宣傳對象分類<br />\n <br />\n<strong><span style=\"color: orange;\">活動日程 - 對象：活動宣傳</span></strong><br />\n所有活動相關文宣依日期排序，<span style=\"color: gold;\">包括所有語言</span>，部份只有一張文宣既活動無開 section，碌落D就會見到<br />\n<br />\n<span style=\"color: orange;\"><strong>行動/支援/打氣 - 對象：手足</strong></span><br />\n所有長期行動，比手足睇既支援/打氣文宣，懶人包，插圖/漫畫，緊急熱線，願榮光歸香港，民間記者會，罷買，black bloc，以武制暴...等等<br />\n<br />\n<span style=\"color: orange;\"><strong>港共警暴黑社會 - 對象：淺黃/正常人</strong></span><br />\n所有警暴濫權，打人殺人扮示威者，新屋嶺，黑警合作，監警會，MTR黨鐵，太子恐襲，元朗恐襲，港共林鄭政府，黑社會藍絲，白色恐怖，智能監控，社會評級，性暴力，毒氣彈，赤納粹，Yellow Object...等等<br />\n<br />\n<strong><span style=\"color: orange;\">中立民生/柔性文宣 - 對象：淺藍/港豬/廢老/貼牆</span></strong><br />\n適合比D自稱中立人士睇既文宣，都適合貼牆，防藍撕，經濟牌，親情牌，赤化，失去自由，長輩圖...等等<br />\n<br />\n<span style=\"color: orange;\"><strong>International Artwork - 對象：外國人</strong></span><br />\n就係國際文宣，所有非活動類既外語文宣，topic用左英文方便外國人直接睇，5 demands, Yellow Object, Police State, Sun UK Ling, Chinazi, Sexually Harassed, How to help HK....等等<br />\n<br />\n仲有文宣相片同GIF由於唔係主力收集所以數量不足，有機會再加多D<br />\n大家除左拎來用之外，都可以根據文宣數量去決定邊D文宣需要做多D<br />\n分類方面仲未完美但我會不停改善<br />\n各位要加油<br />\n<br />\n<br />\n光復香港 時代革命"},"citedBy":0,"replyTime":"2019-09-30T18:48:47.000Z","msg":"有冇呢張 <br />\n<br />\n<img src=\"https://na.cx/i/EnrrKxx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEnrrKxx.jpg&h=581a184c&s={SIZE}\" />"},{"pid":"c2658ce2788646df0a9c7c2304aba89866910623","tid":1593254,"uid":276821,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T18:49:51.000Z","msg":"辛苦晒"},{"pid":"4b94aa4c73e9497a1f18311c062020f7ff72e9d2","tid":1593254,"uid":50218,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-30T21:01:29.000Z","msg":"不愧為文宣王<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}