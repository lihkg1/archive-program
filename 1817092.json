:33437,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-08T23:33:28.000Z","msg":"push"},{"pid":"225c5b82b9a91d7024cb115d9a9ee8597aa32b2b","tid":1817092,"uid":127575,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-08T23:33:59.000Z","msg":"政府又出聲明<br />\n不過又係廢話<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"6a02b662ed89531c92e785aac3c02b62be2c4597","tid":1817092,"uid":36742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-08T23:39:17.000Z","msg":"推<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"fcbb4882cb55806aca36ea43dabdb3861ea3e328","tid":1817092,"uid":29555,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-08T23:46:35.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d1854cea91c06610d5af9815c0f3eebd035bbbd8","tid":1817092,"uid":254383,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-09T00:28:46.000Z","msg":"等國務院報告，就可以正式入名單<img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"}]}