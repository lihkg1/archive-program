ke":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:01:38.000Z","msg":"推"},{"pid":"512f6203abeb6fb734f42923d2ac005ce5eb3ca6","tid":1252000,"uid":53612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:02:01.000Z","msg":"推"},{"pid":"ee6aaf167d04249f88c6a1d8f1dbedefbf29fe37","tid":1252000,"uid":21887,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:02:16.000Z","msg":"push"},{"pid":"fbd6509ec99258d8129e1cd4eea7a067846478f1","tid":1252000,"uid":264394,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:27:41.000Z","msg":"推"},{"pid":"0124f1d31fda0c76e8eccbf5c02cb498dee3766f","tid":1252000,"uid":264394,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:27:51.000Z","msg":"推"},{"pid":"b789dd7b48a5f5a442dba14ad37a6df2067feb23","tid":1252000,"uid":264394,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:28:02.000Z","msg":"推"},{"pid":"e56fb4a2960081003fb882d7cfea10455db31179","tid":1252000,"uid":258696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:28:06.000Z","msg":"捱"},{"pid":"2a17cecdd798cde8662d98cbe8c0acdd8f5e4a92","tid":1252000,"uid":259017,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:28:15.000Z","msg":"推"},{"pid":"1529e87708c257c69b00497b6ac80bc78775fc95","tid":1252000,"uid":9348,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:34:51.000Z","msg":"緊接住<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n[突發] 香港公園開始多人<br />\n<a href=\"https://lih.kg/1252253\" target=\"_blank\">https://lih.kg/1252253</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n【毋忘沙士抗疫英雄】<br />\n本年紀念抗疫英雄將如常舉行，誠邀公眾出席向一眾醫護人員致敬。<br />\n<span style=\"color: red;\"><br />\n日期：二零一九年六月二十三日（星期日）<br />\n時間：下午七時半至八時正<br />\n地點：香港公園太極園</span><br />\n流程：<br />\n七時半 － 自發市民將於太極園派發自行印製之單張，上面刊有當年歷史，供出席者回顧抗疫事蹟。期間市民可到抗疫英雄紀念碑前獻花及追思。<br />\n八時正 － 默哀儀式<br />\n<br />\n主辦單位：無。鼓勵公眾自發參與和派發單張。<br />\n注意事項：誠邀熱心市民自備傳單或鮮花到現場派發，亦歡迎市民無分地點，當晚八時一同悼念。<br />\n<br />\n*************************************************************<br />\n二零零三年，沙士疫症蔓延香港，幸得一眾醫護人員，緊守崗位，得以戰勝疫病。 二零零三年六月二十三日，世界衛生組織終從疫區名單剔除香港，香港人戰勝沙士的標誌一步，惟沙士疫症累計奪走二百九十九位港人寶貴生命，當中八位為醫護人員。是次活動希望藉六二三的歷史意義，重提當年抗疫歷史，紀念殉職之醫護人員外，亦感激抗疫時間香港全體醫護人員的無私付出，藉此呼籲香港人尊重並銘記歷史，毋負他們的付出和犧牲。<br />\n<br />\n我們將準備少量單張和鮮花，力量雖少，希望在此呼籲大家自發參與，有心人士可自備載有當年歷史的單張或鮮花到場派發，讓公眾可以重溫歷史，緬懷過去。我們堅信香港人不會愧對英靈，讓歷史從公眾認知中湮滅，往後不須架設高台，不限時間和地點，香港人都會本著良知，自發悼念，銘記救人事蹟，並將他們無私奉獻的精神傳承今後所有香港人。<br />\n<br />\n英雄無名，謹此向香港所有無私付出的醫護人員致敬。"},{"pid":"11c8d5900ad400299f141603419ea398fcad3168","tid":1252000,"uid":84457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T04:27:56.000Z","msg":"推！"},{"pid":"70dc060beccfb4e6d9ee13bde66b11bb303092c0","tid":1252000,"uid":84457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T04:31:46.000Z","msg":"推"},{"pid":"a95c0ae2857ac68e9a824a9fe8a0669e593e1d60","tid":1252000,"uid":84457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T04:35:54.000Z","msg":"推"},{"pid":"b368ff46d30ef22a40d886353bbea7fc28d803c3","tid":1252000,"uid":84457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T04:36:04.000Z","msg":"推"},{"pid":"1326d090a3533e86d87cdc71b6c3aca76d6cdc82","tid":1252000,"uid":261669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T04:44:56.000Z","msg":"推"},{"pid":"5f6b5bd58c85bad73d30b0b6889ab09a8a0824a7","tid":1252000,"uid":84457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T05:07:03.000Z","msg":"推"},{"pid":"d3149eb69a84c4d5476be89af630cc8c86e9cb4f","tid":1252000,"uid":84457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T05:07:13.000Z","msg":"推"},{"pid":"6c5e01f09fc263ee0fb1fb23815a171c53481d0a","tid":1252000,"uid":84457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T05:07:23.000Z","msg":"推"},{"pid":"477fa655df758d4017b4cbbd471cb1626130e488","tid":1252000,"uid":84457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T