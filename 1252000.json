g src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n星期日 8:00pm, 幫手同friend宣傳下！<br />\n<br />\n<br />\n幫手推！<br />\n[齊屌黑警！]追究黑警濫權集會！<br />\n<a href=\"https://lih.kg/1252000\" data-auto-link target=\"_blank\">https://lih.kg/1252000</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"05b8662bb5a174b0bab6ffe572d2492cb8f5c9b8","tid":1252000,"uid":84457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T11:40:48.000Z","msg":"推"},{"pid":"68a03bd7a68aa6d8447995b9d1259ad8a8c62bee","tid":1252000,"uid":84457,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T11:40:58.000Z","msg":"推"}]}