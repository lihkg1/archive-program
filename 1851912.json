>\n香港人再冇言論自由<br />\n同蝗國一鳩樣"},{"pid":"7e9247a3599b7468fc333ba2e9180651a52b1bb6","tid":1851912,"uid":258106,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T17:29:14.000Z","msg":"罷工啦屌<img src=\"/assets/faces/lny/clown.gif\" class=\"hkgmoji\" />"},{"pid":"c1a73b79ab41a88d18c64a1695f33d165075cff3","tid":1851912,"uid":1249,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-30T17:39:56.000Z","msg":"笑到仆街<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" />可以做潮文"}]}