ig/mock.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-30T06:09:22.000Z","msg":"通常電影有三部曲"},{"pid":"9637c392f695878cab415531c09c28a1d1959ece","tid":1762022,"uid":28435,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-30T06:14:57.000Z","msg":"古狗 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1a9ecc3c3d1f3401d109500e65e0d3f0dd42d8d6","tid":1762022,"uid":173952,"like":7,"dislike":1,"score":6,"quote":{"pid":"c4e32d9a7f669df6be98e3df2dd647f65e7d3dc9","tid":1762022,"uid":134997,"like":0,"dislike":0,"score":0,"quote":{"pid":"6e0092172335bc87633aa5e4db6d6e4290f859d1","tid":1762022,"uid":52881,"like":50,"dislike":2,"score":48,"citedBy":2,"replyTime":"2019-11-29T09:51:42.000Z","msg":"咁撚柒都拎出來做紀錄片<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-30T06:09:22.000Z","msg":"通常電影有三部曲"},"citedBy":0,"replyTime":"2019-11-30T06:16:31.000Z","msg":"今年繼續拍<br />\n美斯（Lionel Messi）用利物浦的事來提醒球隊"},{"pid":"1c102d369ea3dcdb27a00a47ae8ff59b4138dd3b","tid":1762022,"uid":173952,"like":2,"dislike":0,"score":2,"quote":{"pid":"9637c392f695878cab415531c09c28a1d1959ece","tid":1762022,"uid":28435,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-30T06:14:57.000Z","msg":"古狗 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-30T06:18:02.000Z","msg":"離開利物浦去巴塞，為左拎歐聯"},{"pid":"a2b6c3a2a408014f7800ab534705d56c1bfab39a","tid":1762022,"uid":173952,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-11-30T06:27:30.000Z","msg":"比基諷刺皇馬<br />\n<br />\n  在近些年的西班牙國家打比上，巴塞在戰績上具有優勢，作為死敵，巴塞球員也不忘挖苦皇馬。<br />\n<br />\n  最近，巴塞新上映的紀錄片《比賽日》中，就讓人們看到了比基在更衣室裡諷刺皇馬的一幕。<br />\n<br />\n  這一幕發生在上季西班牙盃次回合，巴塞3-0戰勝並淘汰皇馬之後。比基在更衣室裡和隊友們說：「贏皇馬已經成了習慣，踢個3-0、4-0、5-0都無甚麼意思了。」"},{"pid":"a7abd5fa834ad43c57fa64a9952633cc3064a9c1","tid":1762022,"uid":252985,"lik