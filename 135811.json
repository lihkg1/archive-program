i%2FipZBa3.gif&h=ef41e894&s={SIZE}\" /><img src=\"https://na.cx/i/ipZBa3.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FipZBa3.gif&h=ef41e894&s={SIZE}\" /><img src=\"https://na.cx/i/ipZBa3.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FipZBa3.gif&h=ef41e894&s={SIZE}\" /><img src=\"https://na.cx/i/ipZBa3.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FipZBa3.gif&h=ef41e894&s={SIZE}\" /><img src=\"https://na.cx/i/ipZBa3.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FipZBa3.gif&h=ef41e894&s={SIZE}\" />"},{"pid":"31f361db84ac82f3ab74c2d019a380da2648d7f9","tid":135811,"uid":7814,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-26T16:00:20.000Z","msg":"真心on9....柒出國際<br />\n<br />\n好地地自己圍爐打飛機就算啦<br />\n<br />\n本來d 德國佬, 猶太佬都廢鳩事理你<br />\n而家得閒見到報紙一睇<br />\n就即刻覺得你班垃圾直頭係弱撚智"},{"pid":"2c327405341c7c41645dac885412c1cc42c840af","tid":135811,"uid":62257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-26T16:00:58.000Z","msg":"<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"cfd0d4e6cb824caaa53d4f411a08e2723cad9a62","tid":135811,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-26T16:10:46.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"3045ce75b94ad5b26e970c46e8ae696b79ab4822","tid":135811,"uid":3646,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-26T16:44:33.000Z","msg":"<img src=\"/assets/faces/lomoji/29.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/29.png\" class=\"hkgmoji\" />"},{"pid":"fba7ccf4fd9684135f2e5bd69076378db14a1f51","tid":135811,"uid":38255,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-26T17:13:15.000Z","msg":"Israel: Bad experience with international forces&nbsp;<br />\n<br />\nNitzan Kedar, <span style=\"color: red;\">26/02/17 10:25&nbsp;</span><br />\n<br />\nA senior official in Prime Minister Netanyahu's entourage said that during his visit to Australia, the PM managed to enlist Australia into the fight against the passing of anti-Israel resolutions at the United Nations and other international bodies.&nbsp;<br />\n<br />\nPrior to the departure of Netanyahu's plane this morning, the official said in a briefing to reporters that during the visit the Prime Minister answered the Australian foreign minister's question, saying that he felt that a Palestinian state will be established, but could only be possible if Israel retains security control of the entire territory.&nbsp;<br />\n<br />\nNetanyahu told the Australian Minister of Foreign Affairs, Julie Bishop, who questioned him on the matter that Israel does not want international forces to keep the peace in the region, the reason being that Israel's experience in dealing with these forces was not good in the past.&nbsp;<br />\n<br />\nMembers of the Prime Minister's entourage said that during the visit they agreed upon cooperation in many fields including security, economy, technology, and intelligence.&nbsp;<br />\n<br />\n<span style=\"color: red;\">The Prime Minister's plane left Australia on his way to Hong Kong for a stopover.&nbsp;Netanyahu will return to Israel on Monday morning.&nbsp;</span><br />\n<br />\n有無咁橋<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />以色列總理咁啱星期日<br />\n由澳洲飛返以色列中途係香港短暫降落，<br />\n好似因為回教國印尼唔俾以色列飛過佢空域兜遠左路要係香港入一入油<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /><br />\n咁啱撞正香港警察呢排得罪以色列<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"5bba5c912ea5c378c7f92ab299e0c8f49ada7f82","tid":135811,"uid":24227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-26T17:18:42.000Z","msg":"<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" />"},{"pid":"de8264c4850583d2e62efb9fbbe6a5cc94b8497a","tid":135811,"uid":56277,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-26T23:48:22.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"81c8b2d8ab33be8c38affccc109ee4c6ca55c812","tid":135811,"uid":80944,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-26T23:51:08.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"912d886174b26e12c381d5d5e32342ba70b8af3a","tid":135811,"uid":48022,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-26T23:51:08.000Z","msg":"<img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" />"},{"pid":"9c0159a1f3cdde7c7475744e0c7f5a69925d1a68","tid":135811,"uid":51937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-26T23:57:14.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"536f7c94f92d1162fea7dbc5a9ffde6bd32802e9","tid":135811,"uid":3976,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-27T00:09:17.000Z","msg":"一哥係咁割蓆話係私人言論唔代表警方<br />\n<br />\n至弊外國唔係咁諗呢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"457a53e10c59c607cd698e11505dd2d1fe0efd40","tid":135811,"uid":997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-27T00:18:08.000Z","msg":"<blockquote>一哥係咁割蓆話係私人言論唔代表警方<br />\n<br />\n至弊外國唔係咁諗呢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n盧偉聰條打靶仔呢d語言偽術唔係想過鬼佬關呀<br />\n成萬幾隻警犬叫好<br />\n根本話唔代表警方<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6bb03d0b6a9f83e62aec5b9215b5816b