faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" />"},{"pid":"d4e85c671f62a7c50f929ec9a33a1db0fe03c4df","tid":278693,"uid":44197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-10T16:45:38.000Z","msg":"<blockquote><blockquote>結衣女神 生日快樂<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/06/11/003946_cfec82c9c7009c594ecae05183e246ee.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F11%2F003946_cfec82c9c7009c594ecae05183e246ee.jpg&h=c01d6d0a&s={SIZE}\" /></blockquote><br />\n<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\n其實有一張係偽毒源<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n不過唔係因為結衣，我應該唔會咁勤力畫畫！<br />\n多謝結衣Bb<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"ff44b0b6b77ee94729178cf7109222f91bc9fa3e","tid":278693,"uid":2022,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-10T17:12:31.000Z","msg":"此回覆已被刪除"},{"pid":"eb06dd7f628c0d0fcf45efd8380b79fcd125f194","tid":278693,"uid":37985,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-10T17:14:53.000Z","msg":"又開分流？ 再講多次先<br />\n<br />\n<span style=\"font-size: xx-large;\">生日快樂啊結衣<img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" /> </span>"},{"pid":"a258a4fda6ab8ec344c6ec44bec360792054d6f0","tid":278693,"uid":78411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-10T17:16:14.000Z","msg":"<blockquote>同一日<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /></blockquote><br />\n你又係今日?"},{"pid":"5a1ece869f25e35ff9e4ac9099af7b385f6a8235","tid":278693,"uid":33422,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-10T17:16:55.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c27f35803dc9396f830456ac9ad32c353b420e93","tid":278693,"uid":38180,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-10T17:17:48.000Z","msg":"<blockquote><blockquote><blockquote>結衣女神 生日快樂<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/06/11/003946_cfec82c9c7009c594ecae05183e246ee.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F11%2F003946_cfec82c9c7009c594ecae05183e246ee.jpg&h=c01d6d0a&s={SIZE}\" /></blockquote><br />\n<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\n其實有一張係偽毒源<img src=\"/assets/faces/big/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n不過唔係因為結衣，我應該唔會咁勤力畫畫！<br />\n多謝結衣Bb<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /></blockquote><br />\n畫左咁多<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n我都係得3幅結衣Bb"},{"pid":"a4cacb6c95442005758ad6da969f2ed17b7882ad","tid":278693,"uid":86378,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-06-10T17:19:10.000Z","msg":"<div style=\"text-align: center;\"><strong><span style=\"font-size: x-large;\"><span style=\"color: violet;\">結衣BB</span><span style=\"color: red;\">生</span><span style=\"color: blue;\">日</span><span style=\"color: green;\">快</span><span style=\"color: gold;\">樂</span></span></strong></div><br />\n<br />\n  結衣bb, 仲記得我地好細個已經相識，每次妳生日或者我生日我哋都會買生日蛋糕送俾對方<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 而且我哋都會靜靜雞準備一份禮物送俾對方<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> <br />\n  <br />\n我仲記得有一次，好似係我哋11歲嘅時候。我知道妳好鍾意小動物，但係我哋爹哋媽咪又唔比養，於是我送咗一隻狗狗毛公仔俾你<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /> 就算到咗而家我仲歷歷在目記得好清楚當你見到隻毛公仔嗰陣時燦爛又可愛嘅笑容。你話你將來大個左一定會養狗仔，於是我哋就喺度商量第時你養隻狗叫咩名<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> Coco, coco, 你個名就係咁黎架啦<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /> <br />\n<br />\n就算到咗而家，妳係日本發展得如火如荼，或許已經冇乜心機記住我。但我想同妳講，就算發生咩事我都會支持你<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> 最後祝你生日快樂<img src=\"/assets/faces/lomoji/12.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/09.png\" class=\"hkgmoji\" /> <br />\n我哋將來一定可以在次一齊生活嘅<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/06/11/011323_433ea76b53419513cb2605346f863c62.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F11%2F011323_433ea76b53419513cb2605346f863c62.jpg&h=7c024c23&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/06/11/011346_1194200249734aabea1706fe7063e573.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F11%2F011346_1194200249734aabea1706fe7063e573.jpg&h=84045735&s={SIZE}\" />"},{"pid":"ffe899e83151a8fd25522b301d31043dd7c8356f","tid":278693,"uid":5700,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-10T17:26:22.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a6b8a398b6870f810f1897568ee7f0e8fa5cc815","tid":278693,"uid":44197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-10T17:27:51.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>結衣女神 生日快樂<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/06/11/003946_cfec82c9c7009c594ecae05183e246ee.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F06%2F11%2F003946_cfec82c9c7009c594ecae05183e246ee.jpg&h=c01d6d0a&s={SIZE}\" /></blockquote><br />\n<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\