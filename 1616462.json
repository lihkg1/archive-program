BA%E7%94%B3%E8%AB%8B%E5%85%A5%E5%8F%B0%E8%AD%89%E6%96%B0%E5%A2%9E%E4%BB%BB%E8%81%B7%E5%96%AE%E4%BD%8D%E7%AD%89%E5%BF%85%E5%A1%AB%E6%AC%84%20%E5%8F%B0%EF%BC%9A%E4%BE%8B%E8%A1%8C%E6%9B%B4%E6%96%B0%E7%84%A1%E9%87%9D%E5%B0%8D%E6%80%A7?mtc=20023\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fchina.hket.com%2Farticle%2F2465158%2F%25E3%2580%2590%25E5%258F%25B0%25E7%2581%25A3%25E6%25B6%2588%25E6%2581%25AF%25E3%2580%2591%25E6%25B8%25AF%25E4%25BA%25BA%25E7%2594%25B3%25E8%25AB%258B%25E5%2585%25A5%25E5%258F%25B0%25E8%25AD%2589%25E6%2596%25B0%25E5%25A2%259E%25E4%25BB%25BB%25E8%2581%25B7%25E5%2596%25AE%25E4%25BD%258D%25E7%25AD%2589%25E5%25BF%2585%25E5%25A1%25AB%25E6%25AC%2584%2520%25E5%258F%25B0%25EF%25BC%259A%25E4%25BE%258B%25E8%25A1%258C%25E6%259B%25B4%25E6%2596%25B0%25E7%2584%25A1%25E9%2587%259D%25E5%25B0%258D%25E6%2580%25A7%3Fmtc%3D20023&d=Sqlr%2BNOTUp1GXDSzM%2FaCEhSGsERVwMiaoyLN1PNQjS0%3D&h=4eb1b12c\" target=\"_blank\">https://china.hket.com/article/2465158/%E3%80%90%E5%8F%B0%E7%81%A3%E6%B6%88%E6%81%AF%E3%80%91%E6%B8%AF%E4%BA%BA%E7%94%B3%E8%AB%8B%E5%85%A5%E5%8F%B0%E8%AD%89%E6%96%B0%E5%A2%9E%E4%BB%BB%E8%81%B7%E5%96%AE%E4%BD%8D%E7%AD%89%E5%BF%85%E5%A1%AB%E6%AC%84%20%E5%8F%B0%EF%BC%9A%E4%BE%8B%E8%A1%8C%E6%9B%B4%E6%96%B0%E7%84%A1%E9%87%9D%E5%B0%8D%E6%80%A7?mtc=20023</a>"},"citedBy":1,"replyTime":"2019-10-03T13:48:46.000Z","msg":"<img src=\"https://na.cx/i/i3iidxv.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fi3iidxv.jpg&h=aaace6a4&s={SIZE}\" />"},{"pid":"372230a7b85b0165c25c2eae2978fb226cde4699","tid":1616462,"uid":35790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-03T16:55:43.000Z","msg":"pish"},{"pid":"a8238ee6c6158d16857903e0911193b7c56af8e5","tid":1616462,"uid":301989,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1925ec48a9a063e13c37f5d107940b17fed91fe","tid":1616462,"uid":266741,"like":1,"dislike":0,"score":1,"quote":{"pid":"1844123383b4147d01cf472f982480305da696d8","tid":1616462,"uid":35790,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-03T12:27:22.000Z","msg":"【台灣消息】港人申請入台證新增任職單位等必填欄 台：例行更新無針對性<br />\n<br />\n2019/10/03 <br />\n<br />\n港人申請到台灣的網絡簽證頁面，近期新增多項必填欄目，包括任職單位、職稱、預訂航班等。在台灣，陸委會發言人邱垂正今天表示，這是資訊系統的例行更新，並非針對特定對象管制。<br />\n<br />\n台灣陸委會今日舉行例行記者會，有傳媒問到，香港人申請到台灣的網路簽證頁面，近期增加包括入、出境日期、航班班次的欄目，職業欄更必須增填任職單位跟職稱，是否代表台灣有意加強限縮香港警方、公務員來台。<br />\n<br />\n若有不便 會檢討<br />\n<br />\n邱垂正表示，內政部移民署上月26日起實施例行資訊系統檢討更新，同時針對東南亞國家人民來台觀光，先行上網申辦簽證等各種系統，進行全面更新，並非針對特定對象管制。<br />\n<br />\n他強調，政府歡迎香港居民來台立場不變，會持續檢討相關的法規跟措施，如果措施有帶來不方便，政府會持續檢討更新。<br />\n<a href=\"https://china.hket.com/article/2465158/%E3%80%90%E5%8F%B0%E7%81%A3%E6%B6%88%E6%81%AF%E3%80%91%E6%B8%AF%E4%BA%BA%E7%94%B3%E8%AB%8B%E5%85%A5%E5%8F%B0%E8%AD%89%E6%96%B0%E5%A2%9E%E4%BB%BB%E8%81%B7%E5%96%AE%E4%BD%8D%E7%AD%89%E5%BF%85%E5%A1%AB%E6%AC%84%20%E5%8F%B0%EF%BC%9A%E4%BE%8B%E8%A1%8C%E6%9B%B4%E6%96%B0%E7%84%A1%E9%87%9D%E5%B0%8D%E6%80%A7?mtc=20023\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fchina.hket.com%2Farticle%2F2465158%2F%25E3%2580%2590%25E5%258F%25B0%25E7%2581%25A3%25E6%25B6%2588%25E6%2581%25AF%25E3%2580%2591%25E6%25B8%25AF%25E4%25BA%25BA%25E7%2594%25B3%25E8%25AB%258B%25E5%2585%25A5%25E5%258F%25B0%25E8%25AD%2589%25E6%2596%25B0%25E5%25A2%259E%25E4%25BB%25BB%25E8%2581%25B7%25E5%2596%25AE%25E4%25BD%258D%25E7%25AD%2589%25E5%25BF%2585%25E5%25A1%25AB%25E6%25AC%2584%2520%25E5%258F%25B0%25EF%25BC%259A%25E4%25BE%258B%25E8%25A1%258C%25E6%259B%25B4%25E6%2596%25B0%25E7%2584%25A1%25E9%2587%259D%25E5%25B0%258D%25E6%2580%25A7%3Fmtc%3D20023&d=Sqlr%2BNOTUp1GXDSzM%2FaCEhSGsERVwMiaoyLN1PNQjS0%3D&h=4eb1b12c\" target=\"_blank\">https://china.hket.com/article/2465158/%E3%80%90%E5%8F%B0%E7%81%A3%E6%B6%88%E6%81%AF%E3%80%91%E6%B8%AF%E4%BA%BA%E7%94%B3%E8%AB%8B%E5%85%A5%E5%8F%B0%E8%AD%89%E6%96%B0%E5%A2%9E%E4%BB%BB%E8%81%B7%E5%96%AE%E4%BD%8D%E7%AD%89%E5%BF%85%E5%A1%AB%E6%AC%84%20%E5%8F%B0%EF%BC%9A%E4%BE%8B%E8%A1%8C%E6%9B%B4%E6%96%B0%E7%84%A1%E9%87%9D%E5%B0%8D%E6%80%A7?mtc=20023</a>"},"citedBy":1,"replyTime":"2019-10-03T13:48:46.000