g src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"552dec47bff6a84f1c5a3939098102dc9236ce74","tid":1710934,"uid":31962,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T10:26:52.000Z","msg":"全港最大犯罪基地係警署<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"0376b5eec277ef99ac2634201e312b1fc4b782c3","tid":1710934,"uid":281787,"like":0,"dislike":0,"score":0,"quote":{"pid":"fe30eb07be52e87bd89b41ec1e355bb1cd764f39","tid":1710934,"uid":130626,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-11-12T09:15:18.000Z","msg":"警方舉行記者會，公共關係科高級警司江永祥主動回應警方進入大學校園範圍執法時表示，警方因應暴徒行為，積極採進入大學範圍採取驅散和拘捕行動，他強調不會容許香港任何一個地方變成罪犯窩藏地，即使沒有搜查令，《警例》賦予警方法定權力到包括學校、商場和港鐵站在内的處所拘捕。他強調，在《公安條例》下學校並非私人地方，依法辦事是警察責任和天職。<br />\n<br />\n江永祥表示，有暴徒早上在中大範圍内向警方防綫扔磚頭和汽油彈，警察在20分鐘推進和拘捕過程中，被30個汽油彈襲擊，有暴徒將龍門作為路障，甚至準備大批弓箭，又打爛私家車玻璃，噴上謀殺學生的字樣，他反問誰在搬龍門、誰在謀殺應該一清二楚。<br />\n<br />\n他又說，中大已經發聲明指有人破壞運動室門門鎖，拿走弓箭和標槍等極高殺傷力武器，警方樂見中大校方即時取回有關武器，避免暴徒濫用並襲擊任何人。<br />\n<img src=\"https://newsstatic.rthk.hk/images/mfile_1491613_1_20191112164026.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fnewsstatic.rthk.hk%2Fimages%2Fmfile_1491613_1_20191112164026.jpg&h=3ce3827d&s={SIZE}\" /><br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1491613-20191112.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1491613-20191112.htm&d=UyoO8KdNfTPb55o7yEEco9TLU9NF7cMiG%2FeCYohcYb8%3D&h=40434ec4\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1491613-20191112.htm&h=aecf6436\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1491613-20191112.htm</a>"},"citedBy":0,"replyTime":"2019-11-12T10:27:17.000Z","msg":"The Police Station, Quarters