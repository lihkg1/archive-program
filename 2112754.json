.gif\" class=\"hkgmoji\" />"},{"pid":"e5911113e367adea5142fdf4f6711ac96e3569e6","tid":2112754,"uid":49329,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-17T16:23:33.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"1772b6545e51028e45b617b2c40778dd63cbbd30","tid":2112754,"uid":51271,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-07-18T01:14:40.000Z","msg":"免費送肺炎"},{"pid":"85b7af8a104cfe336a5ec08f82f4733db35688ea","tid":2112754,"uid":51271,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-07-18T01:21:13.000Z","msg":"<a href=\"https://news.mingpao.com/pns/%e8%a6%81%e8%81%9e/article/20200718/s00001/1595010089167/%e8%8f%af%e5%a4%a7%e6%aa%a2%e6%b8%ac%e4%b8%ad%e5%bf%83%e7%96%91%e8%90%bd%e8%85%b3%e5%a4%a7%e5%9f%94%e5%b7%a5%e5%bb%88-%e8%a2%ab%e6%8c%87%e8%bf%91%e6%b0%91%e5%b1%85\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2F%25e8%25a6%2581%25e8%2581%259e%2Farticle%2F20200718%2Fs00001%2F1595010089167%2F%25e8%258f%25af%25e5%25a4%25a7%25e6%25aa%25a2%25e6%25b8%25ac%25e4%25b8%25ad%25e5%25bf%2583%25e7%2596%2591%25e8%2590%25bd%25e8%2585%25b3%25e5%25a4%25a7%25e5%259f%2594%25e5%25b7%25a5%25e5%25bb%2588-%25e8%25a2%25ab%25e6%258c%2587%25e8%25bf%2591%25e6%25b0%2591%25e5%25b1%2585&d=6SBmejzB2pOSQzgprEhHpVDHT90Y5dJ0llo76wtTvPU%3D&h=26322306\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2F%25e8%25a6%2581%25e8%2581%259e%2Farticle%2F20200718%2Fs00001%2F1595010089167%2F%25e8%258f%25af%25e5%25a4%25a7%25e6%25aa%25a2%25e6%25b8%25ac%25e4%25b8%25ad%25e5%25bf%2583%25e7%2596%2591%25e8%2590%25bd%25e8%2585%25b3%25e5%25a4%25a7%25e5%259f%2594%25e5%25b7%25a5%25e5%25bb%2588-%25e8%25a2%25ab%25e6%258c%2587%25e8%25bf%2591%25e6%25b0%2591%25e5%25b1%2585&h=e631cc13\" data-auto-link target=\"_blank\">https://news.mingpao.com/pns/%e8%a6%81%e8%81%9e/article/20200718/s00001/1595010089167/%e8%8f%af%e5%a4%a7%e6%aa%a2%e6%b8%ac%e4%b8%ad%e5%bf%83%e7%96%91%e8%90%bd%e8%85%b3%e5%a4%a7%e5%9f%94%e5%b7%a5%e5%bb%88-%e8%a2%ab%e6%8c%87%e8%bf%91%e6%b0%91%e5%b1%85</a><br />\n<br />\n大埔區議員文念志說，收到街坊通知太平工業園設立了「火眼實驗室」，他昨午約5時到場，見3樓A室設立了充氣實驗室等。他說未能確認實驗室是否已運作，稱看到試管等設備，實驗室內有人走動，亦有人裝修，他認為現場衛生環境不太好。<br />\n<br />\n文說實驗室上層為凍肉舖，下層有飯堂，擔心運送檢測樣本的安全性。他又說太平工業園附近為公屋大元邨，亦有居屋汀雅苑，憂慮運送樣本期間有否做足防護。<br />\n<br />\n華大基因開設的華昇診斷中心獲港府以直接採購服務方式，為本港高危群組檢測新冠病毒。但太平工業園的水牌所見，疑用作檢測中心的3樓仍標示為「大埔綉花工藝有限公司」。查冊發現單位屬大埔綉花工藝，之前租予一家水果商。本報記者在現場所見，室內仍放有水果箱。<br />\n<br />\n<br />\nonL9"},{"pid":"09898a21332be82d805d4cc14ac9db67ee4d81ed","tid":2112754,"uid":278524,"like":1,"dislike":1,"score":0,"quote":{"pid":"85b7af8a104cfe336a5ec08f82f4733db35688ea","tid":2112754,"uid":51271,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-07-18T01:21:13.000Z","msg":"<a href=\"https://news.mingpao.com/pns/%e8%a6%81%e8%81%9e/article/20200718/s00001/1595010089167/%e8%8f%af%e5%a4%a7%e6%aa%a2%e6%b8%ac%e4%b8%ad%e5%bf%83%e7%96%91%e8%90%bd%e8%85%b3%e5%a4%a7%e5%9f%94%e5%b7%a5%e5%bb%88-%e8%a2%ab%e6%8c%87%e8%bf%91%e6%b0%91%e5%b1%85\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2F%25e8%25a6%2581%25e8%2581%259e%2Farticle%2F20200718%2Fs00001%2F1595010089167%2F%25e8%258f%25af%25e5%25a4%25a7%25e6%25aa%25a2%25e6%25b8%25ac%25e4%25b8%25ad%25e5%25bf%2583%25e7%2596%2591%25e8%2590%25bd%25e8%2585%25b3%25e5%25a4%25a7%25e5%259f%2594%25e5%25b7%25a5%25e5%25bb%2588-%25e8%25a2%25ab%25e6%258c%2587%25e8%25bf%2591%25e6%25b0%2591%25e5%25b1%2585&d=6SBmejzB2pOSQzgprEhHpVDHT90Y5dJ0llo76wtTvPU%3D&h=26322306\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.mingpao.com%2Fpns%2F%25e8%25a6%2581%25e8%2581%259e%2Farticle%2F20200718%2Fs00001%2F1595010089167%2F%25e8%258f%25af%25e5%25a4%25a7%25e6%25aa%25a2%25e6%25b8%25ac%25e4%25b8%25ad%25e5%25bf%2583%25