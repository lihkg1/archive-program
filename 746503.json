ot;<br />\n<br />\n裁判官判即時監禁<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" /> <br />\n<br />\n<a href=\"http://www.881903.com/Page/ZH-TW/newsdetail.aspx?ItemId=685836&amp;csid=261_341\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.881903.com%2FPage%2FZH-TW%2Fnewsdetail.aspx%3FItemId%3D685836%26csid%3D261_341&d=7f2ZIAzAuNvc8Kmrht0lyTCdMQr7etzq9tFbjrA%2B72k%3D&h=247b4664\" target=\"_blank\">http://www.881903.com/Page/ZH-TW/newsdetail.aspx?ItemId=685836&amp;csid=261_341</a>"},{"pid":"6d35f5bdd82204cd4c1c16be3aac40a687d4c5a0","tid":746503,"uid":152123,"like":30,"dislike":0,"score":30,"quote":{"pid":"51733149cca7f3d86f639407e60b52829fc82e8a","tid":746503,"uid":51134,"like":0,"dislike":5,"score":-5,"citedBy":3,"replyTime":"2018-07-17T17:29:10.000Z","msg":"之前係咪有個城大生<br />\n初犯但係直接判監<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-17T22:00:49.000Z","msg":"三次犯案：重犯機會不大"},{"pid":"b42e9397ddfe801478b5345cf19f0d0bc78d4ecf","tid":746503,"uid":155732,"like":6,"dislike":0,"score":6,"quote":{"pid":"b4d825f2d48027e335995c8bc6f329fe41f306b7","tid":746503,"uid":161050,"like":4,"dislike":13,"score":-9,"citedBy":1,"replyTime":"2018-07-17T17:26:18.000Z","msg":"為何無論你 願意怎樣試 怎樣也不可抗拒去偷拍<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-17T22:02:47.000Z","msg":"弟兄<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"712fd7e8508f6e293958d5bfab9652cc083e75a3","tid":746503,"uid":51105,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-17T23:28:32.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d4c98ed9b5a36bb26818bb83eb18ef1c3d449173","tid":746503,"uid":70888,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-17T23:42:06.000Z","msg":"<img src=\"/assets/faces/normal/d