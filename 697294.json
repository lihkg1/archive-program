d":"db8e8538616934b53bef778ac83824d4a6684ad7","tid":697294,"uid":27597,"like":0,"dislike":0,"score":0,"quote":{"pid":"ac73eb7c4c3013a4e23b72c2297069b9439151f5","tid":697294,"uid":52984,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-11T01:01:07.000Z","msg":"我懷疑我咳傷咗個喉嚨 <br />\n琴晚瞓教咳到嘔出黎 我屌 成晚訓唔到係到咳<br />\n有咩方法止咳啊<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n我唔想咁後生肺結核<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-11T01:10:09.000Z","msg":"肺結核唔係到你想唔想<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n睇醫生照肺啦<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n無咳都可以有肺結核嫁<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"6fb58f08043768a24701cf49a1e8ca05d5372502","tid":697294,"uid":18844,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-06-11T01:10:43.000Z","msg":"先分寒/熱<br />\n<a href=\"http://www2.hkedcity.net/sch_files/a/lkc/lkc-tyl/public_html/food/food12.htm\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww2.hkedcity.net%2Fsch_files%2Fa%2Flkc%2Flkc-tyl%2Fpublic_html%2Ffood%2Ffood12.htm&d=l9VKxDsGp6iGW%2FHX6EPx8Mn%2FdpYTMnF8ODxps2tmzCA%3D&h=1df51004\" target=\"_blank\">http://www2.hkedcity.net/sch_files/a/lkc/lkc-tyl/public_html/food/food12.htm</a><br />\n<br />\n風咳<br />\n風咳多由寒冷空氣、煙味、油煙、塵埃、異味等刺激。風能作癢，所以會引致咽喉部痕癢，咳嗽起病快，病癒也快，常見有咳嗽、咽癢、無痰等症狀。<br />\n<br />\n食療：紫蘇粥<br />\n<br />\n​材料 : 紫蘇葉15克，大米30克，清水和紅糖適量。<br />\n<br />\n做法 : 以清水加大米放入鍋中煮粥，粥成時加入紫蘇葉稍煮，再加入紅糖攪勻即成。<br />\n<br />\n功能 : 和胃解表止咳。<br />\n<br />\n紫蘇葉味辛，性溫，有開宣肺氣，散寒解表、行氣寬中的功效。紫蘇葉能擴張毛細血管，刺激汗液分泌而發汗，其浸液對流感病毒有抑制作用；紅糖性溫味甘，有散寒活血、暖胃健脾功效。<br />\n<br />\n寒咳<br />\n寒咳多由於感受風寒、低溫冷空氣、冷氣空調等而引起，出現咳嗽聲重、氣息急促、頭痛、咽癢、鼻塞流清涕、痰稀色白呈泡末狀，或見惡寒發熱、無汗、身驅酸痛等症狀。<br />\n<br />\n食療：陳皮甘草薑茶<br />\n<br />\n材料 : 陳皮20克，生薑 10克， 甘草5克，茶葉4克，紅糖適量，清水5碗。<br />\n<br />\n做法 : 把材料與清水放入鍋中同煲10-15鐘，加入紅糖成即。<br />\n<br />\n功能 : 疏風散寒、化痰止咳。<br />\n<br />\n陳皮味辛，性溫，能溫化寒痰，宣肺止咳。現代藥理分析 : 陳皮中含有揮發油、黃酮等。能平喘祛痰及能使支氣管擴張，增強身體抗炎作用。<br />\n<br />\n生薑味辛，性溫，生用發散，熟用和中，可解熱、去痰、止咳，能強化白血球效能而提升免疫力。現代藥理分析 : 生薑含有薑油酮、薑油酚和姜辣素等成分，能解熱排汗，去痰止咳，增強免疫系統。<br />\n<br />\n甘草味甘，性平，有潤肺祛痰止咳功效。現代藥理分析 : 甘草含有黃酮素，甘草酸等成份，具有抗炎鎮咳功效。<br />\n<br />\n<br />\n<br />\n熱咳<br />\n多由於感受風熱或暑熱引起，出現咳嗽頻、聲音嘶啞、氣粗、呼出熱氣、咽喉乾痛、痰黏稠或伴色黃，咯痰不爽、鼻塞流黃涕、汗出、發熱、頭痛、頭暈、口渴等症狀。<br />\n<br />\n食療：羅漢果柿餅飲<br />\n<br />\n材料 : 柿餅30克，羅漢果半個，清水5碗。<br />\n<br />\n做法 : 把材料與清水放入鍋中同煲半小時即成。<br />\n<br />\n功能 : 清熱、化痰、止咳。<br />\n<br />\n羅漢果甘涼，有化痰止咳、清肺利咽和生津止渴等功效。現代藥理分析 : 羅漢果含有大量葡萄糖、 果糖以及鐵和碘等。有較明顯的鎮咳、祛痰作用；柿子性寒，能清熱、化痰、止咳。現代藥理分析 : 柿子有祛痰和鎮咳作用，祛痰作用明顯。"},{"pid":"a9e9867d4848d7de98fef29bdd51498d8b82616b","tid":697294,"uid":9447,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-11T01:12:03.000Z","msg":"去買9粒止咳丸<br />\n我同身邊既人都係靠佢"},{"pid":"3da385c7e13db9f02781da9edf4e7e0d958af8ef","tid":697294,"uid":52984,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-11T01:24:48.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/06/11/092038_d726abdd54137dad0a45145f3fdd09ac.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F11%2F092038_d726abdd54137dad0a45145f3fdd09ac.png&h=f3cd655e&s={SIZE}\" /><br />\n<br />\n我復活了 唔想食藥 又見到有糖可以含 🤓 <br />\n雖然都係失聲 但冇咳已經好好<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8eec292b9f4df27364b7f5e1df53bbd744dcd153","tid":697294,"uid":152262,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-06-11T08:38:16.000Z","msg":"請你食蜜糖<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"fe9e5e40d94f8b16b5f88c1c60a78ade5cf0c4ac","tid":697294,"uid":76754,"like":0,"dislike":0,"score":0,"quote":{"pid":"3da385c7e13db9f02781da9edf4e7e0d958af8ef","tid":697294,"uid":52984,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-11T01:24:48.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/06/11/092038_d726abdd54137dad0a45145f3fdd09ac.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F06%2F11%2F092038_d726abdd54137dad0a45145f3fdd09ac.png&h=f3cd655e&s={SIZE}\" /><br />\n<br />\n我復活了 唔想食藥 又見到有糖可以含 🤓 <br />\n雖然都係失聲 但冇咳已經好好<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-12T16:40:36.000Z","msg":"你食左幾多盒先？"}]}