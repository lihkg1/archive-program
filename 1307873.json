ormal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"d52e58d84a4c46ffc0280a8b8e0f6825ce326330","tid":1307873,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T00:42:40.000Z","msg":"推"},{"pid":"74ac6636ad4d582803fb6339ba50e8e96b98f195","tid":1307873,"uid":48887,"like":0,"dislike":0,"score":0,"quote":{"pid":"cc051cffe7c15ab36a31b4d123bf6f05216efc88","tid":1307873,"uid":28202,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-11T22:38:01.000Z","msg":"認同,<br />\n上次雨傘班勇武人仕係你自己唔還手無問題但唔好阻住我還手,唔好督灰,<br />\n今次有啲人係自己唔落場還手,但又屌人唔還手<br />\n<br />\n<br />\n記住無人阻你還手,<br />\n但你唔好迫人還手,想還手既正如樓主所講可以自己組隊落場玩"},"citedBy":0,"replyTime":"2019-07-12T00:52:55.000Z","msg":"講係人都識講<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e8647b0b664935708ebed22d769eb37c249e0895","tid":1307873,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T03:33:40.000Z","msg":"講真，如果你地一齊行動搞連儂牆，其實係set緊陷阱比藍絲踩。<br />\n<br />\n藍絲開始拆，你地就挑釁佢出手。<br />\n佢一出手打兩三拳，其他人就開始警告。<br />\n如果佢唔停手，被打的巴打就要即刻訓低扮暈，其他人就行使「公民拘捕權」，然後順手報警call白車。<br />\n<br />\n當然同時你要搵起碼兩個人由唔同角度拍片。"},{"pid":"64c6dad18b7f6198f028133cd73e24efe5fe755e","tid":1307873,"uid":213379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-12T03:33:51.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: x-large;\"><strong>聽日去上水 三個一齊推 </strong></span></span><br />\n<br />\n[突發][713光復上水]一封北區居民寫給香港人的公開信<br />\n<a href=\"https://lih.kg/1307753\" target=\"_blank\">https://lih.kg/1307753</a><br />\n<br />\n！！緊 急 ！！突 發！！上 水 連 儂 牆 要 人！ ！<br />\n<a href=\"https://lih.kg/1308369\" target=\"_blank\">https://lih.kg/1308369</a><br />\n<br />\n［抗爭支線］！七 月 十 三 ！光 復 上 水 ！踢 走 水 貨 客！<br />\n<a href=\"https://lih.kg/1307559\" target=\"_blank\">https://lih.kg/1307559</a>"},{"pid":"3556e3fda4bd2489ccbf4bf116e9672d7d954a4d","tid":1307873,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-29T02:34:53.000Z","msg":"有人試完即刻比警察告非法禁錮<br />\n<a href=\"https://lihkg.