ke":0,"score":4,"quote":{"pid":"7ca13a88e5a039c372b12209fad631048f941b48","tid":877190,"uid":56428,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-10-26T09:30:01.000Z","msg":"公民黨<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-26T09:33:56.000Z","msg":"又可以大叫法治最黑暗既一日"},"citedBy":0,"replyTime":"2018-10-26T10:26:36.000Z","msg":"唔好漏左石永泰<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"9c4e76f321c1015573edf9750ec11ba84f17aba9","tid":877190,"uid":128369,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-10-26T10:45:36.000Z","msg":"律師會一向紅底"},{"pid":"cf066bbb8da44c2b4238f90776168b11af93f5eb","tid":877190,"uid":126510,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-10-26T10:59:17.000Z","msg":"Rule of Law都收埋皮<br />\nsigh<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"89560b450120ed09cbd6924422a32a371fa58822","tid":877190,"uid":153689,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-27T12:06:17.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"394f09f5f0c180e424028253b2b0304e41eea18b","tid":877190,"uid":30169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-27T12:15:25.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"2ec2d05b610e077bd389060f91c8d35e5880d763","tid":877190,"uid":191926,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-27T12:21:13.000Z","msg":"21世紀紐倫堡大審判<br />\n<br />\n將堆支那畜生全部殺死<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d3d52f1c36e14d0d86c6fb4b52523617b0ab95ee","tid":877190,"uid":10757,"like":0,"dislike":0,"score":0,"quote":{"pid":"ae2cfb438709c67fe8b364fc6219f6a9accd3d48","tid":877190,"uid":35835,"like":1,"dislike":0,"score":1,"quote":{"pid":"7ca13a88e5a039c372b12209fad631048f941b48","tid":877190,"uid":56428,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-10-26T09:30:01.000Z","msg":"公民黨<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-26T09:35:24.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-10-27T12:47:18.000Z"