ba4ef9f5f1bf46afe06","tid":1424220,"uid":389,"like":63,"dislike":0,"score":63,"citedBy":1,"replyTime":"2019-08-06T15:52:49.000Z","msg":"佢解釋幾接近原意"},"citedBy":1,"replyTime":"2019-08-07T01:09:29.000Z","msg":"梁天琦：<br />\n這是他媽的 光復香港 時代革命。<br />\n<img src=\"https://wiki.komica.org/images/9/9e/%E8%97%8D%E8%89%B2%E7%AA%97%E7%B0%BE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwiki.komica.org%2Fimages%2F9%2F9e%2F%25E8%2597%258D%25E8%2589%25B2%25E7%25AA%2597%25E7%25B0%25BE.jpg&h=c178aa6f&s={SIZE}\" />"},{"pid":"27e8948501a348256110eacc7c77c2be989272f9","tid":1424220,"uid":235535,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T01:09:53.000Z","msg":"推"},{"pid":"1dbdb4b005bb7c3ddc1f1756cf5a36c4c1d514e6","tid":1424220,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-07T01:10:19.000Z","msg":"幫到盡<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: x-small;\">都幾夾硬</span>"},{"pid":"5e414e30c753dc53c7dbeda96e95555dd54db219","tid":1424220,"uid":32525,"like":15,"dislike":0,"score":15,"quote":{"pid":"43f1646fa7e7370e027e6cc964ed0d7c0ef15638","tid":1424220,"uid":15371,"like":1,"dislike":0,"score":1,"quote":{"pid":"7c308c750831013cc7d7269208e573725b0fd2a5","tid":1424220,"uid":32525,"like":24,"dislike":0,"score":24,"citedBy":2,"replyTime":"2019-08-06T15:52:34.000Z","msg":"李怡果個最好"},"citedBy":1,"replyTime":"2019-08-06T16:14:58.000Z","msg":"李怡講乜 有冇關鍵字/link"},"citedBy":1,"replyTime":"2019-08-07T01:17:45.000Z","msg":"但「光復香港」我們都知道要「光復」到甚麼時代，不就是人權有保障、市民有法律權利、警察是保護市民而不是向自由表達意見的市民施暴的香港嗎？打出港英旗也好，打出美國旗也罷，重點都不是呼喚英國美國來統治香港，而是表示香港要回到英美體制中對自由、對人權的保護。<br />\n<br />\n「時代革命」是革甚麼命？革命的定義就是尋求根本性的改變。革命不一定是改朝換代，不一定是暴力與流血。工業革命，技術革命也是革命。文化大革命是在原有朝代中進行，辛亥革命實際上暴力與流血不多，有史家認為暴力與流血比日本的明治維新還少。香港的「時代革命」，就是要把被中共港共徹底破壞了的一國兩制、港人治港作根本性的改變。<br />\n<br />\n香港市民本來沒有想到要作這樣根本性改變的，但7.21讓我們覺得香港變成黑社會統治了，於是即使在和理非的示威中，也喊出了梁天琦2016年的口號：「光復香港，時代革命」！事情的變質是由元朗事件引起的。<br />\n<br />\n李怡：光復香港　時代革命<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1420821\" data-auto-link target=\"_blank\">https://lih.kg/1420821</a>"},{"pid":"5e501cb2124547fd737133ff6fdc1ba328e4be8a","tid":1424220,"uid":234719,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-08-07T01:18:28.000Z","msg":"契媽咪講得好囉<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><br />\n劉細良淨係識叫人唔好講"},{"pid":"a4dbee6f19a02d213cddc2a59fcb2efab2f71fb2","tid":1424220,"uid":46411,"like":1,"dislike":0,"score":1,"quote":{"pid":"b05fd022ef0ffa725d3506d4be263c743163ed79","tid":1424220,"uid":20867,"like":2,"dislike":5,"score":-3,"quote":{"pid":"3aa8a4964986e2a2ffb38ba4ef9f5f1bf46afe06","tid":1424220,"uid":389,"like":63,"dislike":0,"score":63,"citedBy":1,"replyTime":"2019-08-06T15:52:49.000Z","msg":"佢解釋幾接近原意"},"citedBy":1,"replyTime":"2019-08-07T01:09:29.000Z","msg":"梁天琦：<br />\n這是他媽的 光復香港 時代革命。<br />\n<img src=\"https://wiki.komica.org/images/9/9e/%E8%97%8D%E8%89%B2%E7%AA%97%E7%B0%BE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwiki.komica.org%2Fimages%2F9%2F9e%2F%25E8%2597%258D%25E8%2589%25B2%25E7%25AA%2597%25E7%25B0%25BE.jpg&h=c178aa6f&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-08-07T01:20:19.000Z","msg":"好撚好笑野屌你老味"},{"pid":"fb567bcb3fdf6768589a3aa6079658ef73e92a3a","tid":1424220,"uid":242323,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T01:20:47.000Z","msg":"推"},{"pid":"1b6df21b5df003d02c8132e540f79e961c072e6e","tid":1424220,"uid":234719,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T01:23:49.000Z","msg":"<span style=\"color: red;\"><strong><span style=\"font-size: xx-large;\"><br />\n光復香港 時代革命 反暴反黑</span></strong></span>"},{"pid":"86f23d61bb23cd59ed8ae6e79263f352a07f7389","tid":1424220,"uid":259329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T01:25:54.000Z","msg":"此回覆已被刪除"},{"pid":"f90eb46d558a60092faa68d28e7914ac1ed9eb42","tid":1424220,"uid":2446,"like":3,"dislike":0,"score":3,"quote":{"pid":"5e414e30c753dc53c7dbeda96e95555dd54db219","tid":1424220,"uid":32525,"like":15,"dislike":0,"score":15,"quote":{"pid":"43f1646fa7e7370e027e6cc964ed0d7c0ef15638","tid":1424220,"uid":15371,"like":1,"dislike":0,"score":1,"quote":{"pid":"7c308c750831013cc7d7269208e573725b0fd2a5","tid":1424220,"uid":32525,"like":24,"dislike":0,"score":24,"citedBy":2,"replyTime":"2019-08-06T15:52:34.000Z","msg":"李怡果個最好"},"citedBy":1,"replyTime":"2019-08-06T16:14:58.000Z","msg":"李怡講乜 有冇關鍵字/link"},"citedBy":1,"replyTime":"2019-08-07T01:17:45.000Z","msg":"但「光復香港」我們都知道要「光復」到甚麼時代，不就是人權有保障、市民有法律權利、警察是保護市民而不是向自由表達意見的市民施暴的香港嗎？打出港英旗也好，打出美國旗也罷，重點都不是呼喚英國美國來統治香港，而是表示香港要回到英美體制中對自由、對人權的保護。<br />\n<br />\n「時代革命」是革甚麼命？革命的定義就是尋求根本性的改變。革命不一定是改朝換代，不一定是暴力與流血。工業革命，技術革命也是革命。文化大革命是在原有朝代中進行，辛亥革命實際上暴力與流血不多，有史家認為暴力與流血比日本的明治維新還少。香港的「時代革命」，就是要把被中共港共徹底破壞了的一國兩制、港人治港作根本性的改變。<br />\n<br />\n香港市民本來沒有想到要作這樣根本性改變的，但7.21讓我們覺得香港變成黑社會統治了，於是即使在和理非的示威中，也喊出了梁天琦2016年的口號：「光復香港，時代革命」！事情的變質是由元朗事件引起的。<br />\n<br />\n李怡：光復香港　時代革命<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1420821\" data-auto-link target=\"_blank\">https://lih.kg/1420821</a>"},"citedBy":1,"replyTime":"2019-08-07T01:26:29.000Z","msg":"毛姨姨嗰個解釋一句精闢講完<br />\n對於弱智人士黎講 你比一邊文佢睇 佢會話你搞屎棍<br />\n一句講完佢load唔到就冇野講"},{"pid":"2a45ef43e7800f08077c2c00f7336e5e72e15110","tid":1424220,"uid":13361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T01:26:54.000Z","msg":"<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip_connect.gif\" class=\"hkgmoji\" />"},{"pid":"2d57aacd979a19c0370f6fee7b7e257a7dbe4888","tid":1424220,"uid":155088,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T01:28:05.000Z","msg":"咩口號都好，主力5大訴求，好多兄弟俾人告暴動，唔好模糊焦點就得，最驚最後攪到啲被拉嘅手足變condom.<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"6a8533d5ec0ed24111c9e4de3ed97e7e9f3847d8","tid":1424220,"uid":62,"like":0,"dislike":0,"score":0,"