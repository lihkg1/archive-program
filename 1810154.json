不了解我哋嘅人去慢慢接受、同行，我喺監獄都唔放棄，香港人，因為團結，我哋先有今日，所以革命未完，你哋點可以放棄呢？<br />\n<br />\n <br />\n<br />\n#光復香港 時代革命<br />\n#五大訴求 缺一不可<br />\n#沒有暴徒 只有暴政<br />\n#解散警隊 刻不容緩<br />\n#釋放義士 還我公義<br />\n#林鄭落地獄<br />\n#黑警死全家<br />\n#香港人反抗/報仇<br />\n#煲底見<br />\n<br />\n原link :<a href=\"https://www.thestandnews.com/politics/%E8%8D%94%E6%9E%9D%E8%A7%92%E9%82%84%E6%8A%BC%E6%89%8B%E8%B6%B3%E7%9A%84%E4%BF%A1-%E6%88%91%E5%96%BA%E7%9B%A3%E7%8D%84%E9%83%BD%E5%94%94%E6%94%BE%E6%A3%84-%E4%BD%A0%E5%93%8B%E9%BB%9E%E5%8F%AF%E4%BB%A5%E6%94%BE%E6%A3%84%E5%91%A2/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E8%258D%2594%25E6%259E%259D%25E8%25A7%2592%25E9%2582%2584%25E6%258A%25BC%25E6%2589%258B%25E8%25B6%25B3%25E7%259A%2584%25E4%25BF%25A1-%25E6%2588%2591%25E5%2596%25BA%25E7%259B%25A3%25E7%258D%2584%25E9%2583%25BD%25E5%2594%2594%25E6%2594%25BE%25E6%25A3%2584-%25E4%25BD%25A0%25E5%2593%258B%25E9%25BB%259E%25E5%258F%25AF%25E4%25BB%25A5%25E6%2594%25BE%25E6%25A3%2584%25E5%2591%25A2%2F&d=GO0vWKcqTLT5bpzdAOrPDvzGhZJjjhZ%2BTSWVZI8Eykc%3D&h=3e5a81d7\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fpolitics%2F%25E8%258D%2594%25E6%259E%259D%25E8%25A7%2592%25E9%2582%2584%25E6%258A%25BC%25E6%2589%258B%25E8%25B6%25B3%25E7%259A%2584%25E4%25BF%25A1-%25E6%2588%2591%25E5%2596%25BA%25E7%259B%25A3%25E7%258D%2584%25E9%2583%25BD%25E5%2594%2594%25E6%2594%25BE%25E6%25A3%2584-%25E4%25BD%25A0%25E5%2593%258B%25E9%25BB%259E%25E5%258F%25AF%25E4%25BB%25A5%25E6%2594%25BE%25E6%25A3%2584%25E5%2591%25A2%2F&h=133f0374\" data-auto-link target=\"_blank\">https://www.thestandnews.com/politics/%E8%8D%94%E6%9E%9D%E8%A7%92%E9%82%84%E6%8A%BC%E6%89%8B%E8%B6%B3%E7%9A%84%E4%BF%A1-%E6%88%91%E5%96%BA%E7%9B%A3%E7%8D%84%E9%83%BD%E5%94%94%E6%94%BE%E6%A3%84-%E4%BD%A0%E5%93%8B%E9%BB%9E%E5%8F%AF%E4%BB%A5%E6%94%BE%E6%A3%84%E5%91%A2/</a>"},"citedBy":0,"replyTime":"2020-01-03T15:33:08.000Z","msg":"支持住！"},{"pid":"148cff62f29bf343fa1c192ae35bd668bbab8e68","tid":1810154,"uid":10471,"li