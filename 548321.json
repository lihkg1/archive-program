48cab431564295a72cbc1488","tid":548321,"uid":132698,"like":0,"dislike":0,"score":0,"quote":{"pid":"30085379dcddc2a83bf959754cc4bc4c330908ef","tid":548321,"uid":137487,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c9c9f1f1ca0c7eedd07b9d27c28f2d932ffb401","tid":548321,"uid":137487,"like":0,"dislike":1,"score":-1,"quote":{"pid":"0388b92b0c0231cf2d9ce54133dad01371be89b6","tid":548321,"uid":132698,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-02-03T07:15:58.000Z","msg":"正你老母呀正<br />\n樓主講緊簡繁呀<br />\n講緊文化呀柒頭<br />\n咗係正字黎咩<br />\n咗係廣東香港文化黎<br />\n香港文化一直都係𨳒你老母<br />\n就係以前高登都打唔到個𨳒字<br />\n咪先打個屌囉<br />\n你要堅持傳統文化就打𨳒啦on 9"},"citedBy":1,"replyTime":"2018-02-03T07:39:48.000Z","msg":"殘體字就係由正體字閹割而成 <br />\n「屌」同「𨳒」本身都係正體字 <br />\n冇任何閹割成份 <br />\n而且康熙字典都將「屌」字納入為正體字 <br />\n但係而家討論緊嘅係啲人將「咗」自我閹割成「左」 <br />\n同正體閹割成殘體本質一樣 <br />\n加上「左」字本身個意思只係得「左邊」<br />\n而「咗」呢個字係啲人特登用嚟作為助詞<br />\n而「屌」同「𨳒」意思一樣<br />\n將「屌」代替「𨳒」唔存在自我閹割文字<br />\n而家樓主就係鬧緊呢種行為 關「屌」係唔係香港文化乜嘢事?<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-03T07:43:13.000Z","msg":"重有我而家只係堅持緊正體字(繁體字)嘅文化<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> <br />\n呢個post嘅着眼點亦都唔係香港文化 而係繁體正體文化 希望你搞清楚<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-03T09:54:01.000Z","msg":"左字本身就唔係殘體字<br />\n你就因為少左個口話人有閹割成份<br />\n我就解釋你聽<br />\n呢d係以前高登文化遺留落黎（打唔到果個字）<br />\n唔好咁神經質話咩被人閹割<br />\n你對簡繁咁敏感都係想抵抗大陸文化姐<br />\n無講錯嘛<br />\n如果係咁我話你知以後唔好打個屌字啦<br />\n呢個字中港互通<br />\n真係香港用既係𨳒字呀知唔知"},{"pid":"b16eadfdb1cda2f855abadf008ba2c03f25473d9","tid":548321,"uid":71391,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-02-03T10:08:55.000Z","msg":"講到hk d 字係得把口咁<br />\n<br />\nso sad"},{"pid":"fe74d18bc7de0fa00f4b0f2a517d992cdc3dd09c","tid":548321,"uid":99028,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-02-03T10:10:44.000Z","msg":"此回覆已被刪除"},{"pid":"34b755aa0837d441ce8317ce291163d4b68b459e","tid":548321,"uid":128600,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-03T10:12:53.000Z","msg":"同意"},{"pid":"4e2e0b4d444ae5ae5f2fb9a0651f789da1a17c79","tid":548321,"uid":162539,"like":0,"dislike":1,"score":-1,"quote":{"pid":"3c3676d19bdd959ace7aece13c9d5bd805361f19","tid":548321,"uid":132698,"like":0,"dislike":0,"score":0,"quote":{"pid":"4f05e096eee288547512a81306a7f3ff7949a17b","tid":548321,"uid":162539,"like":0,"dislike":0,"score":0,"quote":{"pid":"443ca1f9697f69e428534c109382481e0168d766","tid":548321,"uid":132698,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2018-02-02T14:17:37.000Z","msg":"因為我以前都好撚憎人打左字<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n係上高登上得多同化左<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-03T04:49:06.000Z","msg":"証明硬性推簡體字係有效"},"citedBy":1,"replyTime":"2018-02-03T06:36:18.000Z","msg":"咁左又唔係真係簡體字&hellip;"},"citedBy":1,"replyTime":"2018-02-03T11:15:43.000Z","msg":"唔係話左係簡體，<br />\n而係話因為高登唔俾打「咗」就變做「左」，<br />\n慢慢就潛移默化，無人會覺得有問題<br />\n<br />\n咁好嘞，到政府唔俾用繁體字，開頭咪多人鬧囉，過多幾年咪個個都好熟咁用簡體字，到時就會有班自以爲眾人皆非既傻仔出嚟話應該用返繁體字，之後又成班人話佢雞蛋裡挑骨頭。<br />\n<br />\n陳巧文果鑊衰過一次啦"},{"pid":"723b311c3c064e8d5893a38fa0435b8a5750b64b","tid":548321,"uid":30836,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-02-03T12:15:14.000Z","msg":"邊個話「咗」就係正字？<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"b7e921b9e0f5953d78451a2f765b3172b4d3144d","tid":548321,"uid":132698,"like":0,"dislike":0,"score":0,"quote":{"pid":"4e2e0b4d444ae5ae5f2fb9a0651f789da1a17c79","tid":548321,"uid":162539,"like":0,"dislike":1,"score":-1,"quote":{"pid":"3c3676d19bdd959ace7aece13c9d5bd805361f19","tid":548321,"uid":132698,"like":0,"dislike":0,"score":0,"quote":{"pid":"4f05e096eee288547512a81306a7f3ff7949a17b","tid":548321,"uid":162539,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-03T04:49:06.000Z","msg":"証明硬性推簡體字係有效"},"citedBy":1,"replyTime":"2018-02-03T06:36:18.000Z","msg":"咁左又唔係真係簡體字&hellip;"},"citedBy":1,"replyTime":"2018-02-03T11:15:43.000Z","msg":"唔係話左係簡體，<br />\n而係話因為高登唔俾打「咗」就變做「左」，<br />\n慢慢就潛移默化，無人會覺得有問題<br />\n<br />\n咁好嘞，到政府唔俾用繁體字，開頭咪多人鬧囉，過多幾年咪個個都好熟咁用簡體字，到時就會有班自以爲眾人皆非既傻仔出嚟話應該用返繁體字，之後又成班人話佢雞蛋裡挑骨頭。<br />\n<br />\n陳巧文果鑊衰過一次啦"},"citedBy":0,"replyTime":"2018-02-03T12:49:17.000Z","msg":"講咁耐都係為左捍衛香港語言文化姐<br />\n左同咗字根本唔存在正唔正字<br />\n繁或簡既問題<br />\n咗唔係正字<br />\n左又唔係繁體<br />\n你要堅守呢樣野無問題架<br />\n但唔好好似上面條柒頭咁<br />\n話人唔啱但又講個屌字<br />\n香港一直用既係呢個𨳒<br />\n唔好問我呢個字點黎<br />\n咗字都唔會喺歷史或字典上查到<br />\n呢d就係一個地方既獨有文化<br />\n唔係求其上網搵維基話正字就正字<br />\n講多次<br />\n唔係話用咗字係無謂既堅持<br />\n但麻煩批評人之前檢討下自己有無錯"},{"pid":"89506b8056bbe6788d8920fb907e9257433bf77f","tid":548321,"uid":164751,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-03T13:27:31.000Z","msg":"我今日扯咗旗但無打丁<br />\n因為凍"},{"pid":"e99bda0cef4671f51a00a012ba9de6ba0a44edc0","tid":548321,"uid":132698,"like":2,"dislike":1,"score":1,"quote":{"pid":"89506b8056bbe6788d8920fb907e9257433bf77f","tid":548321,"uid":164751,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-03T13:27:31.000Z","msg":"我今日扯咗旗但無打丁<br />\n因為凍"},"citedBy":0,"replyTime":"2018-02-03T13:31:44.000Z","msg":"嗱，你唔應該寫打丁<br />\n你宜家就係自我閹割緊<br />\n應該寫打飛機或者自慰就攞滿分<br />\n咁就唔會俾狗咬嘞"},{"pid":"c20531a1f1c438753d2b595667b8e83f8bf07e01","tid":548321,"uid":2419,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-03T13:34:55.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>正你老母呀正<br />\n樓主講緊簡繁呀<br />\n講緊文化呀柒頭<br />\n咗係正字黎咩<br />\n咗係廣東香港文化黎<br />\n香港文化一直都係𨳒你老母<br />\n就係以前高登都打唔到個𨳒字<br />\n咪先打個屌囉<br />\n你要堅持傳統文化就打𨳒啦on 9</blockquote>殘體字就係由正體字閹割而成 <br />\n「屌」同「𨳒」本身都係正體字 <br />\n冇任何閹割成份 <br />\n而且康熙字典都將「屌」字納入為正體字 <br />\n但係而家討論緊嘅係啲人將「咗」自我閹割成「左」 <br />\n同正體閹割成殘體本質一樣 <br />\n加上「左」字本身個意思只係得「左邊」<br />\n而「咗」呢個字係啲人特登用嚟作為助詞<br />\n而「屌」同「𨳒」意思一樣<br />\n將「屌」代替「𨳒」唔存在自我閹割文字<br />\n而家樓主就係鬧緊呢種行為 關「屌」係唔係香港文化乜嘢事?<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /></blockquote>重有我而家只係堅持緊正體字(繁體字)嘅文化<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> <br />\n呢個post嘅着眼點亦都唔係香港文化 而係繁體正體文化 希望你搞清楚<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /></blockquote>左字本身就唔係殘體字<br />\n你就因為少左個口話人有閹割成份<br />\n我就解釋你聽<br />\n呢d係以前高登文化遺留落黎（打唔到果個字）<br />\n唔好咁神經質話咩被人閹割<br />\n你對簡繁咁敏感都係想抵抗大陸文化姐<br />\n無講錯嘛<br />\n如果係咁我話你知以後唔好打個屌字啦<br />\n呢個字中港互通<br />\n真係香港用既係𨳒字呀知唔知</blockquote><br />\n其實好似唔關高登文化事<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n果陣速成全世界都出唔到果粒字"},{"pid":"292270e22901c7b201016d0ff7479b2e99848f84","tid":548321,"uid":132698,"like":0,"dislike":0,"score":0,"quote":{"pid":"c20531a1f1c438753d2b595667b8e83f8bf07e01","tid":548321,"uid":2419,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-03T13:34:55.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>正你老母呀正<br />\n樓主講緊簡繁呀<br />\n講緊文化呀柒頭<br />\n咗係正字黎咩<br />\n咗係廣東香港文化黎<br />\n香港文化一直都係𨳒你老母<br />\n就係以前高登都打唔到個𨳒字<br />\n咪先打個屌囉<br />\n你要堅持傳統文化就打𨳒啦on 9</blockquote>殘體字就係由正體字閹割而成 <br />\n「屌」同「𨳒」本身都係正體字 <br />\n冇任何閹割成份 <br />\n而且康熙字典都將「屌」字納入為正體字 <br />\n但係而家討論緊嘅係啲人將「咗」自我閹割成「左」 <br />\n同正體閹割成殘體本質一樣 <br />\n加上「左」字本身個意思只係得「左邊」<br />\n而「咗」呢個字係啲人特登用嚟作為助詞<br />\n而「屌」同「𨳒」意思一樣<br />\n將「屌」代替「𨳒」唔存在自我閹割文字<br />\n而家樓主就係鬧緊呢種行為 關「屌」係唔係香港文化乜嘢事?<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /></blockquote>重有我而家只係堅持緊正體字(繁體字)嘅文化<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /> <br />\n呢個post嘅着眼點亦都唔係香港文化 而係繁體正體文化 希望你搞清楚<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /></blockquote>左字本身就唔係殘體字<br />\n你就因為少左個口話人有閹割成份<br />\n我就解釋你聽<br />\n呢d係以前高登文化遺留落黎（打唔到果個字）<br />\n唔好咁神經質話咩被人閹割<br />\n你對簡繁咁敏感都係想抵抗大陸文化姐<br />\n無講錯嘛<br />\n如果係咁我話你知以後唔好打個屌字啦<br />\n呢個字中港互通<br />\n真係香港用既係𨳒字呀知唔知</blockquote><br />\n其實好似唔關高登文化事<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n果陣速成全世界都出唔到果粒字"},"citedBy":0,"replyTime":"2018-02-03T14:19:10.000Z","msg":"no,我以前無論用電話手寫<br />\n定九方都出唔到果d字<br />\n但其他論壇係出到"},{"pid":"4e33850cd755231d08f6b58507c49e14bb2aa544","tid":548321,"uid":71303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-03T17:41:28.000Z","msg":"叻喇叻喇，大學生<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"c33ded7f0dc9fddf81fbd0c80bc41d0c1e6419cd","tid":548321,"uid":105067,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-02-03T17:56:31.000Z","msg":"其實「左」字係有來源根據可追溯。<br />\n古時書寫係由右至左，通常寫到最左邊即係完成。所以「左」字係蘊含結束、完成嘅意思，例如廣東話：做左、講左、聽左，同樣係用黎表達完成某步驟或程序，加上口字邊嘅「咗」字只不過係形容呢個字係表示口語常用姐。"},{"pid":"89893c92f20ccb1e54d2aa03f593d0c3a2442c6e","tid":548321,"uid":122850,"like":1,"dislike":4,"score":-3,"citedBy":1,"replyTime":"2018-02-03T18:14:16.000Z","msg":"On9<br />\n文字梗係隨時間轉變<br />\n食古不化，不思進取<br />\n繼續係連登自成一角捍衛正體字啦<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"df4e071369bd2ba576371a628ab232f7d8211e15","tid":548321,"uid":69718,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-03T18:19:21.000Z","msg":"尼個話題講左好耐<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"cf5af892137e1e37085dd1b34206be51aa2eda50","tid":548321,"uid":44044,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-03T22:20:55.000Z","msg":"左左左左左左左左"},{"pid":"fc7ac6a98481bb1d1c5a96751fd066b5e953c027","tid":548321,"uid":48796,"like":1,"dislike":0,"score":1,"quote":{"pid":"5c920084fc8cc2c82cbf0f7de71cbcac1ad7144e","tid":548321,"uid":132698,"like":0,"dislike":0,"score":0,"quote":{"pid":"3be9f35a971eb426832fbaaf9125cde1747d3b69","tid":548321,"uid":5574,"like":1,"dislike":0,"score":1,"quote":{"pid":"0931a268e10b02cfd8ae5f777b2f925fbc153efe","tid":548321,"uid":137487,"like":127,"dislike":46,"score":81,"citedBy":3,"replyTime":"2018-02-02T12:07:31.000Z","msg":"唔打錯咪冇人煩囉 屌你老母"},"citedBy":1,"replyTime":"2018-02-03T06:52:50.000Z","msg":"𨳒呀屌.."},"citedBy":2,"replyTime":"2018-02-03T06:59:00.000Z","msg":"上面有條大陸仔話屌係啱<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-02-03T23:17:01.000Z","msg":"yup 細個未有上網前，全部公廁涂鴉都係寫「門小」 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}