headline.com%2Frealtime%2Farticle%2F1462003%2F%25E5%258D%25B3%25E6%2599%2582-%25E6%25B8%25AF%25E8%2581%259E-%25E6%25AD%25BB%25E5%259B%25A0%25E7%25A0%2594%25E8%25A8%258A-%25E5%258C%2596%25E9%25A9%2597%25E5%25B8%25AB%25E5%2588%2586%25E6%259E%2590%25E8%25AA%258D%25E7%2582%25BA%25E5%2591%25A8%25E6%25A2%2593%25E6%25A8%2582%25E8%25AA%25A4%25E4%25BB%25A5%25E7%2582%25BA%25E7%259F%25B3%25E7%2589%2586%25E5%25A4%2596%25E6%259C%2589%25E8%25B7%25AF-%25E8%25B7%25A8%25E8%25B6%258A%25E8%25B8%258F%25E7%25A9%25BA%25E8%2587%25B4%25E6%2584%258F%25E5%25A4%2596%3Ffbclid%3DIwAR0zyb3zDTirGEhsbSh1PyV12QTxDaBo-WCIAesqcjHdw8L29osL7ViWrc0&h=c542278e\" data-auto-link target=\"_blank\">https://std.stheadline.com/realtime/article/1462003/%E5%8D%B3%E6%99%82-%E6%B8%AF%E8%81%9E-%E6%AD%BB%E5%9B%A0%E7%A0%94%E8%A8%8A-%E5%8C%96%E9%A9%97%E5%B8%AB%E5%88%86%E6%9E%90%E8%AA%8D%E7%82%BA%E5%91%A8%E6%A2%93%E6%A8%82%E8%AA%A4%E4%BB%A5%E7%82%BA%E7%9F%B3%E7%89%86%E5%A4%96%E6%9C%89%E8%B7%AF-%E8%B7%A8%E8%B6%8A%E8%B8%8F%E7%A9%BA%E8%87%B4%E6%84%8F%E5%A4%96?fbclid=IwAR0zyb3zDTirGEhsbSh1PyV12QTxDaBo-WCIAesqcjHdw8L29osL7ViWrc0</a>"},{"pid":"ca809dde2f4486f2dd2c599d56a3759345853fc1","tid":2344162,"uid":199771,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-12-29T06:18:21.000Z","msg":"專家證人、政府高級化驗師鄭郁棋調查尚德停車場時，指2樓大部分矮牆0.9米高，矮牆之後有行人道。他形容，2樓及3樓的整體設計相似，但3樓的矮牆1.2米高，矮牆之後中空。他又指，由3樓矮牆位置至2樓行人路，垂直距離4.3米。鄭郁棋表示，周梓樂身高1.75米，曾以一名1.78米的同事協助測量，在3樓距離矮牆0.8米遠，才能察覺到矮牆外是中空。         <br />\n<br />\n人生就係咁 一次誤判 <br />\n賠上性命 後悔難返<br />\n古人都話<br />\n一失足成千古恨<br />\n<br />\n新聞來源連結:<br />\n<a href=\"https://news.rthk.hk/rthk/ch/component/k2/1567420-20201228.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1567420-20201228.htm&d=vFDcqKLMx6N8Vlwxc9UzxxR%2FdSTUI%2FcOXZwDwNjmD8Q%3D&h=a46ff215\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.rthk.hk%2Frthk%2Fch%2Fcomponent%2Fk2%2F1567420-20201228.htm&h=df605f4b\" data-auto-link target=\"_blank\">https://news.rthk.hk/rthk/ch/component/k2/1567420-20201228.htm</a>"},{"pid":"c97007f035127f4e08be9e19c2fcad53d726b715","tid":2344162,"uid":185066,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-29T06:27:13.000Z","msg":"【周梓樂死因研訊】推測墮樓原因　政府化驗師：不排除誤會矮牆後有行人路<br />\n<a href=\"https://lih.kg/2344914\" data-auto-link target=\"_blank\">https://lih.kg/2344914</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"dfaf43abe57d2d29d84650ee4ac355920102943a","tid":2344162,"uid":155682,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-12-29T06:27:33.000Z","msg":"梓樂身高約1.75米，鄭找來身高1.78米的男同事模擬在3樓泊車位步向矮牆邊，發現要步近距離牆邊約0.8米，才會看見橫樑下方的外圍街景，意即看見矮牆外是凌空及沒有鋪設行人通道<br />\n<br />\n當佢唔熟個停車場，跳過去果下一定知凌空咗，正常都腳先落地＋最多斷腳喇，點會成個人冇防禦冇反應咁撻落去，仲頭落先，根本唔合邏輯囉。"},{"pid":"a6e87106399b199159f67598ebc72b9c156da21b","tid":2344162,"uid":36901,"like":2,"dislike":2,"score":0,"citedBy":1,"replyTime":"2020-12-29T06:30:23.000Z","msg":"頭身落地先<br />\n3樓圍牆冇掌印腳印<br />\n<br />\n要自跳的話，得呢種可能性<br />\n<img src=\"https://na.cx/i/JqMdoZC.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJqMdoZC.gif&h=e6c3bf44&s={SIZE}\" />"},{"pid":"01ed839f819d6b02a0ac672ffdfb2278e4e1629e","tid":2344162,"uid":192517,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-29T06:30:59.000Z","msg":"<img src=\"/assets/faces/catxm/throw.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/catxm/throw.gif\" class=\"hkgmoji\" />"},{"pid":"d6180fc75cf3c0a8c41744418a469785c516afe7","tid":2344162,"uid":199771,"like":2,"dislike":1,"score":1,"quote":{"pid":"dfaf43abe57d2d29d84650ee4ac355920102943a","tid":2344162,"uid":155682,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-12-29T06:27:33.000Z","msg":"梓樂身高約1.75米，鄭找來身高1.78米的男同事模擬在3樓泊車位步向矮牆邊，發現要步近距離牆邊約0.8米，才會看見橫樑下方的外圍街景，意即看見矮牆外是凌空及沒有鋪設行人通道<br />\n<br />\n當佢唔熟個停車場，跳過去果下一定知凌空咗，正常都腳先落地＋最多斷腳喇，點會成個人冇防禦冇反應咁撻落去，仲頭落先，根本唔合邏輯囉。"},"citedBy":1,"replyTime":"2020-12-29T06:42:34.000Z","msg":"好多租用這個停車塲的車主街坊<br />\n都話呢個位好伏 初到這裡的車主<br />\n好容易睇錯 以為欄杆後係同一樓層<br />\n但係無端端你唔會跳過去<br />\n所以 以往沒有意外發生<br />\n但事發當晚有好多手足（非車主租客）<br />\n來到這個停車塲放哨<br />\n平時他們沒有來這裡<br />\n當晚另外一名手足<br />\n也差點中伏 好彩他及時抓住欄桿<br />\n才沒有令悲劇重演<br />\n<br />\n<img src=\"https://na.cx/i/yY9iz9n.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyY9iz9n.gif&h=f2cb3175&s={SIZE}\" />"}]}