like":3,"dislike":0,"score":3,"quote":{"pid":"4ac0f6037f19f5728efae1ce2b16b5d8ebb32de2","tid":2129480,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-28T15:17:21.000Z","msg":"慶回歸群組<br />\n<a href=\"https://w.wiki/X$a\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fw.wiki%2FX%24a&d=jpV%2F2%2Bss%2F2Wq3uOsKpdaD1cETUAZGKrTpJw0Ojiq68w%3D&h=5fb37e81\" target=\"_blank\">https://w.wiki/X$a</a><br />\n<br />\n富臨群組<br />\n<a href=\"https://w.wiki/Y8A\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fw.wiki%2FY8A&d=jpV%2F2%2Bss%2F2Wq3uOsKpdaD1cETUAZGKrTpJw0Ojiq68w%3D&h=d65636fd\" target=\"_blank\">https://w.wiki/Y8A</a><br />\n<br />\n<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-28T15:36:58.000Z","msg":"寫一篇維基百科條目其實同中學/大學做project差唔多，要睇哂所有相關的新聞，再諗下應該點樣鋪排 / 應該有咩章節。<br />\n<br />\n依度雖然字數唔多，但每篇我都用咗4-6個鐘去寫（雖然一路寫又一路做其他嘢）。寫維基百科唔需要文筆好好，唔需要華麗的修辭，只需要清晰咁表達事實。如果你都有心機針對某個topic去搵資料、寫嘢，請加入維基百科戰線。<br />\n（如果你無心機寫嘢，你可以協助更新現有條目，寫一兩段都已經幫到手。）<br />\n依度記錄咗目前需要幫手的條目：<br />\n<a href=\"https://w.wiki/S6s\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fw.wiki%2FS6s&d=jpV%2F2%2Bss%2F2Wq3uOsKpdaD1cETUAZGKrTpJw0Ojiq68w%3D&h=9d82ec4c\" target=\"_blank\">https://w.wiki/S6s</a>"},{"pid":"1a52736efce80ed9cc9405c66fade08f38dbebc5","tid":2129480,"uid":61494,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-07-28T15:40:28.000Z","msg":"感謝巴打🙏🏿"},{"pid":"ff7c7e17c701342686513f2c25a6503526e04740","tid":2129480,"uid":2054,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-28T15:40:55.000Z","msg":"專攻藍屍<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"17a19d816e26b2830dd5a2efafa6588919fabaae","tid":2129480,"uid":283951,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-28T15:48:18.000Z","msg":"<img src=\"/assets/faces/pig/drum.g