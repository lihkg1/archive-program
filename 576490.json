g":"學定岩架啦<br />\n<br />\n準備面聖啦"},{"pid":"c9a8fe4c63043a176193150c04841cfc4e6fbc4d","tid":576490,"uid":62599,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-01T05:13:13.000Z","msg":"復清滅共"},{"pid":"25ad79af420eee7d44e910ae214fddb2f4899ab9","tid":576490,"uid":43721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-01T05:20:00.000Z","msg":"起到咁都係10億<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"6d1769f8bf9f45e3cf1cc8838555465aa7b89b80","tid":576490,"uid":22736,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-01T05:21:30.000Z","msg":"寶福山？"},{"pid":"c10be01c6a10a3c51d0d4a9b0eecbbed7a23d6da","tid":576490,"uid":29314,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-04T23:22:43.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d35d0f000c4e3fde5db47af65a8a0db650f65808","tid":576490,"uid":55913,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-05T01:03:20.000Z","msg":"香港已經準備好 沙田寶福山"}]}