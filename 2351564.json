ts/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"53b61d51dda08161e400f6ba52debf3f5e404e84","tid":2351564,"uid":2300,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-01-03T16:46:31.000Z","msg":"唔洗諗 一定青衣<br />\n葵芳葵興好撚嘈又多塵 又多蝗蟲同公屋痴線佬"},{"pid":"5afc62e14d7dcba9afea53288be34fa62025362f","tid":2351564,"uid":4333,"like":5,"dislike":0,"score":5,"quote":{"pid":"e764849168f8a4a66f0b5bf53d6a6f550201ab26","tid":2351564,"uid":34863,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2021-01-03T16:40:20.000Z","msg":"竟然話盈翠灝景點解可以貴過新葵興花園<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-03T16:47:16.000Z","msg":"淨係睇個樣都知點解啦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n盈翠仲要地鐵站上蓋仲要加埋青衣城<br />\n新葵興花園點比呀 淨係個商場都無得比啦"},{"pid":"0f5e8a8dc84d6205baa1419bb91f5c7f13684784","tid":2351564,"uid":218688,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-03T16:49:33.000Z","msg":"個問題好簡單<br />\n搵個AA就答到<br />\n一個屋院嘅價值<br />\n市場自然會自行定價"},{"pid":"f059a1429e2b1293a51752f2f6598568e246167c","tid":2351564,"uid":15047,"like":0,"dislike":0,"score":0,"quote":{"pid":"e9b5152371cebd648b2e6bb1f8a1a17a22ddd98b","tid":2351564,"uid":218688,"like":4,"dislike":4,"score":0,"citedBy":1,"replyTime":"2021-01-03T11:29:28.000Z","msg":"住青衣，<br />\n認同葵興方便D<br />\n<br />\n不過用AA嘅角度睇<br />\nmtr站計<br />\n青衣樓新過葵興<br />\n設施齊d<br />\n出中環同機場一程到<br />\n深夜交通幾方便係唔計<br />\n<br />\n所以貴咁多<br />\n<br />\n似奧運同長沙灣分別"},"citedBy":1,"replyTime":"2021-01-03T18:34:45.000Z","msg":"奧運一定方便過長沙灣"},{"pid":"356c1ee1a0b323dd2b2148d457abfe053cb090f3","tid":2351564,"uid":236931,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-03T18:56:29.000Z","msg":"樓主篇嘢真係好亂<br />\n<br />\n講緊葵興但最尾講葵芳<br />\n<br />\n如果住葵興站上蓋<br />\n而又喺屯門元朗返工<br />\n巴士站真係行任何一邊都係遠<br />\n<br />\n葵興站過條行人天橋有賣香港嘅KCC<br />\n唔知入邊多唔多嘢食"},{"pid":"89921e6d541b71ab746e7fd950ce103c064fdeb0","tid":2351564,"uid":123613,"like":0,"dislike":0,"score":0,"quote":{"pid":"356c1ee1a0b323dd2b2148d457abfe053cb090f3","tid":2351564,"uid":236931,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-03T18:56:29.000Z","msg":"樓主篇嘢真係好亂<br />\n<br />\n講緊葵興但最尾講葵芳<br />\n<br />\n如果住葵興站上蓋<br />\n而又喺屯門元朗返工<br />\n巴士站真係行任何一邊都係遠<br />\n<br />\n葵興站過條行人天橋有賣香港嘅KCC<br />\n唔知入邊多唔多嘢食"},"citedBy":0,"replyTime":"2021-01-04T04:11:22.000Z","msg":"sorry 最尾打錯字做葵芳<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"d24256f9638332524caa9b48301dd3be6d0a2e98","tid":2351564,"uid":71620,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-04T04:12:56.000Z","msg":"住新葵興花園不知幾方便<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5f7721085bca8f48c6e045a58dad2a51c4224e85","tid":2351564,"uid":6435,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-04T04:14:05.000Z","msg":"葵興好撚舊喎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n光輝圍果邊夜晚污糟到仆街"},{"pid":"fbd41f26950e08b85b7acf51c7e0db4e8e745eca","tid":2351564,"uid":37487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-04T04:14:40.000Z","msg":"青衣深夜一係搭的士一係搭N車<br />\n葵興深夜可以搭紅van<img src=\"/assets/faces/pig/peanut.gif\" class=\"hkgmoji\" />"},{"pid":"fb9a03909917f0bd925d3e942ef1894347c2400e","tid":2351564,"uid":55835,"like":2,"dislike":0,"score":2,"quote":{"pid":"8a777603f537fd074a7c4be92a44d7f81d6faa23","tid":2351564,"uid":33468,"like":36,"dislike":2,"score":34,"citedBy":2,"replyTime":"2021-01-03T10:41:19.000Z","msg":"新葵芳花園點同盈翠灝景比呀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 盈翠灝景係靚好撚多<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 而且睇你住青衣邊度啦 以上兩個地方 附近有翻新過嘅街市有大型商場有運動場有公園 近巴士站又近地鐵站<br />\n<br />\n利申 青衣打手<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\