?u=https%3A%2F%2Fcdn.shortpixel.ai%2Fclient%2Fq_glossy%2Cret_img%2Fhttps%3A%2F%2Fuyghurpress.com%2Fwp-content%2Fuploads%2F2018%2F11%2Fmerlin_137405457_c44b601a-b0e0-4898-bdda-444d9774f296-master1050.jpg&h=b1d415ed&s={SIZE}\" />"},{"pid":"9b6c83cc62ff3aff8d6cedd42d85c90c10cc3d9e","tid":904800,"uid":29090,"like":1,"dislike":0,"score":1,"quote":{"pid":"551f5674e1bedc507e353019436f922e7b1123be","tid":904800,"uid":163350,"like":5,"dislike":0,"score":5,"quote":{"pid":"a33cbf2af4f2eecba12671241af2f1b924c7850c","tid":904800,"uid":29090,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-11-16T16:04:28.000Z","msg":"Free Tibet!<br />\nFree Xinjiang!"},"citedBy":1,"replyTime":"2018-11-16T16:07:00.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-11-16T16:10:19.000Z","msg":"Thanks for the correction <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"e9a22cf77f49871980168359823470d1d772ddbc","tid":904800,"uid":22054,"like":3,"dislike":0,"score":3,"quote":{"pid":"a82828f7a224bda34b907acdf66554aae06d1865","tid":904800,"uid":51620,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-11-16T16:08:57.000Z","msg":"<img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" /> 班中國人唔係話侵侵嘅共和黨失左眾議院控制權變左跛腳狗咩 <br />\n<br />\n<img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" /> 做咩眾議院會有呢d針對中國嘅法案出嚟？"},"citedBy":0,"replyTime":"2018-11-16T16:36:06.000Z","msg":"內政有機外交而家民主黨個領袖係想直接制裁中國<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cad3b6903596e865bc9c39a21d7eb626350a0971","tid":904800,"uid":153778,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2018-11-16T16:44:04.000Z","msg":"Nancy Pelosi直頭話侵既對華政策太溫和，個呀姐重喪過共和黨班呀伯<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n共和針對經濟，民主針對人權，雙管齊下打中國<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"962002b4e05aeecf