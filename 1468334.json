d":1468334,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T18:58:50.000Z","msg":"<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"45d4af588e09fbd3f964478ffb0d30392841976c","tid":1468334,"uid":115579,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-13T19:19:40.000Z","msg":"到時現場阻人又俾人話左膠，叫人唔好衝又話冷氣軍師<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n今日兩樣都中過"},{"pid":"6d44cf3742e82c8ca1d74598ce58dda64995b473","tid":1468334,"uid":89184,"like":0,"dislike":0,"score":0,"quote":{"pid":"45d4af588e09fbd3f964478ffb0d30392841976c","tid":1468334,"uid":115579,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-13T19:19:40.000Z","msg":"到時現場阻人又俾人話左膠，叫人唔好衝又話冷氣軍師<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n今日兩樣都中過"},"citedBy":0,"replyTime":"2019-08-13T19:24:27.000Z","msg":"推左先啦"},{"pid":"0f1bf7ec5c6736052518db5154ec3b25ec83e857","tid":1468334,"uid":275202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T19:56:13.000Z","msg":"做好場show!"},{"pid":"8987aeb58f1e4b9269075869c9bd048bd125bc00","tid":1468334,"uid":107860,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-13T21:38:10.000Z","msg":"推<br />\n同埋如果AA又出陰招<br />\n1) 亂改Flight Status做CANCEL但實際係照飛<br />\n或者 2) 唔開Checkin counter 同 bag drop<br />\n我地要主動幫啲旅客 叫佢地打去Airline<br />\n問清楚到底班機有冇cancel<br />\n問點解唔開counter 我上唔到機邊個負責<br />\n逼佢地搵人認頭 一係出黎開counter<br />\n<br />\n我地一定要主動幫旅客 叫佢地問清楚<br />\n如果顯示牌寫Cancel 但實際照飛既話 旅客只會見到由cancel突然變boarding soon 甚至係final call<br />\n到時佢地追又追唔到 保險又claim唔到就仆街喇<br />\n<br />\n主動幫受影響既旅客 <br />\n做一場真正既和你飛"},{"pid":"f11cf9c22c0ad94555eb44a890a1698a965b61c7","tid":1468334,"uid":199606,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-13T21:50:23.000Z","msg":"理性講下<br />\n想問點解就算外國人/外交官咁啱被打中<br />\n又真係影住係啲警察做<br />\n咁請問佢地 邊個會受到制裁<br />\n上次旺角都拉左個韓國人啦<br />\n咪又係冇事<br />\n班官都潛左咁耐水<br />\n佢咪又係出黎最多講句對唔住<br />\n冇人問責冇人受罰/<br />\n最多咪交開槍果個<br />\n咁然後呢"}]}