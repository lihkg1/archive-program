assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"7292176027eb4694c40124319d99fa482ca234af","tid":1029732,"uid":136431,"like":0,"dislike":0,"score":0,"quote":{"pid":"bdbb71f1b0be2645529606bf54bad0c07f0f49cb","tid":1029732,"uid":51271,"like":0,"dislike":0,"score":0,"quote":{"pid":"0bad70a3b937b9787583414ed366d1eca53af555","tid":1029732,"uid":136431,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2019-02-20T12:56:49.000Z","msg":"屢靠美國打救 中國做慣「伸手黨」<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n清國門戶開放<br />\n抗日戰爭<br />\n國共內戰唔幫國民黨<br />\n韓戰冇用原子彈炸中國<br />\n中蘇交惡<br />\n改革開放<br />\n習氏家族嘅國籍"},"citedBy":1,"replyTime":"2019-02-20T12:58:59.000Z","msg":"仲有蘋果設廠都係打救支那就業"},"citedBy":0,"replyTime":"2019-02-20T13:00:58.000Z","msg":"仲有仲有 華為偷蘋果技術都係美國打救<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"8d668e9b1eea4c6d44217219b03b3e810149e14f","tid":1029732,"uid":128603,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-02-20T13:06:20.000Z","msg":"沙士由邊度傳入香港？<br />\n<br />\n&quot;2003年2月21日，一名染病的廣州中山大學退休教授來港，並入住旺角京華國際酒店911號房，有關病毒正式進入本港。至3月初，沙田威爾斯親王醫院8A病房的醫護人員及病人相繼出現急性肺炎，及後迅速感染醫院訪客、相關人士的鄰居、同事，疫症終在3月中在社區爆發並蔓延，更經由航運及遊客散播至世界各地，成為一全球疫潮，但大陸方面疫情資訊仍被封鎖，一般市民所知不多。[3]<br />\n<br />\n之後，隨疫情不斷擴散，世界衞生組織對香港發旅遊警告，學校亦需停課，當中大批住客受感染的淘大花園E座更被頒令隔離。其時香港人心惶惶、百業簫條，各行各業大受打撃。&quot;<br />\n<br />\n<a href=\"https://evchk.fandom.com/wiki/2003%E5%B9%B4%E6%B2%99%E5%A3%AB%E7%96%AB%E6%BD%AE\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fevchk.fandom.com%2Fwiki%2F2003%25E5%25B9%25B4%25E6%25B2%2599%25E5%25A3%25AB%25E7%2596%25AB%25E6%25BD%25AE&d=WIvcVJ42Qixy%2BOT8%2FM1n8wKEBJewdHKi9Ib5gSSGE6s%3D&h=d0997e3d\" data-auto-link target=\"_blank\">https://evchk.fandom.com/wiki/2003%E5%B9%B4%E6%B2%99%E5%A3%AB%E7%96%AB%E6%BD%AE</a>"},{"pid":"b12a5f78c9f80ad81760f2c9516775317c6ab46d","tid":1029732,"uid":19552,"like":1