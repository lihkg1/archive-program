blank\">http://www.dw.com/en/spains-acs-takes-majority-stake-in-hochtief/a-15170633</a><br />\n<br />\n- 2015年禮頓控股改名為CIMIC集團<br />\n<a href=\"https://www.smh.com.au/business/leighton-to-change-name-to-cimic-in-wake-of-corruption-allegations-20150320-1m40j3.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.smh.com.au%2Fbusiness%2Fleighton-to-change-name-to-cimic-in-wake-of-corruption-allegations-20150320-1m40j3.html&d=98R5m9l%2B3%2F2o4DkYFN788ywN645TRhVPBLeqKBQ2Igw%3D&h=0ee572f5\" target=\"_blank\">https://www.smh.com.au/business/leighton-to-change-name-to-cimic-in-wake-of-corruption-allegations-20150320-1m40j3.html</a><br />\n<br />\n- 2016年12月CIMIC集團收購澳洲上市公司UGL<br />\n<a href=\"https://www.smh.com.au/business/cimic-in-lightning-raid-on-ugl-20161010-gryisa.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.smh.com.au%2Fbusiness%2Fcimic-in-lightning-raid-on-ugl-20161010-gryisa.html&d=98R5m9l%2B3%2F2o4DkYFN788ywN645TRhVPBLeqKBQ2Igw%3D&h=c54944ef\" target=\"_blank\">https://www.smh.com.au/business/cimic-in-lightning-raid-on-ugl-20161010-gryisa.html</a><br />\n<a href=\"https://www.cimic.com.au/__data/assets/pdf_file/0019/34426/213-COMPULSORY-ACQUISITION-OF-REMAINING-SHARES-IN-UGL.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.cimic.com.au%2F__data%2Fassets%2Fpdf_file%2F0019%2F34426%2F213-COMPULSORY-ACQUISITION-OF-REMAINING-SHARES-IN-UGL.pdf&d=98R5m9l%2B3%2F2o4DkYFN788ywN645TRhVPBLeqKBQ2Igw%3D&h=b553fed4\" target=\"_blank\">https://www.cimic.com.au/__data/assets/pdf_file/0019/34426/213-COMPULSORY-ACQUISITION-OF-REMAINING-SHARES-IN-UGL.pdf</a>"},{"pid":"ad1a8c657aa10666a640eb2344af22aa9c3b357e","tid":705453,"uid":4739,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-18T13:13:42.000Z","msg":"都好過到時出事要搵班工人食"},{"pid":"e53aaa07c6acf35b42304d45315d92e90cc54f30","tid":705453,"uid":169310,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc60b9556d692144295d36e52e9ca658fab1de3a","tid":705453,"uid":153972,"like":0,"disl