\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"77224900ae6305db26f33a2df29048797b83ca4e","tid":926162,"uid":175598,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-03T11:29:58.000Z","msg":"此回覆已被刪除"},{"pid":"2b9f8d378df668c16396bfef41ff767fc06b0624","tid":926162,"uid":219183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-03T17:08:47.000Z","msg":"係曹操寫嫁DLKH<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"ffe194fd8a22a514c27635ac2aa7528e7e33f999","tid":926162,"uid":44073,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2018-12-03T21:43:36.000Z","msg":"此回覆已被刪除"},{"pid":"7a4fcc2bbc4327a071a0f39a8cccfd76a52a147a","tid":926162,"uid":34277,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-04T12:03:24.000Z","msg":"推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}