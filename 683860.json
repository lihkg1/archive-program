{"tid":683860,"cid":15,"subCid":0,"title":"【貿易開戰】特朗普突宣布對５００億美元中國產品加徵關稅時間表","createTime":"2018-05-30T05:08:05.000Z","updateTime":"2018-05-30T06:04:00.000Z","uid":147097,"like":0,"dislike":0,"uniUserReply":8,"replies":[{"pid":"0d058bff77d7dbbdb6ed327ff34944a410a770a1","tid":683860,"uid":147097,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-30T05:08:05.000Z","msg":"《經濟通通訊社３０日專訊》在中美下一輪貿易談判將在數日後舉行之際，美國總統特朗普突然宣布，將推進對５００億美元的進口中國商品加徵２５％關稅並遏制中國在敏感技術領域投資的計劃，除非中國解決竊取美國知識產權的問題。　　白宮發表聲明稱，對進口中國商品徵稅的最終清單將於６月１５日前公布，而關稅將在「此後不久」實施，這是至今為止美國政府針對加徵關稅時間表作出的最為明確的表述。　　白宮還表示，將在６月３０日前宣布對中國投資的新限制措施及強化出口管制措施。　　美國商務部長羅斯將於本周訪問北京，嘗試與中方達成協議，敲定增加對華出口的確切數字。美方原本希望中國用兩年時間將每年對美國的貿易順差減少２０００億美元，但大部分經濟學家及貿易專家都認為這個數字完全不切實際，預計數年後美國對華出口可能最多只增加９００億美元。（ｍｎ）"},{"pid":"d623e602e700f3d858f138731c0b2652b5bac192","tid":683860,"uid":147097,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-30T05:10:13.000Z","msg":"等睇大陸反擊<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" />"},{"pid":"da6d6d1cea52b40a9c7b8ab1fda509f76cc074b5","tid":683860,"uid":33483,"like":2,"dislike":0,"score":2,"quote":{"pid":"d623e602e700f3d858f138731c0b2652b5bac192","tid":683860,"uid":147097,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-30T05:10:13.000Z","msg":"等睇大陸反擊<img src=\"/assets/faces/dog/fight_connect.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-30T05:14:27.000Z","msg":"唔洗架喇<br />\n<br />\n中國或成最大贏家"},{"pid":"28615d1ce2fbaa080bc4e21c7cdc1122a7d55a73","tid":683860,"uid":117947,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-30T05:14:35.000Z","msg":"贏國又贏啦"},{"pid":"379984b687f02fee403c9c082d496ae4b5b1f943","tid":683860,"uid":20898,"like":0,"dislike":0,"score":0,"quote":{"pid":"da6d6d1cea52b40a9c7b8ab1fda509f76cc074b5","tid":683860,"uid":33483,"like":2,"dislike":0,"score":2,"quote":{"pid":"d623e602e700f3d858f138731c0b2652b5bac192","tid":683860,"uid":147097,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-30T05:10:13.000Z","msg":"等睇大陸