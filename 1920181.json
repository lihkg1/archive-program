/%E6%AD%A6%E6%BC%A2%E8%82%BA%E7%82%8E-%E7%96%AB%E6%83%85%E6%95%B8%E6%93%9A%E5%B7%B2%E6%88%90%E9%A2%A8%E5%9C%9F%E7%97%85-%E9%86%AB%E7%AE%A1%E5%B1%80%E5%9B%9B%E6%9C%88%E5%89%8D%E5%A2%9E%E7%B4%84400%E9%9A%94%E9%9B%A2%E7%97%85%E5%BA%8A%E6%87%89%E5%B0%8D/</a><br />\n<br />\n醫管局講嘅<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}