:145317,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:31:45.000Z","msg":"推"},{"pid":"1f228a2aff75189868a3321edaa76f554929fee4","tid":1343992,"uid":32130,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:32:25.000Z","msg":"大家幫幫手<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f5f1ae8aba66f990a7d06d34f639558ce153d626","tid":1343992,"uid":239499,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:32:35.000Z","msg":"推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"2a29aefc1ef91956c36e4b7b86b1324a94a369b5","tid":1343992,"uid":32130,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:32:37.000Z","msg":"推"},{"pid":"2b82163c25704dae9806b1c57be75138fbc7b1c4","tid":1343992,"uid":273252,"like":0,"dislike":0,"score":0,"quote":{"pid":"1b8b704e162a26847af82b4d60ddf306667656e7","tid":1343992,"uid":32130,"like":1,"dislike":0,"score":1,"quote":{"pid":"588b841994b41b28ff33cf56863fbd6d215d2686","tid":1343992,"uid":226993,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-21T20:13:23.000Z","msg":"<a href=\"https://lihkg.com/thread/1343135/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1343135/page/1</a><br />\n<br />\n咁係Twitter 幫下手！記得加#hongkongwarning"},"citedBy":1,"replyTime":"2019-07-21T20:16:41.000Z","msg":"其實有好多外國人想幫手但係唔知點幫 我哋要好明確咁同佢地講點樣先幫到<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-21T20:33:12.000Z","msg":"全民頭盔月<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/dnomJS\" data-auto-link target=\"_blank\">https://lih.kg/dnomJS</a>"},{"pid":"fc063aed30641fa8bd0011766ad4e34cb7de8d71","tid":1343992,"uid":101824,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:33:29.000Z","msg":"推"},{"pid":"039fd477dfca7cc0fb45cd2d000115f59dea6ef1","tid":1343992,"uid":32130,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:33:49.000Z","msg":"推"},{"pid":"3d91ce86e0622df55dd47fac621de49874ae24d1","tid":1343992,"uid":32130,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:34:29.000Z","msg":"小弟英文唔好<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />有冇文宣巴打幫手"},{"pid":"9faa9d3a895c96fb1d6f14fd26e51f96820890c5","tid":1343992,"uid":38742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:34:34.000Z","msg":"推"},{"pid":"e66eeab408d239e51a86eda188ef17cc8e074ff7","tid":1343992,"uid":240968,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-07-21T20:34:38.000Z","msg":"致泰國領事館<br />\n<br />\n本人為香港市民，鑑於香港最近警方對示威者與市民隨機武力鎮壓，乃至昨日7月21日本地黑幫治安問題及警能失效，體現香港一國兩制的崩壞，無法保障訪港旅客之人生與財產安全。本人預計有關情況會持續至少一段時間，並對旅客造成實質安全威脅，現向泰國領事館作出呼籲，要求泰國當局向香港發出黑色旅遊之警示。<br />\n<br />\n近日本地市民自發進行一連串示威行動抗議政府躁暴推行送中條例，以及警方處理手段，政府不回應有關訴求並加以不合理、違法的警權力躁暴對待示威者及途徑市民。就以7月14日沙田遊行為例，警方於當晚10時在商場職員帶領之下進入商場暴力清場，受影響的人等當中不乏路過旅客。以昨日7月21日港島遊行為例，政府總共向示威者開了36發子彈以驅趕人群，當中有不少是在無預警下向示威者開槍。過大的警權力絕對使旅客生命受到威脅。<br />\n<br />\n另外，昨晚7月21日，本地穿著白衫的圍村黑幫集結於新界元朗區，以鐵通、藤條、鐵支無差別毆打非白衫的路過青年，並成群結隊進入元朗地鐵站範圍叫囂恐嚇市民，和平示威者與記者。及後黑幫更追捕人群，進入列車平台並毆打列車內議員、示威者、乘客，造成大規模流血事件，而傷者當中更有老弱婦孺。面對大型衝突，警房不但縱容暴戾黑幫，未有及時派遣警察制止事件，更無理關閉有關通報服務，目前元朗、天水圍及荃灣警署的999電話通報及報案室均暫停服務。若旅客於當區遇上危險，人生財產安全必受嚴重威脅。<br />\n<br />\n再者，網民就昨晚事件，緊急發起7月22日罷市罷工罷課行動，屆時會有不少人響應，將嚴重影響訪港旅客的旅遊體驗。<br />\n<br />\n一國兩制為香港特區政府管治的基礎，但種種跡象顯示中華人民共和國共產黨務求以最快速，最暴力手段鎮壓香港示威者，不惜一切犧牲特區政府以一國兩制為原則下向泰國遊客的承諾與權利。一國兩制已經失效，而當中威脅已經大大影響泰籍遊客實質安全。故此，本人現向泰國領事館作出呼籲，要求泰國當局向香港發出黑色旅遊之警示。<br />\n<br />\n<br />\n市民<br />\nXXX僅啟<br />\n<br />\n2019年7月22日<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n中英文都廢，歡迎任改，建議加圖/ 加新聞link/ 翻譯做英文+各國語言，再send 比領事館/親手交<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">文宣組出動</span></span></strong><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>光復香港 時代革命</strong></span></span>"},{"pid":"688e5e98bd0a32ca5a244c9934790c6566949a30","tid":1343992,"uid":264796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:35:04.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4fb8e5bd8986da1cb752f5f6ee5edbd527417447","tid":1343992,"uid":242737,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-21T20:35:07.000Z","msg":"推"},{"pid":"1ee27955ca38eb989e760506285bf95f3751f765","tid":1343992,"uid":32130,"like":0,"dislike":0,"score":0,"quote":{"pid":"e66eeab408d239e51a86eda188ef17cc8e074ff7","tid":1343992,"uid":240968,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-07-21T20:34:38.000Z","msg":"致泰國領事館<br />\n<br />\n本人為香港市民，鑑於香港最近警方對示威者與市民隨機武力鎮壓，乃至昨日7月21日本地黑幫治安問題及警能失效，體現香港一國兩制的崩壞，無法保障訪港旅客之人生與財產安全。本人預計有關情況會持續至少一段時間，並對旅客造成實質安全威脅，現向泰國領事館作出呼籲，要求泰國當局向香港發出黑色旅遊之警示。<br />\n<br />\n近日本地市民自發進行一連串示威行動抗議政府躁暴推行送中條例，以及警方處理手段，政府不回應有關訴求並加以不合理、違法的警權力躁暴對待示威者及途徑市民。就以7月14日沙田遊行為例，警方於當晚10時在商場職員帶領之下進入商場暴力清場，受影響的人等當中不乏路過旅客。以昨日7月21日港島遊行為例，政府總共向示威者開了36發子彈以驅趕人群，當中有不少是在無預警下向示威者開槍。過大的警權力絕對使旅客生命受到威脅。<br />\n<br />\n另外，昨晚7月21日，本地穿著白衫的圍村黑幫集結於新界元朗區，以鐵通、藤條、鐵支無差別毆打非白衫的路過青年，並成群結隊進入元朗地鐵站範圍叫囂恐嚇市民，和平示威者與記者。及後黑幫更追捕人群，進入列車平台並毆打列車內議員、示威者、乘客，造成大規模流血事件，而傷者當中更有老弱婦孺。面對大型衝突，警房不但縱容暴戾黑幫，未有及時派遣警察制止事件，更無理關閉有關通報服務，目前元朗、天水圍及荃灣警署的999電話通報及報案室均暫停服務。若旅客於當區遇上危險，人生財產安全必受嚴重威脅。<br />\n<br />\n再者，網民就昨晚事件，緊急發起7月22日罷市罷工罷課行動，屆時會有不少人響應，將嚴重影響訪港旅客的旅遊體驗。<br />\n<br />\n一國兩制為香港特區政府管治的基礎，但種種跡象顯示中華人民共和國共產黨務求以最快速，最暴力手段鎮壓香港示威者，不惜一切犧牲特區政府以一國兩制為原則下向泰國遊客的承諾與權利。一國兩制已經失效，而當中威脅已經大大影響泰籍遊客實質安全。故此，本人現向泰國領事館作出呼籲，要求泰國當局向香港發出黑色旅遊之警示。<br />\n<br />\n<br />\n市民<br />\nXXX僅啟<br />\n<br />\n2019年7月22日<br />\n<br />\