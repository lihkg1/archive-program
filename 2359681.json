ts/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"37d7f0bbc06147be661b0beb917b7c443bb9a834","tid":2359681,"uid":35914,"like":1,"dislike":5,"score":-4,"citedBy":0,"replyTime":"2021-01-09T06:35:33.000Z","msg":"我入到黎竟然無圖<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"7773a6c6a7e152c8072c3fe635fce24ce7505583","tid":2359681,"uid":121546,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-09T06:38:13.000Z","msg":"女: 我體重咁重但係睇落仲咁瘦,實係天生麗質"},{"pid":"8ea717e29fb845420d782b605481d066c18757b3","tid":2359681,"uid":123591,"like":1,"dislike":0,"score":1,"quote":{"pid":"a8a2608b18faf02ef80853b9d9a033ea9c8058ee","tid":2359681,"uid":1654,"like":29,"dislike":155,"score":-126,"citedBy":6,"replyTime":"2021-01-09T06:08:25.000Z","msg":"<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2021-01-09T06:39:44.000Z","msg":"第二張係咩黎"},{"pid":"c4ec125034532851d761f9ee99177453afe541d8","tid":2359681,"uid":147522,"like":2,"dislike":0,"score":2,"quote":{"pid":"8ea717e29fb845420d782b605481d066c18757b3","tid":2359681,"uid":123591,"like":1,"dislike":0,"score":1,"quote":{"pid":"a8a2608b18faf02ef80853b9d9a033ea9c8058ee","tid":2359681,"uid":1654,"like":29,"dislike":155,"score":-126,"citedBy":6,"replyTime":"2021-01-09T06:08:25.000Z","msg":"<img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2021-01-09T06:39:44.000Z","msg":"第二張係咩黎"},"citedBy":0,"replyTime":"2021-01-09T06:40:11.000Z","msg":"異形"},{"pid":"0a75982727043e58b0967350d9abaff6aff7e42a","tid":2359681,"uid":8500,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-09T06:40:29.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d584e87dae462e3d2c566b85abaa2e8f279992a8","tid":2359681,"uid":155654,"like":0,"dislike":1,"score":-1,"quote":{"pid":"8ea717e29fb845420d782b605481d066c18757b3","tid":2359681,"uid":123591,"like":1,"dislike":0,"score":1,"quote":{"pid":"a8a2608b18faf02ef80853b9d9a033e