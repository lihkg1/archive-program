ts/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"855ba34b95dacfae8c709be8706521cac31c4f12","tid":1432683,"uid":268519,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-08T10:11:42.000Z","msg":"記者都要升級喇 <br />\n發問問題要有相同片黎認證"},{"pid":"f3f6f0df90d347cd57a562e12483eb7783987f23","tid":1432683,"uid":99274,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-08T10:12:45.000Z","msg":"同埋既然班狗唔會正面答又或者鳩答你地嘅問題<br />\n<br />\n記者就應該直接指控佢地做過嘅仆街野<br />\n<br />\n係呢個咁多人睇嘅時刻展示出佢地做過嘅仆街野<br />\n<br />\n咁做唔係要令到大家仇警<br />\n<br />\n只係要令大眾市民認清楚班仆街嘅真面目<br />\n<br />\n佢地答你地嘅說話係幾咁撚假"},{"pid":"4c4fb7a6ce031db99bcaf8a74a87ed6e9b707d8d","tid":1432683,"uid":99274,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-08T10:14:43.000Z","msg":"TATP同燃燒彈一直被班狗同埋政府用作話題<br />\n<br />\n我個人認為好必要令大眾知道返呢樣野係假嘅<br />\n<br />\n如果真係有嘅話點解釋一隻狗隻都冇受過重傷同燒傷"},{"pid":"776aa7756dedd9159aec5f624c3291a15817d70d","tid":1432683,"uid":278138,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-08T10:22:28.000Z","msg":"集中問721元朗白衣恐襲事件就已經令佢哋啞口無言！"},{"pid":"b376cb2dec32c4175c37a04b382a60e696b1816d","tid":1432683,"uid":99274,"like":0,"dislike":0,"score":0,"quote":{"pid":"776aa7756dedd9159aec5f624c3291a15817d70d","tid":1432683,"uid":278138,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-08T10:22:28.000Z","msg":"集中問721元朗白衣恐襲事件就已經令佢哋啞口無言！"},"citedBy":0,"replyTime":"2019-08-08T10:39:00.000Z","msg":"好難<br />\n<br />\n要問嘅利君雅都已經問晒<br />\n<br />\n我相信佢地依家已經整左個官方答案出黎答晒當日嘅問題"},{"pid":"ada5453210ff8ce308e4a5af462eea20f0d5722f","tid":1432683,"uid":99274,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-08T10:46:36.000Z","msg":"同埋我想講呢<br />\n<br />\n關於革命呢兩個字我聽過梁天琦有個好好嘅解釋<br />\n<br />\n對於一個政權由上而下咁樣去改善嘅話就叫改革<br />\n由下而上去改變一個政權一個政策嘅話就叫做革命"},{"pid":"bfef71b679f634ab7d6163976fd56050686464ed","tid":1432683,"uid":99274,"like":0,"dislike":0,"score":0,"quote":{"pid":"ada5453210ff8ce308e4a5af462eea20f0d5722f","tid":1432683,"uid":99274,"like":0,"dislike":0,"score":0,"cite