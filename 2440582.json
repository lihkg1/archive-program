dn.net/v/t1.0-9/157846998_2957848261111771_1117126462605665679_o.jpg?_nc_cat=101&amp;ccb=1-3&amp;_nc_sid=8bfeb9&amp;_nc_ohc=3QP899NZrYgAX_03_g2&amp;_nc_ht=scontent.ftpe7-4.fna&amp;oh=94e975a89e7148855706aad88a19d1a1&amp;oe=606C1E95\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.ftpe7-4.fna.fbcdn.net%2Fv%2Ft1.0-9%2F157846998_2957848261111771_1117126462605665679_o.jpg%3F_nc_cat%3D101%26ccb%3D1-3%26_nc_sid%3D8bfeb9%26_nc_ohc%3D3QP899NZrYgAX_03_g2%26_nc_ht%3Dscontent.ftpe7-4.fna%26oh%3D94e975a89e7148855706aad88a19d1a1%26oe%3D606C1E95&h=0a1a4b2f&s={SIZE}\" />"},{"pid":"481af85905256092182dd9e8148142ca4c015759","tid":2440582,"uid":361913,"like":0,"dislike":0,"score":0,"quote":{"pid":"b31ac469369b260af44424eab6286c872a98d814","tid":2440582,"uid":337052,"like":1,"dislike":0,"score":1,"quote":{"pid":"e8a253039d4fc0424e2135a605dd096e9c528ff4","tid":2440582,"uid":44454,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-03-10T05:04:36.000Z","msg":"叫中國禁埋紙箱啦<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-10T05:07:03.000Z","msg":"紙箱是台灣製造"},"citedBy":1,"replyTime":"2021-03-10T05:20:24.000Z","msg":"叫黑煙號包圍台灣周邊海空"},{"pid":"c0b0642d08850d11b3b0eef86e87bd98d28c628e","tid":2440582,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-10T05:22:02.000Z","msg":"<a href=\"https://youtu.be/SVVEJ_mSrW4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FSVVEJ_mSrW4&d=QSug7dhZHD7voFbR5lwplW58GJy%2FOqJThDagGYh0BQk%3D&h=6aa1f37b\" data-auto-link target=\"_blank\">https://youtu.be/SVVEJ_mSrW4</a><br />\n台灣鳳梨香港掀熱潮，林兆彬議員介紹太子水果店Joyful Juice &amp; Fruit，熱賣35元/個。"},{"pid":"0efff238bf1a80c74ba7df6823c8eb1e781d7dfd","tid":2440582,"uid":7547,"like":0,"dislike":0,"score":0,"quote":{"pid":"74d58fc599f92fff72f5c1a769ffdedbd9c6d170","tid":2440582,"uid":153956,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-10T05:11:10.000Z","msg":"比香港往年多5倍, 夠唔夠中國無左既1%?"},"citedBy":0,"replyTime":"2021-03-10T05:22:24.000Z","msg":"中國幾億人一個月得2000蚊，你估真係買好撚多咩<br />\n<br />\n只喺中國資訊封鎖未食過好嘢，乜嘢狗屎垃圾都照收，打包賣過去唔洗煩咋嘛。 香港 日本 澳洲開放市場競爭大，其實報價仲低，食慣好嘢差小小都唔要"},{"pid":"4011c93a76a88260a33562a150a1a3d8db5d4ff4","tid":2440582,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"481af85905256092182dd9e8148142ca4c015759","tid":2440582,"uid":361913,"like":0,"dislike":0,"score":0,"quote":{"pid":"b31ac469369b260af44424eab6286c872a98d814","tid":2440582,"uid":337052,"like":1,"dislike":0,"score":1,"quote":{"pid":"e8a253039d4fc0424e2135a605dd096e9c528ff4","tid":2440582,"uid":44454,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-03-10T05:04:36.000Z","msg":"叫中國禁埋紙箱啦<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-10T05:07:03.000Z","msg":"紙箱是台灣製造"},"citedBy":1,"replyTime":"2021-03-10T05:20:24.000Z","msg":"叫黑煙號包圍台灣周邊海空"},"citedBy":0,"replyTime":"2021-03-10T05:23:15.000Z","msg":"小心台灣雄風飛彈"},{"pid":"70669b3ef6c1a484f75846272f12cb354f6e5753","tid":2440582,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-10T05:27:51.000Z","msg":"<strong><span class=\"x-large\">台鳳梨香港熱賣 區議員：發揮黃色經濟圈力量</span></strong><br />\n更新時間：2021-03-10 12:58:48<br />\n<br />\n<a href=\"https://youtu.be/SVVEJ_mSrW4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FSVVEJ_mSrW4&d=QSug7dhZHD7voFbR5lwplW58GJy%2FOqJThDagGYh0BQk%3D&h=6aa1f37b\" data-auto-link target=\"_blank\">https://youtu.be/SVVEJ_mSrW4</a><br />\n<br />\n【新唐人亞太台 2021 年 03 月 10 日訊】中共暫停進口台灣鳳梨，香港、日本等地紛紛掀起買鳳梨熱潮，力挺台灣。有香港區議員說，這次港人再次發揮黃色經濟圈的威力，聲援台灣。請看我們前線記者的報導。<br />\n<br />\n這家位於香港太子的水果店，大大顆台灣鳳梨擺在當眼位置，職員熟練地去皮、切開，從早忙到晚。雖然價錢不便宜，小的35元一顆，大的40-50元港幣，但還是同樣搶購一空。<br />\n<br />\n香港市民：「台灣鳳梨好吃呀，很出名的。我們要支持台灣產品，中共說不好的，我們覺得好呀。中共越說不好的，我們越要支持。」水果店職員：「我們都多謝（台灣）支持香港，我們現在也支持台灣，大家加油！」<br />\n<br />\n當區區議員林兆彬表示，早幾週已收到市民查詢，經聯絡水果店老闆後，特別從台灣空運鳳梨來香港，多家黃店都加入熱賣行列。<br />\n<br />\n香港區議員 林兆彬：「中共打壓台灣鳳梨不對，是政治打壓。香港人聲援台灣，聲援台灣的農民，發揮香港人黃色經濟圈的力量，原來可以離開香港（支持其他地方）」。<br />\n<br />\n據了解，澳門2日也跟隨大陸禁運台灣鳳梨，但出口香港仍然維持，出口價格仍是最高。目前香港水果批發市場沒有進貨，而是靠民眾自發從台灣空運訂購。<br />\n<br />\n新唐人記者 梁珍 香港報導"},{"pid":"32f24772c6b28c348ae62e21e77b81e3085ca79c","tid":2440582,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-10T05:33:46.000Z","msg":"港人力挺台灣鳳梨銷量升5倍 水果店老闆：紙箱不夠用"},{"pid":"72bfbbff571a9a0288e765b70a675401811ce653","tid":2440582,"uid":50935,"like":7,"dislike":0,"score":7,"quote":{"pid":"355a2e499d7663cb031b684f11e78d2928ce3e27","tid":2440582,"uid":337052,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2021-03-10T05:12:55.000Z","msg":"豪記蔬果<br />\n昨天上午4:19  &middot; <br />\n開左門喇🥱<br />\n<br />\n台灣金鑽鳳梨5/6/7/8/9裝<br />\n$160/箱<br />\n<br />\n散買<br />\n$35/個（5裝<br />\n$20/個（9裝<br />\n<br />\n<img src=\"https://scontent.ftpe7-4.fna.fbcdn.net/v/t1.0-9/158105989_827676934451734_8421750906004241978_o.jpg?_nc_cat=107&amp;ccb=1-3&amp;_nc_sid=8bfeb9&amp;_nc_ohc=uIiNuwGj5ekAX_e88kW&amp;_nc_ht=scontent.ftpe7-4.fna&amp;oh=1fc826501bebec4a246f0e747f6aa4eb&amp;oe=606E5247\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.ftpe7-4.fna.fbcdn.net%2Fv%2Ft1.0-9%2F158105989_827676934451734_8421750906004241978_o.jpg%3F_nc_cat%3D107%26ccb%3D1-3%26_nc_sid%3D8bfeb9%26_nc_ohc%3DuIiNuwGj5ekAX_e88kW%26_nc_ht%3Dscontent.ftpe7-4.fna%26oh%3D1fc826501bebec4a246f0e747f6aa4eb%26oe%3D606E5247&h=1c883a0a&s={SIZE}\" /><br />\n<br />\n<a href=\"https://www.facebook.com/156315858254515/photos/a.156328788253222/827676931118401/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F156315858254515%2Fphotos%2Fa.156328788253222%2F827676931118401%2F&d=QSug7dhZHD7voFbR5lwplW58GJy%2FOqJThDagGYh0BQk%3D&h=c1bab88c\" data-auto-link target=\"_blank\">https://www.facebook.com/156315858254515/photos/a.156328788253222/827676931118401/</a>"},"citedBy":0,"replyTime":"2021-03-10T05:37:03.000Z","msg":"隻貓都想食<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7e6cb8edfb14a5a5e4566ff3af57aef86c294c94","tid":2440582,"uid":36157,"l