ormal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"5dd3a0ee0762cc638573fba3cd219045a2a1251b","tid":109973,"uid":34834,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T14:11:50.000Z","msg":"譯做 <br />\n呢件羊毛呢架頂"},{"pid":"3413efaaceb5941d48c8ff0f572f6e153a7fa1f7","tid":109973,"uid":20270,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T14:14:19.000Z","msg":"睇嗰陣都屌晒鬼 想賣弄詞藻 但句句都無乜連貫性 原文文意又譯唔準<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"6199272afdc0df27b16e31298be393f80d77ae05","tid":109973,"uid":34834,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T14:14:58.000Z","msg":"<blockquote>太freestyle,為左要個優美詞藻而犧牲左唔少原文內容<br />\n不過都係一個新嘗試黎<br />\n只不過我地中英都識,好容易就睇到d奇怪位</blockquote><br />\n<br />\n我都覺<br />\n某程度上係舒琪以原文大意作詩<br />\n不過翻譯既orientation好多<br />\n今次就係信同雅既角力"},{"pid":"87957c1598d6eedcf33ef7023a52733e8a720909","tid":109973,"uid":13946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T15:00:06.000Z","msg":"我反而覺得攞到意境已經唔錯<br />\n如果聽唔明英文都感受到個氣氛<br />\n如果直譯無錯係易明啲個歌詞但好似難入個意境<br />\n啲廢中廢老睇會好難明<br />\n<br />\n明天又是新一天<br />\n-會覺得今日係食緊屎<br />\n<br />\n在晴朗的一天再出發<br />\n-會覺得明日復明日等晴朗先再出發但已經起唔切方舟"},{"pid":"890bd2a7da133f0f1efeb7f5b406cbe3b6871c83","tid":109973,"uid":56720,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T15:11:29.000Z","msg":"此回覆已被刪除"},{"pid":"ba7edf92fb3965dc10390833af859b31a784c86e","tid":109973,"uid":6721,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T15:37:54.000Z","msg":"我見到有句好似譯錯tuesday 變左星期四<br />\n利申 emily stone 世界第一"},{"pid":"554fbf673f689b266bf6dcdee6caf22e927f9a79","tid":109973,"uid":48479,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T16:07:34.000Z","msg":"<blockquote>睇睇下會留意左歌詞<br />\n搞到抽離左咁 冇代入感<br />\n有d譯得好有d差<br />\n其實搵返專業翻譯唔得咩<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /></blockquote><br />\n舒琪譯字幕譯咗幾廿年<br />\n讀大學嗰陣讀過有關字幕翻譯嘅course，都有用舒琪嘅論文做教材<br />\n<br />\n其實字幕翻譯係一種好特別嘅翻譯<br />\n首先，字幕出現時間短，要確保觀眾能在幾秒間理解得到<br />\n其次，英語電影字幕翻譯係會同原文一齊被接收 (原文聽覺，譯文視覺)<br />\n而歌舞電影字幕翻譯精妙之處就係要利用文句結構(視覺)配合音樂與歌詞嘅律動(聽覺)，呢方面我個人覺得舒琪做得非常出色<br />\n不過世事無兩全其美，當你要追求文句結構精美嘅時候，難免會跟原文有少許差異。但我唔見戲中有十分嚴重嘅差異，個人覺得舒琪已經攞咗個幾好嘅平衡。<br />\n<br />\n利申：門外漢，有錯請指正"},{"pid":"7a5cb801739f2a74df77e060f57b86a036bb1110","tid":109973,"uid":48479,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T16:09:11.000Z","msg":"<blockquote>我見到有句好似譯錯tuesday 變左星期四<br />\n利申 emily stone 世界第一</blockquote><br />\n真係？<br />\n大約係邊part？等我遲d出碟嗰陣留意下"},{"pid":"d19649832d2da58e9889e7c7e433c66d4723dd36","tid":109973,"uid":9098,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T16:10:18.000Z","msg":"<blockquote><blockquote>睇睇下會留意左歌詞<br />\n搞到抽離左咁 冇代入感<br />\n有d譯得好有d差<br />\n其實搵返專業翻譯唔得咩<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /></blockquote><br />\n舒琪譯字幕譯咗幾廿年<br />\n讀大學嗰陣讀過有關字幕翻譯嘅course，都有用舒琪嘅論文做教材<br />\n<br />\n其實字幕翻譯係一種好特別嘅翻譯<br />\n首先，字幕出現時間短，要確保觀眾能在幾秒間理解得到<br />\n其次，英語電影字幕翻譯係會同原文一齊被接收 (原文聽覺，譯文⋯個幾好嘅平衡。<br />\n<br />\n利申：門外漢，有錯請指正</blockquote><br />\n認同巴打，<br />\n始終「翻譯」同「字幕」重疊範圍都唔少；<br />\n我覺得今次中譯算係咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"aa9e821a9a713271dc44cff2fb462455f26ac83b","tid":109973,"uid":12360,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T16:20:12.000Z","msg":"我覺得平時對白freestyle d冇咩所謂 但佢地唱果陣用返直譯比較入到意境"},{"pid":"c70d9bc4757aa082d0d5afd3b31d20ccf7e2dacd","tid":109973,"uid":5662,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T17:50:55.000Z","msg":"可能對呢一代人嚟講太過文縐縐 你睇宜家香港嘅歌詞都直白咗唔少 識得詩詞歌賦嘅人又所剩無幾"},{"pid":"2707a095f698d1beccc3151a6f02040de1953d43","tid":109973,"uid":39666,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-06T17:59:01.000Z","msg":"站喺歌詞嘅立場，一首旋律好密嘅歌係唔應該有太大嘅訊息量。同理，呢部戲有好多歌都偏快，本身就唔適合將啲歌翻譯得太文謅謅，舒琪唔只改咗人哋嘅意思，仲要不停玩文字玩詞藻，其實會令人睇得好辛苦。"},{"pid":"e2067cbc75201314b60a03ad22b00536eb6ceade","tid":109973,"uid":65600,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-07T01:13:06.00