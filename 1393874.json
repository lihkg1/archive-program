bnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FO9CNzr7.gif&h=d85862df&s={SIZE}\" />"},{"pid":"0c8caa7671f0ad076f5dbf7f502fc31878a51d26","tid":1393874,"uid":66113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T08:33:14.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"fbb440c79bfd652d8bd094a889c05b8a74561c38","tid":1393874,"uid":66113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T08:34:02.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"a728b036338ef5c8dd4d9ea3f242666a9876214e","tid":1393874,"uid":79410,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T08:37:03.000Z","msg":"停埋個人遊啦屌你老母"},{"pid":"d4de97b61cd2909c85a409d5d12ac8e466cde3b4","tid":1393874,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T08:37:04.000Z","msg":"不如去中旅社踩場<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n包保第二日無哂旅客"},{"pid":"c3c1d2b20c472dbcaaaec985e113191c80d3ae22","tid":1393874,"uid":76591,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T08:39:48.000Z","msg":"香港團九成呃人，全部取消對香港旅遊業有幫助"},{"pid":"6dc8c014ebf57ec62a290b2f7bd0a3e176f6af86","tid":1393874,"uid":71199,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T08:59:49.000Z","msg":"呢幾日公司附近都少左旅遊巴同啲塞住成條路嘅大陸客，食飯又唔洗同佢地迫，個世界好似乾淨左又舒服左咁 <img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"6e1178ed37f193dbf1064bed6860f9494a9fd877","tid":1393874,"uid":109629,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-01T09:00:26.000Z","msg":"求你鞭打本王<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},{"pid":"eb646100343fe1f2cdfb1a3348f1175ec78cda87","tid":1393874,"uid":39668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-07T10:50:27.000Z","msg":"<img src=\"https://na.cx/i/fH4hgx4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfH4hgx4.jpg&