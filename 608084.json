id":"68324df9d70e5ac07b9272706a8154c4e7671462","tid":608084,"uid":38973,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-28T03:20:48.000Z","msg":"主主又肥咗<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e0fbbd6da172d822c24daa3b692e9fbc0a9cc6df","tid":608084,"uid":2914,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-28T03:28:04.000Z","msg":"屌你堂堂領導人<br />\n見面都要鬼鬼祟祟<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a347b931aa4c7d287d7a3a68a3549948ea2fdcc6","tid":608084,"uid":67500,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-28T03:33:13.000Z","msg":"李後主我就識"},{"pid":"0f50cda47aec975b3b2b14532f295692c1a7df4f","tid":608084,"uid":20933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-28T03:40:49.000Z","msg":"<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"96d908c9ab67050b7ee94c3f93cbe11b7a5d6b17","tid":608084,"uid":20933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-28T03:46:31.000Z","msg":"<strong> 朝中社：習近平接受金正恩邀請「方便時往訪」</strong><br />\n<br />\n<img src=\"https://fs.mingpao.com/ins/20180328/s00004/299201b30590dbcab40b539ae7d968b5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffs.mingpao.com%2Fins%2F20180328%2Fs00004%2F299201b30590dbcab40b539ae7d968b5.jpg&h=0505a649&s={SIZE}\" /><br />\n<br />\n朝鮮最高領導人金正恩與夫人李雪主於本月25日至28日應邀到北京進行非正式訪問。朝鮮官媒朝中社報道，中國國家主席習近平欣然接受金正恩邀請，在方便的時候訪問平壤。<br />\n<br />\n另外，中國將派出中共中央政治局委員楊潔箎以習近平特別代表身分，明日到訪韓國向總統文在寅介紹中朝領導人會談結果。<br />\n <br />\n據韓聯社報道，楊潔箎會先與韓國國家安保室室長鄭義溶共進晚餐並會談，雙方會就朝鮮半島無核化等問題交換意見；報道又指中方在今早正式公布金正恩訪華消息前，已向青瓦台通報有關事宜。<br />\n<br />\n對於金正恩訪華，美國白宮發言人桑德斯（Sarah Sanders）表示，美方近來對朝鮮施以的巨大壓力為今次中朝會談創造恰當氛圍。"},{"pid":"4f660419fbe3a9451de4d5889382a5058ac2ed94","tid":608084,"uid":11097,"like":10,"dislike":0,"score":10,"citedBy":0,"replyTime":"2018-03-28T03:48:19.000Z","msg":"世界兩大癌細胞"},{"pid":"60348aa6a0c786120be2c7703912ff2ee76d6313","tid":608084,"uid":14503,"like":0,"dislike":0,"score":0,