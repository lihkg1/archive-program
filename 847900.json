":847900,"uid":14103,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-04T19:39:35.000Z","msg":"我做哂短命野 好彩我生存係香港 如果唔係我會好傷心<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"dedf9890463da506f81576f219f52ca1fa149d27","tid":847900,"uid":82917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-10T04:17:40.000Z","msg":"點樣訓15分鐘<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}