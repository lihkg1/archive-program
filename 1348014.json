gmoji\" />"},{"pid":"31ab79c1c3ac30da43acbdf59e5aa0bb2b129e53","tid":1348014,"uid":150739,"like":0,"dislike":0,"score":0,"quote":{"pid":"a0a4e1111451f180cce7d85806d253cec26a7269","tid":1348014,"uid":282438,"like":1,"dislike":0,"score":1,"quote":{"pid":"16bf505de158bff74321f95b8ac03f43facf6472","tid":1348014,"uid":150739,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-07-22T07:17:57.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-22T08:48:04.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-22T09:02:10.000Z","msg":"中間有樓梯落<br />\n落唔到想佢地走遠啲去大窩口方向<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d213692844794cd14c42b4327d2aced1c3b75d10","tid":1348014,"uid":282438,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-22T09:04:58.000Z","msg":"係荃豐千其唔好行天橋，因為大窩口方向係荃灣警署新界南總區警察總部，屯門方向係荃灣區警署，荃豐係正中間。<br />\n<br />\n要走一定要向荃灣西/眾安街方向係地下走。因為荃灣呢個舊區除左楊屋道同青山公路外，其餘只有2條行車線，平時都已經塞車塞到PK。<br />\n<br />\n但重點係大窩口方向嗰個荃灣警署新界南總區警察總部係有戰略設計，屋頂有個特別高直升機台可以作瞭望塔用，基本成個荃灣區區九成十字路口都睇到，但因為係十年前整，所以呢十年先起好係荃灣西樓都會遮緊啲。<br />\n<br />\n另外海濱、綠陽、荃灣中心等比較舊私人屋苑有好多單位由政府以前買落做公務宿舍，大家無必要就唔好去喇。<br />\n<br />\n利申地生地長荃灣人"},{"pid":"9fec4226db73c4fd0f8c087dfe6c674b09d4ffdf","tid":1348014,"uid":56926,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T09:06:11.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"7080df83cbf3a4f12886e52480ac0d601a392f8c","tid":1348014,"uid":60588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T09:07:16.000Z","msg":"荃灣要走時千奇唔好去楊屋道個個方向"},{"pid":"9e863b5cd5af1afb9eb48164d07411c283d42063","tid":1348014,"uid":239205,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T09:07:21.000Z","msg":"荃灣地鐵站附近係咪好危險"},{"pid":"f6834239ea53948c65f061b9e2fb8dda83185f2e","tid":1348014,"uid":212419,"like"