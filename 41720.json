2F16%2F141150_c4e921b5d3c60bbba0fbe6cec1daf3da.jpg&h=2ba9d5c0&s={SIZE}\" /></blockquote><br />\n你依個位邊有40/50米<br />\n佢一加速你又慢緊車 可以撞架WOR</blockquote><br />\n<br />\nbtw<br />\n咁叫40/50米？<br />\n畀盡都係2個車位<br />\n你得2個車位就想出去<br />\n實畀人dup停啦<br />\n<br />\n小路出大路如果令大路車減速就你，已經係錯誤嘅出車時間<br />\n實肥你"},{"pid":"f0176ce5a2b27efa767081ebabbae350f224121a","tid":41720,"uid":52132,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-16T06:35:33.000Z","msg":"好近下其實 一兩啖油就到<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n下次睇定晒見好出"},{"pid":"e88a48bd66459691b1c5366d7b213bf1c701e53a","tid":41720,"uid":65930,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-16T06:38:54.000Z","msg":"留名"},{"pid":"7aed69911dd7288e5cd1a23c695455e38a3f2e08","tid":41720,"uid":21028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-16T06:55:30.000Z","msg":"<blockquote><blockquote><blockquote>即係考官就係神...<br />\n唉...明明仲有一大段距離<br />\n部小巴就係巴士站哩個位置<br />\n<img src=\"https://img.eservice-hk.net/upload/2016/12/16/141150_c4e921b5d3c60bbba0fbe6cec1daf3da.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2016%2F12%2F16%2F141150_c4e921b5d3c60bbba0fbe6cec1daf3da.jpg&h=2ba9d5c0&s={SIZE}\" /></blockquote><br />\n你依個位邊有40/50米<br />\n佢一加速你又慢緊車 可以撞架WOR</blockquote><br />\n<br />\nbtw<br />\n咁叫40/50米？<br />\n畀盡都係2個車位<br />\n你得2個車位就想出去<br />\n實畀人dup停啦<br />\n<br />\n小路出大路如果令大路車減速就你，已經係錯誤嘅出車時間<br />\n實肥你</blockquote><br />\n只要車收慢讓你就已經係危險 <br />\n仲有 唔一定撞先係危險 人地車頭對你車身已經係肥既要點之一 換句話 佢起步一刻 有車向你行緊 已經係肥  果個位 睇清無車先出 小出大 要手快眼明 熟d起步 多車就拉手製等啦 有機會就做準備動作"},{"pid":"4a536b4436b794e54706576bbb7de210cc418d38","tid":41720,"uid":24679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-16T07:00:02.000Z","msg":"多謝各位巴打提醒<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n今次已經係第二次考，考條咁易既線都肥好有挫敗感...<br />\n<br />\n同埋我已經讓哂路人行，上哂岸先開車，點解都會俾人剔左輕微不顧及路人既？<br />\n<br />\n同埋油門，剎車，軚盤，離合器使用不當係咪一定會剔？"},{"pid":"8e238d97f2b