" />"},{"pid":"808785b080614d6c53f35b0575e56775e4b9dba4","tid":2035434,"uid":39365,"like":5,"dislike":0,"score":5,"citedBy":3,"replyTime":"2020-05-26T02:42:42.000Z","msg":"侵仔叫WHO 30日內改革, 我睇個勢WHO應該唔理侵仔架喇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"587f232a5450a92cbc864c3dfc1d5b8fad658a84","tid":2035434,"uid":187,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-26T02:43:25.000Z","msg":"軍雞<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"875bed0f47f288b88f50ffa35536ee98959dfd2a","tid":2035434,"uid":301299,"like":1,"dislike":0,"score":1,"quote":{"pid":"c814287d32a58076d3ad0e3d66f5c87e7a81308d","tid":2035434,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-05-26T02:11:49.000Z","msg":"<img src=\"https://cdn2.ettoday.net/images/4899/4899123.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn2.ettoday.net%2Fimages%2F4899%2F4899123.jpg&h=c62f8d50&s={SIZE}\" /><br />\n（圖／翻攝自WHO官網）<br />\n<br />\n新冠肺炎（COVID-19）重創全球，最早爆發疫情的中國及世界衛生組織（WHO）都備受指責。外媒披露，中國國家主席習近平的妻子彭麗媛與賴比瑞亞前總統瑟利夫（Ellen Johnson Sirleaf）、英超足球隊利物浦（Liverpool）門將貝克（Alisson Becker）同列世衛9名親善大使之一，官網卻對她的身分隻字未提。<br />\n<br />\n根據世衛官網，WHO於2011年6月3日任命彭麗媛為結核病及愛滋病防治親善大使（Goodwill Ambassador for Tuberculosis and HIV/AIDS）。此前，她2006年1月成為中國愛滋病毒預防大使，2007年3月起擔任國家結核病控制及預防大使。<br />\n<br />\nWHO網站上的人物介紹中寫道，彭麗媛是中國著名女高音歌唱家及演員，也是中國人民解放軍總政治部歌舞團團長，在公務員中排名第一，軍階為少將，稱她為衛生及控制結核病及愛滋的堅定倡導者，2011年任命時更盛讚她擁有「聞名世界的嗓音與同情心」、「是一顆閃亮的星，擁有眾多受人尊敬的崇拜者」。<br />\n<br />\n《每日郵報》報導，彭麗媛早在1987年就嫁給時任廣東省廈門副市長的習近平，2011年由當時的WHO秘書長陳馮富珍（Margaret Chan）任命為親善大使。現任世衛總秘書長譚德塞接任後，重新任命彭麗媛擔任組織一員，但官網至今未提她是習近平的妻子。<br />\n<br />\n<a href=\"https://www.ettoday.net/news/20200526/1722558.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ettoday.net%2Fnews%2F20200526%2F1722558.htm&d=tjA1itiRAyOaH4WNB6QjYz2djVMnfBKxsW1BXeekzK0%3D&h=c7cd467e\" data-auto-link target=\"_blank\">https://www.ettoday.net/news/20200526/1722558.htm</a>"},"citedBy":1,"replyTime":"2020-05-26T02:44:04.000Z","msg":"廣東省廈門市<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"842f55caa44b550282f4f14d8d03c576ed320750","tid":2035434,"uid":20170,"like":0,"dislike":0,"score":0,"quote":{"pid":"82871c9ca81a4dc7a90ceaad4da201b73cff2aae","tid":2035434,"uid":184679,"like":12,"dislike":0,"score":12,"citedBy":4,"replyTime":"2020-05-26T02:32:43.000Z","msg":"<img src=\"https://img.techpowerup.org/200526/on20003272o7p06sp3s.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.techpowerup.org%2F200526%2Fon20003272o7p06sp3s.gif&h=81c06c49&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-05-26T02:44:44.000Z","msg":"<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},{"pid":"1f53f1da3fb1f8b4527dde691c62427ee0ca96e9","tid":2035434,"uid":148355,"like":0,"dislike":0,"score":0,"quote":{"pid":"78be43d7bfe4868cb0c025deb1804687779f3a08","tid":2035434,"uid":267494,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2020-05-26T02:20:28.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-26T02:45:23.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"4501d90fb8ffe9d5de96c2f7ecf6933d718771bd","tid":2035434,"uid":255637,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2020-05-26T02:45:27.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />少將<br />\n<br />\n成班都黎搞笑 呢班友只係識跳舞同含撚<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"2cce4a1e1d75a53c7599ae16dbc5b6a6d930b7dc","tid":2035434,"uid":60868,"like":1,"dislike":0,"score":1,"quote":{"pid":"808785b080614d6c53f35b0575e56775e4b9dba4","tid":20354