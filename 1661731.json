normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d3fef0cec675a1b3d74340c30626809d4cc51381","tid":1661731,"uid":209241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T10:07:05.000Z","msg":"仆街<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"f61642a35a0ec04c84b02f0da327f2d02a46101a","tid":1661731,"uid":63401,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T10:07:11.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b8018a540e7e44eab05150abf3b40a93251df71b","tid":1661731,"uid":53037,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-18T10:08:59.000Z","msg":"咪買啲咁嘅精神上嘅嘢直接課金好過啦<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"62def9a55a1c23b8a03bd44cd20963739fa2723a","tid":1661731,"uid":91595,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T10:10:33.000Z","msg":"推"},{"pid":"e2c8ab0c2bb000ddfd4706a9e7d95fe3c663f22b","tid":1661731,"uid":36420,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-18T10:18:10.000Z","msg":"此回覆已被刪除"},{"pid":"f76502d358385f32b14cdc07c47294c14d686b3e","tid":1661731,"uid":4917,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2019-10-18T10:18:30.000Z","msg":"香港民主女神團隊聲明：<br />\n<br />\n我們留意到近日網上有市民於網上出售3D打印的「香港民主女神像」作籌款及／或義賣用途。團隊在此聲明，我們目前沒有與任何機構或者個人合作籌款/義賣。<br />\n<br />\n雖然我們希望3D打印版的女神可以遍地開花，但不希望任何人利用女神像作商業用途，因此，團隊建議行家以成本價為有心人士及各同路人製作女神像，並把利潤捐出予支援抗爭者或此逆權運動之用，延續運動中彼此守望相助、齊上齊落的精神。<br />\n<br />\n同時呼籲市民不要使用坊間高於成本價製作女神像的打印服務。市民如欲自行打印女神像，可咨詢香港民主女神團隊或者熟悉此行業之人士。<br />\n<br />\n香港人，加油～<br />\n<br />\nLady Liberty HK Declaration:<br />\n<br />\nWe are aware that there are claims circulating on the internet on charity sales of the statue of Lady Liberty Hong Kong by local 3D service providers. The team at Lady Liberty Hong Kong hereby declares that we have not reached agreement with any of these service providers regarding the commercial use and sales of the statue designed and built by our team.<br />\n<br />\nWe genuinely wish to see the statue could be assessble to all, yet we prohibit all commercial use of the statue and its image. We, therefore, suggest 3D printing (and related) service providers to offer the production of statue in basic cost, and to donate sales revenue to charity supporting local protesters and the democratic movement, so that we can continue the mutual support spirit.<br />\n<br />\nPlease contact the Lady Liberty Hong Kong team should you have any inquiry on the cost of printing service for the mini statue.<br />\n<br />\nHongkongers, be strong!"},{"pid":"2c78e2905fd6b8d62fcff4078c9ade9c5998f83b","tid":1661731,"uid":48885,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T10:19:58.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><br />\n一隻都唔好買"},{"pid":"856f68c30accb660d9a9f8e8f61f83e324509bc0","tid":1661731,"uid":272017,"like":0,"dislike":0,"score":0,"quote":{"pid":"d2261ed07e15ff681ed17f898825771ea4a80aab","tid":1661731,"uid":293547,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-18T09:41:24.000Z","msg":"昨日，我開ＦＢ睇下玩具ＧＰ，睇到有個賣３Ｄ　Ｐｒｉｎｔ　ＧＥ友仔話代印女神，係佢。<img src=\"https://na.cx/i/kMG2qep.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FkMG2qep.jpg&h=fb28e6b6&s={SIZE}\" /> <br />\n哈哈。。。　我當堂嚇一跳，然後得啖笑。呢個香港，居然有人咁樣搵食，咁即係分明食人血饅頭唧！<br />\n我就即刻ＰＭ佢，問佢咩價位。。。。<br />\n<img src=\"https://na.cx/i/nkXUgnP.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnkXUgnP.jpg&h=3ae0e0e1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/foULn2T.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FfoULn2T.jpg&h=6e2df8b3&s={SIZE}\" /><br />\n嘩，１４ＣＭ高　（０。２　Ｌａｙｅｒ　Ｈｅｉｇｈｔ）賣８９９！？！？！？<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><br />\nＦＵＬＬ　ＳＥＴ　＄１９９０仲有旗仔送咁貼心！？！？<br />\n睇到哩度，作為一個精明消費者，當然唔想被消費啦，立即就繼續扮下有興趣，問下佢會捐幾多俾星火！<br />\n<img src=\"https://na.cx/i/8WKO5if.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F8WKO5if.jpg&h=d517f61b&s={SIZE}\" /> <br />\n５&mdash;１０％？有Ｄ人仲會俾多Ｄ叫佢捐！？！？！？！？！？！？！？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />仲有好多單！？<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /><br />\n好喇，講到哩度，可能你會問，點解我咁肯定係人血饅頭呢？<img src=\"https://na.cx/i/N1tsBvp.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FN1tsBvp.jpg&h=f0595028&s={SIZE}\" /> <img src=\"https://na.cx/i/24DguQw.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F24DguQw.jpg&h=41903f2c&s={SIZE}\" /> <br />\n因為我都ＰＲＩＮＴ左幾隻１６ＣＭ高（比佢提供ＧＥ　ＳＩＺＥ再大少少）ＬＡＹＥＲ佢用０。２，我用０。０３（我冇打多個０呀），如圖中所見，ＰＲＩＮＴ一隻１６ＣＭ高大約用左４４粒鐘。就以１６ＣＭ為例，咁到底成本係幾多呢？１Ｌ　ＲＥＳＩＮ大約６００蚊，以１６ＣＭ黎計大約ＰＲＩＮＴ到５隻，計埋電費，２００蚊都應該唔洗。計埋事前拎張圖加下ＳＵＰＰＯＲＴＩＮＧ（一次性），ＰＲＩＮＴ完又浸洗下火酒哩Ｄ程序，就當你成本３００蚊啦。一隻賺６００蚊，捐５&mdash;１０％俾星火，賣價５０％利潤就咁落左自己袋！<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />仲未計如果ＦＵＬＬ　ＳＥＴ會賺更多（因為有可能都係ＰＲＩＮＴ一轉就ＰＲＩＮＴ到晒４個ＳＩＺＥ）<br />\n多個人睇到，少個人中招，大家一齊幫下佢手啦！<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-18T10:21:50.000Z","msg":"香港民主女神團隊聲明早講左沒有授權喎.........<br />\nFACT CHECK 下啦，P 仔。<br />\n<br />\n<a href=\"https://www.facebook.com/LadyLibertyHongKong/posts/136937454359363\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FLadyLibertyHongKong%2Fposts%2F136937454359363&d=JQdTOMZ4NvWA5L1F4kLiz2vf1q1qK4rBaJpe4ZKN2Es%3D&h=8cf7f951\" data-auto-link target=\"_blank\">https://www.facebook.com/LadyLibertyHongKong/posts/136937454359363</a><br />\n<br />\n香港民主女神團隊聲明：<br />\n<br />\n我們留意到近日網上有市民於網上出售3D打印的「香港民主女神像」作籌款及／或義賣用途。團隊在此聲明，我們目前沒有與任何機構或者個人合作籌款/義賣。<br />\n<br />\n雖然我們希望3D打印版的女神可以遍地開花，但不希望任何人利用女神像作商業用途，因此，團隊建議行家以成本價為有心人士及各同路人製作女神像，並把利潤捐出予支援抗爭者或此逆權運動之用，延續運動中彼此守望相助、齊上齊落的精神。<br />\n<br />\n同時呼籲市民不要使用坊間高於成本價製作女神像的打印服務。市民如欲自行打印女神像，可咨詢香港民主女神團隊或者熟悉此行業之人士。<br />\n<br />\n香港人，加油～<br />\n<br />\n============================<br />\n<br />\nLady Liberty HK Declaration:<br />\n<br />\nWe are aware that there are claims circulating on the internet on charity sales of the statue of Lady Liberty Hong Kong by local 3D service providers. The team at Lady Liberty Hong Kong hereby declares that we have not reached agreement with any of these service providers regarding the commercial use and sales of the statue designed and built by our team.<br />\n<br />\nWe genuinely wish to see the statue could be assessble to all, yet we prohibit all commercial use of the statue and its image. We, therefore, suggest 3D printing (and related) service providers to offer the production of statue in basic cost, and to donate sales revenue to charity supporting local protesters and the democratic movement, so that we can continue the mutual support spirit.<br />\n<br />\nPlease contact the Lady Liberty Hong Kong team should you have any inquiry on the cost of printing service for the mini statue.<br />\n<br />\nHongkongers, be strong!"},{"pid":"03b64aefab922b9f0ad168a406009da3407115d5","tid":1661731,"uid":1646,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T10:23:29.000Z","msg":"人血饅頭"},{"pid":"f42a3a3daf97a44ab1b74449d01824c3ac029291","tid":1661731,"uid":151313,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T10:24:50.000Z","msg":"推"},{"pid":"82749140a55a79c342d13368b615712aaa5dbf25","tid":1661731,"uid":176116,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T10:26:15.000Z","msg":"推"}]}