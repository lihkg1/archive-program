id":"f62514ee00dbda42b9bb3b98c69b682d34aceb2e","tid":1910702,"uid":154892,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-05T06:37:07.000Z","msg":"push"},{"pid":"7741af58a40a8944f6b31764f23a783ebc4da6a5","tid":1910702,"uid":154892,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-05T06:37:18.000Z","msg":"push"},{"pid":"68354949cc83db50b504b94c50f67384a631313e","tid":1910702,"uid":51621,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-05T06:37:43.000Z","msg":"唉"},{"pid":"f1c3bd01ed2475e0a8ac3e417d77aa6e4f2a632c","tid":1910702,"uid":154892,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-05T07:01:36.000Z","msg":"push"},{"pid":"fd23cb60c9c2ca1a2f94a838d148954254f110c6","tid":1910702,"uid":58858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-05T07:08:41.000Z","msg":"多謝手足既付出<br />\n我唔會放棄 會陪你 代你 一直堅持落去 <br />\n直到贏果日 救返你出黎"},{"pid":"52c2a3fe658d4487982c7b4c4a08529a243daaa4","tid":1910702,"uid":68261,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-05T07:09:16.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"fc6af1fa3e11047e288de90e135dfafee8634577","tid":1910702,"uid":12510,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-03-05T02:23:52.000Z","msg":"樓主下次可以補番 sources<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n<a href=\"https://www.facebook.com/108102623935984/posts/194733238606255/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F108102623935984%2Fposts%2F194733238606255%2F%3Fd%3Dn&d=%2BOqOIcZVGdgLhUso5zZbIFm6lgSi2KDQroqMKj6vOm8%3D&h=2e3613e3\" target=\"_blank\">https://www.facebook.com/108102623935984/posts/194733238606255/?d=n</a><br />\n<br />\n頂置我喇"}}