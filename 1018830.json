81db9541586c4a1","tid":1018830,"uid":68062,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-14T15:25:16.000Z","msg":"想問我都有部1660 iphone7 但mon 左下玻璃裂左 有冇得換"},{"pid":"645e8d995a8204b08fb36b56b04df1057fe608f1","tid":1018830,"uid":57369,"like":1,"dislike":0,"score":1,"quote":{"pid":"79806cc7364f1ad8fbf8af760ff9c01623d79eff","tid":1018830,"uid":204398,"like":3,"dislike":3,"score":0,"quote":{"pid":"dd22692590ca740f601764a1fe567a85b2023be0","tid":1018830,"uid":178851,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-12T13:47:19.000Z","msg":"最慘而家人在澳洲 部機香港行貨 唔知喺澳洲有冇得免費整<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-12T13:53:51.000Z","msg":"apple係全球保養"},"citedBy":1,"replyTime":"2019-02-14T15:40:54.000Z","msg":"有SIM卡槽嘅機唔係全球保養"},{"pid":"9afb2abd859141609ba3e23aa089c6de492bf9af","tid":1018830,"uid":178851,"like":0,"dislike":0,"score":0,"quote":{"pid":"99247151b5aaf657bb9a4939781db9541586c4a1","tid":1018830,"uid":68062,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-14T15:25:16.000Z","msg":"想問我都有部1660 iphone7 但mon 左下玻璃裂左 有冇得換"},"citedBy":0,"replyTime":"2019-02-14T15:45:49.000Z","msg":"佢上面寫就咁寫 你可以問一下<br />\n<br />\n但我估唔排除要加錢整mon 因為佢話會係香港運全新嘅ip7黎澳洲 所以佢地都想回收番部完整嘅手機 <br />\n<br />\n同埋佢地都有睇睇我手機外殼同問我有冇跌過同整過 佢話收新機果日連同舊機帶埋去就換到<br />\n<img src=\"https://na.cx/i/BCGFL6v.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FBCGFL6v.png&h=4127394d&s={SIZE}\" /><br />\n<br />\n至於保養果方面 佢話就話唔延長 但澳洲呢面就話送多一年保養 上面話就話唔送 同埋話視乎地區之類<br />\n<br />\n但其實都睇番香港間Apple store 佢地點搞 至少澳洲果間佢地都幫我處理很好好"},{"pid":"498e9e7075ed750ce8154dd3bf992481ba6d031f","tid":1018830,"uid":178851,"like":1,"dislike":0,"score":1,"quote":{"pid":"645e8d995a8204b08fb36b56b04df1057fe608f1","tid":1018830,"uid":57369,"like":1,"dislike":0,"score":1,"quote":{"pid":"79806cc7364f1ad8fbf8af760ff9c01623d79eff","tid":1018830,"uid":204398,"like":3,"dislike":3,"score":0,"quote":{"pid":"dd22692590ca740f601764a1fe567a85b2023be0