rc=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxuT5LEz.gif&h=09d2fd67&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-08-27T14:39:47.000Z","msg":"樓主是樓主<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"c0711e91292cc4f161adc72430ee24b708c541ec","tid":2176552,"uid":19196,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-27T16:02:29.000Z","msg":"呢期二手樓已跌左2成<img src=\"/assets/faces/lm2/eating.gif\" class=\"hkgmoji\" />"},{"pid":"7c8e903f2609c9e879892864184d1ecdb7004fd5","tid":2176552,"uid":271947,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-27T16:17:17.000Z","msg":"十二月賣一月走，交英國税交死你，香港炒樓賺錢係tax free，英國抽重税，你要留意英國tax year點計"},{"pid":"cc02ac713af903fd2fc0f155957d7a7823b22d89","tid":2176552,"uid":361138,"like":0,"dislike":0,"score":0,"quote":{"pid":"7c8e903f2609c9e879892864184d1ecdb7004fd5","tid":2176552,"uid":271947,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-27T16:17:17.000Z","msg":"十二月賣一月走，交英國税交死你，香港炒樓賺錢係tax free，英國抽重税，你要留意英國tax year點計"},"citedBy":0,"replyTime":"2020-08-27T18:44:09.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 走之前賣唔洗交英國稅<br />\n<br />\n<a href=\"https://www.gov.uk/tax-foreign-income/residence\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.gov.uk%2Ftax-foreign-income%2Fresidence&d=a8feNXbjtso6d%2BC97Zvpk2Z69rz5%2BYz%2FKt%2FQ7ZoV0Dw%3D&h=eae0fd1c\" data-auto-link target=\"_blank\">https://www.gov.uk/tax-foreign-income/residence</a><br />\n<br />\n&quot;When you move in or out of the UK, the tax year is usually split into 2 - a non-resident part and a resident part. This means you only pay UK tax on foreign income based on the time you were living here.<br />\n<br />\nThis is called &lsquo;split-year treatment&rsquo;.&quot;"}]}