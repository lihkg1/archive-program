b2ea031d5703e3dfe85429f0d0","tid":732364,"uid":48964,"like":1,"dislike":0,"score":1,"quote":{"pid":"e1697115ab8f2bb345352f412f57c1680bacc10d","tid":732364,"uid":17832,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-07T01:31:01.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-07-07T02:12:07.000Z","msg":"爭個尼恩高蘭"},{"pid":"83baf7c3f76ea8df3e62066ac472735ba22ed54a","tid":732364,"uid":3742,"like":0,"dislike":0,"score":0,"quote":{"pid":"aea16ffbdce596b2ea031d5703e3dfe85429f0d0","tid":732364,"uid":48964,"like":1,"dislike":0,"score":1,"quote":{"pid":"e1697115ab8f2bb345352f412f57c1680bacc10d","tid":732364,"uid":17832,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-07T01:31:01.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-07-07T02:12:07.000Z","msg":"爭個尼恩高蘭"},"citedBy":1,"replyTime":"2018-07-07T02:33:10.000Z","msg":"而家2個肯跑上跑落做一腳波<br />\n出尼恩高蘭實拖慢哂<br />\n費蘭尼好幾球衝到入禁區幫波"},{"pid":"7b19ceae44df996e67bc28c77d9f6966c00a25c0","tid":732364,"uid":48964,"like":0,"dislike":0,"score":0,"quote":{"pid":"83baf7c3f76ea8df3e62066ac472735ba22ed54a","tid":732364,"uid":3742,"like":0,"dislike":0,"score":0,"quote":{"pid":"aea16ffbdce596b2ea031d5703e3dfe85429f0d0","tid":732364,"uid":48964,"like":1,"dislike":0,"score":1,"quote":{"pid":"e1697115ab8f2bb345352f412f57c1680bacc10d","tid":732364,"uid":17832,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-07T01:31:01.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-07-07T02:12:07.000Z","msg":"爭個尼恩高蘭"},"citedBy":1,"replyTime":"2018-07-07T02:33:10.000Z","msg":"而家2個肯跑上跑落做一腳波<br />\n出尼恩高蘭實拖慢哂<br />\n費蘭尼好幾球衝到入禁區幫波"},"citedBy":0,"replyTime":"2018-07-07T03:14:48.000Z","msg":"打機黎講係，觀眾角度黎講又好睇<br />\n<br />\n費蘭尼好少中場幫波，上左去又返唔切，witsel 太exposed。初段巴西前壓，費唔敢拎波，要世三不斷返落低位拎波。1:0之後中場多左空位，中場壓力先冇咁大，但佢都多次失位要犯規<br />\n<br />\n中場中既基本責任，費做得差，俾晒拍檔維素做。當然係馬天尼斯授權佢踢得自由，不斷入禁區頂波，如果對手中場踢得紮實（法國？），又失位又得返維素，就好難踢<br />\n<br />\n費咁踢法，比利時好明顯係失去左平衡，只係巴西把握唔到，同時球own goal 改變左場波"},{"pid":"f1e75c636cf92e7ac990b181f84a09e3301be99e","tid":732364,"uid":29093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-07T03:22:04.000Z","msg":"夏神 同 KDB  都比起四年前 成熟好多  <br />\n用波用得好好  分工越嚟越好  唔會爭做主角 <br />\n<br />\n<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d7e68bd2859f69cd14cdd98c5359ab9a2fd940b8","tid":732364,"uid":155133,"like":6,"dislike":1,"score":5,"citedBy":0,"replyTime":"2018-07-07T03:27:02.000Z","msg":"連登仔最識波<br />\n又話馬天尼斯on9<br />\n又話唔揀尼恩高蘭 廢教練<br />\n<br />\n賽前又係咁屌出費蘭尼<br />\n費撚防守不知幾撚勁<br />\n出 Chadi 又話不如打433<br />\n出黎又係助攻防守撞死啲巴西仔<br />\n迪布尼推上去又問點解<br />\n<br />\n真係想幫馬天尼斯講句<br />\n你識閪咩"}]}