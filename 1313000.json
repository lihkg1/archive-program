{"tid":1313000,"cid":5,"subCid":0,"title":"【Now新聞台】 警方驅散示威者期間多名記者受傷　本台攝影師被警棍擊中","createTime":"2019-07-13T15:56:21.000Z","updateTime":"2019-07-13T16:01:25.000Z","uid":37554,"like":7,"dislike":0,"uniUserReply":4,"replies":[{"pid":"23aca7b581d9a0d4fa765b1c2e354c5c9bafd208","tid":1313000,"uid":37554,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T15:56:21.000Z","msg":"【Now新聞台】警方驅散示威者期間多名記者受傷。<br />\n<br />\n警方在上水廣場外的天橋驅散示威者期間，警方一度施放胡椒噴霧，又用警棍追打示威者。<br />\n<br />\n在混亂中，本台攝影師被警棍擊中，亦有記者懷疑被鐵通擊中倒地，他按着肩膀，由其他記者攙扶離開。<br />\n<a href=\"https://news.now.com/home/local/player?newsId=355306\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D355306&d=mHuePEBkC2D1nBcDBUtUL3aXPXn3VG1rMaGvML0ROe4%3D&h=ce65d4aa\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D355306&h=42a65afa\" target=\"_blank\">https://news.now.com/home/local/player?newsId=355306</a>"},{"pid":"3f23303df6c9a2573d5e9b39e2254a8014acd873","tid":1313000,"uid":46534,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-13T15:56:55.000Z","msg":"推"},{"pid":"73bd36c17ffb64d8d71bdf7efd85800ebba835ba","tid":1313000,"uid":33736,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-07-13T15:57:09.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"0c14ebc8795e278d86076d8d2cfaeb40adcebfa1","tid":1313000,"uid":1241,"like":0,"dislike":0,"score":0,"quote":{"pid":"73bd36c17ffb64d8d71bdf7efd85800ebba835ba","tid":1313000,"uid":33736,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-07-13T15:57:09.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-13T16:01:25.000Z","msg":"推呀"}]}