kgmoji\" />"},{"pid":"f824204f42b169b6977cd19151f404dd96890bdd","tid":646180,"uid":43041,"like":6,"dislike":0,"score":6,"quote":{"pid":"89340eccd5904d0a502124495fb49e667302025b","tid":646180,"uid":76490,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d70665b18661e3f960b7e926f9c11d496265499","tid":646180,"uid":8876,"like":0,"dislike":0,"score":0,"quote":{"pid":"1ff723f75938927dbf64450b72ac8da85c4f8972","tid":646180,"uid":33037,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T02:49:12.000Z","msg":"雪菜肉絲米"},"citedBy":1,"replyTime":"2018-04-29T03:10:33.000Z","msg":"咁咪有肉"},"citedBy":1,"replyTime":"2018-04-29T04:10:52.000Z","msg":"所以真係好難<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-29T06:06:43.000Z","msg":"其實每個人都唔同，要確實知道就要驗血睇下邊樣野刺激到你既身體引發濕疹<br />\n濕疹唔係話個個都一樣唔食得牛啊海鮮咁，中醫叫你戒口話依d野食會發，其實只係因為依類野食係比較常見既致敏源，點都會中<br />\n我對雞蛋雞肉酵母敏感，睇中醫叫我戒曬所有蝦蟹牛之類既都無用，因為我既致敏源並唔常見，根本唔係中醫所謂會發既食物，所以真係要驗血同自己留意先知，你明唔明啊？"},{"pid":"94f0f2b91977de67dc530e739ae39b70d15fc0ad","tid":646180,"uid":79959,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2018-04-29T06:11:36.000Z","msg":"建議你睇黃錫明，早睇早着，睇完藥用完可以加藥(只收藥錢)<br />\n小心醫生脾氣<br />\n利申：濕疹勁到辭左餐廳份工"},{"pid":"323960212465abf1a416756b578b56423426da98","tid":646180,"uid":76490,"like":0,"dislike":0,"score":0,"quote":{"pid":"f824204f42b169b6977cd19151f404dd96890bdd","tid":646180,"uid":43041,"like":6,"dislike":0,"score":6,"quote":{"pid":"89340eccd5904d0a502124495fb49e667302025b","tid":646180,"uid":76490,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d70665b18661e3f960b7e926f9c11d496265499","tid":646180,"uid":8876,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T03:10:33.000Z","msg":"咁咪有肉"},"citedBy":1,"replyTime":"2018-04-29T04:10:52.000Z","msg":"所以真係好難<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-29T06:06:43.000Z","msg":"其實每個人都唔同，要確實知道就要驗血睇下邊樣野刺激到你既身體引發濕疹<br />\n濕疹唔係話個個都一樣唔食得牛啊海鮮咁，中醫叫你戒口話依d野食會發，其實只係因為依類野食係比較常見既致敏源，點都會中<br />\n我對雞蛋雞肉酵母敏感，睇中醫叫我戒曬所有蝦蟹牛之類既都無用，因為我既致敏源並唔常見，根本唔係中醫所謂會發既食物，所以真係要驗血同自己留意先知，你明唔明啊？"},"citedBy":0,"replyTime":"2018-04-29T08:30:36.000Z","msg":"原來係咁⋯⋯唔該巴打<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"2e85961a835218aee7806c84177c32b16fa1ac16","tid":646180,"uid":76490,"like":0,"dislike":0,"score":0,"quote":{"pid":"94f0f2b91977de67dc530e739ae39b70d15fc0ad","tid":646180,"uid":79959,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2018-04-29T06:11:36.000Z","msg":"建議你睇黃錫明，早睇早着，睇完藥用完可以加藥(只收藥錢)<br />\n小心醫生脾氣<br />\n利申：濕疹勁到辭左餐廳份工"},"citedBy":0,"replyTime":"2018-04-29T08:31:36.000Z","msg":"我有幾個朋友都係勁到皮膚又黑又紅⋯⋯好擔心佢都會咁<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"e0b274afb6cca13080257c2cc01173ac767549b5","tid":646180,"uid":57139,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T11:41:39.000Z","msg":"試下轉用手工皂同埋戒口"},{"pid":"fffe39f655a3c126ec53d1ab71937db3df08132c","tid":646180,"uid":140823,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T12:10:54.000Z","msg":"我最近都有依個問題 上網google翻啲post睇翻以前有舊登同連登仔推介用死海海鹽黎醫 我依排都買左<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /> 有啲效用"},{"pid":"6e5efdb4ba5939100565dd6a43bcb897774853b4","tid":646180,"uid":140823,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-29T12:12:11.000Z","msg":"(濕疹jj)有咩可以減輕濕疹<br />\n<br />\n<a href=\"https://lihkg.com/t/31454/1?ref=android\" data-auto-link target=\"_blank\">https://lihkg.com/t/31454/1?ref=android</a><br />\n<br />\nLIHKG @ Android"},{"pid":"61ef597219f1c9c7a75a23d4ed8a9fa42d691549","tid":646180,"uid":141519,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T15:19:34.000Z","msg":"用手黎揉類固醇係咪好笨柒?? 我用黎揉身同腳 但我隻手無 用手揉完即刻洗"},{"pid":"b8c528ba13310b8a84cf290e4b4e9a033c4507d3","tid":646180,"uid":76490,"like":0,"dislike":0,"score":0,"quote":{"pid":"61ef597219f1c9c7a75a23d4ed8a9fa42d691549","tid":646180,"uid":141519,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T15:19:34.000Z","msg":"用手黎揉類固醇係咪好笨柒?? 我用黎揉身同腳 但我隻手無 用手揉完即刻洗"},"citedBy":1,"replyTime":"2018-04-29T16:26:41.000Z","msg":"類固醇係最有效但最大反效果架巴打！唔好用太多"},{"pid":"877ff197beeac265dc24c3baf4bb5c1930a4144d","tid":646180,"uid":76490,"like":0,"dislike":0,"score":0,"quote":{"pid":"fffe39f655a3c126ec53d1ab71937db3df08132c","tid":646180,"uid":140823,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T12:10:54.000Z","msg":"我最近都有依個問題 上網google翻啲post睇翻以前有舊登同連登仔推介用死海海鹽黎醫 我依排都買左<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /> 有啲效用"},"citedBy":0,"replyTime":"2018-04-29T16:28:03.000Z","msg":"其實係點沖？姐係搵盤熱水之後開稀佢？<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"c067d9cb6bd0e58a5ce06f1b026c8be5c5e43f7a","tid":646180,"uid":76490,"like":0,"dislike":0,"score":0,"quote":{"pid":"e0b274afb6cca13080257c2cc01173ac767549b5","tid":646180,"uid":57139,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T11:41:39.000Z","msg":"試下轉用手工皂同埋戒口"},"citedBy":0,"replyTime":"2018-04-29T16:28:52.000Z","msg":"有用過手工嘅野但可惜佢用完之後紅腫⋯⋯<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"9d0c2cdb7274ddf9f82049fdb8808b2e2f65c759","tid":646180,"uid":139804,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-29T16:34:59.000Z","msg":"呢幾個月個嘴濕疹 keep住睇西醫食藥查類固醇。<br />\n我都知治標唔治本，但唔咁做根本返唔到工見人<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n建議樓主可以中西雙管齊下"},{"pid":"e600a2bcdf05c74d72b679ce0c6dd736319b07c5","tid":646180,"uid":153016,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-04-29T16:36:37.000Z","msg":"我濕疹左20年<br />\n越大越嚴重<br />\n千萬唔好用類固醇<br />\n冇錯 用完會好番<br />\n但我可以話你知 <br />\n復發既話 一次比一次嚴重<br />\n我都係今年爆到全身都有<br />\n去左驗血 發現連西瓜都敏感<br />\n我用緊食療去控制（停用仼何藥物）<br />\n用左半年時間得番腳同手既關節位<br />\n建議你女朋友要多菜少肉<br />\n多食魚 每朝空肚一杯蘋果啤梨汁<br />\n大約半個月會見到效果<br />\n同埋可以買益生菌食 記得唔好買粉狀（未到腸已經俾個胃磨死哂）"},{"pid":"f3e7aca3d5f1686aef5a1a94bdaaec8abdb57eb6","tid":646180,"uid":141519,"like":0,"dislike":0,"score":0,"quote":{"pid":"b8c528ba1