8f749109ea587889ced29f7a5962ba8a7992f14f","tid":1270904,"uid":122752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:28:12.000Z","msg":"Push"},{"pid":"cf6817484cf23a2dbb659539dd0dbac2a3c9bb0f","tid":1270904,"uid":8893,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:28:35.000Z","msg":"推"},{"pid":"91187322261406f27cf217434b0f48b597f1ea9c","tid":1270904,"uid":73392,"like":4,"dislike":0,"score":4,"quote":{"pid":"2f95e46f3d0672ed61514f3827abd708cb46903f","tid":1270904,"uid":238013,"like":824,"dislike":5,"score":819,"citedBy":2,"replyTime":"2019-07-01T03:44:01.000Z","msg":"白帶狗好大聲咁教班藍帶狗<br />\n話呢招一用全部人會自動散"},"citedBy":0,"replyTime":"2019-07-01T04:34:17.000Z","msg":"咁天真<img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"d00f187e4fd27db58ce8af8a48bfbbeafc2cd23a","tid":1270904,"uid":238013,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-01T04:38:23.000Z","msg":"<blockquote><blockquote>白帶狗好大聲咁教班藍帶狗<br />\n話呢招一用全部人會自動散</blockquote>咁天真<img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},{"pid":"072c485e26319498e704d3942378fb2b610ee328","tid":1270904,"uid":5930,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:38:50.000Z","msg":"推"},{"pid":"42e6b5a86e663831d163497095ba048c1f09d338","tid":1270904,"uid":200718,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-07-01T04:39:02.000Z","msg":"<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" />"},{"pid":"80e02248aea49c29afe13f97896738ed68b78ad3","tid":1270904,"uid":27993,"like":14,"dislike":0,"score":14,"citedBy":0,"replyTime":"2019-07-01T04:46:31.000Z","msg":"一日唔升級 都係冇用 只會消耗大家意志 令更多人絕望<br />\n你睇到今日出嚟嘅人數同之前比 冇得比！<br />\n再睇下依段時間我地對個政權施到咩壓？冇！一啲都冇！<br />\n咁耐以嚟 各掌權者一直冇出過嚟 冇理過冇回應過香港人嘅訴求<br />\n<br />\n到今日 林鄭出嚟繼續鳩嗡活係平行時空<br />\n你嬲唔嬲？我好撚嬲！<br />\n同時都覺得大家咁耐嘅堅持努力 換嚟佢一臉春風 好唔抵<br />\n<br />\n雖說兄弟爬山 各自努力 大家方向不同 目標一致<br />\n但係大家俾個死線港共 否則行動升級 最後升咗去邊<br />\n如果我係政權 我會當你地係笑話 毫無壓力 我繼續搵人抹黑你地 又唔洗向你地交代 拍拍手出糧又一日<br />\n<br />\n唔係要升級到掟燃燒彈燒車胎<br />\n我地連衝擊都做唔到 靠勇武前線？真係期望前線一小撮人衝散到班武裝狗 然後可以帶嚟改變？我諗前線義士都心灰意冷<br />\n&ldquo;會俾人秋後算帳不了 犯法俾人拉架睇定啲先啦！&rdquo;<br />\n我大膽講句 再有依個諗法 香港冇得贏 一定輸<br />\n因為你輸唔起 所以輸香港<br />\n<br />\n出得嚟 我諗大家都預咗會俾狗追住嚟咬<br />\n我明白每個人都有顧忌 但如果再有咁多顧忌 真係做唔到啲咩<br />\n<br />\n引用梁天琦一句話: 香港人以往太多底線啦<br />\n<br />\n對住冇底線嘅政權 大家嘅底線 有何用？<br />\n當一班義士係前線硬碰硬 然後一班人企 鳥獸散 等狗過嚟驅散動武拉人 依個畫面仲要重複幾多次 <br />\n我真係希望香港人可以齊心啲 有決心用行動警告政權 我地唔會坐以待斃 我死你都唔好諗走得甩<br />\n<br />\n香港唔可以再輸啦<br />\n真係求求大家唔好行返雨革條舊路<br />\n冇用嘅野 你做一百次一千次一萬次都係冇用<br />\n啱聽就聽 唔啱聽隨便屌<br />\n<br />\n利申: 夢遊 1999"},{"pid":"80f9aa955055ab3d235014089d526aaaa2c8162d","tid":1270904,"uid":209746,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-01T04:47:29.000Z","msg":"Up"},{"pid":"dbbd4552a836cf531a8d8f56dfe3040df00001cc","tid":1270904,"uid":209746,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:47:39.000Z","msg":"Up"},{"pid":"ef498b9da23db7e0373d98b2b0a5645871228e2b","tid":1270904,"uid":52621,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:47:56.000Z","msg":"推"},{"pid":"20bcd97ea193297f858286eca77437755383a705","tid":1270904,"uid":230542,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:50:08.000Z","msg":"push"},{"pid":"ec57dcf0cb419689b800109b0501294fbc9af89a","tid":1270904,"uid":54195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:51:06.000Z","msg":"推"},{"pid":"7e61397627f62ad57258f2f72ca7ac1ec575616b","tid":1270904,"uid":165840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:51:40.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"97cb305861cc3e562ea18500a48b3287adce7825","tid":1270904,"uid":173207,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T04:52:21.000Z","msg":"推爆"},{"pid":"c6269a6a6fc5f61400a72f9916e06d77a2982fad","tid":1270904,"uid":217004,"like":0,"dislike":0,"score":0,"citedBy