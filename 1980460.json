,"quote":{"pid":"dbdba77d66ede886f2de98e7800b9bc7a0bc294d","tid":1980460,"uid":50740,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-20T08:10:10.000Z","msg":"林鄭買水<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-20T10:44:41.000Z","msg":"<img src=\"https://i.pinimg.com/originals/f1/f8/39/f1f8391687a005def0bab439e68124c8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.pinimg.com%2Foriginals%2Ff1%2Ff8%2F39%2Ff1f8391687a005def0bab439e68124c8.jpg&h=b2d27ff1&s={SIZE}\" />"},{"pid":"c394614d22ccd0d007f0bb3b9739ada95972873a","tid":1980460,"uid":7439,"like":0,"dislike":0,"score":0,"quote":{"pid":"b3fffc60788bed92ba21635380ecba8b095fbe07","tid":1980460,"uid":50740,"like":0,"dislike":0,"score":0,"quote":{"pid":"5e9e875f6fc0597a22511d72edce0086a7d226a8","tid":1980460,"uid":84081,"like":0,"dislike":0,"score":0,"quote":{"pid":"db94d96a9218fdfe5cc5f8bf4754cc6bbb371661","tid":1980460,"uid":7439,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-20T08:26:58.000Z","msg":"【武漢肺炎】橋底辣蟹每日營業額10萬變1萬 僅存避風塘艇家跌五成生意<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-04-20T08:38:52.000Z","msg":"那有錢 你老母"},"citedBy":1,"replyTime":"2020-04-20T09:00:27.000Z","msg":"那有錢係喜記"},"citedBy":0,"replyTime":"2020-04-20T10:45:35.000Z","msg":"一場武漢肺炎，重創香港旅遊及飲食業，多間老字號亦被迫暫時停業或休業。銅鑼灣避風塘炒蟹一向是香港吸引遊客的賣點之一，如今亦飽受重創，記者查訪區內多間以避風塘菜式聞名的餐廳，<span style=\"color: red;\">除了喜記及越華會在截稿時仍未回覆</span><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />，其他區內名店如橋底辣蟹、信記避風塘海鮮美食都損失慘重，有老闆直言情況比沙士更慘重。<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20200331/large/1585641147_28c3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20200331%2Flarge%2F1585641147_28c3.jpg&h=d5572694&s={SIZE}\" /><br />\n<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"a79b6ee772ab5c06f9788722fd8b46e2ecf93fbf","tid":1980460,"uid":7439,"like":0,"dislike":0,"score":0,"quote":{"pid":"8233fbe778cbc5fa547bdb899c0fd98dcabfac20","tid":1980460,"uid":117729,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-20T09:02:26.000Z","msg":"個個都用八達通買，個夾萬點會有錢"},"citedBy":0,"replyTime":"2020-04-20T17:29:00.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}