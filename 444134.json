rc=\"https://img.eservice-hk.net/upload/2017/10/22/165755_a314e03aac6c5e3b0adb405ff3452969.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F22%2F165755_a314e03aac6c5e3b0adb405ff3452969.gif&h=452bd6be&s={SIZE}\" /> <img src=\"https://img.eservice-hk.net/upload/2017/10/22/165755_71f4b3e31581b978880963e1ca837694.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F22%2F165755_71f4b3e31581b978880963e1ca837694.gif&h=7fdde592&s={SIZE}\" />"},{"pid":"07399b1c09a737ec9a915cf7b2530bd273f13e71","tid":444134,"uid":54228,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-22T09:33:16.000Z","msg":"啲蝗蟲好撚正<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5a535b8615dbb62326d317473894507865db4fa2","tid":444134,"uid":93986,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-22T09:46:02.000Z","msg":"賣國賊"},{"pid":"4c7c33a74fee0db967e9b220351c549d533f5644","tid":444134,"uid":1886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-22T16:36:57.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"628c39bfb07dc2340f8df57b7fd1b0cdd28bd55c","tid":444134,"uid":135265,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-22T16:50:59.000Z","msg":"流膿豬<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n果然冇改錯名<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"d8b529cb9f1381d3d8781c3c96064476d5a4bca8","tid":444134,"uid":46454,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-22T22:55:48.000Z","msg":"Trump: 同我趕走哂所有亞裔,即使係當年起鐵路的華工後代都一樣"},{"pid":"f124a5d4dc92841899681d8ec61c015bbefd03c1","tid":444134,"uid":49955,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-10-22T23:07:13.000Z","msg":"明明係中國人<br />\n華乜撚野裔"},{"pid":"6645d2207fd51ab803eacfa80adf9981c24519fa","tid":444134,"uid":35790,"like":0,"dislike":0,"score