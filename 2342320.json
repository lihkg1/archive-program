=\"_blank\">https://hk.appledaily.com/local/20201227/SYA46HZ3G5ECXO2FHQPF2IEDS4/</a>"},"citedBy":1,"replyTime":"2020-12-27T08:25:21.000Z","msg":"辭職同工出聲明講明集體辭職係針對陳凱興喎"},{"pid":"42510406c447cadc940403d7deaf18e3a47f6418","tid":2342320,"uid":343533,"like":0,"dislike":0,"score":0,"quote":{"pid":"cd0d1be69d17c357b3f614af973e40e714baea5b","tid":2342320,"uid":27986,"like":0,"dislike":0,"score":0,"quote":{"pid":"68a0085694999c2234fde10b408be24a76e0f889","tid":2342320,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-12-27T04:51:19.000Z","msg":"早前好鄰舍北區教會被警方以涉嫌欺詐及洗黑錢罪凍結資產，教會前董事及一名現職員工被捕，教會社工劉家棟其後宣佈辭任教會職務。有員工最近匿名向傳媒發出聲稱代表了20人的集體總辭聯合聲明。北區教會今日在facebook發表聲明指，秘書及傳道堂主任陳凱興已於本月8日辭任教會兩個職位，而教會由12月12日開始，也陸續收到多名員工辭職，並要求即時生效。<br />\n<br />\n聲明指出，今年12月7日，警方拘捕教會兩名人員指其涉嫌「洗黑錢」後，教會出現了人事變動。於12月8日，陳凱興辭任教會秘書及傳道堂主任兩個職位，並要求即時生效。到12月12日起，教會亦陸續收到多名員工辭職，同時要求即時生效。聲明指，乃念有關員工的勞苦，在勞資雙方協商下，承諾寛鬆酌情處理，不追究未有依據合約勞資雙方離職通知期及代通知金的法定權益。<br />\n<br />\n聲明指，教會管理團隊歡迎與任何現職及離職同工溝通，理解曾有同工表示擔心法律風險、家人壓力、情緒困擾等。教會在這非常時期，特別聽取更多法律意見，處理內外事務、行政安排及對外與內的溝通，並於事件發生後，因應同工心理狀況、擔憂而安排是否需要在家工作；亦承諾為所有現職及離職同工作法律支援，強調教會秉承聖經的教導，繼續堅守信仰，守護弱勢，竭力服侍基層，完成上帝所交付的使命。聲明尾聲更特別感謝陳凱興創會至今，服務弱勢社群，盡心盡力侍奉上帝。<br />\n<br />\n<br />\n<a href=\"https://hk.appledaily.com/local/20201227/SYA46HZ3G5ECXO2FHQPF2IEDS4/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20201227%2FSYA46HZ3G5ECXO2FHQPF2IEDS4%2F&d=sZqGLlkYYIxatccyfr7NWKnpKMFcuJZ7CRl7dpp3bCg%3D&h=c1d48c81\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20201227%2FSYA46HZ3G5ECXO2FHQPF2IEDS4%2F&h=c1117a45\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20201227/SYA46HZ3G5ECXO2FHQPF2IEDS4/</a>"},"citedBy":1,"replyTime":"2020-12-27T08:25:21.000Z","msg":"辭職同工出聲明講明集體辭職係針對陳凱興喎"},"citedBy":0,"replyTime":"2020-12-27T08:26:58.000Z","msg":"真"},{"pid":"67eee7bcd358f535cf960081be0922df907ebf02","tid":2342320,"uid":343533,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-12-27T08:29:37.000Z","msg"