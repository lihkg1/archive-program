kg.com/thread/1463088/page/1\" target=\"_blank\">https://lihkg.com/thread/1463088/page/1</a><br />\n[url]<img src=\"https://na.cx/i/y78iYgf.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fy78iYgf.png&h=442b1b20&s={SIZE}\" /> [/url]<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">而加唔係同你講政治，係人道危機，人道救援！</span></span><br />\n你哋係咪要等到香港人變成難民先出聲<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: orange;\">香港人一年捐超過20億</span></span></strong>，但香港人一有事間間INGO就龜縮，你仲好意思繼續問我地拎錢？<br />\n你地打住慈善旗號，但就見死人救，你對唔對得住香港人<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />  對你地 好 失 望！<br />\n唔好講咁多，一人一信去問下佢地幫香港人做左D咩，點解唔發聲！<br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">CUT捐助</span></strong></span>熱線 如下 <br />\n1. 宣明會（香港）: (852) 2394 2394 <br />\n2. 無國界醫生（香港） :  (852) 2959 4229<br />\n3. 樂施會 （香港） :  (852) 3120 5000<br />\n4. 奧比斯（香港） : (852) 2877 9373<br />\n5. UNICEF （香港）: (852) 2833 6139<br />\n6. Save the Children（香港） : (852) 3160-8686    <br />\n7. 香港紅十字會（香港） :  (852) 2802 0021<br />\n8. 國際培幼會（香港） :  (852) 3405 5305<br />\n<br />\nEmail如下<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><br />\n<span style=\"color: violet;\"><span style=\"font-size: large;\">都知各位巴絲都好忙，放便大家一次過問喉佢地<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /></span></span> copy and paste<br />\n香港 INGO email （中/英皆可）：<br />\n<span style=\"font-size: x-small;\">hotline@worldvision.org.hk, office@hongkong.msf.org,  info@oxfam.org.hk, <a href=\"http://info.hk\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Finfo.hk&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=a92383b4\" data-auto-link target=\"_blank\">info.hk</a>@orbis.org, info@unicef.org.hk, hkinfo@savethechildren.org, crd@redcross.org.hk, supporter@plan.org.hk</span> <br />\n國際 INGO email （請用英文）：<br />\n<span style=\"font-size: x-small;\">info@worldvision.org, info@doctorswithoutborders.org,  info@oxfamamerica.org,  info@orbis.org, social@unicefusa.org, info@savethechildren.org, contactus@redcross.org.uk, childprotection@plan-international.org</span><br />\n<br />\nFacebook 如下<br />\n1. 宣明會（香港）:  <a href=\"https://www.facebook.com/WorldVisionhongKong/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FWorldVisionhongKong%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=d9d61c6d\" target=\"_blank\">https://www.facebook.com/WorldVisionhongKong/</a><br />\n2. 無國界醫生（香港） :  <a href=\"https://www.facebook.com/msf.hk/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fmsf.hk%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=49966a2c\" target=\"_blank\">https://www.facebook.com/msf.hk/</a><br />\n3. 樂施會 （香港） : <a href=\"https://www.facebook.com/oxfamhongkong/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Foxfamhongkong%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=14e55ad0\" target=\"_blank\">https://www.facebook.com/oxfamhongkong/</a><br />\n4. 奧比斯（香港） : <a href=\"https://www.facebook.com/ORBISHongKong/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FORBISHongKong%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=0d73500b\" target=\"_blank\">https://www.facebook.com/ORBISHongKong/</a><br />\n5. UNICEF （香港）:  <a href=\"https://www.facebook.com/UNICEFHK/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FUNICEFHK%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=b801de9a\" target=\"_blank\">https://www.facebook.com/UNICEFHK/</a><br />\n6. Save the Children（香港） : <a href=\"https://www.facebook.com/savethechildrenhk/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fsavethechildrenhk%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=c4926809\" target=\"_blank\">https://www.facebook.com/savethechildrenhk/</a><br />\n7. 香港紅十字會（香港） : <a href=\"https://www.facebook.com/hongkongredcross/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fhongkongredcross%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=56d87e2d\" target=\"_blank\">https://www.facebook.com/hongkongredcross/</a><br />\n8. 國際培幼會（香港） : <a href=\"https://www.facebook.com/planhk/?ref=br_rs\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fplanhk%2F%3Fref%3Dbr_rs&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=5ce1d13f\" target=\"_blank\">https://www.facebook.com/planhk/?ref=br_rs</a><br />\n<br />\n唔好問點解燒埋你地果度，做得慈善機構係有一種<span style=\"color: violet;\"><strong><span style=\"font-size: x-large;\">責任</span></strong></span>，更何況你係香港人<br />\n唔好諗住求其出篇新聞稿打發我地，<span style=\"font-size: x-large;\">講 人 話 ！</span><br />\n<br />\n身邊唔少人做NGO，食物鏈底層多數都心繫香港人，但上面班高層堅離地，完全唔知發生咩事（自私豬），淨係諗住籌到幾多錢 最好唔好有人阻到佢番工<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 香港有事你以為你地可以置身事外？為你地下一代諗下啦！<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<span style=\"font-size: xx-large;\">五大訴求 缺一不可</span><br />\n要求正面回應 唔洗止意好似林奠咁帶我地遊花園 <br />\nNever Forget Never Forgive<br />\n<br />\n最後，如果要捐錢就捐比自己人<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n612人道支援基金 612 Humanitarian Relief Fund： <a href=\"https://www.facebook.com/pg/612Fund/about/?ref=page_internal\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fpg%2F612Fund%2Fabout%2F%3Fref%3Dpage_internal&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=02808be3\" target=\"_blank\">https://www.facebook.com/pg/612Fund/about/?ref=page_internal</a><br />\nStand News 立場新聞：<br />\n<a href=\"https://mystand.thestandnews.com\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmystand.thestandnews.com&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=e3485a26\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fmystand.thestandnews.com&h=406cb5b9\" target=\"_blank\">https://mystand.thestandnews.com</a>"},"citedBy":0,"replyTime":"2019-08-21T01:38:14.000Z","msg":"推，呢樣值得做，如果迫到嘅總部出聲明可以進一步令到香港人被迫害嘅事實傳比外國知，連結全球反中共浪潮<br />\n打開國際戰線，迫佢地出聲，否則22億捐款一齊攬炒<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><br />\n<br />\n我loop完佢地8間嘅FB只有兩間有各有一個comment講佢地點解唔為香港出聲，提供人道支援<br />\n照之前狙擊TVB行動嘅經驗，洗低佢地FB評價因為係公開佢地PR一定要出聲，直接記投訴信反而佢地都可以當無事<br />\n有無人中英文好嘅可以幫手draft comment，文宣稿<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n依加暫時秩缺乏一啲明確行動呼籲先無咩人做，我暫時諗到嘅<br />\n1. FB評論比不推薦然後comment留返點解佢地唔援助香港、連最低消費出聲明都唔做<br />\n2.香港咁多人月捐一定有收據，應該出個social media challenge用 收據#ShameOnXXXX咁表達不滿話唔再捐<br />\n3.經過呢兩個月，我深信香港真係有好多好人，要佢地Cut捐款可能會抗拒，可以叫佢地轉捐星火同612呢啲幫助義士嘅基金，捐款收據一樣可以上hashtag 加大效果<br />\n<br />\n星火同盟 抗爭支援<br />\n<a href=\"https://www.facebook.com/sparkalliancehk/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fsparkalliancehk%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=3eddb703\" target=\"_blank\">https://www.facebook.com/sparkalliancehk/</a><br />\n*戶口資料:<br />\n滙豐銀行: 048-857585-838 <br />\n戶口名稱: T PR**E M*L T*A T*C <br />\n轉數快ID: 3771623<br />\n<br />\n612人道支援基金捐款方法，太長唔Copy，FB有哂<br />\n<a href=\"https://www.facebook.com/612Fund/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F612Fund%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=2ceb8cbc\" target=\"_blank\">https://www.facebook.com/612Fund/</a><br />\n<br />\n<br />\n4.文宣要人，要文要圖<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n既然要玩國際戰線，咁應該要玩埋twitter<br />\n<br />\n其他手足有咩idea或者可以幫忙一齊討論下<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"5d79a6d525b3c1625f7d42a64047ac4fe3096cd2","tid":1488193,"uid":50904,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:45:18.000Z","msg":"UN human rights office of the high commissioner<br />\nPress briefing note on Hong Kong, China<br />\n<a href=\"https://www.ohchr.org/EN/NewsEvents/Pages/DisplayNews.aspx?NewsID=24888&amp;LangID=E\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.ohchr.org%2FEN%2FNewsEvents%2FPages%2FDisplayNews.aspx%3FNewsID%3D24888%26LangID%3DE&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=06bd5b8f\" target=\"_blank\">https://www.ohchr.org/EN/NewsEvents/Pages/DisplayNews.aspx?NewsID=24888&amp;LangID=E</a><br />\n<br />\nThe UN Human Rights Office has reviewed credible evidence of law enforcement officials employing less-lethal weapons in ways that are prohibited by international norms and standards. For example, officials can be seen firing tear gas canisters into crowded, enclosed areas and directly at individual protesters on multiple occasions, creating a considerable risk of death or serious injury. The Office would urge the Hong Kong SAR authorities to investigate these incidents immediately, to ensure security personnel comply with the rules of engagement, and where necessary, amend the rules of engagement for law enforcement officials in response to protests where these may not conform with international standards."},{"pid":"1f128ea7c405b4844b5af71994c463d80ecca648","tid":1488193,"uid":228581,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:47:02.000Z","msg":"<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"6a98d05cbf5b7ee80f5196aff617af9680316887","tid":1488193,"uid":50904,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:47:14.000Z","msg":"&lsquo;Act with restraint&rsquo; UN human rights chief urges Hong Kong authorities and protestors, following airport disruption<br />\n呢份稿就係賴中立咁譴責一切暴力，不過都有point可用<br />\n<a href=\"https://news.un.org/en/story/2019/08/1044141\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.un.org%2Fen%2Fstory%2F2019%2F08%2F1044141&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=a581eb7e\" data-auto-link target=\"_blank\">https://news.un.org/en/story/2019/08/1044141</a><br />\n<br />\n&ldquo;The rights of freedom of expression and peaceful assembly and the right to participate in public affairs are expressly recognized in the Universal Declaration of Human Rights, as well as the International Covenant on Civil and Political Rights which is incorporated in the Basic Law of the Hong Kong SAR&rdquo;, the human rights chief maintains.<br />\n<br />\nMr. Colville said that there was &ldquo;credible evidence&rdquo; of law enforcement officials using some anti-riot measures which are &ldquo;prohibited by international norms and standards&rdquo;.<br />\n<br />\nAs an example, he said that officials have been seen firing tear gas canisters into crowded, enclosed areas and directly at individual protesters on multiple occasions, &ldquo;creating a considerable risk of death or serious injury&rdquo;.<br />\n<br />\nSCMP 剪嘅片<br />\nUnited Nations condemns violence in Hong Kong protests<br />\n<a href=\"https://www.scmp.com/video/hong-kong/3022915/united-nations-condemns-violence-hong-kong-protests\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.scmp.com%2Fvideo%2Fhong-kong%2F3022915%2Funited-nations-condemns-violence-hong-kong-protests&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=242fc94e\" data-auto-link target=\"_blank\">https://www.scmp.com/video/hong-kong/3022915/united-nations-condemns-violence-hong-kong-protests</a>"},{"pid":"edacd21f0518de0b1f5310ab29efab8f2998af44","tid":1488193,"uid":137209,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:48:07.000Z","msg":"推"},{"pid":"0b38c7c00a40837386429fab50054841e136d9af","tid":1488193,"uid":50904,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:54:54.000Z","msg":"國際特赦組織香港分會 Amnesty International Hong Kong<br />\n<a href=\"https://www.facebook.com/AmnestyHK/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FAmnestyHK%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=ebb03102\" target=\"_blank\">https://www.facebook.com/AmnestyHK/</a><br />\n<br />\n真係幫香港幫到盡，好多中英資料可以用<br />\n<br />\n連佢地總會秘書長Kumi Naidoo都出片支持香港人<br />\n<a href=\"https://www.facebook.com/AmnestyHK/videos/488611341934350/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FAmnestyHK%2Fvideos%2F488611341934350%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=0948e15a\" target=\"_blank\">https://www.facebook.com/AmnestyHK/videos/488611341934350/</a><br />\n<br />\n612警暴report，中英都有<br />\nHOW NOT TO POLICE A PROTEST: UNLAWFUL USE OF FORCE BY HONG KONG POLICE<br />\n<a href=\"https://www.amnesty.org/en/documents/asa17/0576/2019/en/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.amnesty.org%2Fen%2Fdocuments%2Fasa17%2F0576%2F2019%2Fen%2F&d=3k3yiaJ8En3geZFfXz4NABckzRVyZutP2gug%2B5Lqx%2Fc%3D&h=07134628\" target=\"_blank\">https://www.amnesty.org/en/documents/asa17/0576/2019/en/</a>"},{"pid":"6f8e510db569d5537224b7c1b2d9f197013c0e02","tid":1488193,"uid":293673,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T01:56:08.000Z","msg":"此回覆已被刪除"},{"pid":"1125f3c3dd847e94e3cde2c4682676c4d901c64f","tid":1488193,"uid":8308,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-21T01:58:56.000Z","msg":"以前讀書仲有個好on9既諗法<br />\n我每月食少餐放題 非洲細路就夠食一個月<br />\n所以有一排試過助養<br />\n後尾覺得太ON9 香港夠有好多小朋友需要幫助<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n而且捐完都唔知有幾多真係到左受助人手上<br />\n而家真係一毫子都唔會再捐D垃圾國際機構<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n留返俾立場 蘋果 612 眾籌 同未來所有幫到香港既籌款"},{"pid":"bfe87709bc8faa8ed5627916d21ea0d0add3ca7c","tid":1488193,"uid":183194,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T02:00:45.000Z","msg":"認同"}]}