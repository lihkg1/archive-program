rc=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"f2095bf5373ac4bab3ac3b9e902f03d35bbbcc76","tid":1352310,"uid":273991,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T18:42:48.000Z","msg":"推"},{"pid":"a4a62fe8c9253acbee93ef4454a679367d7aaf78","tid":1352310,"uid":279713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T18:42:58.000Z","msg":"Hong Kongers ASSEMBLE!"},{"pid":"fd72468dc93a3a32c4dca222384277df2eab98b8","tid":1352310,"uid":279713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T18:44:34.000Z","msg":"目前問題：<br />\n<br />\n1.五毛情況嚴重<br />\n<br />\n2.運動焦點模糊<br />\n<br />\n3.戰線分散 有你無我"},{"pid":"e9fe2c599d4c647ee99f28d631c22f7379fd2961","tid":1352310,"uid":279713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T18:45:37.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"5723f178fae4a190e6d1897dd09cce39252a3953","tid":1352310,"uid":279713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T18:49:25.000Z","msg":"推"},{"pid":"2de2c82e55fe2dcc3def7992a642af85688ac677","tid":1352310,"uid":280347,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-07-22T18:54:03.000Z","msg":"<span style=\"font-size: xx-large;\">4.未來網絡五毛問題</span><br />\n<br />\n正如中出羊子個Post所講<br />\n既然現時連登已經有大量五毛可以帶動風向<br />\n我有啲懷疑 <br />\n會唔會佢地已經搵到方法去大量註冊假Acc？<br />\n<br />\n我地連登仔過往對咩&ldquo;帝吧出征&rdquo;不屑一顧（原諒我唔記得呢啲弱智名）<br />\n係因為我地深信佢地唔會有大專/電訊商Email<br />\n但如果佢地真係搵到方法混入嚟嘅話<br />\n結果係可以<span style=\"color: red;\">極度災難性</span><br />\n如果只係入嚟留堆垃圾comment鬧你&ldquo;港燦&rdquo;&ldquo;港獨狗&rdquo; 都算，唔會有咩實質影響<br />\n但如果係入嚟<span style=\"color: red;\">打繁體字扮香港人、扮普通連登仔而搞分化</span>嘅話<br />\n到時我地又會多咗一條網絡戰線處理<br />\n再分散埋文宣組嘅人手<br />\n<br />\n另外，佢地應該都會有hacker去搞連登server<br />\n<br />\n我在此強烈建議同請求連仔：<br />\n1. 預先做好防備，準備應對網絡攻擊<br />\n2. 呢段時間禁止新Acc註冊<br />\n（如果覺得呢個措施有啲誇張嘅話，咁都請求你，<span style=\"color: red;\">一旦連登forum受到太量五毛惡意刷Comment，就立刻停止新會員註冊及發言</span>）"},{"pid":"ff6c9b9101bf9d377acbc634c05115901ee6e762","tid":1352310,"uid":280347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T18:54:17.000Z","msg":"Push<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"0a8870480ef83d4cc0bef4bed4eaf1c732a071e6","tid":1352310,"uid":112748,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T18:56:34.000Z","msg":"推"},{"pid":"12609fcf9b74bb5a8286e47fee0b0f6c6271b218","tid":1352310,"uid":279713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T18:58:03.000Z","msg":"推！！！！！"},{"pid":"4f103fd19f06f3ef80bfc324fc620966202f0c11","tid":1352310,"uid":279713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T18:58:15.000Z","msg":"臨"},{"pid":"4260ca642281610b2c146c7f63640b2a8be080f1","tid":1352310,"uid":279713,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-22T18:58:25.000Z","msg":"瞓"},{"pid":"76250e89a77b4f