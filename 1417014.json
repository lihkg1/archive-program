ree.gif\" class=\"hkgmoji\" />"},{"pid":"e50aeefe54a1809f7505d2382588e633dc09f817","tid":1417014,"uid":49336,"like":1,"dislike":0,"score":1,"quote":{"pid":"e10449024aac35656d9767fdfa64281550fbc5f2","tid":1417014,"uid":49336,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-06T05:57:26.000Z","msg":"當年曹汝霖都係咁樣俾人搞<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-06T05:58:07.000Z","msg":"火燒趙家樓"},{"pid":"737789b0128757cf0ac7cd3eec4b8437c40ea2ab","tid":1417014,"uid":158404,"like":1,"dislike":0,"score":1,"quote":{"pid":"73f72ad59f45135a070f331ed8bb20dba226b393","tid":1417014,"uid":93202,"like":1,"dislike":3,"score":-2,"citedBy":1,"replyTime":"2019-08-05T15:57:56.000Z","msg":"宜家全部注意力變晒警畜<br />\n<span style=\"font-size: xx-large;\">對準政權呀兄弟姊妹</span><br />\n留心力留體力同正苦玩 唔係班走狗呀"},"citedBy":0,"replyTime":"2019-08-06T05:58:37.000Z","msg":"三位一體 林鄭=警=黑<br />\n無得你打邊個唔打邊個"}]}