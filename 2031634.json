oji\" />"},{"pid":"405dc3e9034f2162f039fc7b5e959bfce51429d8","tid":2031634,"uid":11291,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T14:06:55.000Z","msg":"又砌生豬肉"},{"pid":"8bb51e5cfc02328baeb819f502c61ffcae44ecdc","tid":2031634,"uid":280329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T14:10:00.000Z","msg":"我估都係乜撚野支持國安法街站"},{"pid":"bc8d568a6d3e9624af4bb4bfd61e199fe53693eb","tid":2031634,"uid":35107,"like":1,"dislike":0,"score":1,"quote":{"pid":"43d1ee15e72cc2910a9e6e79765442ea2e01ed04","tid":2031634,"uid":180168,"like":2,"dislike":1,"score":1,"citedBy":3,"replyTime":"2020-05-23T13:56:17.000Z","msg":"街站邊個擺先係重點"},"citedBy":0,"replyTime":"2020-05-23T14:17:09.000Z","msg":"係民主派街站比人搞就唔會拉人啦"},{"pid":"a0ea56773c3e161778c44e09e78e910237d62ea3","tid":2031634,"uid":34929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T14:49:38.000Z","msg":"手足<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"0748d11f053a0b6cfbfc30b8177f11dcfb289c80","tid":2031634,"uid":304769,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T14:54:04.000Z","msg":"何已完另一粒lin仲健在就收皮啦<br />\n<br />\n<span style=\"font-size: x-large;\">借個位，連登黑色五毛風向警告</span><br />\n正視聽，<span style=\"color: red;\">國安法唔係攬炒，美國做野先係</span><br />\n<br />\n大家<span style=\"color: red;\">唔好比五毛帶風向去支持國安法，否則會比對家spin成香港人支持國安法</span>。只有<span style=\"color: red;\">香港人強烈反對下通過，美國才有做野的理由</span>。大家小心。<br />\n<br />\n借個位<br />\n連登一向錯曬風向，<span style=\"color: red;\">英國點日落都好，香港問題上都係重要持分者</span>，必須engage。<br />\n我地唔係要拉攏政府班奶共狗（例如Dominic Rabb），而係要<span style=\"color: red;\">拉攏英國民意</span>啊。英國係民主國家，民意最重要。英國民意決定stand with Hong Kong/Boycott China，BJ以至成個政府都無得唔跟。<span style=\"color: red;\">宜家武肺英國死左就三萬幾人，正是推動報仇民意好機會</span>。<br />\n<br />\n另外要借助美國向英國施壓，因為<span style=\"color: red;\">美國有動機（報武肺之仇）同拳頭，加英國有理由（聯合聲明），兩個加埋先容易嚮香港問題做野</span>"},{"pid":"826a04ba78f62fa86542a4d27b219dfb980b23ae","tid":2031634,"uid":152241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T14:54:12.000Z","msg":"推"},{"pid":"5700e9bdf0fa435064be34ce3a07c82a7a9c20f4","tid":2031634,"uid":263600,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T14:57:10.000Z","msg":"probably 係B出口天橋個個&quot;狗龍社團聯會&quot;既街站<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"fc19892b302dee59b6d73d2a4a161db811ed6bfc","tid":2031634,"uid":21470,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-23T15:01:15.000Z","msg":"[更新] 警拘3名藏菜刀少年涉九龍灣街站串謀傷人<br />\n23.05.2020 22:52<br />\n<br />\n<img src=\"https://www.881903.com/News_Images/NewsBoss/resize/20200523_20200523-225301.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.881903.com%2FNews_Images%2FNewsBoss%2Fresize%2F20200523_20200523-225301.jpg&h=47c31bca&s={SIZE}\" /><br />\n<br />\n警方拘捕3名15至16歲男學生，涉嫌在九龍灣一個團體街站串謀傷人。警方表示，警員下午在九龍灣港鐵站巡邏期間，聽到附近有防狼器聲響，上前調查時見到3名少年與擺街站的義工爭執，其中一人作出可疑動作，街站義工懷疑他準備在腰間拔出武器，義工於是拉動防狼器求助，警方最後截停其中兩名少年，在他們身上各搜出一把菜刀，即場將他們拘捕，晚上亦將餘下一名涉案在逃少年拘捕，在他身上同樣檢獲一把菜刀。<br />\n<br />\n警方指，涉及的街站團體是九龍社團聯會，會調查是否有預謀犯案和是否涉及政治爭執。<br />\n<br />\n<a href=\"https://www.881903.com/Page/ZH-TW/newsdetail.aspx?ItemId=1289686&amp;csid=261_341\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.881903.com%2FPage%2FZH-TW%2Fnewsdetail.aspx%3FItemId%3D1289686%26csid%3D261_341&d=s%2ByQnOBpfLb1r8GSWDTSOYCLuBk19a2msHWYQfvuVO4%3D&h=5f2242b6\" data-auto-link target=\"_blank\">https://www.881903.com/Page/ZH-TW/newsdetail.aspx?ItemId=1289686&amp;csid=261_341</a>"},{"pid":"8b88d2136af6b23cdbf41e11a314876265f69410","tid":2031634,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T15:53:18.000Z","msg":"假撚到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"0e4af795dca112af1bf7b43a69143ef63401d47d","tid":2031634,"uid":8014,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-23T15:55:02.000Z","msg":"老鳯不幸被捕？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"074e65c90a26af9145d124de760b85b4