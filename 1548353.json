/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"cee827088d7eddaae5b7c53962ca46a3768c2fa2","tid":1548353,"uid":282480,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T03:59:43.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">《我不自殺聲明》</span></span> 大家快手share<br />\n<a href=\"https://lih.kg/1548331\" data-auto-link target=\"_blank\">https://lih.kg/1548331</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n本人生性謹慎而樂觀開朗，身體健康，有堅強信念，過去／現在／將來無論遭遇疾病／政治迫害／生活艱辛等各種情況，絕不尋求自殺來解脫。如有不測，必有嫁禍，包括車禍／溺水都不可信。除專制暴政別無他敵，特留此存照。<br />\n<br />\n#我不自殺聲明<br />\n<br />\n麻煩大家係FB/IG tag3個朋友再share出去！麻煩文宣整個我不自殺logo畀人轉FB/ IG icon!!!"},{"pid":"f478e611eb03164fa5af0368060cfb08903371d7","tid":1548353,"uid":80363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T03:59:43.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"10c80f63b31bb9a4c6721425aa7680a3dc8404e7","tid":1548353,"uid":26876,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T04:00:11.000Z","msg":"推"},{"pid":"04203e4fcac15a1480891612b27baa930166a0b5","tid":1548353,"uid":80363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T04:01:06.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"ce955f713f71f9425791224a85b4305c4f9d0287","tid":1548353,"uid":80363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T04:01:58.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"1fe4db3c95742e79e2c52b28cdb01176aadf9787","tid":1548353,"uid":80363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T04:03:04.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6c9fbbf989472cbb4d6eabf5b4e544c12f9c97f9","tid":1548353,"uid":80363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T04:05:09.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"fc3d7a26