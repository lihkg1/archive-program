5ffd9158830cb5f0a9d3d52c","tid":2052172,"uid":4942,"like":0,"dislike":0,"score":0,"quote":{"pid":"c1d39c8c7d5b89ceede13c613a273ffa80186de8","tid":2052172,"uid":170987,"like":4,"dislike":0,"score":4,"quote":{"pid":"687d7528c5d94b55ec8006fc1ede4e60ee73bd20","tid":2052172,"uid":76432,"like":8,"dislike":0,"score":8,"quote":{"pid":"2db9003bc928bc9fa67489b2ef0fc8cef294b5d0","tid":2052172,"uid":223084,"like":1,"dislike":38,"score":-37,"citedBy":7,"replyTime":"2020-06-05T10:58:38.000Z","msg":"屎忽落地<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-06-05T11:40:48.000Z","msg":"冇撞到燈柱純粹好彩"},"citedBy":2,"replyTime":"2020-06-05T11:46:48.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2020/06/05/194628_e555ebb2df82682544d117cc23fc8a40.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2020%2F06%2F05%2F194628_e555ebb2df82682544d117cc23fc8a40.gif&h=44acb2fb&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-06-05T11:57:57.000Z","msg":"<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"892a8a46f881cc9d9ce07e803c1563b1c6ac25f4","tid":2052172,"uid":292292,"like":0,"dislike":0,"score":0,"quote":{"pid":"198365b8465854a44490f6c32eecb42abecd2f35","tid":2052172,"uid":141060,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-05T10:24:55.000Z","msg":"<a href=\"https://hk.on.cc/hk/bkn/cnt/amenews/20200605/mobile/bkn-20200605164718521-0605_00972_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Famenews%2F20200605%2Fmobile%2Fbkn-20200605164718521-0605_00972_001.html&d=hYhEKVoQeS8%2B2u2S5aPGGYZnnstt8OVeiO3WagLZNiI%3D&h=1d330490\" data-auto-link target=\"_blank\">https://hk.on.cc/hk/bkn/cnt/amenews/20200605/mobile/bkn-20200605164718521-0605_00972_001.html</a><br />\n<br />\n美國反警暴示威周四（4日）踏入第10天，警方執法方式再起爭議。紐約州水牛城兩名警員清場時，無故推跌一名75歲示威者，對方後腦着地及流血，涉事警員事後無薪停職。<br />\n<br />\n事發在水牛城市政廳地區，當時正值宵禁令剛剛生效，大批警員驅散示威者。此時一名老翁走到警方前線，突然遭警員推落地，事主在地上動也不動，更有鮮血從他的耳朵湧出。有示威者目擊後上前，結果遭警員帶走。片段曝光後轟動全國，當地警方宣布涉事警員停職受查；傷者事後送院，情況嚴重但穩定。<br />\n<br />\n同日，紐約州紐約市布魯克林區有民眾在宵禁令生效後，繼續在街上示威。網上片段可見，一名男子被警員帶走時，高呼自己姓名以及表示是中學教師，聲稱當時只是和平站在街頭。畫面一轉，見到另一名男子躺在地上，後腦流血。<br />\n<br />\n此外，加州洛杉磯費爾法克斯地區過去周末亦有警民衝突，網上片段顯示，警員與示威者對峙期間，突然有警員衝前以警棍大力揮打示威者，也有持防暴槍的警員開槍，暫未知是否有人嚴重受傷或被捕。當地警方周四回應查詢時表示當時情況混亂，有人向警員掟石、水樽等雜物，但未有解釋警員當時的行為。<br />\n<br />\n德州達拉斯26歲男子塞恩斯（Brandon Saenz）過去周末上街時，遭警員發射的海綿彈擊中。他周四表示，當時沒有挑釁警方，事後左眼劇痛，並永久失明。<br />\n<br />\n面對國內反警暴呼聲，民主黨着手推出改革警隊的法案，例如修改豁免條款、建立警方使用武力的資料庫，同時計劃更新培訓要求，包括禁止使用鎖喉術。"},"citedBy":0,"replyTime":"2020-06-05T12:03:30.000Z","msg":"得1個停職， 射爆人隻眼果個無事<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"1fa94b3a52fa947b4a55bbea92a8a692b1c34111","tid":2052172,"uid":308251,"like":0,"dislike":0,"score":0,"quote":{"pid":"d000b1c70f4e77349bb7da0c28441de50547116a","tid":2052172,"uid":20809,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-06-05T11:05:25.000Z","msg":"d五毛話冇得比喎，話人地係民主國家，我地係極權國家，我地就係要硬食<br />\n<br />\non9到合理化佢地口中既極權國家既警暴行為"},"citedBy":0,"replyTime":"2020-06-05T12:05:35.000Z","msg":"咁真係冇得比喎, 你一日唔推翻中共, 你日日比較有咩意思<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n除非你做文宣比其他民主國家睇, 不過啲人民平常唔會理尻你, 同理就係你幾年都唔會理尻新疆西藏, 不過啲政府同議員會理<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"907dead8a1f1f328370d218c5d3eb3b6007ce2cb","tid":2052172,"uid":167548,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-06-05T12:15:34.000Z","msg":"<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" />"},{"pid":"6d5853a5386084f0844d99ac1450fa3eebe36646","tid":2052172,"uid":167548,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-05T12:17:03.00