\" />"},{"pid":"b2caedf28db276ee9a8af475ff84025bc2c6b050","tid":1475211,"uid":14866,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-15T16:09:48.000Z","msg":"住啟晴<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />希望救到呢度"},{"pid":"8889547dc2d51d6b53f2721a5856c04d13c73a01","tid":1475211,"uid":204163,"like":0,"dislike":0,"score":0,"quote":{"pid":"b2caedf28db276ee9a8af475ff84025bc2c6b050","tid":1475211,"uid":14866,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-15T16:09:48.000Z","msg":"住啟晴<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />希望救到呢度"},"citedBy":0,"replyTime":"2019-08-15T16:34:10.000Z","msg":"一樣啊<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n唔想呢條邨繼續沉淪落去<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"45cb17bbe77eaf37030620f955bb1ee3def10241","tid":1475211,"uid":204163,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-15T23:08:35.000Z","msg":"818"},{"pid":"c7822a3261b22565239043c2b7ef120929b2ee38","tid":1475211,"uid":278506,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-15T23:13:35.000Z","msg":"<img src=\"https://na.cx/i/GPGddyT.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FGPGddyT.jpg&h=89d649e5&s={SIZE}\" /><br />\n824麻煩過埋嚟啓晴德朗<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"4d353d389b45cff7026e7039b58d47666c0f72c5","tid":1475211,"uid":274749,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T00:09:59.000Z","msg":"Push"},{"pid":"f22c272795d06fee6464dc69607194f7587e6543","tid":1475211,"uid":230472,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T05:20:55.000Z","msg":"此回覆已被刪除"},{"pid":"3b7c2ce3eb961c3af879d646161a96e387e98906","tid":1475211,"uid":224298,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T06:39:50.000Z","msg":"push push"},{"pid":"421d369546f03866100b66e2674a284f1d994582","tid":1475211,"uid":42942,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T06:44:37.000Z","msg":"推"},{"pid":"34dc7a1eb96c2b6bfd8991fa9d0bad35dfdca186","tid":1475211,"uid":146975,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T06:45:09.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"add40b019092d1291b8db36a8edd3ce10a267907","tid":1475211,"uid":17796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T06:45:58.000Z","msg":"<img src=\"/assets/faces/pig/whip_special.gif\" class=\"hkgmoji\" />"},{"pid":"4e597aae7d0b9c38a20758e1a789e2ae4100d0a9","tid":1475211,"uid":204163,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T08:00:06.000Z","msg":"818<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"5c378fed39343617eb3ac022da844b434f6dd6de","tid":1475211,"uid":285708,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T08:03:19.000Z","msg":"816 集會<br />\n817 紅土<br />\n818 維園"},{"pid":"7147bbdfa09bbd824a9358ea93f343e6cbb9015a","tid":1475211,"uid":288786,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-16T11:47:24.000Z","msg":"時代革命第二波----經濟戰線----趕走親中財團<br />\n真香港人在2019年6月開始的大時代付出了大量傷痛、血汗和生命代價，令自由世界的人民領略到真香港人對抗中共港共的不公義的無比勇敢與極高智慧，全世界都肯定真香港人是最偉大的民族之一。中共的卑劣手段及與民為敵惡魔本性令真香港人更堅定雙普選及民族自決才是未來的出路。<br />\n<br />\n因此我們應該進入下一波時代革命：<span style=\"color: red;\"><span style=\"font-size: x-large;\">在經濟上趕走親共財團與用貪腐養大的中聯辦</span></span>（至少要他們減血九成），這些官商勾結財團是會牢牢掌握佢地嘅不公義制度，為了利益佢地會壞事做盡。<br />\n<br />\n我們應該<span style=\"color: purple;\"><span style=\"font-size: x-large;\">建立抗共經濟，區別於親共財團，我們要通過與歐美的聯繫說服歐美（包括香港人權法等等方式）制裁香港的親共財團的出口及其他經濟活動，同時保持讓真香港人的抗共經濟保持免稅、免制裁優惠</span></span>。<br />\n<br />\n我們絕對可以在這個全球經濟轉型時創造奇蹟，理由如下：<br />\n<br />\n1.香港人的經濟活力、專業精神、全球網絡非常適合industry 4.0及因中美貿易戰需重建的供應鏈，我們可以建立flexible workshop新經濟模式製造靈活的訂單；<br />\n<br />\n2. 香港在90年代有大量的工業技術人才，我們可以利用網絡聯繫重啟他們的技術talent (例如在連登中發表「職得做xxx的入黎」，我們可以製造出比淘寶優質的產品，真香港人現正開始大量參與使用及研發人工智能可以擴展我們的生產能力千倍或萬倍，因此我們可以製造出與淘寶一樣versatile 豐富多彩的產品系列 <a href=\"https://www.google.com/amp/s/www.forbes.com/sites/janakirammsv/2019/08/12/why-aiot-is-emerging-as-the-future-of-industry-40/amp/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.google.com%2Famp%2Fs%2Fwww.forbes.com%2Fsites%2Fjanakirammsv%2F2019%2F08%2F12%2Fwhy-aiot-is-emerging-as-the-future-of-industry-40%2Famp%2F&d=LSsgDEuqvL%2F6lC7PehFbg4T2PPn%2Ft%2FQrHStoP3Eljfw%3D&h=d8e47230\" target=\"_blank\">https://www.google.com/amp/s/www.forbes.com/sites/janakirammsv/2019/08/12/why-aiot-is-emerging-as-the-future-of-industry-40/amp/</a>；<br />\n<br />\n3. 有足夠的香港及海外資金願意投資香港的抗共經濟，尤其是建立的人網絡為產品增值，industry 4.0的產品可以由全球供應鏈合作而成，真香港人正是適合在其中扮演agents；<br />\n<br />\n4. 抗共經濟可以在香港本土迅速成長，我們可以借助文宣的經驗說服香港人大量購買使用抗共經濟的產品；<br />\n<br />\n5.可以考慮用非牟利捐款形式開始智囊及商會，團結越多人越成功，協調logistics 也是真香港人能夠做得最好的。商會也要分辨是否有親中商人混入真香港人經濟圈；<br />\n<br />\n6.真香港人投入新經濟一定會得到全世界的支持，因為industry 4.0正是需要真香港人的特質作為領頭羊，而不是中共貪腐結構下的工業人。不可否認，中國的industry 4.0是相當領先，但他們搞的并非歐美期望的將部分workshop留在歐美(global players,regional segmentation)，真香港人就可以做得到 <a href=\"https://www.google.com/amp/independenttelegraph.com/big-data-analytics-in-manufacturing-industry-market-2018-global-industry-insights-by-global-players-regional-segmentation-growth-applications-major-drivers-value-and-foreseen-till-2023-360-mar/10793/amp/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.google.com%2Famp%2Findependenttelegraph.com%2Fbig-data-analytics-in-manufacturing-industry-market-2018-global-industry-insights-by-global-players-regional-segmentation-growth-applications-major-drivers-value-and-foreseen-till-2023-360-mar%2F10793%2Famp%2F&d=LSsgDEuqvL%2F6lC7PehFbg4T2PPn%2Ft%2FQrHStoP3Eljfw%3D&h=2c736ab3\" target=\"_blank\">https://www.google.com/amp/independenttelegraph.com/big-data-analytics-in-manufacturing-industry-market-2018-global-industry-insights-by-global-players-regional-segmentation-growth-applications-major-drivers-value-and-foreseen-till-2023-360-mar/10793/amp/</a>;<br />\n<br />\n7. 要達到經濟獨立并最終令中共給予真香港人雙普選，我們仍然要間中用抗爭用選票打低親中建制，但請真香港人be water，盡量不要流血或被捕。<br />\n<br />\n本人上述建議只是拋磚引玉，請更多專家們為抗共自主經濟出謀劃策。<br />\n<br />\n<span style=\"color: red;\">光復香港時代革命</span>"}]}