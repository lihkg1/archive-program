c1ff5cd7f","tid":589451,"uid":189,"like":3,"dislike":2,"score":1,"citedBy":1,"replyTime":"2018-03-12T01:18:42.000Z","msg":"成個連登本土派都住九西"},{"pid":"92d1c2b54636990d0d775b46c27f6c7360ac6df7","tid":589451,"uid":12367,"like":6,"dislike":1,"score":5,"quote":{"pid":"366da84c2ce6b09fdc31957a88c82ffc1ff5cd7f","tid":589451,"uid":189,"like":3,"dislike":2,"score":1,"citedBy":1,"replyTime":"2018-03-12T01:18:42.000Z","msg":"成個連登本土派都住九西"},"citedBy":0,"replyTime":"2018-03-12T01:19:42.000Z","msg":"正常，下等人係住呢d深水埗既地方<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"527ed1a3ed33f4babddaaa92005382f2bbc02579","tid":589451,"uid":73915,"like":0,"dislike":1,"score":-1,"quote":{"pid":"48dd3a294a581fc4e4ce533960bfe2c120722f1a","tid":589451,"uid":56677,"like":1,"dislike":0,"score":1,"quote":{"pid":"a9f4acd3edd057be62a3da6a363b1a789bbdde18","tid":589451,"uid":99403,"like":5,"dislike":1,"score":4,"citedBy":3,"replyTime":"2018-03-12T01:10:25.000Z","msg":"今次補選焦土派焦左d咩出黎呀<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-12T01:17:47.000Z","msg":"焦撚左建制條冚家鏟出黎囉"},"citedBy":0,"replyTime":"2018-03-12T03:05:15.000Z","msg":"泛民咪又係認可反對派<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3f61893a6e1667775b1686af41ae62e0fd1f4919","tid":589451,"uid":61280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-12T03:10:20.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2018/03/12/084237_74e818d7da05ecbe8e2e0a7ea708fdf9.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F12%2F084237_74e818d7da05ecbe8e2e0a7ea708fdf9.png&h=6c9baf49&s={SIZE}\" /><br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /></blockquote><br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\"><span style=\"font-size: xx-large;\"><span style=\"font-size: xx-large;\">多撚謝販民班大愛支（尤其民主党工党同社民狗！）囉！！！！<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n啟德一早都知係港共專登設計既市區票倉膽！！！！</span></span></span></strong></span><br />\n<br />\n<img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\"><br />\n<br />\n「姚松炎今次做選舉工程，同我哋傳統政黨，真係好唔同，我哋唔係好慣，尤其係打開地面戰嗰班，其實一直覺得佢危。<br />\n<br />\n我哋擺街站、洗樓、去屋邨，佢哋認為唔使做好多呢啲，覺得做好網上，網上反應熱烈，就好有信心。<br />\n<br />\n即使佢哋助選團，或者幫忙嘅團體開（街）站，但好似用錯力，星期五、六下晝，喺佐敦開站，我哋一般唔會咁做，因為嗰啲係街客，去行街，唔係選民；即使開喺住宅區，有啲朝早9點後先至開，嗰啲時間，人人返晒工，開站都無咩用。<br />\n<br />\n姚松炎團隊去土瓜灣少數族裔拉票，好奇怪，或者踩單車，我哋好多人睇到，暈低咁滯。或者係我哋太傳統，唔慣咁做。<br />\n<br />\n不過泛民好多大佬，就好buy佢呢套，所以一直覺得九西呢個位好易贏，無咩危機感，其實我地做開地區嘅，睇佢唔係咁穩陣。<br />\n<br />\n佢哋呢種選舉工程，喺比例代表制，效果可能會比較好，今次補選只係選一個位，未必可以咁打選戰。今次投票率咁低，有好多原因，如果唔諗點樣做，下次補選，我擔心唔容易贏。」<br />\n<img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/big/fire.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/03/12/082155_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F12%2F082155_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=65e18a89&s={SIZE}\" /><br />\n<br />\n</span></strong></span><img src=\"https://img.eservice-hk.net/upload/2018/03/12/082539_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F12%2F082539_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=e96c93c8&s={SIZE}\" />"}]}