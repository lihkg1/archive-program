oji\" />"},{"pid":"06ae65ac61b57a3af1f221c903ed0fb8abca1fd7","tid":2377854,"uid":172733,"like":0,"dislike":12,"score":-12,"citedBy":1,"replyTime":"2021-01-24T09:28:22.000Z","msg":"開個page乞錢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cb8d89c23d89cab1e6a97d48e53f8993be905ee6","tid":2377854,"uid":261132,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-24T09:31:41.000Z","msg":"樓主加油，係長期抗戰，但係要知自己能力，長期嚴重病適當時間要放手"},{"pid":"d8b4ea9aa94bbed3412056ee7e1f672acdba3244","tid":2377854,"uid":196420,"like":5,"dislike":0,"score":5,"quote":{"pid":"06ae65ac61b57a3af1f221c903ed0fb8abca1fd7","tid":2377854,"uid":172733,"like":0,"dislike":12,"score":-12,"citedBy":1,"replyTime":"2021-01-24T09:28:22.000Z","msg":"開個page乞錢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-24T09:36:59.000Z","msg":"咁你想佢地點<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />高人"},{"pid":"fc69a21a5f8c38209cc67a50bcb76c1a2c98ed5a","tid":2377854,"uid":172733,"like":0,"dislike":7,"score":-7,"quote":{"pid":"d8b4ea9aa94bbed3412056ee7e1f672acdba3244","tid":2377854,"uid":196420,"like":5,"dislike":0,"score":5,"quote":{"pid":"06ae65ac61b57a3af1f221c903ed0fb8abca1fd7","tid":2377854,"uid":172733,"like":0,"dislike":12,"score":-12,"citedBy":1,"replyTime":"2021-01-24T09:28:22.000Z","msg":"開個page乞錢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-24T09:36:59.000Z","msg":"咁你想佢地點<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />高人"},"citedBy":2,"replyTime":"2021-01-24T10:29:59.000Z","msg":"無能力就唔好夾硬黎啦<br />\n<br />\n點解要人幫佢養貓"},{"pid":"acebdd3347386014b9fa502d4eca5335dca4ee4d","tid":2377854,"uid":196420,"like":5,"dislike":0,"score":5,"quote":{"pid":"fc69a21a5f8c38209cc67a50bcb76c1a2c98ed5a","tid":2377854,"uid":172733,"like":0,"dislike":7,"score":-7,"quote":{"pid":"d8b4ea9aa94bbed3412056ee7e1f672acdba3244","tid":2377854,"uid":196420,"like":5,"dislike":0,"score":5,"quot