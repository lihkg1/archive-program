/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"25aa57211e528287a2b0e2f41d48596dc5129c98","tid":798534,"uid":27664,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T11:39:01.000Z","msg":"冇錯，影響就一係有一係冇 <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"1f8819045fda8a5958ff064e5cdb4da31fbfc73e","tid":798534,"uid":106363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T11:49:48.000Z","msg":"文革復闢"},{"pid":"ef379a83ebd928dd1dbeeb9bef5c29567c87e115","tid":798534,"uid":152123,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T11:50:57.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>東張西望</strong></span></span>"},{"pid":"aa91e82b679b08181fc0ca89cfbebc9ca485c032","tid":798534,"uid":156363,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-29T11:52:51.000Z","msg":"香港警察同香港記者低質姐，不過最低質都係有D咁既讀者。"},{"pid":"86e77ac1212e48dd155293a1c228c7690e8eeb35","tid":798534,"uid":83321,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T12:03:14.000Z","msg":"其實套返落之前警署lan線自殺都得"},{"pid":"6f72d0f36595b71154e952f88c5f5026fd46f37b","tid":798534,"uid":141399,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T13:05:39.000Z","msg":"支那藍絲見獵心喜，未審先判之餘，以往咁樣可以抹黑佢地口中嘅整個黃絲陣營"},{"pid":"a1ef4d25b575fc2cfab10091c49d8d372cb5bd87","tid":798534,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T13:08:22.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}