6037fb889766ce54","tid":2485334,"uid":214309,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04-14T06:05:46.000Z","msg":"唔知有無辦法可以寫死佢個故仔<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"d32ccdc4d797f7203947a6895ffa1bc1a0728405","tid":2485334,"uid":98338,"like":0,"dislike":0,"score":0,"quote":{"pid":"7e6d69974efcbf5785e5e0c8650618a9600f61dd","tid":2485334,"uid":345520,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-14T06:04:24.000Z","msg":"幾好睇，樓主加油<img src=\"/assets/faces/pig/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-14T06:07:03.000Z","msg":"之後會有啲魔改同ff<br />\n到時唔好屌咁大力<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"7f9fbb60fd28fc4e511564316dbfb294315a45f7","tid":2485334,"uid":381502,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-14T06:12:19.000Z","msg":"樓主加油<br />\nBetween 會唔會出水芸<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},{"pid":"4766eac5a477227abcbfee1c6a6115d6d9367a69","tid":2485334,"uid":338767,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-14T06:14:03.000Z","msg":"A"},{"pid":"d4c8694e82d3ffe91059779fa194ba078a7405f8","tid":2485334,"uid":182003,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-14T06:18:43.000Z","msg":"Y<br />\n村長應該仲等緊我地，要去搵佢<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"286c0a9a464f56e3434550e4df01ba7b5578d3d2","tid":2485334,"uid":98338,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-14T07:32:38.000Z","msg":"【欺騙倪泰先行，自己趁機回神火村】<br />\n<br />\n倪泰雖然係自己救命恩人，而且都係本住好意，想教你狩獵嘅技巧。<br />\n<br />\n但係你始終都唔係咩能人異士，命仔緊要，你決定作個理由支開倪泰，自己再趁機返回神火村。<br />\n<br />\n「倪泰老師，不如你岀發先啦，我休息一陣可跟上黎，費事拖到入黑，重危險呀！」你動之以情，說之以理。憑你嘅三寸不爛之舌，倪泰比你說服左，先行岀發。<br />\n<br />\n你望住倪泰由左邊嘅斜坡向上走，身影越變越細，終於消失係樹林之間，嘴角忍唔住上揚。你伸過懶腰，挨係樹下。<br />\n<br />\n折騰左大半日，你都有啲肚餓了，諗住搵啲乾糧食，先發覺唔見左。你暗忖應該係啱啱比巨熊襲擊，慌亂之間，將佢掉左係某處。<br />\n<br />\n就係苦惱之際，你見到遠處有隻「艾露貓」&mdash;&mdash;姐係之前係村落見到嘅貓貓，好似執起左你嘅行李，向住倪泰前進嘅方向右手面嘅山路逃跑。<br />\n<br />\n為左唔好捱肚餓，你決定追上去，心諗：快快手搞掂隻貓，再返神火村都唔遲。<br />\n<br />\n臨行前，你重捉左樹邊嘅翔蟲入袋，所以轉眼功夫已經追到「艾露貓」身後。<br />\n<br />\n可惜佢發現左你，佢幾個轉向，你居然跟甩左。<br />\n<br />\n你心灰意冷，打算睇下四周有咩可以充飢，好彩咁發現左有隻野豬係不遠嘅右面。<br />\n<br />\n好事成雙，左手面有個巨型蜂巢，滴住黃澄澄嘅蜂蜜。<br />\n<br />\n你決定：<br />\nA:去右手邊，嘗試狩獵野豬<br />\nB:去左手邊，嘗試拎蜂蜜<br />\n<br />\n（今次得兩個選項。）"},{"pid":"34e28ceeef4df6c42c1913fa22b3e3bdd2cf8fd0","tid":2485334,"uid":98338,"like":0,"dislike":0,"score":0,"quote":{"pid":"7f9fbb60fd28fc4e511564316dbfb294315a45f7","tid":2485334,"uid":381502,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-14T06:12:19.000Z","msg":"樓主加油<br />\nBetween 會唔會出水芸<img src=\"/assets/faces/lm2/lick.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-14T07:33:03.000Z","msg":"多謝<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><br />\n會呀"},{"pid":"52a8c45d112d22a65a79ad6723883909203fd64c","tid":2485334,"uid":98338,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-14T07:33:34.000Z","msg":"btw返工狗返工時間岀唔到咁多<br />\n請見諒<img src=\"/assets/faces/dog/itdog1.gif\" class=\"hkgmoji\" />"},{"pid":"281fa2f44c379a0db066dd70c386b360c7c78c5c","tid":2485334,"uid":266872,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-14T07:58:37.000Z","msg":"a<br />\n我要火芽<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},{"pid":"98546fac8617ecc367c8aa5e1383855b624eebe3","tid":2485334,"uid":182003,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-14T08:02:01.000Z","msg":"A"},{"pid":"53d74e3a8de53cff128753d24403390ae3d490b1","tid":2485334,"uid":345520,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-14T08:10:14.000Z","msg":"A"},{"pid":"8f8d2651a55b14b673655e3c18c81a35995eef20","tid":2485334,"uid":380831,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-14T09:10:06.000Z","msg":"A"},{"pid":"e6b97dd5022607d9ceec9b4e4eaae9e05838a5a4","tid":2485334,"uid":81947,"like":0,"dislike":0,"score":0,"quote":{"pid":"d9ecff2b2c2f4f34b013be1a6037fb889766ce54","tid":2485334,"uid":214309,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04-14T06:05:46.000Z","msg":"唔知有無辦法可以寫死佢個故仔<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-14T10:19:50.000Z","msg":"唔使諗有冇辦法<br />\n呢個根本係連登互動故傳統嚟<br />\n隔離個劉備就嚟俾班巴打寫撚死"},{"pid":"4926127056da822216b4a16b9b8814bcb0a47abb","tid":2485334,"uid":98338,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-14T10:51:50.000Z","msg":"【去右手邊嘗試狩獵野豬】<br />\n<br />\n你太耐無食過肉了，決定去右手邊嘗試狩獵野豬，一祭五臟廟。<br />\n<br />\n野豬好快就發現左你，並加速衝刺，打算迎頭痛擊來犯嘅敵人。<br />\n<br />\n你向旁翻滾，剛好避過野豬嘅衝鋒，當你以為碌過左佢，又黎回馬槍。<br />\n<br />\n你傷勢啱啱好返啲，比野豬咁樣一衝，傷口又再裂開。<br />\n<br />\n你不由得怒火攻心，拔岀狩獵笛錘向野豬。<br />\n<br />\n左揮！左揮！啪！右劈！右劈！碰！<br />\n<br />\n你連環揮擊，野豬早被你擊斃都渾無知覺。<br />\n<br />\n「嘿⋯⋯哈⋯⋯嘿⋯⋯哈⋯⋯」你大口喘息，慢慢平伏過黎。<br />\n<br />\n你用附近嘅木材簡單起左個火，就咁燒熟隻野豬黎食，雖然有啲茹毛飲血嘅原始感，但可能係因為消耗左大量體力嘅關係，你覺得燒野豬係你暫時食過最好食嘅野！<br />\n<br />\n就係你想稍作休息嘅時候，你聽到一群急速嘅腳步聲越來越接近。<br />\n<br />\n「嘶⋯⋯呀⋯⋯」野獸低吟，係一群被烤肉香氣吸引而黎嘅「鐮鼬龍」，魔物慢慢迫近，隱約形成包圍之勢。<br />\n<br />\n你時間無多，要盡快做決定：<br />\n<br />\nA:上前迎擊<br />\nB:嘗試用翔蟲飛向較高處<br />\nX:突圍並向山上逃走<br />\nY:突圍並向左邊逃走"},{"pid":"6443c42d6cb8b404f55a99aa7190a0f6c1af6c0c","tid":2485334,"uid":98338,"like":0,"dislike":0,"score":0,"quote":{"pid":"d9ecff2b2c2f4f34b013be1a6037fb889766ce54","tid":2485334,"uid":214309,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-04-14T06:05:46.000Z","msg":"唔知有無辦法可以寫死佢個故仔<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-14T10:52:33.000Z","msg":"手下留情<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" />"},{"pid":"f7175c8d58766abfdf0207d04448084256c606b6","tid":2485334,"uid":74337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-14T10:55:33.000Z","msg":"A"},{"pid":"85d50e3a0a4d63f315d31df6af4abd66a0f6fc32","tid":2485334,"uid":81947,"like":0,"dislike":0,"score":0,"quote":{"pid":"4926127056da822216b4a16b9b8814bcb0a47abb","tid":2485334,"uid":98338,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":