07d5fe4ff6f7d876b5e86850ce57b624","tid":131502,"uid":82720,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-23T07:54:42.000Z","msg":"銀行?好呀<br />\n冥通吖嘛"},{"pid":"8a15b5201536a9869a26fe73178b6104407f4b26","tid":131502,"uid":59746,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-23T07:55:38.000Z","msg":"銀行佬講野都好信既真係<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"90a270cf987c46c3ce14c4383a3bee075f3669d8","tid":131502,"uid":36152,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-23T07:56:43.000Z","msg":"銀行業，<br />\n不過係幫銀行負責收數ge追數公司"},{"pid":"4f4a31c1f34b5b499f00979c826bf4a37c6b075e","tid":131502,"uid":78971,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-23T07:57:08.000Z","msg":"咁咪得囉<br />\n安心坐啦<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"22fe67a836ae8bd11249ee0a68f942c25bd267bd","tid":131502,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-23T08:04:41.000Z","msg":"<span style=\"color: gold;\"><span style=\"font-size: xx-large;\">中銀41樓有新同事啦！</span></span><br />\n<br />\n<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"7a709f018c665ffc1786b2b79d1454e01b90dd7a","tid":131502,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-23T08:06:16.000Z","msg":"<span style=\"color: gold;\"><span style=\"font-size: xx-large;\">幫手洗黒錢！</span></span><br />\n<img src=\"/assets/faces/lomoji/15.png\" class=\"hkgmoji\" /> <br />\n<br />\n<span style=\"font-size: xx-large;\">中銀米蘭分行洗黑錢案庭外和解 罰款近$500萬 </span><br />\n<br />\n<img src=\"http://static.apple.nextmedia.com/images/e-paper/20170218/large/1487362043_bdad.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fe-paper%2F20170218%2Flarge%2F1487362043_bdad.jpg&h=58dab93a&s={SIZE}\" /><br />\n<br />\n<a href=\"http://hk.apple.nextmedia.com/realtime/international/20170218/56320070\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.apple.nextmedia.com%2Frealtime%2Finternational%2F20170218%2F56320070&d=uli%2BLK8ypwQfiBTSi%2FGP90bWhtBCnEJYRTWbVbFBOac%3D&h=40ca8dc6\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fhk.apple.nextmedia.com%2Frealtime%2Finternational%2F20170218%2F56320070&h=8143538f\" target=\"_blank\">http://hk.apple.nextmedia.com/realtime/international/20170218/56320070</a><br />\n<br />\n 牽涉入45億歐元(370億港元)洗黑錢案的中國銀行，與意大利當局達成庭外和解，同意支付60萬歐元(494萬港元)作罰款。<br />\n<br />\n意大利通訊社ANSA報導，在周五的初步聆訊中，法官又裁定4名銀行職員洗錢罪名成立，判緩刑兩年，至於另一項使用黑手黨手法的控罪則獲撤消。<br />\n<br />\n法官又下令充公98萬歐元(807萬港元)，相等於控方指銀行在案件中的獲利款額。<br />\n<br />\n中國銀行表示，庭外和解的目的是「避免冗日持久的審訊，令米蘭分行可以集中精力發展業務」。銀行又表示其米蘭分行尊重意大利和國際法律。<br />\n<br />\n意大利檢察當局指中國銀行米蘭銀行及相關人士，在2006年至2010年的四年內，把客戶從逃稅、賣淫、剝削非法勞工和售賣冒牌貨所得的超過45億歐元款項，匯到中國。事件涉及297人，大部份是居於意大利的中國人，亦有米蘭分行4名高層職員。<br />\n<br />\n美聯社/《蘋果》資料室"},{"pid":"d94c7ae0f2aeffb24be55816bc9ce5fa650b07d3","tid":131502,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-23T08:07:08.000Z","msg":"<span style=\"color: gold;\"><span style=\"font-size: xx-large;\">黑警放監受聘洗黒錢！</span></span><br />\n <br />\n<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"2ee510cc3542268053d5972a8c3c1bf6fb32d6eb","tid":131502,"uid":83052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-23T08:07:26.000Z","msg":"<blockquote><span style=\"color: gold;\"><span style=\"font-size: xx-large;\">幫手洗黒錢！</span></span><br />\n<img src=\"/assets/faces/lomoji/15.png\" class=\"hkgmoji\" /> <br />\n<br />\n<span style=\"font-size: xx-large;\">中銀米蘭分行洗黑錢案庭外和解 罰款近$500萬 </span><br />\n<br />\n<img src=\"http://static.apple.nextmedia.com/images/e-paper/20170218/large/1487362043_bdad.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fe-paper%2F20170218%2Flarge%2F1487362043_bdad.jpg&h