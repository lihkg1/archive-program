assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"cddd31bb98c27eb4caa50aaedd4f666b6e2d9500","tid":1154703,"uid":116087,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-14T14:10:57.000Z","msg":"我都唔明點解咁都有人信<br />\n依加資訊咁發達<br />\n嘩買之前做下research 已經知條友信唔過<br />\n咁都仲比人呃真係可以考慮下番去刷下首抽"},{"pid":"cd3e973d227c3b942985e06ee4fac989149e3335","tid":1154703,"uid":232927,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-14T14:17:41.000Z","msg":"睇佢的金句，真係好似傳銷洗腦課程講野的人"},{"pid":"6ab6a3633638e0cd2939a474345a5278e0a4731a","tid":1154703,"uid":126329,"like":3,"dislike":0,"score":3,"quote":{"pid":"85e38509da08b719041fb877be0b36fe8e25382a","tid":1154703,"uid":129895,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-14T13:26:37.000Z","msg":"條傻西仲未比差佬拉咩<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-15T00:06:06.000Z","msg":"以家班所謂苦主就真係傻西<br />\n人地走晒法律罅 要你簽免責<br />\n沒成本用自己名昆水分大佣<br />\n真正做到佢所講既低風險高回報<br />\n<br />\n再睇下個班所謂既苦主 沒個敢除口罩 好似自己做左虧心事咁 怕比親友知自己咁撚蠢又咁貪?<br />\n<br />\n牛唔飲水唔撳得牛頭低 更何況一早已經大把人屌緊火昆人 顯然呢班人貪心自己選擇信火 就算今日唔係比火呃 第日都會中其他騙局<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4198c35c22cc6d458d9103a8fa16ab3ddcb54c94","tid":1154703,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-15T00:21:57.000Z","msg":"<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8bac44b5fff61bfabd6eb7d96b3f430c7f0235b3","tid":1154703,"uid":17738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-15T09:02:54.000Z","msg":"香討有人投訴FB，話火尿深利用FB搞騙局<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n<img src=\"https://na.cx/i/FnKXU3W.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFnKXU3W.png&h=f1a3b234&s={SIZE}\" />"},{"pid":"e231680f7e0bf57c7d4ea1d0e1ea03514d4