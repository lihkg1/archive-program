5%2Bb7%2FAbjRF3VpWtqcNNCzs9YdIyDBYU%3D&h=69ea6f95\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Fchina%2F20200610%2FIZ5QKCVTHPWINGOLK5IVMLQ36E%2F&h=4e60c296\" data-auto-link target=\"_blank\">https://hk.appledaily.com/china/20200610/IZ5QKCVTHPWINGOLK5IVMLQ36E/</a>"},"citedBy":0,"replyTime":"2020-06-11T01:07:29.000Z","msg":"等左好耐<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"6a25eac5e20d280b0bf1462d5b8bcdeeef46657a","tid":2059094,"uid":289978,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-11T01:09:30.000Z","msg":"有3000萬個共狗藍屍簽名係手都仲要拖到6月尾?<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"97bcae1868f7d6a20710b83f2cdbedbdd9d080b8","tid":2059094,"uid":345502,"like":1,"dislike":0,"score":1,"quote":{"pid":"a4627b5c6ad23a8c58f3b1b180bae74f4df1d688","tid":2059094,"uid":297045,"like":32,"dislike":0,"score":32,"citedBy":4,"replyTime":"2020-06-10T15:39:18.000Z","msg":"若果真係咁唔顧忌外國反應, 點解當初612要停逃犯條例? 個陣好多人都認為係因為G20先停<br />\n<br />\n不過 anyway 理佢得縮定唔縮, we must move on<br />\n而且收緊政策係大方向, 有無國安法都係一樣<br />\n反而希望佢加辣, 唔好比香港人負責檢控同拘捕, 最好由大陸直接負責."},"citedBy":0,"replyTime":"2020-06-11T01:13:05.000Z","msg":"舊年未有武漢肺炎, 冇全世界圍堵, 老美都未咬得咁緊, 侵果時想trade deal多過滅共.    當時中共仲可以慢慢玩."},{"pid":"0f563aee4838d32126803c22d944fa0d0e36beee","tid":2059094,"uid":147047,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-11T01:22:13.000Z","msg":"快啦，想屌雜種屎眼"},{"pid":"70d7966ba4d43a3d8d1d2481c23aa1a867415466","tid":2059094,"uid":49144,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-11T01:41:31.000Z","msg":"最好啦"},{"pid":"4d8a42142b9f2cf500aec83a38d63cda60b57aa8","tid":2059094,"uid":63885,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-06-11T01:43:42.000Z","msg":"咪撚跪呀維尼<br />\n講得出, 仲要得一票反對, 一定要通過呀"},{"pid":"52ec493d9e91d88aa0564e23f1337e6f5dabdafb","tid":2059094,"uid":43173,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"20