ike":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T14:19:11.000Z","msg":"民主黨會唔會撤回呢個聲明先<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"e15215c52e768a69f6592bfb60dc8427238a38dc","tid":1222713,"uid":109300,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-19T14:19:20.000Z","msg":"和理非非、勇武請聽小弟一言<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1243560\" data-auto-link target=\"_blank\">https://lih.kg/1243560</a>"},{"pid":"c697c062f7f7c5abc781852401dbad9de4d693e9","tid":1222713,"uid":280746,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-11T07:04:06.000Z","msg":"推"}]}