%2F23%2F080628_1fc74e2f5e9f185562f9e08db3a40443.png&h=fe61d7cf&s={SIZE}\" /><br />\n屌連個飽都有綠色蛋<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"3cfb6ca3b83c57b200cded189d8348537320a23f","tid":569591,"uid":7645,"like":9,"dislike":0,"score":9,"citedBy":2,"replyTime":"2018-02-23T00:08:08.000Z","msg":"煮得太熟<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n水煮蛋的蛋黃與蛋白接觸面呈現灰綠色，會不會影響食用安全？<br />\n雞蛋水煮去殼後，偶而會發現蛋黃和蛋白接觸面呈現灰綠色，這是因為蛋在加熱時，蛋白中蛋白質的含硫胺基酸生成硫化物（主要是H2S），與蛋黃的鐵（Fe）反應生成硫化亞鐵，這是正常現象，並不影響食蛋的安全。"},{"pid":"d2ad367b542375311007c21bfdf3ace55058ffc8","tid":569591,"uid":8048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-23T00:09:13.000Z","msg":"<span style=\"color: green;\">正常 當清腸胃囉</span><img src=\"/assets/faces/lny/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"2f9c44c9c8043b97cfce2d4248cb3d90990d5359","tid":569591,"uid":119026,"like":0,"dislike":3,"score":-3,"quote":{"pid":"3cfb6ca3b83c57b200cded189d8348537320a23f","tid":569591,"uid":7645,"like":9,"dislike":0,"score":9,"citedBy":2,"replyTime":"2018-02-23T00:08:08.000Z","msg":"煮得太熟<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n水煮蛋的蛋黃與蛋白接觸面呈現灰綠色，會不會影響食用安全？<br />\n雞蛋水煮去殼後，偶而會發現蛋黃和蛋白接觸面呈現灰綠色，這是因為蛋在加熱時，蛋白中蛋白質的含硫胺基酸生成硫化物（主要是H2S），與蛋黃的鐵（Fe）反應生成硫化亞鐵，這是正常現象，並不影響食蛋的安全。"},"citedBy":0,"replyTime":"2018-02-23T00:09:38.000Z","msg":"應該係擺得太耐<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"c56fb171dfd62ca679528029732ef7359db3d8de","tid":569591,"uid":97451,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-02-23T00:10:42.000Z","msg":"此回覆已被刪除"},{"pid":"54d8ee03b0a5e1ad911a8be3a0a128e3684ccc17","tid":569591,"uid":54424,"like":0,"dislike":5,"score":-5,"quote":{"pid":"3cfb6ca3b83c57b200cded189d8348537320a23f","tid":569591,"uid":7645,"like":9,"dislike":0,"score":9,"citedBy":2,"replyTime":"2018-02-23T00:08:08.000Z","msg":"煮得太熟<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n水煮蛋的蛋黃與蛋白接觸面呈現灰