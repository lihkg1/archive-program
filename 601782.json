"},{"pid":"dc535fcc71fffe050b50e150376bfd843e680f9d","tid":601782,"uid":141841,"like":0,"dislike":0,"score":0,"quote":{"pid":"fcc960057fd81dce595e9363ee38a446fed3ab27","tid":601782,"uid":21028,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-22T13:22:03.000Z","msg":"佢有案底仍可執法嗎<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-22T13:32:19.000Z","msg":"我都想知，<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"764995f84227cf7f247ea04a061d0ec331e88a40","tid":601782,"uid":37661,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-22T14:01:12.000Z","msg":"盧偉聰呼籲駕駛人士要以負責任的態度駕駛，因為一個疏忽足以影響另一家庭。"}]}