/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"cf372bcae399cf9d82610c6b8dd821e3483bbdb6","tid":1670730,"uid":293673,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-23T08:39:02.000Z","msg":"此回覆已被刪除"},{"pid":"c29af5d324325439a41880361e9e55e0f5293ce0","tid":1670730,"uid":1477,"like":0,"dislike":0,"score":0,"quote":{"pid":"f9a9edc9e85863dca00906062f54d34d3fb6aa8c","tid":1670730,"uid":212626,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-23T05:56:23.000Z","msg":"警方和「公眾集會及遊行上訴委員會」近日多次反對民間示威遊行申請，「長洲覆核王」郭卓堅及退休攝影師張德榮認為，此申請安排及制度有違《基本法》和《人權法》，早前向高等法院提出司法覆核。高院今（23日）頒下判辭，指結社和集會自由並非絕對，這些權利亦受維護公眾安全限制，判郭等敗訴。<br />\n<br />\n建議答辯人依次為警務處長盧偉聰和公眾集會及遊行上訴委員主席彭鍵基。<br />\n<br />\n申請方認為，現有遊行示威申請安排和制度違反《基本法》及《人權法》所保障港人的結社和集會自由。 <br />\n<br />\n<span style=\"color: red;\">法官周家明在判辭指出，《基本法》和《人權法》所賦予的結社和集會自由並非絕對，這些權利受法律規限，亦受維護公眾安全、保障其他人自由及利益等因素限制。<br />\n<br />\n判辭續指出，終審法院亦表示，集會遊行須事先通知的制度合憲，而警務處長基於公眾安全而決定是否反對集會遊行亦符合法律。法官認為，現有法定的集會遊行申請制度沒有違反《基本法》和《人權法》</span>。<br />\n<a href=\"https://news.mingpao.com/ins/港聞/article/20191023/s00001/1571804886102/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.mingpao.com%2Fins%2F%E6%B8%AF%E8%81%9E%2Farticle%2F20191023%2Fs00001%2F1571804886102%2F&d=6Qw6l1jLXmk45E1e9I%2BltgOzzNjRw9ZJ5YgnvwIkb18%3D&h=296b0ea9\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.mingpao.com%2Fins%2F%E6%B8%AF%E8%81%9E%2Farticle%2F20191023%2Fs00001%2F1571804886102%2F&h=605d3362\" target=\"_blank\">https://news.mingpao.com/ins/港聞/article/20191023/s00001/1571804886102/</a>"},"citedBy":0,"replyTime":"2019-10-23T08:39:54.000Z","msg":"[極度緊急]急急急，英國領事館外面急要人！！！<br />\n<a href=\"https://lih.kg/1670914\" data-auto-link target=\"_blank\">https://lih.kg/1670914</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"d622bf1aa7f467006afd84fcbc547f5e57e4d346","tid":1670730,"uid":16029,"like":0,"dislike":0,"score":0,"quote":{"pid":"e9988367ce6d3c77c2c59f0711d197bf0d6b2078","tid":1670730,"uid":37869,"like":0,"dislike":0,"score":0,"quote":{"pid":"