pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d8c2d34a2b25b42b4e1cf88711d697bbc03bea96","tid":2085254,"uid":4396,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T03:33:53.000Z","msg":"我重開再依個po 大家再幫手推<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"682d274d35570ffe8d519837c14624e726cf758c","tid":2085254,"uid":4396,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T03:34:46.000Z","msg":"「重開」「國安法前夕，所有人速入」美國戰線最強組織HKDC需要大家幫手！<br />\n<a href=\"https://lih.kg/2085652\" data-auto-link target=\"_blank\">https://lih.kg/2085652</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n我重開左依個po，大家幫我再推過<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"7b5b6eed0a3533ddd033c0dbc9d846dc6313b54f","tid":2085254,"uid":132859,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T12:56:27.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"53084814aa6114b659e3cccdcc0e2a21b4d4ebe5","tid":2085254,"uid":326037,"like":0,"dislike":0,"score":0,"quote":{"pid":"9e9ccb85a85794f55b661b16b6c3f53b0fc2a2fc","tid":2085254,"uid":4396,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-29T19:16:05.000Z","msg":"<span style=\"font-size: x-large;\"><span style=\"color: gold;\">我單刀直入，請大家馬上課金，HKDC需要更多資金去打美國戰線。</span></span><br />\n<br />\nHKDC可以直接同美國國會進行游說工作。未來更會有「<span style=\"color: green;\">黃雀行動2.0</span>」，幫所有手足提供救生艇，保存實力，其重要性不下於英國BNO平權。大家想美國出多兩錢肉緊幫香港就一定要幫手捐錢，幾多都得！<br />\n<br />\n<span style=\"font-size: x-large;\">幫手推上去同send去其他平台俾更多人知！！</span><br />\n<br />\n<span style=\"color: red;\">依條係籌款link:</span><br />\n<a href=\"https://gogetfunding.com/hkdc/?lang=zh自去年九月成立以來，HKDC全力促成下列議程\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgogetfunding.com%2Fhkdc%2F%3Flang%3Dzh%E8%87%AA%E5%8E%BB%E5%B9%B4%E4%B9%9D%E6%9C%88%E6%88%90%E7%AB%8B%E4%BB%A5%E4%BE%86%EF%BC%8CHKDC%E5%85%A8%E5%8A%9B%E4%BF%83%E6%88%90%E4%B8%8B%E5%88%97%E8%AD%B0%E7%A8%8B&d=BZN1wbl1lFElyj%2BXlEN3CCbpne3YAKjwmabJhOlqIzs%3D&h=33e23378\" data-auto-link target=\"_blank\">https://gogetfunding.com/hkdc/?lang=zh自去年九月成立以來，HKDC全力促成下列議程</a><br />\n<br />\n以下係HKDC過往戰績：<br />\n<img src=\"https://na.cx/i/QGQWtDq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQGQWtDq.jpg&h=c53931e3&s={SIZE}\" /><br />\n<br />\n1.協助通過《香港人權與民主法》與《保護香港法》。<br />\n2.堅持中國必須對侵蝕一國兩制及違反香港的高度自治負起責任, 促成國務院確認香港不再享有高度自治。<br />\n3.對迫害香港自治與人權的相關中國官員實施簽證禁令。<br />\n4.引薦14項香港相關法案，包含<span style=\"font-size: large;\">香港移民</span>及<span style=\"font-size: large;\">難民保護法</span>。<br />\n5.透過上百場聽證會、簡報、會議、媒體文宣，使香港成為美國國會最受兩黨關注的議題之一 。<br />\n6. 籌辦今年三月首場HKDC美港政策會議及遊說日。<br />\n<br />\n今次全數捐款將分配於：<br />\n1. <span style=\"color: gold;\">爭取美國儘快向香港人提供更強支援和保障 (40%)</span><br />\n-通過《香港空降法 》，《香港人自由與選擇法》，《香港高度自治法 》，與及建議及推動其他美國對香港的政策與法案<br />\n-加強對侵害香港自治的中國與香港官員和機構實施制裁。<br />\n-每年一次舉辦HKDC美港政策會議及遊說日，提升三倍參加人數從75到225人。<br />\n<br />\n2. <span style=\"color: gold;\">提升在美政治影響力（30%)</span><br />\n- 加強就香港事務發言，成為香港事務的權威。<br />\n-推動美國選民對香港的認知，就今年十一月大選進行「催票」活動。<br />\n-遊說更多國會議員為香港發聲。<br />\n-培訓額外10州或城市的在美香港人的草根組織。<br />\n-與有志抗衡中共威脅和人權迫害的組織進行合作。<br />\n<br />\n3. <span style=\"color: gold;\">拓展HKDC (30%)</span><br />\n-全職職員從1.5名增加至3名。<br />\n-租賃辦公空間。<br />\n-啟動華府獎學金計畫，資助美港相關議題和政策研究。<br />\n<br />\n全數捐款將用來資助HKDC，由執行總監朱牧民籌劃。<br />\n<br />\n<span style=\"color: green;\">黃雀行動2.0</span><br />\n<a href=\"https://hk.appledaily.com/local/20200627/WJJAAP4GIF5DUM6SM6RA6WJQF4/?utm_campaign=hkad_social_hk.nextmedia&amp;utm_medium=social&amp;utm_source=facebook&amp;utm_content=link_post\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200627%2FWJJAAP4GIF5DUM6SM6RA6WJQF4%2F%3Futm_campaign%3Dhkad_social_hk.nextmedia%26utm_medium%3Dsocial%26utm_source%3Dfacebook%26utm_content%3Dlink_post&d=BZN1wbl1lFElyj%2BXlEN3CCbpne3YAKjwmabJhOlqIzs%3D&h=ff8d36a8\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200627%2FWJJAAP4GIF5DUM6SM6RA6WJQF4%2F%3Futm_campaign%3Dhkad_social_hk.nextmedia%26utm_medium%3Dsocial%26utm_source%3Dfacebook%26utm_content%3Dlink_post&h=4cfa857c\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20200627/WJJAAP4GIF5DUM6SM6RA6WJQF4/?utm_campaign=hkad_social_hk.nextmedia&amp;utm_medium=social&amp;utm_source=facebook&amp;utm_content=link_post</a>"},"citedBy":0,"replyTime":"2020-06-30T13:01:40.000Z","msg":"<img src=\"https://na.cx/i/88YpJvb.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F88YpJvb.png&h=2ac96098&s={SIZE}\" />"}],"pinned":{"pid":"682d274d35570ffe8d519837c14624e726cf758c","tid":2085254,"uid":4396,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-30T03:34:46.000Z","msg":"「重開」「國安法前夕，所有人速入」美國戰線最強組織HKDC需要大家幫手！<br />\n<a href=\"https://lih.kg/2085652\" data-auto-link target=\"_blank\">https://lih.kg/2085652</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n我重開左依個po，大家幫我再推過<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"}}