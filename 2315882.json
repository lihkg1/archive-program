"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"455d220ca94c002745024ecea3c2ed9a0225ade6","tid":2315882,"uid":258948,"like":45,"dislike":2,"score":43,"citedBy":0,"replyTime":"2020-12-07T13:22:56.000Z","msg":"咩係大路妹？<br />\n大路任人上既妹啊？"},{"pid":"ae43e1a434f0808c0e74d7b892421e256a0e2317","tid":2315882,"uid":49004,"like":6,"dislike":34,"score":-28,"citedBy":1,"replyTime":"2020-12-07T13:29:53.000Z","msg":"馬賽 對 波圖<br />\n馬賽 對波 圖<br />\n馬賽 對 波 圖"},{"pid":"3f2860a9df241cf24cfd03d880858d74b81f72db","tid":2315882,"uid":196924,"like":432,"dislike":2,"score":430,"citedBy":3,"replyTime":"2020-12-07T13:32:10.000Z","msg":"馬賽<span class=\"red\">1987年</span>7月31日出生於<span class=\"red\">重慶市</span>，十歲與家人遷至<span class=\"red\">深圳</span>。<br />\n<span class=\"red\">2006年</span>，她從深圳實驗學校（中學部）畢業後，到香港修讀香港浸會大學傳理學院電影電視系。<br />\n<span class=\"red\">2016年</span>，正式加入魏坤成立《龐貝工作室》<span class=\"red\">北京</span>分行站。<br />\n<br />\n2006 - 1987 = 19<br />\n2016 - 2006 = 10<br />\n2020 - 2016 = 4<br />\n<br />\n喺支那出世，而家喺支那。<br />\n33歲有23年係喺支那。<br />\n<br />\n咁撚樣都唔叫大陸妹嘅話...<br />\n<br />\n唯有叫支那雞<img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" />"},{"pid":"57eb8ee9ae3cd19853b2c6ca75e39287a9d445ce","tid":2315882,"uid":37413,"like":81,"dislike":4,"score":77,"citedBy":0,"replyTime":"2020-12-07T13:37:07.000Z","msg":"<img src=\"https://na.cx/i/1znwZfj.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1znwZfj.png&h=484fa91c&s={SIZE}\" />"},{"pid":"1f5aed48e02ee2b52697629a6168c02b259872aa","tid":2315882,"uid":127575,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2020-12-07T13:38:46.000Z","msg":"由攣變直<img src=\"/assets/faces/pig/dance3.gif\" class=\"hkgmoji\" />"},{"pid":"60b22e9ec8e2eed26f10c3bb0b51cd004dae6e22","tid":2315882,"uid":254165,"like":59,"dislike":1,"score":58,"citedBy":0,"replyTime":"2020-12-07T13:39:51.000Z","msg":"俾人叫大陸妹咁撚咁撚自卑<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" cl