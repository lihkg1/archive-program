g\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F15%2F204051_e0beb56d3af458b9df80ef5f6c276fbd.jpg&h=c190675f&s={SIZE}\" /><br />\n<br />\n<br />\n<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"f51c9a6b3a2e6d9d3fcac86ab9cb5194187a508f","tid":630221,"uid":75050,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-04-15T12:41:51.000Z","msg":"仲有「好撚好笑」<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/04/15/204137_aaf3a95e5dd55bf59cc8c22cf9c2eacf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F04%2F15%2F204137_aaf3a95e5dd55bf59cc8c22cf9c2eacf.jpg&h=63f40454&s={SIZE}\" />"},{"pid":"91e70ce72105ad77e4a7bcb4835a148857fedaea","tid":630221,"uid":1049,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-04-15T12:45:10.000Z","msg":"淨係記得結局係炒撚左車仲揸到車之後先死<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f18599d691656bb26f341174aa961683554bd802","tid":630221,"uid":38456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-15T12:46:50.000Z","msg":"有"},{"pid":"ccd9a6fd947bfb6bb0ce718eff68d25280216353","tid":630221,"uid":38456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-15T12:47:11.000Z","msg":"保護要人組"},{"pid":"c44b8a211f362540166f0ebe91fe88a50ec5c361","tid":630221,"uid":93900,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-15T12:48:59.000Z","msg":"果套鍾+欣其實做得幾好"},{"pid":"02b659c8baad6795b45324cb7720daa1134cf900","tid":630221,"uid":81234,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-15T17:35:05.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"99e9212b2fb100928d1b4b9d36cec78d4edb1e67","tid":630221,"uid":2732