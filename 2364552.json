,"tid":2364552,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"61ff3677e75fce618b582ec7be7fc12d25ba2061","tid":2364552,"uid":21545,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2021-01-13T05:43:25.000Z","msg":"冇事=有事"},"citedBy":0,"replyTime":"2021-01-13T07:07:17.000Z","msg":"<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"142849f4134cba552ebfc34e3ba38871bdc95a82","tid":2364552,"uid":224066,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-01-13T07:10:13.000Z","msg":"<img src=\"https://na.cx/i/ZMtQXx2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZMtQXx2.jpg&h=e20f1f15&s={SIZE}\" />"}]}