"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" />"},{"pid":"610f8ad1133cf2e387396b11b0705929fd285749","tid":34490,"uid":48796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T16:25:33.000Z","msg":"學校點知你用手機影?"},{"pid":"39b22a4dbf7375ffd56a00016c45597e63e73c1e","tid":34490,"uid":4782,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T17:26:41.000Z","msg":"<blockquote>學校點知你用手機影?</blockquote><br />\n<br />\n唔係咁易架師傅 <br />\n而且一年有幾次 <br />\n好難次次都偷雞成功"},{"pid":"b8726aaa2851184efc28551b9f3b8ba743ed01f0","tid":34490,"uid":48796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T18:10:11.000Z","msg":"<blockquote><blockquote>學校點知你用手機影?</blockquote><br />\n<br />\n唔係咁易架師傅 <br />\n而且一年有幾次 <br />\n好難次次都偷雞成功</blockquote><br />\n問緊你 學校點知你用手機影? <br />\n老師次次檢查張JPEG檔案資料?<br />\n而家手機靚過傻瓜機, 你話用傻瓜機佢吹你唔脹 (當然唔好見到手機個影)<br />\n<br />\n重有你哋家長要俾壓力校方, 唔俾手機影, 原因係咩? 而家家長批準得唔得? 屋企冇相機, 校方係咪有得借相機? 有問題再搵家教會, 學校驚家教會"},{"pid":"06d0d1a0b8f81e988c3a4cfbc7a647d84e8cbc81","tid":34490,"uid":4782,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-11T18:55:15.000Z","msg":"<blockquote><blockquote><blockquote>學校點知你用手機影?</blockquote><br />\n<br />\n唔係咁易架師傅 <br />\n而且一年有幾次 <br />\n好難次次都偷雞成功</blockquote><br />\n問緊你 學校點知你用手機影? <br />\n老師次次檢查張JPEG檔案資料?<br />\n而家手機靚過傻瓜機, 你話用傻瓜機佢吹你唔脹 (當然唔好見到手機個影)<br />\n<br />\n重有你哋家長要俾壓力校方, 唔俾手機影, 原因係咩? 而家家長批準得唔得? 屋企冇相機, 校方係咪有得借相機? 有問題再搵家教會, 學校驚家教會</blockquote><br />\n<br />\n我意思就係話唔係咁易用手機影到 <br />\n後面大半同意<br />\n但校方唔perfer要借比你 <br />\n巴打我上面都有話之後會寫信問喎<br />\n<br />\n利申：其實今日我先知有呢件事 所以先上黎呻下"}]}