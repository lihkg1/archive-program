faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"4510f999ea51fea1064429281ba60f78189720d9","tid":1908702,"uid":7439,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T13:47:04.000Z","msg":"一名66歲新巴車長昨晚在深水涉停燈位期間，被一名突然擅自打開車門登車的中年漢揮拳打傷右眼，送院治理。<br />\n<br />\n警方昨晚11時25分接獲事主報案，指當時駕駛巴士到通州街與東京街西交界，在交通燈前停下，被該名突然登車的男子揮拳打傷右眼，對方之後逃去。據悉，施襲的中年漢擅自從車廂外，按動乘客上車車門開關掣打開車門。<br />\n<br />\n警員接報到場，經初步調查，案件列襲擊致造成實際身體傷害，交由深水埗警區刑事調查隊第七隊跟進，暫未有人被捕。<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"316cf20c7e61fd3bab5816f61499a560512f7567","tid":1908702,"uid":67225,"like":0,"dislike":0,"score":0,"quote":{"pid":"4ded179e572aabbd108957e5ffad5c97972205cf","tid":1908702,"uid":44285,"like":1,"dislike":1,"score":0,"quote":{"pid":"3d9f86fe79e5dcded23f0a6737195f1dddb081ca","tid":1908702,"uid":52571,"like":1,"dislike":1,"score":0,"citedBy":2,"replyTime":"2020-03-03T12:41:49.000Z","msg":"好能心你結埋婚就成熟啲啦"},"citedBy":1,"replyTime":"2020-03-03T12:42:31.000Z","msg":"邊夠你成熟<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-03T13:50:19.000Z","msg":"我都想佢成熟d"},{"pid":"2be31968246ce52346bc0364a9000fbd036131c8","tid":1908702,"uid":8968,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T13:50:48.000Z","msg":"軍隊來了"},{"pid":"a04dfcca8d793c6b1705200af70a39bb5caa6098","tid":1908702,"uid":127454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T17:09:08.000Z","msg":"<blockquote>好能心你結埋<span style=\"color: red;\">紮</span>就成熟啲啦</blockquote>"}]}