rc=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"091510fca47e010bc36366482fe56d0e5da39312","tid":736804,"uid":19527,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-07-10T15:28:51.000Z","msg":"英國鄧文迪"},{"pid":"9a77e4e1581f242e34d2cff2caa859c7b0dc6de7","tid":736804,"uid":153811,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-07-10T15:31:00.000Z","msg":"咪當鬼佬係傻，等你班中國人30年，今年起開始收網，相信以後有班以為攞左外國國藉就唔可以被cancel的共碟一個個被遣返。<br />\n<br />\n今年年尾我諗最豬個班中國人同港豬都應該知道今生咩事。"},{"pid":"7bff2e1fe898a5d78252666d7cd3c62927314b93","tid":736804,"uid":8410,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-10T15:36:12.000Z","msg":"間諜在身旁"}]}