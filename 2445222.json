/faces/mouse/potion.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-16T03:49:49.000Z","msg":"屈屈毛出現鳥"},"citedBy":0,"replyTime":"2021-03-16T04:04:06.000Z","msg":"&ldquo;唔岩聽既就5毛&rdquo;，typical 屈屈毛"},{"pid":"3c1b4f8a6459220e2c30bc42cac64692759b3fd5","tid":2445222,"uid":295459,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-03-16T04:04:41.000Z","msg":"good po<br />\n五毛撚就係鐘意被代表<br />\n成撚日想整個on9稻草人出黎代表其他人<br />\n食撚屎啦支那賤種<br />\n<img src=\"/assets/faces/mouse/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"0de231f5548d99dee15f5b4bf179f4d985b10aed","tid":2445222,"uid":273218,"like":1,"dislike":0,"score":1,"quote":{"pid":"8f98bfc46b294e3ab77ac56f91230fba6eed324b","tid":2445222,"uid":38177,"like":4,"dislike":1,"score":3,"citedBy":1,"replyTime":"2021-03-14T11:34:04.000Z","msg":"推返上去"},"citedBy":0,"replyTime":"2021-03-16T04:05:57.000Z","msg":"<img src=\"https://na.cx/i/yS6PzKX.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyS6PzKX.jpg&h=1d028d5a&s={SIZE}\" />"}],"pinned":{"pid":"651e6b2f369bcb5618353e572103ce43c741f9f4","tid":2445222,"uid":226955,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2021-03-14T16:24:08.000Z","msg":"共匪就係想佢統治下嘅社會道德敗壞，人人互不信任，自自然然就唔會團結得起嚟反抗極權，所以共匪會致力於敗壞原來社會道德，例子有毀滅傳統文化入面有關道德嘅觀念，扭曲教育同媒體，以考試功名同茶餘飯後娛樂全方位日以繼夜咁洗你腦，令你變得自私，除咗政府之外對其他人表現得猜疑，而導人為善嘅宗教亦好自然受到波及，原有教善被扭曲成為極權思想服務，呢點支那大把例子唔洗再點提，以<span class=\"red\">叢林法則嘅觀念植入每一個人心底裡</span>，人人自私自利，正如今日嘅支那社會，篤灰文化盛行，街上見人有難唔會有人幫手，道德敗壞至此，政權就穩如泰山。<span class=\"red\">而五毛就跟住呢個指令去為極權散佈呢種思想，逐步逐步敗壞成個社會嘅道德同對未來嘅希望。</span><br />\n<br />\n<span class=\"gold\">Anyway 大家要學識喺充滿負能量嘅氣氛之下，仍然保持當初嘅信念，控制到自己一直努力嘅目標方向，極權就係要成個社會心灰意冷，最好就係個個「覺得做乜都冇用啦」呢種思想深入民心，自自然然道德觀念崩潰，民間團結唔到，極權政府就可以不費成本而高枕無憂。</span><br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n以下係理論層面去解釋我上面嘅說話：（摘錄自高學歷巴打post）<br />\n<br />\n1970年，蘇聯KGB特工Yuri Bezmenov叛變（無中譯，Google譯做 尤里&middot;貝茲諾夫），投靠美國，並公開蘇聯情報部門顛覆敵對國家社會嘅方法。由意志崩壞（demoralisation）開始，<span class=\"x-large\"><span class=\"red\"><strong>令到整個社會感到無助，唔團結，冷感，撕裂，以致崩潰，不戰而敗。</strong></span></span>呢套理論有學名，叫「顛覆」Subversion，而達到顛覆嘅行爲，就叫做 active measures / активные мероприятия。<br />\n<br />\n2019年，中華人民共和國依舊行使同一套理論，務求不需派兵嘅情況之下，摧毀香港。<br />\n<br />\nSubversion有四個步驟：demoralisation破壞意志+道德，destabilisation社會動盪，crisis災難點，normalisation正常化。<br />\n<br />\n以下係英文原版，RedDragon1會員詳盡中文譯本<br />\n<br />\n<img src=\"https://na.cx/i/mv5bmV1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fmv5bmV1.png&h=e1116adf&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/yM38o9n.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyM38o9n.png&h=00bad446&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/EvWRmV3.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEvWRmV3.png&h=b10ab2c7&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/CMfZvPo.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCMfZvPo.png&h=32ead5cf&s={SIZE}\" /><br />\n<br />\n個圖最後兩個顛覆步驟冇講清楚：<br />\n<br />\n「Crisis災難點」係指令到社會運作嘅機器失效，即係銀行停止發票，立法會停止會議，法院不能夠再審判。同時間，另類政府組織會冒起，如人民法院。<br />\n<br />\n「Crisis災難點」未直接入「Normalisation正常化」之前有可能會走兩條路：國際介入（多國戰爭），or內戰。但係如果冇呢兩樣嘢發生嘅話，就會直接入最後一步：<br />\n<br />\n「Normalisation正常化」，係指「社會動盪被入侵者完全制止」，蘇聯嘅例子係俄羅斯坦克車入城，將原本親蘇聯嘅內奸、政客殺哂（因爲已經冇利用價值），由外來嘅俄羅斯人清洗一切反抗聲音，「正常化」個動盪。"}}