3:41.000Z","msg":"Push"},{"pid":"926b97684528c957e3d7be02d91d3f7f3f9d50b6","tid":1741470,"uid":232766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T11:14:33.000Z","msg":"Push"},{"pid":"d609dc30c4a070b3d1fecdfde461692e4cfe2864","tid":1741470,"uid":19252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T11:15:02.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"cf9d2c4e325930b1c22c0ec234c178fc4ea03fd6","tid":1741470,"uid":232766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T11:17:49.000Z","msg":"Push"},{"pid":"7083232ccfcee873c8b7d91c2edfa72919bd2643","tid":1741470,"uid":232766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T11:19:59.000Z","msg":"Push"},{"pid":"c12ebc18371ed02a17cb15812fc84e2ffb6130a3","tid":1741470,"uid":232766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T11:22:30.000Z","msg":"Push"},{"pid":"1b683c50a4b710062bfa9edcfc6a3471fbbfbc38","tid":1741470,"uid":232766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T11:23:41.000Z","msg":"Push"},{"pid":"ccc464069d28ca48e160b30d7fc1d483f57f8ffa","tid":1741470,"uid":232766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-20T11:30:27.000Z","msg":"Push"},{"pid":"76ee7ed6b139352ecf452fe8056ae22144f65fff","tid":1741470,"uid":289259,"like":0,"dislike":0,"score":0,"quote":{"pid":"af54c9d329993c24181a609414290ab80b52c5f0","tid":1741470,"uid":232766,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-20T10:48:43.000Z","msg":"首先，請參考大雞樂巴呢個 post：<br />\n<br />\n人權法通過 我老母嚇到del哂佢fb啲撐警post！<br />\n<a href=\"https://lih.kg/1741349\" data-auto-link target=\"_blank\">https://lih.kg/1741349</a><br />\n<br />\n有好多藍絲其實只係自私自利、西瓜靠大邊、恃強凌弱嘅勝利球迷。<br />\n<br />\n如果佢哋知道支持政府／警察其實無咩著數，甚至有機會蝕底，佢哋一定有所顧忌。<br />\n<br />\n當然，佢哋可能唔怕制裁（因為連去美國旅行嘅能力都無），但人就係咁，知道其實政府唔係惡哂，咁佢哋就唔會咁大聲。加上佢哋當中實有人因為擔心受到影響而噤聲，咁此消彼長，對藍營嘅打擊可大可小。<br />\n<br />\n文宣組可唔可以準備大量長輩/藍絲圖，叫人：<br />\n<br />\n1. 唔好再喺公開場合撐政府/警暴<br />\n2. delete 相關網上 posts 同留言<br />\n3. 退出相關 WhatsApp 群組<br />\n4. 唔好再幫建制政黨拉票派傳單，怕俾人影到<br />\n5.（仲有無其他？請大家諗諗）<br />\n<br />\n文宣最好扮到係藍絲整嘅，叫大家唔好中邪惡美帝嘅奸計咁，再經 AirDrop 傳出去。佢哋必定有人怕影響到自己利益、仔女移民、出外旅行辦簽證（包括美國及其盟國）而有所收歛。<br />\n<br />\n係要做就快，襯依家單新聞有少少 noise.<br />\n<br />\n唔知有無用。請問大家點睇？<br />\n如果覺得有用麻煩幫推。"},"citedBy":0,"replyTime":"2019-11-20T11:32:10.000Z","msg":"各位手足，關於送林奠去大灣區的partition，尋日激增20000幾人(差不多簽署人數的10%)，證明大家都好希望將佢舉家永遠封印晌大灣區！<br />\n<br />\n嘅然係咁就唔好停了，跟據早前民意調查有7成人唔妥佢嘅，咁我地嘅目標係咪應該set晌490萬個簽名呢？<br />\n<br />\n小弟英文唔好，如果可以的話，亦希望各手足可以幫手將佢推上國際！<br />\n<br />\n唔使俾錢架，簽完再share就唔使比錢㗎啦。<span style=\"color: red;\">最新消息：今朝22萬9千了！目標：490萬</span><br />\n<br />\n<a href=\"https://www.change.org/p/uk-home-office-uk-home-office-should-revoke-carrie-lam-s-family-citizenship?cs_tk=AtIXNHLitQ7NOzo40F0AAXicyyvNyQEABF8BvKv03Ej5HuubaSSmIizKZKU%3D&amp;utm_campaign=514ad83a9aaf489a936c80aa7705b65d&amp;utm_medium=email&amp;utm_source=recruit_sign_digest&amp;utm_term=cs\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.change.org%2Fp%2Fuk-home-office-uk-home-office-should-revoke-carrie-lam-s-family-citizenship%3Fcs_tk%3DAtIXNHLitQ7NOzo40F0AAXicyyvNyQEABF8BvKv03Ej5HuubaSSmIizKZKU%253D%26utm_campaign%3D514ad83a9aaf489a936c80aa7705b65d%26utm_medium%3Demail%26utm_source%3Drecruit_sign_digest%26utm_term%3Dcs&d=Cf%2BepIHKvYs8nB0OclbNLC2wsmw0HNSHoQ%2FRl4ZEJbA%3D&h=b84f9b17\" data-auto-link target=\"_blank\">https://www.change.org/p/uk-home-office-uk-home-office-should-revoke-carrie-lam-s-family-citizenship?cs_tk=AtIXNHLitQ7NOzo40F0AAXicyyvNyQEABF8BvKv03Ej5HuubaSSmIizKZKU%3D&amp;utm_campaign=514ad83a9aaf489a936c80aa7705b65d&amp;utm_medium=email&amp;utm_source=recruit_sign_digest&amp;utm_term=cs</a><br />\n<br />\n<img src=\"https://na.cx/i/Hs8wPcW.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHs8wPcW.jpg&h=66458b29&s={SIZE}\" />"},{"pid":"6292c871e21f01bfa15df801177bbf6fb1435ddd","tid":1741470,"uid":232766,"like":0,"dislike":0,"score":0,"cit