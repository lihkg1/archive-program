5.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/15/223448_3fb2db6cccf4a23383383394b28b2b31.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F15%2F223448_3fb2db6cccf4a23383383394b28b2b31.jpg&h=9d156377&s={SIZE}\" />"},{"pid":"ffe7d6ea522fbe02bba5d2e86087e0a7c76b7460","tid":781074,"uid":19454,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-15T15:56:46.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/15/223327_72acded3acd45e4c8b6ed680854b8ab1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F15%2F223327_72acded3acd45e4c8b6ed680854b8ab1.jpg&h=44604e0f&s={SIZE}\" />"},{"pid":"1a72ea825e0b4ac6e1689040f658ed2474c50871","tid":781074,"uid":62257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-15T16:30:03.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"6dafcfbe7c3d187c2993f36bf5161e87eb96c0f5","tid":781074,"uid":95497,"like":1,"dislike":0,"score":1,"quote":{"pid":"849440e00526612a91e087180a734bf7bc11d826","tid":781074,"uid":144626,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-15T15:24:28.000Z","msg":"會唔會又3年困難時期<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-15T16:34:58.000Z","msg":"全國一齊報假數 大躍進ver.2018<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a600d2b64566ee3caa72fb875ade607751af37ca","tid":781074,"uid":62257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-15T18:12:57.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"442997d9eda12c46bfb0472dd9c238dc3367f2bf","tid":781074,"uid":25424,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-08-15T18:37:48.000Z","msg":"本來糧倉都仲有一兩成係食得既<br />\n又唔撚理自己咩料，屎忽痕玩檢查<br />\n依家就一把火燒晒，屎都無得食<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"05cf1111917195bdfb2a858079fdd2cfacc6be5b","tid":781074,"uid":198400,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-15T19:17:00.000Z","msg":"天滅支共<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}