{"tid":1278600,"cid":5,"subCid":0,"title":"不厭其煩都要講，發夢既野留返係夢入面，要認清現實","createTime":"2019-07-02T13:16:41.000Z","updateTime":"2019-07-03T01:15:09.000Z","uid":119729,"like":17,"dislike":0,"uniUserReply":2,"replies":[{"pid":"2c39de05c5cd160ee2d98fc406a429017fb2b4d7","tid":1278600,"uid":119729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T13:16:41.000Z","msg":"推畀咁多位學生睇<br />\n<br />\n<br />\n就算夢境入面個立法會幾真實都好，<br />\n夢境始終都係夢境，唔好諗住去差館自首。<br />\n<br />\n發夢整污糟左立法會都係，<br />\n千其唔好打算返去立法會清潔，<br />\n認清楚咩係現實，咩係夢境。<br />\n<br />\n更加唔好係公眾地方講自己既夢境，<br />\n要講就留返下次發夢，我地一齊再講。<br />\n<br />\n答位手足，我地下次夢中再見"},{"pid":"b9cb59214f44e099ec9e2f1c122dc68e2ff45d93","tid":1278600,"uid":253127,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T13:17:16.000Z","msg":"推"},{"pid":"13ea7cc94651c339681350f3bfa8d06a43780dc1","tid":1278600,"uid":119729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T13:24:53.000Z","msg":"推"},{"pid":"a9897573e9abbe967d801f03a5ed82f0ee6db69d","tid":1278600,"uid":119729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T13:30:58.000Z","msg":"推"},{"pid":"afc324a99457e08ffc75408d19715285792c07c9","tid":1278600,"uid":119729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T13:37:15.000Z","msg":"推"},{"pid":"8757fc59f4f4e940053efb7e42a1580ca7e55f3d","tid":1278600,"uid":119729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T14:25:20.000Z","msg":"推"},{"pid":"f1419fce3202c7cd09cc231cb1ab4bcd6bb6156f","tid":1278600,"uid":119729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T14:51:49.000Z","msg":"Push"},{"pid":"e583b11091395915857746034e75f647f1095048","tid":1278600,"uid":119729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T01:05:03.000Z","msg":"Push"},{"pid":"3a42e2a021aadc82aa290fe729e18042071f7ba3","tid":1278600,"uid":119729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T01:15:09.000Z","msg":"推"}]}