=\"hkgmoji\" />"},{"pid":"ffc5e1b980fa432e395a308623d77dc806d1576a","tid":2363092,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-12T03:39:52.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"3c3cb6a84e438eee476bbc3641689ac77b2cee15","tid":2363092,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-12T03:40:34.000Z","msg":"推"},{"pid":"51cf2fa6ac9436ee322048ff295b5099dba07204","tid":2363092,"uid":286685,"like":2,"dislike":1,"score":1,"quote":{"pid":"31a65be14f400e11d5dc1267552e88659b4dd4ad","tid":2363092,"uid":8014,"like":4,"dislike":5,"score":-1,"quote":{"pid":"4e7c722769242d17b187bc805580030014716b6c","tid":2363092,"uid":1734,"like":3,"dislike":18,"score":-15,"citedBy":1,"replyTime":"2021-01-12T03:17:46.000Z","msg":"黄官 半年真係算少 手足好彩"},"citedBy":4,"replyTime":"2021-01-12T03:19:34.000Z","msg":"好你老母咩<br />\n<br />\n案發只因被告向商場中庭投擲紙張<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n拋張紙比狗打仲坐半年叫好彩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-12T03:49:19.000Z","msg":"會員編號：#8014 <br />\n會員註冊日期：2016/11/25 <br />\n入 LIST 原因：對去信要求鄧炳強對推跌女童一事道歉的商人周小龍稱「做多咗」、抹黑黃絲市集。  <br />\n<a href=\"https://bit.ly/lihkg_on9_list\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2Flihkg_on9_list&d=REZNLD6XKc%2F2J9Njm9EJuXr2%2BPVmRcyv9paqmPGdWjc%3D&h=a63ef5f9\" target=\"_blank\">https://bit.ly/lihkg_on9_list</a>  <br />\n<blockquote><br />\n<img src=\"https://filedn.eu/l9Hq1YKLkJ4m0VSXcdcfUaJ/LIHKG_on99/8014/8014.1_.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffiledn.eu%2Fl9Hq1YKLkJ4m0VSXcdcfUaJ%2FLIHKG_on99%2F8014%2F8014.1_.png&h=2048f971&s={SIZE}\" /> <br />\n<img src=\"https://filedn.eu/l9Hq1YKLkJ4m0VSXcdcfUaJ/LIHKG_on99/8014/8014.2_.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffiledn.eu%2Fl9Hq1YKLkJ4m0VSXcdcfUaJ%2FLIHKG_on99%2F8014%2F8014.2_.png&h=19c5c5b4&s={SIZE}\" /> <br />\n<img src=\"https://filedn.eu/l9Hq1YKLkJ4m0VSXcdcfUaJ/LIHKG_on99/8014/8014.3_.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Ffiledn.eu%2Fl9Hq1YKLkJ4m0VSXcdcfUaJ%2FLIHKG_on99%2F8014%2F8014.3_.png&h=0ebed1f7&s={SIZE}\" /><br />\n</blockquote> <br />\n <img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> <br />\n <em><span class=\"small\">上述資料更新日期：2020/12/24 P.S. 呢個唔係五毛 LIST，係戇鳩 LIST，可以畀大家認識到比較特別嘅會員 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />。</span></em>"},{"pid":"d9ade06a9d279872a6556e81310fb5a0bd71052b","tid":2363092,"uid":79563,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-01-12T04:16:42.000Z","msg":"<blockquote>被告用力把警員A揈開，甚至把警告A撞到牆上，需要警員B及C協助。被告的行為令警員A前額受傷，警員B左手無名指折斷，導致他需要夾附夾板以及警員C姆指腫脹</blockquote><br />\n<br />\n勁<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" />"},{"pid":"b7f7ada72122c92654ac41990103914fa90760f5","tid":2363092,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-12T04:38:09.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"94c3705a41550822229e96176545dc02fdde011b","tid":2363092,"uid":112581,"like":1,"dislike":0,"score":1,"quote":{"pid":"fac77459e5190f6395513c419920cb4e06710087","tid":2363092,"uid":183844,"like":8,"dislike":0,"score":8,"citedBy":2,"replyTime":"2021-01-12T03:18:52.000Z","msg":"無正視過警暴問題<br />\n俾人打反抗理所當然<br />\n痛會掙扎亦係人之常情"},"citedBy":0,"replyTime":"2021-01-12T04:53:18.000Z","msg":"制度寫明狗唔查DOJ唔告咪冇警暴問題<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" /><br />\n相信制度相信法治"}]}