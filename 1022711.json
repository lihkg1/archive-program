13:54.000Z","msg":"舒服地逗住後面墜後型中場"},{"pid":"0aa6415d2195d73744bb06be5d709d4c072b2acf","tid":1022711,"uid":66436,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-16T00:11:00.000Z","msg":"我噴精了"},{"pid":"b0713fab21c093e4ccbd500d43500cbe6f88c34f","tid":1022711,"uid":65401,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-16T01:14:13.000Z","msg":"𢭃住足球"},{"pid":"bd1305f5f07edc86fa1accb1b1a44d1c094a13b6","tid":1022711,"uid":3028,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-16T01:33:46.000Z","msg":"以前里昂個罰球王<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"ff6312d899d6a5b959b0f6b6f13bb32f17886198","tid":1022711,"uid":233091,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-16T01:41:26.000Z","msg":"豆腐中場"},{"pid":"82d09ddd0096b0add1a31c04bdd99437f3ee4263","tid":1022711,"uid":209679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-16T04:29:42.000Z","msg":"大家有無踢過11人比賽? 有無聽過&quot;豆&quot;住中場<br />\n我就同過一個中場中踼過, 一樣無身形無高度, 佢唔係好扭得, 又唔係最快<br />\n但基本功好札扎實, 控波, 包位, 長短傳, 入波, 樣樣有, 而佢可以係成場零失誤, 你唔洗幫佢, 但佢會衝過黎幫你<br />\n我自問都踢過好多比賽, 但如果對手強, 難免會怯場緊張<br />\n但有佢在場, 你會好放心, 可以發揮返自己水準, 自然成隊波生哂"}]}