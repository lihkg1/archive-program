":"c8c76749a8d78967ff4ae6569835c7a91988d0f0","tid":224684,"uid":38523,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T00:06:21.000Z","msg":"支那<br />\n所以先出到咁多支那五毛狗"},{"pid":"ee7574c6278e4ef03edbe5d3642b0405d129301e","tid":224684,"uid":10757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T00:06:53.000Z","msg":"澳門"},{"pid":"e36779ac3ca525fb491f2346ec68b3504560bf05","tid":224684,"uid":5607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T00:08:07.000Z","msg":"一定係台灣"},{"pid":"412b0003caf1f31b29ae177a1e37226163c2bcae","tid":224684,"uid":52591,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T00:31:10.000Z","msg":"澳&lt;台&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;港&lt;中"},{"pid":"052ec46d5471c52d0e3e30f6941718a10a2670e7","tid":224684,"uid":49392,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T00:40:36.000Z","msg":"一定係香港<br />\n所以千祈大陸人唔好黎香港讀書"},{"pid":"8985e3214ad967f3d64e0738eef68498ef43d778","tid":224684,"uid":2054,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-05-02T00:49:11.000Z","msg":"<img src=\"https://na.cx/i/9oVyDy.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F9oVyDy.jpg&h=1ba7dee1&s={SIZE}\" />"},{"pid":"f1e136c9950cf8451bffdd561c803578492ec078","tid":224684,"uid":50620,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T01:10:14.000Z","msg":"大陸6年都要學政治<br />\n唔怪得洗腦效果咁好<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n香港最好處係揀科彈性同由細到大都學英文，以前既AL難度都係國際級難度"},{"pid":"d7532b1301fc7ccda3bdccb24e46c51ee893b910","tid":224684,"uid":22858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T01:12:47.000Z","msg":"<blockquote>大陸6年都要學政治<br />\n唔怪得洗腦效果咁好<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n香港最好處係揀科彈性同由細到大都學英文，以前既AL難度都係國際級難度</blockquote><br />\n政治仲要係只有中共史觀 <img src=\"/assets/faces/big/369.gif\" class=\"hkgmoji\" />"},{"pid":"ab74dddfab6a1685eabaebd9fbc54a61c8d990eb","tid":224684,"uid":76637,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T01:13:02.000Z","msg":"<blockquote>一定係香港<br />\n所以千祈大陸人唔好黎香港讀書</blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c7a43385334c0589e21f58a2d121687d4e206485","tid":224684,"uid":46527,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T01:13:39.000Z","msg":"以為澳門中學教派牌"},{"pid":"f5f652c225ba4227092d0feeea9335b9a21bfb19","tid":224684,"uid":100680,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T01:28:55.000Z","msg":"相信大家一定好奇大陸ge政治課係學d咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n以下係大陸高中要讀的5本必修政治pdf<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 要注意係殘體字<br />\n<br />\n<br />\n<br />\n<a href=\"http://www.kebenzhan.com/renjiaoban/gaoyi/sixiangzhengzhi_shangce/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.kebenzhan.com%2Frenjiaoban%2Fgaoyi%2Fsixiangzhengzhi_shangce%2F&d=6FpmejEDNbHOA1ae24haowhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=8d2197c3\" target=\"_blank\">http://www.kebenzhan.com/renjiaoban/gaoyi/sixiangzhengzhi_shangce/</a><br />\n<a href=\"http://www.kebenzhan.com/renjiaoban/gaoyi/sixiangzhengzhi_xiace/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.kebenzhan.com%2Frenjiaoban%2Fgaoyi%2Fsixiangzhengzhi_xiace%2F&d=6FpmejEDNbHOA1ae24haowhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=3085ec29\" target=\"_blank\">http://www.kebenzhan.com/renjiaoban/gaoyi/sixiangzhengzhi_xiace/</a><br />\n<a href=\"http://www.kebenzhan.com/renjiaoban/gaoer/sixiangzhengzhi_shangce/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.kebenzhan.com%2Frenjiaoban%2Fgaoer%2Fsixiangzhengzhi_shangce%2F&d=6FpmejEDNbHOA1ae24haowhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=8af3fc88\" target=\"_blank\">http://www.kebenzhan.com/renjiaoban/gaoer/sixiangzhengzhi_shangce/</a><br />\n<a href=\"http://www.kebenzhan.com/renjiaoban/gaoer/sixiangzhengzhi_xiace1/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.kebenzhan.com%2Frenjiaoban%2Fgaoer%2Fsixiangzhengzhi_xiace1%2F&d=6FpmejEDNbHOA1ae24haowhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=d350409b\" target=\"_blank\">http://www.kebenzhan.com/renjiaoban/gaoer/sixiangzhengzhi_xiace1/</a><br />\n<a href=\"http://www.kebenzhan.com/renjiaoban/gaosan/sixiangquanyice/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.kebenzhan.com%2Frenjiaoban%2Fgaosan%2Fsixiangquanyice%2F&d=6FpmejEDNbHOA1ae24haowhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=0e80dbe3\" target=\"_blank\">http://www.kebenzhan.com/renjiaoban/gaosan/sixiangquanyice/</a>"},{"pid":"bebc6c626162dd8f946bf357f28814ea666022ca","tid":224684,"uid":72631,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T01:37:02.000Z","msg":"就咁睇好似台灣最廢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\nMC, fill in the blank<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n7分入大學<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dac3d00d9587e0a040f69a673c1f635f754483be","tid":224684,"uid":51200,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T01:47:31.000Z","msg":"大陸最撚辛苦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n呢個世界，有無國家既教育制度辛苦過大陸<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b6dad67b39e0b6af1d923a7d8553d25c8c58738b","tid":224684,"uid":79403,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T01:57:32.000Z","msg":"大陸行精英教育，台灣行普及教育<br />\n就咁睇個學制好似有啲難比較<br />\n香港而家好似開始貼近台灣嗰種，你覺得係咪好事?"},{"pid":"d34ff81651093e3dbb19f31033686ab7ff7e7a08","tid":224684,"uid":46527,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-05-02T02:55:16.000Z","msg":"<blockquote>大陸行精英教育，台灣行普及教育<br />\n就咁睇個學制好似有啲難比較<br />\n香港而家好似開始貼近台灣嗰種，你覺得係咪好事?</blockquote><br />\n唔係，但中國似日本教育制度<br />\n精英得黎，都搞多啲大學，半普及大學教育。香港最唔好，ASSO 不倫不類"},{"pid":"c12a82a468cb49c6e9bf0911c8d39f71f89458fc","tid":224684,"uid":100680,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T04:26:00.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"463d033ddb94111a7fb6e4a972bd7a0eb3f75955","tid":224684,"uid":6352,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T04:38:55.000Z","msg":"<blockquote><blockquote>大陸行精英教育，台灣行普及教育<br />\n就咁睇個學制好似有啲難比較<br />\n香港而家好似開始貼近台灣嗰種，你覺得係咪好事?</blockquote><br />\n唔係，但中國似日本教育制度<br />\n精英得黎，都搞多啲大學，半普及大學教育。香港最唔好，ASSO 不倫不類</blockquote><br />\n<br />\nAsso係政治產物，其實都好保持著階級分野。"},{"pid":"211ce985ae2b7fd56126e308db09dd62e90086b0","tid":224684,"uid":113073,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T05:14:36.000Z","msg":"澳門啦<br />\n點都讀到大學<br />\n差在雞唔雞<br />\n<br />\n去暨南讀個藥劑，簡簡單單考個牌都3萬幾一個月<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <br />\n<br />\nBand3學校一班前15名都差唔多保送到<br />\n澳大、廈門、中山（前5名普遍先呢幾間）<br />\n<br />\n再黎保送去<br />\n理工、暨南、華僑係最常見<br />\n<br />\n再唔掂會去考科大讀（科大近年排名&gt;澳大<br />\n-------------------------<br />\n勁d既學校就走去保中國排名前10<br />\n-------------------------<br />\n<br />\n台灣份考卷好on9 <img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <br />\n6年前轉哂做選擇題（500分滿，普遍拎200樓下）<br />\n求求其其讀完學士班，走去好d既學校讀碩士洗洗個學歷係現今既人做法"},{"pid":"1c913be572115d9f6df98d0bc6dac227f5b00ed2","tid":224684,"uid":100680,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-02T08:33:03.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}