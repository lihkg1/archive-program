752b5dc44948b2a0d2e3","tid":745413,"uid":190101,"like":0,"dislike":0,"score":0,"quote":{"pid":"c64c5edc8b183636a8def65157eafacab89d85a3","tid":745413,"uid":25671,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-19T06:53:03.000Z","msg":"有無人都係一樣食完差左？"},"citedBy":1,"replyTime":"2018-07-19T10:39:18.000Z","msg":"我無差到，只是無改善<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"75e7182fbe36c0da8e7ddcdebf6e296d4791b725","tid":745413,"uid":149949,"like":0,"dislike":0,"score":0,"quote":{"pid":"f74e0e2c4396021b4756752b5dc44948b2a0d2e3","tid":745413,"uid":190101,"like":0,"dislike":0,"score":0,"quote":{"pid":"c64c5edc8b183636a8def65157eafacab89d85a3","tid":745413,"uid":25671,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-19T06:53:03.000Z","msg":"有無人都係一樣食完差左？"},"citedBy":1,"replyTime":"2018-07-19T10:39:18.000Z","msg":"我無差到，只是無改善<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-19T18:10:57.000Z","msg":"咁點解唔比多次機會食多幾次"},{"pid":"9d16789b4f176338ca296c209baa0595570ac491","tid":745413,"uid":87281,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-19T19:54:44.000Z","msg":"此回覆已被刪除"},{"pid":"736a3b75d6fedc4a14a57d36440fa8f39af92db4","tid":745413,"uid":149949,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d16789b4f176338ca296c209baa0595570ac491","tid":745413,"uid":87281,"like":1,"dislike":0,"score":1,"quote":{"pid":"51d614723e6f17c83d7520fe22a8ba065378c1e3","tid":745413,"uid":149949,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-19T10:09:30.000Z","msg":"咦，打手開始出現 <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-19T19:54:44.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-07-20T07:42:31.000Z","msg":"push, 好壞東西不介意同人分享"},{"pid":"8347dce2c17189ba7540abc173fe8474d8485534","tid":745413,"uid":126178,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-20T16:33:54.000Z","msg":"我由5月尾睇到依家<br />\n<br />\n類風濕關節炎 西醫都話好難醫 之前睇過一個有名既中醫 食左8個月藥 無好到反而更加差 <br />\n<br />\n輾轉黎左漢方睇 坦白講 由最初個膝頭痛到晚上 成日好攰好攰訓係床 咩都唔想做唔想郁 到晚上唔痛先精神返 <br />\n<br />\n食左藥後 變到呢兩個月都可以日日出去唔怕攰 膝頭起身兩個幾三個鐘就唔痛 <br />\n<br />\n當然 病情係有起伏 落大雨可能會痛返啲 有時轉藥方會差左都唔奇 但最緊要痛返既時候都無以前咁未食藥咁痛<br />\n<br />\n醫師都無話寫包單一定會好返斷尾 但我自己做病人 真係覺得病情係明顯咁好轉 連身邊既人都有眼見<br />\n<br />\n連我呢啲咁嚴重既病都可以有改善 其實我唔相信樓上話無用個啲人 係真係一啲啲改善都無<br />\n<br />\n利申 次次真金白銀去睇 睇左幾廿次 唔係醫師朋友上黎做打手 <br />\n<br />\n可以理性討論下"},{"pid":"27c4019919575ddd3155f6c158b22d485e43b4cc","tid":745413,"uid":126178,"like":0,"dislike":0,"score":0,"quote":{"pid":"cc79fe3ac3722a7aa14d675df1b984b4adea73b6","tid":745413,"uid":46752,"like":0,"dislike":0,"score":0,"quote":{"pid":"38a9e0148e96f602d8c07e6811b1c4ca4e84167c","tid":745413,"uid":126178,"like":0,"dislike":0,"score":0,"quote":{"pid":"642dabcfdb13b4a3532bcd3002c028222c29fb2f","tid":745413,"uid":46752,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-17T16:37:02.000Z","msg":"可唔可以影哂成張藥單睇下"},"citedBy":1,"replyTime":"2018-07-17T16:58:02.000Z","msg":"點解"},"citedBy":1,"replyTime":"2018-07-17T17:24:40.000Z","msg":"佢好似全部都係單方 比較少見"},"citedBy":0,"replyTime":"2018-07-20T16:36:08.000Z","msg":"因為太多藥單 睇一次兩張紙 每次返到屋企都扔"},{"pid":"9969b3d4cb3d6e972398c0238d4d824c054d47ce","tid":745413,"uid":126178,"like":1,"dislike":0,"score":1,"quote":{"pid":"7aa4779ace5221826921c4494cdf0bf751fcc99e","tid":745413,"uid":149949,"like":0,"dislike":0,"score":0,"quote":{"pid":"5397d6dabaf5f4ec141fedd6a61cc7bca786e367","tid":745413,"uid":126178,"like":1,"dislike":2,"score":-1,"citedBy":2,"replyTime":"2018-07-17T06:01:09.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/07/17/140049_44d441e54948a256a6c90c7d07f85efd.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F17%2F140049_44d441e54948a256a6c90c7d07f85efd.png&h=c9eba120&s={SIZE}\" /><br />\n<br />\n岩岩先去睇完 唔好話我收錢打手<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-07-17T11:48:57.000Z","msg":"你睇左幾耐啦？係咩事睇？"},"citedBy":1,"replyTime":"2018-07-20T16:41:58.000Z","msg":"本來唔想答咩病 覺得係私人野<br />\n但真心覺得你地幾過份<br />\n一有人持相反意見就負皮個留言 話人打手<br />\n咁就唔係問人地點睇啦 根本想唱衰人 一言堂淨係想人踩9個醫師<br />\n其實你係咪同行 唔抵得人地生意好？"},{"pid":"4f964773e64157e50f3d2e8e49472754563f883c","tid":745413,"uid":126178,"like":1,"dislike":0,"score":1,"quote":{"pid":"8347dce2c17189ba7540abc173fe8474d8485534","tid":745413,"uid":126178,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-20T16:33:54.000Z","msg":"我由5月尾睇到依家<br />\n<br />\n類風濕關節炎 西醫都話好難醫 之前睇過一個有名既中醫 食左8個月藥 無好到反而更加差 <br />\n<br />\n輾轉黎左漢方睇 坦白講 由最初個膝頭痛到晚上 成日好攰好攰訓係床 咩都唔想做唔想郁 到晚上唔痛先精神返 <br />\n<br />\n食左藥後 變到呢兩個月都可以日日出去唔怕攰 膝頭起身兩個幾三個鐘就唔痛 <br />\n<br />\n當然 病情係有起伏 落大雨可能會痛返啲 有時轉藥方會差左都唔奇 但最緊要痛返既時候都無以前咁未食藥咁痛<br />\n<br />\n醫師都無話寫包單一定會好返斷尾 但我自己做病人 真係覺得病情係明顯咁好轉 連身邊既人都有眼見<br />\n<br />\n連我呢啲咁嚴重既病都可以有改善 其實我唔相信樓上話無用個啲人 係真係一啲啲改善都無<br />\n<br />\n利申 次次真金白銀去睇 睇左幾廿次 唔係醫師朋友上黎做打手 <br />\n<br />\n可以理性討論下"},"citedBy":0,"replyTime":"2018-07-20T16:45:29.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/07/21/004405_25b662b79bc3879ab6d4ecfdca390379.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F21%2F004405_25b662b79bc3879ab6d4ecfdca390379.png&h=d6778917&s={SIZE}\" /><br />\n<br />\n有圖有真相 我真係5月尾就去睇<br />\n廢事你地啲玻璃心又話我打手<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"88a7e0acc5505dab6aba035ae1a1898900a61073","tid":745413,"uid":180913,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-07-20T16:52:32.000Z","msg":"我覺得無論中西醫都好蝦人睇呀<br />\n我睇元朗嗰間 南北行 個中醫<br />\n痴撚線嘅<br />\n垃圾到嘔呀<br />\n嗰時我 成日冇力成日暈 頭痛<br />\n食完佢啲藥即刻成個震哂同埋嘔<br />\n成個人天旋地轉咁<br />\n嘔埋黃膽水出嚟㖭<br />\n情況仲衰咗添呀<br />\n<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gi