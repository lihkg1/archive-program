8b6c1a4662c2539637c2b70d6fda0b","tid":1626782,"uid":77237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:01:22.000Z","msg":"推"},{"pid":"2663ad80e085f0090923795deb3f4bd133c80140","tid":1626782,"uid":77237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:01:32.000Z","msg":"推"},{"pid":"6699cb6c8f3cdda1c336ed5a3ccc8dadfc6e88b7","tid":1626782,"uid":77237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:01:42.000Z","msg":"推"},{"pid":"7ec2a45e1688b78748e9ed6507672b679bbe31d3","tid":1626782,"uid":93451,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:01:44.000Z","msg":"<strong><span style=\"font-size: x-large;\">如果學校範圍唔算公眾地方 <br />\n聽日一齊返學校有無得諗</span></strong><br />\n<br />\n我相信好多人都認為聽日係和理非回合[url][/url]<br />\n想出去表達 打下條國際線<br />\n但揾唔到一個一開始同最後唔比人清場嘅方法<br />\n但如果我地帶口罩係大學<br />\n校友\b,大學生,中學生 仲有唔同年齡愛香港嘅香港人<br />\n一齊進行學術討論討論下香港又得唔得呢？<br />\n<br />\n純粹諗到想討論下可行性<br />\n可能時間係好趕<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\"><strong>但聽日最緊要係做到野 同安全</strong></span></span><br />\n<br />\n我地好耐無新嘅創意啦<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">如果八大有好多香港人坐晒係到<br />\n帶口罩表達自己意見<br />\n我覺得個畫面會同二百萬人一樣咁好睇</span></span></strong></span><br />\n最好有法律巴絲入黎分析下<br />\n一齊入黎討論下<br />\n<br />\n<a href=\"https://lihkg.com/thread/1626652/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1626652/page/1</a>"},{"pid":"e9351b6fb98af9a61c6affbcae3e6b6a0095eb8e","tid":1626782,"uid":77237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:01:52.000Z","msg":"推"},{"pid":"8fe05d487d85a53083db177c6d36315bd8bc7b3e","tid":1626782,"uid":77237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:02:15.000Z","msg":"推"},{"pid":"0fcc98489f92b11a9ca8d39d9ae1747889bdf1ea","tid":1626782,"uid":77237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:02:27.000Z","msg":"推"},{"pid