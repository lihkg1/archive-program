=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/28.png\" class=\"hkgmoji\" />"},{"pid":"573279e13d6363414bd655eb27031b1cd8e00a04","tid":2355434,"uid":277640,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T04:37:36.000Z","msg":"Push"},{"pid":"166879f9ce34cd7eb48b03df40ba8c88ab1da3cd","tid":2355434,"uid":293864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T04:37:38.000Z","msg":"twitter呀<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"8363013d917c89d99c95167cd324fefb7d35602a","tid":2355434,"uid":277640,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-07T04:37:47.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"4cea4d10136f969d6d5d2e388702cda85c1eadf4","tid":2355434,"uid":364068,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2021-01-06T11:03:03.000Z","msg":"1. 開 <span class=\"orange\">AC</span> <br />\n2. <span class=\"orange\">Follow手足</span> (通常個名/簡介睇得出 eg. #手足互科 #StandWithHongKong #FollowBackHongKong 等)<br />\n3. Telegram<span class=\"orange\">接任</span> / 跟手足推 (<a href=\"https://t.me/TwitterHelpBot\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FTwitterHelpBot&d=dNeHxx%2FttK3%2FgpwSwFVImT2djVMnfBKxsW1BXeekzK0%3D&h=27ec12cb\" data-auto-link target=\"_blank\">https://t.me/TwitterHelpBot</a>)<br />\n4. TG BOT入面打 <span class=\"orange\">/task</span>，就有分唔同總類既post！<br />\n5. <span class=\"orange\">Like and retweet</span> (好似FB 撳個LIKE 同分享一樣)<br />\n6. <span class=\"orange\">Follow</span>埋<span class=\"orange\">名人</span>議員外國人就最好<br />\n<br />\n<br />\n<a href=\"https://lihkg.com/thread/1609258/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1609258/page/1</a><br />\n<blockquote><span class=\"x-large\"><span class=\"red\">求大家幫手twitter 幫推。有手足24小時update有咩記者post要推，包括埋岩先開槍！</span></span><br />\n<br />\n其實twitter down app再開AC唔洗3分鐘。。。<br />\n<br />\n<img src=\"https://na.cx/i/pa2NxcU.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fpa2NxcU.jpg&h=8d2e1b9b&s={SIZE}\" /><br />\n<br />\n有高人整左個tg bot, 你只要search @TwitterHelpBot，再打/task，就有分唔同總類既post！<br />\n<a href=\"https://t.me/TwitterHelpBot\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FTwitterHelpBot&d=dNeHxx%2FttK3%2FgpwSwFVImT2djVMnfBKxsW1BXeekzK0%3D&h=27ec12cb\" target=\"_blank\">https://t.me/TwitterHelpBot</a><br />\n如下圖：<br />\n<br />\n<img src=\"https://na.cx/i/Wp4tjRE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWp4tjRE.jpg&h=0f44b4cb&s={SIZE}\" /><br />\n<br />\n<strong><span class=\"red\"><span class=\"xx-large\">轉番做文字版，10秒搞掂一個post </span></span></strong><br />\n<br />\n狗開槍，國慶戒嚴，一定要比外國知。佢地搵緊缺口位幫我地嫁！<br />\n<br />\n㩒link --&gt; like and retweet, 鐘意咪留句thank you so much. 3分鐘內完成。<br />\n<br />\n每日用你3分鐘呀~一部手機就夠<br />\n<img src=\"https://na.cx/i/rE5GBGe.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FrE5GBGe.png&h=48ceb362&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/TFcuNYj.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTFcuNYj.jpg&h=b961822c&s={SIZE}\" /><br />\n<br />\n請全民twitter, 推香港上國際熱門<img src=\"/assets/faces/mf/cry.gif\" class=\"hkgmoji\" /></blockquote>"}}