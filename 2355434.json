hr8-2.xx&amp;oh=fb638f3c6308a3eb2b313b82b59d520b&amp;oe=601C7DDA\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-lhr8-2.xx.fbcdn.net%2Fv%2Ft1.0-9%2F135760301_2741317849516339_41508721484844777_o.jpg%3F_nc_cat%3D101%26ccb%3D2%26_nc_sid%3Da26aad%26_nc_ohc%3DWjLqJBXQcqUAX_tLILU%26_nc_ht%3Dscontent-lhr8-2.xx%26oh%3Dfb638f3c6308a3eb2b313b82b59d520b%26oe%3D601C7DDA&h=3f6a81b0&s={SIZE}\" /><br />\n<br />\n<img src=\"https://scontent-lhr8-2.xx.fbcdn.net/v/t1.0-9/136684605_2741317896183001_8531677324604596330_o.jpg?_nc_cat=101&amp;ccb=2&amp;_nc_sid=a26aad&amp;_nc_ohc=d9g0bNygB_0AX8B4SeH&amp;_nc_ht=scontent-lhr8-2.xx&amp;oh=a27fe705576225eb6df9a42f188ac677&amp;oe=601B6C6D\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-lhr8-2.xx.fbcdn.net%2Fv%2Ft1.0-9%2F136684605_2741317896183001_8531677324604596330_o.jpg%3F_nc_cat%3D101%26ccb%3D2%26_nc_sid%3Da26aad%26_nc_ohc%3Dd9g0bNygB_0AX8B4SeH%26_nc_ht%3Dscontent-lhr8-2.xx%26oh%3Da27fe705576225eb6df9a42f188ac677%26oe%3D601B6C6D&h=b64d87f2&s={SIZE}\" /><br />\n<br />\n<img src=\"https://scontent-lhr8-1.xx.fbcdn.net/v/t1.0-9/136639341_2741317929516331_1099685243406799757_o.jpg?_nc_cat=111&amp;ccb=2&amp;_nc_sid=a26aad&amp;_nc_ohc=ESmQ7mI_jGwAX_ZEkFh&amp;_nc_ht=scontent-lhr8-1.xx&amp;oh=356af3cfef1b1500d977554245f89cd5&amp;oe=601A92AB\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-lhr8-1.xx.fbcdn.net%2Fv%2Ft1.0-9%2F136639341_2741317929516331_1099685243406799757_o.jpg%3F_nc_cat%3D111%26ccb%3D2%26_nc_sid%3Da26aad%26_nc_ohc%3DESmQ7mI_jGwAX_ZEkFh%26_nc_ht%3Dscontent-lhr8-1.xx%26oh%3D356af3cfef1b1500d977554245f89cd5%26oe%3D601A92AB&h=bc15e78d&s={SIZE}\" /><br />\n<br />\n黎明未來到，先有大抓捕。<br />\n抗爭平靜片刻，港共立即反噬。<br />\n港共就係要我地恐懼。<br />\n要我地放棄。<br />\n要我地徒勞。<br />\n<br />\n唯獨抗爭意志不滅。<br />\n8/1-11/1，星光燎原，遍地開花！<br />\n寧鳴而死，不默而生！"},{"pid":"c7840904d82c07012cb8a16121a088710a64c405","tid":2355434,"uid":281713,"like":1,"dislike":0,"score":1,"quote":{"pid":"8b3399ad8e784985f6fb762bce8d725c7a0c148f","tid":2355434,"uid":190296,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-01-06T06:10:13.000Z","msg":"見到好多身邊嘅朋友<br />\n淨係識得喺社交平台分享新聞<br />\n其實去到呢個狀況對內輸出係一啲用都冇 <br />\n因為根本相同立場嘅已經自己會識得去睇新聞<br />\n<br />\n<br />\n眼見咁多事 好嬲好嬲之下有啲咩可以做？<br />\n<br />\n而家我俾個最簡單嘅方法大家 <br />\n（其實好耐之前已經）<br />\n<strong><span class=\"x-large\"><span class=\"orange\">Follow小白鼠先生</span></span></strong><br />\n再㩒埋佢個鐘仔：<br />\n<br />\n<a href=\"https://twitter.com/shiroihamusan?s=09\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Fshiroihamusan%3Fs%3D09&d=dNeHxx%2FttK3%2FgpwSwFVImT2djVMnfBKxsW1BXeekzK0%3D&h=21f76eed\" data-auto-link target=\"_blank\">https://twitter.com/shiroihamusan?s=09</a><br />\n<br />\n只要like同埋retweet佢所有嘅post就已經幫到好多<br />\n<br />\n2021只會更加難過 <br />\n但係咪剩係可以坐以待斃 怨天怨地？<br />\n我自己覺得唔係<br />\n<br />\n大家一齊加油 要幫手永遠都唔會遲<br />\n與其淨係識得鬧交不如留返啖氣做實事<br />\n<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n另外再擺一條link：<br />\n<br />\n攬炒巴：推twitter!推twitter!推twitter!<br />\n<a href=\"https://lih.kg/2354975\" data-auto-link target=\"_blank\">https://lih.kg/2354975</a><br />\n- 分享自 LIHKG 討論區"},"citedBy":0,"replyTime":"2021-01-06T10:42:02.000Z","msg":"真，要做，推"},{"pid":"23bfda6f78452d2ab4fe859654330942f0087ceb","tid":2355434,"uid":24862,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-06T10:45:32.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"76782585406b19b41ae67e4a776462c7301217d8","tid":2355434,"uid":10702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-06T10:46:47.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"ac28fdcffe8c66c4eb43371e53c3d0907b18c5ae","tid":2355434,"uid":114781,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-06T10:47:24.000Z","msg":"RT<