37D4MqEuHX91B%2FZbc%3D&h=75780c53\" data-auto-link target=\"_blank\">https://play.google.com/store/apps/details?id=com.newlife330&amp;hl=zh_HK</a><br />\nApp Store：<a href=\"https://apps.apple.com/hk/app/newlife-330/id1047078127\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fapps.apple.com%2Fhk%2Fapp%2Fnewlife-330%2Fid1047078127&d=Q%2BwKghBkVpQFldJLXg3PjQpem%2F37D4MqEuHX91B%2FZbc%3D&h=24ff0f11\" data-auto-link target=\"_blank\">https://apps.apple.com/hk/app/newlife-330/id1047078127</a><br />\n<br />\n<strong>催眠治療（Hypnotherapy）</strong><br />\nVoid 利用手機應用程式作為媒介，把催眠治療、正念、冥想帶來的價值以簡單而有效的方式傳遞予更多人。<br />\nGoogle Play：<a href=\"https://play.google.com/store/apps/details?id=net.appvoid.avoid&amp;hl=zh_HK\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fplay.google.com%2Fstore%2Fapps%2Fdetails%3Fid%3Dnet.appvoid.avoid%26hl%3Dzh_HK&d=Q%2BwKghBkVpQFldJLXg3PjQpem%2F37D4MqEuHX91B%2FZbc%3D&h=e15abaa8\" data-auto-link target=\"_blank\">https://play.google.com/store/apps/details?id=net.appvoid.avoid&amp;hl=zh_HK</a><br />\nApp Store：<a href=\"https://apps.apple.com/hk/app/void-e4-b8-ad-e6-96-87-e6-94-be-e7-a9-ba-e5-86-a5-e6/id1166166909\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fapps.apple.com%2Fhk%2Fapp%2Fvoid-e4-b8-ad-e6-96-87-e6-94-be-e7-a9-ba-e5-86-a5-e6%2Fid1166166909&d=Q%2BwKghBkVpQFldJLXg3PjQpem%2F37D4MqEuHX91B%2FZbc%3D&h=cb25ccf8\" data-auto-link target=\"_blank\">https://apps.apple.com/hk/app/void-e4-b8-ad-e6-96-87-e6-94-be-e7-a9-ba-e5-86-a5-e6/id1166166909</a><br />\n<br />\n請廣傳，感謝。<br />\n<br />\n抗爭成功後，如有巴絲是讀社工、心理、輔導、治療師，請為有盡要嘅人進行輔導。<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"23b45c3433c39805c2abb16df99d6a0794be49d4","tid":1222412,"uid":5627,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-14T13:04:07.000Z","msg":"+1"},{"pid":"4cb5e43595d63c913e129226a6303f6a1eb9328d","tid":1222412,"uid":96852,"like":0,"dislike":0,"score":0,"quote":{"pid":"8949d8ba2f2604f9c51fa295ae22967c9d3b3375","tid":1222412,