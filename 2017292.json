mg src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-15T10:39:14.000Z","msg":"上一個post咪有相"},{"pid":"65311b2780f374f4ea0038c55d10bbb8da241984","tid":2017292,"uid":306914,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-05-15T10:47:56.000Z","msg":"爸爸腦退化，媽媽過咗身，交易本身就有可疑，直接搵金管局同黑警啦"}]}