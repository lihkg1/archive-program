d":741890,"uid":141435,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2018-07-16T11:57:12.000Z","msg":"唔好亂介紹私家醫生啦。<br />\n<br />\n末期嘅野，講真。留返舊錢開開心心玩咗佢又好 食咗佢又好。做啲有意義嘅事啦。<br />\n<br />\n最緊要係止痛。屋企多啲support 好重要。<br />\n<br />\n利申：公立醫護狗"},{"pid":"25bdce6bf7015b7f1bb936b9ee8d64cd6b0c6e9a","tid":741890,"uid":126609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-16T12:04:53.000Z","msg":"此回覆已被刪除"},{"pid":"301db1d9ca82dab1e35a87efa0dc7ee0476bfd1a","tid":741890,"uid":1550,"like":4,"dislike":0,"score":4,"citedBy":4,"replyTime":"2018-08-11T13:15:40.000Z","msg":"爸爸完成心願之後就開始變差<br />\n係同一日走左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"4373beeea074219d1cffeb6add076fabfc15c676","tid":741890,"uid":14259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-11T13:35:23.000Z","msg":"巴打保重、加油!!<br />\nuncle知道你哋都愛佢就足夠了"},{"pid":"f8a2f56fa9e3badac2758baedeb071aac5dfb666","tid":741890,"uid":82373,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-11T13:55:21.000Z","msg":"抗癌4小寶<br />\n<br />\n<a href=\"https://youtu.be/hNQPzVWGflQ\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FhNQPzVWGflQ&d=TiJr7QcSGEERTawMyb8lLi7PofNJLCAwyGXsi6MH%2FEQ%3D&h=80917c91\" data-auto-link target=\"_blank\">https://youtu.be/hNQPzVWGflQ</a><br />\n<br />\n<a href=\"https://youtu.be/k7gmm5hfkYo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2Fk7gmm5hfkYo&d=TiJr7QcSGEERTawMyb8lLi7PofNJLCAwyGXsi6MH%2FEQ%3D&h=f22e01ec\" data-auto-link target=\"_blank\">https://youtu.be/k7gmm5hfkYo</a>"},{"pid":"1929122d375ab45d4cc92af02015b12f138a21f3","tid":741890,"uid":29620,"like":0,"dislike":0,"score":0,"quote":{"pid":"301db1d9ca82dab1e35a87efa0dc7ee0476bfd1a","tid":741890,"uid":1550,"like":4,"dislike":0,"score":4,"citedBy":4,"replyTime":"2018-08-11T13:15:40.000Z","msg":"爸爸完成心願之後就開始變差<br />\n係同一日走左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-12T00:29:42.000Z","msg":"加油<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"5c3c114a23184944bda1e2a6565043a25abfd034","tid":741890,"uid":81174,"like":0,"dislike":0,"score":0,"quote":{"pid":"301db1d9ca82dab1e35a87efa0dc7ee0476bfd1a","tid":741890,"uid":1550,"like":4,"dislike":0,"score":4,"citedBy":4,"replyTime":"2018-08-11T13:15:40.000Z","msg":"爸爸完成心願之後就開始變差<br />\n係同一日走左<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-12T02:37:14.000Z","msg":"無憾已經好好了<br />\n巴打保重"},{"pid":"b34ac9ebfe39d3c1605f8735a5d4a8d5427d6c41","tid":741890,"uid":124643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-12T02:55:30.000Z","msg":"我呀嫲個陣5月尾開始覺得佢面色好黃<br />\n6月頭左右確診胰臟癌<br />\n6月尾做手術<br />\n個手術要將啲內臟左切右切左駁右駁<br />\n然後做左唔夠十日我嫲開始好痛<br />\n醫生就話傷口埋唔到口<br />\n入左icu<br />\n7月中就去左<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n前後夾埋兩個月都無<br />\n<br />\n咁當然人人健康情況唔同<br />\n但係要醫好胰臟癌近乎係不可能<br />\n最多最多都只可能係要佢好辛苦地維持多幾個月<br />\n<br />\n就睇你同你屋企人想佢舒舒服服地走，定還是想陪多佢一段時間但佢可能會辛苦<br />\n我嫲既情況係最sad既，諗住做手術可以陪多佢一陣<br />\n(佢自己決定做手術)<br />\n但係到最尾係個手術令到佢離開"}]}