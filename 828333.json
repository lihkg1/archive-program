{"tid":828333,"cid":5,"subCid":0,"title":"【裸照風波】英國劍橋公爵夫人姬蒂被偷拍半裸照案    法雜誌社上訴失敗","createTime":"2018-09-19T14:53:14.000Z","updateTime":"2018-09-20T14:10:38.000Z","uid":79563,"like":8,"dislike":1,"uniUserReply":9,"replies":[{"pid":"711d2f395ffd8da8c58cceaad080a50a8bb212c6","tid":828333,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-19T14:53:14.000Z","msg":"<img src=\"https://static.appledaily.hk/images/e-paper/20180919/large/1537363188_a735.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20180919%2Flarge%2F1537363188_a735.jpg&h=07c0c415&s={SIZE}\" /><br />\n<br />\n英國劍橋公爵夫人姬蒂6年前在法國被偷拍半裸照一案，法院周三維持判決，裁定法國雜誌社的上訴不得直，雜誌社總編輯及發行人各需支付4.5萬歐元（41萬港元）罰款。<br />\n<br />\n姬蒂2012年與丈夫威廉王子在法國普羅旺斯（Provence）度假，在泳池邊半裸曬太陽時被人用長鏡頭相機偷拍，法國《Closer》雜誌以照片做封面。<br />\n<br />\n英國皇室指雜誌侵犯姬蒂私隱，控告雜誌編輯、攝影師等6人。威廉王子更形容偷拍事件令人「極度震驚」，讓他憶起亡母戴安娜王妃與狗仔隊周旋的不快往事。<br />\n<br />\n法新社"},{"pid":"2a32d8dbcfa9a544141e9a9f3867c5ecd43a1ace","tid":828333,"uid":35014,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2018-09-19T15:28:16.000Z","msg":"此回覆已被刪除"},{"pid":"fc5d7358c70347e09e308eee35066f6ecf75af58","tid":828333,"uid":35870,"like":3,"dislike":0,"score":3,"quote":{"pid":"2a32d8dbcfa9a544141e9a9f3867c5ecd43a1ace","tid":828333,"uid":35014,"like":3,"dislike":1,"score":2,"citedBy":1,"replyTime":"2018-09-19T15:28:16.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-09-19T15:37:48.000Z","msg":"MI6 <br />\n<img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" />"},{"pid":"a927666a61965aab415cbcd039cfb0cd52a6e247","tid":828333,"uid":65128,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-09-20T13:35:33.000Z","msg":"此回覆已被刪除"},{"pid":"e94bdf4ba43b81786aab306e3d2cc7e2e2fced9b","tid":828333,"uid":192808,"like":1,"dislike":4,"score":-3,"citedBy":0,"replyTime":"2018-09-20T13:41:31.000Z","msg":"此回覆已被刪除"},{"pid":"1ed07ab0cb3b6dfe479710823630d6004e6e4bf3","tid":828333,"uid":20816,"like":0,"dislike":0,"score":0,"citedBy":0