51,"uid":62068,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-07-16T12:05:03.000Z","msg":"增值200咁少?<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"a33c760d61971f99da508aa800ee538968dafd45","tid":744651,"uid":106506,"like":0,"dislike":0,"score":0,"quote":{"pid":"4b745a22fea4ab8d081d852297e8e00cf14764e4","tid":744651,"uid":135761,"like":2,"dislike":0,"score":2,"quote":{"pid":"5ccc0cc50e53e9b96d61d0e9710b3dc8676085a7","tid":744651,"uid":106506,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-16T06:02:11.000Z","msg":"有咩咁好笑<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n講嚟聽下"},"citedBy":1,"replyTime":"2018-07-16T10:48:16.000Z","msg":"試過見老闆嗰時諗起朋友啲on9野，差啲忍唔住笑撚咗出聲，唯有滅自己大脾咬嘴唇同埋扮咳去忍笑<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-16T12:51:56.000Z","msg":"朋友啲on9野有時真係估佢唔到咁好笑<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"}]}