ormal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-03T03:32:45.000Z","msg":"管軼都收聲了"},{"pid":"f1eaae171c24aaab477d62330590713a3f4518e5","tid":2430374,"uid":38172,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-03T03:33:33.000Z","msg":"D後生咁垃圾, 教佢地都徙氣, 支持D PROF走 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a4f7a4f13bc5566f4381982037857fdf28238a80","tid":2430374,"uid":71133,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-03-03T03:35:43.000Z","msg":"睇下XGDX幾時跌出百大<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"17c6d4b3b51acb3255f961b5d62f31dfc07fb6a9","tid":2430374,"uid":280593,"like":0,"dislike":0,"score":0,"quote":{"pid":"274c138b92e3cd8a6447001648b605965ae12492","tid":2430374,"uid":271829,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-03T01:41:59.000Z","msg":"<img src=\"https://hk.appledaily.com/resizer/PEl99KRwtUR5BY5G05knPW7ITxY=/720x405/filters:quality(100)/cloudfront-ap-northeast-1.images.arcpublishing.com/appledaily/S64OKPUS6FFLJKTD5IXZUIBAZE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FPEl99KRwtUR5BY5G05knPW7ITxY%3D%2F720x405%2Ffilters%3Aquality%28100%29%2Fcloudfront-ap-northeast-1.images.arcpublishing.com%2Fappledaily%2FS64OKPUS6FFLJKTD5IXZUIBAZE.jpg&h=c8eeed20&s={SIZE}\" /><br />\n■港大微生物學系前系主任胡釗逸（左圖）及劉嘉珮（右圖）夫婦，在國安法生效同月請辭。資料圖片<br />\n<br />\n...<br />\n肝病權威黎青龍不獲續約，本港醫學界隨時再失去極具份量的重要一員。事實上，去年國安法生效後，已先後有多位知名學者出走，公共醫療醫生協會會長馬仲儀相信，在學術自由「低氣壓」之下，不但海外醫學專家不願意來港教授，即使選擇留下來繼續研究的學者，未來也許變得更低調，不肯受訪或觸及任何敏感議題。<br />\n<br />\n港大微生物學系地震<br />\n去年7月國安法生效後，最先離開的知名學者是港大微生物學系兩名前系主任胡釗逸及劉嘉珮夫婦，他們7月請辭、10月離任，據報二人在香港以外繼續研究。二人請辭可謂該系近年最大的人事變動，據悉系方亦始料不及，簡單進行全球招募及系內遴選後，最終擢升40歲出頭的臨床副教授杜啟泓接任系主任一職。而政府抗疫專家組成員、港大公共衞生學院院長福田敬二去年10月不獲港大續約，今年底完成五年合約後將離開。<br />\n中文大學前校長、腸胃科專家沈祖堯亦在國安法生效後一個月表明將會離開香港，到新加坡南洋理工大學擔任醫學院院長和高級副校長。<br />\n...<br />\n<br />\n<a href=\"https://hk.appledaily.com/local/20210303/CLX2MC5QORGZDAGIJ5KDVOCCF4/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210303%2FCLX2MC5QORGZDAGIJ5KDVOCCF4%2F&d=uMWHtpimsJ%2FyHBgDjrBiuhR1GjkmqS0yYYF7Sw2QOJY%3D&h=42a4bd72\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210303%2FCLX2MC5QORGZDAGIJ5KDVOCCF4%2F&h=83ac7534\" target=\"_blank\">https://hk.appledaily.com/local/20210303/CLX2MC5QORGZDAGIJ5KDVOCCF4/</a>"},"citedBy":0,"replyTime":"2021-03-03T03:36:35.000Z","msg":"微生物學系<br />\n怕被自殺"},{"pid":"e6b0ba6be4388704b760e1fd95d42f9736d4c96c","tid":2430374,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-03T03:40:08.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"54a69a213a5fdcf0560957b3d95141d30ded8172","tid":2430374,"uid":33422,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-03-03T03:41:00.000Z","msg":"只要整臭香港，支那就可以輕鬆超越<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />唔係共同進步，因為支那本身就當香港人係外人<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"0180ecbf32383113950f7037e5453c19e82f8a58","tid":2430374,"uid":290118,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-03T03:41:24.000Z","msg":"国安大法好<br />\nGuo An Dafa is good<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"ad57099229ae1b6d12ed92830637aec1a21d1852","tid":2430374,"uid":4942,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-03T03:42:05.000Z","msg":"支共做得出呢d嘢<br />\n<br />\n就預左有呢一日"},{"pid":"fe5543a640fa087a51b195ad4cb0fac0d3d87e3f","tid":2430374,"uid":304916,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-03T03:42:23.000Z","msg":"XGDX <img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" />"},{"pid":"7fa2bbe2de4ced1ef81eee773a7f026b52091ccd","tid