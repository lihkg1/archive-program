/140657_4d37192856d30ad5f5464e1ec0b8308f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F15%2F140657_4d37192856d30ad5f5464e1ec0b8308f.jpg&h=42ab02bb&s={SIZE}\" /><br />\n點解d西人咁鍾意係太空倉潛艇上扑野</blockquote><br />\n<br />\n<br />\n獨食兩條女畀着連登仔都嬲<br />\n<img src=\"https://img.eservice-hk.net/upload/2017/10/15/143441_c1786a189be1d4b58fad1fd63068744e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F15%2F143441_c1786a189be1d4b58fad1fd63068744e.jpg&h=2cba5793&s={SIZE}\" />"},{"pid":"b5abcbcd32da44490e41136a49b450db44c0af46","tid":436373,"uid":82829,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-10-15T06:39:47.000Z","msg":"<blockquote>阿姆士唐 同 愛德華 扑嘢<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /></blockquote><br />\n比你講咗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a50e785c0f2d4a65fc746bfd8aa8d6d03b4bb3df","tid":436373,"uid":5196,"like":19,"dislike":12,"score":7,"citedBy":0,"replyTime":"2017-10-15T06:42:18.000Z","msg":"<blockquote><blockquote>阿姆士唐 同 愛德華 扑嘢<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /></blockquote><br />\n比你講咗<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"https://img.eservice-hk.net/upload/2017/10/15/144216_f18c58f96ebd835d70dedc297682b10e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F15%2F144216_f18c58f96ebd835d70dedc297682b10e.jpg&h=b62feec7&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/10/15/144217_f18c58f96ebd835d70dedc297682b10e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F10%2F15%2F144217_f18c58f96ebd835d70dedc297682b10e.jpg&h=5e387e66&s={SIZE}\" />"},{"pid":"256b716abb7d0205f966c664e8a2eb375bf44f9a","tid":436373,"uid":49197,"like":2,"dislike":13,"score":-11,