F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F25%2F191901_83b5009e040969ee7b60362ad7426573.jpeg&h=d7f2659b&s={SIZE}\" />"},{"pid":"d734be3e7ce30f1c6135707cc6cae40d97e94717","tid":1098284,"uid":26106,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-09T05:05:39.000Z","msg":"唔怕啦<br />\n環保撚都唔講衛生嫁嘛<br />\n仲唔上去幫襯下？<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"dc2dfa81ca7f92903e2bbc6240c35c34c8ac1886","tid":1098284,"uid":31254,"like":26,"dislike":0,"score":26,"citedBy":1,"replyTime":"2019-04-09T05:06:14.000Z","msg":"有一個美國人到中國餐廳吃飯，他先點了一盤龍蝦。<br />\n<br />\n當他吃完，服務生來收盤子的時候，美國人突然問：「你們這個蝦殼都怎麼處理？」<br />\n<br />\n服務生回答：「當然是丟掉啊！」<br />\n<br />\n美國人說：「喔～No No No！在我們美國呢，都是把蝦殼做成蝦餅賣到你們中國來。」<br />\n<br />\n接著，那美國人點了一顆橘子，吃完後服務生來收，美國人突然問：「你們這個橘子皮都怎麼處理？」<br />\n<br />\n服務生回答：「當然是丟掉啊！」<br />\n<br />\n美國人說：「喔～No No No！在我們美國，都是把橘子皮做成橘子醬賣到你們中國來！」<br />\n<br />\n結帳的時候，美國人看到服務生正在吃口香糖，他便問：「你們吃完的口香糖都怎麼處理？」<br />\n<br />\n服務生回答：「當然是丟掉啊！」<br />\n<br />\n美國人說：「喔～No No No！在我們美國，都是把口香糖做成保險套賣到你們中國來。」<br />\n<br />\n服務聲聽了非常生氣，於是說：「那你們保險套用完都怎麼處理勒？」<br />\n<br />\n美國人回答：「當然是丟掉啊！」<br />\n<br />\n服務生就回了他：「喔～No No No！在我們中國呢，都是把用過的保險套做成口香糖賣到你們美國去。」"},{"pid":"66f4c58bded4ad464e82b8955a26925ac1fbd969","tid":1098284,"uid":65780,"like":5,"dislike":1,"score":4,"quote":{"pid":"c6edab2da1e2609901a2340bf25a22d199521204","tid":1098284,"uid":57376,"like":3,"dislike":3,"score":0,"citedBy":1,"replyTime":"2019-04-09T05:00:21.000Z","msg":"又有班人想偷換概念<img src=\"/assets/faces/lm2/silly.gif\" class=\"hkgmoji\" /><br />\n香港有餐廳會入=專登上支那食野唔戇鳩？<img src=\"/assets/faces/lm2/wfc2.gif\" class=\"hkgmoji\" /><br />\n即係「城市環境本身有輻射，所以專登走去大亞灣核電廠自拍都一樣」<img src=\"/assets/faces/lm2/brain.gif\" class=\"hkgmoji\" /><br />\n<br />\n仲有你估去支那食野中招機會大啲定係香港中招機會大？<img src=\"/assets/faces/lm2/nosee.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-04-09T05:06:59.000Z","msg":"刺稻草人？ <br />\n邊到有人咁講 <br />\n人哋話唔好講到事不關己啫 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"c9e81e3183542