s/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"f01c85ee6b1f010696b10495b0718772d15af996","tid":1669890,"uid":86509,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c149148bd45f80655520bb6fa34897a75c4ece8","tid":1669890,"uid":321374,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-23T03:03:23.000Z","msg":"熱狗都放左唔少人係度<br />\nblock極都仲有<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-23T03:04:37.000Z","msg":"我係本民青支持者嚟喎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n雖則我知本民青嘅人好多都係加泰集會呢邊"},{"pid":"69cc015a20bc1edca3636996607f1c463ec1d93d","tid":1669890,"uid":221360,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-10-23T03:04:51.000Z","msg":"去集會果班，唔代表全香港，就好似撐警集會咁，都唔係代表全香港。想去就去，唔想去咪唔好去，反而覺得大家post多d點解要支持／反對個集會既post，比大家自行決定會更加好。<br />\n最後，集會無可能影響我地既初衷，去既只係聲援佢地為自由所做既事，唔係聲援加獨。<br />\n<br />\n勿忘初心，方得始終<br />\n光復香港，時代革命<br />\n五大訴求，缺一不可<br />\n不自由，毋寧死。"},{"pid":"4f58bb23f8acb1f88528cf0d4824ed39a6df8564","tid":1669890,"uid":86509,"like":1,"dislike":0,"score":1,"quote":{"pid":"69cc015a20bc1edca3636996607f1c463ec1d93d","tid":1669890,"uid":221360,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-10-23T03:04:51.000Z","msg":"去集會果班，唔代表全香港，就好似撐警集會咁，都唔係代表全香港。想去就去，唔想去咪唔好去，反而覺得大家post多d點解要支持／反對個集會既post，比大家自行決定會更加好。<br />\n最後，集會無可能影響我地既初衷，去既只係聲援佢地為自由所做既事，唔係聲援加獨。<br />\n<br />\n勿忘初心，方得始終<br />\n光復香港，時代革命<br />\n五大訴求，缺一不可<br />\n不自由，毋寧死。"},"citedBy":0,"replyTime":"2019-10-23T03:15:29.000Z","msg":"我覺得係抗爭者理念分歧<br />\n理念行先定功利主義行先<br />\n兩者都冇錯<br />\n理念型注重過程目的<br />\n功利主義注重成果<br />\n兩者都係公義嘅體現<br />\n<br />\n<br />\n但問題在於<br />\n集會舉辦嘅人冇避重就輕<br />\n嘗試平衡兩邊睇法<br />\n所以開始出現咗一道可見裂痕<br />\n<br />\n用抗爭者牌頭代表抗爭者講第二個完全唔同嘅議題<br />\n其實係大台化<br />\n然後問咗三個人都答我<br />\n自由係代表獨立嘅自由<br />\n前後矛盾<br />\n令人不信服<br />\n<br />\n真係原本係無咩特別<br />\n係比搞集會嗰個人令到分歧浮現<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n唔係好再理呢單嘢<br />\n因為最後發展成點都係搞手影響<br />\n<br />\n人少人多都會造成分裂<br />\n嘥氣。。。"},{"pid":"