{"tid":947801,"cid":10,"subCid":0,"title":"|[ 家用電視遊戲機歷史 ]|","createTime":"2018-12-19T14:01:35.000Z","updateTime":"2019-04-13T15:38:25.000Z","uid":37125,"like":13,"dislike":2,"uniUserReply":21,"replies":[{"pid":"29df1a9578cc484d62f27fe1b2ce36536b52f99a","tid":947801,"uid":37125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-19T14:01:35.000Z","msg":"<a href=\"https://www.youtube.com/watch?v=apwcCbEfwJY&amp;index=1&amp;list=PL_veWBY42plBdhgVayLsR--3PasU2TY4i\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DapwcCbEfwJY%26index%3D1%26list%3DPL_veWBY42plBdhgVayLsR--3PasU2TY4i&d=WxU%2BTxDwFZ9OHfYIV9EPuQRJEaK469wi7EMLOMkgk88%3D&h=3e5b012f\" target=\"_blank\">https://www.youtube.com/watch?v=apwcCbEfwJY&amp;index=1&amp;list=PL_veWBY42plBdhgVayLsR--3PasU2TY4i</a><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=3NE3O7xbrB4&amp;index=2&amp;list=PL_veWBY42plBdhgVayLsR--3PasU2TY4i\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D3NE3O7xbrB4%26index%3D2%26list%3DPL_veWBY42plBdhgVayLsR--3PasU2TY4i&d=WxU%2BTxDwFZ9OHfYIV9EPuQRJEaK469wi7EMLOMkgk88%3D&h=cde0983a\" target=\"_blank\">https://www.youtube.com/watch?v=3NE3O7xbrB4&amp;index=2&amp;list=PL_veWBY42plBdhgVayLsR--3PasU2TY4i</a><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=574ryD7T0ao&amp;index=3&amp;list=PL_veWBY42plBdhgVayLsR--3PasU2TY4i\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D574ryD7T0ao%26index%3D3%26list%3DPL_veWBY42plBdhgVayLsR--3PasU2TY4i&d=WxU%2BTxDwFZ9OHfYIV9EPuQRJEaK469wi7EMLOMkgk88%3D&h=d2dea5b0\" target=\"_blank\">https://www.youtube.com/watch?v=574ryD7T0ao&amp;index=3&amp;list=PL_veWBY42plBdhgVayLsR--3PasU2TY4i</a><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=ZfCPSILRoO4&amp;index=4&amp;list=PL_veWBY42plBdhgVayLsR--3PasU2TY4i\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DZfCPSILRoO4%26index%3D4%26list%3DPL_ve