c=\"/assets/faces/mf/clown.gif\" class=\"hkgmoji\" />"},{"pid":"944cae649f2f93c5e4db0e1e04b1e05e68dfe442","tid":1590980,"uid":52006,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-09-24T03:46:48.000Z","msg":"有否決權即係垃圾冇鳩用"},{"pid":"a6cae62ad95cdab546e7b0abc966b9e4d83320d7","tid":1590980,"uid":25108,"like":3,"dislike":0,"score":3,"quote":{"pid":"b6ddc0b588b15485d4cda254da993fea88a7c453","tid":1590980,"uid":99962,"like":25,"dislike":0,"score":25,"citedBy":4,"replyTime":"2019-09-24T03:27:27.000Z","msg":"聯合國係廢既"},"citedBy":0,"replyTime":"2019-09-24T03:47:36.000Z","msg":"聯合國係廢既"},{"pid":"f1707c6e17ec695c1ed67396790c36e153623259","tid":1590980,"uid":41116,"like":3,"dislike":0,"score":3,"quote":{"pid":"ce34549ca7bb71f5cca097830063bd906ed5c21d","tid":1590980,"uid":997,"like":24,"dislike":1,"score":23,"quote":{"pid":"c8b0dd8b6476c1abcf4648ee30087c41badcab34","tid":1590980,"uid":41116,"like":8,"dislike":0,"score":8,"quote":{"pid":"9e7b8e9a95633f3e713cf76ea0a2c9894c60a4b2","tid":1590980,"uid":69568,"like":6,"dislike":0,"score":6,"citedBy":2,"replyTime":"2019-09-24T03:29:38.000Z","msg":"當年ROC點敗走"},"citedBy":3,"replyTime":"2019-09-24T03:32:16.000Z","msg":"佢自己退的<br />\n請睇中華民國退出聯合國告全國同胞書"},"citedBy":1,"replyTime":"2019-09-24T03:45:06.000Z","msg":"蔣介石真係鞭屍100次都唔夠"},"citedBy":2,"replyTime":"2019-09-24T03:47:49.000Z","msg":"係<br />\n如果仲keep住聯合國席位<br />\n臺灣今日未至於咁"},{"pid":"a19819af2cc7a2664c2e5e4e6da7f138b4070c78","tid":1590980,"uid":271434,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2019-09-24T03:48:01.000Z","msg":"借位post<br />\n<br />\n<br />\n（解密版歡迎轉載）核彈！大家咁做即刻可以令高鐵停駛、高鐵變廢鐵！<br />\n<a href=\"https://lih.kg/1589413\" data-auto-link target=\"_blank\">https://lih.kg/1589413</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<br />\n<span style=\"font-size: medium;\">美國已經通過新疆人權法，準備制裁涉及新疆集中營嘅人士。<br />\n<br />\n最近有黑客獲得片段（見post底部），顯示中國鐵路總公司協助當局運送新疆人去集中營，下圖嘅列車就係屬於中國鐵路公司嘅東風十一型，由中國中車製造，<span style=\"color: red;\">中鐵以及中車參與新疆鎮壓人權證據確鑿。</span></span><br />\n<br />\n<img src=\"https://na.cx/i/XRK38Uf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXRK38Uf.jpg&h=8d26b263&s={SIZE}\" /><img src=\"https://na.cx/i/3kHJpsA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3kHJpsA.jpg&h=b3eb88d4&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: large;\">影片中運轉新疆人入集中營嘅火車頭係同隸屬於中鐵嘅東風十一嘅證據，即是中國鐵路有份參與鎮壓維吾爾人</span>（借圖一張）<br />\n<br />\n<img src=\"https://na.cx/i/WXdsYWx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWXdsYWx.jpg&h=24e25904&s={SIZE}\" /><br />\n<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">至於香港嘅高鐵同埋直通車，大部分班次係中鐵負責</span></span><br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">要令香港高鐵全面停駛、直通車唔再入香港嘅方法係：</span></span><br />\n<br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: gold;\">將呢段中鐵協助中共運送新疆人入集中營嘅片send去美國，請求美國以《全球馬格尼茨基人權問責法案》制裁侵犯新疆人權嘅中國鐵路總公司，以及中車集團。</span><br />\n一旦美國通過咗制裁中鐵，<span style=\"color: gold;\">港鐵就唔可以繼續同中鐵合作，否則港鐵會受到美國嘅制裁，國際業務會立即停止。</span><br />\n<span style=\"color: red;\">如果中鐵受到制裁，以後隸屬港鐵嘅西九龍站再無列車前往中鐵嘅國內車站，香港高鐵即刻變成廢鐵！另外，直通車亦需要立即停駛！還香港人一條屬於香港人嘅東鐵！</span><br />\n<br />\n<span style=\"color: gold;\">至於如果美國能夠制裁埋中車，咁港鐵嘅國產車亦再無西方零件供應，要立即停駛</span><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n如果美國落實制裁嘅話，一定會重創港鐵！<br />\n<br />\n同樣，<span style=\"color: red;\">如果美國通過香港人權法，制裁香港警察，亦可以用同樣方法，請求美國制裁買協助運送警察及協助警察鎮壓嘅港鐵以及港鐵高層。</span>好多港鐵高層有海外資產，佢地將會嚴重受創！<br />\n<br />\n</span><br />\n<br />\n<br />\n\t<br />\n\t<a href=\"https://youtu.be/gGYoeJ5U7cQ\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FgGYoeJ5U7cQ&d=1Biu5Jcu4NfhTOeMSm0obkcTp%2BQsjpNju1TtMRGBB4E%3D&h=c2f299a9\" target=\"_blank\">https://youtu.be/gGYoeJ5U7cQ</a><br />\n\t<br />\n<br />\n<span style=\"font-size: large;\"><strong><span style=\"color: red;\">大家要趁美國通過制裁新疆，請求制裁埋中國鐵路公司，請大家盡量將呢個post廣傳開去，特別係俾文宣睇到，出poster、國際文宣<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n成功嘅話可就以停止香港高鐵、令港鐵承受巨額虧損、打倒中共嘅所謂新四大發明、打倒強國嘅一帶一路</span></strong><br />\n<br />\n<br />\n<strong><span style=\"color: red;\">請大家幫手發起白宮連署，就協助運送新疆人入集中營，請求美國制裁中國鐵路總公司</span></strong><br />\n<br />\n<span style=\"color: red;\">大家亦可以幫手推俾Facebook上嘅「作者」，俾佢想辦法出信去美國方面制裁中鐵</span></span><br />\n<br />\n<a href=\"https://m.facebook.com/yhmetblogspot/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2Fyhmetblogspot%2F&d=1Biu5Jcu4NfhTOeMSm0obkcTp%2BQsjpNju1TtMRGBB4E%3D&h=2e74bb78\" target=\"_blank\">https://m.facebook.com/yhmetblogspot/</a><br />\n<br />\n<br />\n<span style=\"font-size: x-large;\">核彈都唔割！<br />\n<span style=\"color: gold;\">光復香港！時代革命！</span></span>"},{"pid":"b649d6a8cb68fda5b19387781700d2bbc2582e7e","tid":1590980,"uid":282777,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-24T03:48:19.000Z","msg":"此回覆已被刪除"},{"pid":"4429c8fd2560ca7a80d0de82bea8484af74c522e","tid":1590980,"uid":282777,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-24T03:48:37.000Z","msg":"此回覆已被刪除"},{"pid":"ed384e160251e1b24a8a16e4b02f5ef5f507fd50","tid":1590980,"uid":121131,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-09-24T03:49:34.000Z","msg":"舊聞黎，最後中共屈服取消強加一帶一路字眼"},{"pid":"8e4685454118eb6d6c9d903a57ea17f162d667f7","tid":1590980,"uid":99962,"like":16,"dislike":0,"score":16,"quote":{"pid":"c8b0dd8b6476c1abcf4648ee30087c41badcab34","tid":1590980,"uid":41116,"like":8,"dislike":0,"score":8,"quote":{"pid":"9e7b8e9a95633f3e713cf76ea0a2c9894c60a4b2","tid":1590980,"uid":69568,"like":6,"dislike":0,"score":6,"quote":{"pid":"e34bdbcc879e16b72383e44fcd4c35d87895771f","tid":1590980,"uid":39365,"like":46,"dislike":1,"score":45,"citedBy":3,"replyTime":"2019-09-24T03:27:24.000Z","msg":"中共唔自己退出, 其他國家根本踢唔走佢, 同WTO一樣, 真係ON9制度"},"citedBy":2,"replyTime":"2019-09-24T03:29:38.000Z","msg":"當年ROC點敗走"},"citedBy":3,"replyTime":"2019-09-24T03:32:16.000Z","msg":"佢自己退的<br />\n請睇中華民國退出聯合國告全國同胞書"},"citedBy