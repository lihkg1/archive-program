2066280,"uid":317282,"like":0,"dislike":0,"score":0,"quote":{"pid":"973261576110b685058a8f632bef00ee828166ae","tid":2066280,"uid":54965,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-06-16T14:56:06.000Z","msg":"我覺得首先要剪指甲先 因為新手好易整親眼<br />\n之後用食指尖住掂住副con既3份1 將con既上半部分放上眼球先 再慢慢掂埋下眼球<br />\n<br />\nBtw我帶左好耐con都覺得除透明con好難<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" />帶就易啲"},"citedBy":0,"replyTime":"2020-06-16T15:27:48.000Z","msg":"我指甲本身唔長<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n除都難咁我點算<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"d97f3c6148bb5ce6fe9d1c69ef1b4e211f98669f","tid":2066280,"uid":238504,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T15:37:22.000Z","msg":"除先最痛苦"},{"pid":"2bcd80bf0e19af02e492bd0ffd7197158b04d531","tid":2066280,"uid":305742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T15:40:09.000Z","msg":"除30秒就得<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />第一次帶用左成個鐘"},{"pid":"5ca2981ef31cbfd9d61f1c2933e2685cd8e83428","tid":2066280,"uid":211005,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T15:40:58.000Z","msg":"滴保濕眼藥水拎個feel 習慣下會冇咁敏感"},{"pid":"bd75776f559d34b5f0e62d6a01cc083139e7022d","tid":2066280,"uid":66716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T15:41:34.000Z","msg":"試過除唔到 點搞<img src=\"/assets/faces/lm2/nosee.gif\" class=\"hkgmoji\" />"},{"pid":"acc892f6936ed7922de05e8ad3c0d63294f10b27","tid":2066280,"uid":271539,"like":0,"dislike":0,"score":0,"quote":{"pid":"d40a13278dedf08c46740f8879aade75214682d8","tid":2066280,"uid":317282,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2020-06-16T07:41:58.000Z","msg":"正常人平均半粒鐘就搞掂<br />\n我試左成粒鐘 試到隻眼有少少腫都試唔到<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" /><br />\n次次掂到眼球嘅時候都會反射動作成個人彈起身 跟住就戴唔到<br />\n想喊<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />各位可唔可以分享吓心得或者點樣容易啲戴嘅方法<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-06-16T15:43:42.000Z","msg":"都係個句 你要唔怕佢<br />\n你越驚就越戴唔到 隻眼會不停眨<br />\n仲有 佢教你個手勢你最好跟足"},{"pid":"61fee50090931525f47bfb0affa8dd014dd4c5a3","tid":2066280,"uid":201056,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T15:54:16.000Z","msg":"我新手個陣係眼鏡舖都搞左2個鐘<br />\n左右眼戴+除各1粒鐘<br />\n如果係女仔經常化妝畫眼線應該易好多 起碼冇咁驚隻手掂眼<br />\n不過克服到頭一兩次就得 練一個星期已經可以幾分鐘唔洗就搞掂晒"},{"pid":"647c4cbd1f16a819b2b0b99fe1acd8cda0dee930","tid":2066280,"uid":23197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T15:58:33.000Z","msg":"我第一次戴con除con都係1take過<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n我自己覺得你戴右眼果陣用左眼做主視眼就無咁驚"},{"pid":"788dfa888b334ec93b24fffd465a2da37b88da76","tid":2066280,"uid":206784,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-06-16T16:05:14.000Z","msg":"平時練下掂眼球真係有用<br />\n有時d眼線甩左會跌幾粒黑色入眼，我會拉低眼袋用手指點一下點番粒野出黎（記得要洗乾淨手先）<br />\n習慣左掂到眼球就會發覺好易戴con<br />\n戴嗰陣望住鏡入面既瞳孔係最好，如果掛住望副con你又唔慣掂眼球既應該會驚<br />\n<br />\n利申：第一次試戴con 10秒就戴好<br />\n除con就耐少少20秒<br />\n個視光師仲好懷疑我係咪第一次戴"},{"pid":"03d44e6355368544765459c4f50f54122d02c818","tid":2066280,"uid":57868,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-16T16:09:54.000Z","msg":"唔好驚 同自己講唔好驚之後兩隻手指用小小力壓隻con同時眨眼 隻con會痴住你隻手指就可以拎出嚟了"},{"pid":"12e5bf75e01e3474a134b343ad7af173c6fcf218","tid":2066280,"uid":57868,"like":0,"dislike":0,"score":0,"quote":{"pid":"03d44e6355368544765459c4f50f54122d02c818","tid":2066280,"uid":57868,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-16T16:09:54.000Z","msg":"唔好驚 同自己講唔好驚之後兩隻手指用小小力壓隻con同時眨眼 隻con會痴住你隻手指就可以拎出嚟了"},"citedBy":0,"replyTime":"2020-06-16T16:10:29.000Z","msg":"帶con一樣唔驚就得"},{"pid":"fda8002fe16f65581b6ac91064820049970aa878","tid":2066280,"uid":77905,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T16:11:27.000Z","msg":"本身咁撚抗拒<br />\n小心戴完好多麻煩嘢<br />\n戴唔到唔好勉強"},{"pid":"d4e8c0465126c97c80b5b07a02af6b0f9f18b3e0","tid":2066280,"uid":146464,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T18:49:36.000Z","msg":"頭幾次係咁上下啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f2a007acdd654122c4556fd471ebecb0d9e81158","tid":2066280,"uid":181940,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T19:01:01.000Z","msg":"戴除第一次搞左三粒鐘，之後仲搞到隻眼發炎眼皮腫咗，大細眼左幾日。"},{"pid":"397de0c0ad0ceddc597337fd9c42f71f652bafdd","tid":2066280,"uid":211496,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T19:07:07.000Z","msg":"用右手戴con  左手用撳實眼皮 要掂到眼睫毛 同埋肯定眼皮郁唔到 之後慢慢篤隻con入去<br />\n都係驚嘅話戴之前滴眼藥水<br />\n我第一次戴都用咗20分鐘 <br />\n如果除con嘅話朋友教我用棉花棒固定個con再用另外一隻手輕力除出嚟<br />\n（不過唔建議用工具戴/除con，始終都係用返自己手指最好，因為你控制到力度先唔會用錯力傷到隻眼）<br />\n我個陣用咗兩次棉花棒除Con之後就學識就咁用手除<br />\n用眼藥水可以等隻眼容易啲習慣 但平時唔好滴咁多<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"d2a8dff6f64e20ca5acdb36be6b6842fc034375f","tid":2066280,"uid":16250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T19:07:54.000Z","msg":"用手指幫手撐撚大隻眼 再輕輕一放"},{"pid":"f11a9b98329b451e95eb2ca2045d8033d9bc682c","tid":2066280,"uid":360850,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-16T19:08:40.000Z","msg":"戴右眼嗰陣望實鏡入面嘅左眼瞳孔<br />\n戴左眼就望右眼<br />\n咁就冇咁易眨眼<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0e79d7ff1ad0836530cf1c62a18c1e7648bdaaaa","tid":2066280,"uid":247799,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-06-16T19:25:05.000Z","msg":"之前去眼鏡鋪到試咗3個幾鐘都戴唔到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />搞到我唔敢再學戴con<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><br />\n後尾為咗克服塞嘢入眼嘅恐懼決定自己係屋企試下洗乾隻手之後用手指掂個眼球 然後過多幾日買咗盒con返屋企試 用咗45分鐘終於戴到<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n依家戴con已經戴到好熟手"}]}