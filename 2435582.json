26","tid":2435582,"uid":37235,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-11T10:30:11.000Z","msg":"輕輕一推"},{"pid":"b42308cddae9980ac4103c25b0a993ef4d625475","tid":2435582,"uid":393962,"like":0,"dislike":0,"score":0,"quote":{"pid":"d34d7024f03751ab85ddc9da48c218b0cd8b3c26","tid":2435582,"uid":37235,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-11T10:30:11.000Z","msg":"輕輕一推"},"citedBy":0,"replyTime":"2021-03-11T11:07:50.000Z","msg":"唔該巴打<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a7492d0c4dd1023dd582f588f94adccab1354606","tid":2435582,"uid":167178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-11T18:25:12.000Z","msg":"推一推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"cb6728d7789a4702b5427bebec3bed56dd957080","tid":2435582,"uid":393962,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-03-11T23:28:07.000Z","msg":"第四集<br />\n<br />\n於是～我本着神農嘗百草的心，皺着眉頭地去挑戰這顆可能令我再昏睡三個月的魚蛋。<br />\n<br />\n「哇屌!! 咁撚硬架!! 」我大聲地叫，連忙把這顆「魚蛋」吐出來～<br />\n<br />\n正確來說&mdash;&mdash;這是一個實心的球體，堅硬程度甚至比得上石頭，幾乎要把我的牙齒都咬碎&hellip;&hellip;<br />\n<br />\n「乞嚏!! 」當我正沉醉於研究這顆「魚蛋」之際，冷不勝防打了個噴嚏～<br />\n<br />\n不知道是不是家裏空無一人的情況，令我倍感寒意，氣溫彷如比昏迷前低了十幾度，全身上下一直在顫抖(我只穿了一件內衣，加上已經離開被窩) &mdash;&mdash;家裏總有着說不出的陰森感覺。<br />\n<br />\n於是，我在衣櫃拿出並穿上兩件大衣～此時我決定要儘快下樓一探箇中原因，因為這一切都來得太過不合理了!! <br />\n<br />\n於是我馬上衝出房門，這時，一個偌大的紙皮箱就擱在客廳內，就這樣堵在前往洗手間的路上，就正正擋住我梳洗出門的路。<br />\n<br />\n我極不情願的，大力踢了兩腳，踢開這個頗有重量的箱子，心裏想著～怎麼老豆會這樣的沒手尾?? <br />\n<br />\n對，老豆，一向收拾整齊，連半點灰塵都容不下的他，怎可能會把紙箱就這樣放在路邊?? <br />\n<br />\n這時，不安的心情再一次衝上我的心頭～<br />\n<br />\n我小心翼翼地打開紙箱，發現裏面是一個個奇怪的罐頭?! <br />\n<br />\n究竟他要這些罐頭來幹甚麼?? 正確來說，這不是老豆帶回來的～"},{"pid":"317921b9e3a3b5911e4901e25b3409d9d756803a","tid":2435582,"uid":342849,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-12T18:17:48.000Z","msg":"推一推<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n巴打加油<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"016a32a0d40a3a6d2992e46f20ae08b8e9f82202","tid":2435582,"uid":393962,"like":0,"dislike":0,"score":0,"quote":{"pid":"317921b9e3a3b5911e4901e25b3409d9d756803a","tid":2435582,"uid":342849,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-12T18:17:48.000Z","msg":"推一推<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n巴打加油<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-13T01:21:14.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"e6b3d1d8c863380d639eabfd537bcd1af960d6ed","tid":2435582,"uid":393962,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-13T01:23:01.000Z","msg":"就出第五集<br />\n呢邊既文其實高登篇文情節再深化版<br />\n加左唔少細節位"},{"pid":"8fcb9bfe0e27f44997e5d5bcafe2de812e36830c","tid":2435582,"uid":167178,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-13T16:12:12.000Z","msg":"推一推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"11db560686f27852281602f051deac176164f9e6","tid":2435582,"uid":393962,"like":0,"dislike":0,"score":0,"quote":{"pid":"8fcb9bfe0e27f44997e5d5bcafe2de812e36830c","tid":2435582,"uid":167178,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-13T16:12:12.000Z","msg":"推一推<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-14T02:21:15.000Z","msg":"唔該巴打<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"51b3ea7caec93ec0672346db799eb162484e46ab","tid":2435582,"uid":40723,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-16T12:45:53.000Z","msg":"輕輕一推"},{"pid":"6279ee5405ba625590d8db9963d3bc0c2df53e3d","tid":2435582,"uid":393962,"like":0,"dislike":0,"score":0,"quote":{"pid":"51b3ea7caec93ec0672346db799eb162484e46ab","tid":2435582,"uid":40723,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-16T12:45:53.000Z","msg":"輕輕一推"},"citedBy":0,"replyTime":"2021-03-16T15:59:41.000Z","msg":"聽朝出第五集"},{"pid":"bb75f7422a8436b3ca41fe51b34d78bf01ef5b67","tid":2435582,"uid":393962,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-17T10:21:52.000Z","msg":"第五集<br />\n<br />\n太奇怪，一切太奇怪了!! <br />\n<br />\n從我在街上暈倒，醒來竟然在冷冷清清、毫無人氣的家，又有一個個不知有甚麼作用的罐頭。太離奇～就像被綁架一樣，我寧願這一切只是一埸普通的綁架～難道外星人綁架我?!! 你真係白痴!! 你有甚麼價值?? <br />\n<br />\n我沒想太多，洗了個臉，穿多了幾件大衣便下樓了。<br />\n<br />\n「快手少少啦! 」我心裏暗自想着，這時我的不安再進一步提升，雙腳像被蟻咬一樣站不定，我看著手錶的秒針順時針地從入升降機的5字，一直轉著，偏偏遲遲未到平台。<br />\n<br />\n「叮～」這升降機門總算打開了，秒針轉了一個圈，再去到了9字，這一趟升降機旅程，大約花了80秒。<br />\n<br />\n我步出升降機門，步出好運中心，走到沙田商場群連接着的平台。<br />\n<br />\n我在黑夜中回望5樓的家，回望整棟好運中心，是清一色的黑，沒有任何一點的燈光，就一點也沒有! 轉眼間，整個沙田就只有路燈仍然亮着～<br />\n<br />\n太奇怪了，難道已經是午夜了，居民都把燈光關掉要好好入睡?? <br />\n<br />\n「可能就是這樣! 」我努力地安慰著自己，擺脫那恐懼～<br />\n<br />\n然而，手錶的提示響鬧正在響着，時針正在停在9字，旁邊的小格正顯示着am，代表現在是上午九時正!! <br />\n<br />\n「唔撚係呀&hellip;&hellip;」我暗暗吃了一驚，一屁股坐在平台上，望看漆黑的天空。<br />\n<br />\n「沙&mdash;&mdash;」<br />\n<br />\n在一片死寂之中，即使是一點聲音也顯得特別響亮，這裏有人，而且正在窺視著我&hellip;&hellip;"},{"pid":"a809e0a7192b52abc27eab67ffe6def58d55885b","tid":2435582,"uid":393962,"like":0,"dislike":0,"score":0,"quote":{"pid":"bcda567c456363f42beb8cd17076fceeb8ec12af","tid":2435582,"uid":164598,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-07T10:58:07.000Z","msg":"啲"},"citedBy":1,"replyTime":"2021-03-17T10:22:32.000Z","msg":"李瑜巴早晨<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"0c419bdcb66ca9d642f22d47a81a268e1f9c7c84","tid":2435582,"uid":164598,"like":0,"dislike":0,"score":0,"quote":{"pid":"a809e0a7192b52abc27eab67ffe6def58d55885b","tid":2435582,"uid":393962,"like":0,"dislike":0,"score":0,"quote":{"pid":"bcda567c456363f42beb8cd17076fceeb8ec12af","tid":2435582,"uid":164598,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-07T10:58:07.000Z","msg":"啲"},"citedBy":1,"replyTime":"2021-03-17T10:22:32.000Z","msg":"李瑜巴早晨<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-17T10