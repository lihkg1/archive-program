f4c2ac2a68b29d83d","tid":580613,"uid":61631,"like":20,"dislike":1,"score":19,"quote":{"pid":"e3713722def53375dc5025911910520a1cb1bad1","tid":580613,"uid":69886,"like":0,"dislike":16,"score":-16,"citedBy":2,"replyTime":"2018-03-04T16:07:21.000Z","msg":"成班保險狗<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-04T16:11:08.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />  係咪冇朋友到咁 定未去過旅行"},{"pid":"c45b657493e1038ba0947fecf776228944a63df7","tid":580613,"uid":23485,"like":12,"dislike":0,"score":12,"citedBy":0,"replyTime":"2018-03-04T16:16:02.000Z","msg":"要買啊<br />\n我岩岩旅行完返來，好彩有買旅遊保<br />\n今次唔好彩撞左車要賠錢<br />\n如果無買保險真係喊出來<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"89f823d615ebf8125035cb12ba0f38f28d3508a9","tid":580613,"uid":77201,"like":0,"dislike":5,"score":-5,"citedBy":0,"replyTime":"2018-03-04T16:19:57.000Z","msg":"睇你點玩<br />\n如果大部分時間都只係搭捷運行下街又唔會買貴野咁我覺得無謂<br />\n但你話唔係既都買份求安心囉<br />\n<br />\n利申每次獨遊如果唔係強制既話都冇買"},{"pid":"874b6f62a57a100f739459f8e508cd5f35709eca","tid":580613,"uid":122892,"like":6,"dislike":1,"score":5,"citedBy":0,"replyTime":"2018-03-04T16:22:12.000Z","msg":"此回覆已被刪除"},{"pid":"b214130c1ee045639ba3d52c30680767754a5977","tid":580613,"uid":18720,"like":4,"dislike":2,"score":2,"citedBy":0,"replyTime":"2018-03-04T16:27:32.000Z","msg":"千其咪撚買呀<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n你全家啲賤命唔值錢<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 有咩急病咪一萬幾千睇個醫生囉 又唔係比唔起<br />\nflight/行李delay唔緊要啦 反正你地啲時間都唔值錢<br />\n唔見相機/電話呢啲輕鬆啦<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /> 比盡咪一萬幾千咋嘛<br />\n<br />\n千其唔好買旅遊保<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"1d16e5588cfaf827d580033a2075125f9486225f","tid":580613,"uid":173133,"like":0,"dislike":5,"score":-5,"citedBy":2,"replyTime":"2018-03-04T16:38:55.000Z","msg":"因為我之前跟團買旅遊保，好好彩都未出過事，就覺得好似買黎都冇用<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n如果真係要買，買邊間好？又平又好<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\n可以比小妹參考下，Thanks<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d46557e10ee75cb6fa967e8f17878736d4963dba","tid":580613,"uid":51753,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-04T16:39:37.000Z","msg":"所以話呢"},{"pid":"0859380899591c9504199e4c0b27eb08f551f146","tid":580613,"uid":173133,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-03-04T16:41:15.000Z","msg":"同埋小妹岩岩考完車，Fail左，所以想慳慳地自由行<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"dd74d579e880f78e454f4ace8e7b88828bede52c","tid":580613,"uid":22558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-04T16:42:22.000Z","msg":"有買開保險 就搵番經紀買啦<br />\n<br />\n中銀上網投保果啲就算把啦 出事果陣搵邊個？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4d77adefd756033da7d07b6e1a56c3f1dc921c63","tid":580613,"uid":22558,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-03-04T16:43:23.000Z","msg":"<blockquote>同埋小妹岩岩考完車，Fail左，所以想慳慳地自由行<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /></blockquote><br />\n貴極咪幾百蚊 呢啲錢慳得架咩？<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"75ed947872ba782302a01b38cb73807c0cbb11da","tid":580613,"uid":105041,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-04T16:44:42.000Z","msg":"旅遊保真係唔好慳"},{"pid":"9f7ea1cdc16587a05061a788fd0748b2c0a8b5a5","tid":580613,"uid":173133,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2018-03-04T17:17:16.000Z","msg":"Love All 巴絲打，咁我再睇完波，再Google 下買邊間旅遊保好<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"b9e29888495474dfaa0a932b2dd7ff9626e1b194","tid":580613,"uid":4142,"like":1,"dislike":0,"score":1,"quote":{"pid":"9f7ea1cdc16587a05061a788fd0748b2c0a8b5a5","tid":580613,"uid":173133,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2018-03-04T17:17:16.000Z","msg":"Love All 巴絲打，咁我再睇完波，再Google 下買邊間旅遊保好<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-04T17:47:13.000Z","msg":"保險唔好慳<br />\n最好出發前幾星期買定先<br />\n<br />\n試過出發前一日做運動斷腳<br />\n乜都claim 哂返黎<br />\n冇買既話機票酒店加加埋埋成五千就咁拜拜 <br />\n你唔用果陣就冇用 用果陣就好有用<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"9050f6c739eed71761581d883e8e4898ebbb0840","tid":580613,"uid":147770,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-04T17:51:41.000Z","msg":"如果係一定要買就立咗法例強制市民買啦"},{"pid":"80b892cc70bf1f8a5160f5411194e568dc537d56","tid":580613,"uid":42881,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2018-03-04T18:04:07.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/daily/article/20150312/19073128\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20150312%2F19073128&d=v5gXNw8t0g5mCxe%2BPAM8gZ4%2BuNhYgvPKbWZYs3KJomg%3D&h=f56cf843\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20150312%2F19073128&h=867a854b\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20150312/19073128</a><br />\n<br />\n<br />\n遊沖繩食牛舌<br />\n女子鯁喉命危<br />\n<br />\n【本報訊】三十七歲的玩具採購員陳愛玲上月中赴日本沖繩度歲，年初一品嚐日式燒牛舌時鯁喉昏迷，送院期間心跳曾停頓三分鐘，在當地醫院救治二十一天，現情況危殆。<strong><span style=\"color: red;\">由於她無買旅遊保險，當地住院醫療開支高達每天一萬港元</span></strong>，家人支付十萬元醫療費後已山窮水盡，正四處求助，盼盡早將她接返港治療。七十二歲的陳母哀痛地說：「希望善心人幫幫忙，等妹妹可以快啲返嚟香港。」"},{"pid":"ac3c9cc7d5e9e860ea89f442d116512cfbdc5654","tid":580613,"uid":6833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-05T04:20:31.000Z","msg":"一定要買"},{"pid":"2fdcd4801414baafd0a3c036179a3bcd6e68b09f","tid":580613,"uid":73089,"like":0,"dislike":0,"score":0,"quote":{"pid":"80b892cc70bf1f8a5160f5411194e568dc537d56","tid":580613,"uid":42881,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"201