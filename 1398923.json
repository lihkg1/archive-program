c985fdd30a5680d90","tid":1398923,"uid":282445,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-03T03:57:47.000Z","msg":"同事send緊封信去ceo blog<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"9d4a0a3cdd2e9aa9c449e62d852f30b237ce3c44","tid":1398923,"uid":282445,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-03T04:00:48.000Z","msg":"馬會保安好野<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n據了解，屬前警官的馬會保安及誠信審查部總監蒲汝傑（Martin Purbrick）今日向其保安部門發信，指就處理員工請假或病假時，若有員工在工作日需出席任何活動，可循正常程序告假；若員工生病或感到不適而需告假一天，則毋須遞交病假紙，信末則以中文字寫上「加油 香港」四字。<br />\n<br />\n<a href=\"https://s.nextmedia.com/realtime/a.php?i=20190803&amp;s=6996647&amp;a=59891433\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fs.nextmedia.com%2Frealtime%2Fa.php%3Fi%3D20190803%26s%3D6996647%26a%3D59891433&d=JkVIzhDRZadGdMc0KemjDUB1UtkZy1G9%2FYekDAkGV2Y%3D&h=228d8775\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fs.nextmedia.com%2Frealtime%2Fa.php%3Fi%3D20190803%26s%3D6996647%26a%3D59891433&h=8afb058d\" target=\"_blank\">https://s.nextmedia.com/realtime/a.php?i=20190803&amp;s=6996647&amp;a=59891433</a>"},{"pid":"f3bda03ceeda22ec45ac4a2adea4e22169c65a2b","tid":1398923,"uid":282445,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-03T04:01:23.000Z","msg":"我要罷工"},{"pid":"7a49679357cfbb4741a7290f98b00de893c756b3","tid":1398923,"uid":282445,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-03T04:02:08.000Z","msg":"我要罷工"},{"pid":"509b686f1b57dd5c4642835ca7a173c5cb552c7a","tid":1398923,"uid":282445,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-03T04:02:20.000Z","msg":"我要罷工"},{"pid":"1b699337f8e613dfc7502339584b7a75097cb98b","tid":1398923,"uid":282445,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-03T04:02:31.000Z","msg":"我要罷工"},{"pid":"95f038f9d