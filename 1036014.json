-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FC48BYGW.jpg&h=93b6380c&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-02-25T06:17:19.000Z","msg":"<img src=\"http://static.stheadline.com/stheadline/inewsmedia/20171208/_2017120818464239231.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.stheadline.com%2Fstheadline%2Finewsmedia%2F20171208%2F_2017120818464239231.jpg&h=56dbcea2&s={SIZE}\" /><br />\n<br />\n<img src=\"https://cdn.thestandnews.com/media/photos/cache/E2E1788EE3C9FB2BB561E3F5886D16F3_hNVf1_1200x0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.thestandnews.com%2Fmedia%2Fphotos%2Fcache%2FE2E1788EE3C9FB2BB561E3F5886D16F3_hNVf1_1200x0.jpg&h=f3d28457&s={SIZE}\" /><br />\n<br />\n<img src=\"http://orientaldaily.on.cc/cnt/news/20100527/photo/0527-00176-014b1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Forientaldaily.on.cc%2Fcnt%2Fnews%2F20100527%2Fphoto%2F0527-00176-014b1.jpg&h=06307b0e&s={SIZE}\" />"},{"pid":"7fbd40ffd8d32f424ffcaca35fc07593e880ce94","tid":1036014,"uid":216032,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-02-25T06:21:36.000Z","msg":"跑道都填唔到 重話要填個人工島<br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"eb0d6970a685a54ebdf8b54ba7818e8786bd364f","tid":1036014,"uid":35430,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-25T06:25:14.000Z","msg":"咁個千4億去左邊"},{"pid":"0022d8a95d25d9050ca362bff7737249917464cf","tid":1036014,"uid":61954,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-25T06:27:23.000Z","msg":"都話起三跑on9㗎啦"},{"pid":"d192f6e8807c9c12befdf29b9daa46732020a01c","tid":1036014,"uid":52946,"like":0,"dislike":0,"score":0,"quote":{"pid":"7fbd40ffd8d32f424ffcaca35fc07593e880ce94","tid":1036014,"uid":216032,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-02-25T06:21:36.000Z","msg":"跑道都填唔到 重話要填個人工島<br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-02-25T06:35:31.000Z","msg":"就係<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"f7d37c705493d6867c6bf85e0384885b550bc691","tid":1036014,"uid":12994,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-25T10:46:05.000Z","msg":"一日美國唔制裁埋香港<br />\n一日都有水過比大陸"},{"pid":"18c11bcf0e597d56e0bea97450a298b269f60092","tid":1036014,"uid":41116,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-25T11:17:31.000Z","msg":"人地以前移山填海係有理由嘅<br />\n買砂<br />\n買得幾多"}]}