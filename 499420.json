16%2F04%2F26%2Fjapan-youtuber-prowerstling-shibatar-zz%2F92346%2Fnews_report&d=QityVE64U90TG%2BhHdk7iNW6tz0R9Svbxs0EcWe5CwMI%3D&h=c21bc6ec\" data-auto-link target=\"_blank\">https://stoneip.info/2016/04/26/japan-youtuber-prowerstling-shibatar-zz/92346/news_report</a>"},{"pid":"a9866a31e334025dbc668174db4e5725c805552d","tid":499420,"uid":148093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-14T19:15:06.000Z","msg":"冇人有<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"e218a48b3802e20b81676181419d647ff8fba538","tid":499420,"uid":148093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-14T19:15:18.000Z","msg":"<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"f098386842e57c526e2466259adbaa39a6c5abfb","tid":499420,"uid":148093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-14T19:15:28.000Z","msg":"1"},{"pid":"8e65bc096da9fcf26496b4d85c37623c22aa11d6","tid":499420,"uid":148093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-14T19:15:38.000Z","msg":"2"},{"pid":"f43d293df4b79ccbcf54d1355569f2409520b8d2","tid":499420,"uid":148093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-14T19:15:52.000Z","msg":"3"},{"pid":"0ad36aa315a7e9824e4697806bba36a5035a5915","tid":499420,"uid":148093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-14T19:16:06.000Z","msg":"4"},{"pid":"441c805f0e7c0812598519e8b52183afda94a63c","tid":499420,"uid":148093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-14T19:16:16.000Z","msg":"5"},{"pid":"a3a4e8819b4b83bcde0281f0a6e6bdebeb599954","tid":499420,"uid":148093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-14T19:16:31.000Z","msg":"6<img src=\"/assets/faces/normal/bouncer.gif\" class=\"hk