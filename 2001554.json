faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"0d3939b39c80c44b3facdcb60f83cd6338311152","tid":2001554,"uid":59818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-04T16:04:26.000Z","msg":"有道理 就算真係要退都可以上下初選論壇先"},{"pid":"1ebbfe13f075ecb788f853cb4b39be883f53b4d9","tid":2001554,"uid":109462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-04T16:09:54.000Z","msg":"自推十<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"5ed47b2a055be4cf82a298f3585370d14f25b394","tid":2001554,"uid":109462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-04T16:15:43.000Z","msg":"自推十一<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"c27a9018b86439aa94fe1c29a25c160589d9bbd9","tid":2001554,"uid":109462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-04T16:19:50.000Z","msg":"自推十二<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d5a33c74026aca0d12a21ecd680892a1e71a3fb8","tid":2001554,"uid":109462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-04T16:24:28.000Z","msg":"自推十三<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"df0083073cc41a81cf50ec5a9a2947ff60b093df","tid":2001554,"uid":101392,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-04T17:43:28.000Z","msg":"李傲然同埋余德寶都會各自支持返光譜相近嘅人初選 集中票源<br />\n相反 如果繼續出選 同光譜嘅人票源被分薄<br />\n可能令相同光譜嘅人一個都入唔到圍"},{"pid":"78fcfdd0eebe589901140c26c1845ff559b5c857","tid":2001554,"uid":109462,"like":0,"dislike":0,"score":0,"quote":{"pid":"df0083073cc41a81cf50ec5a9a2947ff60b093df","tid":2001554,"uid":101392,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-04T17:43:28.000Z","msg":"李傲然同埋余德寶都會各自支持返光譜相近嘅人初選 集中票源<br />\n相反 如果繼續出選 同光譜嘅人票源被分薄<br />\n可能令相同光譜嘅人一個都入唔到圍"},"citedBy":0,"replyTime":"2020-05-04T19:16:09.000Z","msg":"如果佢哋有咁嘅安排都係好事，我擔心嘅係會造成骨牌效應，對於其他地區／其他光譜而暫時落後嘅擬參選人帶來輿論壓力，逼佢地「大局為重」提早退出⋯⋯"},{"pid":"0fc4f01bef2d457cf0471f57bfbb544e766a7253","tid":2001554,"uid":28818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-04T23:10:41.000Z","msg":"屬於香港人嘅書店<br />\n<a href=\"https://lih.kg/2000687\" data-auto-link target=\"_blank\">https://lih.kg/2000687</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"a77e7ab6e13494171a0de85f3a14755e549c248f","tid":2001554,"uid":28818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-04T23:11:18.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"29b8499d20a77d0a49f77329430d6f96168fdc70","tid":2001554,"uid":242998,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-04T23:12:55.000Z","msg":"未初選你又知黃碧雲贏硬？"},{"pid":"06cbd38d6914a6d7c3194aeb64f5150466626f57","tid":2001554,"uid":109462,"like":0,"dislike":0,"score":0,"quote":{"pid":"29b8499d20a77d0a49f77329430d6f96168fdc70","tid":2001554,"uid":242998,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-04T23:12:55.000Z","msg":"未初選你又知黃碧雲贏硬？"},"citedBy":0,"replyTime":"2020-05-05T05:11:43.000Z","msg":"我就係想叫所有擬參選人堅持到初選，唔好形成骨牌效應、受到壓力自己提早退出，搞到最後變成冇初選、冇競爭嘅「全民擁戴」式推出候選人；因為如果大家喺有初選之前就係咁退出，最後剩返嘅必然只會係大黨嘅代表"},{"pid":"7b122fbc054deca39511f33a1d348f155592b093","tid":2001554,"uid":109462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-05T05:30:33.000Z","msg":"自推十四<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"}]}