service-hk.net%2Fupload%2F2018%2F07%2F27%2F090434_78724d9f458accd121671845955b274c.png&h=0a00d344&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/07/27/090437_a18a2f28454adf3108c1a343fbdd9337.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F07%2F27%2F090437_a18a2f28454adf3108c1a343fbdd9337.png&h=8e5e3bad&s={SIZE}\" /><br />\n<br />\n咁樣囉 <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"5ccc3b2fc730e13f2039673e7acb73b1d3e9eb45","tid":756673,"uid":196829,"like":0,"dislike":0,"score":0,"quote":{"pid":"67bee8f73cf5707a7f51dc7ca6f74aab7c92ed45","tid":756673,"uid":181040,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-26T22:08:55.000Z","msg":"搭單問句 樓主部車好唔好力<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-27T01:06:11.000Z","msg":"都幾好架 <br />\n最快可以開到120-130km/h"},{"pid":"9a7563139de25a053da465a49c87c074bcc61f85","tid":756673,"uid":58987,"like":0,"dislike":0,"score":0,"quote":{"pid":"6ce8c85f9a3b4a7ba6fc9b7df9845b9fdb379a20","tid":756673,"uid":92690,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-07-26T19:07:30.000Z","msg":"千其唔好去大角咀力恆，黑店<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-27T03:23:50.000Z","msg":"點黑法？"},{"pid":"e626a72b4e8e29ed131d52476d50ec7cbcd676cc","tid":756673,"uid":92690,"like":0,"dislike":0,"score":0,"quote":{"pid":"9a7563139de25a053da465a49c87c074bcc61f85","tid":756673,"uid":58987,"like":0,"dislike":0,"score":0,"quote":{"pid":"6ce8c85f9a3b4a7ba6fc9b7df9845b9fdb379a20","tid":756673,"uid":92690,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-07-26T19:07:30.000Z","msg":"千其唔好去大角咀力恆，黑店<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-27T03:23:50.000Z","msg":"點黑法？"},"citedBy":1,"replyTime":"2018-07-27T03:58:09.000Z","msg":"早幾年炒左車，我去換fairing噴油缸, 開頭話二千幾攪掂，之後埋單四千幾(當時市價平均35xx)。又應承幫我痴隔熱棉又無痴到，揸返屋企成個肚兜熔左。<br />\n<br />\n之後問其他車房話未試過有呢種情況，話佢係淘寶訂最垃圾果種fairing先會熔。手工垃圾到震，攞d生銹鋼牙羅絲用電批直接上，鑽穿埋fairing。油缸淨係噴黑色都噴到一達二達，間野主力仲要係做噴油...<br />\n<br />\n最賤格係佢攪左成兩月都未攪掂都算，攪掂果日佢唔夠位放車，迫我一定要即日攞車，恐嚇我唔攞就會花，果日仲要落大雨，加上要搵人車埋d舊原裝fairing, 好彩臨急臨忙搵到有fd得閒幫到手車，但攪到欠左人地一個人情。攞車果陣成架車濕晒，佢就攞佢掛頸用黎抺汗既臭毛巾同我捽，仲要有沙既，一抺就有幾條花痕<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"5b265ddec7c47ebc6664bbd74558a20302d37893","tid":756673,"uid":89801,"like":0,"dislike":2,"score":-2,"quote":{"pid":"5ccc3b2fc730e13f2039673e7acb73b1d3e9eb45","tid":756673,"uid":196829,"like":0,"dislike":0,"score":0,"quote":{"pid":"67bee8f73cf5707a7f51dc7ca6f74aab7c92ed45","tid":756673,"uid":181040,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-26T22:08:55.000Z","msg":"搭單問句 樓主部車好唔好力<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-27T01:06:11.000Z","msg":"都幾好架 <br />\n最快可以開到120-130km/h"},"citedBy":1,"replyTime":"2018-07-27T05:12:05.000Z","msg":"300cc都係得120-130？"},{"pid":"45c3f4a58da9dcf63d39715ce0d1c42126097b11","tid":756673,"uid":89801,"like":0,"dislike":0,"score":0,"quote":{"pid":"c21c9dc349df711b0547a90725dcf5241dd0e28f","tid":756673,"uid":196829,"like":0,"dislike":0,"score":0,"quote":{"pid":"8e6ad61bd8ea50c04b2a8b7f54868461b50a034c","tid":756673,"uid":89801,"like":0,"dislike":0,"score":0,"c