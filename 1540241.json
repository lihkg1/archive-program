Y.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1ktasvY.jpg&h=e8e5ebbd&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/WwTmzaZ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWwTmzaZ.jpg&h=1a577aad&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/a889SFe.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fa889SFe.jpg&h=3fb438bf&s={SIZE}\" /><br />\n<br />\n機場壓力測試，其實係連「機場」都唔需要入的<br />\n<a href=\"https://lih.kg/1531743\" data-auto-link target=\"_blank\">https://lih.kg/1531743</a><br />\n<br />\n- 分享自 LIHKG 討論區"},{"pid":"66562671a9cd7936162eebaa6a4a81b51d4ed0c0","tid":1540241,"uid":13349,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T11:18:44.000Z","msg":"#FiveDemands<br />\n星期日 美領見"},{"pid":"20e7adb394bb1ea7250543caecc2e1120b92ec6d","tid":1540241,"uid":89641,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T11:19:35.000Z","msg":"Got it!<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"7ba89bdd7cbedb0a6c7e0d788e935e071791533a","tid":1540241,"uid":19278,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T11:19:54.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"50953c6d42797a14fcc0d1e4e2870cf9f62284e8","tid":1540241,"uid":4931,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T11:21:01.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>今日若果我哋接受政府條件，我哋受傷及被捕手足不會原諒我哋。<br />\n<br />\n五大訴求，缺一不可</strong></span></span><br />\n<br />\nThe FIVE demands of the protest<br />\n<br />\n1. Full withdrawal of the extradition bill <br />\n<br />\n2. A commission of inquiry into alleged police brutality <br />\n<br />\n3. Retracting the classification of protesters as &ldquo;rioters&rdquo; <br />\n<br />\n4. Amnesty for arrested protesters <br />\n<br />\n5. Dual universal suffrage, meaning for both the Legislative Council and<br />\nthe Chief Executive <br />\n<br />\nFIVE DEMANDS,<br />\nNOT ONE LESS.<br />\nLIBERATE HONG KONG,<br />\nREVOLUTION OF OUR TIMES."},{"pid":"dea8607992cf99bd989af506a025793b7030136c","tid":1540241,"uid":72800,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T11:22:41.000Z","msg":"<div style=\"text-align: center;\"><span style=\"color: red;\">港共殺人政權企圖以<strong>錄音、撤回、學季開始</strong><br />\n轉移<strong><span style=\"font-size: x-large;\">太子地鐵傷亡、<br />\n六警壓脊椎休克 <span style=\"color: teal;\">至今嚴重昏迷</span>、<br />\n新屋嶺、民主人權法案、<br />\n臥底實彈、武警滲透、<span style=\"color: green;\">清朝債主權問題</span><br />\n</span></strong></span>連串<span style=\"font-size: xx-large;\"><strong>核彈</strong></span><span style=\"color: red;\">事件焦點<br />\n醒呀大家 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /> <span style=\"font-size: xx-large;\">政府帶緊風向</span><br />\n背後繼續大清算 入獄 利刑 一年後被失蹤</span></div><br />\n<br />\n<br />\n<pre><code data-type=\"\">林鄭錄音：事件現時已經上升至「國家主權及國家安全的層次，\n加上世界兩大經濟體前所未有的張力」，她可以做的已經非常少。</code></pre><br />\n<br />\n<div style=\"text-align: right;\"><blockquote><strong><span style=\"color: orange;\"><span style=\"font-size: large;\">英、美領事館請願 大遊行</span></span></strong><br />\n審視中英聯合聲明 法定性<br />\n中共正統性<br />\n中共毀約 無視國際社會<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: blue;\">請求國際介入香港前途</span></span></strong> <br />\n<strong><span style=\"font-size: large;\"><span style=\"color: blue;\">施壓制裁港府 還港人雙普選 <br />\n協助制定民主進程</span></span></strong><br />\n香港人道災難 高壓滅聲 白色恐怖 <br />\n執法機器無法無天 受命中共 <br />\n<span style=\"font-size: large;\">港府管治班子失去自治權 聽命中央</span><br />\n實彈恐怖 威嚇扼殺<span style=\"font-size: x-large;\">民主自由</span>現代普世價值<br />\n<strong>人權民主法案 事在必行</strong></blockquote></div><br />\n<br />\n#FiveDemands<br />\n#1down4togo<br />\n<br />\n<pre><code data-type=\"\">暗黑兵法劇本 出沒注意：\n\n沒收gear 未來兩星期大量武警喬裝示威者 嫁禍衝擊\n內部分化示威者、\n酷刑凌虐威嚇被捕人士、\n邊緣打壓香港 渲染港獨 阻抗爭之風蔓延內陸、\n假新聞、擺拍、編輯、洗腦文宣製造風向 污名化運動、\n暴力鎮壓 拘捕 扣留 私刑 企圖瓦解前線、\n文宣 抹黑 嫁禍 插贜 示威者、\n暗殺 第一滴血 企圖逆轉民意 國際譴責、\n市民絕望噤聲 憤怒冷卻、\n中立派 賺錢派 政治疲勞、\n鼓吹經濟下滑風向 富豪商家屈服 加速瓦解、\n學季始開，拖延 分散 擊破、\n白色恐怖、清除異己、染紅香港\n\n拖字訣 雨傘結局 ⋯</code></pre><br />\n<br />\n<div style=\"text-align: center;\"><span style=\"color: blue;\"><strong>這不只是反修例活動<br />\n這是屬於香港人的<span style=\"font-size: xx-large;\">時代革命</span></strong></span></div><br />\n<div style=\"text-align: center;\"><strong><span style=\"font-size: xx-large;\">流水革命</span></strong></div>"},{"pid":"45169886d47ff7c79e0f304a6b32cd42a371ff8f","tid":1540241,"uid":122275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T11:23:31.000Z","msg":"Twitter reddit要人"},{"pid":"952eb38ce29a9d7906c0dd8c54968985effbec21","tid":1540241,"uid":114,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T11:27:15.000Z","msg":"<img src=\"https://na.cx/i/QD0wnYH.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQD0wnYH.png&h=c78406d2&s={SIZE}\" />"}]}