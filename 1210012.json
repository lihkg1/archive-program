46621,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-12T19:12:29.000Z","msg":"邊套警匪片係賊贏<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"cb6948fd9a3f1465e246e3f0995b6608759828f2","tid":1210012,"uid":149973,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f1eb539ca3f5b72e8a75a96a943f915f85a294f","tid":1210012,"uid":146621,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-12T19:12:29.000Z","msg":"邊套警匪片係賊贏<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-12T19:19:36.000Z","msg":"罷睇罷看罷拍<br />\n全部假<br />\n警察邊有正義救市民 打市民就真<br />\n<br />\n拍消防好過"}]}