lass=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"a348117000a0adf1d631d12b439c926b8c1cd646","tid":2218301,"uid":229502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-26T06:21:36.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e8cf39c76063a886a46664678239b979ad15b590","tid":2218301,"uid":229502,"like":0,"dislike":0,"score":0,"quote":{"pid":"54cf834e45c6ead72e6de74e1e86e22b1f18ed3c","tid":2218301,"uid":135081,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-09-26T06:21:33.000Z","msg":"認真po要推<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-26T06:21:51.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"8222058ae390ed411ac288f4213b8f52d00bf5ea","tid":2218301,"uid":229502,"like":0,"dislike":0,"score":0,"quote":{"pid":"54cf834e45c6ead72e6de74e1e86e22b1f18ed3c","tid":2218301,"uid":135081,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-09-26T06:21:33.000Z","msg":"認真po要推<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/f