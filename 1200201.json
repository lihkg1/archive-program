b2858ac2bcb5818b9d396250c9e90045887","tid":1200201,"uid":115579,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-10T17:07:52.000Z","msg":"唔好呀<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n真心呢度死左都冇人知"},{"pid":"4ab94b3e687542955bfecec0be7e73751e8d17ed","tid":1200201,"uid":32511,"like":4,"dislike":34,"score":-30,"quote":{"pid":"132b7b2858ac2bcb5818b9d396250c9e90045887","tid":1200201,"uid":115579,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-06-10T17:07:52.000Z","msg":"唔好呀<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n真心呢度死左都冇人知"},"citedBy":0,"replyTime":"2019-06-10T17:12:49.000Z","msg":"點可以輸比祖先睇<img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/hate.gif\" class=\"hkgmoji\" /><br />\n<br />\n約前218年[1]，秦始皇派屠睢率50萬秦軍分五路進攻嶺南和閩越地區的百越族&mdash;&mdash;南越、西甌、駱越和閩越。秦始皇派史祿率領士兵在湘水和灕水之間修築了靈渠，保障了秦軍的後勤供給。秦軍進攻西甌初時很順利，殺了西甌的首領譯吁宋。但西甌的越人不肯屈服，逃入叢林推選出新的將領與秦軍對抗。後來還發動夜襲大破秦軍，殺死秦軍統帥屠睢。"},{"pid":"e9a63eda26cc85b84f890a6cd74dbdf5ff845e59","tid":1200201,"uid":249885,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-10T17:13:32.000Z","msg":"鳩up"},{"pid":"8ccffa039eee3adfacfdfe69da8733a363284ff1","tid":1200201,"uid":56015,"like":0,"dislike":0,"score":0,"quote":{"pid":"824cee90acb7178b55adef97e1fde5518646d6a3","tid":1200201,"uid":116289,"like":162,"dislike":1,"score":161,"citedBy":2,"replyTime":"2019-06-10T16:58:33.000Z","msg":"你條撚樣次鳩次出新聞都冇source<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-10T17:15:06.000Z","msg":"咪就係"},{"pid":"99649b14e58b7c005deececb20b65e3458aa9055","tid":1200201,"uid":45910,"like":347,"dislike":1,"score":346,"quote":{"pid":"39ae37b8f256b676a9619fc4906da44fd0c95664","tid":1200201,"uid":16061,"like":787,"dislike":14,"scor