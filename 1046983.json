e":"2019-03-05T01:23:54.000Z","msg":"條友咁似警訊d壞人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-05T01:27:13.000Z","msg":"樓主作故仔啦"},{"pid":"4dc95dfef254ca7d673df0a7b9a524aa20b36e5a","tid":1046983,"uid":37668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-05T01:35:58.000Z","msg":"俾人呃左都話自己醒目<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"88fa40e5bc525140edd682640a6b4dc86f2ac206","tid":1046983,"uid":71712,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-05T01:40:31.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3ae247c70d0be1b9860774f11aaa5ebf04f992f0","tid":1046983,"uid":3369,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-05T01:41:42.000Z","msg":"呢個唔係Gay佬黎咩<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"60d799b7fc7c4dbb0d4aba685565b8fd40aee0d3","tid":1046983,"uid":82398,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-03-05T01:41:48.000Z","msg":"我岩岩撞到佢 我幫你捉左佢了<img src=\"https://img.eservice-hk.net/upload/2019/03/05/094116_f14c109765fec197624a7fb7ccd9bf94.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F03%2F05%2F094116_f14c109765fec197624a7fb7ccd9bf94.png&h=ad1ad0f4&s={SIZE}\" />"},{"pid":"3698b4faa150df8d9b83af80198d8fdc5163641d","tid":1046983,"uid":11840,"like":0,"dislike":0,"score":0,"quote":{"pid":"3ae247c70d0be1b9860774f11aaa5ebf04f992f0","tid":1046983,"uid":3369,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-05T01:41:42.000Z","msg":"呢個唔係Gay佬黎咩<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-05T03:40:01.000Z","msg":"尖尖maymay"},{"pid":"5ee4dc0fd14bb1e776bc9c217468fdc80d73cfaf","tid":1046983,"uid":173271,"like":0,"dislik