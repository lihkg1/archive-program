\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DTaJ3QSyi_aU&d=5AUjfk%2BhgFT%2FKzSacqcGpIVlFhl8e2VpHQ9vpRm7Uxg%3D&h=ae2301ed\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=TaJ3QSyi_aU</a><br />\n片段二<br />\n<a href=\"https://m.facebook.com/groups/803879953032830/permalink/2552993321454809\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2Fgroups%2F803879953032830%2Fpermalink%2F2552993321454809&d=5AUjfk%2BhgFT%2FKzSacqcGpIVlFhl8e2VpHQ9vpRm7Uxg%3D&h=e98a26ed\" data-auto-link target=\"_blank\">https://m.facebook.com/groups/803879953032830/permalink/2552993321454809</a>"},"citedBy":0,"replyTime":"2019-11-02T17:36:19.000Z","msg":"推啊 做野"},{"pid":"23d64ab7ce19502aa4ee7f232358f85f691d9fe8","tid":1689260,"uid":26553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-03T03:43:11.000Z","msg":"消防高層好撚廢"}]}