mg src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"fc56a03982cacb9d92a647107d817dca25cd5ba1","tid":685140,"uid":44391,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-31T09:35:58.000Z","msg":"此回覆已被刪除"},{"pid":"073dcb607f1f7e4a76502dc62939854752424ae1","tid":685140,"uid":32665,"like":1,"dislike":0,"score":1,"quote":{"pid":"d3ae335d42dacc9ddc45577ba2215041817f1e34","tid":685140,"uid":123014,"like":0,"dislike":0,"score":0,"quote":{"pid":"d41a35dabe838cf7361b438ddff872844cef62dc","tid":685140,"uid":188928,"like":0,"dislike":0,"score":0,"quote":{"pid":"f1e406d99bb6ce9b83f0ad693f3ff6eda9c9e593","tid":685140,"uid":32665,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-31T09:32:47.000Z","msg":"絲 都可以"},"citedBy":1,"replyTime":"2018-05-31T09:34:29.000Z","msg":"我不是sheshe<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-31T09:35:29.000Z","msg":"都可以架..."},"citedBy":0,"replyTime":"2018-05-31T09:35:59.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"bdb4e4be26fa863ba089c21ffc519db517c7f06c","tid":685140,"uid":161352,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-05-31T09:37:52.000Z","msg":"收幾錢/hr<br />\n<br />\n有啲家長好on9 臨考試又加堂 聖誕暑假又直接停曬<br />\n<br />\n有無遇過類似<br />\n<br />\n同埋你洗唔洗備課<br />\n<br />\n有無試過教到個學生級排名退左<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 真係好尷尬"},{"pid":"e8d73600daa8a6ab086f946a12d53ac633d36713","tid":685140,"uid":188928,"like":0,"dislike":0,"score":0,"quote":{"pid":"fc56a03982cacb9d92a647107d817dca25cd5ba1","tid":685140,"uid":44391,"like":0,"dislike":0,"score":0,"quote":{"pid":"772775583b549692e8db18b101e36f35c8a90888","tid":685140,"uid":188928,"like":0,"dislike":0,"score":0,"quote":{"pid":"a6371aa23ae3e7e5e40dcbbf79ad41d3a50e7dd3","tid":685140,"uid":44391,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-31T09:30:14.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-05-31T09:33:22.000Z","msg":"有試過一個ADHD. 但係個家長本身都唔知 (太忙由朝做到晚, 小朋友係工人湊)<br />\n我同個家長講返, 之後做檢查發現真係<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n冇收貴到, 因為佢一開始都唔知<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-31T09:35:58.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-05-31T09:41:23.000Z","msg":"只可以講真係要好有耐性... 唔可以一味靠惡, 因為佢地唔驚<br />\n要有耐心咁解釋幾次個題目/ 一堂講幾十次叫佢地坐好咁~<br />\n有時我會同佢地傾下閒計先, 佢地講其他野就會好樂意<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n傾到最後叫佢地做下功課佢地就會肯做下 (為左同我繼續傾埋落去)<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"5d280bf8f10a159836290c158fa9c75bf3cba790","tid":685140,"uid":188928,"like":0,"dislike":0,"score":0,"quote":{"pid":"bdb4e4be26fa863ba089c21ffc519db517c7f06c","tid":685140,"uid":161352,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-05-31T09:37:52.000Z","msg":"收幾錢/hr<br />\n<br />\n有啲家長好on9 臨考試又加堂 聖誕暑假又直接停曬<br />\n<br />\n有無遇過類似<br />\n<br />\n同埋你洗唔洗備課<br />\n<br />\n有無試過教到個學生級排名退左<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 真係好尷尬"},"citedBy":0,"replyTime":"2018-05-31T09:44:38.000Z","msg":"$80-150都有<br />\n<br />\n當然有.. 應該話係一定會咁.考試前係旺季, 好多家長都一早就同我約哂時間, 又會叫我加鐘<br />\n一放長假就會話想俾個小朋友休息下先<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n要備課, 會自己整工作紙, 考試會出卷<br />\n<br />\n有試過進步左一排又退步返咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n不過大部分都有進步的<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"41e73f995576cd5a00e74d71bd8e9bd9be5a2a9c","tid":685140,"uid":56837,"like":6,"dislike":0,"score":6,"citedBy":1,"reply