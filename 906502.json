ssets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> 多謝班香港政黨"},{"pid":"6dddf744e0b39f493e4780984c0d0e518cc3dde0","tid":906502,"uid":16087,"like":1,"dislike":0,"score":1,"quote":{"pid":"6f18f5abec516f860115664fe20e7bce4b1c3b85","tid":906502,"uid":121146,"like":0,"dislike":0,"score":0,"quote":{"pid":"2af9a0d6c0336224eaf830f7fd3c32e3baa13820","tid":906502,"uid":35790,"like":0,"dislike":0,"score":0,"quote":{"pid":"debf7f0fbaa1f75f84131007e05a3ab4631833c8","tid":906502,"uid":98289,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-11-18T05:39:25.000Z","msg":"英檔：鄧蓮如猜李柱銘想港獨是選項 李指鄧「完全錯誤」：一國兩制唯一可行選擇  2018/7/24<br />\n<br />\n【明報專訊】港府近日擬取締支持港獨的香港民族黨，而最新解密的英國檔案披露，英國首相馬卓安1992年與獲港英政府倚重的建制重量級人物鄧蓮如會面時表示，不想用任何行動限制本港民主派領袖李柱銘，又期望李可與中方有聯繫。鄧蓮如在會面中表示，李柱銘的策略是建基於中國可能出現改變的假設，「甚至可能會去想香港獨立是一個選項」。身為民主黨創黨主席的李柱銘接受本報查詢時表示，鄧蓮如的看法「完全錯誤」，他一向認為一國兩制是香港唯一可行的選擇，香港獨立從來不是選項。<br />\n<br />\n李柱銘<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<a href=\"https://m.mingpao.com/pns/dailynews/web_tc/article/20180724/s00002/1532369281941\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.mingpao.com%2Fpns%2Fdailynews%2Fweb_tc%2Farticle%2F20180724%2Fs00002%2F1532369281941&d=tg3Dda7iVq8UyaQIpyYsBEbWhtBCnEJYRTWbVbFBOac%3D&h=63d16b54\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fm.mingpao.com%2Fpns%2Fdailynews%2Fweb_tc%2Farticle%2F20180724%2Fs00002%2F1532369281941&h=a2fef10c\" target=\"_blank\">https://m.mingpao.com/pns/dailynews/web_tc/article/20180724/s00002/1532369281941</a>"},"citedBy":2,"replyTime":"2018-11-18T05:42:15.000Z","msg":"大中華膠<br />\n反共愛國"},"citedBy":2,"replyTime":"2018-11-18T05:45:28.000Z","msg":"民主回歸派的代表人物司徒華解釋他支持回歸的原因，其中一項是「百餘年來，香港是殖民地，因而遠離很多源自中國的災難；然而，我未能與祖國同胞一起經歷，心中有愧。現在回歸到一個獨裁專制的政