/mock.gif\" class=\"hkgmoji\" />"},{"pid":"e6dc2b5f523ce4d3794ec9405a60e1def95f0976","tid":1785262,"uid":290238,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-17T03:33:11.000Z","msg":"快d拿曬d有錢佬嘅錢 等距地對內地果套清醒下"},{"pid":"c048add8af17771e7556312a75248a14304e96c6","tid":1785262,"uid":127454,"like":2,"dislike":0,"score":2,"quote":{"pid":"7aa849098a074414c4a6a02d312393a4b16c6302","tid":1785262,"uid":1886,"like":5,"dislike":5,"score":0,"quote":{"pid":"a72cb88be657dc446692e88702d1783dae6fe8e2","tid":1785262,"uid":74302,"like":33,"dislike":6,"score":27,"quote":{"pid":"192916738202cd3dff2a4d831fe789e4e79e0bc6","tid":1785262,"uid":158499,"like":6,"dislike":1,"score":5,"citedBy":1,"replyTime":"2019-12-16T09:21:15.000Z","msg":"Haters成日話Apple啲機廢<img src=\"/assets/faces/pigxm/pointing.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2019-12-16T09:33:53.000Z","msg":"事實係FACE ID 可能係APPLE 近年推出最完美既技術<br />\n因為一出就好精準，冇BUG，只有愈來愈快......硬件唔洗提升都會加快<br />\n而單純新機UPDATE CPU配合佢用又可以更快, 連FACEID 個硬件都冇更新過......<br />\n<br />\nM字額係難頂, 但係取捨之下, 有佢解鎖同做交易, 係放心好多"},"citedBy":2,"replyTime":"2019-12-17T00:37:27.000Z","msg":"pixel 4 無 m 額，點睇？<br />\n<br />\n<img src=\"https://img.technews.tw/wp-content/uploads/2019/10/24183038/2019-10-24-14.00.53.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.technews.tw%2Fwp-content%2Fuploads%2F2019%2F10%2F24183038%2F2019-10-24-14.00.53.png&h=ce816ff2&s={SIZE}\" /><br />\n<br />\nPixel 4 另外一個新功能，其實是 3D 臉部解鎖功能，Google 稱它為 Face Unlock。與以往 Android 手機的 2D 臉部解鎖不同，Pixel 4 在手機螢幕上方設計了紅外線照射器、紅外線微點投影器以及紅外線相機，因此可透過偵測臉部 3D 曲線而達到更高的臉部解鎖安全性，<span style=\"color: red;\"><strong>原理與 iPhone 的 Face ID 基本上是一樣的</strong></span>，因此在行動支付時，也可以透過 Face Unlock 來做為身分驗證。<br />\n<br />\n值得一提的是，Pixel 4 的 Face Unlock 也與 Motion Sense 互相合作，前面提到當 Motion Sense 偵測到有人在附近時，會把螢幕 AOD 打開，這時只要在螢幕上方揮一下手，鎖定畫面就會開啟，然後再把臉湊過去，手機就自動解鎖，從頭到尾都不需要碰到手機。另外，<span style=\"color: red;\"><strong>Face Unlock 不論是直立、橫向或是上下顛倒，怎麼拿手機都可以解鎖，這點與 iPhone 只能直立解鎖相比方便很多。</strong></span>"},"citedBy":0,"replyTime":"2019-12-17T03:41:58.000Z","msg":"填海咁填埋左右上角咁咪冇m額<br />\n上邊條邊咪又係咁闊<br />\n自欺欺人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e41debe2aede717269a14805e3d4c61b617c565a","tid":1785262,"uid":103575,"like":0,"dislike":0,"score":0,"quote":{"pid":"7aa849098a074414c4a6a02d312393a4b16c6302","tid":1785262,"uid":1886,"like":5,"dislike":5,"score":0,"quote":{"pid":"a72cb88be657dc446692e88702d1783dae6fe8e2","tid":1785262,"uid":74302,"like":33,"dislike":6,"score":27,"quote":{"pid":"192916738202cd3dff2a4d831fe789e4e79e0bc6","tid":1785262,"uid":158499,"like":6,"dislike":1,"score":5,"citedBy":1,"replyTime":"2019-12-16T09:21:15.000Z","msg":"Haters成日話Apple啲機廢<img src=\"/assets/faces/pigxm/pointing.gif\" class=\"hkgmoji\" />"},"citedBy":4,"replyTime":"2019-12-16T09:33:53.000Z","msg":"事實係FACE ID 可能係APPLE 近年推出最完美既技術<br />\n因為一出就好精準，冇BUG，只有愈來愈快......硬件唔洗提升都會加快<br />\n而單純新機UPDATE CPU配合佢用又可以更快, 連FACEID 個硬件都冇更新過......<br />\n<br />\nM字額係難頂, 但係取捨之下, 有佢解鎖同做交易, 係放心好多"},"citedBy":2,"replyTime":"2019-12-17T00:37:27.000Z","msg":"pixel 4 無 m 額，點睇？<br />\n<br />\n<img src=\"https://img.technews.tw/wp-content/uploads/2019/10/24183038/2019-10-24-14.00.53.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.technews.tw%2Fwp-content%2Fuploads%2F2019%2F10%2F24183038%2F2019-10-24-14.00.53.png&h=ce816ff2&s={SIZE}\" /><br />\n<br />\nPixel 4 另外一個新功能，其實是 3D 臉部解鎖功能，Google 稱它為 Face Unlock。與以往 Android 手機的 2D 臉部解鎖不同，Pixel 4 在手機螢幕上方設計了紅外線照射器、紅外線微點投影器以及紅外線相機，因此可透過偵測臉部 3D 曲線而達到更高的臉部解鎖安全性，<span style=\"color: red;\"><strong>原理與 iPhone 的 Face ID 基本上是一樣的</strong></span>，因此在行動支付時，也可以透過 Face Unlock 來做為身分驗證。<br />\n<br />\n值得一提的是，Pixel 4 的 Face Unlock 也與 Motion Sense 互相合作，前面提到當 Motion Sense 偵測到有人在附近時，會把螢幕 AOD 打開，這時只要在螢幕上方揮一下手，鎖定畫面就會開啟，然後再把臉湊過去，手機就自動解鎖，從頭到尾都不需要碰到手機。另外，<span style=\"color: red;\"><strong>Face Unlock 不論是直立、橫向或是上下顛倒，怎麼拿手機都可以解鎖，這點與 iPhone 只能直立解鎖相比方便很多。</strong></span>"},"citedBy":0,"replyTime":"2019-12-17T03:43:04.000Z","msg":"你望下pixel 4大大個額頭<img src=