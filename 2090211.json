=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"85fb617693220bd9d868647b500f66be75f1a377","tid":2090211,"uid":98386,"like":0,"dislike":0,"score":0,"quote":{"pid":"dec46926565659b207d2e08b2d5c126a90f90326","tid":2090211,"uid":202425,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-02T05:08:58.000Z","msg":"<span style=\"color: red;\">裁判官質疑為何她不能判處被告人即時監禁<br />\n</span>"},"citedBy":0,"replyTime":"2020-07-02T05:13:37.000Z","msg":"咁佢又冇講錯喎 法官係唔一定要接納感化官個意見 之不過大多數都照跟咁解"}]}