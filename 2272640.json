 src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f8e3644ced8d135981e417f1c90af0d5a4f1ae8b","tid":2272640,"uid":51183,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-11-05T08:15:12.000Z","msg":"如果一球唱幾首歌<br />\n又好難唔賺<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b9072c4e618c436ae1df21aacbaad0fb2bea8b3f","tid":2272640,"uid":10757,"like":7,"dislike":0,"score":7,"quote":{"pid":"8ab9a6b7a269f2455175ad02b8e382e2fcb41391","tid":2272640,"uid":127425,"like":8,"dislike":409,"score":-401,"citedBy":19,"replyTime":"2020-11-05T07:58:12.000Z","msg":"<strong><span class=\"xx-large\">點都好<br />\n佢始終係我地香港人既校長<br />\n請尊重</span></strong>"},"citedBy":0,"replyTime":"2020-11-05T08:16:17.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />依個呀伯冇在我年代 有咩事蹟喎 同我老豆老母講"},{"pid":"07a1262702c9883a421f910d25c335fab01c1e94","tid":2272640,"uid":171107,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-05T08:20:39.000Z","msg":"酒廊歌手"},{"pid":"4d607e931c6699ba62cae0a3b22ecfb1a57ccc8c","tid":2272640,"uid":70888,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2020-11-05T08:27:27.000Z","msg":"先不論依條藍絲奶共等落地獄死既廢老譚<br />\n<br />\n成個show都on撚99咁制<br />\n支那人個腦真係唔知諗咩<img src=\"/assets/faces/big/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"53be41d439e2d7d8209f08fc63ba921de5368b3c","tid":2272640,"uid":156376,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-05T08:41:44.000Z","msg":"<strong>死廢老，仲好意思出黎獻世</strong>"},{"pid":"19f68141711837ec831af6f1efa9c69e3b9b2916","tid":2272640,"uid":80724,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-05T08:42:59.000Z","msg":"痰廢佬<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"e514600fde02a7f34a5f049540ef81e5fbaa969a","tid":2272640,"uid":42804,"like":28,"dislike":0,"score":28,"quote":{"pid":"8ab9a6b7a269f2455175ad02b8e382e2fcb41391","tid":2272640,"uid":127425,"like":8