85d5f5a22133602d","tid":776133,"uid":154054,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-11T18:31:57.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> 開店賣"},"citedBy":1,"replyTime":"2018-08-11T18:55:41.000Z","msg":"唔得啦 我自己玩下就掂<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-11T20:19:11.000Z","msg":"香港都好似少鋪頭賣自己整嘅棉花糖<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"8b0099dd1ea69f1754287ca2e93044eb7e3236f4","tid":776133,"uid":12879,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-11T20:25:10.000Z","msg":"好正呀 想食<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"55d22e578e5f2a1281eed94fe219e580dbbbe34e","tid":776133,"uid":180604,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-08-11T20:28:34.000Z","msg":"此回覆已被刪除"},{"pid":"75b165fac21260aae6744df362701d651ddb7ca4","tid":776133,"uid":182127,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-11T20:30:33.000Z","msg":"<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"1e6eee2c6efe65abdab0332db155d22492ceede5","tid":776133,"uid":182683,"like":0,"dislike":0,"score":0,"quote":{"pid":"8b0099dd1ea69f1754287ca2e93044eb7e3236f4","tid":776133,"uid":12879,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-11T20:25:10.000Z","msg":"好正呀 想食<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-11T20:52:21.000Z","msg":"試下整<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />  不過有野唔明記得問我<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"c2634ea3ddcebecb24061cdfc3cf473080fa90fd","tid":776133,"uid":182683,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2