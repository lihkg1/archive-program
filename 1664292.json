2,"uid":131696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T06:18:31.000Z","msg":"推"},{"pid":"6577ffbac0bf6e9efa63dd8bcf3eda706665173b","tid":1664292,"uid":249766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T06:18:37.000Z","msg":"Push"},{"pid":"c213b1eba59a7a99a14416b790f9baa5d772570a","tid":1664292,"uid":218863,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T06:18:59.000Z","msg":"推"},{"pid":"188ecf5f490b98c8c20c385166a16fef515fb47f","tid":1664292,"uid":91866,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T06:20:29.000Z","msg":"推"},{"pid":"aeea922d72ae26a434e4651735dfbfafc1e6f9cb","tid":1664292,"uid":98797,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T06:21:44.000Z","msg":"推"},{"pid":"c08a77eea62056e079e679477a391818832f6150","tid":1664292,"uid":131696,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-10-20T06:26:28.000Z","msg":"唔好捉鬼 只需提防 be water"},{"pid":"457bd70ee422e0d2bc2d05aba5e53eb9413d3e54","tid":1664292,"uid":35456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T06:27:20.000Z","msg":"此回覆已被刪除"},{"pid":"9e48d75a6e70c65c1ec16b71c5e000a2c8657a50","tid":1664292,"uid":103102,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T06:27:27.000Z","msg":"推"},{"pid":"2d0a5fa6d3054970ff6fd3e2d124e9d4d498c8a4","tid":1664292,"uid":239247,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T06:27:47.000Z","msg":"其實同勇武裝一樣 唔好亂捉！"},{"pid":"9f15d849e67776a45a72cd13b744cc94867c5a40","tid":1664292,"uid":239247,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T06:28:36.000Z","msg":"1234568都係真勇武會做 <br />\n咪撚亂黎"},{"pid":"b2329328209d5b246ff05a4c6cbee5fcdfab6773","tid":1664292,"uid":94819,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-20T06:29:13.000Z","msg":"此回覆已被刪除"},{"pid":"25c96d66353e0d833f40d7a399a594f80d4cad93","tid":1664292,"uid":239247,"like":0,"dislike":0,"score":0,"citedBy":0,"rep