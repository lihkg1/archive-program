藍衫"},{"pid":"5e8d1464b392c8853b7714ffeddf07be0e98a92f","tid":1375052,"uid":54303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T04:41:22.000Z","msg":"bookmarked<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"8068fa03621ee02650f3ce78a12739f608a3dfad","tid":1375052,"uid":27432,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-29T04:42:41.000Z","msg":"晒氣啦<br />\n咁耐以黎<br />\n無數次屌9佢地出示委任證<br />\n係無一次佢地有拎出黎"},{"pid":"029d8b5df10ec7f6a62e007f9743059a7b569fac","tid":1375052,"uid":278201,"like":0,"dislike":0,"score":0,"quote":{"pid":"8068fa03621ee02650f3ce78a12739f608a3dfad","tid":1375052,"uid":27432,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-29T04:42:41.000Z","msg":"晒氣啦<br />\n咁耐以黎<br />\n無數次屌9佢地出示委任證<br />\n係無一次佢地有拎出黎"},"citedBy":0,"replyTime":"2019-07-29T04:44:42.000Z","msg":"你講到明&quot;按照邊一條邊一項&quot; <br />\n我相信效果好過只係講&quot;警例要你出示委任證&quot;"},{"pid":"137aa8c57d1a3655e42e967d63f6550d7ffb094d","tid":1375052,"uid":278201,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T04:53:39.000Z","msg":"推"},{"pid":"f1395271d1655ace6c471f7e8b6f691702807986","tid":1375052,"uid":278201,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T05:04:26.000Z","msg":"推"},{"pid":"c7c2a0266dfaeef2b5ae8e4e4639a718e5dc79be","tid":1375052,"uid":278201,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-29T09:21:42.000Z","msg":"推"}]}