1:18.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"70a0c81703452be56e66021cb477700d510847e9","tid":582842,"uid":72280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-06T23:54:33.000Z","msg":"<blockquote><img src=\"https://img.eservice-hk.net/upload/2018/03/07/062158_cf152568de747a7dc2172fd9f3a4c2c1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F07%2F062158_cf152568de747a7dc2172fd9f3a4c2c1.png&h=8c134560&s={SIZE}\" /><br />\n被炒夫婦 234x/30X (LCK)<br />\n被炒男工會代表 258D (TM)<br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/03/07/062334_0da419e30fccdaa312349bcdbeaed1ac.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F07%2F062334_0da419e30fccdaa312349bcdbeaed1ac.png&h=9318e80a&s={SIZE}\" /><br />\n承傳被炒九號女車長（Klb )</blockquote>"},{"pid":"b487ba093f3ac2f470f8579c34f0437bbc08fa8d","tid":582842,"uid":4525,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2018-03-06T23:56:04.000Z","msg":"wfc"},{"pid":"44aab16fc87e8f6f55a079c976bb877397c47eef","tid":582842,"uid":47966,"like":1,"dislike":0,"score":1,"quote":{"pid":"b487ba093f3ac2f470f8579c34f0437bbc08fa8d","tid":582842,"uid":4525,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2018-03-06T23:56:04.000Z","msg":"wfc"},"citedBy":0,"replyTime":"2018-03-07T00:00:37.000Z","msg":"Wfc你又入嚟<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /> 過主啦"}]}