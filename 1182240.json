s=\"hkgmoji\" />"},{"pid":"ced3a49740df87dd3a79862a25e7506e13b89a06","tid":1182240,"uid":3241,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-02T05:58:32.000Z","msg":"最冇法治嘅支那係度講法治<br />\n仲要果隻係共匪黎<br />\n可信度簡直係零"},{"pid":"eccdf4cf8845de0508ad0713594de7f0854505ab","tid":1182240,"uid":21470,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa4b9aec55998b348e3e152246ead06edbb44dba","tid":1182240,"uid":49588,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-06-02T05:48:01.000Z","msg":"中國大陸依法治國<br />\n<br />\n<br />\n真係人唔笑，狗都吠。<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-02T05:59:35.000Z","msg":"按字面解又冇錯既<br />\n下級官員冇執行 = 行政 / 紀律問題 <br />\n佢立咩法中央人民全權被代表<br />\n<br />\n所以依法一直都係愚民，唔會提該法是否有公義<br />\n如果不能以法達義，單講依法係冇意思"},{"pid":"f7b9f72f16f4e1b7ec664dc18630f09d17bedf9b","tid":1182240,"uid":49588,"like":1,"dislike":0,"score":1,"quote":{"pid":"eccdf4cf8845de0508ad0713594de7f0854505ab","tid":1182240,"uid":21470,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa4b9aec55998b348e3e152246ead06edbb44dba","tid":1182240,"uid":49588,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-06-02T05:48:01.000Z","msg":"中國大陸依法治國<br />\n<br />\n<br />\n真係人唔笑，狗都吠。<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-06-02T05:59:35.000Z","msg":"按字面解又冇錯既<br />\n下級官員冇執行 = 行政 / 紀律問題 <br />\n佢立咩法中央人民全權被代表<br />\n<br />\n所以依法一直都係愚民，唔會提該法是否有公義<br />\n如果不能以法達義，單講依法係冇意思"},"citedBy":0,"replyTime":"2019-06-02T06:12:58.000Z","msg":"好多傻豬一見到「依法辦案」，就以為有理<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d785b