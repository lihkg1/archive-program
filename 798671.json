kgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7de4157bfdfddde5a7ef502a853bf5d5d87a315e","tid":798671,"uid":79563,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T13:12:52.000Z","msg":"北美MPF基金IS A MUST"},{"pid":"0033c328bcac59d26b13b1188d6aa39127f9a20e","tid":798671,"uid":153778,"like":0,"dislike":0,"score":0,"quote":{"pid":"9abb75c3bcaa16cce9ca160815798fa2a663e571","tid":798671,"uid":201374,"like":18,"dislike":0,"score":18,"citedBy":3,"replyTime":"2018-08-29T12:59:24.000Z","msg":"<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <br />\n如果侵侵張成績表咁靚都冇得連任，美國人就全部都係智障<br />\n<br />\n幾時先接管埋中國<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-29T13:19:49.000Z","msg":"侵要先消滅左膠<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"6051237bcd0b95f9c1bffb647169251939c634ba","tid":798671,"uid":22736,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-29T13:21:59.000Z","msg":"發達國家來講呢個數字真係痴撚線<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"2ae7eee679d76fe6a5541523212a2ff0880287e6","tid":798671,"uid":79563,"like":0,"dislike":8,"score":-8,"quote":{"pid":"6051237bcd0b95f9c1bffb647169251939c634ba","tid":798671,"uid":22736,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-29T13:21:59.000Z","msg":"發達國家來講呢個數字真係痴撚線<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-29T13:24:10.000Z","msg":"香港仲勁<br />\n<br />\n<strong><span style=\"color: red;\">本港今年首季GDP增長4.7%</span></strong><br />\n文章日期：2018年5月11日 16:52<br />\n<br />\n統計處公布，本港第一季本地生產總值按年增長4.7%，升幅高於上一季的3.4%，連續第6個季度高於過去10年平均每年2.7%的趨勢增長率。經季節性調整後按季比較，實質本地生產總值在第一季急升2.2%，而上一季的升幅則為0.8%。<br />\n<br />\n第一季整體貨物出口表現強勁，按年增長5.2%。受惠於訪港旅遊業強勁復甦，環球金融市場活動活躍，以及區內貿易往來蓬勃，服務輸出的按年實質增長亦加快至7.5%，增長遍及各個環節。<br />\n<br />\n內部需求續強，數據顯示，首季私人消費開支按年升8.6%，反映市民消費情緒樂觀。機器及設備購置顯著擴張，加上樓宇及建造活動溫和上升，整體投資開支按年增長3.8%。至於勞工市場方面，首季經季節性調整的失業率維持2.9%，屬20年來最低水平。<br />\n<br />\n政府經濟顧問歐錫熊表示，第一季經濟實際增長數字較預期強勁，惟鑑於外圍環境，特別在貿易及金融的不明朗因素有所增加，故仍維持今年本地生產總值增長預測為3至4%。"},{"pid":"b5083205e38a696d8fd9f1dff20ce1ff057986f0","tid":798671,"uid":54733,"like":15,"dislike":0,"score":15,"citedBy":1,"replyTime":"2018-08-29T13:24:43.000Z","msg":"原因是企業擴大軟體支出，<span style=\"color: red;\">進口減少</span>。<br />\n<br />\n侵侵加關稅有用<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"7526f41a177a1d92e2f57aedbc55a01a5908685f","tid":798671,"uid":12609,"like":7,"dislike":0,"score":7,"citedBy":0,"replyTime":"2018-08-29T13:26:30.000Z","msg":"奧巴馬真係垃圾屎黎"},{"pid":"c90cb5b58d6c39fe689c3e9ab5d6152f86e64ad1","tid":798671,"uid":79563,"like":1,"dislike":0,"score":1,"quote":{"pid":"b5083205e38a696d8fd9f1dff20ce1ff057986f0","tid":798671,"uid":54733,"like":15,"dislike":0,"score":15,"citedBy":1,"replyTime":"2018-08-29T13:24:43.000Z","msg":"原因是企業擴大軟體支出，<span style=\"color: red;\">進口減少</span>。<br />\n<br />\n侵侵加關稅有用<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-29T13:26:39.000Z","msg":"CCTVB講到美國無左支那會死咁<br />\n<br />\n<br />\n<img src=\"/assets/faces/big/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2e873c62f56c042da0dfb06372bf4ecb2a633d2a","tid":798671,"uid":41116,"like":5,"dislike":0,"score":5,"quote":{"pid":"9abb75c3bcaa16cce9ca160815798fa2a663e571","tid":798671,"uid":201374,"like":18,"dislike":0,"score":18,"citedBy":3,"replyTime":"2018-08-29T12:59:24.000Z","msg":"<img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/adore.gif\" class=\"hkgmoji\" /> <br />\n如果侵侵張成績表咁靚都冇得連任，美國人就全部都係智障<br />\n<br />\n幾時先接管埋中國<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-08-29T13:27:50.000Z","msg":"反侵係主流<br />\nd 明星十個九個都反侵<br />\n講下反侵野就勁多like<br />\n個個爭住講下 笑下侵咁<br />\n而家美國係政治正確嘅年代<br />\n反同 反女權 支持侵 反移民都係不正確"},{"pid":"de18096cac58edc984ce935254119d85a5f2f83d","tid":798671,"uid":19527,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T13:28:23.000Z","msg":"道指劍指三幻二<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"66c950ed07aadf38979ce6e0285bba260c88172e","tid":798671,"uid":10757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T13:28:49.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 又要掘醜聞了"},{"pid":"1c8f281d81ec2c65c0c3e563db0110092b30b68c","tid":798671,"uid":51828,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2018-08-29T13:31:29.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/29/213124_2f9d087bb585505730bb811219e9fb9a.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F29%2F213124_2f9d087bb585505730bb811219e9fb9a.gif&h=0e09edaf&s={SIZE}\" />"},{"pid":"8c984e38b1c977806044f4b1211670ed43fe0e4a","tid":798671,"uid":11148,"like":8,"dislike":0,"score":8,"quote":{"pid":"2ae7eee679d76fe6a5541523212a2ff0880287e6","tid":798671,"uid":79563,"like":0,"dislike":8,"score":-8,"quote":{"pid":"6051237bcd0b95f9c1bffb647169251939c634ba","tid":798671,"uid":22736,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-29T13:21:59.000Z","msg":"發達國家來講呢個數字真係痴撚線<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-29T13:24:10.000Z","msg":"香港仲勁<br />\n<br />\n<strong><span style=\"color: red;\">本港今年首季GDP增長4.7%</span></strong><br />\n文章日期：2018年5月11日 16:52<br />\n<br />\n統計處公布，本港第一季本地生產總值按年增長4.7%，升幅高於上一季的3.4%，連續第6個季度高於過去10年平均每年2.7%的趨勢增長率。經季節性調整後按季比較，實質本地生產總值在第一季急升2.2%，而上一季的升幅則為0.8%。<br />\n<br />\n第一季整體貨物出口表現強勁，按年增長5.2%。受惠於訪港旅遊業強勁復甦，環球金融市場活動活躍，以及區內貿易往來蓬勃，服務輸出的按年實質增長亦加快至7.5%，增長遍及各個環節。<br />\n<br />\n內部需求續強，數據顯示，首季私人消費開支按年升8.6%，反映市民消費情緒樂觀。機器及設備購置顯著擴張，加上樓宇及建造活動溫和上升，整體投資開支按年增長3.8%。至於勞工市場方面，首季經季節性調整的失業率維持2.9%，屬20年來最低水平。<br />\n<br />\n政府經濟顧問歐錫熊表示，第一季經濟實際增長數字較預期強勁，惟鑑於外圍環境，特別在貿易及金融的不明朗因素有所增加，故仍維持今年本地生產總值增長預測為3至4%。"},"citedBy":1,"replyTime":"2018-08-29T13:32:34.000Z","msg":"香港經濟其實係美國間接帶起<br />\n<br />\n支那衰美國好=香港好<br />\n<br />\n支那好香港一定衰 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1e5e4e373aeb1bbcb81c1ce997745f2ea601668a","tid":798671,"uid":6604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-29T15:00:26.000Z","msg":"厲害了！我的美國！<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"3d6f9a9c4cc296568048ac9a2aaa744e06d84505","tid":798671,"uid":128761,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c984e38b1c977806044f4b1211670ed43fe0e4a","tid":798671,"uid":11148,"like":8,"dislike":0,"score":8,"quote":{"pid":"2ae7eee679d76fe6a5541523212a2ff0880287e6","tid":798671,"uid":79563,"like":0,"dislike":8,"score":-8,"quote":{"pid":"6051237bcd0b95f9c1bffb647169251939c634ba","tid":798671,"uid":22736,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-29T13:21:59.000Z","msg":"發達國家來講呢個數字真係痴撚線<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-29T13:24:10.000Z","msg":"香港仲勁<br />\n<br />\n<strong><span style=\"color: red;\">本港今年首季GDP增長4.7%</span></strong><br />\n文章日期：2018年5月11日 16:52<br />\n<br />\n統計處公布，本港第一季本地生產總值按年增長4.7%，升幅高於上一季的3.4%，連續第6個季度高於過去10年平均每年2.7%的趨勢增長率。經季節性調整後按季比較，實質本地生產總值在第一季急升2.2%，而上一季的升幅則為0.8%。<br />\n<br />\n第一季整體貨物出口表現強勁，按年增長5.2%。受惠於訪港旅遊業強勁復甦，環球金融市場活動活躍，以及區內貿易往來蓬勃，服務輸出的按年實質增長亦加快至7.5%，增長遍及各個環節。<br />\n<br />\n內部需求續強，數據顯示，首季私人消費開支按年升8.6%，反映市民消費情緒樂觀。機器及設備購置顯著擴張，加上樓宇及建造活動溫和上升，整體投資開支按年增長3.8%。至於勞工市場方面，首季經季節性調整的失業率維持2.9%，屬20年來最低水平。<br />\n<br />\n政府經濟顧問歐錫熊表示，第一季經濟實際增長數字較預期強勁，惟鑑於外圍