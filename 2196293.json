kgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f5b33bba3b76cc02aec0ae41a3dfa8bac5f84c00","tid":2196293,"uid":147970,"like":0,"dislike":0,"score":0,"quote":{"pid":"37adf7838eb792ef66e751814a0b0869ce8b4594","tid":2196293,"uid":235996,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-09T19:31:46.000Z","msg":"以毒攻毒 繼續努力<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-09-09T19:35:19.000Z","msg":"我一直有嘗試<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />最癲係日日都搭巴士 去到後尾個人麻木咗 啲frd問我點解木口木面<img src=\"/assets/faces/lm2/noodles.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/noodles.gif\" class=\"hkgmoji\" />"},{"pid":"e3ba2a82ef55c9effba365ca965ccd7e17d7c581","tid":2196293,"uid":253723,"like":3,"dislike":0,"score":3,"quote":{"pid":"2b57501e1c572452d19e92ebdf3d9814d3075707","tid":2196293,"uid":147970,"like":0,"dislike":0,"score":0,"quote":{"pid":"8f0db5ffad5e714517320d9fba711530e37a649f","tid":2196293,"uid":253723,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-09T19:27:06.000Z","msg":"你係暈船浪個種作嘔定點"},"citedBy":1,"replyTime":"2020-09-09T19:29:17.000Z","msg":"係啊<img src=\"/assets/faces/fs/hoho.gif\" class=\"hkgmoji\" />同埋個人會搞到大半日都好無精神 好似on99咁"},"citedBy":0,"replyTime":"2020-09-09T19:38:03.000Z","msg":"我之前都係咁<br />\n唔關個胃事<br />\n係耳水不平衡 無得醫<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n郁啲就作嘔反胃<br />\n但係我大大下就開始無咩事啦<br />\n消化不良就係個胃問題"},{"pid":"c5ead857d8bfd937ed797109c6c288503ccf99a1","tid":2196293,"uid":182519,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-09-09T19:39:38.000Z","msg":"你依家大約幾Shui"},{"pid":"b4c78bafd1839526dc729b40945eeafe988055cf","tid":2196293,"uid":182519,"like":0,"dislike":0,"score":0,"quote":{"pid":"c5ead857d8bfd937ed797109c6c288503ccf99a1","tid":2196293,"uid":182519,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-09-09T19:39:38.000Z","msg":"你依家大約幾Shui"},"citedBy":0,"replyTime":"2020-09-09T19:41:13.000Z","msg":"歲*"},{"pid":"d455d8a88c42eb0bbfc3750328a9208732eeecbc","tid":2196293,"uid":873,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2020-09-09T20:34:36.000Z","msg":"暈車浪 應該係耳水不平衡<img src=\"/assets/faces/fs/smile_big.gif\" class=\"hkgmoji\" /><br />\n可以試下打平個人 或者望遠野/綠色野 加聽歌<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" /><br />\n細個個時都係坐唔到車<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"5dd32a65e2ee3c2f9351f9a982ff4ba93d5880a6","tid":2196293,"uid":69977,"like":0,"dislike":0,"score":0,"quote":{"pid":"c95fcdc2d0825dfa3369ebfddb29538741e4c016","tid":2196293,"uid":147970,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-09-09T19:15:03.000Z","msg":"成日消化不良 食少少就想嘔翻曬出嚟<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n由細到大淨係可以行路/搭屋企人車 因為入面有聞開嘅香薰<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />有時連屋企人車我都作嘔 好短車程都覺得難頂<br />\n其實我都好鐘意搭巴士慢慢一站到下一站嘅感覺 但一搭超過15分鐘車程就會反胃 <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n小巴的士就更加唔掂 chok到我頭暈到要半日先回到神<br />\n我個胃到底係想點<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-09T20:38:47.000Z","msg":"好易胃痛<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"b085db5b07