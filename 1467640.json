.000Z","msg":"推"},{"pid":"46305c703b5b4b3b0b431acab018d0161f420ead","tid":1467640,"uid":204436,"like":0,"dislike":0,"score":0,"quote":{"pid":"bdbff388d9073963708b2ec908b8435e098d562d","tid":1467640,"uid":2002,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-13T17:41:08.000Z","msg":"劉業成啊<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n乜事 P牌仔"},"citedBy":0,"replyTime":"2019-08-13T17:53:09.000Z","msg":"唔好意思<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"}]}