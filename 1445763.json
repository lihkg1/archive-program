ov.hk/gia/general/201908/11/P2019081100825.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.info.gov.hk%2Fgia%2Fgeneral%2F201908%2F11%2FP2019081100825.htm&d=5YfG332q5u5uc%2FC0Cq16RYaGsx%2BcvHJ2yW7UCA6IqyI%3D&h=3f95804f\" target=\"_blank\">https://www.info.gov.hk/gia/general/201908/11/P2019081100825.htm</a>"},"citedBy":0,"replyTime":"2019-08-11T14:54:21.000Z","msg":"你老母燒傷左係傷<br />\n爆眼唔撚係傷？"},{"pid":"db25e6e5bcc9bcf0a458cb285745511eeb549810","tid":1445763,"uid":63363,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T14:54:49.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">麻包袋</span></strong></span>"},{"pid":"ccbe0bc96ba944005db26fe088875f138b0e2724","tid":1445763,"uid":79001,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T14:55:18.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"87042fe5874d3212a5b54ae5d9414a568f45c784","tid":1445763,"uid":275924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T14:55:32.000Z","msg":"食屎啦"},{"pid":"48a1021f699fcb94e43a9b1b26c35e75f5489352","tid":1445763,"uid":199754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T14:56:34.000Z","msg":"自己友做嘅<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},{"pid":"de734911b725d3b47483f120010da4afdc5f982d","tid":1445763,"uid":166197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T14:57:20.000Z","msg":"比自己友燒抵撚死啦<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"adf07d570cb7c5c877c440c131cbc8ce7e6a4b5c","tid":1445763,"uid":272119,"like":1,"dislike":0,"score":1,"quote":{"pid":"56c90f8bd4be1ab9c3a81d3933539c4427e3f5ec","tid":1445763,"uid":244034,"like":191,"dislike":2,"score":189,"citedBy":2,"replyTime":"2019-08-11T14:30:32.000Z","msg":"收皮啦你自己啲夥計做嘅"},"citedBy":0,"replyTime":