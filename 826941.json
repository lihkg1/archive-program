":0,"quote":{"pid":"3c527a6c8ccacfc6e1eb8408fb802a2e9cbe9478","tid":826941,"uid":152630,"like":65,"dislike":1,"score":64,"citedBy":2,"replyTime":"2018-09-18T14:46:27.000Z","msg":"飲食業絕對係辛苦/收入回報率最低 落場文化<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-18T14:51:07.000Z","msg":"都有65蚊一個鐘<br />\n同事都唔錯<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<br />\n<br />\n同埋我返工個到幫啲洗碗呀姨執好啲碗筷方便佢哋洗<br />\n<br />\n之後有啲同事放工會拎啲餐包畀啲公公婆婆(太多好難同大嘅交代<br />\n<br />\n<br />\n我而家半工， 都有不時返去做"},{"pid":"6d363ea21832b9c1d7a899b0f6829ee04d2d942f","tid":826941,"uid":35931,"like":1,"dislike":4,"score":-3,"citedBy":0,"replyTime":"2018-09-18T14:53:58.000Z","msg":"只有一大<br />\n自己果行"},{"pid":"0782d541a1c0a74dd1de6e0c1a18f55cca5b10b2","tid":826941,"uid":59511,"like":19,"dislike":1,"score":18,"citedBy":0,"replyTime":"2018-09-18T14:54:54.000Z","msg":"地盤佬<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n返工又辛苦又日曬雨淋,日日要帶老母返工,<br />\n地盤處處暗藏危機,做得安全又俾人屌慢,跟老屎忽果套中左招又俾人笑柒,<br />\n放工好似摩西過紅海咁,冇人敢埋身,受盡白眼,<br />\n耐唔耐又俾人拖糧要衝出馬路討薪等上報<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"e7ddb53c8146c259a5919af13a884a54c6a9f85b","tid":826941,"uid":13586,"like":2,"dislike":3,"score":-1,"citedBy":0,"replyTime":"2018-09-18T14:54:58.000Z","msg":"飲食：<br />\n最辛苦，有開工冇收工<br />\n<br />\n公立醫院，急症：<br />\n雖然人工似樣，但on call36人都癲，人累容易出錯，就會有醫療事故，人生已完<br />\n求其打個乞啑都入急症嗰啲又係正仆街<br />\n<br />\n清潔：<br />\n尤其洗碗，屌仲要人手洗，俾狗做<br />\n<br />\n暫時三個先，諗到再講"},{"pid":"ab0c7f6f8fa8c5db6bf3d524d70f305bc29e56b6","tid":826941,"uid":125079,"like":4,"dislike":3,"score":1,"citedBy":0,"replyTime":"2018-09-18T15:09:35.000Z","msg":"救護 : 不停救人都要比鬧用咗時間食飯<br />\n<br />\n飲食: 做到隻狗咁, 人工又低<br />\n<br />\n清潔(特別掃街/洗碗/洗廁所): 對社會黎講非常重要, 但人工低同比人睇唔起<br />\n<br />\n售貨員: 日日企同行, 搬野, 又要用把口搵食, 身心勞損<br />\n<br />\n地盤/工人: 辛苦工, 日曬雨淋, 容易出意外<br />\n<br />\n長時間工作既司機 : 日日坐係度, 10幾個鐘揸車唔夠休息, 經常比人鬧受氣"},{"pid":"63851c8fd05ee1e5513d852423e4a9ae7a065263","tid":826941,"uid":198165,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-09-18T15:54:59.000Z","msg":"有咩辛苦得過飲食<br />\n付出收穫不成正比<br />\n清潔都叫做厭惡但最少可以慢慢做<br />\n冇人有資格話辛苦過做炒場飲食既人<br />\n<br />\n做過三年飲食，不了<br />\n<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"ace85341c79f903fe347e9e0d8f82ae3625f1c84","tid":826941,"uid":200000,"like":8,"dislike":0,"score":8,"citedBy":2,"replyTime":"2018-09-18T15:59:51.000Z","msg":"香港會計<br />\n<br />\n全球工時最長職業"},{"pid":"35796659888fd31fc99309985ec24950ef561af9","tid":826941,"uid":2419,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-18T16:25:21.000Z","msg":"電競師"},{"pid":"8ea95ca07af2cb650a2c39fc40484c39951f507f","tid":826941,"uid":118671,"like":0,"dislike":0,"score":0,"quote":{"pid":"ace85341c79f903fe347e9e0d8f82ae3625f1c84","tid":826941,"uid":200000,"like":8,"dislike":0,"score":8,"citedBy":2,"replyTime":"2018-09-18T15:59:51.000Z","msg":"香港會計<br />\n<br />\n全球工時最長職業"},"citedBy":0,"replyTime":"2018-09-19T05:34:01.000Z","msg":"想知點解"},{"pid":"24aff5ac9b9bcd4a60b1ed684914fc27cc5f7b04","tid":826941,"uid":7125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-19T05:35:36.000Z","msg":"飲食物流地盤應該走唔甩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"dc8fa714655be73070da9ade8a0c485bf17ccd11","tid":826941,"uid":48253,"like":0,"dislike":0,"score":0,"quote":{"pid":"05b4ae788823621c9df9ee9f2e8dc3a1e62a2ef2","tid":826941,"uid":169698,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-18T14:45:07.000Z","msg":"心目中第一又係邊行？"},"citedBy":0,"replyTime":"2018-09-19T05:36:05.000Z","msg":"電訊"},{"pid":"e238638c9090b68f2a7d3a08165cb065c06bc8a8","tid":826941,"uid":196321,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-09-19T05:38:34.000Z","msg":"香港打工仔<br />\n香港基層打工仔<br />\n香港基層外判打工仔<br />\n香港假自僱打工仔..............我不懂吹了,自己編啦"},{"pid":"1eeeb07512150357ffee35c9e7cbffa2db4acfe7","tid":826941,"uid":49974,"like":0,"