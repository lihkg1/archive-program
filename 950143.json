m/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"9681906ff9fbcf7c24daa6a8405a6383e0f1c06a","tid":950143,"uid":138707,"like":0,"dislike":0,"score":0,"quote":{"pid":"8eec42ba54a6fa6c1cd4036c757030e091bcd5f5","tid":950143,"uid":158145,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-12-21T10:11:25.000Z","msg":"Ou"},"citedBy":0,"replyTime":"2018-12-22T09:37:26.000Z","msg":"OU政府嘢應該係最有錢先啱"}]}