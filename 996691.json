om%2Fa%2Fworld-s-second-largest-mobile-operator-suspended-the-deployment-of-huawei-business-20190125%2F4759932.html&d=P5qmjWKYo%2FOmEiOTDoYowozu7PIJYhBZqlGrkalTKs4%3D&h=3ef5970f\" data-auto-link target=\"_blank\">https://www.voacantonese.com/a/world-s-second-largest-mobile-operator-suspended-the-deployment-of-huawei-business-20190125/4759932.html</a>"},"citedBy":1,"replyTime":"2019-01-28T15:16:57.000Z","msg":"咁策略聯盟既 3HK 係咪會停止部署？"},{"pid":"15c088a695f5d00956aa1a5ddc11d200f7a809a4","tid":996691,"uid":133641,"like":0,"dislike":0,"score":0,"quote":{"pid":"970e641d0757a570277fe73f20d01d73a7020fb8","tid":996691,"uid":147314,"like":6,"dislike":0,"score":6,"citedBy":3,"replyTime":"2019-01-26T14:41:13.000Z","msg":"全球第二大移動運營商暫停部署華為業務<br />\n2019年1月26日<br />\n<img src=\"https://gdb.voanews.com/94517A95-5595-4741-A3B8-A57EF8ADB544_cx0_cy6_cw0_w1023_r1_s.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fgdb.voanews.com%2F94517A95-5595-4741-A3B8-A57EF8ADB544_cx0_cy6_cw0_w1023_r1_s.jpg&h=7e8b946e&s={SIZE}\" /><br />\n全球第二大移動運營商沃達豐（Vodafone）表示，公司暫停在核心網絡部署華為設備，直到西方國家解決有關華為活動的擔憂為止。<br />\n<br />\n<a href=\"https://www.voacantonese.com/a/world-s-second-largest-mobile-operator-suspended-the-deployment-of-huawei-business-20190125/4759932.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.voacantonese.com%2Fa%2Fworld-s-second-largest-mobile-operator-suspended-the-deployment-of-huawei-business-20190125%2F4759932.html&d=P5qmjWKYo%2FOmEiOTDoYowozu7PIJYhBZqlGrkalTKs4%3D&h=3ef5970f\" data-auto-link target=\"_blank\">https://www.voacantonese.com/a/world-s-second-largest-mobile-operator-suspended-the-deployment-of-huawei-business-20190125/4759932.html</a>"},"citedBy":0,"replyTime":"2019-01-28T18:42:10.000Z","msg":"支那又蠃 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"e81dc8018839e994d6eaef3b94663eb45f0d0107","tid":996691,"uid":220701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-28T19:31:52.000Z","msg":"瞓咗冇睇，華為做咗5g大佬未"},{"pid":"28e78a4227339bdf5982de130705ac8c024e4810","tid":996691,"uid":105366,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-28T19:33:17.000Z","msg":"T-mobile 免費提供既家用4G LTE personal hotspot router, 年頭已經由zte轉左去Nokia。"},{"pid":"0d2acd60fce1ee2ff396687ecf98d21985ed1c6d","tid":996691,"uid":156363,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-28T19:36:05.000Z","msg":"香港全部用華為<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"db75a33184dd3b13fc128528f5bd02c53d7f60d5","tid":996691,"uid":7206,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-01-28T19:42:09.000Z","msg":"人人喊打，遲早收皮<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n慢慢舟只要美國被定罪，華為下場會同中興一樣<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"d4a9745dad7d3ce213c5568f1df08410f405d401","tid":996691,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"0d2acd60fce1ee2ff396687ecf98d21985ed1c6d","tid":996691,"uid":156363,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-28T19:36:05.000Z","msg":"香港全部用華為<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-28T23:40:55.000Z","msg":"<img src=\"/assets/faces/lm2/dead.gif\" class=\"hkgmoji\" />"},{"pid":"4038a9bf6ea972711272d9d56df0114191b3bdfd","tid":996691,"uid":147314,"like":0,"dislike":0,"score":0,"quote":{"pid":"550643ab2f44f706f2b3843498aeb7f50be2d4d9","tid":996691,"uid":79563,"like":0,"dislike":0,"score":0,"quote":{"pid":"970e641d0757a570277fe73f20d01d73a7020fb8","tid":996691,"uid":147314,"like":6,"dislike":0,"score":6,"citedBy":3,"replyTime":"2019-01-26T14:41:13.000Z","msg":"全球第二大移動運營商暫停部署華為業務<br />\n2019年1月26日<br />\n<img src=\"https://gdb.voanews.com/94517A95-5595-4741-A3B8-A57EF8ADB544_cx0_cy6_cw0_w1023_r1_s.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fgdb.voanews.com%2F94517A95-5595-4741-A3B8-A57EF8ADB544_cx0_cy6_cw0_w1023_r1_s.jpg&h=7e8b946e&s={SIZE}\" /><br />\n全球第二大移動運營商沃達豐（Vodafone）表示，公司暫停在核心網絡部署華為設備，直到西方國家解決有關華為活動的擔憂為止。<br />\n<br />\n<a href=\"https://www.voacantonese.com/a/world-s-second-largest-mobile-operator-suspended-the-deployment-of-huawei-business-20190125/4759932.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.voacantonese.com%2Fa%2Fworld-s-second-largest-mobile-operator-suspended-the-deployment-of-huawei-business-20190125%2F4759932.html&d=P5qmjWKYo%2FOmEiOTDoYowozu7PIJYhBZqlGrkalTKs4%3D&h=3ef5970f\" data-auto-link target=\"_blank\">https://www.voacantonese.com/a/world-s-second-largest-mobile-operator-suspended-the-deployment-of-huawei-business-20190125/4759932.html</a>"},"citedBy":1,"replyTime":"2019-01-28T15:16:57.000Z","msg":"咁策略聯盟既 3HK 係咪會停止部署？"},"citedBy":0,"replyTime":"2019-01-29T08:44:17.000Z","msg":"上個禮拜 3 話未決定  <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <br />\n<br />\n【業界取態】5G電訊設備會否選用華為？3香港：仍物色<br />\n2019年01月21<br />\n<br />\n和記電訊（215）3香港執行董事及行政總裁古星輝表示，5G何時正式推行現時未有確實時間表，要待政府分配及拍賣完頻譜後，再按計劃進行。<br />\n<br />\n現時香港3大電訊商（中移動香港、3香港及csl.）4G網絡都選用華為電訊設備，古星輝坦言，5G仍在物色設備商，未有最後定案，「現時正在測試，同每個廠家都會做。」有記者問到是否近期因華為事件影響公司決定，他就指：「依一刻我唔想對任何廠家有任何傾斜，有資料公司會公佈。」<br />\n<br />\n他指和記全球都選用不同的設備商，沒有進行集中採購；他亦重申現時公司4G設備沒有跟華為簽約。"}]}