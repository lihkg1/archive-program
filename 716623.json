gmoji\" />"},{"pid":"2a1adf4a83388720d79a9d72ac16e648d100e510","tid":716623,"uid":24368,"like":5,"dislike":0,"score":5,"quote":{"pid":"7cb585be40ecfb93b2e74537bc1608e114bbac3c","tid":716623,"uid":17232,"like":4,"dislike":0,"score":4,"quote":{"pid":"111c52c85114d35157087153f4af4af1c28de9b3","tid":716623,"uid":75026,"like":1,"dislike":11,"score":-10,"quote":{"pid":"210d564b37fa397dd9c60a0c839cdb13b4a24f3b","tid":716623,"uid":82829,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2018-07-24T18:26:55.000Z","msg":"有冇諗過其他苦主可能都等錢洗<br />\n點解一定要同女人派帽做比喻<br />\n派帽都冇得告<br />\n兩樣性質嘅嘢點拉埋嚟講"},"citedBy":3,"replyTime":"2018-07-24T19:24:06.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-07-24T21:31:10.000Z","msg":"有人犯法叫人唔好報警拉人係叫唔跟連登大隊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 弱智真係無智商下限<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-07-24T21:53:49.000Z","msg":"真係笑死<br />\n仲覺得自己係眾人皆醉佢獨醒<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2d534c4f9f3e8d8deba7bfc8cbb3a0b49058b069","tid":716623,"uid":75026,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2018-07-24T22:23:55.000Z","msg":"此回覆已被刪除"},{"pid":"8e85cf76a9fba0ea56ed35b81d9ecd208afaf52b","tid":716623,"uid":75026,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2018-07-24T22:34:33.000Z","msg":"此回覆已被刪除"},{"pid":"cd5806f271f406683d9aa538baf4356340d7f56d","tid":716623,"uid":78085,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-27T19:13:40.000Z","msg":"updates <br />\n1.網上報案到落口供拉到人我諗大概3個月拉到人<br />\n<br />\n(真心算快 同中間程序唔兒戲 雖然金額唔多佢地會想你私了但只要你堅持既話佢地都要幫你追落去)<br />\n<br />\n2.有晒證據 所以最後拉到加問你想點charge <br />\na. 守行表 加罰款了事 過左一定時間無再犯無案底 <br />\nb. 上庭判 多數都係罰款 但會有案底 <br />\n兩樣都會上庭"},{"pid":"7be6dc9db8237764b60701f978ad77bd06b0bd25","tid":716623,"uid":186800,"like":1,"dislike":0,"score":1,"quote":{"pid":"cd5806f271f406683d9aa538baf4356340d7f56d","tid":