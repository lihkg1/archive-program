:00.000Z","msg":"自推"},{"pid":"ccbff304dcf10eeda21e5a03d0258993857e4ef6","tid":1434772,"uid":279854,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T01:23:02.000Z","msg":"要質疑北角警署整D網出黎係咪想自導自演放火<br />\n防止對方嫁禍畀示威者"},{"pid":"8d6a0a1b0b9c58764df6f4f47ab83832dff59846","tid":1434772,"uid":36075,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-09T01:23:13.000Z","msg":"好同意, 唔知有沒有記者會直接問一條問題：有沒用過期催淚彈, 有定無, 要正面回答.... 多謝記者"},{"pid":"38843d4a94322d7c5182708f20288bdf82767fc6","tid":1434772,"uid":275074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T01:24:00.000Z","msg":"黑警每次拉到人都圍圈擋記者拍攝"},{"pid":"5ce80c8f00775a96d881b514099690965977cefe","tid":1434772,"uid":300602,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T01:29:17.000Z","msg":"其實好想記者們都冷處理4點個記者會 <br />\n<br />\n講真理差佬既十九野日日都會有 <br />\n但係咪要focus 係部錄音機度？？<br />\n<br />\n失晒焦 <br />\n<br />\n傳媒都有好大責任 <br />\n<br />\n建議記者們夾埋 每日都係問個幾個重點問題<br />\n有無用過期催淚彈 ？<br />\n低殺傷力武器有幾底要就示範？"},{"pid":"579d92f64b9763cec468df48f71f419ffdaf9062","tid":1434772,"uid":6375,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T01:37:08.000Z","msg":"再推"},{"pid":"fefc9dce13cc36abfd2c08ef9806a57f06a5a7c6","tid":1434772,"uid":6375,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-09T01:38:26.000Z","msg":"推上熱門<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6fba4c856f574503a3ec72a8efce4b44cd2989c1","tid":1434772,"uid":264144,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T01:39:05.000Z","msg":"推啊"},{"pid":"f2774075f4cc3f549d825c14350fc8fd74e65283","tid":1434772,"uid":43005,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T01:39:37.000Z","msg":"Pish"},{"pid":"a5a34f028d4936cdae9851ddb64a8b997ef5ac38","tid":1434772,"uid":135274,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-09T01:40:35.000Z","msg":"利君雅被消失係fake news"},{"pid":"de08d80f168fbbbfa8d2676ececb2d2c5bfb7b23","tid":1434772,"uid":3