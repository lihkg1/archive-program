 推Po直接打「721 811 831 新屋嶺」/<br />\n貼文宣圖 / <span style=\"color: red;\">行動日期時間地點</span>，唔打「推」<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">五大訴求，缺一不可<br />\n光復香港，時代革命</span></span>"},{"pid":"e5ed89bd8fc22a7c55a60b2c1a251a1441ba5ade","tid":1596744,"uid":94069,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T17:06:46.000Z","msg":"good evening sir!!"},{"pid":"fa8c0122801f632105e1dfb6bf28925d6d739e70","tid":1596744,"uid":210677,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-26T17:08:08.000Z","msg":"此回覆已被刪除"},{"pid":"66e0c5cf76a620904354d0e3225e1a5340848f3c","tid":1596744,"uid":257114,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T17:11:42.000Z","msg":"你點影的"},{"pid":"0ac4378419b44142cb9ec9a06295f87a3d1c5367","tid":1596744,"uid":104811,"like":0,"dislike":0,"score":0,"quote":{"pid":"fa8c0122801f632105e1dfb6bf28925d6d739e70","tid":1596744,"uid":210677,"like":0,"dislike":0,"score":0,"quote":{"pid":"0b351466283cc40b3050ed90caadec21e04f93e0","tid":1596744,"uid":104811,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-09-26T15:38:37.000Z","msg":"認同 但係 你點知的 <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-26T17:08:08.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-09-26T17:12:31.000Z","msg":"用左啲時間睇篇野 呀蛇又講得幾好 <img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"0136861880b68e8bf18b08e5a42070d397a4ca19","tid":1596744,"uid":24097,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T17:14:02.000Z","msg":"推"},{"pid":"a44726f1ed3719fd118a32d571ca650432e2204a","tid":1596744,"uid":249766,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T17:15:39.000Z","msg":"推"},{"pid":"b93c7e162a326dae1fb695082783d6cc0e3ac176","tid":1596744,"uid":144541,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T17:16:00.000Z","msg":"硬鳩蛇有冇份係新屋嶺打人"},{"pid":"7c34ac5e64b56e3780fb92e4502da1475659301