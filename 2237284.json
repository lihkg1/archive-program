25A6%25E8%25BB%258A%25E9%25A7%2590%25E5%25AE%2588%25E6%2588%2592%25E5%2582%2599-%25E5%2585%25AD%25E6%2597%25AC%25E7%25BF%2581-%25E7%25B4%2580%25E5%25BF%25B5%25E6%25AD%25B7%25E5%258F%25B2%25E6%259C%2589%25E9%258C%25AF%25E5%2592%25A9%2F&h=8f1c7c91\" data-auto-link target=\"_blank\">https://www.thestandnews.com/politics/%E5%B8%82%E6%B0%91%E8%B5%B4%E5%B1%AF%E9%96%80%E7%B4%85%E6%A8%93%E7%B4%80%E5%BF%B5%E9%9B%99%E5%8D%81-%E6%A5%AD%E4%B8%BB%E8%81%98%E5%A4%96%E7%B1%8D%E4%BF%9D%E5%AE%89%E9%98%BB%E6%94%94%E7%88%86%E8%A1%9D%E7%AA%81-%E8%AD%A6%E8%BB%8A%E9%A7%90%E5%AE%88%E6%88%92%E5%82%99-%E5%85%AD%E6%97%AC%E7%BF%81-%E7%B4%80%E5%BF%B5%E6%AD%B7%E5%8F%B2%E6%9C%89%E9%8C%AF%E5%92%A9/</a><br />\n<br />\n<br />\n六十多歲的宋先生與紅樓外的保安理論，要求進入孫中山紀念碑廣場。他說自己過去二十多年來，每年都有參與該處的升旗禮。談及日後未必再能舉辦有關活動，他慨嘆政府竟然容不下巿民表達心聲，更一度哽咽，「歷史紀錄咗孫中山先生喺度策劃辛亥革命，哪怕今日時移世易，但係歷史係改變唔到㗎」，「我哋唔係想造反，我哋想維持我哋嘅思想自由，難道我哋紀念歷史，我哋有錯咩？」他期望該址業主及政府能尊重歷史及巿民聲音，容許他們日後繼續舉辦雙十升旗禮。"},{"pid":"b49cbba14a62fd1415771ed94e44e0eb55423b27","tid":2237284,"uid":886,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-10-10T06:32:01.000Z","msg":"業主咁把炮今年揸正黎做<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8166eddbb8bc5daae34ee9f632bc99e5102b2d98","tid":2237284,"uid":14918,"like":4,"dislike":0,"score":4,"quote":{"pid":"b49cbba14a62fd1415771ed94e44e0eb55423b27","tid":2237284,"uid":886,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-10-10T06:32:01.000Z","msg":"業主咁把炮今年揸正黎做<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-10T06:32:40.000Z","msg":"個業主係紅底<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d11c05f91747d8e58e071a01c42467324c52581f","tid":2237284,"uid":79563,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-10-10T06:54:23.000Z","msg":"咁人地係業主"},{"pid":"208627df3fb5869246e3c471f3319cc47990f792","tid":2237284,"