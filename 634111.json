hkg.com/link?u=https%3A%2F%2Ftw.news.appledaily.com%2Finternational%2Frealtime%2F20180419%2F1337336%2F&d=QuYGBJ2uhMQvO05CnOtc2cmB%2BETtKD6oVAJ%2Bxq8xWyI%3D&h=014d3805\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftw.news.appledaily.com%2Finternational%2Frealtime%2F20180419%2F1337336%2F&h=3ef18c50\" target=\"_blank\">https://tw.news.appledaily.com/international/realtime/20180419/1337336/</a>"},{"pid":"ae4386e268ef76b49ea7222f46581dcc2d0dd79e","tid":634111,"uid":178374,"like":8,"dislike":0,"score":8,"quote":{"pid":"b62752298e3452e7ae2d64a53ab99b84d977d4dc","tid":634111,"uid":44333,"like":5,"dislike":25,"score":-20,"citedBy":1,"replyTime":"2018-04-19T03:35:31.000Z","msg":"睇曬都唔明咩叫半身扯出機外"},"citedBy":1,"replyTime":"2018-04-19T03:49:52.000Z","msg":"<a href=\"https://youtu.be/uDLvbzDu72U\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FuDLvbzDu72U&d=QuYGBJ2uhMQvO05CnOtc2cmB%2BETtKD6oVAJ%2Bxq8xWyI%3D&h=3c1f7f68\" target=\"_blank\">https://youtu.be/uDLvbzDu72U</a><br />\n<br />\n我諗起呢單。<br />\nBritish Airways Flight 5390"},{"pid":"22d2f7058c8468499bee323babc371c07f203cf8","tid":634111,"uid":44333,"like":1,"dislike":6,"score":-5,"quote":{"pid":"ae4386e268ef76b49ea7222f46581dcc2d0dd79e","tid":634111,"uid":178374,"like":8,"dislike":0,"score":8,"quote":{"pid":"b62752298e3452e7ae2d64a53ab99b84d977d4dc","tid":634111,"uid":44333,"like":5,"dislike":25,"score":-20,"citedBy":1,"replyTime":"2018-04-19T03:35:31.000Z","msg":"睇曬都唔明咩叫半身扯出機外"},"citedBy":1,"replyTime":"2018-04-19T03:49:52.000Z","msg":"<a href=\"https://youtu.be/uDLvbzDu72U\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FuDLvbzDu72U&d=QuYGBJ2uhMQvO05CnOtc2cmB%2BETtKD6oVAJ%2Bxq8xWyI%3D&h=3c1f7f68\" target=\"_blank\">https://youtu.be/uDLvbzDu72U</a><br />\n<br />\n我諗起呢單。<br />\nBritish Airways Flight 5390"},"citedBy":2,"replyTime":"2018-04-19T04:02:18.000Z","msg":"點樣淨係上半身吸出機外"},{"pid":"7d1faf36e9cfc640c7f17735e51bbb99494efb86","tid":634111,"uid":4917,"like":3,"dislike":1,"score"