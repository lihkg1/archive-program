nk?u=https%3A%2F%2Ftwitter.com%2FUSAinHKMacau&d=%2FE8yPsxO6SBEJdrny20pcW0Q%2Fwx8zutUsTDhO6XOofs%3D&h=87b3699c\" data-auto-link target=\"_blank\">https://twitter.com/USAinHKMacau</a><br />\n<br />\nFb：<br />\n美國駐港總領事館<br />\n<a href=\"https://www.facebook.com/USAinHKMacau\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2FUSAinHKMacau&d=%2FE8yPsxO6SBEJdrny20pcW0Q%2Fwx8zutUsTDhO6XOofs%3D&h=9b743442\" data-auto-link target=\"_blank\">https://www.facebook.com/USAinHKMacau</a><br />\n<br />\nGOD BLESS USA AND HK!<br />\n<img src=\"https://na.cx/i/nyG19Jx.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FnyG19Jx.png&h=5ff470ee&s={SIZE}\" />"},{"pid":"c16fd545b16a493d6644f1114806c3f3b4cbdcf7","tid":1863851,"uid":155095,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-16T05:11:37.000Z","msg":"華春瑩爆料<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"6b6045e0787842e1379c4f649d1d23c55c9455bc","tid":1863851,"uid":155095,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-17T00:08:53.000Z","msg":"push"},{"pid":"5c761a3db850f0d1e649799ce35cc8aeaf1139df","tid":1863851,"uid":283494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-17T00:21:38.000Z","msg":"點解有張無忌?"}]}