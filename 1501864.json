n<span style=\"color: red;\"><span style=\"font-size: x-large;\">光復香港<br />\n時代革命</span></span>"},"citedBy":0,"replyTime":"2019-08-24T13:45:22.000Z","msg":"push"},{"pid":"5858f7d2bb7e64af46f8e5ee25e882188bf15b9e","tid":1501864,"uid":70817,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T13:45:43.000Z","msg":"和理非快d睇睇"},{"pid":"df4d128a12f2a03262927a0951a81b798e691cef","tid":1501864,"uid":199257,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T13:45:56.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e2f67c73129f46d781eb9b08e197ca3031601c8f","tid":1501864,"uid":6833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T13:46:09.000Z","msg":"講得岩! 大家要加油,保重"},{"pid":"ab7de9434d1a481b6fa07d6ccf9f2d5e98ba9b02","tid":1501864,"uid":282328,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T13:46:48.000Z","msg":"push"},{"pid":"2c364bf57bd23a76cec0cf9e1f50c65126d69333","tid":1501864,"uid":282328,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T13:47:08.000Z","msg":"<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},{"pid":"8eb638122b50ee54a0b6a1413476ef677d1655d2","tid":1501864,"uid":70817,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T13:47:08.000Z","msg":"幫幫手推多d人睇"},{"pid":"b35295c49da0387f64056e0076fdb21e927dc889","tid":1501864,"uid":8948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T13:47:44.000Z","msg":"最基本戰術，唔該前線記住<br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">鐵馬鋪地，讓磚頭飛</span></span></strong>"},{"pid":"7e0deae3bf77cdc59c0562fe68b6fd45622e9721","tid":1501864,"uid":70817,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T13:48:50.000Z","msg":"825"},{"pid":"4dc5867b1874f80d24e6e6c338cf234897b760fe","tid":1501864,"uid":70817,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-24T13:50:51.000Z","msg":"825"},{"pid":"f3db3092b15b5