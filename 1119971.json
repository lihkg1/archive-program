-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHEXWkD7.png&h=b4e26404&s={SIZE}\" />"},{"pid":"418ee5eda0ef2ecdf62e4414909d57351b1c7128","tid":1119971,"uid":40161,"like":0,"dislike":0,"score":0,"quote":{"pid":"aec734687c1fce87883c19ed70278570d528dfbd","tid":1119971,"uid":47526,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-04-22T10:39:51.000Z","msg":"考慮下問銀行借60%+25%發展商二按 （自已confirm一下呢個盤有冇呢種offer先）"},"citedBy":0,"replyTime":"2019-04-22T11:10:40.000Z","msg":"師兄我明你講咩啦，可以ignore 之前嘅reply 😂😂"},{"pid":"4cf04f371d4eb679d21ff20fef88a0dd75d5bd47","tid":1119971,"uid":5267,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-22T11:13:04.000Z","msg":"此回覆已被刪除"},{"pid":"2a84f7f2f4a455b94b69c05b67bce3629019af7f","tid":1119971,"uid":55299,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ea48c2cbd4cf756d0cde572f71323390de93595","tid":1119971,"uid":40161,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-22T11:08:26.000Z","msg":"其實家臺呼吸 同一二按plan 如下<br />\n<br />\n<img src=\"https://na.cx/i/HEXWkD7.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHEXWkD7.png&h=b4e26404&s={SIZE}\" />"},"citedBy":1,"replyTime":"2019-04-22T11:19:13.000Z","msg":"留意番 option 2 計法係 <br />\n 二按係會先扣左你一按還款 再用你全期最高利率去計 即係P+1 再加3厘<br />\n同時做二按要一按銀行同意<br />\n所以都唔容易過 <br />\n<br />\n&lsquo;如果二按的成數是高於樓價2成，整個壓力測試的標準會更嚴格。一按+二按的在現行利率下供款不可逾月入45%。而壓測再加3厘後，一按+二按的供款不可逾月入55%&rsquo;"},{"pid":"fde829e82c8858bb775df9acbcca0c0ce412b26c","tid":1119971,"uid":40161,"like":0,"dislike":0,"score":0,"quote":{"pid":"4cf04f371d4eb679d21ff20fef88a0dd75d5bd47","tid":1119971,"uid":5267,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-04-22T11:13:04.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-04-22T11:24:03.000Z","msg":"依個我都有諗過，諗住人情唔會蝕好多，夠還錢掛<img src=\"/assets/faces/big/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3810ec3c3c420b1bd70410a97660912075d46bbd","tid":1119971,"uid":40161,"like":0,"dislike":0,"score":0,"quote":{"pid":"2a84f7f2f4a455b