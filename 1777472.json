查「反送中運動」發生的性暴力<br />\n<br />\n*個人資料及通訊紀錄在實錄完成後可按受訪者意願全部銷毀<br />\n詳情及相關安排請聯絡Tg @protesttoo"},{"pid":"228b7ed7d48f4dc1333ed82f056e4de9d47ace6d","tid":1777472,"uid":211512,"like":0,"dislike":0,"score":0,"quote":{"pid":"28a4de11172b3a6d58ce4f768bf27c294871cbdc","tid":1777472,"uid":308567,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-10T08:58:46.000Z","msg":"食完元氣個口生蟲"},"citedBy":0,"replyTime":"2019-12-10T09:13:45.000Z","msg":"元氣 不了"},{"pid":"f3824cb4ab77426bfbfcc492b89c6dbe50ab6062","tid":1777472,"uid":211512,"like":0,"dislike":0,"score":0,"quote":{"pid":"25ea6649963dd7208a9a64ff3dc286078055809f","tid":1777472,"uid":226067,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-12-10T08:56:48.000Z","msg":"食消炎藥 去藥房買"},"citedBy":1,"replyTime":"2019-12-10T09:22:26.000Z","msg":"有冇分邊種"},{"pid":"0d4c7dca762e1c33cc5bbce99c4b4dc94b3b573b","tid":1777472,"uid":226067,"like":0,"dislike":0,"score":0,"quote":{"pid":"f3824cb4ab77426bfbfcc492b89c6dbe50ab6062","tid":1777472,"uid":211512,"like":0,"dislike":0,"score":0,"quote":{"pid":"25ea6649963dd7208a9a64ff3dc286078055809f","tid":1777472,"uid":226067,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-12-10T08:56:48.000Z","msg":"食消炎藥 去藥房買"},"citedBy":1,"replyTime":"2019-12-10T09:22:26.000Z","msg":"有冇分邊種"},"citedBy":0,"replyTime":"2019-12-10T09:25:56.000Z","msg":"食開sc xxxxx<br />\n唔記得全名 白盒藍字"},{"pid":"def93844a0587880784e1adb09d56ae7bbf71edf","tid":1777472,"uid":159155,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-10T09:55:08.000Z","msg":"扺撚死"},{"pid":"9ae403cdf6e43de04aaa6881f0bd91e0cf62a10c","tid":1777472,"uid":211362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-10T09:55:41.000Z","msg":"抵死"},{"pid":"2a2aecd0a8f828110b81c5b25aa989710ed36182","tid":1777472,"uid":320293,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-10T10:12:24.000Z","msg":"下世小心啲"},{"pid":"58671a9fe9ba2e5c7fe1e98d02edcbe798d10025","tid":1777472,"uid":300013,"like":0,"dislike":0,"score":0