blank\">https://lihkg.com/thread/1800956/</a>"},{"pid":"626f778cbe2a63491ef4b48e14a7105b7106207c","tid":1801384,"uid":253016,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-29T02:17:51.000Z","msg":"又係支那賤畜"},{"pid":"50bb0bb56ea2f4b83023e2a5f426f76882e96214","tid":1801384,"uid":343066,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-29T02:19:56.000Z","msg":"冇品"},{"pid":"a32f236f5d06b7f411b76c55d210353be4c4c816","tid":1801384,"uid":54060,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-12-29T03:32:10.000Z","msg":"Twitter有留言話立陶宛受過共產黨逼害<br />\n有反共產法<br />\n舉報呢個仆街十支那人唔知有無用？"},{"pid":"b297653d57e4792896cd7de6287935db345dda5d","tid":1801384,"uid":14103,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-29T03:35:10.000Z","msg":"留言d支那竟然會屌鳩個大媽？"},{"pid":"7ed9eea17305e9db97bb8e6917c4850bb3f6cec9","tid":1801384,"uid":306664,"like":0,"dislike":0,"score":0,"quote":{"pid":"b297653d57e4792896cd7de6287935db345dda5d","tid":1801384,"uid":14103,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-29T03:35:10.000Z","msg":"留言d支那竟然會屌鳩個大媽？"},"citedBy":0,"replyTime":"2019-12-29T06:12:53.000Z","msg":"因為佢去外國旅行<img src=\"/assets/faces/pigxm/mock.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/mock.gif\" class=\"hkgmoji\" />當佢係特權份子<img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pigxm/clap.gif\" class=\"hkgmoji\" />"},{"pid":"c16ac41c8ace70eb6754117df4ed18739e96a06b","tid":1801384,"uid":221265,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-12-29T06:18:34.000Z","msg":"［藍絲破壞十字架山可恥］梁啓智<br />\n<br />\n黃藍是政見，人品是良知。帶團來到立陶宛十字架山，不幸見到藍絲把他們在香港的腦殘行為帶到這兒。<br />\n<br />\n先說一說歷史。十字架山是一個宗教聖地，也是一個抗爭地標。第一代的十字架山來自1831年立陶宛人對俄羅斯的反抗，村民紀念陣亡的義士，十字架山成為身分認同的寄託。到了蘇聯時代，當地政權在六七十年代最少三次清除這些十字架，村民之後又會重新架起，不屈不撓。來到今天，立陶宛已重新獨立，十字架山成為此國最重要的地標之一，估計有超過十萬個十字架架設在此。<br />\n<br />\n很多遊人來到這兒都會參與其中，通過架設十字架來紀念先人或感謝天恩。因為這處的抗爭歷史，也會有人架設寫上政治訴求的十字架。近半年來，就有不少寫上「光復香港 時代革命」的十字架出現。<br />\n<br />\n意想不到的，是今天早上來到，發現在一個紀念先人的十字架上，被人寫上「願曱甴早日安息 願香港早日回復平靜」的字句。<br />\n<br />\n見到這字句，我怒憤難平。<br />\n<br />\n第一，你有東西要發表，你自己可以豎立另一個十字架，門口紀念品店有售，兩尺高的也只賣八歐羅。在紀念一位與香港不相關的先人的十字架上寫上這樣的字句，是對先人的大不敬。<br />\n<br />\n第二，十字架山的存在是紀念立陶宛人的反抗歷史。把對香港抗爭者的仇恨帶到這兒，是對這段歷史和抗爭精神的大不敬。<br />\n<br />\n第三，神愛世人，十字架本身也代表為信念犧牲。在十字架上寫上仇恨言論是對宗教的大不敬。<br />\n<br />\n第四，立陶宛是納粹屠殺猶太人的其中一個主要地點，附近的考努斯就有五萬名猶太人被殺。在立陶宛的地標寫上「曱甴」一詞，是對人文精神和普世價值的大不敬。<br />\n<br />\n身為一名香港人，請容許我在此向立陶宛人致歉，我們的政治爭議讓這位腦殘藍絲染污了你們的地方。可惜我趕著離開，希望下一批有機會來到這兒的香港人可以幫忙和管理人員溝通，以作妥善處理。<br />\n<br />\n<a href=\"https://bit.ly/2ZvkBAI\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F2ZvkBAI&d=9uLtkTaOKuy%2FgkD%2BHbzoNZktsUQkmpJZziL8xq2DbDY%3D&h=05bb82a0\" target=\"_blank\">https://bit.ly/2ZvkBAI</a>"},{"pid":"e04b3474d7cbf0accc8172ddb1fab72e5384d163","tid":1801384,"uid":180173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-29T06:20:10.000Z","msg":"d蝗蟲真係好撚on9"},{"pid":"6ccdc606bf7c7d7e2bc1ba473e216667b0983515","tid":1801384,"uid":38109,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-29T06:40:31.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"90755bc727f92582815acb3b2d08d07e5300b7b3","tid":1801384,"uid":221265,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-29T06:54:13.000Z","msg":"<span style=\"color: red;\">已搵到十字架山及立陶宛各傳媒聯絡方法，及美國2黨關注波羅的海小組web</span><br />\n<br />\n大家可以去反映<br />\n<br />\nsiauliuraj@gmail.com<br />\n<br />\n<br />\n<img src=\"https://na.cx/i/tRwHnD6.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FtRwHnD6.png&h=819dae41&s={SIZE}\" /><br />\n<a href=\"https://bit.ly/37jvjgh\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbit.ly%2F37jvjgh&d=9uLtkTaOKuy%2Fgk