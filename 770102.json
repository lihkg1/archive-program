-08-07T01:01:06.000Z","msg":"乜 9 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-07T02:15:55.000Z","msg":"新會然<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"1e4c3f47a120f75c20239b94d4b0b7d95eb419e9","tid":770102,"uid":12755,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-08-07T02:28:23.000Z","msg":"真的打不了，只能打假的<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7450800a4b20b3220bc8a075635baae6d44dfb0a","tid":770102,"uid":39855,"like":56,"dislike":0,"score":56,"citedBy":3,"replyTime":"2018-08-07T02:34:38.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/08/07/103435_d51aff2a2a54a90613e997a82a1716b3.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F07%2F103435_d51aff2a2a54a90613e997a82a1716b3.png&h=e47a9933&s={SIZE}\" />"},{"pid":"97da34ae5bd806ec5117290bb5a7e7c1c14c6d53","tid":770102,"uid":129506,"like":4,"dislike":0,"score":4,"quote":{"pid":"b341e8ac4a990af4f2f0a0496cd7fb23fd10bd43","tid":770102,"uid":172365,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-07T01:57:58.000Z","msg":"有時啲大陸網民講野都好幾到肉<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-08-07T02:35:03.000Z","msg":"啲大陸狗講野好撚抵死<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"521222c419522ccd183d1916d02c03c1ca8b4eeb","tid":770102,"uid":22553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-07T02:42:04.000Z","msg":"皇叔都敢打<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"a74d21d382a2f2572c0063be28d13c5b307e4483","tid":770102,"uid":113626,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-08-07T02:43:00.000Z","msg