ore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"43d1c6dea91f421b924bfb744cc725ef05911a05","tid":1384961,"uid":291616,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:47:12.000Z","msg":"Push!!!"},{"pid":"f8fe93c24d57c9ff30be566cd5c2e5904413e959","tid":1384961,"uid":235711,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:49:41.000Z","msg":"推"},{"pid":"adb546e0395421497e13cd5eb2f97e1e9853263b","tid":1384961,"uid":271199,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:52:57.000Z","msg":"send 了"},{"pid":"2f490bf919337d60ef8bb57196c9976e7ce947cc","tid":1384961,"uid":69276,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:54:28.000Z","msg":"<img src=\"/assets/faces/lm2/frown.gif\" class=\"hkgmoji\" />"},{"pid":"7f9a64054e365d42369583d0fd9e996226fda8f0","tid":1384961,"uid":264994,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:54:54.000Z","msg":"推 推 推"},{"pid":"e3890a3383cbe19a8db818379881db3f8f02646b","tid":1384961,"uid":11854,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:54:58.000Z","msg":"自推"},{"pid":"8247ae0b6527d3a3257524ae6bbabe78bac0c5c6","tid":1384961,"uid":58958,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:57:19.000Z","msg":"Sent"},{"pid":"9c8abe72e0dceab961e90cd3ad8806dbd2427a3c","tid":1384961,"uid":58958,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:58:32.000Z","msg":"推"},{"pid":"705233e70ec7ef91e93344ae33ef2d4d79084bb8","tid":1384961,"uid":173849,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T03:59:29.000Z","msg":"三毛五毛見分化和理勇武失敗，依家spin去分化泛民、社工同劉細良，為保皇狗屌票<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1376567\" data-auto-link target=\"_blank\">https://lih.kg/1376567</a>"},{"pid":"cfe663380f5978f98150cec646f77593072f8491","tid":1384961,"uid":214192,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-30T04:01:34.000Z","msg":"[急求救！！！！]發起公務員集會嘅手足比藍絲瘋狂投訴緊<br />\n<a href=\"https://lih.kg/1383457\" data-auto-link target=\"_blank\">https://lih.kg/1383457</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"47b446e95dddec44f1f4203d1ae581e55380c978","tid":1384961,"uid":162731,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T04:08:13.000Z","msg":"sent! push"},{"pid":"cb5ef649746cd8228362a7fe5dfa3150e62c866e","tid":1384961,"uid":242724,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T04:09:34.000Z","msg":"鍵盤戰士埋位!"},{"pid":"e1de75e4b31acb3c04f3cb38f929af0bc09761e8","tid":1384961,"uid":54431,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-07-30T04:11:41.000Z","msg":"冷氣軍師 assemble!!<br />\n又要我地班公務員一齊罷<br />\n冇理由嚮應完你地帶頭搞罷工之後變成condom<br />\n日後仲點行落去<br />\n一人一信<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"5258942d12c48395e1f509d2244298838d50aff5","tid":1384961,"uid":158090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T04:13:35.000Z","msg":"未send既快send"},{"pid":"0513fc0165c9f546d3908883d7e1f8bdf35015c2","tid":1384961,"uid":249260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T04:13:44.000Z","msg":"Push"},{"pid":"c959959c5f411af29506aa7ef6b56b180e016915","tid":1384961,"uid":6799,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T04:14:28.000Z","msg":"推"},{"pid":"1db96b4d25fa773cc24b26a8dc62ee7695100cfd","tid":1384961,"uid":6528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T04:17:13.000Z","msg":"全民8月5曰大罷工！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n五大訴求，缺一不可！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n雙普選應要排最頭！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n全民黑衫、口罩同頭盔，返工返學行街，唔擺工既日子一齊做，將抗爭帶入生活，保護示威者<br />\n<a href=\"https://lih.kg/1379839\" data-auto-link target=\"_blank\">https://lih.kg/1379839</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n光復香港，時代革命！<br />\n－－－－－－－－－－－－－－－－－－－－－－－－－－－－－<br />\n想比更多人知道其實而家呢一刻基本上得番香港獨立呢條路，<br />\n我知好多人未準備好，我知而家急唔黎。<br />\n但係想大家思考下，種下一個思想，唔好屌我住。<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n而家就算有真普選其實都係under中共！！<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><br />\n咁唔通去到2047再抗爭過咩，西方國家都出唔到手幫你地。<br />\n因為白紙黑字寫明50年，西方國家唔好話出手，連發聲既正當性都冇啊<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n可能好多前人都係到諗點解英國當時唔寫999年！<br />\n可能好多我地呢代既諗點解上一代冇去抗爭！<br />\n可能好多下一代係2047係到諗點解我地唔直接爭取獨立！！！<br />\n<br />\n2047到時只會都係變返中國，仲要一下子就變，一定好多人接受唔到。<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n<br />\n所有問題去到最後只會追究到主權問題，希望大家思考下。<br />\n今次搞到咁大真係最後一次反擊同最大力量。<br />\n<br />\nBTW，五大訴求，缺一不可！<br />\n雙普選應要排最頭"},{"pid":"e3a7df315f563aa9d28a511225b8e08749c82f9f","tid":1384961,"uid":6528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T04:17:28.000Z","msg":"大家幫幫手<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"e77a88758b6af15cb71f31637c3c3fb8670c8841","tid":1384961,"uid":93908,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-30T04:18:33.000Z","msg":"<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"9b975da7ec6aff242a97f542f2bdaa4b703456cd","tid":1384961,"uid":7570,"like":0,"dislike":0,"score":0,"quote":{"pid":"5ec3e43f6ff405cb208097e818f75a0fb72328ab","tid":1384961,"uid":212274,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2019-07-30T03:42:09.000Z","msg