e2b32817d17a543673d694753bb","tid":599630,"uid":171177,"like":7,"dislike":3,"score":4,"citedBy":1,"replyTime":"2018-03-21T00:32:58.000Z","msg":"此回覆已被刪除"},{"pid":"be07e7f95d8605d4ddbffaf70f71b02379077c02","tid":599630,"uid":59465,"like":2,"dislike":17,"score":-15,"quote":{"pid":"e1285983c59c750f42c7b8c9230b68509d332e2a","tid":599630,"uid":174530,"like":5,"dislike":0,"score":5,"quote":{"pid":"b2173c789f80a8526cf5e458b33e00d9304ce229","tid":599630,"uid":59465,"like":7,"dislike":61,"score":-54,"citedBy":4,"replyTime":"2018-03-20T15:16:43.000Z","msg":"自己諗下點解Cristiano Ronaldo叫做 C朗<br />\n但係Ronaldo Luis 就叫朗拿度<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n仲有 乜撚嘢叫做 巴西朗拿度<br />\n你會唔會李嘉誠做香港李嘉誠<br />\n叫bill gates 做美國bill gates <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-20T18:14:52.000Z","msg":"請問撞名我加個地區分別下有咩問題？"},"citedBy":1,"replyTime":"2018-03-21T00:40:23.000Z","msg":"難怪咁多人中文閱讀理解唔合格<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n成段個意思擺明就係指朗拿度個人本身太出名<br />\n地位太高 太有代表性<br />\n所以根本唔需要係佢個名前邊加個地方名<br />\n嚟說明邊個係你地口中所謂嘅巴西朗拿度<br />\n<br />\n意思等於全世界有十幾廿億華人<br />\n姓李嘅已經一億<br />\n你諗下有幾多人會叫李嘉誠<br />\n<br />\n但係所有人係提到長實老闆個時<br />\n都只係會講李嘉誠 <br />\n而唔會叫佢做香港李嘉誠㗎嘛<br />\n知唔知點解？<br />\n<br />\n畫埋條腸比你睇<br />\n成段嘢都係用嚟指出<br />\n朗拿度係有幾出名幾勁幾有代表性<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n利申 CE AL 中文中化reading A<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"9a4d15b6f379fe6957e9809d32a9a895b269fce0","tid":599630,"uid":52876,"like":1,"dislike":0,"score":1,"quote":{"pid":"32e8a5e8ec55ce2b32817d17a543673d694753bb","tid":599630,"uid":171177,"like":7,"dislike":3,"score":4,"citedBy":1,"replyTime":"2018-03-21T00:32:58.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-03-21T00:46:16.000Z","msg":"咁點解另外4條煙又做唔到比肥朗?"},{"pid":"a42e1c704aae36eaf3afa372985a4de4441ac996","tid":599630,"uid":171177,"like":5,"dislike":3,"score":2,"citedBy