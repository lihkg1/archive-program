:"2019-03-22T01:25:59.000Z","msg":"出水馬封路未？"},{"pid":"cef2f431dc84f38cf35756191a5c51a0b9a9d658","tid":1072194,"uid":48011,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-22T01:31:40.000Z","msg":"香港發大財未"},{"pid":"6d9bcefff0f96f2046aa73e8569fa968aa99cb80","tid":1072194,"uid":155095,"like":1,"dislike":0,"score":1,"quote":{"pid":"ac202d42b1db75ca9fe0ee3262b491f5fcf5e1e5","tid":1072194,"uid":144372,"like":0,"dislike":0,"score":0,"quote":{"pid":"2a07c9ba8ebfcb03985469ab06a77c3459fd7917","tid":1072194,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-03-22T01:21:32.000Z","msg":"勁過總書記"},"citedBy":1,"replyTime":"2019-03-22T01:23:52.000Z","msg":"開幕嗰陣習近平唔係去過咩?"},"citedBy":1,"replyTime":"2019-03-22T01:35:13.000Z","msg":"<img src=\"https://vignette.wikia.nocookie.net/evchk/images/8/8d/港珠澳大橋.jpg/revision/latest?cb=20181024030020\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fevchk%2Fimages%2F8%2F8d%2F%E6%B8%AF%E7%8F%A0%E6%BE%B3%E5%A4%A7%E6%A9%8B.jpg%2Frevision%2Flatest%3Fcb%3D20181024030020&h=966184c2&s={SIZE}\" />"},{"pid":"01f1bf4d29b263d583aa6751ef1480ee47fdd96e","tid":1072194,"uid":141151,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d9bcefff0f96f2046aa73e8569fa968aa99cb80","tid":1072194,"uid":155095,"like":1,"dislike":0,"score":1,"quote":{"pid":"ac202d42b1db75ca9fe0ee3262b491f5fcf5e1e5","tid":1072194,"uid":144372,"like":0,"dislike":0,"score":0,"quote":{"pid":"2a07c9ba8ebfcb03985469ab06a77c3459fd7917","tid":1072194,"uid":141151,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-03-22T01:21:32.000Z","msg":"勁過總書記"},"citedBy":1,"replyTime":"2019-03-22T01:23:52.000Z","msg":"開幕嗰陣習近平唔係去過咩?"},"citedBy":1,"replyTime":"2019-03-22T01:35:13.000Z","msg":"<img src=\"https://vignette.wikia.nocookie.net/evchk/images/8/8d/港珠澳大橋.jpg/revision/latest?cb=20181024030020\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fvignette.wikia.nocookie.net%2Fevchk%2Fimages%2F8%2F8d%2F%E6%B8%A