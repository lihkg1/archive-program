ets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"4c907557f61bf255767bdb891a266fc113ecdfd9","tid":1945394,"uid":317376,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-27T04:30:20.000Z","msg":"咪癲啦邊有紅肉健康㗎<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"043799870adf0852709ed6fa361ae02d85f56263","tid":1945394,"uid":317376,"like":0,"dislike":1,"score":-1,"quote":{"pid":"1f550d041f105b0e9c6874294d3a8e9953eb087c","tid":1945394,"uid":168698,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-03-27T04:28:34.000Z","msg":"應該同兔肉差不多"},"citedBy":0,"replyTime":"2020-03-27T04:30:44.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n唔撚好啦&hellip;"},{"pid":"8823695928542601ad8c4eee96c5dd3aaa8447bf","tid":1945394,"uid":168698,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-27T04:31:06.000Z","msg":"野松鼠肉可以入藥，它能理氣調經，對人類的肺結核和肋膜炎以及月經不調和痔瘡等多種常見病都有很好的治療作用，<br />\n<br />\n另外野松鼠肉還含有在大量蛋白質和多種微量元素，能滿足人體對不同營養成分的需要，對提高身體素質也有很大的好處。<br />\n<br />\n野松鼠肉燉食也是一種常見吃法，平時可以把它與香菇一起燉制，燉的時候，要把松鼠肉處理好切成大塊，把香菇提前泡好，再加入筍片適量，<br />\n<br />\n在炒鍋中放油加熱以後把先把松鼠肉炒制，加入醬油和胡椒粉以及蔥與姜提味，炒好以後放水放入香菇和筍片一起燉熟，出鍋前加鹽與味精提味就可以。"},{"pid":"5af88726de400984eaf29a100a803dc0e0b2418b","tid":1945394,"uid":168698,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-27T04:32:09.000Z","msg":"之前去美國旅行成日看見松鼠，d鬼佬話有人會吃"},{"pid":"95031c85bf03d4c155303202b2c7217dcf3d3115","tid":1945394,"uid":168698,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-27T04:33:59.000Z","msg":"<img src=\"https://i2.kknews.cc/SIG=1a0cv3j/pn50005r272s03o5r91.jpg\" data