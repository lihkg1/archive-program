d":"eb0c3665246e4eb5ceb3bf8c42a37c80b551cb50","tid":2085403,"uid":284429,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-30T12:03:27.000Z","msg":"<img src=\"https://na.cx/i/pFvoeho.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpFvoeho.jpg&h=735c519e&s={SIZE}\" /><img src=\"https://na.cx/i/25FzkXq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F25FzkXq.jpg&h=46f4ff7d&s={SIZE}\" /><img src=\"https://na.cx/i/JZ50gvL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJZ50gvL.jpg&h=9fb5b019&s={SIZE}\" /><img src=\"https://na.cx/i/jM2mLo6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjM2mLo6.jpg&h=d65990ba&s={SIZE}\" />"},{"pid":"80865d56380542c4c4c1d0438999aa2483225175","tid":2085403,"uid":19817,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-30T12:03:44.000Z","msg":"PUSH"},{"pid":"0148716ea47aa39a8f5e8b6a66ed98602887be99","tid":2085403,"uid":172506,"like":0,"dislike":0,"score":0,"quote":{"pid":"eb0c3665246e4eb5ceb3bf8c42a37c80b551cb50","tid":2085403,"uid":284429,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-06-30T12:03:27.000Z","msg":"<img src=\"https://na.cx/i/pFvoeho.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpFvoeho.jpg&h=735c519e&s={SIZE}\" /><img src=\"https://na.cx/i/25FzkXq.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F25FzkXq.jpg&h=46f4ff7d&s={SIZE}\" /><img src=\"https://na.cx/i/JZ50gvL.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJZ50gvL.jpg&h=9fb5b019&s={SIZE}\" /><img src=\"https://na.cx/i/jM2mLo6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjM2mLo6.jpg&h=d65990ba&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-06-30T12:06:31.000Z","msg":"聽日一齊食飯<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoji\" />"},{"pid":"e5b3c7cf43641a473ce08e2a5da99f4819c8bc2d","tid":2085403,"uid":172506,"like":0,"dislike":0,"score":0,"quote":{"pid":"80865d56380542c4c4c1d0438999aa2483225175","tid":2085403,"uid":19817,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-30T12:03:44.000Z","msg":"PUSH"},"citedBy":0,"replyTime":"2020-06-30T12:06:55.000Z","msg":"Thanks <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"80ac3a06278ea6b75600e01e7b671c4ab2806757","tid":2085403,"uid":209644,"like":2,"dislike":0,"score":2,"quote":{"pid":"d85f699932701bfb5f96dead39c20fc35613f43d","tid":2085403,"uid":172506,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-30T01:05:50.000Z","msg":"(剛剛係隔離時間囊po (剛剛係隔離時間囊po 講完 有感而發 <br />\n唔知講完會唔會比人拉呢<img src=\"/assets/faces/fs/fozen_smile.gif\" class=\"hkgmoji\" />)<br />\n<br />\n生於斯 長於斯 死於斯 <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我唔希望終有一日我要流亡海外<br />\n(咁講絕無對流亡手足 不敬<br />\n相反 我對佢地感受緊嘅痛苦 更加敬畏<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />)<br />\n感謝2019、2020年嘅香港人、手足 <img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n感謝每一個係街頭上並肩作戰過嘅每一位<br />\n家長 後勤 文宣 黃圈 國際線 記者 FA<br />\n默默係唔同崗位上為著同一個目標而努力過嘅每一位<img src=\"/assets/faces/fs/agree.gif\" class=\"hkgmoji\" /><br />\n感謝生於這時代<img src=\"/assets/faces/fs/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n香港作為一個細到鼻屎咁嘅地方今次可以成為世界大國角力中心之一<br />\n其實真係好值得自豪<br />\n尤其是我地正面對一個人類文明歷史上最強大最邪惡嘅極權<img src=\"/assets/faces/fs/battle.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n香港人 舊年一波又一波嘅多元攻勢 一度打到港府死狗咁<br />\n又作歌 又高汁文宣 又國際戰線<br />\n又黃圈 又眾籌登報<br />\n街頭抗爭手段如滅煙、BlackBlock等等影響埋伊拉克、智利、印度、加泰(塞機場)等等等等<br />\n太多太多不能盡錄<img src=\"/assets/faces/fs/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n縱然 隨住時間過去 抗爭熱度跌咗 (呢個係必須承認嘅事實<img src=\"/assets/faces/fs/jj.gif\" class=\"hkgmoji\" />)<br />\n有分化(風向撚、鬥黃) 有內耗 有人渣(真.人血饅頭/呃錢撚)<br />\n<br />\n<strong><span style=\"font-size: large;\"><span style=\"color: orange;\">但我地香港人 實在太高汁 太善良<br />\n我地係值得擁有自己嘅國家<br />\n我地係值得建立自己嘅民族</span></span></strong><br />\n<br />\n<span style=\"color: green;\"><strong><span style=\"font-size: large;\">嚟緊 可能要長達數以十年嘅黑暗日子 等緊我地</span></strong></span><br />\n可能要流血 死好多人 被禁聲 被秘密警察捉走 好多人被迫逃亡<br />\n有生之年都未必睇到真正獨立建國一日<br />\n但觀乎歷史<br />\n學<strong><span style=\"color: red;\">工聯會</span></strong>話齋 從來無一個極權政黨可以永遠執政<br />\n<br />\n願 香港人 平安<img src=\"/assets/faces/fs/superman.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: gold;\">願榮光歸香港<br />\n光復香港 時代革命<br />\n香港民族 命運自決<br />\n香港獨立 唯一出路</span></strong></span>"},"citedBy":2,"replyTime":"2020-06-30T12:08:22.000Z","msg":"過去一年 能夠和大家在抗爭路上並肩作戰 是一軰子的回憶 願手足安好"},{"pid":"5f10d8558ba047a9290aa3e41fd94fa86c728e14","tid":2085403,"uid":43062,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-06-30T12:09:56.000Z","msg":"香港真係一個好奇妙嘅地方<img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/cry.gif\" class=\"hkgmoji\" />"},{"pid":"6fcc82f42d357e9d8f614102985973268279ae00","tid":2085403,"uid":172506,"like":2,"dislike":0,"score":2,"quote":{"pid":"80ac3a06278ea6b75600e01e7b671c4ab2806757","tid":2085403,"uid":209644,"like":2,"dislike":0,"score":2,"quote":{"pid":"d85f699932701bfb5f96dead39c20fc35613f43d","tid":2085403,"uid":172506,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-30T01:05:50.000Z","msg":"(剛剛係隔離時間囊po (剛剛係隔離時間囊po 講完 有感而發 <br />\n唔知講完會唔會比人拉呢<img src=\"/assets/faces/fs/fozen_smile.gif\" class=\"hkgmoji\" />)<br />\n<br />\n生於斯 長於斯 死於斯 <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n我唔希望終有一日我要流亡海外<br />\n(咁講絕無對流亡手足 不敬<br />\n相反 我對佢地感受緊嘅痛苦 更加敬畏<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />)<br />\n感謝2019、2020年嘅香港人、手足 <img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /><br />\n感謝每一個係街頭上並肩作戰過嘅每一位<br />\n家長 後勤 文宣 黃圈 國際線 記者 FA<br />\n默默係唔同崗位上為著同一個目標而努力過嘅每一位<img src=\"/assets/faces/fs/agree.gif\" class=\"hkgmoji\" /><br />\n感謝生於這時代<img src=\"/assets/faces/fs/good.gif\" class=\"hkgmo