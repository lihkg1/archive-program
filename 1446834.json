om.hk%2Famp%2Fs%2Fshopee.tw%2Famp%2F%2525E7%252599%2525A2%2525E7%252599%2525A2%2525E7%2525B2%252589-i.16248282.196099996&d=rP1lJsqA2sO3Td0%2BA1LJ5%2Fno2Xhlbsa%2F7jwkLKy9%2F%2FE%3D&h=564b35a8\" target=\"_blank\">https://www.google.com.hk/amp/s/shopee.tw/amp/%25E7%2599%25A2%25E7%2599%25A2%25E7%25B2%2589-i.16248282.196099996</a><br />\n<br />\n為麻包袋打起前哨戰<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">致所有黑社會、殺人兇手</span></strong></span>"},{"pid":"3ca4d3ad3b7ab0476150831da34717078740da58","tid":1446834,"uid":44751,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T15:23:07.000Z","msg":"721元朗恐襲"},{"pid":"b00928483d3f911f7e5588515c1cce89c9a734c8","tid":1446834,"uid":44751,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-08-11T15:23:36.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">禍</span></span>"},{"pid":"dcdb0621552425ecb3f8846561085d9082c5e407","tid":1446834,"uid":44751,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-11T15:23:48.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">必</span></span>"},{"pid":"3984ae75832f60eb5a9476b1302366e5890a954a","tid":1446834,"uid":44751,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-11T15:24:01.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">及</span></span>"},{"pid":"cffc9d2c7a887b292504b7d2126cea15d7598fff","tid":1446834,"uid":44751,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-11T15:24:21.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">妻</span></span>"},{"pid":"bba333f95052f28fe79167e66996e2b1a0e3374b","tid":1446834,"uid":44751,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-11T15:24:37.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">兒</span></span>"},{"pid":"6df38efb4a38db8a0b5a018682f8d5f60f63295e","tid":1446834,"uid":255439,"like":5,"dislike":0,"score":5,"citedB