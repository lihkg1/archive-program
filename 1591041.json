個諗起你"},{"pid":"c67225bb057119c38a20c2d92504a586d851af9a","tid":1591041,"uid":258696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-24T04:06:00.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><span style=\"font-size: x-large;\"><strong><span style=\"color: orange;\">請廣傳！香港人任務表！</span></strong></span><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: red;\">1. 每日TVB廣告洗嬲+罷買<br />\n<br />\n2. 推爆Twitter 國際戰線 （yellow object，人權法等）<br />\n<br />\n3. 每晚10點鳩叫<br />\n<br />\n4. 連儂牆修復（貼完拿拿林走 唔浪費時間落廢老身上）<br />\n<br />\n5. 杯葛藍屍鋪頭<br />\n<br />\n6. 幫手推行動po上熱門<br />\n<br />\n7. 幫手將新行動推出連登以外</span><br />\n<br />\n<span style=\"color: blue;\"><strong><span style=\"font-size: large;\">兄弟爬山，勿忘初心！<img src=\"/assets/faces/pig/lihkg.gif\" class=\"hkgmoji\" /><br />\n<br />\n不分化，不割蓆！ <img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><br />\n<br />\n光復香港，時代革命！</span></strong></span><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"7535fce685060624dee7245144db650529ba7091","tid":1591041,"uid":54800,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-24T04:06:16.000Z","msg":"無奈cut 唔到<br />\n<br />\n<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a6aa6d19d21342530e3fd6ed6191c3f21ce8cead","tid":1591041,"uid":21545,"like":6,"dislike":1,"score":5,"quote":{"pid":"7bf2d7ff5ab3dba614d7494cd079fbee21624ad9","tid":1591041,"uid":184370,"like":3,"dislike":0,"score":3,"quote":{"pid":"715f19fbbfa350ba35a0b60a0d92068684e761ef","tid":1591041,"uid":21545,"like":9,"dislike":0,"score":9,"quote":{"pid":"2a8754a1662f04eacca94760b3c24c5cacba9db0","tid":1591041,"uid":196552,"like":6,"dislike":1,"score":5,"citedBy":1,"replyTime":"2019-09-24T03:56:51.000Z","msg":"南亞仔受訪<im