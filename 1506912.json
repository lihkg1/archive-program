b6cd4c8b8b922ab92e902e879e36","tid":1506912,"uid":116034,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T08:11:40.000Z","msg":"推"},{"pid":"94972ff52685f3fe6dca9c39ad0d5665daa3e64b","tid":1506912,"uid":116034,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T08:11:51.000Z","msg":"推"},{"pid":"ca11df5fa0201f5e0ec649eca3993b73c1bdf79a","tid":1506912,"uid":116034,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T08:12:05.000Z","msg":"推"},{"pid":"7ed13c829d6e66c0ca3af1c5037b3e910a6a7ab1","tid":1506912,"uid":105353,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T08:34:18.000Z","msg":"推"},{"pid":"bdc5ce0d7d5d7727c54b2ea3c73ee307ede7580e","tid":1506912,"uid":173002,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T08:41:20.000Z","msg":"要遊行集會到10月後。 <img src=\"/assets/faces/lm2/ok.gif\" class=\"hkgmoji\" />"},{"pid":"c010c0ab6ffdf38bc359ea37ff622eb379531848","tid":1506912,"uid":53026,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T08:44:32.000Z","msg":"應該有任何人侮辱任何人罪"},{"pid":"9caeb8855ac62f8f6ec1ca08fcf9f79a183fe215","tid":1506912,"uid":268903,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-26T08:50:00.000Z","msg":"Push"},{"pid":"c42a2a8f475a6cd0c98f598d9bd241d59e554432","tid":1506912,"uid":264083,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-26T09:10:08.000Z","msg":"集合以上手足既list 再加 個人加左既 （紅字爲個人加左既）<br />\n<br />\n1. 全面撤回《2019年逃犯及刑事事宜相互法律協助法例（修訂）條例草案》，必需采用「撤回」字眼<br />\n2. 撤銷對本年6月至今遊行及示威人仕的檢控，盡快以恐怖襲擊控告7月21日元朗襲擊事件中「白衫人」<br />\n3. 撤回本年6月至今所有遊行及示威的暴動定性<br />\n4. 設立獨立調查委員會，徹查警方濫權濫捕、黑社會危害社會、立法會議員勾結黑社會嫌疑<br />\n5. 全面實行雙真普選<br />\n6. 立法規管所有軍裝警員（包括防暴警察、速龍小隊、飛虎隊）制服上必須明確顯示出警員編號，便裝警員被任何人要求出示委任證必須立即配合<br />\n7. 立例規管警員態度，以改善警隊形象<br />\n8. 重新定立對警員培訓，改正警員敵示市民的態度<br />\n9. 下調警方對集會遊行示威使用武力，及規管警員必須律從指引執法<br />\n10. 取消智能燈柱<br />\n11. 取消「明日大嶼」計劃<br />\n12. 取消立法會功能組別<br />\n13. <span style=\"color: red;\">永</span>不可因政治立場為由撤消<span style=\"color: red;\">候選人/當選</span>議員資格<br />\n14.取消警員獨立薪酬<br />\n15.保留通識必修必考<br />\n16.檢討丁屋政策<br />\n17.保留中文卷聆聽説話<br />\n18.取消普教中<br />\n19.要求撥款發展能源自主 <span style=\"color: red;\">（本地）</span><br />\n20.取消150新移民<br />\n21.<span style=\"color: red;\">加強篩選</span>優質專才計劃  <br />\n22.立即發展海水淡化廠<br />\n23.<span style=\"color: red;\">有工作能力</span>而領取綜援而無業人士須由政府安排工作，如清潔泳灘<span style=\"color: red;\">/義工</span><br />\n<span style=\"color: red;\">24.提升ICAC執法/起訴的權力，及向獨立委員會報告，改善現時只向特首報告的體制，避免特首權力過大<br />\n25.把新移民（不論其國籍）領取綜援/福利的年期重新調整至7年 及 加強調查新移民的海外資產是否符合領取綜援/福利的資格<br />\n26.確認及確實所有候選人議員/當選議員之資料，例如：學歷</span>"}]}