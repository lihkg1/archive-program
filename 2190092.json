aces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a1370f9cd4c344f22d93b3ce557377944e6ce202","tid":2190092,"uid":191650,"like":0,"dislike":0,"score":0,"quote":{"pid":"b5c861271db4a6f6220b9a1e134f1a543f33711e","tid":2190092,"uid":373438,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-09-05T10:57:16.000Z","msg":"睇吓又幾過癮嘅，不過講到可信性<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" /><br />\n見仁見智啦<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-05T10:57:44.000Z","msg":"係幾過癮 但有啲真係好match"},{"pid":"f0f1fe154236a35bb04c73fc6f6907cf44278410","tid":2190092,"uid":15605,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-05T10:58:08.000Z","msg":"陰毛論"},{"pid":"acd2bb9473eb86a226fcbf0217e71e667002229b","tid":2190092,"uid":191650,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-05T10:58:30.000Z","msg":"<span class=\"xx-large\"><span class=\"red\">甘迺迪刺殺案</span></span><br />\n<br />\n1963年11月22日，甘迺迪總統和妻子傑奎琳乘坐一輛敞篷轎車經過德克薩斯州達拉斯市的迪利廣場時不幸中彈殞命。當年的調查顯示，暗殺甘迺迪的刺客是24歲的李&middot;哈維&middot;奧斯瓦爾德，而奧斯瓦爾德在被帶往服刑監獄的途中被一位名叫傑克&middot;魯比的酒店老闆開槍打死。<br />\n<br />\n雖然官方認定奧斯瓦爾德是刺殺甘迺迪的唯一真兇，但是超過70%的美國人認為此事絕不會如此簡單，其背後一定隱藏着巨大的陰謀。一些專家表示現場的彈道痕跡顯示，奧斯瓦爾德當時開槍地點和甘迺迪遇刺時的角度不對應，因此在別的什麼地方一定有人還開了幾槍。當時美國中央情報局正因甘迺迪總統解決古巴「豬灣事件」的方式而對其極為不滿，因此有很多人都將矛頭指向了中央情報局。<br />\n<br />\n在刺殺事件發生後的20年內，涉及該案的重要證人接二連三地丟掉了性命，死亡人數已近200人，但該案的真相卻始終未浮出水面。"},{"pid":"656ccb826a8418b4d90369ec0dcb154ba8029c92","tid":2190092,"uid":191650,"like":0,"dislike":0,"score":0,"quote":{"pid":"f0f1fe154236a35bb04c73fc6f6907cf44278410","tid":2190092,"uid":15605,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-05T10:58:08.000Z","msg":"陰毛論"},"citedBy":0,"replyTime":"2020-09-05T10:58:43.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"7a1a20ec0906d662486095cc737b7cb6eeaa16fb","tid":2190092,"uid":211729,"like":0,"dislike":0,"score":0,"quote":{"pid":"06e82d5364be5f7f406a848d7c91d3dd0ebcfbf5","tid":2190092,"uid":191650,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-05T10:54:50.000Z","msg":"事件的黑暗面<br />\n我覺得911 同埋甘迺迪刺殺都好多嘢睇<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-05T10:59:30.000Z","msg":"翠嶺路魷魚絲陰謀論"},{"pid":"a1a6be0885f0bb552df17cfc309cf1456f35ecf3","tid":2190092,"uid":191650,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-09-05T10:59:31.000Z","msg":"<span class=\"xx-large\"><span class=\"red\">  「9&middot;11」事件  </span></span><br />\n<br />\n來自美國最頂尖大學的幾十名教授和科學家成立了一個名為「揭露『9&middot;11』真相」的組織。<br />\n<br />\n911事件<br />\n<br />\n他們不相信官方對此事的說法，所以自己成立專門的組織調查。這些科學家在一份報告中寫道，噴氣式客機燃燒時產生的火焰不足以完全破壞世貿雙塔的結構，不能導致雙塔最後全部坍塌;在世貿中心廢墟上發現的熔化金屬是一種高溫鋁熱劑所致(鋁熱劑常被用於焊接或切割金屬)。這些科學家依此質疑政府的解釋，並推斷極有可能是某人使用炸藥炸毀了雙塔，或乾脆是政府為了侵入伊拉克而製造了這個如此駭人聽聞的巨大陰謀。"},{"pid":"902f1cba088cf42f908cebd893b99a244d17e7cc","tid":2190092,"uid":191650,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-05T11:00:42.000Z","msg":"<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"3b840be3ba0927456592c27d65c190eebb42d7ca","tid":2190092,"uid":251026,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-09-05T11:06:01.000Z","msg":"911 Controlled Demolition<br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=D7Rm6ZFROmc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DD7Rm6ZFROmc&d=bvaV6%2BUCrkGuzNdoarVmR3r2%2BPVmRcyv9paqmPGdWjc%3D&h=e9e6dc03\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=D7Rm6ZFROmc</a><br />\n<br />\n<img src=\"/assets/faces/lm2/bang.gif\" class=\"hkgmoji\" />"},{"pid":"c13011757f8c01b3a38176b9b3552aa0618c8a89","tid":2190092,"uid":191650,"like":0,"dislike":0,"score":0,"quote":{"pid":"3b840be3ba0927456592c27d65c190eebb42d7ca","tid":2190092,"uid":251026,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-09-05T