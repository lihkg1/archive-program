4:45.000Z","msg":"此回覆已被刪除"},{"pid":"5d0d41e2fecdd3b3b96444d8ceac69fe225fa546","tid":813990,"uid":13878,"like":0,"dislike":0,"score":0,"quote":{"pid":"82b464c765d37663867d8b5bbb3e6a68cc556e97","tid":813990,"uid":11127,"like":0,"dislike":0,"score":0,"quote":{"pid":"b10e74e477bf8e2445e74756dc76fcf6146c61db","tid":813990,"uid":81368,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-09-11T04:24:46.000Z","msg":"#27 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-09-11T04:26:34.000Z","msg":"幾有代入感<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-11T06:45:46.000Z","msg":"真人真事, 講大話我切"},{"pid":"771ea6a2d77da5996a102a03975a9c003911aa7c","tid":813990,"uid":16281,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-09-11T06:47:18.000Z","msg":"此回覆已被刪除"},{"pid":"4300d05615576b01deb5b67f75649a691fd74ee5","tid":813990,"uid":22559,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T06:47:36.000Z","msg":"公園"},{"pid":"9d6d67d288ee814194d848398b0c2c918a0862c7","tid":813990,"uid":127857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T07:02:39.000Z","msg":"夢入面"},{"pid":"983832398a21f3f8e0bf10ff9fd9357f4d6a8baf","tid":813990,"uid":78574,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-11T07:04:04.000Z","msg":"百佳"},{"pid":"a28c64814d424d279f1e95ab7bd8da6390b76937","tid":813990,"uid":20238,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T07:11:33.000Z","msg":"我仲係青頭仔"},{"pid":"93bd9c0d689b69b27f0118a201ed95e894d2a31d","tid":813990,"uid":90978,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2018-09-11T07:13:39.000Z","msg":"Bam<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"0cbba3ba2a0575faacbd736104be68fd7766e93a","tid":813990,"uid":47237,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-09-11T07:18:22.000Z","msg":"我係永星里彌敦道交界間酒店，已拆左<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n同當日玩石器時代，一個細我2年的女網友<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"51cea36579f22d9d0aabc6ef578d43c8478ce5e9","tid":813990,"uid":112303,"like":25,"dislike":3,"score":22,"quote":{"pid":"257ce139bc8843c5700905241ce43c0a37111fd2","tid":813990,"uid":13878,"like":27,"dislike":513,"score":-486,"quote":{"pid":"5e7d8e9b130780fa79f35ce10430b52e7df1b266","tid":813990,"uid":14208,"like":14,"dislike":1,"score":13,"quote":{"pid":"6e88080c4429c294c46d367981e415225a2832f5","tid":813990,"uid":13878,"like":260,"dislike":9,"score":251,"citedBy":2,"replyTime":"2018-09-11T01:32:22.000Z","msg":"中學參加濕尻咩領袖生交流團, 有100個中四-中六學生去北京同東北三省18天團<br />\n<br />\n當年中四16歲未破處<br />\n<br />\n去完番黎屌左3條女...."},"citedBy":1,"replyTime":"2018-09-11T01:35:25.000Z","msg":"Details?"},"citedBy":2,"replyTime":"2018-09-11T03:18:10.000Z","msg":"都無乜特別姐其實<br />\n成班後生仔女玩truth or dare<br />\n玩玩下開始黎料, 有個大我兩年, 18歲既姐姐(叫津津)要同我濕吻30秒<br />\n完左帶左佢番自己房, 我既第一次就發生左...<br />\n之後就晚晚都有屌...<br />\n<br />\n好在我聰明..買左12個裝既套去<br />\n<br />\n去到第三日, 突然有另一個同form, 16歲既女仔(叫彤彤)走黎我房, <br />\n同team既 (分左10team)<br />\n同我講話鐘意我...問我可唔可以錫佢<br />\n於是我錫左佢額頭一啖, 佢大前晚玩game都係度, <br />\n佢係比人罰要入廁所幫我屙尿入個水樽...<br />\n佢話我大前晚做乜咁大膽同第二個濕吻, 而家淨係錫佢額頭...<br />\n跟住就上床黎料...果時我都係做過2,3次...無乜經驗<br />\n點知原來佢又係第一次...不過佢緊好多..同埋有見紅...<br />\n我仲記得果種唔識含, 有D牙既痛感<br />\n<br />\n之後我就晚晚都屌完津津, 就屌彤彤<br />\n去到後期, 我同津津講...其實我同彤彤都有上床<br />\n佢想做我女朋友, 大我兩年既大姐姐好似唔介意咁, 因為佢好似根本無諗過要同我拍拖...<br />\n佢淨係講左一句唔緊要...之後我地就連套都無用...佢同我講話有食藥..原來中出真係好唔同..<br />\n<br />\n去到唔記得北理工大學, 第10日咁上下<br />\n隔離team有個女仔叫shelly, 好靚女既, 成個公仔咁<br />\n我成日想借D兒同佢講野<br />\n終於有一晚可以去到佢地組到玩D game, 其實都係果D truth or dare<br />\n不過我發現佢果組有3個男仔都好似想mark實佢咁, 圍住佢坐...<br />\n我唯有坐開D啦<br />\n<br />\n去到shelly轉完果陣, 佢開左個DARE係話要出酒店外面除左上身衫跑一個圈...<br />\n果時勁大雪, 勁凍...-20幾度....點知轉到我<br />\n咁都要頂硬上啦<br />\n<br />\n跑完番黎凍到冰條咁...我話我唔玩啦..好凍啊, 作病咁 (因為太凍)<br />\n點知SHELLY黎左我房門口, 話煲D熱水我飲...好對唔住果D<br />\n<br />\n我震晒咁係床上面, 佢拎左杯上過黎...跟住就除晒D衫上床攬住我<br />\n真係好暖好暖...果晚我地咩都無發生過<br />\n不過第二朝我5,6點起身, 好番好多啦<br />\n佢都醒左, 我地就開始kiss...同埋做<br />\n佢好濕好濕, 但係佢都係第一次...<br />\n我拉住佢大脾, 拖佢上黎壓住我...<br />\n跟住慢慢, 入出入出咁慢慢入左去<br />\n好暖, 真係成個人都暖晒...跟住淨底果幾日...<br />\n我淨係同津津&amp;SHELLY上床...因為兩個都無帶套...<br />\n都射晒係入面...而咁岩SHELLY應該係岩岩黎完M...<br />\n最後都無事...<br />\n<br />\n番到香港之後...<br />\n我同津津竟然拍左半年拖<br />\n而彤彤就消失左係我生命入面, 因為有其中一晚佢黎搵我..<br />\n我間房入面shelly係度無著衫...<br />\n而shelly就做左我2年SP..."},"citedBy":0,"replyTime":"2018-09-11T07:27:38.000Z","msg":"津津 彤彤 叫雞叫上腦<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> <br />\n師兄受左咩打擊<br />\n實情係truth or dare 要濕吻 條女見到係你<br />\n即刻走左 <br />\n俾人撚完裸跑 原來成班都無理過你 繼續玩<br />\n自己就病到仆街<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n好可憐"},{"pid":"a7e7a11baad5054840040a7792be30649d784c17","tid":813990,"uid":191926,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T07:29:45.000Z","msg":"果年去左金鐘m記後<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"acb91506380d9c5eff324ccb1daf0fb52f07bc4c","tid":813990,"uid":14065,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T07:30:40.000Z","msg":"自己張床<br />\n好普通<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"edc33319f2d5dbbb7d8fcb4b62b788777a4440e7","tid":813990,"uid":6222,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T07:35:22.000Z","msg":"長洲渡假屋"},{"pid":"6a0e7091f587c098512e5e067af143fb28dc1097","tid":813990,"uid":71508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-11T07:38:16.000Z","msg":"ff?"},{"pid":"d0f7b89bafd091ed0311b81db1d923c8430b26e8","tid":813990,"uid":14618,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-11T07:51:03.000Z","msg":"此回覆已被刪除"},{"pid":"c9a86b355f84a70996218005d2e002d26e8aac1c","tid":813990,"uid":112198,"like":0,"dislike":4,"score":-4,"quote":{"pid":"257ce139bc8843c5700905241ce43c0a37111fd2","tid":81399