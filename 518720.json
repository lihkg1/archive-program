b5f17abddec1f0e9a4.png&h=adc351bf&s={SIZE}\" />"},{"pid":"8f33adfe69119d8c263655d416399f8b583f0bb6","tid":518720,"uid":82829,"like":0,"dislike":0,"score":0,"quote":{"pid":"3932abd1244c8616c167440fe6ec6ebe60b84827","tid":518720,"uid":36383,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2018-01-03T15:38:28.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/01/03/233825_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F03%2F233825_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=adc351bf&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-01-03T15:44:47.000Z","msg":"<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" />"},{"pid":"907a7c0f56b92637af140560c6937fad530e8751","tid":518720,"uid":82175,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-01-03T15:48:27.000Z","msg":"有單屌埋都無野 <br />\n主角唔係靚坤 唔係果單"},{"pid":"d71a94024ea0101ed8a35e93bb292aa5551b8ef0","tid":518720,"uid":82829,"like":0,"dislike":0,"score":0,"quote":{"pid":"907a7c0f56b92637af140560c6937fad530e8751","tid":518720,"uid":82175,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-01-03T15:48:27.000Z","msg":"有單屌埋都無野 <br />\n主角唔係靚坤 唔係果單"},"citedBy":0,"replyTime":"2018-01-03T15:58:04.000Z","msg":"姐係邊單<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"72cd7d09ed9b6d2df3e4210f420c65368b590eb6","tid":518720,"uid":71237,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-01-03T16:04:48.000Z","msg":"一些其他保護兒童的法例，例如《防止兒童色情物品條例》下的罪行，縱然控方不需要證明被告明知被描劃的人是兒童[7]，但還是有明文規定辯方可提出「採取一切合理和切實可行的步驟確定被描劃者的年齡」、「基於合理理由相信被描劃者不是兒童」等等的抗辯理由[8]，而非採用「絕對法律責任」。<br />\n<br />\n<a href=\"http://www.pentoy.hk/不知者有罪：思考「絕對法律責任」（文：法政匯/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.pentoy.hk%2F%E4%B8%8D%E7%9F%A5%E8%80%85%E6%9C%89%E7%BD%AA%EF%BC%9A%E6%80%9D%E8%80%83%E3%80%8C%E7%B5%95%E5%B0%8D%E6%B3%95%E5%BE%8B%E8%B2%AC%E4%BB%BB%E3%80%8D%EF%BC%88%E6%96%87%EF%BC%9A%E6%B3%95%E6%94%BF%E5%8C%AF%2F&d=1msKypFCHQ3Q1DD7TfmxMG6tz0R9Svbxs0EcWe5CwMI%3D&h=299481f8\" target=\"_blank\">http://www.pentoy.hk/不知者有罪：思考「絕對法律責任」（文：法政匯/</a>"},{"pid":"1a17e50a146b449baf105c2d49405bb8694d5bfd","tid":518720,"uid":71237,"like":1,"dislike":0,"score":1,"quote":{"pid":"907a7c0f56b92637af140560c6937fad530e8751","tid":518720,"uid":82175,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2018-01-03T15:48:27.000Z","msg":"有單屌埋都無野 <br />\n主角唔係靚坤 唔係果單"},"citedBy":0,"replyTime":"2018-01-03T16:06:29.000Z","msg":"錯啦<br />\n非禮罪已經有絕對法律責任<br />\n參考返香港特別行政區 訴 蔡偉麟，HCMA 620/2016"},{"pid":"a66051f8111d93e2df4950aef4cb4cc5e663453f","tid":518720,"uid":76148,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-03T16:06:53.000Z","msg":"hello moto"},{"pid":"8c4b9d3ec8b89e85a9966007b243ad8edbc9fe9b","tid":518720,"uid":61763,"like":0,"dislike":0,"score":0,"quote":{"pid":"72cd7d09ed9b6d2df3e4210f420c65368b590eb6","tid":518720,"uid":71237,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-01-03T16:04:48.000Z","msg":"一些其他保護兒童的法例，例如《防止兒童色情物品條例》下的罪行，縱然控方不需要證明被告明知被描劃的人是兒童[7]，但還是有明文規定辯方可提出「採取一切合理和切實可行的步驟確定被描劃者的年齡」、「基於合理理由相信被描劃者不是兒童」等等的抗辯理由[8]，而非採用「絕對法律責任」。<br />\n<br />\n<a href=\"http://www.pentoy.hk/不知者有罪：思考「絕對法律責任」（文：法政匯/\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.pentoy.hk%2F%E4%B8%8D%E7%9F%A5%E8%80%85%E6%9C%89%E7%BD%AA%EF%BC%9A%E6%80%9D%E8%80%83%E3%80%8C%E7%B5%95%E5%B0%8D%E6%B3%95%E5%BE%8B%E8%B2%AC%E4%BB%BB%E3%80%8D%EF%BC%88%E6%96%87%EF%BC%9A%E6%B3%95%E6%94%BF%E5%8C%AF%2F&d=1msKypFCHQ3Q1DD7TfmxMG6tz0R9Svbxs0EcWe5CwMI%3D&h=299481f8\" target=\"_blank\">http://www.pentoy.hk/不知者有罪：思考「絕對法律責任」（文：法政匯/</a>"},"citedBy":0,"replyTime":"2018-01-03T16:08:43.000Z","msg":"<a href=\"http://legalref.judiciary.hk/lrs/common/search/search_result_detail_frame.jsp?DIS=110598&amp;QS=%2B&amp;TP=JU&amp;ILAN=tc\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Flegalref.judiciary.hk%2Flrs%2Fcommon%2Fsearch%2Fsearch_result_detail_frame.jsp%3FDIS%3D110598%26QS%3D%252B%26TP%3DJU%26ILAN%3Dtc&d=1msKypFCHQ3Q1DD7TfmxMG6tz0R9Svbxs0EcWe5CwMI%3D&h=4ec4d427\" target=\"_blank\">http://legalref.judiciary.hk/lrs/common/search/search_result_detail_frame.jsp?DIS=110598&amp;QS=%2B&amp;TP=JU&amp;ILAN=tc</a><br />\n3.  控方現在以案件呈述方式要求原訟法庭就下列因本案聆訊時所產生的法律問題提出上訴及要求作出指引：&mdash;<br />\n<br />\n(1)   基於本案的事實裁定，裁判官引用英國案例R v K[3]的裁決作為本案裁決的基礎是否正確？<br />\n<br />\n(2)   裁判官裁定有關猥褻侵犯罪行的受害人的年齡議題並不是一項「絕對法律責任」是否正確？<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n結論<br />\n<br />\n49.  基於上述原因，就控方的提出的法律問題，本席的裁定如下：<br />\n<br />\n(1) 裁判官裁定英國上議院案例R v K的裁決在本猥褻侵犯案中適用是否正確？<br />\n<br />\n裁斷：該英國案例可作區分但並不適用在本猥褻侵犯案件。<br />\n<br />\n(2) 裁判官裁定猥褻侵犯罪在受害人的年齡這議題而言並不是一項絕對法律責任罪行，這裁決是否正確？<br />\n<br />\n裁斷：不正確。"}]}