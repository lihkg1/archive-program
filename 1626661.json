thread/1626523/page/1</a>"},{"pid":"09920d1f5725a0e0693f60c56d2208fd470a0144","tid":1626661,"uid":61886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:24:30.000Z","msg":"push"},{"pid":"1ce9a957623676d9b667593ec13ba91a5a3f814b","tid":1626661,"uid":250356,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:29:15.000Z","msg":"推"},{"pid":"e6b5aaba7b13ab5e75bef841a46cfa6f9e84113e","tid":1626661,"uid":61886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:31:05.000Z","msg":"push"},{"pid":"fb85e7bebf6395543ad3bd73d207f7aaec90d999","tid":1626661,"uid":14566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:31:08.000Z","msg":"和理非去港島<br />\n做野去黨鐵沿線/商場"},{"pid":"e293f37dcc81d1150db35c0f6a8926bf0765251c","tid":1626661,"uid":61886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:35:34.000Z","msg":"push"},{"pid":"41212d9eb980da4cc003d7a06d250f2bc3db82d2","tid":1626661,"uid":183971,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-05T13:37:19.000Z","msg":"叫左唔好去港島啦冇人理"},{"pid":"bc95236980f9290bd19d255fd64680be1e1716d0","tid":1626661,"uid":255637,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-05T13:38:17.000Z","msg":"岩 勇武手足留係九龍 班狗部陣 一定重兵港島"},{"pid":"77ccd9162f9e63ae442f8a7ba71a9901374db9f2","tid":1626661,"uid":61886,"like":0,"dislike":0,"score":0,"quote":{"pid":"41212d9eb980da4cc003d7a06d250f2bc3db82d2","tid":1626661,"uid":183971,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-05T13:37:19.000Z","msg":"叫左唔好去港島啦冇人理"},"citedBy":1,"replyTime":"2019-10-05T13:38:50.000Z","msg":"和理非去ok<br />\n但勇武手足諗清楚好啲"},{"pid":"8aec6242c42dfb282dfb0e018b507316de736ff7","tid":1626661,"uid":169195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-05T13:39:15.000Z","msg":"yes 和理非有和理非行"},{"pid":"9dfd9e07e4eaac6ffd154585cab1d83cc54543a8","tid":1626661,"uid":76310,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-05T13:40:42.000Z","msg