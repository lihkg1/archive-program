ata-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaMf1RYs.jpg&h=d189414d&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">把我臉上的口罩撕下來朝我吐了口吐沫，說「我活不了，你們都別想活」</span></span><br />\n<img src=\"https://na.cx/i/XkLMVDM.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXkLMVDM.jpg&h=058fd92f&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">撕扯她們的防護服<br />\n「要死一起死」</span></span><br />\n<img src=\"https://na.cx/i/i7qtpw7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fi7qtpw7.jpg&h=11a8b2cc&s={SIZE}\" />"},{"pid":"8f550e6256976876627011ba4c39b9564d2bee24","tid":1847131,"uid":24133,"like":0,"dislike":0,"score":0,"quote":{"pid":"5603e0f69ab338232eca4818a28c8bcb554fed9b","tid":1847131,"uid":38842,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-28T02:41:19.000Z","msg":"醫管局員工陣線訴求<br />\n<img src=\"https://na.cx/i/j81sQgB.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fj81sQgB.jpg&h=bb0e553a&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-01-28T06:22:24.000Z","msg":"信我 你哋一日唔<img src=\"/assets/faces/normal/censored.gif\" class=\"hkgmoji\" />人 一日都唔會冇事 <img src=\"/assets/faces/lny/smile3.gif\" class=\"hkgmoji\" />"},{"pid":"6622c15cfb9d9fe49fe2d766e60287be3672f63c","tid":1847131,"uid":38842,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T07:13:40.000Z","msg":"<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"a7feabbbc4eab7f31cc4847132465ef72d45b638","tid":1847131,"uid":37528,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T07:15:00.000Z","msg":"一齊罷"},{"pid":"190214c836a0bcebc07c8687230c61d4a06bafbd","tid":1847131,"uid":10070,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":