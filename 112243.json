ss=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"d5bace18b8467d201b7d2092bd5e5b406cab9d65","tid":112243,"uid":77189,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T06:38:25.000Z","msg":"仲未有文<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /><br />\n放低左正皮啦，麻煩加速<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"6f8b51183e326401d76789a43fe92a0541622d5c","tid":112243,"uid":76306,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T06:43:54.000Z","msg":"快啲出埋佢 完啦好嗎<img src=\"/assets/faces/lomoji/16.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/16.png\" class=\"hkgmoji\" />"},{"pid":"0b161aa35063c6a4dc9ac7c5725fff18b40c361d","tid":112243,"uid":10962,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T06:55:57.000Z","msg":"正呀"},{"pid":"be215b5041449824ca06ff8c61fc07ccae576cca","tid":112243,"uid":5647,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T08:50:42.000Z","msg":"留名<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b1c9c3e62f5e04324f6e7fdf290ff6d560ea36d3","tid":112243,"uid":342,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T08:55:24.000Z","msg":"皮已正<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"784071c7ce40d4a236ba9da56d51a67e21d366ff","tid":112243,"uid":38395,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T10:36:39.000Z","msg":"文呀屌你<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"2503b828413d6c8368234ad8c85e193a57432dd9","tid":112243,"uid":17607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T11:12:36.000Z","msg":"文"},{"pid":"9b28e526d11c9dfc0a092a60264bdf68a21399d1","tid":112243,"uid":17386,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T11:35:23.000Z","msg":"文呢屌<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"dbf19cecc64837c0bb731f86e81317bf1233a8ad","tid":112243,"uid":54282,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T11:35:53.000Z","msg":"Lm"},{"pid":"a5d2b23a1e00ce47c2a8f75fa277c695b4a3be7e","tid":112243,"uid":74996,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T11:39:06.000Z","msg":"留名"},{"pid":"925a585d8d50e2546abbe54ee04cf52d9f81000b","tid":112243,"uid":8380,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T13:39:31.000Z","msg":"文呢"},{"pid":"8a0b14e1dfb5bf84335e474ec89d892ad98730ea","tid":112243,"uid":79790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T14:57:53.000Z","msg":"留名"},{"pid":"af8e3b7f006125ed692db7f17e16ce9feb1c4790","tid":112243,"uid":4852,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T15:22:12.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"369d04fe11a22b3429959121ea5b6bdbcef7233e","tid":112243,"uid":17607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T15:25:24.000Z","msg":"Dllm"},{"pid":"5858318e8a612f0007251bd5acf6f7a9619a6d19","tid":112243,"uid":81824,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T15:52:06.000Z","msg":"dnlm"},{"pid":"b06a6fbab15b5dd4b8ec2893ccd0a0c0519dac42","tid":112243,"uid":49062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T16:20:24.000Z","msg":"文呀"},{"pid":"d6ee39ead7bb6abb80ec768195f6d29ebffa89c1","tid":112243,"uid":38966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T16:49:18.000Z","msg":"「找我出來想說是什麼？」<br />\n<br />\n看著玄茵那疑惑的眼神，我愈發她可愛的一面。心內萌起了戲弄她的想法。<br />\n<br />\n「把手伸出來，我有東西想交給妳。」<br />\n<br />\n她有點遲疑道「給我什麼？」<br />\n<br />\n「把手伸出來先。」<br />\n<br />\n雖然她仍有不惑，但也照著我說話做。她有手伸出，掌心朝天。<br />\n<br />\n我把右手伸進褲袋裡，握緊拳頭。<br />\n<br />\n「等一下記緊要捉實。」我再次開口提醒，同時把手拿出來。<br />\n<br />\n「嗯⋯⋯」從她的語氣中，我感到一絲緊張。<br />\n<br />\n我快速地把手迎著她的手拍下去，可能因為聽到我的指示，她也立即捉緊。<br />\n<br />\n而她捉緊的只是我的手。<br />\n<br />\n我牽著她的手向前跑，原來她的手也很小。<br />\n<br />\n她沒有撇開我的手，低著頭籌跟著我慢慢跑。<br />\n<br />\n跑了一少段，我便停下來。我看著她不知是因運動還是害羞而紅的臉道「我們慢慢走吧。」<br />\n<br />\n她點點頭，輕聲細語地道「嗯。」<br />\n<br />\n我把手牽得更緊，慢慢走著。"},{"pid":"520d543a36b74a89744aba131a0dd21961fa82de","tid":112243,"uid":38966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T16:49:28.000Z","msg":"今日仲有"},{"pid":"b8aa4ef89787f2260882656965c62667a35e853a","tid":112243,"uid":29125,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T17:02:28.000Z","msg":"我是來留名的<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"bef2e4e4585fe406184a4d19b5009d6e0e755772","tid":112243,"uid":73633,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T18:05:45.000Z","msg":"有文未"},{"pid":"95cbd18e63aab7a124a6d83cff78188a55e96908","tid":112243,"uid":35822,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T18:47:15.000Z","msg":"求文<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"ad4ccdb8c3f581c2402f7993fcb1e492e5706cc7","tid":112243,"uid":38966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T21:59:46.000Z","msg":"「捉得這麼緊，我都食不了東西啦。」<br />\n<br />\n看著她可動的只剩下左手。我馬上鬆手，摸一摸後腦道「不好意思⋯⋯」<br />\n<br />\n她看著我這笨拙的一面，掩著嘴輕輕笑著，越笑我便越覺尷尬。<br />\n<br />\n我唯有提早說正事才可打破這個困局。「話說嫉妒之神的下屬也可以下凡嗎？」<br />\n<br />\n她支支吾吾地道「可⋯可以呀。怎麼了？」<br />\n<br />\n我接著問「那妳知道他們現在在凡間嗎？」<br />\n<br />\n她的眼神稍有轉移道「我不清楚。」<br />\n<br />\n我壓低聲浪，用那認真的語氣對她說「我懷疑阿智是受到他們的影響，所以才性情大變。」<br />\n<br />\n她詫異地望著我。<br />\n<br />\n「我想救阿智，幫幫我，告訴我真說話吧，拜託！」我低下頭謹誠地說。<br />\n<br />\n她嘆一嘆氣「好吧，但我知道的也不多。」<br />\n<br />\n「嗯」我把椅子拉近到旁，細心地聽著。<br />\n<br />\n「其實我再次回來的其中一家重要原因是要調查嫉妒之神的一個下屬。他也下來了，而且有消息指他在這裡附近。」<br />\n<br />\n雖然不知道他身在何方，但是了解到這消息也好，起碼可以確保我猜中了。<br />\n<br />\n「那他們有弱點嗎？」<br />\n<br />\n「我也不太清楚，可能和我們相反。我們仙子非常討厭嫉妒的感覺，可能他們也討厭愛意吧？」<br />\n<br />\n看到停下來沈思的我，玄茵推了一推「在想什麼？都停下口。」<br />\n<br />\n我順著她的視線望下去，才發現我的飯原來只食了一口。<br />\n<br />\n這個好機會我當然不會放過，我望著她的雙眼「在想妳。」<br />\n<br />\n玄茵用她的小手輕輕打了我的手臂一下道「智障，食你就食啦。」<br />\n<br />\n我看一看手錶，眼看午膳時間也差不多完結，我加快了進食速度。"},{"pid":"53aecdacc8bb79d04808e144d2ad40c97d11dee3","tid":112243,"uid":17607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T23:36:16.000Z","msg":"咁少"},{"pid":"76e2d8a232e28c0e8d0c86808336897c04e1df5b","tid":112243,"uid":35946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-08T23:55:01.000Z","msg":"<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" />"},{"pid":"280c0b89f87f4341f48f02e45a1c4d26096b45a0","tid":112243,"uid":5647,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-09T00:34:22.000Z","msg":"Live<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f8f8f88dead2b3f41272fa366a5bdd98019cc8dd","tid":112243,"uid":73924,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-09T04:05:17.000Z","msg":"Live<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"154d112bc40ea02b081e637bd904e924306a42f1","tid":112243,"uid":68185,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-09T08:49:30.000Z","msg":"live<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"291e18dcd114ba61a788002c4204ba095dcc051d","tid":112243,"uid":17607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-09T10:25:02.000Z","msg":"文"},{"pid":"3880e9acf5d0f9a25ce562d77de129cd9029c29b","tid":112243,"uid":46158,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-09T10:33:08.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"02dd4b0380b64c1006db8d6e106ebe727e93bfaa","tid":112243,"uid":18958,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-09T12:26:26.000Z","msg":"live<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"9b4daa615129e691d08b5dd8af0ab21c8042571d","tid":112243,"uid":57490,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-09T16:25:17.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c5af772b9255a5f1c8d9f9529c9cd323c6b722ac","tid":112243,"uid":38966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-09T17:27:07.000Z","msg":"以下為穎怡視覺<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n「還以為妳會有異性無人性，忘了我們這班姐妹呢。」小美挽著我的手靠了過來。<br />\n<br />\n雖然同樣為女生，但手臂感覺到她那頗為豐滿的胸脯，難免會有點不自在。<br />\n<br />\n「怎麼會忘了妳們，我永遠也不會忘記的。」我微笑著，望向小美和雪櫻，向她們許下承諾。<br />\n<br />\n奇怪，我怎麼有種以前也說過的感覺？<br />\n<br />\n小美摸著她的肚子。「我們先去餐廳找位置吧，我有點餓。」<br />\n<br />\n那酥胸向我擠過來，我感受到我和她相比只是小巫見大巫，同時內心也越來越嫉妒她。<br />\n<br />\n突然間，雪櫻驚叫了一下，指著前方「妳們看！」<br />\n<br />\n那不是阿洛和玄茵嗎？他們怎麼會牽著手？<br />\n<br />\n看著他們倆人的身影，一種似曾相識的感覺再次升起。我不知不覺間對玄茵生起妒忌感。<br />\n<br />\n一個奇怪的想法出現在我腦海，為什麼他旁邊的不是我？<br />\n<br />\n我搖一搖頭，希望把這個想法撇開。<br />\n<br />\n小美用那意味深長的語氣道「阿洛真人不露相呀。」<br />\n<br />\n「其實他們也很襯呀，尤其是在聖誕舞會的時候。妳說是不是？」雪櫻望著我。<br />\n<br />\n我敷衍地應了一句「嗯。」此刻的我腦海中只剩下葡萄感，已經無法正常思考。"},{"pid":"fed40bf2033cb82a8316dd1205b29380ea167988","tid":112243,"uid":49483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-09T22:49:46.000Z","msg":"到底最尾阿洛會唔會接手呢個愛情之神同玄茵一齊happy happy呢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5b4c20540546d07e83100d836700f9b7b105e9aa","tid":112243,"uid":17607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T01:20:15.000Z","msg":"加甜"},{"pid":"5482ecb6c4fe2fffafa7582ec2a2ff316193f7d4","tid":112243,"uid":35946,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T01:33:46.000Z","msg":"有嫉妒感出現！"},{"pid":"f4448de352d0ea7269c05cd756731bfaa730a105","tid":112243,"uid":38395,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T02:03:24.000Z","msg":"<blockquote>加甜</blockquote><br />\n+1+1+1"},{"pid":"0c71fae36d707e8a7fbb10d83506cbf73382278c","tid":112243,"uid":39763,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T08:33:10.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"59c04b1008471c41e74a66778fdd2346c418626c","tid":112243,"uid":49062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T13:07:09.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"cc587078d92bd6c53f1f570851a60ec655587c5a","tid":112243,"uid":80673,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T13:25:39.000Z","msg":"留名<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b3f5366220d198540c071db0fe8deb06b053038f","tid":112243,"uid":38395,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T14:19:10.000Z","msg":"文文文文文文文文文文文文文文文文文文文文文文文文阿"},{"pid":"c8f1ff5752d8b28e36a0d00762b52fe3e263b946","tid":112243,"uid":12855,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T23:37:56.000Z","msg":"會唔會穎怡係妒忌仙子<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <br />\n兩大仙子鬥法"},{"pid":"767fd22d309ef61543ecd07dc1e1858d862a7c80","tid":112243,"uid":17607,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-10T23:50:54.000Z","msg":"文"},{"pid":"95e139656e6ae249f73235863bdfb175b9bb733f","tid":112243,"uid":44493,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-11T02:32:30.000Z","msg":"留名"},{"pid":"af2974ae20f818c42dcd58432e29ea84d0b444c5","tid":112243,"uid":25106,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-11T02:47:35.000Z","msg":"加速<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"41bc1d9a664dd0bedff354fe800f97df427ace6d","tid":112243,"uid":25483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-11T14:23:34.000Z","msg":"<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> 文呢"},{"pid":"c52e0c95dd5e1415c9f1f119b4a434889aaf8a33","tid":112243,"uid":38395,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-11T15:25:53.000Z","msg":"文呀"},{"pid":"a45221469e452b10573b440efadbe3adb285e924","tid":112243,"uid":14871,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-11T16:50:52.000Z","msg":"無文<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"b172188fa7794126a7056b71d183f009357c7935","tid":112243,"uid":4852,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-11T18:20:37.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4fffeee4c093f2bcf404a0000c6b8297723e476c","tid":112243,"uid":16306,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-12T02:33:46.000Z","msg":"樓主係咪想要負皮？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4a35d9163d4afbac67cba7efd5387e82b06ec5b8","tid":112243,"uid":38966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-12T03:38:35.000Z","msg":"以下為穎怡視覺<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n我推開圖書館的門，走向那我固定的座位。<br />\n<br />\n咦？竟然有人坐在我的位置上？<br />\n<br />\n我望一望，原來是阿洛和玄茵，今天已經撞見他們幾次了，就好像是有人在引導我一樣。<br />\n<br />\n那個座位是很久以前我和他人約定的位置，但是我卻想不起那個他是誰。<br />\n<br />\n我一直沈思在我的腦海裏。一回過神來，已經走向他們旁的那個書櫃，在觀察他們。<br />\n<br />\n他們坐在鄰座，各自各專心地做功課。<br />\n<br />\n「喂！看過來。」玄茵拿起筆指在阿洛的臉頰不遠的地方。<br />\n<br />\n「怎麼了？」阿洛雖然在對玄茵說話，但頭卻專心向著作業，沒有望過去。<br />\n<br />\n一如我所料，那支筆恰好戳到阿洛。<br />\n<br />\n「哈哈，你真可愛。」玄茵笑起來。<br />\n<br />\n阿洛舉起食指，放在嘴邊「殊，圖書館要小聲一點。」<br />\n<br />\n玄茵依然笑著，但換了個方式。她掩著嘴，笑到曲起腰，頭向阿洛的方向靠過去。<br />\n<br />\n看著他們倆個如此的打情罵俏，我心中的嫉妒感再次出現，彷彿是我心愛的東西被搶走。<br />\n<br />\n我望向他們的桌上，阿洛的那張書籤吸引著我的目光。<br />\n<br />\n我從書包中拿出一本書，翻開。<br />\n<br />\n那張書籤和我擁有的那一張一模一樣！<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n「為什麼是三葉草？不是送四葉草？」<br />\n<br />\n「才不是咧。這個明明是四葉草。妳沒聽說過嗎？其實每個三葉草也是四葉草，而它的第四塊葉就在這裡。」那個男孩指一指他的心。<br />\n<br />\n男孩再次張口解釋「因為三葉草的葉子是心形，只要再加上它，三葉草才會完整成為四葉草。」<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n我那模糊的記憶開始變得清晰，我想起那個男生是誰了！<br />\n<br />\n那個和我一起做過很多約定，一直伴隨我身邊的人是阿洛！！"},{"pid":"7a857aafe7ec131dd0631d8c068b49153d776255","tid":112243,"uid":54961,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-12T03:51:21.000Z","msg":"加速<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"75fce494f21b74e5e3f4d9b994fcf197e13dbf7d","tid":112243,"uid":5647,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-12T09:16:53.000Z","msg":"加速<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e84b6922a8bc4551f3456388ee001b2c20e010e5","tid":112243,"uid":49062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-12T09:28:29.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"aeedffb459c95d8965bf8550d441467d32188529","tid":112243,"uid":35301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-12T11:24:51.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"43d570eca1762799f47cae5969369c8966c81e20","tid":112243,"uid":38395,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-12T15:18:03.000Z","msg":"加速"},{"pid":"069f9da5269d55e9f68a63a01717906a13e9371b","tid":112243,"uid":25483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-12T16:31:44.000Z","msg":"加速<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"54677a21682f210afadd3be9199713321028f2ca","tid":112243,"uid":38966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-13T08:25:07.000Z","msg":"以下仍然為穎怡視覺<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<br />\n「震⋯」<br />\n<br />\n一條來自阿智的信息「去圖書館找到資料嗎？」<br />\n<br />\n望著手機，我內心開始掙扎起來。<br />\n<br />\n之前我失去和阿洛的記憶，忘了和他經歷過的一切。而阿智對我也不差，所以我才答應他的追求。<br />\n<br />\n如今我已經回想起以前的一點一滴，重拾我對阿洛的那一份感情。無謂再給予假希望阿智，我應該跟他說清楚。<br />\n<br />\n「嗯，等一陣在課室見面可以？我有說話要對你說。」<br />\n<br />\n我踏出圖書館，去面對我的那份感情。<br />\n<br />\n「妳到了，有甚麼想跟我說？」阿智從我到開始一直微笑著，看得出是由心而不是刻意的笑。<br />\n<br />\n面對這樣子的阿智，我心中的內疚感更加強烈。<br />\n<br />\n我向阿智躹躬說「對不起！」<br />\n<br />\n我瞄一瞄他，他那錯愕的表情，我這一輩子也不會忘記。<br />\n<br />\n我接著道「我想起以前忘記的一些事，我喜歡的人是阿洛，對不起，我不能接受你。」我再次躹躬道歉。<br />\n<br />\n這一秒寧靜得可怕，彷彿世界突然停頓了。<br />\n<br />\n我抬頭打算望一望他的反應。<br />\n<br />\n他面目猙獰地望著我「阿洛！阿洛！又是阿洛！」<br />\n<br />\n阿智推開了我，走了出去。"},{"pid":"c8a7fe1a9b7f6f64c94a6c6663947f2596641885","tid":112243,"uid":25106,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-13T08:29:23.000Z","msg":"好好睇<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> 加油"},{"pid":"7ac0e551344ebb31f45de802b9cb392bc7cf077e","tid":112243,"uid":38966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-13T08:39:44.000Z","msg":"求正評<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"00a9b63a87a6cfb9adfe473539a084caa3101285","tid":112243,"uid":38966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-