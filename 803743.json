1e531e594cefd3caf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F223246_503fcba7fd9f8ca1e531e594cefd3caf.jpg&h=cf672452&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/223246_c662d3e93f63a19e63bdd890328fd36f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F223246_c662d3e93f63a19e63bdd890328fd36f.jpg&h=62548a3b&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/223246_100fd7c795104a3e277c1b105a6feaa5.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F223246_100fd7c795104a3e277c1b105a6feaa5.jpg&h=63ef127d&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/223247_0b240c3e9888dca7b8262d93794be4c4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F223247_0b240c3e9888dca7b8262d93794be4c4.jpg&h=2c3b4ac9&s={SIZE}\" /><br />\n<br />\n最後都留返個IG 得閒都會放吓相上去:<br />\n<a href=\"https://www.instagram.com/tay.wong_/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Ftay.wong_%2F&d=Vy0TySViDNS4XTsTqoj6lpWUQYxlHU4vp7GM3pu%2FB4U%3D&h=fc568c94\" target=\"_blank\">https://www.instagram.com/tay.wong_/</a><br />\n<br />\n同埋都總結吓帶咗啲咩相機<br />\nIn case有人有啲興趣嘅話<br />\n- Rolleicord VB (菲林相機)<br />\n- Contax TVS (菲林相機)<br />\n- Sony A7<br />\n鏡頭就得兩枝:<br />\n- Sony FE55 1.8 (八成時間都用佢)<br />\n- Canon 17-40L (除咗道頓堀近乎冇用過)<br />\n<br />\nP.S.<br />\n嘢食呀有咩玩其實都唔講太多 都係去吓USJ 食吓壽司大阪燒鰻魚飯之類<br />\n唯一特別啲就係去咗呢啲有成層Game Room嘅Airbnb<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/230458_06a25663cbd5e6683273448bb031484e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F230458_06a25663cbd5e6683273448bb031484e.jpg&h=54141a25&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/230458_4f404e4ac770a466b742e0bf247b976d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F230458_4f404e4ac770a466b742e0bf247b976d.jpg&h=7833fb5d&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/230459_c3794bb4c871a3a878457082b0664a5e.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F230459_c3794bb4c871a3a878457082b0664a5e.jpg&h=99d76b0e&s={SIZE}\" /><br />\n不過心水清都知呢啲係連鎖經營嘅 所以就自行判斷啦<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n一來第一次去乜都唔識 二來大阪都係太過熱門嘅地方好多人都去過哂 而且連登大把高手識搵嘢食又識搵路<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <br />\n所以見唔多人開呢路Post 都係專心Po相 不過都不妨吹吓水<span style=\"font-size: small;\"><del>幫手推吓Post</del></span><img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<span style=\"color: orange;\"><span style=\"font-size: xx-large;\">文同圖都已完 一齊留言傾吓計<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> </span></span>"},{"pid":"45ab6c866985e4cb0479f7981c4ba2acf74dc104","tid":803743,"uid":19162,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-02T14:19:00.000Z","msg":"大阪食蟹除左蟹道樂，有咩好推介？？"},{"pid":"489757948710784ee4e876307d4eb11e5b4124ba","tid":803743,"uid":38569,"like":0,"dislike":0,"score":0,"quote":{"pid":"45ab6c866985e4cb0479f7981c4ba2acf74dc104","tid":803743,"uid":19162,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-02T14:19:00.000Z","msg":"大阪食蟹除左蟹道樂，有咩好推介？？"},"citedBy":0,"replyTime":"2018-09-02T15:02:07.000Z","msg":"今次去得好hea同第一次去 冇食過蟹<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"9b86edafefc0e408fb9f810b4b3386a39d618449","tid":803743,"uid":3932,"like":1,"dislike":0,"score":1,"quote":{"pid":"1ed557c3bbc23afcd1a69c10d0e750dcba6fda03","tid":803743,"uid":38569,"like":0,"dislike":0,"score":0,"quote":{"pid":"a6c0def9c2506e74ae7b55