/>\n唔該各位用盡所有渠道宣傳<br />\n威迫利誘你哋嘅兄弟家人出嚟築成人鏈。<br />\n<br />\n拖手其實係一樣好閒嘅事。<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n唔好介意拖手， 唔會生bb，唔會有任何野。<br />\n愛自己，愛香港，拖一次。"},"citedBy":0,"replyTime":"2019-08-23T02:44:06.000Z","msg":"推"},{"pid":"269c2617a16b23e2677eded4fe79ac3dabc14e1b","tid":1497221,"uid":238275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-23T02:45:04.000Z","msg":"pushhh"},{"pid":"936686f070d25d120b4709d269c52fb7e4768bf3","tid":1497221,"uid":181035,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-23T02:45:33.000Z","msg":"鳩蛇一齊出啦"},{"pid":"a14b0247e0ddbd1f6053bfaadc23dd38544dd607","tid":1497221,"uid":62270,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-23T02:46:12.000Z","msg":"推"},{"pid":"3ff7884491f2e20c0cbc71be45a353b555d88bdb","tid":1497221,"uid":43785,"like":0,"dislike":0,"score":0,"quote":{"pid":"936686f070d25d120b4709d269c52fb7e4768bf3","tid":1497221,"uid":181035,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-23T02:45:33.000Z","msg":"鳩蛇一齊出啦"},"citedBy":0,"replyTime":"2019-08-23T02:55:52.000Z","msg":"好"},{"pid":"2fc48c2d40d80f954fa80784c37391d8062e7350","tid":1497221,"uid":60563,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d6f24ba5f9e65fa6c443fe29a7bddeedc103c53","tid":1497221,"uid":300740,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-08-23T01:20:09.000Z","msg":"你 同事 叫人 曱甴？？"},"citedBy":0,"replyTime":"2019-08-23T02:57:25.000Z","msg":"鳩硬蛇wor<br />\n佢同事咪曱甴屎<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"855fb23883634d28023dd6d2502483be6d387385","tid":1497221,"uid":93962,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-23T02:57:44.000Z","msg":"721"},{"pid":"d243b341f856ccdb7f21bf3bac08befe0601d333","tid":1497221,"uid":7738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-23T02:58:24.000Z","msg":"今晚見"},{"pid":"04d6aaffe81ca1ae9b361829d3c082ae42a0abc0","tid":1497221,"uid":10778,"like":0,"dislike":0,"sco