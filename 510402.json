.gif\" class=\"hkgmoji\" />"},{"pid":"302fd839c5a9c57320f46e021561acecba9a9975","tid":510402,"uid":68014,"like":0,"dislike":0,"score":0,"quote":{"pid":"95245c76118cd7ad33c4c58245285bf36bc5dad8","tid":510402,"uid":68014,"like":2,"dislike":1,"score":1,"citedBy":1,"replyTime":"2017-12-26T14:39:22.000Z","msg":"講回憶我諗細個幾歲仲讀緊幼稚園個陣<br />\n成日阿媽接完放學去食個鰻魚飯<br />\n好懷念<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2017-12-26T14:40:16.000Z","msg":"美心個鰻魚飯，講漏左"},{"pid":"789253758f3398b5d1b17e4b111bd50f645d5a8c","tid":510402,"uid":127041,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-12-26T15:32:05.000Z","msg":"<img src=\"/assets/faces/xm/oh.gif\" class=\"hkgmoji\" />"},{"pid":"7ed631e8c783f2bfaf50a13fb69e142abbfdf45e","tid":510402,"uid":3068,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-12-26T16:10:28.000Z","msg":"未食過呢隻咁濕潤<img src=\"/assets/faces/xm/wonder.gif\" class=\"hkgmoji\" /> 唔係燒嘅咩？<img src=\"/assets/faces/xm/angel.gif\" class=\"hkgmoji\" />"},{"pid":"3869faec7d71e7d3b0ec581ab1aeaa623a5084f9","tid":510402,"uid":103317,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2017-12-26T16:29:27.000Z","msg":"<blockquote>急凍櫃拎出黎再放入熱水浸15分解凍都有人鍾意食</blockquote><br />\n公仔麵夠係搵熱水浸3分鐘，全世界唔知幾多億人鍾意食呢"},{"pid":"bbe98854b7af6cc3f598b5b771e48fc35727337d","tid":510402,"uid":15471,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2017-12-26T16:35:04.000Z","msg":"<img src=\"http://www.twwiki.com/uploads/wiki/c9/73/649532_0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.twwiki.com%2Fuploads%2Fwiki%2Fc9%2F73%2F649532_0.jpg&h=71fccac2&s={SIZE}\" />"},{"pid":"d221e94fcb9e727c018a184b1a1b49a43f3d5628","tid":510402,"uid":127041,"like":0,"dislike":0,"score":0,"quote":{"pid":"7ed631e8c783f2bfaf50a13fb69e142abbfdf45e","tid":510402,"uid":3068,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2017-12-26T16:10:28.000Z","msg":"未食過呢隻咁濕潤<img src=\"/assets/faces/xm/wonder.gif\" class=\"hkgmoji\" /> 唔係燒