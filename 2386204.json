{"tid":2386204,"cid":5,"subCid":11,"title":"匈牙利批准使用國藥疫苗　成首個使用中國疫苗歐盟國家","createTime":"2021-01-29T12:26:53.000Z","updateTime":"2021-01-29T17:17:58.000Z","uid":218158,"like":2,"dislike":14,"uniUserReply":11,"replies":[{"pid":"d764daac156c1b7d1aa949953044e361b41146e6","tid":2386204,"uid":218158,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-29T12:26:53.000Z","msg":"<a href=\"https://t.me/rthk_new_c/151708\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Frthk_new_c%2F151708&d=mGfgamXUORjeED7mKz2VH3Kg77Sy3LnB9Oyli8DN%2Bms%3D&h=8b408867\" data-auto-link target=\"_blank\">https://t.me/rthk_new_c/151708</a><br />\n<br />\n匈牙利監管當局，通過批准使用中國國藥集團研發的新冠疫苗，匈牙利成為首個批准使用中國疫苗的歐盟國家。匈牙利預計會在下月接收50萬劑國藥疫苗。匈牙利總理歐爾班早前表示，最快會在今日或明日，簽署訂購中國新冠疫苗的協議，他又表示，一直留意鄰國塞爾維亞的疫苗接種情況。塞爾維亞是首個使用中國疫苗的歐洲國家，早前亦展開大規模接種工作。"},{"pid":"fa3c3fc9b4d8173fd9e0c2ab1b60be905338dda3","tid":2386204,"uid":15010,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-01-29T12:29:46.000Z","msg":"good luck"},{"pid":"6ab3b4ccc22476462e258b75afeac19c609c6a86","tid":2386204,"uid":218158,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-29T12:31:01.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"cfafedeeb206e62a4a90aa7e9c0f6c91456e9f5a","tid":2386204,"uid":89683,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-29T12:31:16.000Z","msg":"匈奴人"},{"pid":"67c9d9e4065b6b845bcc0a4dca051c6c18fa4e22","tid":2386204,"uid":53062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-29T12:32:11.000Z","msg":"支持佢"},{"pid":"e74506e02dde6f794b874e2f42999baaa8ed3fc9","tid":2386204,"uid":129169,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-01-29T12:32:42.000Z","msg":"人口清洗<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"ef79aa83dfbb01ebe07a19eee227086dfb2d9b05","tid":2386204,"uid":251732,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-