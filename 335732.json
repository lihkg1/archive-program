ces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"7dc3081a9323da0ef66c61b5e4c8293795d825c1","tid":335732,"uid":106375,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-07-26T02:44:16.000Z","msg":"特別係果啲唔岩音仲夾硬塞隻字落去既<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"9eae588705d411945203fe8ac78a54ece6659898","tid":335732,"uid":342,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T02:46:03.000Z","msg":"有意思嘅就冇問題<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b7510489642cb1e52e3d042d44cbfe7f4fb795b4","tid":335732,"uid":54424,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2017-07-26T02:54:20.000Z","msg":"覺唔覺你老豆老母生你改你個名好柒好無意思&hellip;<br />\n<br />\n好覺&hellip;俾個老冧你咪得囉，駛乜改名啫&hellip;好小學雞囉"},{"pid":"f23429e0e6f4b2f7dbd6a774373a9701b5808c3c","tid":335732,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T02:56:28.000Z","msg":"改花名就柒<br />\n咁樓主幾時真名上連登"},{"pid":"cfd23ed5cbab992452d989e267f3f835d43aaac9","tid":335732,"uid":79627,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-07-26T03:04:16.000Z","msg":"終於有人開post 講<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> .<br />\n成日覺得啲藍絲改花名好低質，突顯佢哋水平低<br />\n如果我哋想多啲市民支持，應該突顯我哋高質嘅一面唔係小學雞咁<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"10376cd1dfa7da046f36ac1aacc514f8d860e703","tid":335732,"uid":60535,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2017-07-26T03:17:48.000Z","msg":"屌咗好耐都冇人理<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n幫一啲仆街高官改花名，除咗比較易屌啲之外，跟本將件事娛樂化咗，仲幫埋佢地容易入屋。<br />\n<br />\n令到政治冷感/撐政府嘅廢老，將政府官員嘅醜聞搞到易入口，睇睇下就麻木哂，最後所有嘢變咗屌完就算。<br />\n香港人出名記性差，大家覺得反正有人屌過喇，就冇咗件事，所以咪越嚟越多港豬囉<br />\n<br />\n你笑緊梁振英係689，狼鷹依啲名嗰陣，佢一樣喺度高床暖枕，冚家望住你班傻閪好似生番咁，緊係忍唔住笑啦。<br />\n<br />\n冇成本又可以玩嘢，點解唔玩？佢有錢收又可以玩嘢，仲要玩死你，邊個得益多啲？"},{"pid":"cde63421b49ea714f0e9c220209756bb3c1c792a","tid":335732,"uid":50719,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T03:57:30.000Z","msg":"<a href=\"http://www.storm.mg/article/301816\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.storm.mg%2Farticle%2F301816&d=oViV65MKjtusFbMuXh0bSTOU%2Fspzl0GStOx2So8CiJ8%3D&h=2d67357b\" target=\"_blank\">http://www.storm.mg/article/301816</a><br />\n新華社發佈報導禁用詞：「中華民國、台灣政府」通通不准用，「九二共識」不可提「一中各表」<br />\n<br />\n新華社近日發佈《新華社新聞信息報導中的禁用詞和慎用詞（2016年7月修訂）》，在2015年11月發佈的《在新聞報導中的禁用詞（第一批）》的45條禁用詞語基礎上，新增57條內容。當中對台灣事務的報導詞語有嚴格規定，除徹底否定台灣的國家地位，連「台語」、「中華民國」跟「福爾摩莎」也不准使用，只能說「閩南語」跟「台灣地區」；該規定還明令「『九二共識』不可使用台灣方面『九二共識、一中各表』的說法」。<br />\n<br />\n香港方面，唔準講「三權分立」，要講「行政主導」，無聊？你知唔知有權有勢過你一千萬倍既共產黨對依d無聊野幾上心？依家講緊政治鬥爭啊！名不正則言不順，語言係好重要既鬥爭工具，點可以睇少佢？"},{"pid":"bf08df5f75cfd513a106d0d3023f191c0383f525","tid":335732,"uid":20531,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2017-07-26T05:14:16.000Z","msg":"On9，你講人正名，人地有機會告你誹謗，<br />\n你講花名，起碼你有得咬<br />\n咁簡單道理都唔明？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f49fc0e3f8d1eb4380539a6140ffed426d8cedfb","tid":335732,"uid":1773,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-26T07:26:24.000Z","msg":"<blockquote>On9，你講人正名，人地有機會告你誹謗，<br />\n你講花名，起碼你有得咬<br />\n咁簡單道理都唔明？<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote><br />\n你最撚醒"},{"pid":"9a565922911f85d6e519aa95902b3e453d78ee05","tid":335732,"uid":23170,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-27T05:34:36.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"09935057d47c9545fc896e2fb24c2d340812db39","tid":335732,"uid":66943,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-07-27T14:06:39.000Z","msg":"<blockquote>得 禮義廉 同<del> 民賤聯 </del>係改得好</blockquote>"},{"pid":"7fe5b26d52eb749e759dcfd901c4d9e26ef4d979","tid":335732,"uid":28765,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-27T14:41:28.000Z","msg":"泰上黃同阿丐達真係好好笑<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosa