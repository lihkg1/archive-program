normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-12-07T07:11:08.000Z","msg":"<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />支持"},"citedBy":1,"replyTime":"2019-12-07T11:54:00.000Z","msg":"7月22日的一個清早，日照和煦。<br />\n<br />\n「今天收穫應該很豐富吧！」<br />\n阿虎響應過何律師昨夜的止暴制亂行動，正盤算著自己應得的豐厚賞金...<br />\n<br />\n「鈴 &mdash; 鈴」<br />\n看著被風吹過的窗紗，無情的門鈴正好打斷了阿虎的春秋大夢，阿虎只好拖著疲憊的身軀出去應門。<br />\n<br />\n「虎哥，立即帶備武器！跟我們到荃灣找何律師算帳！」<br />\n「這..怎麼了...！」<br />\n「這他媽的靠北野律師，居然膽敢拖欠我們薪金！」<br />\n「對啊！帳目未有付清，還害得南哥躺在醫院生死未卜！跟我們去把他的辦公室拆掉！」<br />\n<br />\n過去，葉虎一直守候在何律師身旁，默默付出，躹躬盡瘁，從未想過終有一日招致何律師背叛，此刻葉虎心裡徬徨至極，萬感交雜而胡思亂想。相比起賞金，葉虎更害怕何律師另結新歡，將其棄如敝屣。想到這裡，葉虎不禁情緒崩潰，泣不成聲。於是立馬帶同噴漆鐵鎚，一行二十人浩浩蕩蕩向著何君堯荃灣辦事處的方向進發......"},{"pid":"61f53d43da2748a159a5f523a51aa965955c020e","tid":1771884,"uid":52658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-07T12:05:14.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"e400f56b4a6a9bc4d99b8f9bb413e4cd551bb709","tid":1771884,"uid":52658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-07T14:24:04.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"31bb925802dd25f3f46f3dab5ebd32fb7f5cb1d6","tid":1771884,"uid":327740,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-07T14:26:38.000Z","msg":"此回覆已被刪除"},{"pid":"c6dec54c3769d876fa43d9e035bd0c6c5854c121","tid":1771884,"uid":52658,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-07T14:39:11.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7162d39d8c5d02bf12768256e23e2df0818c98eb","tid":1771884,"uid":226573,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-07T14:44:07.000Z","msg":"<img src=\"/asse