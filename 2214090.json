個大媽叫我走 (完)<br />\n<br />\n<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<br />\n希望無其他人會中招<br />\n<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"}]}