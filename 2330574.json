nail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs.yimg.com%2Fny%2Fapi%2Fres%2F1.2%2FIxCjXcauKuVoefgcfjVlOQ--%2FYXBwaWQ9aGlnaGxhbmRlcjt3PTEyNDI-%2Fhttps%3A%2F%2Fmedia.zenfs.com%2Fzh-TW%2Fthesun.hk.com%2Fcaab841e014cf8ffcaeaf03b2232b7dd&h=6790120d&s={SIZE}\" /><br />\nHera外出掃家電，買返愛巢準備同居生活。<br />\n<br />\n<img src=\"https://s.yimg.com/ny/api/res/1.2/u.Rs9jLOuvpAfEnUbAUm_Q--/YXBwaWQ9aGlnaGxhbmRlcjt3PTEyNDI-/https://media.zenfs.com/zh-TW/thesun.hk.com/94522165e73d7214351b79de220bf1c1\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs.yimg.com%2Fny%2Fapi%2Fres%2F1.2%2Fu.Rs9jLOuvpAfEnUbAUm_Q--%2FYXBwaWQ9aGlnaGxhbmRlcjt3PTEyNDI-%2Fhttps%3A%2F%2Fmedia.zenfs.com%2Fzh-TW%2Fthesun.hk.com%2F94522165e73d7214351b79de220bf1c1&h=a1687203&s={SIZE}\" /><br />\n甘心為Ian做煮飯婆的Hera，踎地揀電飯煲。"},{"pid":"4420de68fa31c2387ba1e7103fed949980fe5cc8","tid":2330574,"uid":52605,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-12-18T06:38:34.000Z","msg":"陳曉華手長頸長腳長<br />\n係對波唔長。"},{"pid":"c6554b885869e963281e36b75fc50a08dc8bb42d","tid":2330574,"uid":117837,"like":5,"dislike":1,"score":4,"citedBy":1,"replyTime":"2020-12-18T06:39:02.000Z","msg":"閪恥 閪恥有閪屌<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},{"pid":"84318f88677c3a9ff0e7587bac713f1b59a5ef3c","tid":2330574,"uid":152123,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2020-12-18T06:39:39.000Z","msg":"條女又柒 條仔又on9 登對"},{"pid":"e7c54fd9223d44cf3eb5db1052c6c35f5499f76d","tid":2330574,"uid":117837,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-12-18T06:41:34.000Z","msg":"其實兩個台究竟點識？"},{"pid":"226e5447364cb2e9302780328664463cae967cf3","tid":2330574,"uid":117412,"like":2,"dislike":0,"score":2,"quote":{"pid":"c6554b885869e963281e36b75fc50a08dc8bb42d","tid":2330574,"uid":117837,"like":5,"dislike":1,"score":4,"citedBy":1,"replyTime":"2020-12-18T06:39:02.000Z","msg":"閪恥 閪恥有閪屌<img src=\"/assets/faces/lm2/diu.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-12-18T06:41:39.000Z","msg":