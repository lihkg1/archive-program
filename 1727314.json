sets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"332c316b2cee80c05d63207a331e2f43c27e0c4e","tid":1727314,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T12:57:11.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"81c70f0f16e216c588284420d5282ec5e5ed729e","tid":1727314,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:04:41.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"3eed06a6975d0a72d619561680b8e6eedc8b36c2","tid":1727314,"uid":293947,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:06:36.000Z","msg":"如果再出老解要播64影片或聲帶,或者雜總,軍頭D 貪污報導聲帶打下氣.<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ca7381fcfd49cdcdee712c00230ca1dce0697507","tid":1727314,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:10:00.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"a0e26dd0ee802bbb6bb0d79dd07e180d8489b010","tid":1727314,"uid":126730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:10:38.000Z","msg":"推"},{"pid":"4406a94ff7e3889a28b4f3398127cf3bbe4a7a16","tid":1727314,"uid":80437,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:11:39.000Z","msg":"RB一定一定一定唔可以SET，因為如果老解再出，林奠會好難做！因為第一次當無通知你，如果再出，林奠會解釋唔到。所以如果最後老解唔出的話，老解同雜種會好無面！<br />\n我地唔可以俾領導人難做的！一定唔可以再去果到SET RB!!!!!大家説對不對！？"},{"pid":"5ca2ae47109f31f17885462b9d622ff87d369c90","tid":1727314,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:11:58.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"4dd0149134d2c1971a2a75317a0b74d55256700d","tid":1727314,"uid":277695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:13:25.000Z","msg":"琴日光明頂陶傑講左條好橋可以即時解決呢場動亂，個觀點初初聽落幾過癮，但諗落又真係可行，建議大家去聽聽<br />\n<br />\n唔得閒聽既，以下將整合要點：<br />\n<br />\n１）引用基本法１６條，以援助為由出動解放軍，到道路上清路障<br />\n<br />\n２）解放軍不帶任何裝備、不矇面，只穿背心，清除路面雜物<br />\n<br />\n３）示威者成功引解放軍出動，攬炒目的已達到<br />\n<br />\n４）解放軍出動之後，馬上成立獨立調查委員會，清算濫捕濫暴警察，將違法警察送上法庭，重建法治信心。<br />\n<br />\n５）警察即使被清算，但因解放軍在港，而不敢倒戈／政變<br />\n<br />\n６）成立清算警察機制之後，民情緩和，區選如期舉行，容許泛民大勝。<br />\n<br />\n７）激烈局勢於１２月中平息，宣佈普選具體方案，指令林鄭下台，全體政府高官班底重組。<br />\n<br />\n呢條橋，和理非成立爭取五大訴求、攬炒派目的達到、藍絲出解放軍既願望實現，唯獨是要清算違法違例既前線下級警員。真係可以話係一石好多鳥。"},{"pid":"c0b2386d9316e838fb29403fb51edbf0cd7594c8","tid":1727314,"uid":18223,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:15:20.000Z","msg":"Push"},{"pid":"9c9fd727880aa96bfd284d5c13b9a163262a75c4","tid":1727314,"uid":181474,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:18:44.000Z","msg":"其實出解放軍係國際核彈嘅另一論調<br />\n<a href=\"https://lih.kg/1727524\" data-auto-link target=\"_blank\">https://lih.kg/1727524</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"f1c10f8c10344cbb828002b4ef59cd0f8c3fa7d0","tid":1727314,"uid":99904,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:19:54.000Z","msg":"支持<br />\n<br />\n老解食撚屎啦"},{"pid":"c972ac449b894092acb45adfc01c33f50f10e139","tid":1727314,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:23:23.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"00f4fff3ac9de9bc5e71070d106e27adf0343991","tid":1727314,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:24:55.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"c4114473dcede89d11046bf57e68103e39481061","tid":1727314,"uid":68084,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:28:08.000Z","msg":"<span style=\"font-size: x-large;\"><span style=\"color: red;\">Facebook: Kevin Hui<br />\n<br />\n中文名:許家偉<br />\n<br />\n中學:香港中文大學校友會聯會陳震夏中學<br />\n<br />\n大專:HKCC</span></span><br />\n<br />\n事源就係女朋友係facebook無啦啦有個三唔識七既人inobx佢<br />\n<img src=\"https://na.cx/i/Kx8wuNP.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FKx8wuNP.png&h=507fbd36&s={SIZE}\" /> <br />\n仲要問一唔一齊出去,真係唔知咩心態<br />\n<br />\n<br />\n係facebook PO下新聞扮同路人<br />\n<br />\n實際上就係想借呢件事黎食女<br />\n<br />\n絲打真係要小心<br />\n<br />\n狗公ig:<br />\n<img src=\"https://na.cx/i/7NWNMVs.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7NWNMVs.jpg&h=58c06442&s={SIZE}\" /><br />\n<br />\n條撚樣仲要好似有女朋友?<br />\n做佢女朋友真係慘<br />\n<br />\n絲打們認住呢條撚樣,踢波既 小心佢<br />\n<br />\n<img src=\"https://na.cx/i/gc2k6Wh.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fgc2k6Wh.png&h=893df396&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n垃圾狗公咁撚鍾意消費呢場運動?<br />\n<br />\n<img src=\"https://na.cx/i/r30ZC4p.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fr30ZC4p.png&h=bda94586&s={SIZE}\" /><br />\n<br />\n返去玩玩具啦屌你老母<br />\n<br />\n<br />\n<span style=\"font-size: large;\">絲打們要小心,好撚多呢種垃圾狗公借機搵食<br />\n<br />\n特別係呢條死狗公 許家偉!!</span>"},{"pid":"1fdebf69df6cc6fcfd2fa0792e751fbd21c2722b","tid":1727314,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:36:16.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"8ae3217da33d00b3c8edca916bf93300fc5aba32","tid":1727314,"uid":68080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:37:09.000Z","msg":"1117愛丁堡有個集會"},{"pid":"8f846104f27e0aaaf516c79065ae6d7820c35977","tid":1727314,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-16T13:42:59.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"c340924c834cafdedf8e6ef115440fb414b132d5","tid":1727314,"uid":339638,"like":0,"dislike":0,"score":0,"quote":{"pid":"080bbf8eb1a5bee262d7f54f19b6b99a91d062cd","tid":1727314,"uid":189404,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-16T11:41:26.000Z","msg":"就搵民陣或者其他團體搞個反解放軍大遊行啦，一於見招拆招"},"citedBy":0,"replyTime":"2019-11-16T13:43:58.000Z","msg":"仲要煲大藍屍歡呼<