ny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/chicken3.gif\" class=\"hkgmoji\" />"},{"pid":"a0915ad100b6392f25b7343674c4ac0155e7157a","tid":1840800,"uid":49827,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T05:43:38.000Z","msg":"<img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/adore.gif\" class=\"hkgmoji\" />"},{"pid":"a3d5b18dcfb329ad7cdfbbebcb6d03f54684d3c0","tid":1840800,"uid":280886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T05:44:50.000Z","msg":"如果認同請幫推幫share<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: red;\">大大力宣傳中共習近平既醜聞，中共港共千祁要限制內地同胞來港，唔好比佢地睇到！！</span><br />\n<br />\n(肺炎)港府唔限制大陸人來港，我地就令大陸政府限制佢地黎！<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1834124\" data-auto-link target=\"_blank\">https://lih.kg/1834124</a><br />\n<br />\nA. 方法：大陸政府最怕大陸人知道既，唔係香港點解抗爭（大陸已經洗曬地，而且大陸人唔care香港人點慘），而係：<br />\n<br />\n1. 高官好有錢（針對仇富心理）<br />\n<br />\n2. 高層全是外國勢力（針對民族主義）<br />\n<br />\n3. 習近平的情人們（針對八掛心理）<br />\n銅鑼灣書店事件係因此書觸怒習而起，雖然本書有點9up，但從事件可見，習真係好驚本書既內容見光<br />\n本書摘要：<a href=\"http://blog.udn.com/meatball2/47616636\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fblog.udn.com%2Fmeatball2%2F47616636&d=EXOoM7fQMXhTNR4rfnaZT2rU9%2B1YVtZAf0CByt%2F7qsI%3D&h=cb6f48b2\" data-auto-link target=\"_blank\">http://blog.udn.com/meatball2/47616636</a><br />\n<br />\nB. 形式：<br />\n各大關口、購物熱點（上水、旺角、西九高鐵等）<br />\n連儂牆文宣（各區區議會亦應盡快設定好連儂墻，保障文宣手足安全！）、傳單、街站（大大聲普通話講比大陸人聽）<br />\n<br />\n<img src=\"https://na.cx/i/vJ3idBa.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FvJ3idBa.jpg&h=bcc6d841&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/29wGVPx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F29wGVPx.jpg&h=89a68a4d&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/AKJqC2T.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAKJqC2T.png&h=ef0fff20&s={SIZE}\" />"},{"pid":"21be9e06ec168ab275f88d37a36329d00147fd4d","tid":1840800,"uid":106604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T05:47:33.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"f05293c0373ad22d646aa38d9fb1d96f41f49d79","tid":1840800,"uid":63808,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T05:50:29.000Z","msg":"高溫燒毒啦"},{"pid":"4a39593405b4e94334d96b9061b8c4709403612d","tid":1840800,"uid":168020,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T05:51:03.000Z","msg":"Push"},{"pid":"b87af362fa6381dcc833a9b6d9945afc8ffa3d6a","tid":1840800,"uid":74316,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T05:52:21.000Z","msg":"推"},{"pid":"5518ff39d114d9de89c0fbb09a04e9b38b9c7ac7","tid":1840800,"uid":259613,"like":0,"dislike":0,"score":0,"quote":{"pid":"15ba9cbd0c1c6fe4e9690a3855b4881771517546","tid":1840800,"uid":327089,"like":8,"dislike":0,"score":8,"quote":{"pid":"c5e830c3f36e7225c9abf22acfc8c2fe822e336e","tid":1840800,"uid":41298,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-25T05:12:54.000Z","msg":"大家睇情況<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"c