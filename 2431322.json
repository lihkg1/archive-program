pHCTTcQcXY6VsQHNTK4%3D&h=cb4cc820\" target=\"_blank\">https://www.hk01.com/地產樓市/508450/德福業主回港賣樓-兩房830萬沽-勁賺逾三倍離場</a>"},{"pid":"028c8d3eb23df9c35421632fa9bd02311aeb0c4d","tid":2431322,"uid":284855,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c33890ed4a2794352e15764f4f2f603ff1c399b","tid":2431322,"uid":33622,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-03T14:47:38.000Z","msg":"望狗屋面壁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-08T23:37:01.000Z","msg":"仲要同狗住埋一齊，日日畀狗笑你on9要畀錢買樓<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4f4b0c55887572226ded043db46b543885c6eab5","tid":2431322,"uid":29784,"like":0,"dislike":0,"score":0,"quote":{"pid":"028c8d3eb23df9c35421632fa9bd02311aeb0c4d","tid":2431322,"uid":284855,"like":0,"dislike":0,"score":0,"quote":{"pid":"8c33890ed4a2794352e15764f4f2f603ff1c399b","tid":2431322,"uid":33622,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-03T14:47:38.000Z","msg":"望狗屋面壁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-08T23:37:01.000Z","msg":"仲要同狗住埋一齊，日日畀狗笑你on9要畀錢買樓<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-