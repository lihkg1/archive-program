&h=51c55db5&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-04-04T18:20:41.000Z","msg":"唔理老高講野有幾無稽<br />\n<br />\n平心而論真係因為佢老婆先睇<br />\n<br />\n<br />\n所以唔分錢比人都合理<br />\n<br />\n屌下面果幅，扮可憐前照下鏡先啦😡😡😡😡😡"},{"pid":"0f4db7e63d73300defb262065a044e28fcdaacb4","tid":1958402,"uid":54927,"like":1,"dislike":1,"score":0,"quote":{"pid":"2815dd1f7c2bddecb506d9a6977516eef61d468e","tid":1958402,"uid":69994,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2020-04-04T16:49:07.000Z","msg":"老肉 , 老高 , 大學同學 , 2014 年共同成立 &quot; 酷愛ZERO (KUAIZERO) &quot; channel , 老肉負責PC遊戲/玩具 , 老高負責手提電話遊戲 .<br />\n<br />\n老高和小茉<br />\n<img src=\"https://na.cx/i/esYD4g4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FesYD4g4.png&h=b8bdd490&s={SIZE}\" /><br />\n<br />\n老肉和曉哲<br />\n<img src=\"https://na.cx/i/6O29rvv.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6O29rvv.png&h=51c55db5&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-04-04T18:27:56.000Z","msg":"下面兩件睇到都唔開胃啦"},{"pid":"1bc060b4ccb3de22f157e475abcd651b74153eb3","tid":1958402,"uid":308251,"like":0,"dislike":0,"score":0,"quote":{"pid":"003daa92e1e20f0cf0a949f4b17e6761ed442768","tid":1958402,"uid":69994,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-04T15:26:34.000Z","msg":"<blockquote>五花老肉<br />\n1 day ago<br />\n<span style=\"color: red;\">還是有好多老高的觀眾在質疑我們為什麼用跟老高類似的模式，既然老高堅持什麼都不說，那我只好自己來說一些事實了。（本想做一期影片來說，但是發現實在說不出口，就發個貼文吧）</span><br />\n我和老高創立酷愛ZERO的時候，在開始有收入之前就約定，之後不管兩個人誰收入高，誰收入低，每個月的收入55開平均分。從15年1月份開始有收入以來，連續44個月，一直都是我和Teddy的的頻道收入高，每個月我都按照約定跟老高平分收入。後來我們根據頻道的發展，商量探索遊戲視頻之外的方向，因為當時我這邊收入穩定在老高的2~3倍（見下表），老高說：&ldquo;你把主要精力放在維持遊戲視頻收入上，探索新模式的事情就交給我吧。&rdquo;老高創立現在的頻道，逐漸放棄遊戲頻道，新頻道走紅之後，<span style=\"color: red;\">18年9月，老高的收入超過了我的收入，他按照約定跟我平分了3個月之後，說嫂子認為新頻道是因她而紅，而之前約定的是我跟老高平分收入，所以今後就不分給我了。</span>我說好吧，那我今後也做這個模式的時候，你幫我帶一帶吧，老高說好。然後我們的合作就基本結束了。<br />\n那為什麼一定要用跟老高相同的模式呢？因為當時老高走紅，我們合作還沒結束那段期間，我們是有討論為什麼這個模式會火的，有好多影響因素，既然老高是代表酷愛ZERO探索出來的成功模式，我覺得我也可以使用。<br />\n其他大家不知道的事情還有好多，我目前只想解釋我們為什麼會用跟老高相同的模式做節目，其他的暫時不考慮全都說出來。<br />\n<br />\n只說一點，關於「酷愛ZERO」為什麼不能用了，有人說是我註冊了，這純屬無中生有，背後的真相有必要的時候我會說出來，我自己問心無愧就好了。<br />\n所以懇請大家以後不要再以「模仿」說事了，我跟Teddy經營了一個遊戲頻道，也想跟Teddy的媽媽經營一個雜談頻道，這樣一家人一起努力挺好的。</blockquote><br />\n<br />\n<img src=\"https://na.cx/i/CDE0xJL.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCDE0xJL.png&h=3875857a&s={SIZE}\" /> <br />\n<br />\n世界大戰抹黑宇宙了 Can you feel？<br />\n利申 : 每條老高片都有睇 <img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-04T18:31:00.000Z","msg":"你食屎啦，睇大陸北佬加內地臭雞片"},{"pid":"759912530f541cb787e263172d24022a762cfba0","tid":1958402,"uid":301534,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-04-04T18:41:30.000Z","msg":"嫂子認為新頻道是因她而紅<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n臭閪"},{"pid":"827a48acf9efc67efc0d19d698c3efbedd903482","tid":1958402,"uid":301534,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2020-04-04T18:47:23.000Z","msg":"老高平分左三個月就唔肯再分錢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />人地之前收入高過佢果陣都肯55分啦<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />老高好撚仆街下喎都<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"4d379d8b5a76339db79f8b071b4484904149168a","tid":1958402,"uid":69994,"like":1,"dislike":0,"score":1,"quote":{"pid":"759912530f541cb787e263172d24022a762cfba0","tid":1958402,"uid":301534,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-04-04T18:41:30.000Z","msg":"嫂子認為新頻道是因她而紅<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n臭閪"},"citedBy":0,"replyTime":"2020-04-04T19:17:57.000Z","msg":"之前佢掉老高部電話落泳池 , 但老高唔敢鬧佢 <img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://na.cx/i/d6Tc9Aq.png\" data-thumbnail