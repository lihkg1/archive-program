,"tid":1485403,"uid":1080,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-08-18T16:10:47.000Z","msg":"deadline set 後日啦 <br />\n比夠一日時間佢"},{"pid":"0e3b263fb81155bcaab7e90ab8d11f8fd399ced1","tid":1485403,"uid":8532,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:11:40.000Z","msg":"死線！"},{"pid":"b477753f3219994238de08e88ece31460036c7bf","tid":1485403,"uid":79471,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:13:18.000Z","msg":"死線"},{"pid":"68eb00237c2e963b9ebe43ec75a2e5896d29e985","tid":1485403,"uid":63822,"like":0,"dislike":0,"score":0,"quote":{"pid":"687081a4cc17078ec78514f15be72132e1829b52","tid":1485403,"uid":66049,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-18T16:10:03.000Z","msg":"下次831 <br />\ndeadline 應該係幾時<br />\n要預文宣831"},"citedBy":0,"replyTime":"2019-08-18T16:13:51.000Z","msg":"我認為830係最好既deadline<br />\n<br />\n第一，佢唔回應既話，我地打鐵趁熱，第二日立即行動，唔好比對面時間分散注意力，打散民意<br />\n<br />\n第二，比到臨行動前一日，時間充足，沒有絲毫刁難，大方得體"},{"pid":"519f463edfb91cf9690789ab84d73d07b3ee7bf8","tid":1485403,"uid":79471,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:15:37.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d3c9ad389e5ba6ac379e4c4b4653cdeadee9e2ed","tid":1485403,"uid":198343,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:18:27.000Z","msg":"831"},{"pid":"7e127376335ea1579bbef341d4c6a8e649c77fba","tid":1485403,"uid":167878,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T16:19:17.000Z","msg":"死線後 入機場"},{"pid":"76b772a25aaabb76d1b06e18b0911494bd3f455a","tid":1485403,"uid":53172,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-18T16:19:44.000Z","msg":"今日政府回覆<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<img src=\"https://na.cx/i/xJv9S2N.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FxJv9S2N.jpg&h=fdf9ba6b&s={SIZE}\" />"},{"pid":"