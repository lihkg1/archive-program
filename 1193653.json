normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"77c27ab5004ccdf591ac7e9091c761a709f2f463","tid":1193653,"uid":41389,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-09T04:42:24.000Z","msg":"巧驚驚呀"},{"pid":"323f9df92ad991a6a94e8441e1173fa0ae3ce53b","tid":1193653,"uid":41389,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2019-06-09T04:42:40.000Z","msg":"-遊行起點：銅鑼灣維多利亞公園中央草坪 （維園草地）<br />\n-遊行路線：維園草地起點&gt;高士威道&gt; 禮頓道&gt;伊榮街&gt;邊寧頓街&gt;軒尼詩道西行車路&gt;金鐘道&gt;樂禮街&gt;夏愨道&gt;添美道&gt;立法會外行人路終點<br />\n-集合時間：2：30PM<br />\n-起步時間：3：00PM（或維園草地達八成滿）<br />\n-衝定唔衝，自己執生<br />\n-記得宗旨：不散<br />\n<br />\n溫和：<br />\n<strong>【長期置頂】69反送中遊行須知整合</strong><br />\n<a href=\"https://lihkg.com/thread/1191837/page/1\" target=\"_blank\">https://lihkg.com/thread/1191837/page/1</a><br />\n<br />\n<strong>[懶人包] 第一次參加遊行的常見疑問Q&amp;A</strong><br />\n<a href=\"https://lihkg.com/thread/1186623/page/1\" target=\"_blank\">https://lihkg.com/thread/1186623/page/1</a><br />\n<br />\n<strong>【極重要】69遊行記得帶防Rfid卡套</strong><br />\n<a href=\"https://lihkg.com/thread/1190797/page/1\" target=\"_blank\">https://lihkg.com/thread/1190797/page/1</a><br />\n<br />\n勇武： <br />\n<strong>食放題須知，全部資料，一世受用</strong><br />\n<a href=\"https://lihkg.com/thread/1191403/page/1\" target=\"_blank\">https://lihkg.com/thread/1191403/page/1</a><br />\n<br />\n<strong>[law撚］被捕人仕須知</strong><br />\n<a href=\"https://lihkg.com/thread/1189300/page/1\" target=\"_blank\">https://lihkg.com/thread/1189300/page/1</a><br />\n<br />\n<strong>［抗爭手冊］End game前準備</strong><br />\n<a href=\"https://lihkg.com/thread/1169374/page/1\" target=\"_blank\">https://lihkg.com/thread/1169374/page/1</a><br />\n<br />\n<strong><span style=\"font-size: x-large;\">黑色三毛特別警告信號現正生效 6月9日08時</span></strong><br />\n<br />\n<strong><span style=\"font-size: medium;\"><span style=\"color: purple;\">表示連登 facebook 網絡廣泛地區已錄得或預料會有每秒三毛回覆量超過100次/禁100次正評的網絡分化攻勢，且攻勢可能持續或於今晚或明朝早上升級。</span></span></strong><br />\n<img src=\"https://na.cx/i/VNv7C24.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FVNv7C24.jpg&h=73f7da13&s={SIZE}\" /><br />\n<br />\n<span style=\"color: red;\"><strong><span style=\"font-size: large;\">注意事項</span></strong></span><br />\n<strong>網民應注意username 同 三毛開post 目的 而非三毛post正評數量。<br />\n網民應負皮三毛post 入去屌佢老母 而毋須參與分化討論。<br />\n鍵盤戰士應努力推正經post 例如準備事項去抵擋三毛攻勢。<br />\n三毛會開一啲反共post 減低大家戒心 請細心思考現時網絡上所有言論。<br />\n一般市民應少上連登 關電視 而休養等待今午遊行。<br />\n鬼得一隻 林奠 其他完全唔重要 。</strong><br />\n<img src=\"https://na.cx/i/ZB4gyv7.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FZB4gyv7.gif&h=7cacc0df&s={SIZE}\" />"},{"pid":"a6b6c4302fd5e8ae4ce06a43ec8372d95cebb432","tid":1193653,"uid":34348,"like":14,"dislike":0,"score":14,"citedBy":1,"replyTime":"2019-06-09T04:43:11.000Z","msg":"唔撚好開呀，開咗正契弟<br />\n2014都行到10點啦驚閪你咩<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"25b8a5a6092fdeed4c1bb05a8c285a0ee49b1c18","tid":1193653,"uid":65838,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-06-09T04:44:17.000Z","msg":"學19才子話齋，係好事。"},{"pid":"ac0f90e6cea04cffdfa6dad143147b7fad297941","tid":1193653,"uid":24390,"like":12,"dislike":0,"score":12,"citedBy":0,"replyTime":"2019-06-09T04:44:20.000Z","msg":"一定開，班友用雪糕筒咪又係想易搬啲<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"f281501f04115346e3235da643a76838182d6800","tid":1193653,"uid":172031,"like":0,"dislike":0,"score":0,"quote":{"pid":"b351e57ec8235213da1783915781df036eaf3aa1","tid":1193653,"uid":169074,"like":15,"dislike":116,"score":-101,"citedBy":4,"replyTime":"2019-06-09T04:11:15.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-06-09T04:44:23.000Z","msg":"一定唔會<br />\n除非想打仗"},{"pid":"2e0c797aa9a4058fe6f4b3696f41c0b7d3beaaa7","tid":1193653,"uid":112241,"like":37,"dislike":1,"score":36,"quote":{"pid":"545bbb58abec09e590a813970af45a0a9f42c6eb","tid":1193653,"uid":227275,"like":259,"dislike":2,"score":257,"citedBy":4,"replyTime":