ts/faces/dog/bye.gif\" class=\"hkgmoji\" />"},{"pid":"504943c638b74b9136a79d28161f486bc61d647f","tid":1594584,"uid":282637,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T18:40:08.000Z","msg":"<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://lihkg.com/thread/1319023/page/1\" target=\"_blank\">https://lihkg.com/thread/1319023/page/1</a><br />\n人哋最睇重支旗<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n你想人幫手<br />\n咪用英文寫slogan<br />\n但唔好搞人枝旗<br />\n你又唔係美國佬舉乜撚美國旗<br />\n鬼佬見到只會反感<br />\n英國旗仲有得拗吓<br />\n<br />\n咪撚信共諜陳雲<br />\n出屎穚玩爛件事"},{"pid":"d4adab0b7063972b39a6e82e700ac436bb1dd7b2","tid":1594584,"uid":169074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-21T16:19:20.000Z","msg":"此回覆已被刪除"},{"pid":"fadb85c2763f3431b00ec78fccf522dadd0b845e","tid":1594584,"uid":169074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-22T16:16:53.000Z","msg":"此回覆已被刪除"},{"pid":"b821450f60c4c384737773680664e4cb07da6519","tid":1594584,"uid":169074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-24T17:33:02.000Z","msg":"此回覆已被刪除"},{"pid":"627896501758236d275560efffab012f752a5496","tid":1594584,"uid":265192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-24T17:45:59.000Z","msg":"<span style=\"font-size: x-large;\"><strong><span style=\"color: orange;\">一、誠意推薦：</span></strong></span><br />\n<br />\n<strong><em>香港大專學界國際事務代表團眾籌計劃</em></strong><br />\nHong Kong IAD Crowdfunding Plan<br />\n<a href=\"https://gogetfunding.com/hkiad-crowdfunding/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgogetfunding.com%2Fhkiad-crowdfunding%2F&d=nuTNs4p9zVAmxGYrSBNXTiWRWsFhQrZK9M853DAdSZ8%3D&h=80bfc32b\" target=\"_blank\">https://gogetfunding.com/hkiad-crowdfunding/</a><br />\n<br />\n<strong><em>香港眾志國際眾籌計劃 Demosisto International Campaign Crowdfunding Project</em></strong><br />\n<a href=\"https://gogetfunding.com/%E9%A6%99%E6%B8%AF%E7%9C%BE%E5%BF%97%E5%9C%8B%E9%9A%9B%E7%9C%BE%E7%B1%8C%E8%A8%88%E5%8A%83-demosisto-international-campaign-crowdfunding-project/?show_desktop=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgogetfunding.com%2F%25E9%25A6%2599%25E6%25B8%25AF%25E7%259C%25BE%25E5%25BF%2597%25E5%259C%258B%25E9%259A%259B%25E7%259C%25BE%25E7%25B1%258C%25E8%25A8%2588%25E5%258A%2583-demosisto-international-campaign-crowdfunding-project%2F%3Fshow_desktop%3D1&d=nuTNs4p9zVAmxGYrSBNXTiWRWsFhQrZK9M853DAdSZ8%3D&h=14573f53\" target=\"_blank\">https://gogetfunding.com/%E9%A6%99%E6%B8%AF%E7%9C%BE%E5%BF%97%E5%9C%8B%E9%9A%9B%E7%9C%BE%E7%B1%8C%E8%A8%88%E5%8A%83-demosisto-international-campaign-crowdfunding-project/?show_desktop=1</a><br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: orange;\">二、什麼是遊說集團？</span></span></strong><br />\n<br />\n遊說集團的工作，<strong><ins>是嘗試影響立法者</ins></strong>或其他持份者決定或行為，在政治角力中為服務對象<strong><ins>爭取利益</ins></strong>。遊說集團的服務對象，可以是國家、企業、社會團體、個人。在美國，政治遊說是極為普遍及重要的一環；幾乎所有政治操作都有遊說集團的參與。<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: orange;\">三、為什麼香港需要遊說隊伍？</span></span></strong><br />\n<br />\n任何國家的政治，背後都擁有複雜的政治脈絡；包括國家政策、政治形勢、民意、錯綜複雜的利益網絡、乃至個別官員或議員的性情喜好。要在國際社會維護和爭取香港的利益，<strong><ins>香港需要一支能具經驗和技巧，能夠有效收風、熟識政治形勢</ins></strong>、具備遊說策略的隊伍。<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: orange;\">四、遊說集團？對家一早做緊啊！</span></span></strong><br />\n【華為被禁】華為遊說費飆60倍！原來聘用特朗普籌款人 欲說服白宮<br />\n<a href=\"https://china.hket.com/article/2479940?r=cpsdlc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fchina.hket.com%2Farticle%2F2479940%3Fr%3Dcpsdlc&d=nuTNs4p9zVAmxGYrSBNXTiWRWsFhQrZK9M853DAdSZ8%3D&h=255a105a\" target=\"_blank\">https://china.hket.com/article/2479940?r=cpsdlc</a><br />\n<br />\n董建華基金會 擲2,240萬左右美政策<br />\n大搞政治游說 否認中共代理人<br />\n<a href=\"https://hk.news.appledaily.com/local/daily/article/20171130/20230175\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20171130%2F20230175&d=nuTNs4p9zVAmxGYrSBNXTiWRWsFhQrZK9M853DAdSZ8%3D&h=4f44733c\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20171130%2F20230175&h=11b362ed\" target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20171130/20230175</a>"},{"pid":"778596be27080e949ea9acecb7ee1881069398b3","tid":1594584,"uid":169074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-24T17:48:32.000Z","msg":"此回覆已被刪除"},{"pid":"703fd8e26e039a579f94e921ce32a885c6570098","tid":1594584,"uid":261300,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-24T17:50:00.000Z","msg":"我係美國人都想睇下你班香港人係自撚私定係會幫下其他人既文族<br />\n<a href=\"https://lih.kg/1673583\" data-auto-link target=\"_blank\">https://lih.kg/1673583</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"98c563afa63eac104e8ef89289e9a3eab973fe56","tid":1594584,"uid":169074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-28T11:39:42.000Z","msg":"此回覆已被刪除"},{"pid":"06db69978edfa6766aff8666a992a5e66250c6e1","tid":1594584,"uid":169074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-28T12:00:12.000Z","msg":"此回覆已被刪除"},{"pid":"d493e9e7c3486a36b6084a29481c7632e3809278","tid":1594584,"uid":169074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-29T17:30:39.000Z","msg":"此回覆已被刪除"},{"pid":"fe57538730f0432bb06f735ad0554b95f32642ad","tid":1594584,"uid":169074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-29T17:41:52.000Z","msg":"此回覆已被刪除"},{"pid":"b81483619ec552e2b603dd9441a47d8c757fff98","tid":1594584,"uid":169074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-30T17:50:54.000Z","msg":"此回覆已被刪除"},{"pid":"d56bd5468df6dcab9ce2703b0d4ecfcce142481f","tid":1594584,"uid":169074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-31T06:30:18.000Z","msg":"此回覆已被刪除"},{"pid":"