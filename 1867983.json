islike":0,"score":0,"citedBy":0,"replyTime":"2020-02-07T15:18:05.000Z","msg":"推"},{"pid":"1204438187c758bee456a5d94a9922a32ac24968","tid":1867983,"uid":220985,"like":0,"dislike":0,"score":0,"quote":{"pid":"34184519f25e4a337f3301115a4e87bb46efe053","tid":1867983,"uid":225100,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-02-07T11:58:25.000Z","msg":"2月10大三罷"},"citedBy":0,"replyTime":"2020-02-07T15:18:08.000Z","msg":"pish"},{"pid":"3ad5988bb69e9bc0697da14b1e4733049d05f5e7","tid":1867983,"uid":26708,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-07T15:22:01.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">泛民議員係邊呀</span></span>"},{"pid":"75822a0334fcab7ceb71025ee0ade6b5f0bee0a9","tid":1867983,"uid":26708,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-07T15:22:14.000Z","msg":"<blockquote><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"2bf47634f3500993704d25bb758df82965928fdc","tid":1867983,"uid":265271,"like":0,"dislike":0,"score":0,"quote":{"pid":"53d07fa4b266aa3df40caad780683e4c3525ffa4","tid":1867983,"uid":225100,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-07T10:59:56.000Z","msg":"<strong>半年反送中</strong><br />\n成日想勇武退場等和理非接力<br />\n終於勇武拉咗一大堆 打殘一堆 被消失又一堆 清算未齊停過<br />\n逼於無奈轉晒地下 只能處於半退場狀態<br />\n他們的犧牲換來<br />\n法案正式撤回<br />\n區議會大勝<br />\n人權法通過<br />\n<span style=\"color: red;\">但其餘訴求仍然未見其踪</span><br />\n<br />\n依加個天整個肺炎畀支那<br />\n雖然燒埋香港人<br />\n但講咗半年嘅罷工總算踏出咗第一步<br />\n<code>大人肯罷工 細路唔洗衝</code><br />\n<br />\n<strong>到依加罷工</strong><br />\n<span style=\"color: red;\">醫護就係當時嘅勇武 就如612金鍾 71衝入立法 一直走在最前嘅嗰班人</span><br />\n依加醫護決定復工(退場)<br />\n要爭取嘅全面封關只係階段性勝利 尤如半年黎嘅反送中<br />\n但醫護的確開咗個頭 示範畀大家睇咩叫罷工<br />\n然而疫情日益嚴重 醫護復工的決定我是尊重的 <br />\n<span style=\"color: red;\">而我亦相信 罷工醫護由其是幾位主席必定如勇武一樣將會遭到邪惡政權的清算</span><br />\n<br />\n呢個時候<br />\n<span style=\"color: gold;\">其他工會(和理非) 係唔係有責任出黎接力 <br />\n出黎話畀醫護手足聽一星期嘅努力沒有白費呢?</span><br />\n<br />\n<code>光復香港 時代革命</code><br />\n唔係一句口號<br />\n而係香港人以行動去實踐 再達成嘅目標<br />\n<br />\n現在迷霧里最遠處吹來了號角聲<br />\n你願意來齊集這里 來全力抗對<br />\n來接力繼續去光復香港嗎?<br />\n<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /> <span style=\"color: gold;\">好 我同其他工會接力 醫護手足辛苦了</span><br />\n<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" /> <span style=\"color: red;\">不了 醫護on9咁都復工 冇得畀我Freeride</span>"},"citedBy":0,"replyTime":"2020-02-07T15:25:31.000Z","msg":"612"},{"pid":"c555d03b5b05f6c19f70a12e3aef3de50525dba3","tid":1867983,"uid":62889,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-07T15:48:41.000Z","msg":"推"},{"pid":"ecf64a71e8921f6d2899af74dfaf1902bc1667e0","tid":1867983,"uid":82815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-08T02:31:43.000Z","msg":"推"},{"pid":"680a273d4c67ce16a7d6a0d97238df42c6ee5222","tid":1867983,"uid":76078,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-08T02:47:16.000Z","msg":"pish"},{"pid":"bf252f1429ff93550edef8f5d9a0177828de7fdf","tid":1867983,"uid":225100,"like":0,"dislike":0,"score":0,"quote":{"pid":"e5d151b177589b9bb90aa55059afd42355e4a4cc","tid":1867983,"uid":220985,"like":0,"dislike":0,"score":0,"quote":{"pid":"c08c14b38275eb023be498696715ea6d7aa6b1e2","tid":1867983,"uid":225100,"like":13,"dislike":0,"score":13,"citedBy":1,"replyTime":"2020-02-07T11:01:18.000Z","msg":"唔好再Freeride<br />\n唔想再被condom了<br />\n香港人 一次咁多<br />\n團結 一齊罷好唔好?"},"citedBy":1,"replyTime":"2020-02-07T15:17:57.000Z","msg":"啱啊 <br />\n雖然我都做唔到d 咩了<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-08T03:16:46.000Z","msg":"一個醫護都做唔到啲咩<br />\n但至少佢哋有7000人<br />\n多你一個好多"},{"pid":"b392ae574edc4d241eac2d164c4ba95c4f4567ee","tid":1867983,"uid":225100,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-11T04:11:27.000Z","msg":"<code>沒有普選 唯有獨立</code>"},{"pid":"de0f5d52248587ea4783915f8c165dde108a4e81","tid":1867983,"uid":2