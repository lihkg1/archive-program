3D&h=79676e68\" data-auto-link target=\"_blank\">https://math.stackexchange.com/questions/2648962/how-to-prove-that-x2yzxy2zxyz2-leq-frac13-where-x2y2z2-1-a</a>"},{"pid":"9c0df6beda3c8240783f44aae25c8ba3e2fe79b7","tid":2221064,"uid":264839,"like":0,"dislike":0,"score":0,"quote":{"pid":"dc7e637a513c32e77eb142c65f3ca04f729de279","tid":2221064,"uid":200529,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-28T06:27:06.000Z","msg":"q1<img src=\"/assets/faces/dog/math.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://math.stackexchange.com/questions/2648962/how-to-prove-that-x2yzxy2zxyz2-leq-frac13-where-x2y2z2-1-a\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fmath.stackexchange.com%2Fquestions%2F2648962%2Fhow-to-prove-that-x2yzxy2zxyz2-leq-frac13-where-x2y2z2-1-a&d=Wx0cKZaQlto0GELw8F4hIYtKjO%2FIGoH7AJS0Ocrd4mI%3D&h=79676e68\" data-auto-link target=\"_blank\">https://math.stackexchange.com/questions/2648962/how-to-prove-that-x2yzxy2zxyz2-leq-frac13-where-x2y2z2-1-a</a>"},"citedBy":0,"replyTime":"2020-09-28T06:31:34.000Z","msg":"еҘҪдәәдёҖдё–е№іе®үрҹҷҮрҹҸ»&zwj;вҷӮпёҸ"},{"pid":"a436a51dabbb0c5421997e8c2f509c86d7d8d9c4","tid":2221064,"uid":130174,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-28T08:27:56.000Z","msg":"жЁ“дё»еҘ§ж•ёж•ҷз·ҙпјҹ"},{"pid":"2b27d493038bb3892f703d1524c29c46a17e2b1f","tid":2221064,"uid":121095,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-09-28T11:29:28.000Z","msg":"5. <br />\nR.H.S.<br />\n= (a+b+c)(a+b-c)<span class=\"violet\">(b+c-a)(c+a-b)</span> <br />\n= <span class=\"violet\">-</span>(a+b+c)(a+b-c)<span class=\"violet\">(a-b-c)(a-b+c)</span><br />\n= -((a+b)^2 - c^2)) ((a-b)^2 - c^2))<br />\n<br />\nFor positive real numbers, <br />\n(a+b)^2              &gt;= (a-b)^2<br />\n(a+b)^2 - c^2      &gt;= (a-b)^2 - c^2<br />\n-((a+b)^2 - c^2)  &lt;= (a-b)^2 - c^2<br />\n-<span class=\"pink\">(</span>(a+b)^2 - c^2<span class=\"pink\">)</span> <span class=\"pink\">(</span>(a-b)^2 - c^2<span class=\"pink\">)</span> &lt;= <span class=\"pink\">(</span>(a-b)^2 - c^2<span class=\"pink\">)</span>^2<br />\n<br />\nSo R.H.S. &lt;= ((a-b)^2 - c^2)^2<br />\n<br />\nL.H.S.<br />\n= (a^2 + b^2)^2<br />\n&gt;= (a^2 - b^2)^2<br />\n&gt;= ((a-b)^2)^2<br />\n&gt;= ((a-b)^2 - c^2))^2<br />\n<br />\nSo L.H.S. &gt;= R.H.S."},{"pid":"c0178cc55de0bfd5e60da31a7277c722e2bc073f","tid":2221064,"uid":121095,"like":0,"dislike":0,"score":0,"quote":{"pid":"2b27d493038bb3892f703d1524c29c46a17e2b1f","tid":2221064,"uid":121095,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-09-28T11:29:28.000Z","msg":"5. <br />\nR.H.S.<br />\n= (a+b+c)(a+b-c)<span class=\"violet\">(b+c-a)(c+a-b)</span> <br />\n= <span class=\"violet\">-</span>(a+b+c)(a+b-c)<span class=\"violet\">(a-b-c)(a-b+c)</span><br />\n= -((a+b)^2 - c^2)) ((a-b)^2 - c^2))<br />\n<br />\nFor positive real numbers, <br />\n(a+b)^2              &gt;= (a-b)^2<br />\n(a+b)^2 - c^2      &gt;= (a-b)^2 - c^2<br />\n-((a+b)^2 - c^2)  &lt;= (a-b)^2 - c^2<br />\n-<span class=\"pink\">(</span>(a+b)^2 - c^2<span class=\"pink\">)</span> <span class=\"pink\">(</span>(a-b)^2 - c^2<span class=\"pink\">)</span> &lt;= <span class=\"pink\">(</span>(a-b)^2 - c^2<span class=\"pink\">)</span>^2<br />\n<br />\nSo R.H.S. &lt;= ((a-b)^2 - c^2)^2<br />\n<br />\nL.H.S.<br />\n= (a^2 + b^2)^2<br />\n&gt;= (a^2 - b^2)^2<br />\n&gt;= ((a-b)^2)^2<br />\n&gt;= ((a-b)^2 - c^2))^2<br />\n<br />\nSo L.H.S. &gt;= R.H.S."},"citedBy":0,"replyTime":"2020-09-28T11:46:00.000Z","msg":"R.H.S. жјҸе·ҰеҖӢnegative sign"},{"pid":"00d625e557c24c249257bb103443baa12cf4d883","tid":2221064,"uid":337498,"like":0,"dislike":0,"score":0,"quote":{"pid":"17d148df48e552f8c1c990c2ee4f8183a2d5c6d7","tid":2221064,"uid":264839,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-09-28T06:09:16.000Z","msg":"<img src=\"https://na.cx/i/zSDYUw6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzSDYUw6.jpg&h=616d507d&s={SIZE}\" /><img src=\"https://n