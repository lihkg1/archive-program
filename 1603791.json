citedBy":1,"replyTime":"2019-09-29T20:30:55.000Z","msg":"上環無限極嗰邊行人天橋幾撚多呢D<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"36a964e74d79d24876a5539561a440944d186b79","tid":1603791,"uid":13751,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T15:31:18.000Z","msg":"推"},{"pid":"f1101db7913d1cbabd788031a79840bac1850606","tid":1603791,"uid":13751,"like":0,"dislike":0,"score":0,"quote":{"pid":"01d09735f526b0cc37f16a9f6a5d8b7452c0d54d","tid":1603791,"uid":3873,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-29T20:30:55.000Z","msg":"上環無限極嗰邊行人天橋幾撚多呢D<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-01T15:32:18.000Z","msg":"每日team ic都會喺當日嘅location list揀location，所以同一個位可以每日都唔同人"},{"pid":"078a839a56d47061690f3ee233f47ecae0354672","tid":1603791,"uid":158235,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-01T15:32:23.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"}]}