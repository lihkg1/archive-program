{"tid":540944,"cid":5,"subCid":0,"title":"濃煙罩伊院　百醫護疏散","createTime":"2018-01-26T03:07:05.000Z","updateTime":"2018-01-26T03:07:05.000Z","uid":25558,"like":0,"dislike":0,"uniUserReply":1,"replies":[{"pid":"1ded9b03d74e250a54f6b7990a4583bc97a63353","tid":540944,"uid":25558,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-26T03:07:05.000Z","msg":"<a href=\"https://hk.news.appledaily.com/local/daily/article/20180126/20285930\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20180126%2F20285930&d=QRFx0Pw9SOxgqvOnL0Rsbp7TfgnX9jywtYe9GXZmhCU%3D&h=e30c01ae\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20180126%2F20285930&h=65ec196c\" target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20180126/20285930</a><br />\n<br />\n<br />\n濃煙罩伊院　百醫護疏散<br />\n<br />\n港聞   <br />\n         <br />\n<br />\n<br />\n0:00<br />\n<br />\n<br />\n【本報訊】油麻地伊利沙伯醫院護士宿舍旁工地的一幢兩層高建築物，昨午1時50分突然起火，黑煙直捲半空，鄰近病理大樓受濃煙籠罩，過百醫護及職員疏散，消防出動一喉一煙帽隊灌救（圖），初步相信是建築廢料起火，事件中無人受傷，醫院服務未受影響。<br />\n<br />\n<br />\n<img src=\"https://static.appledaily.hk/images/apple-photos/apple/20180126/large/26ls2p4new.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fapple-photos%2Fapple%2F20180126%2Flarge%2F26ls2p4new.jpg&h=e6d53e60&s={SIZE}\" /><br />\n梁澤岡攝"}]}