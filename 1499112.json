full British Citizenship.<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=iLyAB%2BOE6twWPMF9W2uC6hTmJET03dBbukdTSFliYCA%3D&h=a542c81d\" target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"56f345801b6effbaf97643c22c2b8f8b9f93a3e2","tid":1499112,"uid":293382,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-23T16:10:43.000Z","msg":"#boycottchina"},{"pid":"85a27539a22d650d6d490e9f23c41befa3cf99af","tid":1499112,"uid":287449,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-23T16:13:04.000Z","msg":"824<br />\n<br />\n有冇人知道依家個保護記者基金既情況係點？<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1498020\" data-auto-link target=\"_blank\">https://lih.kg/1498020</a><br />\n唔知都幫幫P牌仔推一推POST<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"74d20ffb9d57d96ec7d618522551f1309871c5f6","tid":1499112,"uid":282225,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-23T16:13:06.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"33cba7c22af5c7f6d9a3ff419b24e7658b2ebf4e","tid":1499112,"uid":43231,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-23T16:13:32.000Z","msg":"<img src=\"/assets/faces/lm2/nosee.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/nosee.gif\" class=\"hkgmoji\" />"},{"pid":"88d0063b0ae43febae5125c8f9ea2b29968611d3","tid":1499112,"uid":5490,"like":1,"dislike":0,"score":1,"quote":{"pid":"362913908c5484e0e4614cc1850c3587381f66d5","tid":1499112,"uid":22558,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-08-23T15:28:11.000Z","msg":"呢場戰爭真係烽火四起 係希望<img src=\"/assets/faces/lm2/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/love.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-23T16:13:55.000Z","msg":"香港係其中一個主戰場"},{