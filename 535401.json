a352831fcc62cf7b46a120dece3383","tid":535401,"uid":38017,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-22T00:31:03.000Z","msg":"雞柳放雪櫃可以放幾多日"},{"pid":"b0d2387fa030388f9c8763c6a7d769264f71931a","tid":535401,"uid":32213,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-22T00:37:04.000Z","msg":"<img src=\"/assets/faces/fs/wink.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/wink.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/wink.gif\" class=\"hkgmoji\" />"},{"pid":"60ab54f712c36548d29cd18dacbfb95af9e1bd4d","tid":535401,"uid":72478,"like":14,"dislike":0,"score":14,"citedBy":3,"replyTime":"2018-01-22T00:49:02.000Z","msg":"我個個星期都係咁<br />\n呢D叫常備菜<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n網上都好多常備菜食譜<br />\n但我上次買左幾本書<br />\n好詳細咁講埋點樣存放先放到一星期都唔變壞<br />\n同埋D菜可以放幾耐等等<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n琴日整左<br />\n鹽燒鯖魚 汁燒鯖魚同三文魚<br />\n章魚餅 豬肉秋葵卷  同烚左唔同蔬果<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n每日個飯盒都好多顏色<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"e44b3669b20c405765ca3c8264b74fe73a59a23a","tid":535401,"uid":56230,"like":0,"dislike":0,"score":0,"quote":{"pid":"50d455f96c6b1b5944e0eb8159772000d14fffd3","tid":535401,"uid":29314,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-21T05:30:28.000Z","msg":"炆，咖喱，焗野咁<br />\n有焗爐既可以一炮過，煮面都得，落下餃丸蛋<br />\n一係外賣出街食咪無咁煩，但用錢多幾倍"},"citedBy":0,"replyTime":"2018-01-22T00:51:14.000Z","msg":"已經連續半年三餐都係外賣<br />\n真係唔多健康<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"6db4f8b0239747c8800dc0d8e91e436cc54b834c","tid":535401,"uid":40864,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-01-22T00:58:12.000Z","msg":"一條友住好難淨係買一餐份量，<br />\n差唔多每次都係煮兩餐份量，連續食好易厭又唔想keep太耐所以頂多三餐到<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"fecb48b7cefb8e1d6ec24a79c353aaf9987730de","tid":535401,"uid":1367,"like":0,"dislike":5,"score":-5,"quote":{"pid":"ea36dbd9c121cac84b588a77bb34352d9d4e96f5","tid":535401,"uid":131686,"like":2,"dislike":20,"score":-18,"citedBy":1,"replyTime":"2018-01-21T16:24:25.000Z","msg":"睇下樓主幾時有癌症<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-01-22T01:00:02.000Z","msg":"Aggaer <br />\n <br />\nPs:從唔食隔餐野，何況隔日"},{"pid":"6b86a1ddb1424f6111de040d85d1de67a8abce68","tid":535401,"uid":47674,"like":0,"dislike":0,"score":0,"quote":{"pid":"fecb48b7cefb8e1d6ec24a79c353aaf9987730de","tid":535401,"uid":1367,"like":0,"dislike":5,"score":-5,"quote":{"pid":"ea36dbd9c121cac84b588a77bb34352d9d4e96f5","tid":535401,"uid":131686,"like":2,"dislike":20,"score":-18,"citedBy":1,"replyTime":"2018-01-21T16:24:25.000Z","msg":"睇下樓主幾時有癌症<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-01-22T01:00:02.000Z","msg":"Aggaer <br />\n <br />\nPs:從唔食隔餐野，何況隔日"},"citedBy":0,"replyTime":"2018-01-22T01:03:13.000Z","msg":"所以咪整炆餸囉<br />\n炆餸隔日仲好食<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"cb293bfb323d7a41438299ca506bd3bd691b62af","tid":535401,"uid":5891,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-22T15:27:25.000Z","msg":"推"},{"pid":"f9bdba09217a0db960b7306c8b13a115be3d9006","tid":535401,"uid":42734,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-22T15:29:00.000Z","msg":"新垣結衣"},{"pid":"4c674d3dfc8a1f59952b7f7a3013dd975c678a7f","tid":535401,"uid":31712,"like":0,"dislike":0,"score":0,"quote":{"pid":"39c6406d00a00bff37e03d6c648d08a231b6b845","tid":535401,"uid":6532,"like":1,"dislike":0,"score":1,"quote":{"pid":"87f605cdc549233a1fa4976f4556e8abf6b5bc7c","tid":535401,"uid":31712,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-01-21T20:50:16.000Z","msg":"食隔飯飯會係咁放屁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 所以要食新鮮煮既米<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n不過會星期六日煮定三四個餸，咁平日就唔洗煮可以慳返好多時間<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> 有d似日本人既常備菜但中菜版<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n人住外國出街買餸要搭成個鐘車所以就用呢種生活方式，每星期五一次過買兩條友五晚晚餐份量<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> 都唔會話太複雜"},"citedBy":1,"replyTime":"2018-01-22T00:15:16.000Z","msg":"可否簡單分享餐單及保存方法<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-22T23:15:18.000Z","msg":"魚香茄子（實有人話咩現成醬汁慘過食屎）<br />\n多數煮多汁既野，男朋友鍾意撈飯<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />  越南炆豬胸肉，生薑照燒汁煮羊肉片（外國難買豬肉薄片，有都好貴，五蚊歐羅勉強夠一個男人食量），小棠菜炒木耳，青椒肉絲etc<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n有焗爐可以焗香口野食，好多時買急凍炸物然後用焗爐代替炸<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />  有心機可以整下韓國碗菜，醬煮「奄」春蛋果種都好正<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n<br />\n煮多d就好易搵到自己鍾意既「常備菜」<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />  個人覺得香港好方便就買到肉片，又有好多種煮法又唔使切，一流<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"e21a67e78fb977944ddb5733ed6b49f13e175630","tid":535401,"uid":31712,"like":0,"dislike":0,"score":0,"quote":{"pid":"60ab54f712c36548d29cd18dacbfb95af9e1bd4d","tid":535401,"uid":72478,"like":14,"dislike":0,"score":14,"citedBy":3,"replyTime":"2018-01-22T00:49:02.000Z","msg":"我個個星期都係咁<br />\n呢D叫常備菜<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n網上都好多常備菜食譜<br />\n但我上次買左幾本書<br />\n好詳細咁講埋點樣存放先放到一星期都唔變壞<br />\n同埋D菜可以放幾耐等等<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n琴日整左<br />\n鹽燒鯖魚 汁燒鯖魚同三文魚<br />\n章魚餅 豬肉秋葵卷  同烚左唔同蔬果<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n每日個飯盒都好多顏色<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-22T23:15:57.000Z","msg":"好多食魚呀<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"67669cd5948e2a9d9e42ebe9a954cafa3b4c497e","tid":535401,"uid":18844,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-01-22T23:29:25.000Z","msg":"需要一個女朋友擺係雪櫃<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"3d0a2bc2d3b67f597396e04a5504dfc69b688534","tid":535401,"uid":106375,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-01-22T23:36:39.000Z","msg":"仲以為講白飯<br />\n我自己一個住果時會一次煮4,5碗分量<br />\n然後用保鮮紙包住舊飯再放入保鮮袋再放雪櫃<br />\n拎返出黎會同岩岩煮完放凍冇咩分別<br />\n但老母黎探我時見到我咁就即卡塞左幾千蚊俾我"},{"pid":"8dca146e0723ef6a55b4a8981e14fb0899e4f6d4","tid":535401,"uid":9031,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-01-23T21:40:19.000Z","msg":"聽日準備完d飯餸之後擺上黎分享下 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"34c5413772afc22d4983392cb4ec31ddc84f10ca","tid":535401,"uid":47674,"like":1,"dislike":0,"score":1,"quote":{"pid":"3d0a2bc2d3b67f597396e04a5504dfc69b688534","tid":535401,"uid":106375,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-01-22T23:36:39.000Z","msg":"仲以為講白飯<br />\n我自己一個住果時會一次煮4,5碗分量<br />\n然後用保鮮紙包住舊飯再放入保鮮袋再放雪櫃<br />\n拎返出黎會同岩岩煮完放凍冇咩分別<br />\n但老母黎探我時見到我咁就即卡塞左幾千蚊俾我"},"citedBy":0,"replyTime":"2018-01-23T21:47:26.000Z","msg":"等我又試下咁煮先<img src=\"/assets/faces/normal/biggrin.gif\" 