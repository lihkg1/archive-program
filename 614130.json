r />\n貼張報左警既cap圖就嚇到縮翻佢老母個閪到<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-02T10:05:51.000Z","msg":"之前睇佢講嘢都覺得佢小學雞<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b23d75986d7c3d807193fea0bbc52d57e8e3274b","tid":614130,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-02T10:50:16.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"51c1711357eae32820452c50141229239f0b0ce3","tid":614130,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-03T01:08:26.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"4c27a25438f1856b26f644af940ef145d22cf125","tid":614130,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-03T01:28:35.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"475c119d0090184a8b3c08d85d1a65d7ab85f98d","tid":614130,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-03T02:53:26.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"123b5c6a5f5d0fcfe8001c1c02197f4ab4a2798a","tid":614130,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-03T03:30:17.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7644d6f904ed55c1163bf40cec88b61dd5438fab","tid":614130,"uid":402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-04T06:50:07.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"449d4acd1c1ae3d0d8e1eef15fc9082b799a2778","tid":614130,"uid":51129,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-10T14:19:35.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"bded711277056d26226cdae8