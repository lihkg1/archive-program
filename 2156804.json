,"uid":267410,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-14T17:53:51.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"de918fa9595af9ddcce30cd6d588e32c63bd94aa","tid":2156804,"uid":126797,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-14T17:56:59.000Z","msg":"作大話都唔怕厭架喎<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f602802772fa8c14c533dcfda7641d61c5748467","tid":2156804,"uid":304992,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-08-14T18:00:38.000Z","msg":"<img src=\"https://na.cx/i/bkmdHWr.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbkmdHWr.png&h=8f71e7e5&s={SIZE}\" /><br />\n<a href=\"https://www.facebook.com/178843345631203/posts/1581115415403982/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F178843345631203%2Fposts%2F1581115415403982%2F&d=NZlAC2w8bMplDXSravNUcWWzMblEAwKPRhfqpO9yGDY%3D&h=d83f0b71\" data-auto-link target=\"_blank\">https://www.facebook.com/178843345631203/posts/1581115415403982/</a>"},{"pid":"df275fa2cae5d74bfefc80a10ad4c38a0d8b6cef","tid":2156804,"uid":80890,"like":1,"dislike":0,"score":1,"quote":{"pid":"812999ba8e7e3fd4308f1083f99695b75d786199","tid":2156804,"uid":321059,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-08-14T16:53:15.000Z","msg":"【 警方呼籲一宗「交通意外有人受傷案」的報案人盡快聯絡警方錄取口供 】<br />\n<br />\n昨晚（8月14日）約7時，警方接獲一名男子報案，表示於西區山市街被一輛私家車跟蹤， 其間私家車涉嫌撞傷報案人。<br />\n<br />\n警方到場調查，經了解後確認私家車司機及乘客均為記者，<span class=\"red\">惟報案人於現場拒絕錄取口供</span>，亦拒絕到醫院驗傷。<span class=\"red\">警方隨後要求私家車司機及乘客一同前往警署錄取口供，並向司機進行酒精呼氣測試。</span><br />\n<br />\n案件現列作「交通意外有人受傷」，由港島區交通意外特別調查隊第二隊跟進調查。私家車司機通過酒精呼氣測試，警方亦已向私家車司機及乘客錄取口供，現呼籲報案人盡快與警方聯絡及錄取口供，以協助案件調查。<br />\n<br />\n另外，警方留意到有個別媒體就上述案件的報道失實，惡意指控警方豁免查驗後放行涉事司機，居心叵測，令人遺憾。<br />\n<br />\n<br />\n<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-14T18:05:22.000Z","msg":"傷人果個咪係港共恐怖分子<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"b1c9ad6b5710a479de6c9e7b2e925bf822c73291","tid":2156804,"uid":80890,"like":1,"dislike":0,"score":1,"quote":{"pid":"f602802772fa8c14c533dcfda7641d61c5748467","tid":2156804,"uid":304992,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-08-14T18:00:38.000Z","msg":"<img src=\"https://na.cx/i/bkmdHWr.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbkmdHWr.png&h=8f71e7e5&s={SIZE}\" /><br />\n<a href=\"https://www.facebook.com/178843345631203/posts/1581115415403982/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F178843345631203%2Fposts%2F1581115415403982%2F&d=NZlAC2w8bMplDXSravNUcWWzMblEAwKPRhfqpO9yGDY%3D&h=d83f0b71\" data-auto-link target=\"_blank\">https://www.facebook.com/178843345631203/posts/1581115415403982/</a>"},"citedBy":0,"replyTime":"2020-08-14T18:06:55.000Z","msg":"對牛彈琴<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n辛苦曬許勇<img src=\"/assets/faces/dog/notcry.gif\" class=\"hkgmoji\" />"},{"pid":"691138fd9211bdceefc79839a436e278b18df44a","tid":2156804,"uid":13856,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-14T18:07:27.000Z","msg":"講大話當人傻<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}