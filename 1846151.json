ass=\"hkgmoji\" />"},{"pid":"f3a3ee70be30bec6f21703bff5de6b5a431d668d","tid":1846151,"uid":79075,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T13:37:48.000Z","msg":"即刻封羅湖同落馬洲站"},{"pid":"6a67af784cf8ef1d6e392e227500e82bf9fe8504","tid":1846151,"uid":79075,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T13:38:30.000Z","msg":"封呀屌"},{"pid":"4235594f8ab34c378b511b6ea353f7d5c3a3e6e2","tid":1846151,"uid":79075,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-01-27T13:39:06.000Z","msg":"無撚可能大學就封羅湖唔撚封"},{"pid":"13430bc5f40196ef40f2fcdfe6e80d66f26e81ad","tid":1846151,"uid":79075,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T13:40:51.000Z","msg":"封站"},{"pid":"f37d9748f1552bafab52ab4ea45bab76771c47f9","tid":1846151,"uid":344033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T13:40:53.000Z","msg":"手足裝備抗沙士：護目鏡 非常重要！分析文！大力推！<br />\n<a href=\"https://lih.kg/1845419\" data-auto-link target=\"_blank\">https://lih.kg/1845419</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<a href=\"https://www.facebook.com/112357283631796/posts/117867026414155/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F117867026414155%2F%3Fd%3Dn&d=gjA94EiKSJsk9JMrtOnM5oeNTHq1rgEicHo%2BkVhR8rs%3D&h=2e36fa22\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/117867026414155/?d=n</a><br />\n<br />\n手足裝備抗沙士：護目鏡<br />\n整體分析：<a href=\"https://www.facebook.com/112357283631796/posts/116690396531818/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F116690396531818%2F%3Fd%3Dn&d=gjA94EiKSJsk9JMrtOnM5oeNTHq1rgEicHo%2BkVhR8rs%3D&h=f4d78677\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/116690396531818/?d=n</a><br />\n<br />\n首選：Sellstrom S80225/S80226 Wildland Fire Goggles （戴眼鏡都用得）<br />\n<a href=\"https://www.amazon.com/Sellstrom-Wildland-Goggles-Non-Vented-Anti-Fog/dp/B07DJVPL9Q\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.amazon.com%2FSellstrom-Wildland-Goggles-Non-Vented-Anti-Fog%2Fdp%2FB07DJVPL9Q&d=gjA94EiKSJsk9JMrtOnM5oeNTHq1rgEicHo%2BkVhR8rs%3D&h=069ce903\" data-auto-link target=\"_blank\">https://www.amazon.com/Sellstrom-Wildland-Goggles-Non-Vented-Anti-Fog/dp/B07DJVPL9Q</a><br />\n<br />\nSellstrom 依款眼罩，上年九月果陣，已經係前線手足標準裝備，有手足認證，包保放心！其中，依款眼罩有兩大特點。<br />\n<br />\n第一，依款眼罩寫明係 non-vented，即係氣密。戴左之後，基本上就阻隔左外面嘅空氣進入眼罩，所以擋到TG，亦都擋到帶病毒嘅飛沫同空氣，乜春都入唔到眼。依個亦都係佢可以俾美國消防員救山火果陣用嘅原因。氣密係眼罩第一重要條件，如果唔係氣密，病毒同TG都可以經眼罩邊位入眼，大陸衛健委都講明病毒傳染性不斷上升，美國有教授都講左武漢沙士嘅reproductive rate 高過曬佢見過佢嘅病毒，證明今次係非常嚴重，必須要用高規格嘅產品保護自己！<br />\n<br />\n第二，依款眼罩經過 ANSI Z87+ 嘅驗證，保護性極高！<br />\nANSI Z87+嘅定義如下：<br />\n&lsquo;Each product must go through rigorous third-party testing which simulates hazards such as impact by flying objects and debris, high mass impact, and sharp object penetration. In each testing scenario, the lenses and frame must stay intact to pass&rsquo;<br />\n根據網上一個對ANSI Z87+ 眼罩嘅測試，散彈槍都射佢唔穿，所以ANSI Z87+ 嘅standard 係非常高，亦都只有依種眼罩嘅保護性先可以保護前線免受橡膠子彈同布袋彈威脅。<br />\n<br />\n次選：Pyramex CAPSTONE (G504DT或其他型號）<br />\n<a href=\"https://www.amazon.com/Pyramex-Capstone-Direct-Indirect-Anti-Fog/dp/B003UUEW88\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.amazon.com%2FPyramex-Capstone-Direct-Indirect-Anti-Fog%2Fdp%2FB003UUEW88&d=gjA94EiKSJsk9JMrtOnM5oeNTHq1rgEicHo%2BkVhR8rs%3D&h=1d67b6bd\" data-auto-link target=\"_blank\">https://www.amazon.com/Pyramex-Capstone-Direct-Indirect-Anti-Fog/dp/B003UUEW88</a><br />\n<br />\n第一，依款眼罩有氣密帽，應該同樣做到氣密效果，但係因為佢嘅氣密帽可以拆卸，多左個連接位，所以氣密保護性會低小小（始終多個連接位就多個出錯機會）。<br />\n第二，依款眼罩經過D3 測試，證實可以防水滴同化學劑嘅飛淺，理論上有足夠防水性能。<br />\n第三，依款眼罩經過MIL-PRF 32432 美軍標準測試，對子彈衝擊力有一定防禦。<br />\n<br />\n最後選擇：泳鏡（仲易買過平光鏡）<br />\n<br />\n泳鏡顧名思義，就係for 遊水，氣密效果有一定嘅保證，同埋求其一間運動鋪都可以買到，買近視鏡嘅話眼睛都唔洗戴，幾十蚊就有，保護性一定好過平光鏡，不過如果係講嘢都要除口罩，放屁要除褲，戴左帽可能腦都用唔到嘅人，可能佢戴左就會睇唔野。<br />\n<br />\n8.5 最新護目鏡實測 條帶戴高D 鼻位GAP就會消失!!! &amp; 前線超過400位豬嘴實測<br />\n<a href=\"https://lih.kg/1411916\" data-auto-link target=\"_blank\">https://lih.kg/1411916</a><br />\n<br />\n大家幫幫手，like &amp; share 等多啲人睇到！<br />\n<br />\n香港眼罩網店列表：（請各位幫手加落去）<br />\n<br />\n<a href=\"https://www.3armystore.com/products/pyramex-capstone-dual-lens\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.3armystore.com%2Fproducts%2Fpyramex-capstone-dual-lens&d=gjA94EiKSJsk9JMrtOnM5oeNTHq1rgEicHo%2BkVhR8rs%3D&h=49973734\" data-auto-link target=\"_blank\">https://www.3armystore.com/products/pyramex-capstone-dual-lens</a><br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<a href=\"https://shop.outletexpress.com.hk/index.php?route=product/product&amp;product_id=4252\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fshop.outletexpress.com.hk%2Findex.php%3Froute%3Dproduct%2Fproduct%26product_id%3D4252&d=gjA94EiKSJsk9JMrtOnM5oeNTHq1rgEicHo%2BkVhR8rs%3D&h=022afaca\" data-auto-link target=\"_blank\">https://shop.outletexpress.com.hk/index.php?route=product/product&amp;product_id=4252</a><br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n<a href=\"https://www.autoworld.hk/chinese/pygg504t.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.autoworld.hk%2Fchinese%2Fpygg504t.html&d=gjA94EiKSJsk9JMrtOnM5oeNTHq1rgEicHo%2BkVhR8rs%3D&h=f6ad1195\" data-auto-link target=\"_blank\">https://www.autoworld.hk/chinese/pygg504t.html</a><br />\n<br />\n<br />\n#屠龍 #藍絲 #藍屍 #黃色經濟圈 #黃店 #裝備 #口罩 #武漢肺炎 #武漢 #P95 #文宣 #N95 #肺炎 #沙士 #香港 #支那人 #高鐵 #眼罩 #tg #lihkg #連登 #高登 #d100 #黑警"},{"pid":"b1077b40e49102d7ab14c8eb6b661ce2a7724b73","tid":1846151,"uid":79075,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-27T13:41:26.000Z","msg":"封站"},{"pid":"9f7de0f5996ca06c4e705171dac4d454e87f7330","tid":1846151,"uid":1627,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-27T13:41:43.000Z","msg":"棄東鐵啦，冇必要儘量唔好搭啦"},{"pid":"6622830d6469e62279db89a58e5e09657ea75c6d","tid":1846151,"uid":79075,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-01-27T13:42:21.