到，只識濫捕告唔入，死死地氣放返出黎，打狗放火食警嫂無後果吹我地唔脹，照樣生勾勾照上街抗爭屌狗做野<br />\n<br />\n屌你老母黑警毅進狗死全家，落地獄"},{"pid":"2940aa874da22c6f4c928a6db9ca07ecf568e4a8","tid":1734034,"uid":111898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T08:47:11.000Z","msg":"推"},{"pid":"e0b8c6a36cc625bc436c656902549e55353a3c1a","tid":1734034,"uid":204625,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T08:47:24.000Z","msg":"up"},{"pid":"edd4d0ab092c5d46c657179794583a7de285e6ef","tid":1734034,"uid":5967,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T08:47:31.000Z","msg":"真，有用"},{"pid":"944522d134bfcf94df8b2f48cf192d4d66af6bd0","tid":1734034,"uid":302668,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T08:47:36.000Z","msg":"有drone空投未，要唔要籌旗？"},{"pid":"c3c668bb6e1bc4827dc10c7ba54736feb3a5cca0","tid":1734034,"uid":55669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T08:47:44.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"7c76c56b037f2809a1ad1e3b00f4df1496bfc761","tid":1734034,"uid":73573,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T08:47:45.000Z","msg":"推"},{"pid":"fd2037f4be4bcb4e513a160a4568d9686189c53d","tid":1734034,"uid":332422,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T08:47:57.000Z","msg":"推"},{"pid":"06e0d3e6a00c21d909ae0a26b87ba13077ba5dbf","tid":1734034,"uid":73573,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T08:50:19.000Z","msg":"推"},{"pid":"62c88250ed244ec0d0987771ef4b1723990c796a","tid":1734034,"uid":143124,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-18T08:51:19.000Z","msg":"推"}]}