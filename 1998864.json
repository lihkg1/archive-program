d.gif\" class=\"hkgmoji\" />)"},{"pid":"28113f21d2cc2f48632f1b335b5406bff9ede046","tid":1998864,"uid":238369,"like":0,"dislike":0,"score":0,"quote":{"pid":"c8b9a2b78e5cda9af3ac590fb464f45e070ee17d","tid":1998864,"uid":268516,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-05-02T17:37:43.000Z","msg":"對煮飯嗰個身體唔好<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n聽過有人反問<br />\n人類始祖本身食無定時<br />\n唔會日日定時有獵物走出嚟俾佢地開飯"},"citedBy":2,"replyTime":"2020-05-02T18:16:07.000Z","msg":"咁始祖咪好短命囉"},{"pid":"221fa90271f715f0cdbc3f8f40a32a0dce799a2e","tid":1998864,"uid":268516,"like":0,"dislike":0,"score":0,"quote":{"pid":"28113f21d2cc2f48632f1b335b5406bff9ede046","tid":1998864,"uid":238369,"like":0,"dislike":0,"score":0,"quote":{"pid":"c8b9a2b78e5cda9af3ac590fb464f45e070ee17d","tid":1998864,"uid":268516,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-05-02T17:37:43.000Z","msg":"對煮飯嗰個身體唔好<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n聽過有人反問<br />\n人類始祖本身食無定時<br />\n唔會日日定時有獵物走出嚟俾佢地開飯"},"citedBy":2,"replyTime":"2020-05-02T18:16:07.000Z","msg":"咁始祖咪好短命囉"},"citedBy":1,"replyTime":"2020-05-02T18:17:21.000Z","msg":"但無絕種喎"},{"pid":"fdd0136cf33a6f780763a4caeaf6541fcebad02f","tid":1998864,"uid":241832,"like":0,"dislike":0,"score":0,"quote":{"pid":"b4920cb736e0ad431c9e15c4e3dd2bb9d0c1b3f9","tid":1998864,"uid":192409,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-05-02T17:43:14.000Z","msg":"胃酸分泌問題，通常胃酸會定左某個時間分沁，食唔定時咪會做成有時胃酸分泌左 但個胃無食物喺度，就會傷胃 利申：9up"},"citedBy":0,"replyTime":"2020-05-02T19:34:57.000Z","msg":"飲多啲水咪得"},{"pid":"5f94938e28fd9d14bffc916c2364350f8930a60e","tid":1998864,"uid":241832,"like":0,"dislike":0,"score":0,"quote":{"pid":"7beaef13712469898086ecd71b73048951143849","tid":1998864,"uid":16137,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2