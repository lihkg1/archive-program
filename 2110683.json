"pid":"9cdee73c1afc6014d2b40e631b89ed0577ca641e","tid":2110683,"uid":259246,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-07-16T06:08:09.000Z","msg":"千福BB<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"05a1c68976461e2a1da91d8ee63373e959c693ce","tid":2110683,"uid":126305,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-16T07:51:59.000Z","msg":"美國盟友<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"9745cba026db42beec1c4085b5ce361db18557a8","tid":2110683,"uid":237425,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-16T07:59:39.000Z","msg":"<img src=\"https://hk.appledaily.com/resizer/eOkhoYuExincCvQeZI8Y0POViiA=/706x945/filters:quality(100)/arc-photo-appledaily.s3.amazonaws.com/ap-ne-1-prod/public/AZNFP2XWHPPQLTYIYQ6HHQC6MM.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.appledaily.com%2Fresizer%2FeOkhoYuExincCvQeZI8Y0POViiA%3D%2F706x945%2Ffilters%3Aquality%28100%29%2Farc-photo-appledaily.s3.amazonaws.com%2Fap-ne-1-prod%2Fpublic%2FAZNFP2XWHPPQLTYIYQ6HHQC6MM.jpg&h=c8821f17&s={SIZE}\" /><br />\n<br />\n2013年黎HK, 真心最貼地既美帝總領事<br />\n<br />\n曾任六方會談特使 北京忌憚<br />\n更新時間 (HKT): 2013.08.01 05:20<br />\n【拆局】<br />\n曾獲美國總統奧巴馬委任，出任六方會談特使的夏千福，有30多年外交經驗，曾在台灣學習普通話。<br />\n抵埗即展親民姿態<br />\n<br />\n相關新聞：「榮幸親歷香港民主發展新階段」  美總領事履新 提真普選<br />\n<br />\n夏甫履新即展露外交功力，透過領事館facebook專頁，發出參觀花園道領事館旁的茶具文物館的相片，在館內的茶餐廳佈置擺甫士拍照，稱很想快些「去真正嘅茶餐廳度食早餐」，投入本地生活，姿態親民。<br />\n面對政治手腕高超的外交老手，北京對其任命大為緊張，本港左派輿論過去兩個月多次評論，質疑美國派出曾駐內地、台灣、伊拉克和前蘇聯的「中國通」夏千福來港，是要搞「顏色革命」。<br />\n有知情人士指，北京對夏千福來港十分忌憚，因夏是美國外交界重量級人物，今次任命令北京憂慮美國會否加強插手香港事務。<br />\n中大政治與行政學系高級講師蔡子強認為，美方已充份掌握香港左派取態，相信已有準備就政改與左派磨擦升溫。<br />\n民主黨創黨主席李柱銘指左派對夏的批評荒謬，因為落實普選是中國政府的承諾，笑言「佢（夏千福）未來港左派已鬧佢，呢位阿哥夠勁喎」<br />\n<br />\n<a href=\"https://hk.news.appledaily.com/local/20130801/ZRIM2MWGOZHD34W4O2DSKXVCUY/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20130801%2FZRIM2MWGOZHD34W4O2DSKXVCUY%2F&d=CgM6%2BPDcwTI4Uk%2BisK9n3%2Bu9cyR3gY7uP1sO3WVLDIg%3D&h=636084ef\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2F20130801%2FZRIM2MWGOZHD34W4O2DSKXVCUY%2F&h=eb4d2ccd\" target=\"_blank\">https://hk.news.appledaily.com/local/20130801/ZRIM2MWGOZHD34W4O2DSKXVCUY/</a>"},{"pid":"c1b05b6b4679f415ed773b12b7826bb6ea7b5e00","tid":2110683,"uid":237425,"like":2,"dislike":0,"score":2,"quote":{"pid":"1bb186a867f9190b6735a2036fde4b19714bc324","tid":2110683,"uid":34010,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-07-16T05:56:52.000Z","msg":"千福BB <img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-16T07:59:55.000Z","msg":"好掛住千福BB <img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/adore.gif\" class=\"hkgmoji\" />"},{"pid":"5a0bdfb6fd830c30d692a30c0407a716540da350","tid":2110683,"uid":268957,"like":1,"dislike":0,"score":1,"quote":{"pid":"b8b3c12ede332e2d1c9fee2936fadc07de75183c","tid":2110683,"uid":111253,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-07-16T05:45:44.000Z","msg":"夏千福之前好似話一國兩制乜乜柒柒<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-16T08:03:38.000Z","msg":"果個係肥仔唐偉康"},{"pid":"d86ae0af97fa5572978d4747cd383d9f97530c7c","tid":2110683,"uid":280648,"like":0,"dislike":0,"score":0,"quote":{"pid":"74d9171814b5aac4fa15639e5fbe2863281dbe3f","tid":2110683,"uid":100337,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-07-16T05:50:16.000Z","msg":"挑戰明將嘅總領事<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-07-16T08:04:39.000Z","msg":"<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"41f0ae665281fa65598290573f14f6cd80da34b9","tid":2110683,"uid":60635,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-16T08:07:05.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"75b64bfe88ff82ab246c694e847e003506ba3283","tid":2110683,"uid":124711,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-16T08:08:57.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}