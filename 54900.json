nk?u=http%3A%2F%2Fm.soccer.sina.com.hk%2Fnews%2Farticle%2F6720100%2F87%2F20161226&d=v6tcZVhR5zdeH8CLGWrrsUsIbL4fERhwM0ZRx9Zc9p0%3D&h=c54c2b9a\" target=\"_blank\">http://m.soccer.sina.com.hk/news/article/6720100/87/20161226</a><br />\n<br />\n<br />\n竟然完全唔放軒達巨在眼內<img src=\"/assets/faces/lomoji/36.png\" class=\"hkgmoji\" /><img src=\"/assets/faces/lomoji/36.png\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/08.png\" class=\"hkgmoji\" />"},{"pid":"47c0ee92811fd63a4582da686671af4bbd919b67","tid":54900,"uid":18669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-26T05:28:39.000Z","msg":"<img src=\"http://i1.hoopchina.com.cn/blogfile/201612/26/BbsImg148272402551937_268x230.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi1.hoopchina.com.cn%2Fblogfile%2F201612%2F26%2FBbsImg148272402551937_268x230.gif&h=34221a50&s={SIZE}\" />"},{"pid":"61bd022f149425b71b119bb6eb06e1aa22d7d1b5","tid":54900,"uid":40940,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-26T05:34:13.000Z","msg":"<img src=\"http://stream1.gifsoup.com/view3/20140120/4957344/costa-fazio-o.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstream1.gifsoup.com%2Fview3%2F20140120%2F4957344%2Fcosta-fazio-o.gif&h=140d3dae&s={SIZE}\" />"},{"pid":"3d6718ad7d923b9d8483d25c1fc750fe55ffb60a","tid":54900,"uid":38390,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-26T06:00:47.000Z","msg":"軒仔又贏"},{"pid":"33e0497ce215cfa0906fd0f7c7d7bbe342ceadf9","tid":54900,"uid":49269,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-26T06:47:01.000Z","msg":"<blockquote><img src=\"http://stream1.gifsoup.com/view3/20140120/4957344/costa-fazio-o.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstream1.gifsoup.com%2Fview3%2F20140120%2F4957344%2Fcosta-fazio-o.gif&h=140d3dae&s={SIZE}\" /></blockquote><br />\n<img src=\"/assets/faces/lom