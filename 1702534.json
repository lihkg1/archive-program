quote":{"pid":"3bfec0c312c01d440f06f13a2fa3f7c128920e5f","tid":1702534,"uid":227275,"like":1,"dislike":0,"score":1,"quote":{"pid":"cc3804f020ff769a9289b6e97c205edae5000ac5","tid":1702534,"uid":254330,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-11-09T17:47:31.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-09T17:50:35.000Z","msg":"不過日本係又平 又用國產牛同珍珠米 都屌打香港"},"citedBy":0,"replyTime":"2019-11-09T17:55:40.000Z","msg":"D牛仲要係燒牛肉<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"da04618fed5a300ca8a0993dd60b80323db24eaf","tid":1702534,"uid":227275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T18:09:09.000Z","msg":"4"},{"pid":"ff5a572fb144af634cae45ae6c4958fa9955adfc","tid":1702534,"uid":159448,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-09T18:15:29.000Z","msg":"其實美心都好間接啦 果條女收股息姐<br />\n啲官買滙豐收息唔通又裝修滙豐咩<br />\n<br />\n不過支持裝修行為<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"e84aa89c8657d4314329b70b872f5eb2d38c0547","tid":1702534,"uid":227275,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff5a572fb144af634cae45ae6c4958fa9955adfc","tid":1702534,"uid":159448,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-09T18:15:29.000Z","msg":"其實美心都好間接啦 果條女收股息姐<br />\n啲官買滙豐收息唔通又裝修滙豐咩<br />\n<br />\n不過支持裝修行為<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-11-09T18:26:49.000Z","msg":"其實都岩<br />\n條8婆年收130萬息<br />\n但其實買2千萬匯豐一年都收到130萬 <br />\n<br />\n不過算喇 有美心做例子比班仆街知驚下都好"},{"pid":"9bd6648080440f3ac7c2ab1a321b8f3a75ecd39f","tid":1702534,"uid":88101,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-09T18:30:43.000Z","msg":"祭旗"},{"pid":"036cf2f2b125b33cd15c30ac5f359c98da0a9cbb","tid":1702534,"uid