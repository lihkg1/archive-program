請各位寄資料既時候記得<br />\n<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">用物理方式遮蔽敏感個人資料</span></strong></span><br />\n我地只係要核實你地確實喺台灣,<br />\n同埋係呢段時間走難過黎既<br />\n請保障你地個人資料, <br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: red;\">我地現在及將來都唔會要求你提供</span></strong></span><br />\n另外考慮我地冇辦法運送資金 亦無公信力進行集資<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">現時我地唔接受有心人士捐款</span></span></strong><br />\n多謝你地有心"},{"pid":"b024e29bbd27d87a7cc282fd1d4bd28d2cbf754e","tid":1542980,"uid":68730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T04:39:03.000Z","msg":"推"},{"pid":"5e215cde9e1548eaa84616c63e1e479d73bc0c13","tid":1542980,"uid":68730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T04:39:13.000Z","msg":"推"},{"pid":"8092375f8fce675ec7caf2ebec1d5f5fee477e75","tid":1542980,"uid":68730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T04:39:48.000Z","msg":"推"},{"pid":"002e3fb0737e4a3bc5b31d495e9c080a738017c5","tid":1542980,"uid":70973,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T04:39:49.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"4ef6e75dd4d80ed6eb4bfb0774722252ffe48794","tid":1542980,"uid":68730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T04:40:01.000Z","msg":"推"},{"pid":"65381db657f1ede9a68175ce7597e611f466abfb","tid":1542980,"uid":68730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T04:40:22.000Z","msg":"推"},{"pid":"7cc0f1097b6ed7da06f425856328a675779ce245","tid":1542980,"uid":68730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T04:40:34.000Z","msg":"推"}]}