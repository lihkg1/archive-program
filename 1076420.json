10_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=3c69ba23&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/30/133221_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F30%2F133221_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=ec45a1f1&s={SIZE}\" />"},{"pid":"0e653dfe0fbe46cd91dad7fc829d12c441204e5c","tid":1076420,"uid":214534,"like":0,"dislike":0,"score":0,"quote":{"pid":"f6bbeb94b12ef273c10e8d097b46f2378f68ff5b","tid":1076420,"uid":25900,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-25T12:03:24.000Z","msg":"係街鬧個仔你都分到公屋定私樓<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-03-25T12:17:30.000Z","msg":"<span style=\"font-size: large;\"><span style=\"color: red;\">中產父母：Jayden，No！唔好搞啲野，Jayden！ I say No ！<br />\n<br />\n之後雖然小朋友會有啲唔開心 但都會自動停手<br />\n<br />\n呢個時候好既中產父母就話講返點解唔得<br />\n差少少就咩都唔講<br />\n<br />\n但我相信已經好過好多公屋父母<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /></span></span>"},{"pid":"fe4024865076f0e0c95ba3e699da711bdceef4d0","tid":1076420,"uid":41508,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-03-25T12:20:32.000Z","msg":"此回覆已被刪除"},{"pid":"5eb444beff63f75eb18601dfcb9e6998c4db5d98","tid":1076420,"uid":214534,"like":0,"dislike":0,"score":0,"quote":{"pid":"fe4024865076f0e0c95ba3e699da711bdceef4d0","tid":1076420,"uid":41508,"like":0,"dislike":0,"score":0,"quote":{"pid":"802266a83bc5fa6863ffd48460e330938cc01d18","tid":1076420,"uid":42188,"like":3,"dislike":0,"score":3,"quote":{"pid":"720b82c6dd7132ecd46a74268e382b7518922a73","tid":1076420,"uid":41508,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-03-25T12:08:05.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-03-25T12:12:37.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/01/30/132649_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F30%2F132649_ea3dc39ca0b2f6b5f17abddec1f0e9a4.png&h=5c5cced4&s={SIZE}\" /><br />\n<br />\n由於原post內容過於對<span style=\"color: red;\">黃巢(~9527)陳育權</span>不利比admin搬去站務台，現開個新post整合有關資料<br />\n<br />\nand已向admin舉報及cap圖<br />\n<br />\n原post精彩時空門<br />\n踢爆會員黃巢及9527~真身有埋圖及多位連登巴打認證後發窮惡區3<br />\n<a href=\"https://lihkg.com/thread/612756/page/2?ref=web&amp;post=31\" target=\"_blank\">https://lihkg.com/thread/612756/page/2?ref=web&amp;post=31</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: large;\"><strong>黃巢係9527~同時又係白卡陳育權老母叫愛姐<br />\n<br />\n比一眾連登巴打連續踢爆，所以發窮惡洗板阻人討論<br />\n<br />\n<br />\n已舉報<br />\n<br />\n<br />\n樓會貼cap圖多位巴打仗儀篤爆呢隻白卡五毛<br />\n<br />\n一樓有佢同佢阿媽副尊容，仲有多謝蔣仔提供<br />\n<br />\n二樓會貼cap圖多位巴打仗儀篤爆呢隻白卡五毛<br />\n<br />\n三樓有罪證，去到台灣都有人知<br />\n<br />\n四樓打後係發窮洗板討論總集，唔止我d post連其他無辜會員d post都搞貼金剛棒阻人討論，同濕仔一樣，今日洗左15個post，截之今日為止總數係65個 post<br />\n<br />\n</strong></span></span><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/01/18/011850_cd2b8e352a852ddf1e0942e076a0767b.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F18%2F011850_cd2b8e352a852ddf1e0942e076a0767b.png&h=e21bb43e&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/01/18/011851_8e2065722c02f57a2e31a859c72b952f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F18%2F011851_8e2065722c02f57a2e31a859c72b952f.png&h=9b9a248a&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/01/18/011852_0ace8ba150b34433818fe49ec954a385.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F01%2F18%2F011852_0ace8ba150b34433818fe49ec954a385.png&h=1436daef&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/01/18/011853_5b6048fd0eb0b2f87b480790c0c41ab1.png\" data-thumbn