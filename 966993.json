K%2BarviWWi1w7%2FDyS2Kz%2BsYtkalU0Y%3D&h=6e9e5af6\" target=\"_blank\">https://www.lcsd.gov.hk/CE/Museum/Space/archive/FAQ/moon/c_faq_moon_7.htm</a></blockquote><br />\n快手打錯<br />\n香港太空館<br />\n<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> 自膠一打"},{"pid":"ddfa0861d169e269e32bc10aa8f05cbbb9680c44","tid":966993,"uid":55924,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-01-03T08:21:47.000Z","msg":"係cctv 1號廠影架炸"},{"pid":"d8f8dc851a258caa0f32ad8a521f47a446963ffc","tid":966993,"uid":19712,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-03T08:22:59.000Z","msg":"點解著陸先影 未登錄前唔影張遠鏡"},{"pid":"3c2c3c2276cfcb415b10fc928ee387daae571af9","tid":966993,"uid":216228,"like":0,"dislike":0,"score":0,"quote":{"pid":"ddfa0861d169e269e32bc10aa8f05cbbb9680c44","tid":966993,"uid":55924,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-01-03T08:21:47.000Z","msg":"係cctv 1號廠影架炸"},"citedBy":0,"replyTime":"2019-01-03T08:33:12.000Z","msg":"我都覺得係嘅機會好大<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"c0e1976425e64b8aa44876e736fad9be0f455bd5","tid":966993,"uid":4780,"like":0,"dislike":0,"score":0,"quote":{"pid":"e956fe6a8ef347e35da8d7ec70bc067e2c667dc2","tid":966993,"uid":5020,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-03T08:20:32.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>唔係話月球背面係極之凹凸不平？因為幫地球擋咗好多子彈。<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <br />\n<br />\n咁光嘅原因應該係架飛船嘅燈射出嚟啫。</blockquote>月球係會自轉架<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> 無論邊一邊都一樣幫地球擋子彈, 關月背咩事</blockquote>連登真係多小學雞<br />\n係呀<br />\n月球係識自轉，但係佢除咗自轉，仲識繞地球公轉，而兩者既時間一樣<br />\n導致月球公轉到去邊都用一個面向住地球<br />\n所以先會話月球有正面(長期向住地球)同背面(長期背住地球)<br />\n<br />\n再唔清楚去google 月球公轉自轉啦</blockquote>怕你小學雞未去到<span style=\"color: red;\">香港太空館</span><br />\ncopy埋<span style=\"color: red;\">香港太空館</span>既解說<br />\n<img src=\"https://www.lcsd.gov.hk/CE/Museum/Space/archive/FAQ/moon/Image/7_1.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.lcsd.gov.hk%2FCE%2FMuseum%2FSpace%2Farchive%2FFAQ%2Fmoon%2FImage%2F7_1.gif&h=674b8c69&s={SIZE}\" /><br />\n<img src=\"https://www.lcsd.gov.hk/CE/Museum/Space/archive/FAQ/moon/Image/7_2.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.lcsd.gov.hk%2FCE%2FMuseum%2FSpace%2Farchive%2FFAQ%2Fmoon%2FImage%2F7_2.gif&h=e9c48b8a&s={SIZE}\" /><br />\nＡ) 月 球 是 否 經 常 以 同 一 面 向 著 地 球 ？<br />\nB) 月 球 有 沒 有 自 轉 ？<br />\n答<br />\nA) 是 ；B) 有 。<br />\n由 於 月 球 看 來 永 遠 以 同 一 面 向 著 地 球 ， 因 此 很 多 人 以 為 月 球 沒 有 自 轉 。 事 實 剛 好 相 反 ， 由 於 月 球 不 斷 環 繞 地 球 公 轉 ， 如 果 月 球 沒 有 自 轉 的 話 ， 我 們 便 有 機 會 看 到 月 面 的 所 有 區 域 。 月 球 既 有 自 轉 及 公 轉 ， 可 是 我 們 卻 只 能 見 到 月 球 的 同 一 面 ， 那 是 由 於 月 球 的 公 轉 周 期 與 它 的 自 轉 周 期 完 全 一 樣 ( 等 於 27.3 日 ) 。<br />\n<a href=\"https://www.lcsd.gov.hk/CE/Museum/Space/archive/FAQ/moon/c_faq_moon_7.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.lcsd.gov.hk%2FCE%2FMuseum%2FSpace%2Farchive%2FFAQ%2Fmoon%2Fc_faq_moon_7.htm&d=qaW8S7LnwtA7LVK%2BarviWWi1w7%2FDyS2Kz%2BsYtkalU0Y%3D&h=6e9e5af6\" target=\"_blank\">https://www.lcsd.gov.hk/CE/Museum/Space/archive/FAQ/moon/c_faq_moon_7.htm</a></blockquote><br />\n快手打錯<br />\n香港太空館<br />\n<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> 自膠一打"},"citedBy":0,"replyTime":"2019-01-03T09:50:51.000Z","msg":"<img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" />"},{"pid":"6163eced50ceec716033bf3284358bb249c23e5a","tid":966993,"uid":18251,"like":0,"dislike":0,"score":0,"quote":{"pid":"28f26cc1ea8454701b152c1a154b277420a4fdf6","tid":966993,"uid":114175,"like":1,"dislike":14,"score":-13,"quote":{"pid":"c5d4d93cebaf5f344d78d3c4dcf1e36082c08c9a","tid":966993,"uid":216228,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-03T08:00:16.000Z","msg":"唔係話月球背面係極之凹凸不平？因為幫地球擋咗好多子彈。<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <br />\n<br />\n咁光嘅原因應該係架飛船嘅燈射出嚟啫。"},"citedBy":2,"replyTime":"2019-01-03T08:02:51.000Z","msg":"月球係會自轉架<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> 無論邊一邊都一樣幫地球擋子彈, 關月背咩事"},"citedBy":0,"replyTime":"2019-01-03T10:08:10.000Z","msg":"<img src=\"/assets/faces/dogxm/haha.gif\" class=\"hkgmoji\" />"},{"pid":"7b1a601b6fe9d857a44da64709bddfe84b81f52f","tid":966993,"uid":128600,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-03T10:09:17.000Z","msg":"Cut!"},{"pid":"905f6d31fa2bf524687561776d712d7b7dd5eb3e","tid":966993,"uid":27616,"like":0,"dislike":0,"score":0,"quote":{"pid":"5a111539cba34e1089ebe5fc0d65e269ef0afefa","tid":966993,"uid":119494,"like":1,"dislike":0,"score":1,"citedBy