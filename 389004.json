gZtp%2B4HOw%3D&h=866bf15d\" target=\"_blank\">https://line.me/R/ti/p/@snp0516q</a><br />\nInstagram : <a href=\"https://www.instagram.com/justin_yu_1/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.instagram.com%2Fjustin_yu_1%2F&d=6hPYI1bzOCvKS%2BKbsFK6bV0Hwm5JNK6yt%2FgZtp%2B4HOw%3D&h=d96013f2\" target=\"_blank\">https://www.instagram.com/justin_yu_1/</a><br />\nTwitter : <a href=\"https://twitter.com/justin_yu_1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Fjustin_yu_1&d=6hPYI1bzOCvKS%2BKbsFK6bV0Hwm5JNK6yt%2FgZtp%2B4HOw%3D&h=1847f752\" target=\"_blank\">https://twitter.com/justin_yu_1</a><br />\n<img src=\"https://i.imag.cx/FR9gM.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FFR9gM.png&h=28783526&s={SIZE}\" /><br />\nDead by daylight呢隻GAME,係一隻4 VS 1既GAME,4個人類一邊維修發電機一邊避開個殺手,維修夠發電機開大門走佬;玩殺手既就係盡量殺D人,唔俾佢地走到佬<br />\n可惜,呢隻GAME,外國好多人玩,偏偏淨係香港冇人玩<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> 好多係身在外國既香港人,都同我講呢隻GAME外國係勁多人玩,普遍香港人個STEAM都設定係香港,所以香港人買左,馬上開GAME,幾乎係肯定冇場,因為香港SER根本冇人,已經真係有玩開GAME既人,都已經轉哂SER去其他國家玩,而依家最多人既SER而又唔會太LAG既地方,係轉去台灣泰國日本韓國呢D地方既SER玩<br />\n<img src=\"https://i.imag.cx/HdDRQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FHdDRQ.jpg&h=300ec0a8&s={SIZE}\" /><br />\n<a href=\"https://youtu.be/TKEUxPYvRfI?list=PLSow1H3Pe09MwgV9rjsjfYx4FiIKrNU4a\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FTKEUxPYvRfI%3Flist%3DPLSow1H3Pe09MwgV9rjsjfYx4FiIKrNU4a&d=6hPYI1bzOCvKS%2BKbsFK6bV0Hwm5JNK6yt%2FgZtp%2B4HOw%3D&h=9a5bea8a\" target=\"_blank\">https://youtu.be/TKEUxPYvRfI?list=PLSow1H3Pe09MwgV9rjsjfYx4FiIKrNU4a</a><br />\n由於係香港開CAM開台而又玩呢隻GAME既人,係得我一個台,所以呢隻GAME官方果邊都俾左呢一件twitch台台主先有既SKIN我<br />\n<img src=\"https://i.imag.cx/hBFf8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FhBFf8.jpg&h=fe9aa4b7&s={SIZE}\" /><br />\n<img src=\"https://i.imag.cx/hBXlI.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FhBXlI.jpg&h=32290e7c&s={SIZE}\" /><br />\n<img src=\"https://i.imag.cx/vHoXA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FvHoXA.jpg&h=1fb87b30&s={SIZE}\" /><br />\n下面呢個係隨便台Official LINE群,有咩突發消息,開台通知,我都會係呢度公布<br />\n<img src=\"http://qr-official.line.me/L/aqio2VXZLo.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fqr-official.line.me%2FL%2Faqio2VXZLo.png&h=03fd5638&s={SIZE}\" /></blockquote>"},{"pid":"cfc0cc1907f388b04ecf1380fb36548880ee2567","tid":389004,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-06T01:17:53.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d29fe08b14d447ee57a0e89267df96542cea8519","tid":389004,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-06T01:41:29.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"2aef82f3c2cf90e1a661be6072a06db4e275a53a","tid":389004,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-06T01:54:36.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"148ca8ff7b18999a0eb5bd86e645be5c7dc58537","tid":389004,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-06T02:07:49.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"26921458da2077b4b484d478ec2df25a7f5b203f","tid":389004,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-06T02:32:59.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"38344da7269f15b4e5a2078c43e84b7d