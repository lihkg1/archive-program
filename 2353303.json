3.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c7fc3acf7450b93201eaabef3e5a3c9d82d3532d","tid":2353303,"uid":52705,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-04T15:37:29.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"c426429fa1ac0e3e4c00352ce2246f539edb570d","tid":2353303,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-04T15:38:18.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"067b7a370237be56e69cc81a7c4d3caa5daa65ff","tid":2353303,"uid":204231,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-04T15:38:21.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"29598b78d28b6a9374f955eeb3086f5878ebfed8","tid":2353303,"uid":267942,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-01-04T15:38:53.000Z","msg":"發現最近有人帶風向不停左割右插企圖分化<br />\n<br />\n<br />\n一開始就係一句<br />\n<br />\n不受傷 不被補 不戀戰 不割蓆 各自爬山 一齊黎 一齊走<br />\n<br />\n<br />\n有野做錯左，做過左，可以收歛，修正，做得唔好，唔夠好可以改善。<br />\n<br />\n逐步前行，逐步學習，團結莫被人分化擊破。<br />\n<br />\n<br />\n同9共做梗嘅係目標分化大家，令我地互割，仇視敵對...咁就又自斷一臂，中正9共下懷。<br />\n<br />\n<br />\n最後都係果句<br />\n<br />\n<br />\n不受傷 不被補 不戀戰 不割蓆 各自爬山 一齊黎 一齊走"},{"pid":"13cbfe2b607cdff6c9fa21e165c8d738c5f59243","tid":2353303,"uid":94771,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-04T15:39:33.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"a29b2d6f16ef7a3f9adeb745e21e4d337e025db2","tid":2353303,"uid":11291,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"