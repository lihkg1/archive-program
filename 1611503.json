plyTime":"2019-10-02T03:43:41.000Z","msg":"尋日之後唔知又多左幾多勇武新兵<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"57947a505dc1dcb3d23a8c4d5b8af48c2f6bde83","tid":1611503,"uid":56260,"like":0,"dislike":0,"score":0,"quote":{"pid":"17acd0dbc5f247bbf8b2594f9f89f25df0b24661","tid":1611503,"uid":187950,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-02T03:43:41.000Z","msg":"尋日之後唔知又多左幾多勇武新兵<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-02T03:46:17.000Z","msg":"尋日前線所見 係多左好多學生<br />\n身邊好多朋友都有老有嫩唔敢出黎/唔再敢留得耐<br />\n但我地既心同前線係連埋一齊<br />\n就算物理位置唔同 我地都要繼續做一切有幫助既事<br />\n義無反顧支持學生 不離不棄！<br />\n<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"2c12eae5e23dc27f7ceb6189d00ea4d236a9d08f","tid":1611503,"uid":56260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T03:47:18.000Z","msg":"推"},{"pid":"a0081cdc561dfe5e771012f5c1cc8b5e9072b64c","tid":1611503,"uid":56260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T03:48:05.000Z","msg":"推"},{"pid":"d5463b03758d1d8c75ee0b2f0d704c58cd70e19c","tid":1611503,"uid":287422,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T03:48:37.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"cdfb7e9090f3a25028468eb0155b40d51e4fded7","tid":1611503,"uid":56260,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T03:49:10.000Z","msg":"推"},{"pid":"79a189b9c8d9be36a0784882bcc2686bdba1c12f","tid":1611503,"uid":265314,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-02T03:51:26.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b9db493e2fe7e615a99de0c94671d9fd9129c1bf","tid":1611503,"uid":56260,"like":0,"dislike":0,"score":0,"