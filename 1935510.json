Fi%2FCiRHhSW.jpg&h=8bc74995&s={SIZE}\" />"},{"pid":"b4b951c07798c8694d7697294a0ff2542bc22ba2","tid":1935510,"uid":183576,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-03-21T00:13:22.000Z","msg":"點撚解又係尚十呢個閪地方<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> 嫌上次拉得唔夠多？"},{"pid":"3099efb42250b2ed12a792d7f2f25847c5cc86de","tid":1935510,"uid":125079,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-21T00:16:01.000Z","msg":"悼念一個人都要比狗逼害"},{"pid":"3cc6b73b555a6058a8bd1feb261ff8f6b74d802f","tid":1935510,"uid":27196,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T00:25:10.000Z","msg":"Push"},{"pid":"2519534f773186856c702fc6075ac7262ca1b4c7","tid":1935510,"uid":171627,"like":0,"dislike":0,"score":0,"quote":{"pid":"b4b951c07798c8694d7697294a0ff2542bc22ba2","tid":1935510,"uid":183576,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-03-21T00:13:22.000Z","msg":"點撚解又係尚十呢個閪地方<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /> 嫌上次拉得唔夠多？"},"citedBy":1,"replyTime":"2020-03-21T00:56:54.000Z","msg":"有冇諗過係因為次次大家都留低唔走<br />\n唔係尚十既問題<br />\n<br />\n人唔識be water轉18區都唔會安全<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<br />\n相反尚十比HKDI安全好多<br />\nDI四面環馬路，狗要包抄仲容易<br />\n四面都隨時可以有便衣狗車突襲手足<br />\n<br />\n保安又森嚴 上個月19號黃昏同朋友去放白花已被趕！<br />\n唔排除校方見22號有悼念會提早報狗<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n但當然，手足自己諗下去邊度就得，悼念都可以在心中<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"f5c2adbe4404a6b17e78465b9c4bd51ddf92a40a","tid":1935510,"uid":39218,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-21T01:03:37.000Z","msg":"有用post冇人理<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"441478ba9b538a0309696d9a304f8e72e71af25b","tid":1935510,"uid":183576,"like":0,"dislike":0,"score":0,"quote":{"pid":"2519534f773186856c702fc6075ac7262ca1b4