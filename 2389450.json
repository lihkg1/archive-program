g/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"e9bcc3ba9a371500b26653b2ed21da6b190d01a7","tid":2389450,"uid":166080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-01T03:11:58.000Z","msg":"Push"},{"pid":"28f490b9f0658f2d125b74bcae2f51ae3ea46bbc","tid":2389450,"uid":239336,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-01T03:31:51.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"1397f4dd3fddc6f21a5b90df4c4f5a91926723bd","tid":2389450,"uid":298796,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-01T03:43:46.000Z","msg":"有D哂氣, 歐洲議會屌到開哂聲, 默婆有無理? 未又係照簽貿易協議"},{"pid":"df5bbb3ac2c85eee3a8395523fc7282a5a8ace88","tid":2389450,"uid":239336,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-01T04:23:47.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"7c95993b4d1281b8e1a3b82b4bb1d79aa5cb608a","tid":2389450,"uid":220252,"like":0,"dislike":0,"score":0,"quote":{"pid":"2588b0e0ee6f6420f37a63fcd284cbf32293b3fd","tid":2389450,"uid":239336,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-01T02:17:44.000Z","msg":"德國國會於1月25日剛舉行聽證會，討論是否制裁在香港進行違反人權行為的中港官員。從收集足夠簽名，到因疫情而懸而未決，最終在網上直播的情況下，這次由港人鄺頌晴及德國青年穆達偉（David Missal）發起的聽證會成功舉行。然而，中歐已簽訂投資協定，即使歐洲議會呼籲歐盟制裁中港官員，歐盟各國會否對中國或相關人士作出具阻嚇性的行動，仍屬未知之數。鄺頌晴希望今次聽證會是一個開始，又指有德國政黨的代表對華態度已出現轉變，而穆達偉則發起眾籌支付學術機構收取的手續費，以調查中國捐款對學術界的影響。<br />\n<br />\n「我希望這聽證會只是開始。」鄺頌晴25日在聽證會場地外接受訪問時說。在聽證會前後一直接受德國傳媒的訪問，完成聽證會又馬不停蹄，與出版德語專書講述反送中運動的德國學者Alexander G&ouml;rlach對話。隔天再接受訪問時，她手機仍響個不停，遊說推廣的工作，未因聽證會完結而停止。「聽證會才完結了一天，現在還未能說到與德國國會或政府有甚麼正式的後續。」但她認為，聽證會反映出某些正面的轉變，例如德國左黨（Die Linke）代表的態度，就有明顯改變。<br />\n<br />\n德國有比較健全的民主政制，不同的黨派對香港、中國的態度也有不同。據鄺的分析，綠黨（Die Gr&uuml;nen）一直對人權及社會議題十分重視，支持香港的民主運動，也希望阻止德國政府簽訂中歐投資協定。自由民主黨（FDP）則是自由派，成員Gyde Jenson是德國國會人權委員會的主席，非常支持香港，而他們的黨魁Christian Lindner，也曾被香港拒絕入境。整體來說，這政黨比較面向商界，除了上述兩位，其他成員也會就香港及台灣議題發聲，但就會比較考慮商界的利益。<br />\n<span class=\"red\"><span class=\"x-large\">左黨因為信奉左派思想，曾經比較親中，但近來立場開始改變。「左黨我個人只認識Stefan Liebich，我只能評論他的立場。我記得前年他曾寫過文章，指香港因為被殖民與八國聯軍的歷史，其他國家不應該評論太多。當時我也寫了文章還擊。之後在活動中碰面，他也會說德國應該與中國做好朋友。但到了現在，他的立場已經慢慢轉變，說他們應該對中國強硬一點，要做多一點，真的幫助香港人。」</span></span><br />\n<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://hk.appledaily.com/international/20210201/AV7KOXGGYBDJ3GI5K6HJILTOC4/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Finternational%2F20210201%2FAV7KOXGGYBDJ3GI5K6HJILTOC4%2F&d=NiOc6rc%2FE9fikVhzT7%2F1G%2FQJlsOaju8aQhUrU01WOmc%3D&h=65b77e2f\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Finternational%2F20210201%2FAV7KOXGGYBDJ3GI5K6HJILTOC4%2F&h=c2529c41\" data-auto-link target=\"_blank\">https://hk.appledaily.com/international/20210201/AV7KOXGGYBDJ3GI5K6HJILTOC4/</a>"},"citedBy":0,"replyTime":"2021-02-01T04:33:38.000Z","msg":"推"},{"pid":"29565b21db5ffdb0a1d61f33548f7d36048bc908","tid":2389450,"uid":239336,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-01T06:45:40.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"dd39d535a77a000e21e8042a49f538be086f0406","tid":2389450,"uid":239336,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-01T07:19:16.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"}]}