e4136a35b0e58e61c15af9ba1","tid":1273223,"uid":132848,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:20:45.000Z","msg":"push"},{"pid":"9595c2718410f894355fb9e8827d95494f16722a","tid":1273223,"uid":124372,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:20:59.000Z","msg":"林鄭同班冷血警犬<br />\n天佑港人"},{"pid":"e955c2deea6a705afeaeff5ae221fe57b752b523","tid":1273223,"uid":117744,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:21:12.000Z","msg":"推"},{"pid":"06e6dba8db8cb888316129cf89167df565c5c5f0","tid":1273223,"uid":269696,"like":1,"dislike":0,"score":1,"quote":{"pid":"80ccc823ce1abfe60a6f7de79d0a9b471be26f6e","tid":1273223,"uid":232237,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f51931e3625e14e9f591f0aa2e7d2ccbc96c497","tid":1273223,"uid":218848,"like":0,"dislike":0,"score":0,"quote":{"pid":"fc5cfda5a6f7f7d94464ef0ab3e9322e437d634b","tid":1273223,"uid":36157,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-01T13:58:37.000Z","msg":"可接受<br />\n<br />\n<strong>盡快PRESS CON</strong>"},"citedBy":1,"replyTime":"2019-07-01T13:59:05.000Z","msg":"push"},"citedBy":1,"replyTime":"2019-07-01T14:02:50.000Z","msg":"push"},"citedBy":0,"replyTime":"2019-07-01T14:21:45.000Z","msg":"各位親愛的香港市民：<br />\n我們是一群來自民間的示威者，與你們一樣抱有守護香港的感情。從6月9日、6月12日到今天，我們手無寸鐵，只剩赤子之心內的一腔熱忱，進佔香港特別行政區立法會大樓。現場沒暴戾的青年，只有政權的暴力；沒有心存不軌的暴徒，只有謹守良知的青年；沒有陰謀論與騎劫，只有為公義與香港而戰的香港人。我們與你們一樣，對香港這片土地，有無窮無盡的愛。<br />\n1997年前的香港成為英屬殖民地，1997年後的香港移交予中華人民共和國成為特區。這22年來，香港的政經民生每況愈下，香港人的苦痛經歷，有添無減。現任特首林鄭月娥上任至今，只有更強硬無理的施政，賣港賣民，無日無之。現任政府先是虧空庫房建明日大嶼、再以修訂《移交條例》為由，斷送香港一國兩制底下的僅存的法治精神。連日下來百萬民意，三人殉道，政府竟然置若罔聞，繼續與民為敵。<br />\n現任特區政府已為中央走狗，再不以港人願想為優先。立法會作為立法機關，竟淪為橡皮圖章。我們在街頭，為了逼使政府回應香港人對公義的訴求，不得已佔領立法會，希望香港政府能回到正軌。<br />\n我等街頭的無名抗爭者，不求保存一已之身，只求政府回應五大訴求：<br />\n一、徹底撤回修例<br />\n二、收回暴動定義<br />\n三、撤銷對今為所有反送中抗爭者控罪<br />\n四、徹底追究警隊濫權情況<br />\n五、以行政命令解散立法會，立即實行雙真普選<br />\n「反送中運動」發展至今，我們願意以微弱肉身相諫，希望社會大眾團結一致，為自由、為公義，反對惡法，對抗暴政，守護香港。<br />\n<br />\n一群無名的抗爭者 謹啟<br />\n咁改得唔得？draft，隨便改"},{"pid":"e3473bc4a93968791b32c055ab2018eb71537b47","tid":1273223,"uid":15730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:22:16.000Z","msg":"推"},{"pid":"245d0edaf273c3ba4620603b5a92831fce5abf1e","tid":1273223,"uid":223378,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-07-01T14:22:19.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"2effc728475121b05bc542b7b4b056450ca6dd83","tid":1273223,"uid":209294,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:22:20.000Z","msg":"推啊！"},{"pid":"35865365466e149217fa292e7d137edd14aca5de","tid":1273223,"uid":43350,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:22:25.000Z","msg":"Push"},{"pid":"3458035c8b06f6e67bd027405363278205c5833d","tid":1273223,"uid":8891,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:22:52.000Z","msg":"Push"},{"pid":"4c459cb1d03968174ec5d7482aebb6ff2e7c4021","tid":1273223,"uid":73930,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:23:42.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"3fab7caa58719fa9a85ffebde18636dfec6d47b4","tid":1273223,"uid":75782,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:23:43.000Z","msg":"推"},{"pid":"a47e8a4c51033da9583afb4017de8acb0a77e691","tid":1273223,"uid":152464,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:24:17.000Z","msg":"PUSH"},{"pid":"cf1f5c47001de922b262de4c4f5fd4422348a896","tid":1273223,"uid":19557,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:24:18.000Z","msg":"推"},{"pid":"086e1b552fe5a3dc46cd63d46123b1820aa9551b","tid":1273223,"uid":23271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:24:20.000Z","msg":"push"},{"pid":"207aa46ba8bec082addc1e534dc2a8a1998124b4","tid":1273223,"uid":216280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:24:42.000Z","msg":"Push"},{"pid":"7a06253d2423679a57b6c5dc1315396fae74ff79","tid":1273223,"uid":117744,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:24:52.000Z","msg":"推"},{"pid":"9751a390f83001feeb8f3996bff40c55debf1552","tid":1273223,"uid":152387,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:24:52.000Z","msg":"你想係一個莊嚴嘅地方做金鐘宣言<br />\n定係一個背景全部都係粗口兼凌亂嘅地方做金鐘宣言"},{"pid":"71bb6d8a31c58c6bc554256563e988bc75514d22","tid":1273223,"uid":223378,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-07-01T14:25:12.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"ff3867ae8629a49defb23b3c62a6f72a9d788a44","tid":1273223,"uid":124372,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:25:28.000Z","msg":"煲底的人全部去立法會<br />\n全部人去立法會<br />\n人多聚眾<br />\n唔係佢地會分好惨架<br />\n林鄭在笑"},{"pid":"1ee5938a7e3b7ab3640a7e79aa3007243a775f9d","tid":1273223,"uid":267337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:25:48.000Z","msg":"推"},{"pid":"c486129db3abee0886b35d7f1ce8ce2a1a612de9","tid":1273223,"uid":31296,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:26:29.000Z","msg":"推"},{"pid":"c81df1948f96990cee25d9c424b9f553f8e40305","tid":1273223,"uid":223378,"like":0,"dislike":0,"score":0,"quote":{"pid":"71bb6d8a31c58c6bc554256563e988bc75514d22","tid":1273223,"uid":223378,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-07-01T14:25:12.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-01T14:26:36.000Z","msg":"推"},{"pid":"a78f3acaddb46a6f6fa08434c3f7669610f585cb","tid":1273223,"uid":181035,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:27:48.000Z","msg":"推"},{"pid":"14e891478bf0b04f8d1589fc4d6be40cbc979373","tid":1273223,"uid":265653,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:29:34.000Z","msg":"推"},{"pid":"8507eae5c38ac4b0f1ebe00f639de695602e9031","tid":1273223,"uid":250036,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:29:48.000Z","msg":"推"},{"pid":"35f7366b3c0d2e7c61762cf802f55c963bb1c755","tid":1273223,"uid":17379,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:29:58.000Z","msg":"讀宣言 讀完走 唔想見到義士流血/被捕"},{"pid":"47d8216e8418a9f60a25dccd38368a45a02f6044","tid":1273223,"uid":269982,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:29:58.000Z","msg":"推"},{"pid":"19245d64e956a00e6152019813533fa553494292","tid":1273223,"uid":89184,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:30:53.000Z","msg":"警察話清場<br />\n無論守唔守到<br />\n走之前都要向國際社會作出宣言先"},{"pid":"279ca1f03104cfb697c07e6bd76effeef471edc9","tid":1273223,"uid":35271,"like":0,"dislike":0,"score":0,"quote":{"pid":"71bb6d8a31c58c6bc554256563e988bc75514d22","tid":1273223,"uid":223378,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2019-07-01T14:25:12.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-01T14:31:00.000Z","msg":"推"},{"pid":"ecd6ae9c67273fbb7cd247c7ebc05e04529c1d42","tid":1273223,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:31:25.000Z","msg":"推"},{"pid":"01afbc61c1f77d15f80486a6340a1af2cad69868","tid":1273223,"uid":182047,"like":5,"dislike":1,"score":4,"citedBy":0,"replyTime":"2019-07-01T14:31:54.000Z","msg":"小弟寫嘅佔領立法會宣言，如覺寫得好可叫前線讀：<br />\n<br />\n逃犯條例風波，令香港人震怒。二百萬人上街反對，人數之多，全球各國未曾見，人類史上未曾見。<br />\n<br />\n六月以來，港人多日抗爭，用盡和平手段，流血流汗。惟始作俑者，特首林鄭月娥，紋風不動，鐵石心腸。冷血政權對民意視若無睹，三位年輕人先後以死相諫，令人痛心！<br />\n<br />\n我等香港人，為我城未來而焦急，為下一代性命安危而焦急！我等絕不容許再多一條生命犧牲。我等今集結於立法會中，重申五大訴求：<br />\n<br />\n1.完全撤回逃犯修例<br />\n2.追究警方開槍責任<br />\n3.不檢控及釋放示威者<br />\n4.撤銷定性6月12日集會為暴動<br />\n5.林鄭月娥問責下台<br />\n<br />\n我等現要求林鄭月娥本人親自到場回應。否則我等將持續佔領立法會，甚至廢除現有立法會，另組新議會，以全面反映民意。<br />\n<br />\n不撤、不散！"},{"pid":"b6c6e42d1e7331cbe99ff3db6bf02fd876c5eb89","tid":1273223,"uid":206021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:35:36.000Z","msg":"Push"},{"pid":"26acd156f3bdd861269a56f9201cd7d2e820d3a0","tid":1273223,"uid":206021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:35:50.000Z","msg":"Push"},{"pid":"77f4a609b42630f7fb76b15f5fb5a23979c0f0e2","tid":1273223,"uid":206021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:36:03.000Z","msg":"Push"},{"pid":"1b5aee2598201470e55f7090e7b65aeebfd864de","tid":1273223,"uid":110018,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:36:58.000Z","msg":"推"},{"pid":"d91e291009aab5e437056644d39a6d971203b20e","tid":1273223,"uid":36742,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:37:02.000Z","msg":"屌 快呀"},{"pid":"356fdea4887ff974ea07ff2badb366b5b13eb57b","tid":1273223,"uid":89184,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:37:05.000Z","msg":"push"},{"pid":"99fb04c89e36c68602d552f135ae730856338a6e","tid":1273223,"uid":252854,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:37:22.000Z","msg":"推！！！"},{"pid":"286cb32c607e5dce734498916ce45bb73b902ae2","tid":1273223,"uid":105114,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:37:24.000Z","msg":"推"},{"pid":"df1d11b286f36add43c7b4076e49249b3cc6a95e","tid":1273223,"uid":144237,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:37:40.000Z","msg":"快"},{"pid":"b89c54da8afbc8cd883cbd51037d8f83adec787d","tid":1273223,"uid":56567,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:37:52.000Z","msg":"推"},{"pid":"7cac651b375a4752dfaa4765f8fe03dae7c11f0b","tid":1273223,"uid":202912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:38:59.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"06150a91cbe9fbbb312cee272ecb9e925f15cff1","tid":1273223,"uid":267337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-01T14:39:39.000Z","msg":"推"},{"pid"