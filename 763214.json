:0,"replyTime":"2018-08-01T04:07:40.000Z","msg":"投降都係贏<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"dc9b09a8ee4b08df5368940ee02f292e6d5e434b","tid":763214,"uid":22876,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-01T04:08:36.000Z","msg":"屎味"},{"pid":"2454154620dba18387f728bec1d967cb9490caaf","tid":763214,"uid":7369,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-01T04:09:13.000Z","msg":"成篇文兩個字寫完啦 &quot;鳩縮&quot;嘛, 屌你老母!"},{"pid":"25a8428a089b82e819fa001015067161b95a381f","tid":763214,"uid":123264,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-01T04:10:24.000Z","msg":"有人要投降了"},{"pid":"461cabaf9295c5b03aea31bf300ae9dd0b6c4d11","tid":763214,"uid":152589,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-01T04:12:06.000Z","msg":"我哋應該幫手 挑釁美國<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"7fc55ff1d7847fff89f3556d77e2d6d412e2720c","tid":763214,"uid":41245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-01T04:14:39.000Z","msg":"亮劍啦！"}]}