都是知名地產物業公司，中原地產代理獲批 1.15 億元資助額，承諾（保留）受薪僱員 5,612 人。且其他中原集團相關科技，包括中原數據科技、中原測量行、中原移民顧問均獲批超過 100 萬元，他們分別獲批金額，139.9 萬元、111.6 萬元和 61 萬元，承諾受薪僱員分別是 65 人、51 人和 24 人。另外，同屬地產的利嘉閣地產獲批 4,728 萬元資助額，承諾受薪僱員 2,105 人。<br />\n<a href=\"https://sme.hket.com/article/2687778/%E3%80%90%E4%BF%9D%E5%B0%B1%E6%A5%AD%E8%A8%88%E5%8A%83%E3%80%91%E4%B8%AD%E5%8E%9F%E5%9C%B0%E7%94%A2%E3%83%BBTVB%E7%8D%B2%E6%89%B9%E8%B3%87%E5%8A%A9%E6%9C%80%E5%A4%9A%E3%80%801%E4%BA%BA%E6%89%BF%E8%AB%BE%E5%8F%97%E8%96%AA%E5%83%B1%E5%93%A1%E5%85%AC%E5%8F%B8%E7%8D%B22%E8%90%AC%E5%A4%9A%E5%85%83%E8%A3%9C%E8%B2%BC\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fsme.hket.com%2Farticle%2F2687778%2F%25E3%2580%2590%25E4%25BF%259D%25E5%25B0%25B1%25E6%25A5%25AD%25E8%25A8%2588%25E5%258A%2583%25E3%2580%2591%25E4%25B8%25AD%25E5%258E%259F%25E5%259C%25B0%25E7%2594%25A2%25E3%2583%25BBTVB%25E7%258D%25B2%25E6%2589%25B9%25E8%25B3%2587%25E5%258A%25A9%25E6%259C%2580%25E5%25A4%259A%25E3%2580%25801%25E4%25BA%25BA%25E6%2589%25BF%25E8%25AB%25BE%25E5%258F%2597%25E8%2596%25AA%25E5%2583%25B1%25E5%2593%25A1%25E5%2585%25AC%25E5%258F%25B8%25E7%258D%25B22%25E8%2590%25AC%25E5%25A4%259A%25E5%2585%2583%25E8%25A3%259C%25E8%25B2%25BC&d=2u41qa%2Bce9Gslgrzp%2F5KikzKa5je2Ql9GrxhcbxOrro%3D&h=da63cab9\" data-auto-link target=\"_blank\">https://sme.hket.com/article/2687778/%E3%80%90%E4%BF%9D%E5%B0%B1%E6%A5%AD%E8%A8%88%E5%8A%83%E3%80%91%E4%B8%AD%E5%8E%9F%E5%9C%B0%E7%94%A2%E3%83%BBTVB%E7%8D%B2%E6%89%B9%E8%B3%87%E5%8A%A9%E6%9C%80%E5%A4%9A%E3%80%801%E4%BA%BA%E6%89%BF%E8%AB%BE%E5%8F%97%E8%96%AA%E5%83%B1%E5%93%A1%E5%85%AC%E5%8F%B8%E7%8D%B22%E8%90%AC%E5%A4%9A%E5%85%83%E8%A3%9C%E8%B2%BC</a>"},{"pid":"c439f0f44fc3214ddd03896ee32f6b4e44690171","tid":2262974,"uid":3204,"like":0,"dislike":0,"score":0,"quote":{"pid":"4f510bb61a451333df4813a5b3761dbbe271c42c","tid":2262974,"uid":51271,"like":1,"dislike":0,"score":1,"quote":{"pid":"d5e52b02044d97657c2854cc1ff3cfd3b9d2da6c","tid":2262974,"uid":149494,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2020-10-2