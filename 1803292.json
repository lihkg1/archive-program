fe9c21ee1be3","tid":1803292,"uid":241026,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-12-30T07:18:49.000Z","msg":"咁都想燈<img src=\"/assets/faces/xm/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/xm/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"4e867ff7bcdf8a06895e9b815aaef07bb9e1030d","tid":1803292,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-30T07:36:09.000Z","msg":"贏歐聯 棄聯賽咪得"},{"pid":"fb0f889ac62a30d26db865a0e08a513dc61fee5b","tid":1803292,"uid":103207,"like":0,"dislike":0,"score":0,"quote":{"pid":"4e867ff7bcdf8a06895e9b815aaef07bb9e1030d","tid":1803292,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-30T07:36:09.000Z","msg":"贏歐聯 棄聯賽咪得"},"citedBy":0,"replyTime":"2019-12-30T07:39:02.000Z","msg":"哥狗話如果咁快放棄聯賽,會士氣潰散,最後兩頭空,所以唔會放棄"},{"pid":"f7ab40d8af07d5721fc3da946350ad9969baabf9","tid":1803292,"uid":278409,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-30T07:42:39.000Z","msg":"此回覆已被刪除"},{"pid":"0d7503afbc9ca52d7fe588efc53882b9f7e8ba2e","tid":1803292,"uid":31626,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-30T08:23:13.000Z","msg":"<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"},{"pid":"523611545c8ddc0525ecf5367ed29007585e13a6","tid":1803292,"uid":19552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-30T09:30:35.000Z","msg":"阿古路：曼城很難追趕利物浦<br />\n曼城早前2：3不敵狼隊，之後今輪2：0小勝錫菲聯，兩場比賽過後仍然和利物浦相差極遠，特別是紅軍繼續在聯賽不敗，令到兩隊分差越來越大。<br />\n<br />\n阿古路說起英超爭標情況時說：「利物浦實在太難追趕了，曼城只能夠集中做好自己工作，爭取保住歐聯資格，然後再看看會發生甚麼事情吧。」"}]}