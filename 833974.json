4491c19ff2673ccda8373450c6b8e154a5359b2","tid":833974,"uid":6329,"like":152,"dislike":1,"score":151,"citedBy":2,"replyTime":"2018-09-24T04:16:05.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2018/09/24/121601_110f5cf937ded9168222f72a03ea741d.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F09%2F24%2F121601_110f5cf937ded9168222f72a03ea741d.png&h=8aa08cc9&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-09-24T04:55:30.000Z","msg":"<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"8238c461b9b4373fffcad2e6ecd2616e65ccedde","tid":833974,"uid":23180,"like":8,"dislike":0,"score":8,"citedBy":0,"replyTime":"2018-09-24T05:00:29.000Z","msg":"民智低就民智低<br />\n<br />\n啱啱你個皇帝先想拉契哥埋堆<br />\n<br />\n你仲走去搞事"},{"pid":"ad3851333096e1b3b9c5f63fd6daf7aeca62f3eb","tid":833974,"uid":52595,"like":17,"dislike":0,"score":17,"citedBy":2,"replyTime":"2018-09-24T05:06:25.000Z","msg":"此回覆已被刪除"},{"pid":"c93af5a0b2de8d3d24d5ee66a02182e837c1ce66","tid":833974,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-24T05:21:02.000Z","msg":"<img src=\"/assets/faces/mf/donno.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/donno.gif\" class=\"hkgmoji\" />"},{"pid":"17888022769819fea55b4264e82487a2aa8df7ca","tid":833974,"uid":13303,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-24T09:13:11.000Z","msg":"<img src=\"/assets/faces/mf/clown.gif\" class=\"hkgmoji\" /> 收利是係中國文化呀厲害了"},{"pid":"48dfc05e78728536f8d215d28e1ea002be2a3f1c","tid":833974,"uid":28309,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-24T09:18:38.000Z","msg":"唔是西方邪惡集團<img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"d2d06c9cc81028f57556510b0110e7a240f9fc66","tid":833974,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-24T10:31:22.000Z","msg":"<img src=\"/assets/faces/mf/kiss.png\" class=