{"tid":2080033,"cid":5,"subCid":10,"title":"12新工會到G20領事館請願促施壓中方 實名聯署示真香港人意願","createTime":"2020-06-26T07:14:28.000Z","updateTime":"2020-06-26T07:18:34.000Z","uid":240362,"like":9,"dislike":0,"uniUserReply":3,"replies":[{"pid":"856f891f2a0cb24db7e26f4d46af3472cc6bd824","tid":2080033,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-26T07:14:28.000Z","msg":"<a href=\"https://hk.appledaily.com/local/20200626/5VAFNAHWB6ZFWVJ3OHPJUEP5E4/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200626%2F5VAFNAHWB6ZFWVJ3OHPJUEP5E4%2F&d=jQldmXM9xAXOA%2BwUl6G2h6GvShGfzVnrv2JJWMS0YvQ%3D&h=2e01565d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20200626%2F5VAFNAHWB6ZFWVJ3OHPJUEP5E4%2F&h=e9bf4e49\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20200626/5VAFNAHWB6ZFWVJ3OHPJUEP5E4/</a><br />\n<br />\n「港版國安法」實施在即，12個新工會今日兵分三路，以「馬拉松式」接力到20國集團（G20）領事館，遞交「全民反國安，還我真香港」實名聯署簽名及請願信。香港調酒師工會主席侯翠珊聯同其他工會代表，今早10時於德國領事館外向代表遞交聯署文件及請願信，以示「真香港人」反對《國安法》立法的意願，促請外國繼續關注事件並支持香港人。"},{"pid":"8b3214612e1f243653c2c4dd088f8e375078e642","tid":2080033,"uid":51271,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-26T07:15:17.000Z","msg":"支持工會手足"},{"pid":"df33f33f88ffe29a82bee5b7e62760e7c1590b8f","tid":2080033,"uid":253016,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-26T07:18:34.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}