b81e527f00d3a","tid":1886151,"uid":234357,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-18T18:35:08.000Z","msg":"721"},{"pid":"71b241f1ccf4099d2a72f6a647520700e9a5bcf5","tid":1886151,"uid":146535,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-18T18:36:51.000Z","msg":"我覺得中共嘅定位係咁<br />\n佢知好多民意點都唔會逆轉，但佢仍然試圖扭返一部份所謂淺黃/淺藍/中立，乜都好總之納得就納<br />\n<br />\n咁好多人話，民意點都唔會逆轉架啦，晒氣嘅<br />\n咁中共想要嘅咪民意基礎囉，唔好唔記得有班人，區選嗰日收個枕頭就投左共，所以佢先叫得到一個4 成嘅偽民意，點都好呢個係佢嘅民意基礎，總之就係有一班人唔理咩原因都要投共<br />\n<br />\n喺呢個假設底下，其實可以納得就納，因為今次都可能收到一批本來投左共嘅人，唔好話咩冇可能，因為始終有啲人會改變嘅"},{"pid":"0ced9d42f752e785e1ce4b38aab43fa270cafdca","tid":1886151,"uid":116615,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-18T18:37:37.000Z","msg":"push"},{"pid":"8d6dce7d540b200036553985651c3d9d2daa70fe","tid":1886151,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T18:38:11.000Z","msg":"統戰就係搞分化"},{"pid":"2c758633563096209d0f91b836fc78c882f44245","tid":1886151,"uid":13176,"like":0,"dislike":0,"score":0,"quote":{"pid":"9b856113d41809d393f34ed334c52f4d2b83115f","tid":1886151,"uid":57588,"like":0,"dislike":0,"score":0,"quote":{"pid":"25c848c14669aed9f850198437d8a68810712916","tid":1886151,"uid":13176,"like":10,"dislike":0,"score":10,"citedBy":1,"replyTime":"2020-02-18T18:11:50.000Z","msg":"證明連登仔上星期成功拆穿咗中共KOL 100既計劃，而且不斷report YouTube channel係有用<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> 所以對家又用返佢地最擅長既招數，派大量五毛開post轉移大家視線，務求我地內亂內鬥又變咗捉鬼咁<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<br />\n而家最需要既係聚焦返最鮮明既敵人，嗰班中共KOL！<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />佢地拍片抹黑醫護罷工，係有集團式有戰略目的，唔係單純無腦藍絲廢up幾句咁簡單。<br />\n<br />\n大家一定要沉著應戰，認清你既最大敵人係中共<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n「資訊戰」有個痴線佬準備好曬中宣部旗下youtuber既report link<br />\n<a href=\"https://lih.kg/1883056\" data-auto-link target=\"_blank\">https://lih.kg/1883056</a><br />\n- 分享自 LIHKG 討論區"},"citedBy":1,"replyTime":"2020-02-18T18:15:43.000Z","msg":"<span style=\"color: red;\">而家最需要既係聚焦返最鮮明既敵人</span><br />\n無錯，但拆穿還拆穿，千祈唔係低估佢地<br />\n大家幾年前都無諗FB YOUTUBE咁多殘體廢老"},"citedBy":0,"replyTime":"2020-02-18T18:42:47.000Z","msg":"係，真係唔好輕敵。其實KOL 100根本同中共d微博/電視新聞洗腦工具一樣，不過嚟到香港為咗令人易入口，換咗模式搵班人用YouTube拍片咁解。<br />\n<br />\n當中共都識拍片控制輿論帶風向，我地都要進步識認清敵人手段反擊<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" />  唔好再內鬥消耗己方勢力，聚焦返敵人&mdash;中共！<br />\n<br />\n<br />\n攻擊攻擊！<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n「資訊戰」有個痴線佬準備好曬中宣部旗下youtuber既report link<br />\n<a href=\"https://lih.kg/1883056\" data-auto-link target=\"_blank\">https://lih.kg/1883056</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"19ad08f084b7df786eaad559842bca79ce9d344b","tid":1886151,"uid":88743,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-02-18T18:43:39.000Z","msg":"呢大半年已經經歷過無數次同類事件<br />\n我覺得真係好煩厭<br />\n<br />\n<img src=\"https://na.cx/i/jLd2zJ8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjLd2zJ8.jpg&h=8bceb890&s={SIZE}\" />"},{"pid":"968c834efebaab447fe9e80a44ea9c531311f61f","tid":1886151,"uid":57588,"like":0,"dislike":0,"score":0,"quote":{"pid":"19ad08f084b7df786eaad559842bca79ce9d344b","tid":1886151,"uid":88743,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-02-18T18:43:39.000Z","msg":"呢大半年已經經歷過無數次同類事件<br />\n我覺得真係好煩厭<br />\n<br />\n<img src=\"https://na.cx/i/jLd2zJ8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjLd2zJ8.jpg&h=8bceb890&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-02-18T18:47:32.000Z","msg":"一齊努力<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" />"},{"pid":"a1f4e98012d02548aee534b97bcc5eba702cadb1","tid":1886151,"uid":83052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-18T19:02:01.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"bad57618eb1e8815ab690acd5fe514a31089b931","tid":1886151,"uid":273294,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-18T19:04:09.000Z","msg":"好文"},{"pid":"de337ab026ee26ec0e00583e899b2d7ed46c1af1","tid":1886151,"uid":123308,"like":1,"dislike":0,"score":1,"quote":{"pid":"8d6dce7d540b200036553985651c3d9d2daa70fe","tid":1886151,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T18:38:11.000Z","msg":"統戰就係搞分化"},"citedBy":1,"replyTime":"2020-02-18T19:07:17.000Z","msg":"<img src=\"https://na.cx/i/DGhB0Mm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDGhB0Mm.jpg&h=61ef321b&s={SIZE}\" /><br />\n<br />\n【 志祺七七 】中共如何使用「統戰」，讓原本漢賊不兩立的國民黨不得不親中？《生難字彙大辭海》EP 017<br />\n<a href=\"https://www.youtube.com/watch?v=R336KUICMFc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DR336KUICMFc&d=WZLdF6k3LRQ%2Bb7h5E4OoDoeNTHq1rgEicHo%2BkVhR8rs%3D&h=d98d1ad8\" data-auto-link target=\"_blank\">https://www.youtube.com/watch?v=R336KUICMFc</a><br />\n<br />\n統戰 = 統一戰綫 &ne; 統一戰爭<br />\n<br />\n鎖定戰場，避免一次開太多支綫，分身乏術<br />\n<br />\n設定主要敵人，聯合其他勢力<br />\n<br />\n一邊聯合，一邊鬥爭<br />\n<br />\n一邊聯合，一邊分化 =&gt;<br />\n剷除異己 =&gt;<br />\n鞏固領導權<br />\n<br />\n聯合次要敵人，打擊主要敵人"},{"pid":"a6a5b8204cc5bfdf8f02a98213e7d6a5579dce1d","tid":1886151,"uid":57588,"like":1,"dislike":0,"score":1,"quote":{"pid":"de337ab026ee26ec0e00583e899b2d7ed46c1af1","tid":1886151,"uid":123308,"like":1,"dislike":0,"score":1,"quote":{"pid":"8d6dce7d540b200036553985651c3d9d2daa70fe","tid":1886151,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-18T18:38:11.000Z","msg":"統戰就係搞分化"},"citedBy":1,"replyTime":"2020-02-18T19:07:17.000Z","msg":"<img src=\"https://na.cx/i/DGhB0Mm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDGhB0Mm.jpg&h=61ef321b&s={SIZE}\" /><br />\n<br />\n【 志祺七七 】中共如何使用「統戰」，讓原本漢賊不兩立的國民黨不得不親中？《生難字彙大辭海》EP 017<br />\n<a href=\"https://www.youtube.com/watch?v=R336KUICMFc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DR336KUICMFc&d=WZL