xda.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FLyc4xda.jpg&h=3cbc97ef&s={SIZE}\" /><img src=\"https://na.cx/i/WkJn3jT.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FWkJn3jT.jpg&h=bd519dea&s={SIZE}\" /><img src=\"https://na.cx/i/YepniTf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FYepniTf.jpg&h=fd1f437e&s={SIZE}\" /><img src=\"https://na.cx/i/JaAYBEW.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJaAYBEW.jpg&h=ecc9e95d&s={SIZE}\" /><br />\n然後每次老闆娘臨返屋企前會叫同事煮一煲新嘅、冇比老鼠咬過嘅珍珠，for佢帶返屋企比佢啲仔女飲。<br />\n<br />\n由老鼠事件開始，我就默默留意舖頭嘅用料、食材。<br />\n唔睇仲好一睇就出事！除咗每日要嘅珍珠、芋圓，差唔多全部都過期！！！！！<br />\n最嚴重更加係過期足足兩年，有同事好心同老闆娘講，佢竟然以生產商印錯日期為由，話材料冇過期，甚至要求同事試食。<br />\n所以我開始默默影低佢嘅過期嘢！<br />\n（今日收到風有25仔爆咗比老闆娘聽，而佢dum咗部分冇得met走最佳食用日期嘅食材，但同時保留部分可以met走最佳食用日期嘅食材照用）<img src=\"https://na.cx/i/QpS4xdo.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FQpS4xdo.jpg&h=6bc2f506&s={SIZE}\" /><img src=\"https://na.cx/i/d85d9Z4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fd85d9Z4.jpg&h=832f119b&s={SIZE}\" /><img src=\"https://na.cx/i/hq6dqyr.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fhq6dqyr.jpg&h=3dbffb5d&s={SIZE}\" /><img src=\"https://na.cx/i/7GgH3j6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7GgH3j6.jpg&h=6231d889&s={SIZE}\" /><img src=\"https://na.cx/i/HiT7uZ8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHiT7uZ8.jpg&h=31207fb9&s={SIZE}\" /><img src=\"https://na.cx/i/AzbH3kd.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAzbH3kd.png&h=d58f32dd&s={SIZE}\" /><img src=\"https://na.cx/i/hiofDTz.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhiofDTz.jpg&h=0484608b&s={SIZE}\" /><img src=\"https://na.cx/i/18szUrV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F18szUrV.jpg&h=63652a35&s={SIZE}\" /><br />\n<br />\n十月份開始係茶樂返工，一開始上網睇過話係黃店，仲係油麻地貼出炒咗個藍屍嘅公告出嚟。<br />\n結果返工開始就知道，老細同老闆娘都係大陸人，係大陸開連鎖藥店(老闆娘自爆+google過老細個名)，但就偽黃食兩家茶飯。<br />\n佢哋一開始有4間分店，依家執到得返兩間，行過路過記得唔好幫襯，話埋比身邊朋友同屋企人知！<img src=\"https://na.cx/i/jqXzUsr.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjqXzUsr.png&h=4f374e01&s={SIZE}\" />"},"citedBy":0,"replyTime":"2021-04-19T14:01:00.000Z","msg":"<img src=\"https://ipfs.infura.io/ipfs/QmUCKJ6LNo3pV9c7g2qG5dUEnqt8VFmhhu1YbqqU1Ka8EE?filename=PoFd93d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FPoFd93d.jpg&h=b39e7c20&s={SIZE}\" /><br />\n漏咗張"},{"pid":"0fbc474fa7d6c25cc9c8c4f41bf18c60b30783e2","tid":2496001,"uid":219128,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-19T14:02:06.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"b05b9c8d94810cb6c22920db0bc0c94223d955ec","tid":2496001,"uid":325899,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-19T14:02:50.000Z","msg":"<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"31399d839edaeb25a69584a0578b8c2eaf0fb759","tid":2496001,"uid":264887,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-19T14:04:25.000Z","msg":"煲大佢<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"a1e503018334d8e8f1b1a634dd35f4ceea89e7b9","tid":2496001,"uid":325899,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-04-19T14:05:01.000Z","msg":"推比更多人知道<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"},{"pid":"768def08c561a6de2fdd794ceee811714b80c92a","tid":2496001,"uid":384614,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2021-04-19T14:05:48.000Z","msg":"一齊搵米奇<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><img src=\"https://ipfs.infura.io/ipfs/Qmb6ogc4