d":227242,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-25T06:15:51.000Z","msg":"送黎送去都好攰<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> 男朋友返完成日工出黎見一陣，就唔洗佢送，叫佢早啲返去抖仲好"},{"pid":"daf03ce6fe518c819b2e9e59e2db2097f4a58b99","tid":955013,"uid":190962,"like":0,"dislike":0,"score":0,"quote":{"pid":"635a363f0190d7a5eb13c78812be9e46696e4ce7","tid":955013,"uid":196924,"like":2,"dislike":0,"score":2,"quote":{"pid":"5516b96814f2f365c823ca844207903e725940f6","tid":955013,"uid":190962,"like":0,"dislike":0,"score":0,"quote":{"pid":"d68712672918908ba3fdd0bc8c9a8f1a40733c19","tid":955013,"uid":196924,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-12-25T05:42:23.000Z","msg":"識過個啦<br />\n我尋晚由將軍澳去到屯門都係7個字<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-12-25T05:55:12.000Z","msg":"你揸車咁實係㗎，不過點解要將送返屋企睇做啲咁必然嘅事？<img src=\"/assets/faces/xm/wonder.gif\" class=\"hkgmoji\" /> <br />\n<img src=\"/assets/faces/normal/wonder2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-12-25T06:13:47.000Z","msg":"冇話必唔必然嘅<br />\n我自己就覺得 見多一陣唔好咩"},"citedBy":0,"replyTime":"2018-12-25T06:19:47.000Z","msg":"咁又係嘅，<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n不過如果冇車嘅話次次見都要送嘅話好辛苦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"04a19dde52b15d2f06566fc64d69b37f5726c5ce","tid":955013,"uid":190962,"like":2,"dislike":0,"score":2,"quote":{"pid":"e4e3adecf2db15b7a29687a0407cd4068947b521","tid":955013,"uid":227242,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-25T06:15:51.000Z","msg":"送黎送去都好攰<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" /> 男朋友返完成日工出黎見一陣，就唔洗佢送，叫佢早啲返去抖仲好"},"citedBy":0,"replyTime":"2018-12-25T06:21:35.000Z","msg":"我都係咁話<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /> 己所不欲 勿施於人，間唔中送就ok，但係次次都送就不了。大家都攰"},{"pid":"d09582bfa5b11b77caf384bf90473ee394982324","tid":955013,"uid":50154,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2018-12-25T06:23:41.000Z","msg":"唔係必然架 <br />\n我一直都覺得有手有腳 屋企又遠 自己番好正常<br />\n但直至識到現任追我時已經堅持要送<br />\n我認真咁話過唔洗送 佢都會極man咁叫我收聲 <br />\n跟埋我上車<img src=\"/assets/faces/xm/smile.gif\" class=\"hkgmoji\" /> 嗰下又幾感動<img src=\"/assets/faces/xm/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n你可以話佢係on9做爛市 <br />\n但我覺得最重要係送嗰個係咪心甘情願<br />\n被送嗰個係咪識欣賞識珍惜<br />\n<br />\n利申 見到佢咁真係好辛苦 比佢送到同居<img src=\"/assets/faces/xm/angel.gif\" class=\"hkgmoji\" />"},{"pid":"27b78816df601c68e67af0e959e9413fa779ac80","tid":955013,"uid":85461,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-25T06:25:11.000Z","msg":"而家香港治安差過美帝國咩?"},{"pid":"6165fd6ca62f36c911ad54ad20c8726efc362964","tid":955013,"uid":196924,"like":0,"dislike":0,"score":0,"quote":{"pid":"27b78816df601c68e67af0e959e9413fa779ac80","tid":955013,"uid":85461,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-25T06:25:11.000Z","msg":"而家香港治安差過美帝國咩?"},"citedBy":0,"replyTime":"2018-12-25T06:31:21.000Z","msg":"蝻太恐怖"},{"pid":"09b4f215ac09c0d2dd819b6982d786711bc3cde6","tid":955013,"uid":186708,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-25T07:12:36.000Z","msg":"我會送男仔返屋企<img src=\"/assets/faces/xm/angel.gif\" class=\"hkgmoji\" />"},{"pid":"3a8834eee8476a8c3fdbe6f89fa2ea9bfaf4e698","tid":955013,"uid":203619,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-25T07:17:09.000Z","msg":"晚晚車條女返屋企<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"c08d416581c027ea9e8501c25e6d95d42666eb05","tid":955013,"uid":181527,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-12-25T07:38:59.000Z","msg":"如果真係夜就要送喎<br />\n你諗下你懶咗今次 聽朝見到條女比人姦咗上報紙<br />\n而你就早咗一粒鐘返屋企打機<img src=\"/assets/faces/xm/bouncer.gif\" class=\"hkgmoji\" /> <br />\n除非你條女個樣好安全 一係就早啲出完街"},{"pid":"c1e30ccf90b2ad80a3a1f96cd5fcc01a93fa31e9","tid":955013,"uid":54452,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-25T08:27:53.000Z","msg":"好多難民<img src=\"/assets/faces/xm/clown.gif\" class=\"hkgmoji\" />"},{"pid":"ed341410de53efc9ba1c8f6a02964dfd1b54f1ac","tid":955013,"uid":46042,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-25T08:34:40.000Z","msg":"<span style=\"font-size: xx-large;\">以前條女送我返屋企<br />\n<br />\n</span>"}]}