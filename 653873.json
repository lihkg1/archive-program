&h=97bfbf07&s={SIZE}\" /><br />\n<img src=\"http://ssl.fairwood.com.hk/eng/menu/images/Breakfast/BKF_Dec22/B03.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fssl.fairwood.com.hk%2Feng%2Fmenu%2Fimages%2FBreakfast%2FBKF_Dec22%2FB03.jpg&h=3ead0379&s={SIZE}\" /><br />\n<img src=\"http://ssl.fairwood.com.hk/eng/menu/images/Breakfast/BKF_Dec22/B02.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fssl.fairwood.com.hk%2Feng%2Fmenu%2Fimages%2FBreakfast%2FBKF_Dec22%2FB02.jpg&h=f20703e7&s={SIZE}\" /><br />\n<br />\n煎雙蛋, 十分營養, 絕對足夠一個朝頭早<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n炒蛋如是, 睇你點揀"},{"pid":"a1abb646ad82a5e60c1dbb0cb2ac9348f4c495d8","tid":653873,"uid":35070,"like":3,"dislike":3,"score":0,"citedBy":2,"replyTime":"2018-05-05T08:01:48.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">港女要減肥?</span></span><br />\n<br />\n唔緊要, 大快活輕怡早餐啱晒佢<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"http://ssl.fairwood.com.hk/eng/menu/images/Breakfast/WD1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fssl.fairwood.com.hk%2Feng%2Fmenu%2Fimages%2FBreakfast%2FWD1.jpg&h=0abe00fb&s={SIZE}\" />"},{"pid":"329cd8c163483417ba21102d2bd1f1f9b85b0b06","tid":653873,"uid":103127,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-05T08:43:23.000Z","msg":"此回覆已被刪除"},{"pid":"89e09e1ab956a588cc98643ab169fbc5b9771706","tid":653873,"uid":35070,"like":0,"dislike":1,"score":-1,"quote":{"pid":"329cd8c163483417ba21102d2bd1f1f9b85b0b06","tid":653873,"uid":103127,"like":0,"dislike":0,"score":0,"quote":{"pid":"a1abb646ad82a5e60c1dbb0cb2ac9348f4c495d8","tid":653873,"uid":35070,"like":3,"dislike":3,"score":0,"citedBy":2,"replyTime":"2018-05-05T08:01:48.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">港女要減肥?</span></span><br />\n<br />\n唔緊要, 大快活輕怡早餐啱晒佢<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br 