dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3c5b062166df5c4c69fed10d9d0c49264ff0e1cd","tid":1921213,"uid":184261,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-03-12T01:33:56.000Z","msg":"你還有黨呀<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"49e490381970e6934638e877dd9c91f98edc371c","tid":1921213,"uid":104804,"like":6,"dislike":0,"score":6,"quote":{"pid":"0122d72b9ec8417a14b80d806457741f56b45fb3","tid":1921213,"uid":10503,"like":13,"dislike":0,"score":13,"citedBy":1,"replyTime":"2020-03-12T01:16:39.000Z","msg":"韭菜有野食仲想點<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />咁唔滿意上街暴動囉"},"citedBy":0,"replyTime":"2020-03-12T01:48:13.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n比屎都要照食既啦<br />\n支那人唔反抗一世都係支那人"},{"pid":"be7576422880f1d5ae581ab5b50b977c87267d2f","tid":1921213,"uid":158071,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-03-12T01:50:37.000Z","msg":"到今時今日<br />\n仲覺得政府當自己係人"},{"pid":"f9ce1d70f0c3d8d6e58a7b84247373593c67cae0","tid":1921213,"uid":42065,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-03-12T01:52:05.000Z","msg":"武漢養豬場<img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/free.gif\" class=\"hkgmoji\" />"},{"pid":"0555b7f0215011f5e65752f3a54039a163a6da37","tid":1921213,"uid":148817,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2020-03-12T01:52:32.000Z","msg":"竟然係擔心架車放過口罩<br />\n<br />\n運過屍都唔奇啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4b9952e8b9c1acc5d69d3caa2529976e67c5bbfb","tid":1921213,"uid":198175,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-03-12T01:54:32.000Z","msg":"党:你班屁民, 有肉食仲咁多嘢講, 不知感恩...<br />\n<br />\n即刻收回, 連到口嘅垃圾肉都冇得食<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"954e48e695551a7d392f655811d0015bd268a