932381,"uid":95138,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-03-18T16:39:02.000Z","msg":"附圖兩張：<br />\n<img src=\"https://na.cx/i/bBOx52z.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbBOx52z.jpg&h=50476cfb&s={SIZE}\" /> <br />\n<img src=\"https://na.cx/i/bpJezVV.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbpJezVV.jpg&h=0a4431df&s={SIZE}\" />"},"citedBy":0,"replyTime":"2020-03-18T17:18:50.000Z","msg":"仲有張：<br />\n<img src=\"https://na.cx/i/4XOKcVQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4XOKcVQ.jpg&h=a1c75996&s={SIZE}\" /><br />\n圖片攝於野味市場（作者提供）"},{"pid":"6411fafc1a6f773c1b9738690e1fdf4d3d2381bc","tid":1932381,"uid":8948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:18:52.000Z","msg":"武漢新冠狀病毒乃中國人劣質文化之產物，濫捕濫食野生動物、不人道對待動物、不尊重生命，為滿足各種欲望而繼續食野味，中國人陋習劣根才是病毒之源。如此態度，十多年後，沙士3.0定必出現。"},{"pid":"70650ea3df536f6a65ae837a7c425afd384ead61","tid":1932381,"uid":95138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:21:33.000Z","msg":"推到有人譯<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"dc2ebae21dfab5821f11a6dc069f37e237e331ec","tid":1932381,"uid":95138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:25:55.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"5593b97194c973269162b500b44d200d17cee624","tid":1932381,"uid":95138,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-18T17:33:27.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"baadf4b1cd8a134a7bdf4210556a95f863737867","tid":1932381,"uid":95138,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-03-18T16:39:02.000Z","msg":"附圖兩張：<br />\n<img src=\"https://na.cx/i/bBOx52z.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbBOx52z.jpg&h=50476cfb&s={SIZE}\" /> <br />\n<img src