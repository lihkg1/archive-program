uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-03T08:09:53.000Z","msg":"<img src=\"/assets/faces/dog/beg_connect.gif\" class=\"hkgmoji\" />"},{"pid":"45b1bc538fda72baca3b2cc872301d083da18504","tid":1044742,"uid":42762,"like":1,"dislike":0,"score":1,"quote":{"pid":"2834c9cf6bc50f551fbfb0f3ffe03b98b10a00bc","tid":1044742,"uid":103156,"like":20,"dislike":0,"score":20,"citedBy":2,"replyTime":"2019-03-03T06:42:07.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2019/03/03/144140_8c7b3087e61d38dd6ecc0e6e8c45237c.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2019%2F03%2F03%2F144140_8c7b3087e61d38dd6ecc0e6e8c45237c.jpg&h=8b7e42e8&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-03-03T08:22:56.000Z","msg":"<img src=\"http://static.apple.nextmedia.com/images/e-paper/20121004/large/1349333301_8fe4.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.apple.nextmedia.com%2Fimages%2Fe-paper%2F20121004%2Flarge%2F1349333301_8fe4.jpg&h=adbd3c84&s={SIZE}\" />"},{"pid":"352db0781ad3e08250c62a95f875bdec7e50876a","tid":1044742,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-03T15:39:51.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"baaa9678a30451efd57a538859ed65525941aa51","tid":1044742,"uid":155919,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-03T16:33:03.000Z","msg":"港獨之父係話d學生做得唔夠，未去到最盡<br />\n<br />\n佢借港英時期o既香港訓介年青人要拋頭顱撒熱血咁去抗爭， 暴力先係唯一出路。<br />\n<br />\n港獨之父好野<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"}]}