張伯倫今季從阿仙奴加盟，季初一度失去正選，但後來慢慢表現出色，多次成為球隊的贏波功臣。然而，就在距離世界盃決賽周開打只餘50日左右受重創，對他個人而言也是一大打擊。<br />\n<br />\n<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"0d1e50d666b0e3fd32a1f290260cf4aed809d3e1","tid":641360,"uid":4675,"like":3,"dislike":0,"score":3,"quote":{"pid":"d5238cbf4a0fcad7e32dcbe3f020eeb5d3f6aa1d","tid":641360,"uid":36497,"like":23,"dislike":1,"score":22,"quote":{"pid":"1a994aa85b3f7b0cd2d5a7bfef23b43058ed6080","tid":641360,"uid":53543,"like":0,"dislike":0,"score":0,"quote":{"pid":"c313a9517807ca53a4ea105c33fd4193d0ddd8c1","tid":641360,"uid":36497,"like":24,"dislike":0,"score":24,"citedBy":2,"replyTime":"2018-04-25T03:08:46.000Z","msg":"雲加愛惜的人，就是我愛惜的人"},"citedBy":1,"replyTime":"2018-04-25T03:12:16.000Z","msg":"但佢反雲<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-04-25T03:14:57.000Z","msg":"彼得三次不認主，猶大做二五仔<br />\n主耶穌一一饒恕"},"citedBy":1,"replyTime":"2018-04-25T04:01:28.000Z","msg":"爺爺<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n喺OX打斷鏝個不敗保住爺爺記錄果一刻, 爺爺已經原諒左佢"},{"pid":"be07b5e5d2604b62ee32f24df1398dc319156922","tid":641360,"uid":11149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-25T04:14:10.000Z","msg":"雲爺爺祝福你<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" />"},{"pid":"92bb8285236d7b3d8b93c812ea54a982321f320e","tid":641360,"uid":69568,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-25T04:27:37.000Z","msg":"369 259"},{"pid":"d95e03e1e3008b5780a98922dd3b4839a8b7dddb","tid":641360,"uid":87394,"like":0,"dislike":0,"score":0,"quote":{"pid":"0d1e50d666b0e3fd32a1f290260cf4aed809d3e1","tid":641360,"uid":4675,"like":3,"dislike":0,"score":3,"quote":{"pid":"d5238cbf4a0fcad7e32dcbe3f020eeb5d3f6aa1d","tid":641360,"uid":36497,"like":23,"dislike":1,"score":