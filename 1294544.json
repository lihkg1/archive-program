src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"12ad659db7bcdb33783a15705dc4c583066a7fc5","tid":1294544,"uid":17008,"like":0,"dislike":0,"score":0,"quote":{"pid":"1398ad18f832be8920859172976787526fbca6b3","tid":1294544,"uid":44391,"like":2,"dislike":0,"score":2,"quote":{"pid":"f443b69ff161ce1fc7c68c0247b1de71ac53dffe","tid":1294544,"uid":32979,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-07-07T20:12:15.000Z","msg":"冇記者，義士會仲危險"},"citedBy":1,"replyTime":"2019-07-07T20:15:27.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-07-08T23:06:15.000Z","msg":"我都諗過示威果班人會唔會咁樣玩<br />\n記者一樣都跟好貼 肯定無問題<br />\n但警察就要一千千人送過去 亦唔夠時間開會設計 封路 包圍等等<br />\n之前每次都可事前準備 如果地點不可預知  警察可能每個地點都要做d準備功夫<br />\n<br />\n果班搞手們tg自己討論過 約定時間公報集合地點 開始時間 路線 注意事項，同每個唔同位置be water大約要點避點散 <br />\n警察連開會時間 調動人力時間都唔夠 難好似旺角咁實施有效包圍"},{"pid":"3ef2bd27d67be5000f57d045a34ec77779680004","tid":1294544,"uid":17008,"like":0,"dislike":0,"score":0,"quote":{"pid":"5867ded0475f4ad16afe4101332cb1926a0e0f47","tid":1294544,"uid":232660,"like":0,"dislike":0,"score":0,"quote":{"pid":"d937c5acce7b3957cf2444226c66ff2c24b2448b","tid":1294544,"uid":77788,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-07-07T20:15:28.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-07-07T20:22:07.000Z","msg":"Mk 有經驗"},"citedBy":0,"replyTime":"2019-07-08T23:17:20.000Z","msg":"mk好易包圍<br />\n可能唔一定市區<br />\n果日屯門頂多一萬人 但警方一樣派好多人去 如果去到幾偏 警察都會跟去<br />\n屯門 順便趕走大媽淫叔依類人民公敵 爭取到中立民意 而且公園大 唔駛下下過馬路 走入周圍商場極易"},{"pid":"f815788a5d1b5cf7fbc8fd22f2abb06a0245632b","tid":1294544,"uid":1670,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T13:31:51.000Z","msg":"每次行動都少緊人，再推"},{"pid":"9a4540adb7910933bd894b38cd431680acbdf79e","tid":1294544,"uid":288523,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T13:34:24.000Z","msg":"此回覆已被刪除"},{"pid":"c7c7feb815d2c82062ff9a56d059d1405058d9d7","tid":1294544,"uid":1670,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T13:54:00.000Z","msg":"如果話擔心冇記者問題<br />\n其實我地每一個戰線都可以分工<br />\n抗爭者自己分擔前線，文宣，記者，物資嘅分工<br />\n每個人各有職責"}]}