%3A%2F%2Ftwitter.com%2Fjoshuawongcf%2Fstatus%2F1190625969502949382%3Fs%3D20&d=sHvBfS5bCv0nfD6zjI7mDd%2BR0LtvndqJ8lr%2BzYsHiyM%3D&h=96be6c0c\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftwitter.com%2Fjoshuawongcf%2Fstatus%2F1190625969502949382%3Fs%3D20&h=1e740e4d\" data-auto-link target=\"_blank\">https://twitter.com/joshuawongcf/status/1190625969502949382?s=20</a>"},"citedBy":0,"replyTime":"2019-12-04T08:40:47.000Z","msg":"導彈嚟<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"145e58bdcbf3c8f3b8a6e8204c17c5bc11438e86","tid":1768504,"uid":290314,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-04T08:41:11.000Z","msg":"搵催淚彈沖水比佢地飲啦"},{"pid":"e8c24495d107cb2c380d5fdfcaa6d0bb39047f39","tid":1768504,"uid":288343,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-04T08:47:29.000Z","msg":"有名你叫陳肇<br />\n<br />\n<br />\n<br />\n即係無始"},{"pid":"412dbda77c23cdfd135be38faa93dfd481eedb4d","tid":1768504,"uid":42536,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-04T08:53:31.000Z","msg":"點解唔問下佢咁孟蘭清明重陽點算？全香港都有人狂燒嘢"},{"pid":"deea240f1e241274e40a4918ace3833cf7a82e29","tid":1768504,"uid":55627,"like":0,"dislike":0,"score":0,"quote":{"pid":"492f80bc35f5b9966d76694e4c5669a83e98b38e","tid":1768504,"uid":130626,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-04T06:04:36.000Z","msg":"警方在全港多區施放催淚彈放題，不少市民大受影響。食物及衞生局局長陳肇始稱，催淚煙主要為粒狀物質，由於較空氣重，施放後會向下沉降，強調其殘留物沉降後一般會附在地面或物件表面，不會長期懸浮於空氣中及擴散範圍有限。不過，她反指，環境保護署的分析發現，有個別日子因為有人縱火，令附近監測站錄得的懸浮粒子濃度，有數小時上升至高於當天正常水平兩倍，反指縱火活動對附近地區的空氣質素造成影響。<br />\n<br />\n民主黨立法會議員胡志偉以書面質詢催淚彈殘留物對健康的影響，陳肇始稱，環境保護署曾分析今年6月至今，曾施放催淚煙地區附近空氣監測站所錄得的粒子數據，沒有發現在曾施放催淚煙地區附近的監測站錄得的粒子水平出現異常情況，顯示催淚煙未使到整個地區的懸浮粒子濃度明顯增加。但她稱，有個別日子因有縱火情況，令附近監測站錄得懸浮粒子濃度有數小時上升至高於當天正常水平兩倍，顯示縱火活動會對附近地區的空氣質素造成影響。<br />\n警方圍攻理工大學該段時間也施放多枚催淚彈，周邊多間學校、香港科學館及香港歷史博物館也受影響。陳肇始稱，兩所博物館在上月17日至26日休館，而康文署與機電署已協調，早前已於科學館和歷史博物館採取相應措施，包括預先關閉冷氣機鮮風閘，以減少館外情況影響館內的空氣質素。而康文署在休館時有清潔場地、安排機電署清洗或更換冷氣系統隔濾網，確保館內環境狀況適合公眾參觀，兩館現已重新開放。<br />\n<br />\n陳肇始又稱，清潔催淚煙殘留物時，應盡量使用一次性清潔物品，並戴上適當的個人防護裝備，例如口罩、橡膠手套、膠圍裙等。受污染的表面一般可使用肥皂水浸濕的布抹，不應使用熱水以免令殘留物蒸發及避免重新揚起殘留微粒，也不應使用高壓水槍、掃把及電風扇。在清潔完成後，應把一次性清潔物品妥善包妥後才棄置。<br />\n她強調，食環署已向屬下員工和潔淨服務承辦商發出工作指引，而房屋署在參考衞生防護中心資訊後，亦已向潔淨服務承辦商發出工作指引，包括清理化學物品殘留物需注意的事項。<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20191204/large/1575439109_60fd.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20191204%2Flarge%2F1575439109_60fd.jpg&h=e37cf2a3&s={SIZE}\" /><br />\n<a href=\"https://hk.news.appledaily.com/local/realtime/article/20191204/60340384\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20191204%2F60340384&d=sHvBfS5bCv0nfD6zjI7mDd%2BR0LtvndqJ8lr%2BzYsHiyM%3D&h=e4499e3c\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Frealtime%2Farticle%2F20191204%2F60340384&h=9ca3315c\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/local/realtime/article/20191204/60340384</a>"},"citedBy":0,"replyTime":"2019-12-04T08:54:11.000Z","msg":"咁咪射粒支國TG,驗下先囉<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"23c2cbfed01b2c3cd4b2414dd178eb5e9ea01ef2","tid":1768504,"uid":156121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-04T08:54:38.000Z","msg":"垃圾<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" />"},{"pid":"b4c7ee30d63fc03be357a1352546d1904e962e67","tid":1768504,"uid":161322,"like":0,"dislike":0,"score":0,"quote":{"pid":"f6a0c7c83b919b495faeeae8bd87f34f8f8145fb","tid":1768504,"uid":61405,"like":0,"dislike":0,"score":0,"quote":{"pid":"118a36c7a331029914177de813000349e052d6f3","tid":1768504,"uid":161322,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-12-04T07:41:16.000Z","msg":"<span style=\"font-size: xx-large;\">咁環境保護署個網站做咩唔公佈二噁英濃度呀？？？</span