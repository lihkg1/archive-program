e0315c47aa80ea1425439340071608634dafc","tid":1159381,"uid":35660,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-05-18T01:15:26.000Z","msg":"無波點女友"},{"pid":"a5e45d1f10d053178e5d6a261e69d0d9f0afbe2f","tid":1159381,"uid":52524,"like":0,"dislike":0,"score":0,"quote":{"pid":"a390c31ec9adcbd066ed035981f671571aacffc9","tid":1159381,"uid":815,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-05-17T21:22:11.000Z","msg":"俾坤狗食過<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-18T01:16:22.000Z","msg":"人生污點"},{"pid":"59c778ba40aeb39bb895bf46ca72d888155d03af","tid":1159381,"uid":175112,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-18T01:18:30.000Z","msg":"好撚正。。。"},{"pid":"0a1f5aae9b93f379ea6af9945b6058f2830f3048","tid":1159381,"uid":68641,"like":1,"dislike":0,"score":1,"quote":{"pid":"a390c31ec9adcbd066ed035981f671571aacffc9","tid":1159381,"uid":815,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-05-17T21:22:11.000Z","msg":"俾坤狗食過<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-18T01:47:22.000Z","msg":"仲好意思話小心識人<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"}]}