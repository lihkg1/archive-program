g src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ae648597c696c066ec23db5345f823887bd5870b","tid":800771,"uid":40932,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-13T10:52:49.000Z","msg":"pubg仲有人提？"},{"pid":"1542946770df22d8a270378f6a0af56f4fa1cfbf","tid":800771,"uid":119778,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-22T00:47:12.000Z","msg":"6700？"},{"pid":"cf3a68148a42072950a3be652e899362838bc5a1","tid":800771,"uid":33130,"like":0,"dislike":0,"score":0,"quote":{"pid":"4c5b2029544e5702530275066fa75c4606f76cf7","tid":800771,"uid":23549,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-08-31T12:48:30.000Z","msg":"Crysis世界第一"},"citedBy":0,"replyTime":"2018-09-22T01:30:49.000Z","msg":"代樓主講: Crysis世界第一<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}