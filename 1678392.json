s/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"eff63ceabaf2ebb817f2c018be67e21d9039093c","tid":1678392,"uid":154406,"like":2,"dislike":0,"score":2,"quote":{"pid":"27cb936b47827f71315aaddda695447754e92a60","tid":1678392,"uid":136116,"like":4,"dislike":1,"score":3,"citedBy":1,"replyTime":"2019-10-27T15:56:01.000Z","msg":"屌你叫FOJ情何以堪<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-27T15:56:48.000Z","msg":"嗰件垃圾我等緊佢斷腳"},{"pid":"215c12f0723a3c5c9321719b506977187769738a","tid":1678392,"uid":265192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-27T15:57:58.000Z","msg":"<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">國際戰線，兩面夾擊！</span></span></strong><br />\n抵抗中國魔掌，需要你課金支持！<br />\n<br />\n<span style=\"font-size: x-large;\"><strong>一、遊說戰線：</strong></span><br />\n<span style=\"font-size: small;\">中共一直斥巨資，僱用遊說集團在華盛頓進行統戰，收賣美國政客及團體，左右美國政策和輿論。單是華為2019年第3季的遊說支出，就達到176萬美元。董建華的中美交流基金會，過去五年在美國支出近300萬港元。</span><br />\n<strong>組建香港人的遊說團隊，請支持大專學界及香港眾志眾籌計劃！</strong><br />\n<strong><em><span style=\"color: orange;\">香港大專學界國際事務代表團眾籌計劃<br />\nHong Kong IAD Crowdfunding Plan</span></em></strong><br />\n<a href=\"https://gogetfunding.com/hkiad-crowdfunding/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgogetfunding.com%2Fhkiad-crowdfunding%2F&d=qY%2BFdmg29Nq5PZFqoXGv4fRe10cHvJvhFGsNMWslaGA%3D&h=d0f10963\" target=\"_blank\">https://gogetfunding.com/hkiad-crowdfunding/</a><br />\n<strong><em><span style=\"color: orange;\">香港眾志國際眾籌計劃 Demosisto International Campaign Crowdfunding Project</span></em></strong><br />\n<a href=\"https://gogetfunding.com/%E9%A6%99%E6%B8%AF%E7%9C%BE%E5%BF%97%E5%9C%8B%E9%9A%9B%E7%9C%BE%E7%B1%8C%E8%A8%88%E5%8A%83-demosisto-international-campaign-crowdfunding-project/?show_desktop=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgogetfunding.com%2F%25E9%25A6%2599%25E6%25B8%25AF%25E7%259C%25BE%25E5%25BF%2597%25E5%259C%258B%25E9%259A%259B%25E7%259C%25BE%25E7%25B1%258C%25E8%25A8%2588%25E5%258A%2583-demosisto-international-campaign-crowdfunding-project%2F%3Fshow_desktop%3D1&d=qY%2BFdmg29Nq5PZFqoXGv4fRe10cHvJvhFGsNMWslaGA%3D&h=4419f51b\" target=\"_blank\">https://gogetfunding.com/%E9%A6%99%E6%B8%AF%E7%9C%BE%E5%BF%97%E5%9C%8B%E9%9A%9B%E7%9C%BE%E7%B1%8C%E8%A8%88%E5%8A%83-demosisto-international-campaign-crowdfunding-project/?show_desktop=1</a><br />\n<br />\n<span style=\"font-size: x-large;\"><strong>二、輿論戰線：</strong></span><br />\n<span style=\"font-size: small;\">香港民主運動和抗爭，不斷受到中國造遙抹黑；中國媒體、英文五毛、投共白人，不斷在網上製造不利香港的輿論。為了令香港人不被代表、為了令外界清楚知道香港清晰的民意；</span><br />\n<strong>香港需要一份科學、具公信力的民調來反映真相。請支持：</strong><br />\n<strong><em><span style=\"color: orange;\">【我們香港人】倡導計劃</span></em></strong><br />\n<a href=\"https://www.collaction.hk/project/story/1209/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.collaction.hk%2Fproject%2Fstory%2F1209%2F&d=qY%2BFdmg29Nq5PZFqoXGv4fRe10cHvJvhFGsNMWslaGA%3D&h=dbb06100\" data-auto-link target=\"_blank\">https://www.collaction.hk/project/story/1209/</a>"},{"pid":"3d6add9040f0d5029cf7c0b72a69a6481c4d1d2f","tid":1678392,"uid":205442,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2019-10-27T16:01:47.000Z","msg":"點解係佢斷腳唔係共狗斷<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"9d38e43818fcc9d1ce4ad9476221c66eb0e35049","tid":1678392,"uid":225130,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2019-10-27T16:07:31.000Z","msg":"真係咁解？<br />\nnets老細共產黨喎"},{"pid":"83139b5308176929142e037a227b46d3b8e94c9f","tid":1678392,"uid":136116,"like":4,"dislike":0,"score":4,"quote":{"pid":"9d38e43818fcc9d1ce4ad9476221c66eb0e35049","tid":1678392,"uid":225130,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2019-10-27T16:07:31.000Z","msg":"真係咁解？<br />\nnets老細共產黨喎"},"citedBy":1,"replyTime":"2019-10-27T16:07:56.000Z","msg":"Irving都有出聲"},{"pid":"6