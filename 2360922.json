e":"2021-01-10T08:39:10.000Z","msg":"Push"},{"pid":"1c5a6ebbe490df840e4519dc62cd732610bee12e","tid":2360922,"uid":50931,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2021-01-10T08:39:57.000Z","msg":"點解冇敖卓軒/邵嵐 <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"b4893829f3ecb2cd9c92248f803d61e6a6cf3ba8","tid":2360922,"uid":232157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-10T09:10:38.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"6caf96dc11c51b465161053df68eac3385be23ba","tid":2360922,"uid":169137,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-10T09:11:00.000Z","msg":"Push"},{"pid":"bb726f675636f0629f131dcf9fd3c5c0667ab488","tid":2360922,"uid":325716,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2021-01-10T09:13:56.000Z","msg":"香港版大紀元<br />\n其實只係證明真係冇咩可以做"}]}