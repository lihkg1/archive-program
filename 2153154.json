3:09.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"8461b6cecb7b860a24f8b5b1d555149226336416","tid":2153154,"uid":252492,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-13T08:53:56.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"884f23d7f0e246c494d63dd63c6e22c63f1ae3a7","tid":2153154,"uid":252492,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-13T22:51:03.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f7c8768aa136dd74245dddaf51b9aac33276babd","tid":2153154,"uid":252492,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T03:44:23.000Z","msg":"<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"94393b60b16c05b0ee2d170595834d05008cfa20","tid":2153154,"uid":294648,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-15T04:01:25.000Z","msg":"制裁埋公民袋<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"ce2976c29fba2431960820ea809cb40be0619932","tid":2153154,"uid":73883,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-08-13T02:05:42.000Z","msg":"<img src=\"https://na.cx/i/7HOLkKJ.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F7HOLkKJ.png&h=528e0fa5&s={SIZE}\" /><br />\n<br />\n【有線新聞】全國人大常委決定立法會延任至少一年，政府表明毋須再次宣誓，所有議員可以原班過渡，民主派對去留未有共識，公民黨主席梁家傑認為目前需要守好每個關口，傾向「一齊上車」，但有抗爭派就主張總辭杯葛。<br />\n<br />\n去、抑或留，考慮多日，民主派仍未有答案。關鍵四人，即是被DQ下屆參選資格的四位議員，公民黨佔了三席。梁家傑：「現時明顯需要我們守著每一個關口。我覺得應該盡量服應於民主運動，現時需要我們的團結及需要我們做的事，就去做，我傾向應該上車。」<br />\n<br />\n熱血公民鄭松泰說初步決定留任，除非泛民願意走這一步。鄭松泰：「是不是所有民主派要去杯葛及不再參與香港選舉制度？這個方向才有意思，否則我只會考慮自己。」<br />\n<br />\n在民主派初選中，勝出的抗爭派就認為要考慮他們的聲音。民主派初選出線人鄒家成：「權力是來自中共的施捨，把握今次這麼重要的時機，杯葛『臨立會』，創造抗爭痕跡。」<br />\n<br />\n行政會議成員前公民黨成員湯家驊認為，如果民主派總辭令議會失去制衡，是對不起香港市民，而且總辭的解說亦可能有後果，「如果解說涉及不接受這個制度，特別是一國兩制或一國的權力，行為可能會影響將來參選時，會不會被判斷為不擁護基本法及不效忠特區。」<br />\n<br />\n建制派就說如果民主派留任，是同心抗疫、很歡迎。工聯會黃國健：「如果回來搗亂、拖後腿拉布，我相信市民想法是不回來比回來好。」"}}