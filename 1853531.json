v3rjd6zAHDU%2B6Dwik7Xqul57XbQM8lVYa5HUNM4%3D&h=9cf189f0\" data-auto-link target=\"_blank\">https://academic.oup.com/annweh/article/56/1/92/166111</a>"},"citedBy":0,"replyTime":"2020-02-01T06:23:50.000Z","msg":"正<br />\n<br />\nWhen FFRs were examined post decontamination by viral culture, all three decontamination methods were effective, reducing virus load by &gt;4 log median tissue culture infective dose. <br />\n<br />\n但佢無講點叫effective decontamination <img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />"},{"pid":"8b7b859a188f4041336e4f69eed2fea9dce3b00b","tid":1853531,"uid":44923,"like":0,"dislike":0,"score":0,"quote":{"pid":"50bdc7607c2807714c25fa944fb096f3e4243866","tid":1853531,"uid":28628,"like":1,"dislike":0,"score":1,"quote":{"pid":"2f36e8581a2e972a03c2bd5d8346b3b3e66f0e87","tid":1853531,"uid":44923,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-31T04:42:16.000Z","msg":"如果唔計入面條鐵線，灯罩會唔會可以令入面水份加熱蒸發？<br />\n<br />\n一來高溫殺菌，二來無水份後病毒未能依附傳播<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2020-01-31T06:10:36.000Z","msg":"有paper 講係得<br />\n但實質上用係嚟 <br />\n你不如戴個新<br />\n<a href=\"https://academic.oup.com/annweh/article/56/1/92/166111\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Facademic.oup.com%2Fannweh%2Farticle%2F56%2F1%2F92%2F166111&d=7U4Tv3rjd6zAHDU%2B6Dwik7Xqul57XbQM8lVYa5HUNM4%3D&h=9cf189f0\" data-auto-link target=\"_blank\">https://academic.oup.com/annweh/article/56/1/92/166111</a>"},"citedBy":0,"replyTime":"2020-02-01T06:25:45.000Z","msg":"Since previously worn FFRs may serve as a reservoir for the spread of virus, the reuse of filters exposed to microorganisms requires careful consideration. If respirator shortages are to be mitigated through reuse, rapid, low-cost, and efficient decontamination methods must be established<br />\n<br />\n理論上得但要做得正確先得 所以大家最好唔好試<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"bd8f43eb15e2cd2ced133f1b31cb0ecdbfa4bdf2","tid":1853531,"uid":245484,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-01T06:28:49.000Z","msg":"可以順手放埋八達通入去增值 <img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"d3b77ec726071234021998b549f34cd639c87afa","tid":1853531,"uid":44923,"like":0,"dislike":0,"score":0,"quote":{"pid":"bd8f43eb15e2cd2ced133f1b31cb0ecdbfa4bdf2","tid":1853531,"uid":245484,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-01T06:28:49.000Z","msg":"可以順手放埋八達通入去增值 <img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-01T06:33:35.000Z","msg":"Microwave-generated steam.<br />\n<br />\nA 1250-W (2450 MHz) commercially available microwave oven (Panasonic Corp., Secaucus, NJ, USA) with a rotating glass plate was used to irradiate a single respirator per treatment. Samples were placed above a plastic box filled with 50 ml of room temperature tap water. The top of the box was perforated with 96 holes (7 mm diameter) evenly distributed over the entire surface to allow MGS to vent through the respirator. The virus-contaminated respirator was placed with the convex surface pointed toward the steam source and the FFR was then irradiated for 2 min at full power.<br />\n<br />\n唔係玩膠呀 真心問架<img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />"},{"pid":"6c9dd2726354d6e3313ae526d8e12b6f2464235f","tid":1853531,"uid":131621,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-01T06:33:50.000Z","msg":"碳燒好啲<img src=\"/assets/faces/lny/tongue2.gif\" class=\"hkgmoji\" />"},{"pid":"81a5012ae099d63dde28709aad1412ebe44e1d88","tid":1853531,"uid":321002,"like":0,"dislike":0,"score":0,"quote":{"pid":"2f36e8581a2e972a03c2bd5d8346b3b3e66f0e87","tid":1853531,"uid":44923,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-31T04:42:16.000Z","msg":"如果唔計入面條鐵線，灯罩會唔會可以令入面水份加熱蒸發？<br />\n<br />\n一來高溫殺菌，二來無水份後病毒未能依附傳播<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-01T06:39:17.000Z"