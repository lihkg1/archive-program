{"tid":303243,"cid":5,"subCid":0,"title":"【習總送大禮】運輸署網絡系統故障　實時交通無畫面","createTime":"2017-06-30T04:29:36.000Z","updateTime":"2017-06-30T04:42:58.000Z","uid":23707,"like":0,"dislike":1,"uniUserReply":0,"replies":[{"pid":"35ffdc5b3e320095b11b072260bf13c84d63c375","tid":303243,"uid":23707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T04:29:36.000Z","msg":"<a href=\"http://hk.on.cc/hk/bkn/cnt/news/20170630/bkn-20170630113331491-0630_00822_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20170630%2Fbkn-20170630113331491-0630_00822_001.html&d=KtAiQ8SDkA72PzGucwi2MZWUQYxlHU4vp7GM3pu%2FB4U%3D&h=707d344a\" target=\"_blank\">http://hk.on.cc/hk/bkn/cnt/news/20170630/bkn-20170630113331491-0630_00822_001.html</a><br />\n<br />\n【因報訊】運輸署網頁提供直播及相片，以顯示全港交通現況，讓市民更易掌握實時交通情況，惟署方網頁於早上7時許開始「全部熄機」，均未能顯示交通情況。運輸署發言人回覆東網時證實，署方網絡系統出現故障，現正進行搶修，暫未知完成復修的時間。<br />\n<br />\n根據運輸署網頁，不論是快拍或直播，均未能顯示實時情況，僅顯示「暫時未能提供服務」。"},{"pid":"d98d19a68cea85f52829582fc035305afc93464e","tid":303243,"uid":21423,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2017-06-30T04:31:40.000Z","msg":"此回覆已被刪除"},{"pid":"8523dca13026be45ebe625ab9c18fec3b26f4bb1","tid":303243,"uid":23707,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T04:37:45.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"ff07e7b9391da326a40193380ffa13708a6995c4","tid":303243,"uid":531,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T04:40:37.000Z","msg":"風水既野"},{"pid":"7b9a39c50263d010dcc6aca1e1131268be794300","tid":303243,"uid":4496,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T04:41:26.000Z","msg":"做大茶飯<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <br />\n<br />\n破壞晒d閉路電視先"},{"pid":"ac6e0b0df5807278d33af2b7d6b693e18f9fe191","tid":303243,"uid":20815,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-06-30T04:42:58.000Z","msg":"呀 乜咁橋呀"}]}