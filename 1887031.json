 />"},{"pid":"14af8f7481bb5a2fe5c2e398327e8bac3a4e5477","tid":1887031,"uid":299514,"like":0,"dislike":0,"score":0,"quote":{"pid":"542500f76271d219fef947a819702804dfcf9119","tid":1887031,"uid":12994,"like":9,"dislike":0,"score":9,"citedBy":3,"replyTime":"2020-02-19T10:05:50.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-20T04:12:41.000Z","msg":"咁點解依家本地工廠有材料做口罩<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"7da6de961959bf52bcbca87258e27bccdff1cb42","tid":1887031,"uid":91897,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-20T04:12:52.000Z","msg":"有罩係好事，但依家情況係有罩都好大機會奶野<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n成日形住自己中左招"},{"pid":"0344eb8031e6ba2da15ecc960288e8038e48ab18","tid":1887031,"uid":271485,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-20T04:26:16.000Z","msg":"唔係貨鴻穩定或多咗<br />\n而家藥房賣果啲係由於一直佢地都全球掃<br />\n貨多到自己都驚<br />\n而疫症又無預其月大爆發<br />\n每日响度唧牙膏咁中招<br />\n<br />\n所以拎返些少出嚟<br />\n一來可以坐少啲貨<br />\n二來等市民有深刻概念記得邊間有口罩賣<br />\n方便下一波搵錢<br />\n就好似外圍要買返落馬會咁<br />\n<br />\n遲啲真正大爆發<br />\n佢地又會收埋話無貨<br />\n過兩日再賣貴一倍話好辛苦撲返嚟<br />\n<br />\n其實批貨一個月前已經响貨倉"},{"pid":"9471b79c586cbeee14bc32f638360b73ebf765e6","tid":1887031,"uid":12994,"like":0,"dislike":0,"score":0,"quote":{"pid":"14af8f7481bb5a2fe5c2e398327e8bac3a4e5477","tid":1887031,"uid":299514,"like":0,"dislike":0,"score":0,"quote":{"pid":"542500f76271d219fef947a819702804dfcf9119","tid":1887031,"uid":12994,"like":9,"dislike":0,"score":9,"citedBy":3,"replyTime":"2020-02-19T10:05:50.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-20T04:12:41.000Z","msg":"咁點解依家本地工廠有材料做口罩<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-20T04:45:58.000Z","msg":"維基只係搵到一舊 整到一百萬隻<br />\n佢都未係搵到穩定既供應商<br />\n你再睇下新聞 韓國要原材料 中國唔比<br />\n整一百萬隻 一日兩隻<br />\n其實都係唔夠香港一日用量<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b8eceb043d57164e3276f1625c00b698e5b1dda4","tid":1887031,"uid":163985,"like":0,"dislike":0,"score":0,"quote":{"pid":"9471b79c586cbeee14bc32f638360b73ebf765e6","tid":1887031,"uid":12994,"like":0,"dislike":0,"score":0,"quote":{"pid":"14af8f7481bb5a2fe5c2e398327e8bac3a4e5477","tid":1887031,"uid":299514,"like":0,"dislike":0,"score":0,"quote":{"pid":"542500f76271d219fef947a819702804dfcf9119","tid":1887031,"uid":12994,"like":9,"dislike":0,"score":9,"citedBy":3,"replyTime":"2020-02-19T10:05:50.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-20T04:12:41.000Z","msg":"咁點解依家本地工廠有材料做口罩<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-02-20T04:45:58.000Z","msg":"維基只係搵到一舊 整到一百萬隻<br />\n佢都未係搵到穩定既供應商<br />\n你再睇下新聞 韓國要原材料 中國唔比<br />\n整一百萬隻 一日兩隻<br />\n其實都係唔夠香港一日用量<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-02-20T04:50:04.000Z","msg":"佢好似話每隻5蚊？"},{"pid":"9d2834a5763a0f8c7d4b986053021afbe76977e2","tid":1887031,"uid":227404,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-02-20T04:57:47.000Z","msg":"依家市面上有貨嘅口罩係嚟自邊度<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n東南亞 由其vietnam 菲律賓 印尼不了<br />\n日本口罩<img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" />"},{"pid":"5b02f50f9e3456f19098bf382b474a24d4b24d0a","tid":1887031,"uid":126382,"like":2,"dislike":0,"score":2,"quote":{"pid":"9d2834a5763a0f8c7d4b986053021afbe76977e2","tid":1887031,"uid":227404,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-02-20T04:57:47.000Z","msg":"依家市面上有貨嘅口罩係嚟自邊度<img src=\"/assets/faces/normal/sosad.gif\" class