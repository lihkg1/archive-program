rc=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />大大力鞭落去羅密歐度<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"804fc4210d50affb2eef28a5342bbf043a662581","tid":1637120,"uid":149978,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T01:45:45.000Z","msg":"戲已完"},{"pid":"3b502da3870d3d2699933b78d2e5b8d9177b7ef0","tid":1637120,"uid":169079,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T01:51:16.000Z","msg":"人地彩你都On9<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 根本由頭到尾你係你港共交所自導自演，當人地on9咩人地點會唔知你係共狗控制左"},{"pid":"b2c580ea16e1e780a09244b388978acf944db56c","tid":1637120,"uid":52538,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T01:51:58.000Z","msg":"FF得太多<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"546065e816cb27f343a330db0feee70be3281e90","tid":1637120,"uid":167102,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-08T01:52:00.000Z","msg":"根本冇可能收購到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}