310265fb3099a4c9b4fafa8013e1287878e97e","tid":2507804,"uid":236140,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-28T14:16:31.000Z","msg":"Good luck"},"citedBy":1,"replyTime":"2021-04-28T14:18:02.000Z","msg":"真心定叫我睇路？"},"citedBy":2,"replyTime":"2021-04-28T14:23:35.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-28T14:31:35.000Z","msg":"我其實唔係真係鳩買，metaphorically said so<br />\n<br />\n升市season好似買乜升乜<br />\n我都乜眼睇"},{"pid":"c74370b0b34ca597423a56537e610938414fe48b","tid":2507804,"uid":236140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-28T14:32:00.000Z","msg":"<a href=\"http://cablenews.i-cable.com/ci/news/article/37/732460\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fcablenews.i-cable.com%2Fci%2Fnews%2Farticle%2F37%2F732460&d=APk9rvMsCVL9feuIhYiW0mWzMblEAwKPRhfqpO9yGDY%3D&h=d6170c88\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fcablenews.i-cable.com%2Fci%2Fnews%2Farticle%2F37%2F732460&h=ebd5272f\" target=\"_blank\">http://cablenews.i-cable.com/ci/news/article/37/732460</a><br />\n<br />\n<span class=\"x-large\">多間診所遭領展加租三至四成　西醫工會指不排除號召罷診　領展籲有關診所交資料</span><br />\n<br />\n領展近日向轄下商場多間醫務所大幅加租三至四成，西醫工會形容加幅瘋狂、不能接受，不排除會號召私家診所的醫生罷診抗議。<br />\n東涌這間診所原本月租35,000元，領展將要求加租至每月45,000元，醫生說大大增加經營壓力。西醫李偉龍：「東涌主要客人都是來自機場，港龍結業了、國泰又裁員，很多航空公司及附屬機構都裁員，所以客源少很多。加幅十分不合理，加輻差不多28%，即是30%。這還未包括管理費、冷氣費，那些亦足足合共8,000元。」<br />\n<br />\n<br />\n香港啲地產商，食人唔𦧲骨，佢去劏客，好過我自己打理啦"},{"pid":"d0f3519f7ecc29b6380985b7409e337bf3445fad","tid":2507804,"uid":73269,"like":0,"dislike":0,"score":0,"quote":{"pid":"4340abae3e8620bf346fab6913cc57660a4e2060","tid":2507804,"uid":236140,"like":0,"dislike":0,"score":0,"quote":{"pid":"4144241bd90858358646f7792bf2d4e760abe36f","tid":2507804,"uid":73269,"like":0,"dislike":0,"score":0,"quote":{"pid":"3c310265fb3099a4c9b4fafa8013e1287878e97e","tid":2507804,"uid":236140,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-28T14:16:31.000Z","msg":"Good luck"},"citedBy":1,"replyTime":"2021-04-28T14:18:02.000Z","msg":"真心定叫我睇路？"},"citedBy":2,"replyTime":"2021-04-28T14:23:35.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-28T14:34:19.000Z","msg":"我本身當賭場，(冇話我長線必勝)，比人打理我冇野玩"},{"pid":"2b340412dd59ea947c8b0a729207bffbf0805c58","tid":2507804,"uid":236140,"like":0,"dislike":0,"score":0,"quote":{"pid":"d0f3519f7ecc29b6380985b7409e337bf3445fad","tid":2507804,"uid":73269,"like":0,"dislike":0,"score":0,"quote":{"pid":"4340abae3e8620bf346fab6913cc57660a4e2060","tid":2507804,"uid":236140,"like":0,"dislike":0,"score":0,"quote":{"pid":"4144241bd90858358646f7792bf2d4e760abe36f","tid":2507804,"uid":73269,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-28T14:18:02.000Z","msg":"真心定叫我睇路？"},"citedBy":2,"replyTime":"2021-04-28T14:23:35.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-28T14:34:19.000Z","msg":"我本身當賭場，(冇話我長線必勝)，比人打理我冇野玩"},"citedBy":2,"replyTime":"2021-04-28T14:39:35.000Z","msg":"自問冇地產商咁有牙力加租，交俾佢哋，我又有覺好瞓，一起身望到IFC仲喺度，代表我嘅資產仍然喺度<br />\n<br />\n所以交俾班地產霸權同我打理好過<br />\n<br />\n自己就攞其他資金炒其他嘢"},{"pid":"ca31b070eca04c6c80bf4324c5207ae9576f9d5e","tid":2507804,"uid":140454,"like":0,"dislike":1,"score":-1,"quote":{"pid":"ee56c429fcad2a685b838451e0106993482c2730","tid":2507804,"uid":89752,"like":0,"dislike":0,"score":0,"quote":{"pid":"7676fbf0cbf822fb02fb0df983385dce866bc3b0","tid":2507804,"uid":236140,"like":4,"dislike":0,"score":4,"quote":{"pid":"5816fc9589ac93788bd0b6ca8cf57d8295c1a3fc","tid":2507804,"uid":345941,"like":9,"dislike":3,"score":6,"citedBy":1,"replyTime":"2021-04-28T11:56:16.000Z","msg":"連登啲小朋友都未畢業，你問佢哋，佢哋只會叫你移民<br />\n<br />\n我成日都話，有乜嘢投資可以比你leverage 10倍，2%利息都唔使，可以借足30年"},"citedBy":1,"replyTime":"2021-04-28T11:59:26.000Z","msg":"邊Q度有10倍？ <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/f