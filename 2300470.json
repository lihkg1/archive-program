9da783948b03619cce350","tid":2300470,"uid":269202,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-11-25T14:56:23.000Z","msg":"點解深圳灣要檢測？歧視中國人？可恥"},{"pid":"c504f87a5611d97a5563e8762950b6a8a471779d","tid":2300470,"uid":46245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T14:57:51.000Z","msg":"中國送大禮系列，多x謝晒"},{"pid":"aa0ad484dac0de4cba6d595cd0406b9caa47b750","tid":2300470,"uid":1089,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:01:10.000Z","msg":"香港係大灣區一部份，所以係本地感染<img src=\"/assets/faces/pig/argue.gif\" class=\"hkgmoji\" /><br />\n<br />\n幫你諗埋，唔洗多謝"},{"pid":"0ec93d4efb1f2644c59ca78a668402a8ca08957c","tid":2300470,"uid":204423,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:01:42.000Z","msg":"中國冇人感染<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" />"},{"pid":"31d9e8165dea59948931281c7f6455c81701f0c9","tid":2300470,"uid":350051,"like":0,"dislike":0,"score":0,"quote":{"pid":"37f0b86a8fe87f7f4a79dec3fd351f921f5fd317","tid":2300470,"uid":105567,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-11-25T14:06:17.000Z","msg":"【Now新聞台】本港新增85宗新冠病毒確診，84宗屬本地感染，當中63人屬歌舞群組。另外，一名患者從深圳灣口岸入境完成14天檢疫後確診，衞生防護中心調查是否屬輸入個案。<br />\n<br />\n歌舞群組繼續擴大，再多63人確診，群組累積已有250人感染。<br />\n<br />\n其中一名確診者是在旺角中心一期十八樓仲堅醫療中心應診的婦產科專科醫生劉黃色鳳，她亦於馬鞍山仁安分科診所應診。<br />\n<br />\n衞生防護中心傳染病處主任張竹君：「婦產科醫生有穿足保護衣物，相信傳染給病人的機會較小。不過，我們會視乎如何追蹤，她的診所需要進行大清洗，她自己進了醫院，診所需要關閉14天。」<br />\n<br />\n另外，有一名屬歌舞群組初步陽性的患者，是土瓜灣兆景安老院的員工，這名員工平時並無接觸長者。<br />\n<br />\n另外，有十六宗源頭不明個案分布港九新界，包括北角、愉景灣、粉嶺及觀塘等。<br />\n<br />\n當中，有一名亞博館清潔工人。醫管局指，這名工人並無在社區治療設施內當值，並沒有緊密接觸者，已安排另一間清潔外判商為一、二號館的社區治療設施清潔，相信館內感染的風險低。<br />\n<br />\n其他確診個案還有一名住深水埗的44歲女子，本月八日由深圳灣抵港，之後在家中檢疫至22日，同住的52歲女子都染病。衞生防護中心表示，仍調查她們是本地或輸入個案。<br />\n<br />\n張竹君：「其中一名是家居檢疫人士，另外一名有外出。我們初步估計，該外出人士有機會傳染給該家居檢疫人士，至於在何處受染或其他情況，仍在跟進中。」<br />\n<br />\n目前亦有逾60宗初步陽性個案，包括一名港怡醫院急症室27歲男護士，感染源頭不明。<br />\n<br />\n<a href=\"https://news.now.com/home/local/player?newsId=414270&amp;fbclid=IwAR2F-s3fFux_cYqmmz3Udyu7E2Bq-iMRabgiPMD9kXfv3jKS1qsbcYblhZo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D414270%26fbclid%3DIwAR2F-s3fFux_cYqmmz3Udyu7E2Bq-iMRabgiPMD9kXfv3jKS1qsbcYblhZo&d=Z5fxCpLMP6GgpQ63MmTuwi2wsmw0HNSHoQ%2FRl4ZEJbA%3D&h=040d50cb\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D414270%26fbclid%3DIwAR2F-s3fFux_cYqmmz3Udyu7E2Bq-iMRabgiPMD9kXfv3jKS1qsbcYblhZo&h=6fe16902\" target=\"_blank\">https://news.now.com/home/local/player?newsId=414270&amp;fbclid=IwAR2F-s3fFux_cYqmmz3Udyu7E2Bq-iMRabgiPMD9kXfv3jKS1qsbcYblhZo</a>"},"citedBy":0,"replyTime":"2020-11-25T15:01:46.000Z","msg":"中國清零<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"2429360cfc53b59ca9551bf72788d5f0b70a97f3","tid":2300470,"uid":280431,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:03:47.000Z","msg":"清零喎 <img src=\"/assets/faces/fs/kill.gif\" class=\"hkgmoji\" />"},{"pid":"17af1c1289c01ebc4e620f17556d207e1bf517b4","tid":2300470,"uid":28997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:05:03.000Z","msg":"點解既 中國唔係零個案架咩<br />\n無可能確診架喎<br />\n檢測條友係咪想犯國安法呀??散播謠言乜乜乜間碟乜乜乜呀"},{"pid":"2d334c7247f5a4fd27eaa47b3be033df680276dc","tid":2300470,"uid":88743,"like":1,"dislike":1,"score":0,"quote":{"pid":"d29b14589d04dc18a988155ff8af3378ea755dc4","tid":2300470,"uid":246419,"like":1,"dislike":0,"score":1,"quote":{"pid":"81231cd52bae872ce6ccbc6ccfabb4887cbf5a55","tid":2300470,"uid":88743,"like":6,"dislike":3,"score":3,"quote":{"pid":"3acb81a13bc7b0a76a001226e92602f8f86f5c07","tid":2300470,"uid":256246,"like":31,"dislike":1,"score":30,"citedBy":1,"replyTime":"2020-11-25T14:14:32.000Z","msg":"輸你家姐咩，係不明源頭呀<img src=\"/assets/faces/lm2/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-11-25T14:34:07.000Z","msg":"錯<br />\n係香港輸入大陸 大陸再輸入香港"},"citedBy":1,"replyTime":"2020-11-25T14:47:51.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-25T15:05:26.000Z","msg":"係<br />\n好似查到係德國去美帝先"},{"pid":"84af130b496f59e7c538a1adb09d0a58fc47a734","tid":2300470,"uid":301152,"like":4,"dislike":0,"score":4,"quote":{"pid":"421ab8fa9fc555666cb615f3fa2deaa302820775","tid":2300470,"uid":34869,"like":118,"dislike":0,"score":118,"citedBy":2,"replyTime":"2020-11-25T14:13:30.000Z","msg":"依家日日幾千人落黎呀<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-11-25T15:06:00.000Z","msg":"<span class=\"orange\"><span class=\"x-large\">仲有好多豁免檢疫<br />\n</span></span><br />\n<br />\n<img src=\"/assets/faces/dog/beat.gif\" class=\"hkgmoji\" /> 有幾多隱性患者？<br />\n<br />\n<a href=\"https://hk.appledaily.com/local/20201124/TRTAE27LKZFSPG2BKAQUP7MD3I/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20201124%2FTRTAE27LKZFSPG2BKAQUP7MD3I%2F&d=Z5fxCpLMP6GgpQ63MmTuwi2wsmw0HNSHoQ%2FRl4ZEJbA%3D&h=519330e1\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20201124%2FTRTAE27LKZFSPG2BKAQUP7MD3I%2F&h=b845e4de\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20201124/TRTAE27LKZFSPG2BKAQUP7MD3I/</a><br />\n<br />\n<blockquote><br />\n<span class=\"violet\">第四波疫情根本原因係政府豁免檢疫<br />\n<a href=\"https://lih.kg/2295904\" data-auto-link target=\"_blank\">https://lih.kg/2295904</a><br />\n</span><br />\n本周一名30歲女子，從尼泊爾抵港一天後才確診，期間住在紅磡都會軒1座，<br />\n屬<span class=\"orange\"><span class=\"x-large\"> 豁免檢疫人士</span> </span><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n<br />\n翻查九月至十一月輸入個案，39名確診者從尼泊爾抵港，<span class=\"red\"><span class=\"large\">當中17人確診時已經離開機場，進入社區檢疫。<br />\n</span></span><br />\n<br />\n而到最新的梅窩渡假群組，以及東涌和大埔等本地個案，就流行新的病毒株，較近似尼泊爾輸入的個案。<br />\n<br />\n</blockquote><a href=\"http://news.now.com/home/local/player?newsId=412656&amp;refer=Share\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D412656%26refer%3DShare&d=Z5fxCpLMP6GgpQ63MmTuwi2wsmw0HNSHoQ%2FRl4ZEJbA%3D&h=1b6cbee0\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fnews.now.com%2Fhome%2Flocal%2Fplayer%3FnewsId%3D412656%26refer%3DShare&h=9b033cf4\" data-auto-link target=\"_blank\">http://news.now.com/home/local/player?newsId=412656&amp;refer=Share</a>"},{"pid":"0729602d076642f4b1a6c6415f518aa720be1c3f","tid":2300470,"uid":169116,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:06:11.000Z","msg":"大陸根本就大量感染者"},{"pid":"a4b6948a15e2b47d6c063265e6702a2eb928ada5","tid":2300470,"uid":385516,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:07:10.000Z","msg":"此回覆已被刪除"},{"pid":"724cf3d1634ffba777a6d76d5a7af88eb9974b19","tid":2300470,"uid":310867,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:07:28.000Z","msg":"<span class=\"xx-large\"><span class=\"red\">支那零確診</span></span><img src=\"/assets/faces/dog/zzz.gif\" class=\"hkgmoji\" />"},{"pid":"587c5a714ed07ce70e8102054248279a0ccb6a40","tid":2300470,"uid":38177,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:07:35.000Z","msg":"爆爆爆<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},{"pid":"74b1d2a9dea5abc2564252d96288c011002411d5","tid":2300470,"uid":8636,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:09:23.000Z","msg":"屌你老母支那肺炎"},{"pid":"e51328af2f4a001d9a2218f3bdc4c50706876f22","tid":2300470,"uid":66346,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:09:30.000Z","msg":"唔使隔離嗰啲周街跑緊啦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"374f9ce825164e7af652e70ac0d519b89d92cba7","tid":2300470,"uid":36901,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-25T15:10:22.000Z","msg":"叫左唔好返來啦<br />\n係祖國咪好好地<br />\n一返來就中招<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"2276d869f3908ebf82f8ccb5985e9d09f76d3ab9","tid":23004