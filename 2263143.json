>"},{"pid":"5c096a3201dfc9e2654f0ae31e46ca752fdf98b3","tid":2263143,"uid":109385,"like":1,"dislike":0,"score":1,"quote":{"pid":"17451244f41ab3abd7e78c968fb1d280b5ca162c","tid":2263143,"uid":244066,"like":0,"dislike":0,"score":0,"quote":{"pid":"574e580534cff677114bb4710bb09fa8ee9f9cf3","tid":2263143,"uid":366281,"like":1,"dislike":0,"score":1,"quote":{"pid":"f8e5924fba0edd2c00137a36777f2e147d82c89a","tid":2263143,"uid":244066,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-10-29T15:53:46.000Z","msg":"多謝你有埋圖<br />\n不過因為張枱成80cm高，所以用唔到衣架"},"citedBy":2,"replyTime":"2020-10-29T15:55:26.000Z","msg":"拆開衣架做一條直線<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":3,"replyTime":"2020-10-29T16:03:04.000Z","msg":"咁請問點樣確保痴力同埋又唔傷紙?<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-29T16:11:03.000Z","msg":"<img src=\"https://na.cx/i/bsGcJC8.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbsGcJC8.png&h=f7cca92d&s={SIZE}\" /><br />\n拆開就應該兩支先夠穩陣<br />\n中間交叉位多數要加條鐵線仔先唔會令膠紙變形<br />\n<br />\n你張卡應該係膠做 <br />\n唔係紙做架嘛，用膠紙痴一痴抆開應該就唔會點傷張卡既<br />\n搵手機照一照大約位置落去<br />\n落去中就會夠痴力拉返上黎<br />\n<br />\n唔夠痴力就換膠紙"},{"pid":"7e9871e619eca3ccb5d55c0761dafcee9ae00a38","tid":2263143,"uid":66468,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-29T16:19:25.000Z","msg":"我之前都有類似情況<br />\n<br />\n我啊媽就買左把長鐵尺，跟著痴膠紙<br />\n<br />\n樓上巴打話拆開衣架都可以，如果唔夠力先用鐵尺"},{"pid":"458cb2d79ed71d6aab8ca7805df0d2ff5fc43b8f","tid":2263143,"uid":371879,"like":0,"dislike":0,"score":0,"quote":{"pid":"fd2db3e5b50b04617b43bdea55fd0fc131d4cf5a","tid":2263143,"uid":27416,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-10-29T15:42:57.000Z","msg":"咸濕到以為係ball gap<br />\n我錯"},"citedBy":0,"replyTime":"2020-10-29T16:20:56.000Z","msg":"我都係<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"}]}