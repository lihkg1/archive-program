08.000Z","msg":"此回覆已被刪除"},{"pid":"155240b1957baaa92567f787fe6f8031418df1e3","tid":1323484,"uid":36901,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T04:06:56.000Z","msg":"參考2005 年告士打道圍捕近千韓農"},{"pid":"32efea04b7415e46b9c3153cfe1324a0c8fe3c2f","tid":1323484,"uid":210612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T05:06:02.000Z","msg":"721推土機出動<br />\n================<br />\n堅守五大訴求 勿分化勿指責 <br />\n齊上齊落<br />\n建議大家自備物資 做流動物資站<br />\n頭盔 眼罩 口罩 毛巾 是啤衫<br />\n我無嘢講 我要見律師"},{"pid":"ffdc414a93e4d663960122d82a739fa981039f4e","tid":1323484,"uid":193541,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T05:10:35.000Z","msg":"push"},{"pid":"43d661816e43220eb7f4e6ceba5542256e277f76","tid":1323484,"uid":142332,"like":0,"dislike":0,"score":0,"quote":{"pid":"9c1919a5b6e6f5fc719082a28254d9db38596b9c","tid":1323484,"uid":61886,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-16T09:06:48.000Z","msg":"<span style=\"color: red;\">此post並非鼓吹非法集結<br />\n本人極力支持和平理性非暴力反映訴求<br />\n</span><br />\n<br />\n綜合以下最近幾次的衝突<br />\n就警犬721的行動，個人有此下預測<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">預測行動方向</span></span></strong><br />\n1. 警犬將會避免落單開無雙<br />\n2. 警犬將會避免近距離攻擊，主力以遠距離攻勢。<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">原因如下</span></span></strong><br />\n1. 新城市一役係警犬有少少意想不到，唔係唔會有傻鳩出黎落單送頭。<br />\n2. 想送一個警犬去浩園令民意翻盤依個我暫時有保留；示威者自殺都走左幾個，警犬死會唔會可以翻盤，我覺得唔係咁易。(btw 個人係反對玩死狗)<br />\n3. 金鐘係極適合警犬拉距離打<br />\n4. 綜觀咁多次喺金鐘，催淚彈一次只要放得夠多，暫時都係可輕鬆清場。<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: x-large;\"><strong>詳細行動預測</strong></span></span><br />\n1. 100%係會玩「圍堵」；估計會喺示威者防線50米佈防20個長盾，再喺長盾後200米準備大量防暴，目的令你哨兵只見到20個長盾，而忽略再後面既步署，時間一到多方圍夾。<br />\n2. 可參考612由中信開始用催淚彈步步進迫推到去電車路，721好大機會長盾封埋PP/中環及灣仔方向，全數抄牌加影大頭相。(如民陣遊行路線終點非政總再作討論)<br />\n3. 催眠彈+速龍組合，上幾次都係主要出催淚彈散走大部分示威者，再出速龍驅散；但721我覺得會係出催淚彈，然後速龍係全力衝出黎捉人，而唔係驅散。(避免落單)<br />\n4. 水炮車早前我有開post講過佢既威力，自己小心。<br />\n<br />\n歡迎討論"},"citedBy":0,"replyTime":"2019-07-17T06:49:33.000Z","msg":"邊個再講叫班狗從良同我入來<br />\n<a href=\"https://lih.kg/1324459\" data-auto-link target=\"_blank\">https://lih.kg/1324459</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"387d3a4596fc02ba1836358a1e67464f0dedd97d","tid":1323484,"uid":65089,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T08:10:30.000Z","msg":"721 見"},{"pid":"afa97fd6bcb49e87fdeb6c7f52a46541a6bb0980","tid":1323484,"uid":220853,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T15:51:33.000Z","msg":"點解冇人討論戰術 終院之後應該何去何從?<br />\n向北行ifc同碼頭? 橫街窄巷就會好似旺角/沙田咁"},{"pid":"81aa8c7167cd896166bcd05b83e9c2a66112d9bd","tid":1323484,"uid":259581,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T16:58:52.000Z","msg":"點解依家無人用Laser 嘅？<br />\n<br />\n又輕又方便收藏，又射程遠又可擾敵，而且日頭都可以用"},{"pid":"29087d04b572910ee89ae5dbb19dacd154903773","tid":1323484,"uid":55002,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T17:02:44.000Z","msg":"正經po一定要推<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"2b88e1967246e8cb6607f3a9cd3c4c37c5861474","tid":1323484,"uid":47509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T17:10:12.000Z","msg":"721 人手置頂"},{"pid":"43a47bcfd0bb66acee987866ac5772b78f0af0d5","tid":1323484,"uid":10524,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T17:20:57.000Z","msg":"答案 ：<br />\n咪撚再去金鐘打咪得囉"},{"pid":"e74b53cf9f8240c87dfc7f3077cab06f75e32ac6","tid":1323484,"uid":10524,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T17:21:22.000Z","msg":"1:00銅鑼灣開壇"},{"pid":"f66ab85c92a62304d271967c725df3b40197d28e","tid":1323484,"uid":10524,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T17:21:57.000Z","msg":"民陣一起就集結"},{"pid":"fa903cc8da7a80953954bc171c1e7082bd28b682","tid":1323484,"uid":199727,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-17T19:07:45.000Z","msg":"721見"},{"pid":"98614309eed8d673d75b039c6a40c536f