k%2Fimages%2F6%2F61%2F12898322_1084048031658363_9089008761401386379_o.jpg%2Frevision%2Flatest%3Fcb%3D20160401190004&h=7868de20&s={SIZE}\" />"},{"pid":"f0065f2b542a01a0e722fcb5b9dfa23fa278c055","tid":1798824,"uid":511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-27T12:39:01.000Z","msg":"沒有普選，唯有獨立<img src=\"/assets/faces/pigxm/whip.gif\" class=\"hkgmoji\" />"},{"pid":"8a3e1c0434d8bdeffd226b19f2a37761dedbd56c","tid":1798824,"uid":205927,"like":0,"dislike":0,"score":0,"quote":{"pid":"1cfe5c79ce5f333a552c7ae5fd8af6d3c79e04c5","tid":1798824,"uid":212731,"like":10,"dislike":0,"score":10,"citedBy":3,"replyTime":"2019-12-26T13:44:28.000Z","msg":"本身係暗獨派<br />\n我上個post仲諗緊香港獨立應唔應該講好<br />\n依家諗通左 普選同獨立combine埋一齊講咪得<br />\n<br />\n沒有普選，唯有獨立<br />\n一清二楚<br />\n<br />\n唔使再分化<br />\n兄弟爬山，各自努力<br />\ndealt<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-12-27T12:39:42.000Z","msg":"支持<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />不分化"},{"pid":"8eaa6b7b5906b4b14fea4e37b5f48e0439f7bfbe","tid":1798824,"uid":304845,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-27T12:40:03.000Z","msg":"此回覆已被刪除"}]}