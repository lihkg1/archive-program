"558cdeee28b8332c757a179a92bc749965acf58d","tid":424822,"uid":64181,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T15:55:25.000Z","msg":"係呀我昆人，記得放完買層樓比我睇<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"97b49191f1120396f9d659a8d4830a7db946781c","tid":424822,"uid":64181,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2017-10-27T15:56:13.000Z","msg":"快 d strong hold"},{"pid":"93e6a1566badecef3297df6deb1d46fc2dcddffe","tid":424822,"uid":64181,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-10-27T15:56:44.000Z","msg":"<img src=\"http://static.stheadline.com/stheadline/news_res/2017/09/23/261926/wnnp002p02a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fstatic.stheadline.com%2Fstheadline%2Fnews_res%2F2017%2F09%2F23%2F261926%2Fwnnp002p02a.jpg&h=b22ca6e1&s={SIZE}\" />"}]}