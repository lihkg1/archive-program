assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"cc49477e80dd72918a1e39b2b58f0cf123b6caf5","tid":1197200,"uid":50642,"like":34,"dislike":2,"score":32,"citedBy":0,"replyTime":"2019-06-10T03:54:34.000Z","msg":"巴打唔好塞中環, 金鐘, 旺角, 九龍塘<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"47c5e2a9d193adcfe1f4746f2727f2ce5d868e65","tid":1197200,"uid":5809,"like":9,"dislike":1,"score":8,"citedBy":0,"replyTime":"2019-06-10T03:56:44.000Z","msg":"唔好推埋個喼入地鐵啊<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"61f87d986d32e45b8e86f9edce72a501a36d6c52","tid":1197200,"uid":197637,"like":13,"dislike":2,"score":11,"citedBy":2,"replyTime":"2019-06-10T03:59:02.000Z","msg":"地鐵本身都係咁柒多人架啦<br />\n你要幾多人先塞夠一架呀<br />\n當你塞到半滿最多咪擾民"},{"pid":"a52c0503c61dbf9c8319ebd807d2e17b64ee9fbf","tid":1197200,"uid":167648,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-10T03:59:06.000Z","msg":"琴晚講到而加<br />\n咁熱 係就今日收工一齊涼冷氣"},{"pid":"ddc5497a9eaf0de424d3de53d136b20873721dbc","tid":1197200,"uid":167648,"like":9,"dislike":0,"score":9,"quote":{"pid":"61f87d986d32e45b8e86f9edce72a501a36d6c52","tid":1197200,"uid":197637,"like":13,"dislike":2,"score":11,"citedBy":2,"replyTime":"2019-06-10T03:59:02.000Z","msg":"地鐵本身都係咁柒多人架啦<br />\n你要幾多人先塞夠一架呀<br />\n當你塞到半滿最多咪擾民"},"citedBy":0,"replyTime":"2019-06-10T03:59:44.000Z","msg":"你琴日究竟有冇入去涼冷氣！"},{"pid":"70ce837f8e4a8c47dc0787ee35a9cc589c3a73ef","tid":1197200,"uid":135517,"like":18,"dislike":1,"score":17,"citedBy":1,"replyTime":"2019-06-10T04:02:19.000Z","msg":"廣傳 12號會出黎嘅義仕記住抄呢兩個號碼係手或者背咗佢 侓師電話<br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\"><br />\n26081400<br />\n65499452</span></span>"},{"pid":"1ddeea577d1f785add7c78d5275f44a0b866b0ff","tid":1197200,"uid":84581,"like":8,"dislike":1,"score":7,"citedBy":0,"replyTime":"2019-06-10T04:03:42.000Z","msg":"This might work. Push"},{"pid":"1bc40ec4289bc1eec258a1cc2bfbfb4df32c