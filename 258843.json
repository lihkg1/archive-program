20_8d110bac74d51559c4fa74de40277159.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F125020_8d110bac74d51559c4fa74de40277159.jpg&h=c6a47e06&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/27/125020_26911ad8b7887894c6e0007ef97af0fc.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F125020_26911ad8b7887894c6e0007ef97af0fc.jpg&h=256969df&s={SIZE}\" />"},{"pid":"96732adb5397c5b3366ee3850aac2863eee1e375","tid":258843,"uid":20609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T04:52:59.000Z","msg":"我無join 當地團所以唔清楚！如果巴打唔租車、坐巴士都可以、不過班次疏、要有心理準備！waikiki睇下浪都好舒服、周圍行下relax下都好正！"},{"pid":"e537b7ba192f8ec931ce51bbe7f6b4f153b2f451","tid":258843,"uid":20609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T04:58:10.000Z","msg":"每晚international market place 七點都會有傳統夏威夷舞表演睇、唔錯架<br />\n<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/05/27/125806_47cf9ca4a708bc3d1021e8c22432aeb7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F125806_47cf9ca4a708bc3d1021e8c22432aeb7.jpg&h=b343ab0d&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/27/125808_47cf9ca4a708bc3d1021e8c22432aeb7.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F125808_47cf9ca4a708bc3d1021e8c22432aeb7.jpg&h=83d95e04&s={SIZE}\" />"},{"pid":"9e11e5293c2c114573849440697a5b1fee8609fa","tid":258843,"uid":34701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T05:06:15.000Z","msg":"以毒巴打嘅資料好詳盡<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n真心幫到我plan行程<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n唔該晒你先<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"