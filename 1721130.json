pid":"2d59c99a19fc8f728ef6f5e69f82edc8dd795d2c","tid":1721130,"uid":163149,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-14T15:10:27.000Z","msg":"on9, 曲線唔係咁玩"},{"pid":"2836c480c723f9e970051af2531517353bd454c4","tid":1721130,"uid":69563,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-11-14T15:10:52.000Z","msg":"手足你唔簡單！欽敬！"},{"pid":"544f74e6cce07e78c38f1e335c66bdcd1a0897bb","tid":1721130,"uid":123168,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-11-14T15:11:26.000Z","msg":"就算炒車，其實係好少事。<br />\n一個平時惡貫滿盈嘅仆街，突然間做一件好事，會令你有錯覺自己係咪一路都睇錯佢，無須要將呢件事放大，亦唔需要內疚自己係咪怪錯人。<br />\n721警黑勾結係事實，瞄住頭打細路係事實，無必要情況下開槍打細路係事實！<br />\n總之事實嘅嘢係唔需要懷疑。"},{"pid":"18a7ecee35ec3ea32d8682b65b44c4bd0d3959cc","tid":1721130,"uid":35457,"like":0,"dislike":0,"score":0,"quote":{"pid":"2d59c99a19fc8f728ef6f5e69f82edc8dd795d2c","tid":1721130,"uid":163149,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-14T15:10:27.000Z","msg":"on9, 曲線唔係咁玩"},"citedBy":0,"replyTime":"2019-11-14T15:11:35.000Z","msg":"on9, 曲線唔係咁玩 x2"},{"pid":"02ed63f0f2c90e8b4346e91b31dbf946e4304031","tid":1721130,"uid":37875,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-11-14T15:11:58.000Z","msg":"睇下啦 連登一班傻閪唔睇文架<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"67fd1fd8b9ffb373249f688e7aa5ec8de842d835","tid":1721130,"uid":264192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T15:12:01.000Z","msg":"雖然曲線<br />\n但唔認同<br />\n拉"},{"pid":"3147fc220a27c6570c874c18e4f9371a72b218b3","tid":1721130,"uid":2322,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T15:14:22.000Z","msg":"你憑咩"},{"pid":"6ab662fdd7e77145d8f86c60f63187f37d4735e6","tid":1721130,"uid":71502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-14T15:14:47.000Z","msg":"Good"},{"pid":"48c430580031236978585404a929ec097ecd94c6","tid":1721130,"uid":81531,"like":0,"dislike":0,"score":0,"cite