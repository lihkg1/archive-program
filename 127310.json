assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d94cdd6a752046dec5216169f05e5b6fb793afac","tid":127310,"uid":86288,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-28T11:07:33.000Z","msg":"做乜夏冬<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/35.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/35.png\" class=\"hkgmoji\" />"},{"pid":"b896f3781bda9d56bba0aa619da73f9287fdd8b0","tid":127310,"uid":24006,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-28T11:21:17.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"9d723d3fe8ae69eb377b901649967b3bdf611c26","tid":127310,"uid":54564,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-28T11:57:50.000Z","msg":"幫手推 <br />\n上年我都俾呢間中介拖中介費拖咗半年 8月尾拖到1月先榜水<br />\n<br />\n本身幫個細佬補咗一堂 之後家長話想要個有住hall嘅學生方便d 主動cancel咗我 <br />\n根據中介佢寫嘅規則 理應嗰堂錢我同中介一人一半 (180一堂 一人90)<br />\n之後佢要我過咗兩堂錢360蚊俾佢先 話遲下三十日後先退返嗰270蚊俾我<br />\n咁我過完數諗住ok la<br />\n點知過咗30日就係咁話遲d出遲d出 同事唔記得<br />\n提多兩次就玩唔應機 fb whatsapp inbox全部唔覆 打電話去唔聽 一拖拖咗半年<br />\n後尾揾咗位朋友幫我問下<br />\n<br />\n我朋友扮係想揾補習嘅生導師 問佢好多補習details 中介費點計咁 <br />\n之後問到如果出現我呢單case嘅時候佢會點處理<br />\n最後等間中介答咗嘅時候就攞返我呢單case出嚟問佢 做乜唔俾返d中介費我<br />\n終於令間中介成功出返筆錢俾我<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <br />\n<br />\n垃圾中介<br />\n搞到我依家完全信唔過d中介"},{"pid":"58c9c0a2b86d63bf974f7c5a83e577c8d4af6963","tid":127310,"uid":24513,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-28T12:02:34.000Z","msg":"幫親過 上完第一堂比人炒<br />\n見咁多同類個案 唔知係咪佢地叫家長咁做"},{"pid":"d798e84105884342f101de952993509f01a44dc3","tid":127310,"uid":29197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-28T13:48:52.000Z","msg":"<blockquote>幫親過 上完第一堂比人炒<br />\n見咁多同類個案 唔知係咪佢地叫家長咁做</blockquote><br />\n屌我都係 有兩單都係補完一堂比家長炒"},{"pid":"3df78630c32d15b1e9a075fdecc8c608a80d33b8","tid":127310,"uid":84460,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-28T13:56:49.000Z","msg":"幫推 <br />\n恕我蠢<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> xx係咩"},{"pid":"22f904b1f3062592c1c0f2d6a89abfdfbc483e2e","tid":127310,"uid":29197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-28T14:05:52.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/02/28/220545_28d7e97b452e18ca1aff06c0a8f37bc6.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F02%2F28%2F220545_28d7e97b452e18ca1aff06c0a8f37bc6.jpg&h=47c9f4b3&s={SIZE}\" /><br />\n<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"beda01717f9759018d5518875157b18f161d4757","tid":127310,"uid":30250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-28T15:59:18.000Z","msg":"<blockquote>幫推 <br />\n恕我蠢<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> xx係咩</blockquote><br />\not"},{"pid":"afa16546fe6fd64b501109314f2b638f84c97a15","tid":127310,"uid":86956,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-02T06:11:40.000Z","msg":"<blockquote><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/01.png\" class=\"hkgmoji\" /> <img src=\"/asset