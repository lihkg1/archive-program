/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"6a737bfed2fd793c2e642922d6fa91c42cd03843","tid":759331,"uid":28713,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-29T05:54:40.000Z","msg":"我認為有啲詞填口語無咩問題<br />\n「我哋大家在獅子山下相遇上」<br />\n「我哋」就係香港人<br />\n同咱們（北京人），阿拉（上海人），儂家（福州人），我們（中國人）係有分別<br />\n你唔了解，係你戇鳩"},{"pid":"93ce0abe3e178148fe05a3be03df5ac966b8f05e","tid":759331,"uid":52658,"like":1,"dislike":3,"score":-2,"quote":{"pid":"6a737bfed2fd793c2e642922d6fa91c42cd03843","tid":759331,"uid":28713,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-29T05:54:40.000Z","msg":"我認為有啲詞填口語無咩問題<br />\n「我哋大家在獅子山下相遇上」<br />\n「我哋」就係香港人<br />\n同咱們（北京人），阿拉（上海人），儂家（福州人），我們（中國人）係有分別<br />\n你唔了解，係你戇鳩"},"citedBy":1,"replyTime":"2018-07-29T05:56:43.000Z","msg":"會唔會係你過份解讀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b54f10f9363eee974ac8a13b9a5df67ab3fd569a","tid":759331,"uid":28713,"like":1,"dislike":0,"score":1,"quote":{"pid":"93ce0abe3e178148fe05a3be03df5ac966b8f05e","tid":759331,"uid":52658,"like":1,"dislike":3,"score":-2,"quote":{"pid":"6a737bfed2fd793c2e642922d6fa91c42cd03843","tid":759331,"uid":28713,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-07-29T05:54:40.000Z","msg":"我認為有啲詞填口語無咩問題<br />\n「我哋大家在獅子山下相遇上」<br />\n「我哋」就係香港人<br />\n同咱們（北京人），阿拉（上海人），儂家（福州人），我們（中國人）係有分別<br />\n你唔了解，係你戇鳩"},"citedBy":1,"replyTime":"2018-07-29T05:56:43.000Z","msg":"會唔會係你過份解讀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-29T06:01:09.000Z","msg":"「我哋」大家用艱辛努力寫下那 不朽香江名句<br />\n會唔會係同咱們寫下香江名句一樣呀？"},{"pid":"f603c6697ee80924783d96a63ff01e86a546e9c0","tid":759331,"uid":57460,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-07-29T06:11:58.000Z","msg":"口水歌不知幾琅琅上口，<br />\n係填詞上有難度，因為廣東話有9聲，唔計入聲都有6聲，配合音樂係難，<br />\n但唔好因此就話口語填詞係on9，<br />\n就係因為呢啲口水歌先帶起咗廣東歌呢個文化<br />\n<br />\n<a href=\"https://youtu.be/aAR99yobIB8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FaAR99yobIB8&d=lSILiO91gCnBUF%2B6whAwRC7bS0i5kAixZS1hjGmvpwM%3D&h=32f3bf7a\" target=\"_blank\">https://youtu.be/aAR99yobIB8</a>"},{"pid":"801f59ad1ef181b009757e1fe650c8751766e001","tid":759331,"uid":140738,"like":0,"dislike":0,"score":0,"quote":{"pid":"191d9abc5c61076696c70f121bea0ec98fafe134","tid":759331,"uid":85557,"like":37,"dislike":9,"score":28,"citedBy":1,"replyTime":"2018-07-28T13:45:42.000Z","msg":"過去十八歲　沒戴錶　不過有時間<br />\n夠我沒有後顧　野性貪玩<br />\n<br />\n霎眼廿七歲　時日無多方不敢偷懶<br />\n宏願縱未了　奮鬥總不太晚<br />\n<br />\n然後突然今秋<br />\n望望身邊　應該有　已盡有<br />\n我的美酒　跑車　相機　金錶　也講究<br />\n直到世間　個個也妒忌　仍不怎麼富有<br />\n用我尚有　換我沒有　其實已用盡所擁有<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n不知幾正"},"citedBy":1,"replyTime":"2018-07-29T06:18:21.000Z","msg":"依首係正 但無樓主講嗰啲口語詞<br />\n<br />\n<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /> <br />\n<br />\n覺得口語書面語夾埋無咩問題<br />\n<br />\n例如苦心選中今天想車你回家<br />\n<br />\n依句我都諗唔到書面語應該點寫<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"83d0404e1fe05634e1a80b165729290975fac445","tid":759331,"uid":79403,"like":0,"dislike":0,"score":0,"quote":{"pid":"801f59ad1ef181b009757e1fe650c8751766e001","tid":759331,"uid":140738,"like":0,"dislike":0,"score":0,"quote":{"pid":"191d9abc5c61076696c70f121bea0ec98fafe134","tid":759331,"uid":85557,"like":37,"dislike":9,"score":28,"citedBy":1,"replyTime":"2018-07-28T13:45:42.000Z","msg":"過去十八歲　沒戴錶　不過有時間<br />\n夠我沒有後顧　野性貪玩<br />\n<br />\n霎眼廿七歲　時日無多方不敢偷懶<br />\n宏願縱未了　奮鬥總不太晚<br />\n<br />\n然後突然今秋<br />\n望望身邊　應該有　已盡有<br />\n我的美酒　跑車　相機　金錶　也講究<br />\n直到世間　個個也妒忌　仍不怎麼富有<br />\n用我尚有　換我沒有　其實已用盡所擁有<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n不知幾正"},"citedBy":1,"replyTime":"2018-07-29T06:18:21.000Z","msg":"依首係正 但無樓主講嗰啲口語詞<br />\n<br />\n<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /> <br />\n<br />\n覺得口語書面語夾埋無咩問題<br />\n<br />\n例如苦心選中今天想車你回家<br />\n<br />\n依句我都諗唔到書面語應該點寫<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkg