:0,"replyTime":"2018-04-14T16:02:12.000Z","msg":"我真係未見過有報紙可以用狼狽為奸呢啲字眼<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"606e69004062bd983507e72656a8dd54ef60404c","tid":628934,"uid":42751,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2018-04-14T16:02:13.000Z","msg":"支持蒙古國統一"},{"pid":"7df6f2509a54069ecbfcb2516748fccd57b12aab","tid":628934,"uid":47359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-15T03:04:28.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"18c48db878b150f62a9516508eb370b33a02c58a","tid":628934,"uid":35790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-15T03:09:59.000Z","msg":"大越國 大理國 復國<br />\n支那人回到秦漢前逐鹿中原"}]}