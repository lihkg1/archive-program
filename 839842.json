63386fb1a8f879f0bf659f","tid":839842,"uid":93977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-28T10:37:37.000Z","msg":"連登無人揸的士?<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"f2e9b12ef8b33ac2142092f5272c61c56cc552de","tid":839842,"uid":35746,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-28T10:39:25.000Z","msg":"撞野"},{"pid":"d6cefb9df83ab0fb02a54c5264338b081d518bb5","tid":839842,"uid":28304,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-28T10:48:56.000Z","msg":"睇下你想早定夜<br />\n早更生活正常d<br />\n但搵錢一定係夜<br />\n<br />\nbtw考左牌未<img src=\"/assets/faces/mf/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"62f0e65d18a3d12b017503c21e5020a0f6408673","tid":839842,"uid":28304,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-28T10:52:33.000Z","msg":"同埋做人做狗自己諗<br />\n唔一定揀客/做黑的先搵到食<br />\n識走位先係最緊要<br />\n唔好貪平租舊車（5座位）<br />\n汽錢都係返度<br />\n除非你做泥鯭的計人頭收錢"},{"pid":"5083636a4772396aab2ada08ad96baffda9d63c7","tid":839842,"uid":99805,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2018-09-28T14:10:40.000Z","msg":"識玩：4，5萬<br />\n唔識玩：1萬都未必有"},{"pid":"18c89871acbfa830058b06b468e761d1253c1022","tid":839842,"uid":89801,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-09-28T20:13:31.000Z","msg":"我剩係揸星期日夜晚<br />\n揸到攰 中間會hea 兩三個鐘<br />\n扣返本金 都有800-900蚊落袋<br />\n如果勤勤力力 唔會成日冚旗 唔拒載 過一千蚊唔難<br />\n不過踩足12個鐘真係幾辛苦 所以我一星期揸一日就夠"},{"pid":"9170ac8056ed79482c920f2396005477d7f613e0","tid":839842,"uid":207443,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2018-09-28T21:06:02.000Z","msg":"考牌街名係咪好難？<br />\n租車又點玩法？"},{"pid":"a232c4bc2b6157dec20945911994f598886fde3c","tid":839842,"uid":104513,"like":0,"dislike":1,"score":-1,"quote":{"pid":"9170ac8056ed79482c920f2396005477d7f613e0","tid":839842,"uid":207443,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2018-09-28T21:06:02.000Z","msg":"考牌街名係咪好難？<br />\n租車又點玩法？"},"citedBy":0,"replyTime":"2018-09-28T21:07:23.000Z","msg":"唔係難， 而係好撚難<br />\n<br />\n租車比車行1萬按金再計租"},{"pid":"2d159ad895f01fcd84cfba2f91f525f15f55c446","tid":839842,"uid":112376,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-09-28T21:13:18.000Z","msg":"我揸星期六日替更紅的<br />\n日更就正常啲揸10個鐘 (630am-430pm)，但要早起<br />\n有時攞老特就可以踩耐少少搵多d，多2舊車租個零鐘都返本，同最好搵係人地交更嘅4－6點時間<br />\n我都未算話完全識玩，始終都只係揸左幾個月，但係扣租扣氣淨袋平均一個鐘都有$90-100左右，絕對搵到食<br />\n我都淨係用hktaxi，都未學其他app點玩"},{"pid":"abea1202444d5d5121651fafba0d9c2ec2374c1e","tid":839842,"uid":203036,"like":0,"dislike":0,"score":0,"quote":{"pid":"69d4e7f869016feb79ff4347a0804e304596b425","tid":839842,"uid":44454,"like":16,"dislike":0,"score":16,"citedBy":3,"replyTime":"2018-09-28T08:55:56.000Z","msg":"短程唔做，過海唔做，唔熟路唔做，長程唔做，入機長唔做"},"citedBy":1,"replyTime":"2018-09-29T00:34:12.000Z","msg":"其實點解入機場唔做？識得個朋友老豆揸的士淨係入機場"},{"pid":"289a84d22f96dfc86f430c428914f5858b4c2415","tid":839842,"uid":37458,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-29T00:46:50.000Z","msg":"屌曬所有的士佬屎眼<br />\n<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"1e0b0afca383c43b44389ad0d943a6a476a6277a","tid":839842,"uid":182885,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-29T04:12:22.000Z","msg":"part time DC9 ，一星期一至兩日夜更，覺得好好玩，平均都過千"},{"pid":"022b7c1e9f25368e25ad7dbae16f2b0a9e5f538b","tid":839842,"uid":120850,"like":0,"dislike":0,"score":0,"quote":{"pid":"5c0cfde135dbab96e774300808b7a6e7d4d11b67","tid":839842,"uid":93977,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-28T10:36:42.000Z","msg":"有冇人知一個月搵到幾多錢<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-29T04:24:13.000Z","msg":"三四萬"},{"pid":"a4bf17dfd97cbd6a5156bba5fc3b5de6a9107b4f","tid":839842,"uid":120850,"like":0,"dislike":0,"score":0,"quote":{"pid":"abea1202444d5d5121651fafba0d9c2ec2374c1e","tid":839842,"uid":203036,"like":0,"dislike":0,"score":0,"quote":{"pid":"69d4e7f869016feb79ff4347a0804e304596b425","tid":839842,"uid":44454,"like":16,"dislike":0,"score":16,"citedBy":3,"replyTi