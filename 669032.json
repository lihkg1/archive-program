ke":3,"dislike":0,"score":3,"quote":{"pid":"6088123e0d429460fdefafba62afd5396e5b9abc","tid":669032,"uid":94749,"like":18,"dislike":8,"score":10,"citedBy":2,"replyTime":"2018-05-18T08:54:30.000Z","msg":"呢間垃圾<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n你間唔中食一餐半餐做客梗係開心啦<br />\n佢啲野其實好油膩 好重口味<br />\n間唔中食一次半次係幾好嘅<br />\n至於點解會「平」呢？（其實我都重係覺得好撚貴唔抵人女<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> ）因為好多都唔係新鮮<br />\n要做嘅工序其實真係好少 炒飯又有部炒飯機<br />\n之前試過有客投訴 炒飯少 但收幾十蚊<br />\n個薄餅就最撚hea 你有冇見到個餅成日都好撚樣衰？係因為唔係真係做餅嘅餅底黎<br />\n<br />\n而且間野對員工好差 返全日飲得果2杯野<br />\n其他自己飲水 比較好就係可以係menu上面揀野食<br />\n但都唔係樣樣食得 所以都唔係想像中咁多選擇<br />\n<br />\n利串 朋友做過 表示以後唔會食<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-05-22T02:24:35.000Z","msg":"出街食好多嘢都好油膩<br />\n要健康就唔會揀沙爹王"},"citedBy":1,"replyTime":"2018-05-22T07:23:32.000Z","msg":"搭單問, 如果出街食想健康又方便有咩揀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"182ab2b40b3d67c650805ea28801ab9818330a88","tid":669032,"uid":72173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-22T07:30:02.000Z","msg":"點解你唔問M記點賺錢<br />\n佢24蚊餐<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n平條撚咩沙嗲王"},{"pid":"d8a54a21b0c9425a5a956443690af17cb42c436a","tid":669032,"uid":36434,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-22T08:00:42.000Z","msg":"狗也不屌<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"b73069bd313a4cd5bf6df7381da3c25b2728c3c6","tid":669032,"uid":167042,"like":0,"dislike":0,"score":0,"quote":{"pid":"b9d80929bd046b5b288b3162567acd6d269b6d25","tid":669032,"uid":173939,"like":3,"dislike":45,"score":-42,"citedBy":3,"replyTime":"2018-05-18T06:54:46.000Z","msg":"良心企業，甘多年來都冇點加過價，同吉野家一樣<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-22T08:28:52.000Z","msg":"因為佢一嚟嘅價錢已經支持到佢咁多年唔加價"},{"pid":"7d9cf2158d83ee4ca99360a0fe518cd1c3799212","tid":669032,"uid":