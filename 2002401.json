\"https://na.cx/i/H2KwiRk.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FH2KwiRk.jpg&h=2a44ab52&s={SIZE}\" /><br />\n輕鬆！！！多謝大家！！！"},{"pid":"75921acea979a8712c5282246350f8ef7e3c8436","tid":2002401,"uid":207462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-05T09:51:42.000Z","msg":"未入個post已經估到係李斯<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"e2eed0ae417f6e028777185d259a8c4d7909bdb8","tid":2002401,"uid":137704,"like":0,"dislike":0,"score":0,"quote":{"pid":"b1179c7211e9c70cd3a8317eca669e8ae6b606b8","tid":2002401,"uid":195248,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-05T09:01:57.000Z","msg":"安祿山<br />\n契老母都食 仲要食肥婆食得咁偏"},"citedBy":0,"replyTime":"2020-05-05T09:51:52.000Z","msg":"古代興食肥婆嘛"}]}