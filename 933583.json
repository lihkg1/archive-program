4c30e","tid":933583,"uid":129521,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-08T16:40:34.000Z","msg":"冇練過or飲開係咪淨係飲到苦味<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"74463a81a67d45e9bcce77f328a9e811b7f2b056","tid":933583,"uid":41315,"like":1,"dislike":0,"score":1,"quote":{"pid":"48281c08cae8da455d5eea998189869a7044c30e","tid":933583,"uid":129521,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-08T16:40:34.000Z","msg":"冇練過or飲開係咪淨係飲到苦味<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-08T16:43:06.000Z","msg":"咁要睇沖啡果個有無練過<br />\n<br />\n如果我沖既話，正常發揮之下<br />\n我練開既沖法一向係追甜感<br />\n所以會比較容易飲到 核果類既甜味<br />\n又或者 蜜糖類甜味"},{"pid":"0092651c63da5adc505a334c0f8abfd7517101ac","tid":933583,"uid":214448,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-08T16:54:58.000Z","msg":"入嚟學下嘢<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> 我由上年上過堂workshop就開始自己學下沖<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 手勢嚟講唔知正唔正宗，但過咗期或者開始唔新鮮嘅豆飲落第一啖都真係偏酸/咸，而新鮮豆就好快飲到nuts味，不過可能都同沖法有關<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 同埋而家都係不斷試豆嘅階段，我又無咩偏好，飲落balance就算<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"7503ae9abeac272c5dc776e6e04a0581f5753b2f","tid":933583,"uid":45431,"like":0,"dislike":0,"score":0,"quote":{"pid":"bca4bd4cb2b156e1ee6274e589f0f667894742f0","tid":933583,"uid":29689,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2018-12-08T16:05:22.000Z","msg":"<img src=\"/assets/faces/normal/offtopic.gif\" class=\"hkgmoji\" /> <br />\n巴打即浴咖啡有冇咩推介<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n要無糖無奶<br />\n<br />\n想返工嗰陣飲來續命<br />\n又唔想飲屎水<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-12-08T16:56:36.000Z","msg":"兩個方便既選擇<br />\n一，買部nespresso<br />\n二，去咖啡店買掛耳包"},{"pid":"90938fb2fec398fd08271033aca91fa48f03e41f","tid":933583,"uid":41315