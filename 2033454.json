/Rs0PCKJ.png\" />"},{"pid":"a9103721cd3a92680a153edb8c4dd95a61387ba8","tid":2033454,"uid":51701,"like":2,"dislike":0,"score":2,"quote":{"pid":"30654a482af474dcfc6cc3ed37e7c65e7cb8367d","tid":2033454,"uid":36481,"like":5,"dislike":1,"score":4,"citedBy":1,"replyTime":"2020-05-24T16:13:55.000Z","msg":"你真係痴撚線<br />\n依家中國破壞中英聯合聲明<br />\n英國出手係應該<br />\n殖完民賺完錢唔洗付出代價？<br />\n去到又唔係唔做野<br />\n一係你英國爭返香港返黎囉屌"},"citedBy":0,"replyTime":"2020-05-24T16:17:32.000Z","msg":"<img src=\"https://i.lih.kg/540/https://na.cx/i/Rs0PCKJ.png\" />"},{"pid":"13ddf73c4029a3f84637c8d6f739cedfbbd21360","tid":2033454,"uid":90282,"like":0,"dislike":0,"score":0,"quote":{"pid":"c3bf39cc5ef795a1ac1316db4a4347155a6cafdd","tid":2033454,"uid":316927,"like":0,"dislike":4,"score":-4,"citedBy":3,"replyTime":"2020-05-24T16:12:04.000Z","msg":"唔gur我有BNO牙"},"citedBy":1,"replyTime":"2020-05-24T16:20:17.000Z","msg":"咁撚串?"},{"pid":"ed24d3d0236a8cf2b5e7a6c1ee8c4d5f4ed361af","tid":2033454,"uid":304769,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-05-24T16:22:52.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: x-large;\">BNO平權正視聽</span></span><br />\n連登一向有大量風向L、放負L，睇到BNO平權消息就用<span style=\"color: red;\"><strong>割97後等風向挑撥離間</strong></span>，大家上連登請帶埋個腦。<br />\n<br />\n我從六月開始打英國戰線，希望嚮呢度講幾句。<br />\n第一，BNO平權唔會割97後，因為我地一向都係爭取救<strong><span style=\"color: red;\">BNO及其後代</span></strong>。，除非你係雙非，否則幾乎一定會受惠。<br />\n第二，BNO平權絕對係<span style=\"color: red;\"><strong>同美國行動有關係</strong></span>，故此毫無疑問就係一個救手足之舉，甚至可能與<strong><span style=\"color: red;\">軍事撤僑</span></strong>有關。<br />\n第三，BNO平到權主要唔係用包機包船黎接香港人去英國，亦都冇咩可能會接，畢竟人數太多。平到權最大重點係<span style=\"color: red;\"><strong>BNO變正式英國國民，中共逼害英國國民嘅話，英國以至美國就有理由做野</strong></span>。<br />\n第四，BNO平權估計會寬鬆處理，英屬香港人（BOTC、BDTC、CUKC）無BNO或者已經過期應該都ok。因為英國情報已經判斷香港情況差到似烏干達難民。<br />\n第五，BNO平權大家可以更加無後顧之憂，因為將來要良民證黎移民，可以向英國當局申請。"},{"pid":"d58d6797f8c948d96190e9fe23bbd74ebee588a2","tid":2033454,"uid":258578,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-05-24T16:32:10.000Z",