key 貼係度<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e7297f7ab0794f434fb6f0a38055033ea812794f","tid":466330,"uid":36157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-12T17:13:36.000Z","msg":"3萬幾小時<img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" />"},{"pid":"a3d186cc10b6c720f53792b3503178c4c0ce7b96","tid":466330,"uid":60287,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-12T17:21:18.000Z","msg":"用ghost clone左隻碟唔得咩<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"}]}