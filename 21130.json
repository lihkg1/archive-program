40.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b70cfe8f298b4911a414c0b5036eeb4994845eab","tid":21130,"uid":56377,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-06T04:47:26.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}