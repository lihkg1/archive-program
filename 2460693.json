moji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-25T04:21:31.000Z","msg":"<img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" />"},{"pid":"d81d5be402c155a0fc3db7cc479bbc372c1ba124","tid":2460693,"uid":27122,"like":0,"dislike":0,"score":0,"quote":{"pid":"bfb4a9ba7bb6a9f731b95580ad6c34548e5d127d","tid":2460693,"uid":240362,"like":0,"dislike":0,"score":0,"quote":{"pid":"9ae99b7e5d4731b15450cd4a11adddc8991c21be","tid":2460693,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-25T04:14:33.000Z","msg":"<img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-25T04:21:31.000Z","msg":"<img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-25T04:26:40.000Z","msg":"<img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/lomore_kill.gif\" class=\"hkgmoji\" />"},{"pid":"566364e77d7a7371bef97e6955eceded65e88913","tid":2460693,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-25T04:47:29.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"005fae3a952bcdc5989a06f0beec0796950989b4","tid":2460693,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-25T04:52:48.000Z","msg":"網台主持「傑斯」尹耀昇被指去年在網上節目發表煽動言論，牽涉制裁香港官員、支持民主派35+初選、批評共產黨等內容，上月被控以4項「具有煽動意圖行為」罪，提堂後被總裁判官兼國安法官蘇惠德拒絕保釋。傑斯今向高等法院申請保釋，國安法指定法官杜麗冰聽罷陳詞後，拒絕申請。傑斯隨即被帶離法庭，臨步入囚室前，他與女兒趁機隔着犯人欄緊緊握手，但迅即遭懲教人員分開。<br />\n<br />\n開庭前傑斯步出囚室，精神尚可。旁聽席紛紛舉手跟他打招呼，又向他手比愛心，握拳低喚「頂住」。傑斯看在眼裏，即時觸動情緒，眼淚直流。懲教人員為他遞上紙巾，傑斯禮貌地致謝，然後拉低口罩抹掉涕淚。他又逐一與旁聽人士點頭，並手按胸口，表示領受。<br />\n<br />\n<a href=\"https://hk.appledaily.com/local/20210325/H23T4B3OKFFMLC6N4TNDSAACVQ/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210325%2FH23T4B3OKFFMLC6N4TNDSAACVQ%2F&d=G6FzB8XOFkGMVaf%2BSD5%2FxoRM%2FwdnRWUJBfohchWxIRY%3D&h=a0ac0ad2\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20210325%2FH23T4B3OKFFMLC6N4TNDSAACVQ%2F&h=dab47984\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20210325/H23T4B3OKFFMLC6N4TNDSAACVQ/</a>"},{"pid":"db40b8411c31747ab80ad4901fb875404af8e5f4","tid":2460693,"uid":126919,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-25T04:56:32.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"03fc9fb0b758f4c2279d60cb8a44fb0d5441da2a","tid":2460693,"uid":51752,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-25T07:03:01.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e7a3599f94b02f6425c0698daeb87b54cff11823","tid":2460693,"uid":53498,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-25T07:06:22.000Z","msg":"<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" />"}]}