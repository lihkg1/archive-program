ces/lny/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1fb95453e2e44d29ebfaac40985d7602f93c6bc3","tid":573914,"uid":39728,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-02-27T05:29:37.000Z","msg":"可能以前本身你著緊佢多啲<br />\n到後尾角色調轉左<br />\n佢會更加留意到同埋在意個差距<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"37e2d8aed5decaaea9e800db584119efa6b8db23","tid":573914,"uid":20514,"like":2,"dislike":0,"score":2,"quote":{"pid":"41e0519794a37226c08a513efcddbabe9c89bfcb","tid":573914,"uid":53254,"like":8,"dislike":0,"score":8,"quote":{"pid":"c5cf7e49ac57454ee28093a2ac8eca2b7fd303ad","tid":573914,"uid":20514,"like":55,"dislike":0,"score":55,"citedBy":2,"replyTime":"2018-02-27T03:27:10.000Z","msg":"日夜做　儲的錢　都應該夠<br />\n到聖誕　正好講　跟我白頭<br />\n誰知她開了口<br />\n未能挨下去　已恨我很久"},"citedBy":1,"replyTime":"2018-02-27T05:27:41.000Z","msg":"第一次認真讀呢段嘢 原來咁sad<img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-02-27T05:33:24.000Z","msg":"係呀,首歌D詞好簡單直白,老生常談 , 但毎次聽都有位感動到我<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"20cc8ceeb9698d515c607e903b389967f0592e66","tid":573914,"uid":56626,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-02-27T05:36:35.000Z","msg":"嗰九成係你自己以為做得好啫<img src=\"/assets/faces/lny/smile2.gif\" class=\"hkgmoji\" /> <br />\n用自己角度睇對方既需要係無用既"},{"pid":"2e97b2cca6e4076f748fd872a58455ced883b41d","tid":573914,"uid":81458,"like":13,"dislike":0,"score":13,"citedBy":0,"replyTime":"2018-02-27T05:36:59.000Z","msg":"如果佢對你熱情但你反應冷淡既話個女仔好快都會心淡，正能量呢啲返左工之後其實已經好少會有，自己都唔夠用既時候仲想留俾自己中意既人但佢又冇咩反應都會有少少hurt既。<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n例如滿心歡喜買左份禮物俾對方諗著佢見到會開心，點知真係送既時候對方目無表情仲話唔需要既時候真係會唔太開心<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> 不過呢啲野大家都要講出來先知"},{"pid":"9779db684fdab34a64d47a6b8ca96ef4713422eb","tid":573914,"uid":70350,"like":1,"dislike":7,"score":-6,"citedBy":0,"replyTime":"2018-02-27T05:38:13.000Z","msg":"睇晒你地啲留言，<br />\n有巴打講得岩呀，我都認係我忽略咗情感表達，當然我以後會識做啦。<br />\n另外八年幾，太多細節交代唔到，無論我同佢，都有不是嘅地方，呢個唔再計較亦於事無補。好同意巴打講，你付出嘅唔係對方想要，但係問心反之亦然。<br />\n所以希望大家同另一半要坦誠相對。"},{"pid":"60ae4fcdc47a6b57419d70c36e17be7ef196a70f","tid":573914,"uid":29127,"like":35,"dislike":1,"score":34,"citedBy":0,"replyTime":"2018-02-27T05:38:52.000Z","msg":"我feel到你女朋友有幾唔開心<br />\n其實我諗佢想要既係你回應<br />\n女人對住自己真鐘意既人感性啲<br />\n如果果陣佢等你返屋企<br />\n你當時係微笑，摸摸佢個頭<br />\n佢應該唔會心碎<br />\n我真係feel到你女朋友有幾心酸<br />\n因為佢用盡自己可以做既野維繫段感情<br />\n而且係佢心入面應該比左好多次機會你<br />\n<br />\n岩岩有句:係你始終係就係你<br />\n其實我唔係好認同，好似你唔洗做任何野<br />\n對方鐘意你就返黎<br />\n如果你同以前無分別，點解要同返你一齊<br />\n我都有不安，有傷心，有擔憂<br />\n係好愛你，但唔再敢同你一齊<br />\n<br />\n利申 7年 已分手"},{"pid":"01f41dfeafe7cd1d549428df681840e90d0e2a04","tid":573914,"uid":37675,"like":0,"dislike":0,"score":0,"quote":{"pid":"4bb46971fb5d32bf4ab34c246edd5b564b213553","tid":573914,"uid":70350,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-27T02:22:43.000Z","msg":"我同女友喺讀大學時認識，初初同佢一齊嘅時候，佢抱住玩玩下嘅心態，最後比我誠意打動，認真同我講佢以後會好好對待呢段關係。<br />\n<br />\n從嗰次開始，我嘅世界只有佢，學業、朋友等等我都放喺第二位，頭幾年佢間唔中都會發脾氣講分手，雖然好攰好唔開心，我亦曾經叫自己放棄，但係最後我都堅持落去，因為我愛佢。<br />\n<br />\n過咗四年幾，我同佢開始同居。雖然大家生活習慣有啲唔同，但係大家互相遷就下都生活得好開心。<br />\n<br />\n同居生活過咗四年，到近幾個月發現佢開始對我冷淡。一個月前同佢傾過，原來有啲野佢一直唔鍾意我咁做而我又冇理過，例如我表現冷淡，對佢一啲甜密嘅舉動冇乜反應，佢上堂親手整禮物比我，我亦表現冷淡，去旅行冇幫手計劃行程。<br />\n<br />\n係我唔好，一齊耐咗，工作忙經常加班，漸漸忽略咗生活上嘅情趣，所有野變得理所當然。以上佢指控我嘅事，係我嘅錯。<br />\n<br />\n原來，我表現出黎對佢嘅愛並唔係佢想要嗰種。衣食住行，我自問照顧周到，對佢好過對我自己。但係我自以為做得好，忽略咗更多嘅細節。<br />\n<br />\n呢一個月，我嘗試做番好多已經冇做嘅野去挽回佢，可惜最終都係冇用。<br />\n<br />\n近呢一年，我開始想結婚，慢慢儲緊錢規劃我地嘅將來。諗唔到，已經冇咁嘅需要。<br />\n<br />\n我唔想再同你計邊個付出咗啲乜，就算我九成做得幾好都好，剩低嗰一成你唔滿意始終都係冇用。最後，祝你幸福，保重。"},"citedBy":0,"replyTime":"2018-02-27T05:40:56.000Z","msg":"放手 放開所有<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"8e00fea875a8133ceeab940f21fe87d2ea273b4f","tid":573914,"uid":173484,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-02-27T05:51:39.000Z","msg":"同巴打差唔多case 一齊左七年幾 中學開始一齊 中學大學圈子都一樣 最近都差啲分手 因為我冇乜點俾驚喜佢同帶佢周圍去 所以依家開始的起心肝 差唔中買啲野俾佢 帶佢去啲未去過既地方 雖然好似要專登去做啲野去合符佢既要求 但想留住佢就要咁做<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9a7ab42ed45fb9f73905873f9ade8959851d9f64","tid":573914,"uid":72952,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-27T05:56:49.000Z","msg":"拉著妳的手，我用力握緊， 我有些不冷靜，因為我知道要失去妳。 <br />\n時間不留情，，歲月不饒妳 妳說青春已用盡，現在該選擇放棄， <br />\n妳曾說另一個人，比我用心，比我体貼，更懂溫柔，妳也想要有人更愛妳， <br />\n後悔當時沒有，及時反應，妳的不安，擁抱著妳，把妳給我的也給妳，<br />\n為何總要等到，最後一刻，無法挽留，我才明白，最寶貴的是妳的真心 <br />\n<span style=\"color: red;\">原來愛不是前世註定，原來愛也需要回應。</span> <br />\n所以我求求妳，別讓我離開妳，除了妳我不能感到一絲絲情意 <br />\n望著妳背影，看不見表情 我知道有些話，現在只能感動自已 <br />\n心甘不情願，因為傷心出賣了，自已 <br />\n眼淚不會說謊，全世界我只在乎妳 任時光匆匆留去，我只在乎妳﻿"},{"pid":"ac4ea5a8dd80bee32c2016b0de23caeae9e78383","tid":573914,"uid":61688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-27T05:59:51.000Z","msg":"抵撚死啦<br />\n唔識得珍惜，人地先會8年感情都要斬欖"},{"pid":"ddfc2a966095f55aa37f690e3a803dca0b492e9d","tid":573914,"uid":164439,"like":4,"dislike":10,"score":-6,"citedBy":2,"replyTime":"2018-02-27T06:05:09.000Z","msg":"追完post，都唔知是我怪定有代溝，我好難同意「淡」同「一齊唔sweet唔開心」就是分手藉口。結婚過人世真係咁sweet咁開心咩？我諗到既全部都是煩惱同困難呀。唔開心唔sweet就離婚搵下一個呀？<br />\n<br />\n呢個世界是咪冇「你不放下我，我不放下你」既感情。<br />\n<br />\n我可以好肯定既係，愛一個人，受難都是sweet。"},{"pid":"4531d5ffa0fd4cb0d8d65ea855a316fc2ca038b3","tid":573914,"uid":96728,"like":7,"dislike":0,"score":7,"quote":{"pid":"ddfc2a966095f55aa37f690e3a803dca0b492e9d","tid":573914,"uid":164439,"like":4,"dislike":10,"score":-6,"citedBy":2,"replyTime":"2018-02-27T06:05:09.000Z","msg":"追完post，都唔知是我怪定有代溝，我好難同意「淡」同「一齊唔sweet唔開心」就是分手藉口。結婚過人世真係咁sweet咁開心咩？我諗到既全部都是煩惱同困難呀。唔開心唔sweet就離婚搵下一個呀？<br />\n<br />\n呢個世界是咪冇「你不放下我，我不放下你」既感情。<br />\n<br />\n我可以好肯定既係，愛一個