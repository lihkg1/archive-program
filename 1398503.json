5%8F%8A-%E6%9A%B4%E5%8B%95%E7%BD%AA-%E9%81%95%E6%86%B2%2F&d=JkVIzhDRZadGdMc0KemjDWWYsxP5Z0Wle18NOkmjjC4%3D&h=6a7c26fa\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%E8%A2%AB%E8%A3%9C%E7%BE%A9%E5%A3%AB%E6%87%89%E7%9B%A1%E5%BF%AB%E6%8F%90%E8%AB%8B%E5%8F%B8%E6%B3%95%E8%A6%86%E6%A0%B8-%E6%8C%91%E6%88%B0-%E9%9D%9E%E6%B3%95%E9%9B%86%E7%B5%90%E7%BD%AA-%E5%8F%8A-%E6%9A%B4%E5%8B%95%E7%BD%AA-%E9%81%95%E6%86%B2%2F&h=3e9a2eae\" data-auto-link target=\"_blank\">https://thestandnews.com/politics/被補義士應盡快提請司法覆核-挑戰-非法集結罪-及-暴動罪-違憲/</a>"},{"pid":"7800d63b3bb0fcdf4184939939d8cefae00e5c8d","tid":1398503,"uid":287311,"like":1,"dislike":0,"score":1,"quote":{"pid":"b82ff8657ceec3cae72ff77f1faa7a7fdd639eea","tid":1398503,"uid":123870,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-05T10:31:31.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-08-05T16:29:04.000Z","msg":"有無source or 案例？求教，搵唔到<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"594fcd401b78616e9fb806c5a956b519bb588181","tid":1398503,"uid":62226,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-05T16:30:38.000Z","msg":"第一要錢，一告就一定要預咗會上到終審"},{"pid":"5eb86a56458c0c72c59d36a248efe8b7ab93001e","tid":1398503,"uid":132217,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-05T16:36:05.000Z","msg":"推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}