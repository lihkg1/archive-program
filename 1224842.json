ces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"f42678a0fc632b47ae468f201ff2d3b39a6cae0c","tid":1224842,"uid":259121,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T06:39:35.000Z","msg":"推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"9a02251e23b0196ddb3a5d6b5c924f6217c31e79","tid":1224842,"uid":209738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T06:40:20.000Z","msg":"下一步應該係想辦法來名正言順地主動「結束」這個法案"},{"pid":"09c49e8f1f1ca55d119307855c6323ca19e0fcfd","tid":1224842,"uid":37933,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-06-15T06:40:36.000Z","msg":"好簡單<br />\n之前話暫緩唔搞住叫收貨<br />\n係因為冇話打到人仆街<br />\n今次仲有人生死未卜 暫緩點收貨？"},{"pid":"eaf03cf2ac4c495d571fc6291b179fcd0194a150","tid":1224842,"uid":78420,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-15T06:43:05.000Z","msg":"要救埋班老師，別被秋後算帳！"},{"pid":"1111bb1086a551476538ed9ff5cf342614db5ef1","tid":1224842,"uid":260744,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T06:51:26.000Z","msg":"直線抽擊"},{"pid":"c97af7d9a6ffc9d5fe4923acb5e68d6a4808922c","tid":1224842,"uid":138233,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T06:57:32.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"3f4c9e97dbf884949729df00a0b8018a1cad7cc7","tid":1224842,"uid":50937,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-15T06:59:07.000Z","msg":"推"},{"pid":"963a0e4d94a6ce2f5058cb6cd53b32732e3aa107","tid":1224842,"uid":22585,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-15T07:00:21.000Z","msg":"睇得出才子好撚嬲<img src=\"/assets/faces/normal/sosad.gif\" c