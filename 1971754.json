:0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-04-14T15:36:03.000Z","msg":"推"},{"pid":"099dcde541eaacc080ad82aea5f5ea80b95165ae","tid":1971754,"uid":172303,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-04-14T15:37:04.000Z","msg":"法治已死"},{"pid":"572ba30960386f27e5abb8bc6c94a84a6682ac41","tid":1971754,"uid":38177,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-04-14T15:40:43.000Z","msg":"罪犯法官？龍門任搬"},{"pid":"82e0ec6ef10d130ce1f17e86ea996d469f4342e5","tid":1971754,"uid":153811,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-04-14T15:44:28.000Z","msg":"終院應該可以dq 佢"}]}