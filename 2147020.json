r-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.etnet.com.hk%2Fwww%2Ftc%2Fnews%2Ftopic_news_detail.php%3Fcategory%3Dspecial%26newsid%3D9554%26part%3D1&d=SXj%2FfRDdIS6Y9psqMYminONdVtVfIexd6qH9K0u6Sk4%3D&h=03cec594\" data-auto-link target=\"_blank\">http://www.etnet.com.hk/www/tc/news/topic_news_detail.php?category=special&amp;newsid=9554&amp;part=1</a>"}],"pinned":{"pid":"d265e81051f4383c8b348cb4b586f7f35f22a39f","tid":2147020,"uid":132898,"like":1,"dislike":3,"score":-2,"citedBy":1,"replyTime":"2020-08-09T04:04:49.000Z","msg":"其實真係有得諗 重可以保留香港人語言同文化唔洗俾人洗腦<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}}