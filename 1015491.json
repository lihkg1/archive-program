es/lny/clown4.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/clown3.gif\" class=\"hkgmoji\" />"},{"pid":"cf5b3c201a9f94e68c82131822e52f7b108391db","tid":1015491,"uid":3434,"like":1,"dislike":3,"score":-2,"citedBy":0,"replyTime":"2019-02-11T08:21:04.000Z","msg":"<img src=\"/assets/faces/normal/yipes.gif\" class=\"hkgmoji\" />"},{"pid":"75efdab5b4bc51eb9705b8ab92a0586bb7f841b7","tid":1015491,"uid":182325,"like":1,"dislike":2,"score":-1,"citedBy":1,"replyTime":"2019-02-11T08:25:27.000Z","msg":"中出即飛咪得囉<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"df314852ed6f3a22d38ea7757520f4fdbc8e74a6","tid":1015491,"uid":126763,"like":22,"dislike":0,"score":22,"quote":{"pid":"a78e4192f065ed4788e336d3a318f203f3d86005","tid":1015491,"uid":6222,"like":226,"dislike":10,"score":216,"citedBy":4,"replyTime":"2019-02-11T07:04:20.000Z","msg":"係咪發覺自己見識少好失禮人呢<img src=\"/assets/faces/lny/hehe.gif\" class=\"hkgmoji\" /> <br />\n<br />\n人地同屋企人年年去2次旅行<br />\n<br />\n你就連返大陸都有困難<img src=\"/assets/faces/lny/369.gif\" class=\"hkgmoji\" /> <br />\n<br />\n上到人地屋企見到咁大間屋係咪嚇親你<img src=\"/assets/faces/lny/@.gif\" class=\"hkgmoji\" /> <br />\n<br />\n自己間公屋又細又有癡線佬係隔離鳩叫<br />\n<br />\n收手啦公屋仔<img src=\"/assets/faces/lny/banghead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n係咪想比人笑到面黃<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-02-11T08:30:32.000Z","msg":"私樓仔千其唔好溝豪宅妹...之前同條女去歐州滑雪 我咁大過仔第一次去滑 佢同d frd個個都5歲開始 每年都滑幾次<img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" />"},{"pid":"c424dc80c15afe8422bc0df99071b3caeebc945b","tid":1015491,"uid":209097,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-02-11T09:01:23.000Z","msg":"唔係公屋仔唔喺到私樓妹就會簡樓主你<img src=\"/assets/faces/lny/pig2.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lny/pig2.gif\" class=\"hkgmoji\" />"},{"pid":"95561eb1b6172d35dfe266f174be5ad102bb7b9c","tid":1015491,"uid":22148,"like":50,"dislike":1,"score":49,"quote":{"pid":"0d22750e293034e4a62ffc3ea5c90056923ff63b","tid":1015491,"uid":105366,"like":0,"dislike":6,"score":-6,"quote":{"pid":"ab21d935e0a7e7a79fcd6d566d68fc3f3d5eaef2","tid":1015491,"uid":22148,"like":60,"dislike":3,"score":57,"quote":{"pid":"7c8a1d0c72f36d6dd470bc68038c70770e5f3c29","tid":1015491,"uid":105366,"like":10,"dislike":21,"score":-11,"citedBy":1,"replyTime":"2019-02-11T07:29:18.000Z","msg":"結婚十八年<br />\n公屋仔大，老婆係私樓妹。<br />\n有乜問題？"},"citedBy":3,"replyTime":"2019-02-11T07:42:17.000Z","msg":"唔係你老婆肯嫁你，你仲係公屋仔..<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-11T07:51:50.000Z","msg":"我未聚佢之前已經唔係住公屋<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-02-11T09:11:50.000Z","msg":"訓街？<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n好心你啦，你結咗婚18年，當年2000年頭，果時香港邊有而家咁貧富不均？果時想上車有幾難？成個環境都唔同... 你睇唔明樓主想表達咩？<br />\n2000年頭，我剛剛升中學，公屋仔，當時經濟係差，但至少無乜住屋問題.. 邊有公屋/私樓之分？<br />\n<br />\n係呢幾年，樓市升到痴咗線，d後生仔創作咗好多「住私樓食雞脾」黎諷刺香港.. 資產嘅增值令好多人覺得公屋私樓嘅階層分明咗，5/600呎私樓至少值7/800萬，咪令人睇唔起公屋仔..<br />\n<br />\n私樓仔女，就算得1間，阿爸肯按下層樓都有錢俾首期，公屋？<br />\n<br />\n我都係公屋仔，30出頭，2017買樓，層樓我同老婆儲咗6年錢買.. 但我唔覺得自己叻，因為生活負擔堅大。<br />\n<br />\n但我最灰心係政府根本無打算幫年輕人，最後得3種人上到車，1父幹，2能力堅高，3早幾年膽粗粗入市（80頭，呢班人最黑人憎）<br />\n<br />\n長遠下去，呢d labelling effect 只會越來越大.."},{"pid":"c0564f60a9e3e5baacabc12adb40d506039c0a67","tid":1015491,"uid":29606,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-11T09:17:40.000Z","msg":"此回覆已被刪除"},{"pid":"1f12b3d5c21b2712e0b7bf011823dd3fdba0b036","tid":1015491,"uid":203814,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-02-11T09:38:16.000Z","msg":"居屋同私樓差距大唔大？"},{"pid":"b70c15bbd060d79e9fa77bcb6abaf3526deede21","tid":1015491,"uid":158613,"like":0,"dislike":1,"score":-1