agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"98e6fd698afca7bc6780d341bd062e6382caa040","tid":1082562,"uid":54337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-29T04:55:50.000Z","msg":"等睇9錢1心巴打入嚟<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"307abb67a1718acdc8d0faf0313915c9d6f25846","tid":1082562,"uid":53672,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-29T04:56:26.000Z","msg":"警隊高層震怒<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"55767f80a0786656a51fd1828156eb717177bed0","tid":1082562,"uid":227089,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-03-29T04:57:07.000Z","msg":"此回覆已被刪除"},{"pid":"ebed849cc9e1c9886e3ef5c3388f14529ba12198","tid":1082562,"uid":54337,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-03-29T04:58:04.000Z","msg":"<img src=\"https://static.appledaily.hk/images/apple-photos/apple/20190329/large/a1201a.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fapple-photos%2Fapple%2F20190329%2Flarge%2Fa1201a.gif&h=8ab10ea1&s={SIZE}\" /><br />\n前高級督察李士鳴否認盜竊罪受審<br />\n<br />\n李sir<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n掛靴名宿"},{"pid":"52b73ebaf872df6a33ebb97346e62029e2edd323","