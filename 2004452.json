\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6af73cb0c2194224fee4c5f7951b825135a45664","tid":2004452,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-06T14:44:52.000Z","msg":"推post推post推post"},{"pid":"fbd8f1f0bb8b8167820f2d2ef97da7f55f698789","tid":2004452,"uid":70487,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-06T14:48:14.000Z","msg":"本土文化好重要<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n<div style=\"text-align: right;\">香 港 國 寶 ： 許冠傑<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1973620\" data-auto-link target=\"_blank\">https://lih.kg/1973620</a></div>"},{"pid":"122c4e3359830d1ac735f3758977ca55bdd0c780","tid":2004452,"uid":62226,"like":0,"dislike":0,"score":0,"quote":{"pid":"24d05428055dd29356f008dbdd9d250a60ae968f","tid":2004452,"uid":59297,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-06T14:39:19.000Z","msg":"其實講實際方法好難講<br />\n<br />\n人哋咁短條片，又要曲線咁講點講<br />\n<br />\n討論35+攬炒實際點做，開節目講兩個鐘都講唔完啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-05-06T14:51:08.000Z","msg":"實際方法應該貴過廿萬<br />\n泛民俾廿萬都係只可以問到星期五個內會嘅法律意見<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f16af89af749fa625009570050ec66715e9bf135","tid":2004452,"uid":31637,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-05-06T15:25:20.000Z","msg":"唔見得本土派都有執政意志<br />\n蟲泰玩國旗比元秋嚇2嚇就鳩都縮埋<br />\n黃洋達收死亡恐嚇後就唔敢再叫打倒共產黨<br />\n而家好撚明顯就係由緊班好撚怕死既人掌控緊垃圾會"},{"pid":"a2987be3f53b45d51eaeaba385328a877f2333b0","tid":2004452,"uid":31637,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-06T15:28:23.000Z","msg":"要有執政意志，最低門濫要好似梁天琦等新生代咁既級數"}],"pinned":{"pid":"5e9e3f0a4ee985e2abd9b8f26071174232476b3c","tid":2004452,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-05-06T16:41:34.000Z","msg":"本土派要提上國際層面，係我角度有兩個方法<br />\n第一個最難，自立一戶話比人聽香港仲有一個pro-indigenous parties<br />\n咁就名正言順，但係會令到歐美各國消息混亂唔知支持邊一個勢力<br />\n<br />\n第二個就係我地將pro-democracy parties呢個名用風頭蓋過泛民<br />\n比外國知道香港親民主派最強既一支就係本土派<br />\n咁樣到時有本土派接掌權力既機會會大左好多"}}