h.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmY6zfG1.jpg&h=2872a6ba&s={SIZE}\" />"},{"pid":"413363fa4a9acb5d47a12517f2a7a7f5126a9fcf","tid":1910870,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-13T02:26:43.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"e6e93e7cd8fa403bfa67d9c69ed7f909d73c1cae","tid":1910870,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-13T02:39:20.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"15e7a2b459ff9f1bb1b7e004cfe9a4c218f869b7","tid":1910870,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-13T03:06:35.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"ed730b5df9a4719cdd7f61c37a8443edce153022","tid":1910870,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-13T03:37:49.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"e0388fe0ae885a80fa9978aadd3de662574aae10","tid":1910870,"uid":38109,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-13T03:38:25.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"7ac954de9b07e90673862fc4ffeb0ad71a0f209b","tid":1910870,"uid":52090,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-13T04:21:40.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"bfd3371f4bed43b089e470c2d6e0e547b2f9189b","tid":1910870,"uid":242262,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-13T04:32:22.000Z","msg":"向職工會登記局申請的時候，申請表上須寫上工會成立日期。換句話説，只要你的工會在今年&nbsp;5 月 2 日前成立 (須 30 天內申請登記)，保存運作證明(例如成立時的會議紀錄丶工會登記的申請表副本)，並趕及明年 5 月 2 日前正式完成登記刊憲，就可登記為選民。留意，正式完成登記刊憲前，工會絕大部分運作也是禁止的，基本上只可做與登記工會相關的時宜，你可定期內部開會跟進並向政府查詢登記進度，保存相關證明。<br />\n<br />\n<a href=\"https://www.thestandnews.com/politics/%E5%8B%9E%E5%B7%A5%E7%95%8C%E6%9C%80%E6%96%B0%E6%88%B0%E6%B3%81%E5%88%86%E6%9E%90/\" data-s