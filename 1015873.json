d9db3cbc3a09fae42f555da6327e161914d6","tid":1015873,"uid":53026,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-10T12:08:15.000Z","msg":"XYZ<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"cd1e6d31d82e60cf7bb27892f889debabb67f554","tid":1015873,"uid":41524,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-02-10T12:09:48.000Z","msg":"23歲<br />\n年輕一輩都咁垃圾"},{"pid":"443ef885b49eee5345a130ddc98fb4d2cec3ab28","tid":1015873,"uid":18251,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2019-02-10T12:35:21.000Z","msg":"屈佢藏毒啦屌"},{"pid":"b841978ffb93fa54e7e5d032d50cb8bfc0205780","tid":1015873,"uid":37502,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-02-10T12:48:24.000Z","msg":"蝗vs蠙<img src=\"/assets/faces/lny/smile2.gif\" class=\"hkgmoji\" />"},{"pid":"8a1ac0881b7b734e2fd6dd41eea337b8879f6c7c","tid":1015873,"uid":209225,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-10T12:55:05.000Z","msg":"今次我撐你！"},{"pid":"b6a5c5a484682901f5d39c98f0802fb5164ab2d1","tid":1015873,"uid":124107,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-10T13:12:03.000Z","msg":"此回覆已被刪除"},{"pid":"567057664db74e1644894dcf41ffb16392766776","tid":1015873,"uid":21545,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-02-10T13:22:22.000Z","msg":"菲律賓&gt;支那<img src=\"/assets/faces/lny/smile2.gif\" class=\"hkgmoji\" />"},{"pid":"c2fd7f87e6470cf668428f35e48f313a05debc5e","tid":1015873,"uid":16193,"like":0,"dislike":6,"score":-6,"citedBy":0,"replyTime":"2019-02-11T08:23:52.000Z","msg":"今次支持大陸妹。<br />\n<br />\n平時班大陸人唔守秩序固然人人喊打，但菲律賓無理囚禁香港人，屈佢地販毒，令人齒冷，呢位大陸妹為大家出了一口氣，大家理應支持！<br />\n<br />\n我認為，應該<strong>即時驅逐所有菲律賓人出境<br />\n自己家務自己做！</strong>"}]}