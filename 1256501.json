14c3e48b2f92f65e99979349178e","tid":1256501,"uid":97716,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T06:36:15.000Z","msg":"Canceled"},{"pid":"53cf618eaf670ea0c48f61a16cf7fbd81c53127c","tid":1256501,"uid":119033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T06:36:24.000Z","msg":"Push"},{"pid":"ef51c3adce83f9863c68b909575cecc88e5e2f69","tid":1256501,"uid":49695,"like":0,"dislike":0,"score":0,"quote":{"pid":"fca4a9d4bef88dcd9ac206a2c4ed110de5f766b4","tid":1256501,"uid":104333,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-25T06:34:18.000Z","msg":"取消咗喇"},"citedBy":0,"replyTime":"2019-06-25T06:37:07.000Z","msg":"firm?"},{"pid":"211f737c951a1584cb05aedf82f92efc2124cf1f","tid":1256501,"uid":21849,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T06:37:16.000Z","msg":"怕到取消左！！ 取消埋右！！！"},{"pid":"a3ea68d8d0179fc2869118f892f0e14479f4b91f","tid":1256501,"uid":175481,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-25T06:41:35.000Z","msg":"<a href=\"https://www.info.gov.hk/gia/general/201906/25/P2019062500410.htm\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.info.gov.hk%2Fgia%2Fgeneral%2F201906%2F25%2FP2019062500410.htm&d=DgFN9ivcdgICzBQxXV443vtobIAPz7vP9zHpdy2ENqg%3D&h=91bbec2a\" data-auto-link target=\"_blank\">https://www.info.gov.hk/gia/general/201906/25/P2019062500410.htm</a><br />\n<br />\n區議會選舉活動建議指引公眾諮詢大會取消<br />\n＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊＊<br />\n下稿代選舉管理委員會發出：<br />\n <br />\n  選舉管理委員會（選管會）經風險評估後，基於公眾安全和保安考慮，決定取消原定今日（六月二十五日）晚上七時至九時在香港鰂魚涌基利路1號鰂魚涌社區會堂舉行的區議會選舉活動建議指引公眾諮詢大會。公眾人士請不要前往公眾諮詢大會。巿民可就建議指引內容提供書面意見。<br />\n <br />\n        選管會發言人表示：「選管會舉辦公眾諮詢大會並邀請巿民出席發表意見，需要考慮場內所有參與者的安全。經風險評估，選管會決定取消今日的公眾諮詢大會。」<br />\n <br />\n  建議指引的公眾諮詢於六月十一日展開，至七月十日結束，為期三十日。巿民可就建議指引內容提供書面意見。<br />\n <br />\n  市民可以在七月十日或之前，把書面意見郵寄到香港灣仔港灣道二十五號海港中心十樓選管會秘書處，亦可透過傳真（2511 1682）或電郵（eacenq@eac.hk）遞交。逾期遞交的意見將不予考慮。<br />\n <br />\n  如有查詢，請致電2891 1001。 <br />\n <br />\n完<br />\n2019年6月25日（星期二）<br />\n香港時間14時15分"},{"pid":"a29d1bff81df1d77dec1f36c6196d1d23678b6ba","tid":1256501,"uid":153329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T06:42:02.000Z","msg":"推"},{"pid":"943e4f8399366dbfb7b0e3f0f98a1d51a8a6cb03","tid":1256501,"uid":153329,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-25T06:42:13.000Z","msg":"推"},{"pid":"2cc7a208588a137e8729aa42b76fd923b17ae3a2","tid":1256501,"uid":212182,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T06:42:36.000Z","msg":"push"},{"pid":"eb11002f1750372b911d7f8615d4d2735e5ef0dd","tid":1256501,"uid":38461,"like":1,"dislike":0,"score":1,"quote":{"pid":"943e4f8399366dbfb7b0e3f0f98a1d51a8a6cb03","tid":1256501,"uid":153329,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-25T06:42:13.000Z","msg":"推"},"citedBy":0,"replyTime":"2019-06-25T06:42:48.000Z","msg":"取消咗呀屌你"},{"pid":"5c5ae2c332cd4f3ff50bd8e82020c0169467bb33","tid":1256501,"uid":15835,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T06:59:35.000Z","msg":"取消咗啦，仲推 <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"903e24026cff777459cf63157d57dd6998031e12","tid":1256501,"uid":172826,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T07:01:15.000Z","msg":"市民可以在七月十日或之前，把書面意見郵寄到香港灣仔港灣道二十五號海港中心十樓選管會秘書處，亦可透過傳真（2511 1682）或電郵（eacenq@eac.hk）遞交。逾期遞交的意見將不予考慮。"},{"pid":"1bb61f59cbd9796e8a7cf3c43f11bab5501c3636","tid":1256501,"uid":69064,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T07:02:30.000Z","msg":"打"},{"pid":"a6cbfebf819b8e97e7fdc73cb7384d8fd7961ace","tid":1256501,"uid":170988,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T07:03:09.000Z","msg":"cancel咗了喎，好似"},{"pid":"eaecfa64f010907961b9b58aae6eea40ec5b96b6","tid":1256501,"uid":241224,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-25T07:03:53.000Z","msg":"推"},{"pid":"bfbe62cf1f7ad7f81f20b21541e27ccee1dafff6","tid":1256501,"uid":9193,"like":0,"dislike":0,"score":0,