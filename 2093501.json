d":2093501,"uid":187201,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-04T03:16:19.000Z","msg":"推"},{"pid":"2716275ed54c86bf27294e75a9b73cf8e5f01880","tid":2093501,"uid":55955,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-04T03:19:09.000Z","msg":"Wire呢"},{"pid":"032c98ef33564d7fffd5d527fc840ae5fe01dfcd","tid":2093501,"uid":50588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-04T03:21:13.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f60239f5772a94e8dccda7966ee536280ef08bb3","tid":2093501,"uid":86509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-04T03:24:10.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"506789261eafb45417940ac85816e34adb3c3679","tid":2093501,"uid":56107,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-04T03:24:34.000Z","msg":"其實end-to-end encryption係防止個app / service偷你資料<br />\n如果你唔擔心service俾你資料去政府，或者你講嘅野本身就人人都睇到(即係公海 / channel)，咁有無end-to-end encryption都無分別。"},{"pid":"f9aa22c7cc3df366df9fbf0be5a7bb020f157a0f","tid":2093501,"uid":263197,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-04T03:27:31.000Z","msg":"留名"},{"pid":"4742550ce7ab1a2039dd5664992fbc08bcb57223","tid":2093501,"uid":131691,"like":0,"dislike":0,"score":0,"quote":{"pid":"2716275ed54c86bf27294e75a9b73cf8e5f01880","tid":2093501,"uid":55955,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-07-04T03:19:09.000Z","msg":"Wire呢"},"citedBy":0,"replyTime":"2020-07-04T03:28:38.000Z","msg":"2019年Wire俾一間美國公司買咗，同時有成USD 8mil風險投資<br />\n同一間Morpheus Ventures持有成堆保險同語音AI，所以Wire應該係入咗個大數據黑洞"},{"pid":"e990b7fa8253f5b01cc851f61bf078c6b725287d","tid":2093501,"uid":131691,"like":0,"dislike":0,"score":0,"quote":{"pid":"506789261eafb45417940ac85816e34adb3c3679","tid":2093501,"uid":56107,"like":0,"di