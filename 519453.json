pid":"abed49c51954b5e3e54e275063b875fc379fa510","tid":519453,"uid":51594,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-01-07T13:44:42.000Z","msg":"屌你老母25卡勞<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 睇標題以為有麻友圖先入泥<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />  點能知乜都冇<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"}]}