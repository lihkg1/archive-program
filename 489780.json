 data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F05%2F141548_c8dadcd7103fcbe6a136347fcf400b76.jpg&h=8494f362&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2017/12/05/141549_64d2500cf060554dbbf777c6b96ddf9b.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F05%2F141549_64d2500cf060554dbbf777c6b96ddf9b.jpg&h=6cbf7b40&s={SIZE}\" /><br />\n<br />\n或者<br />\nCanon EF 1200mm f/5.6 L USM <br />\n<img src=\"https://img.eservice-hk.net/upload/2017/12/05/141626_53068f07824e060479e48a7f0a555fcf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F12%2F05%2F141626_53068f07824e060479e48a7f0a555fcf.jpg&h=01fa8e63&s={SIZE}\" />"},{"pid":"c7ab2bd3060122398f650a3508fc500970db00a7","tid":489780,"uid":79870,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-05T08:28:18.000Z","msg":"上面位巴打唔好咁啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cfa8f28dc89b1b2de6770a24e96010162890109f","tid":489780,"uid":10509,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-05T08:37:13.000Z","msg":"a6000"},{"pid":"ce6402f62fd5ac07588953aac6b46159c40dc9be","tid":489780,"uid":8460,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-12-05T08:51:26.000Z","msg":"<blockquote>上面位巴打唔好咁啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n講下笑啫<img src=\"/assets/faces/lomoji/12.png\" class=\"hkgmoji\" /> <br />\n其實如果真係新手入門，真係有幾平得幾平，又或者有幾貴得幾貴。點解咁講？因為你影影下進步左挑起左條癮，好快就會慾求未滿，發覺自己部機太廢高不成低不就，換鏡又唔係換機又唔係。買部超平價既機起碼到時換機冇咁肉赤，買部超貴既，有排你探索起碼用個三五七年先換機或者轉會。平價機咩型號都冇所謂，高階就建議無反，利申用緊N記<br />\n<br />\n順帶一提，音響窮三代 攝影累全家，努力搵錢啦"},{"pid":"0a1c4584bd5144e7f8e84d4fa78e06371aa25fd5","tid":489780,"uid":79870,"like":0,"dislike":0,"s