f310a792d745dd84d5f4941f60e0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F19%2F032350_d08af310a792d745dd84d5f4941f60e0.png&h=17f8aa5a&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/10/19/032354_e861fada44eebfdd9759457c09b6c332.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F10%2F19%2F032354_e861fada44eebfdd9759457c09b6c332.png&h=b4d257a1&s={SIZE}\" /><br />\n<br />\n加埋對翼真係好似<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /> <br />\n<br />\n最後就係 <strong>How to train your dragon 3</strong> 出年上 <br />\n可以滿足下我對佢嘅愛啦<img src=\"/assets/faces/lomoji/06.png\" class=\"hkgmoji\" /> <br />\n<a href=\"https://youtu.be/CyEnAOl8nzM\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FCyEnAOl8nzM&d=t4r4g0Dhr8wDwtQfLOx%2BfQhMEkA7P3Wv%2FuCJwdwWxT4%3D&h=9da383eb\" target=\"_blank\">https://youtu.be/CyEnAOl8nzM</a>"},{"pid":"4f6d4e2ee6a4a72b1bb29ac4c1106d5f888e1aa7","tid":867584,"uid":81040,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-18T19:54:45.000Z","msg":"爬蟲鋪間中都會有,不過聽講比較難養...."},{"pid":"31bccdc22f7a011a9546238e1dc878c1fc47bfaf","tid":867584,"uid":157827,"like":0,"dislike":0,"score":0,"quote":{"pid":"4f6d4e2ee6a4a72b1bb29ac4c1106d5f888e1aa7","tid":867584,"uid":81040,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-18T19:54:45.000Z","msg":"爬蟲鋪間中都會有,不過聽講比較難養...."},"citedBy":0,"replyTime":"2018-10-18T20:08:35.000Z","msg":"係咪旺角嗰啲舖？難養係因為溫度？<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"46ee48dece5e0b2e32ba8b98e4b88c3d0012959f","tid":867584,"uid":13432,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-18T20:12:49.000Z","msg":"第一次見<br />\n真係好得意 <img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"2e34cc7d0c72671cf0d5cb7449f0f05297603804","tid":867584,"uid":149566,"like":0,