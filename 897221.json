\" />"},{"pid":"9bd7a863de7a4816d5531112663e36b16fa9fbf9","tid":897221,"uid":117200,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-10T20:09:38.000Z","msg":"連俄佬都同你反面<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /> <br />\n中國係呢個世界上仲有無朋友<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"9910ca13565428b25a6e38f4e46f239162ff25ed","tid":897221,"uid":78143,"like":15,"dislike":0,"score":15,"citedBy":0,"replyTime":"2018-11-10T20:10:12.000Z","msg":"<img src=\"https://na.cx/i/J5k136i.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJ5k136i.jpg&h=7d09a0a7&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/RHEimSZ.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FRHEimSZ.gif&h=35fe0d46&s={SIZE}\" />"},{"pid":"519a82bdace7fbed5266940e48b80262b0308f07","tid":897221,"uid":25424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-10T20:43:37.000Z","msg":"支那其實係俄佬殖民地<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7202b4dc7e98045d324e41dfb4253f5677e856d4","tid":897221,"uid":7206,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-10T20:55:57.000Z","msg":"中共破壞自己環境，反而出錢幫外國搞環保<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2d81015866a8247404250b5c0aed33ebbc88914b","tid":897221,"uid":6347,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-10T21:38:07.000Z","msg":"俄佬趁火打劫<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" />"},{"pid":"8cb75e98a02a428a6b871a5e0b068357e52e7665","tid":897221,"uid":42283,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-10T21:41:52.000Z","msg":"<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /> 終於到真大佬收保護費"},{"pid":"90da41e19291010778ccee16ab067e89c9390c78","tid":897221,"uid":55913,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2018-11-11T00:39:46.000Z","msg":"你俾錢種 再同我買<br />\n嘩 幾正"},{"pid":"ee1b45900af239fa67f7ee946ceb830690af400b","tid":897221,"uid":82929,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-11T02:16:23.000Z","msg":"講真，西伯利亞要不是有支那照顧<br />\n<br />\n神早餓撚死哂<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 唔餓撚死都食窮莫斯科<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"d6763543564d504e8e3cf91f9d92fdea69d00424","tid":897221,"uid":54337,"like":0,"dislike":0,"score":0,"quote":{"pid":"578b05710a43ff51d30fc62c867fc5b81c5b5ba0","tid":897221,"uid":81190,"like":6,"dislike":1,"score":5,"citedBy":1,"replyTime":"2018-11-10T17:26:34.000Z","msg":"惡人自有惡人磨"},"citedBy":0,"replyTime":"2018-11-11T02:18:41.000Z","msg":"一物治一物"},{"pid":"93554213fec3e8f1059cbb5fc8877325e6a6d8a4","tid":897221,"uid":99172,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-11T02:23:05.000Z","msg":"香港庫房又要冇多筆喇<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"3739a49d09cd5974f1e374e9bb984cdeda6a103e","tid":897221,"uid":209773,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-11T03:57:18.000Z","msg":"冇中國買你啲木材"},{"pid":"7e15a07e79a0331495071029084aee7e0b0bdc96","tid":897221,"uid":59570,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-11T04:04:49.000Z","msg":"睇到支那今時今日咁既局面真係好心涼<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lo