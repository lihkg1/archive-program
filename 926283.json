":222809,"like":0,"dislike":0,"score":0,"quote":{"pid":"af13eba01794cc99e5a8c48a7e1b8f0e6df77757","tid":926283,"uid":28277,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-03T10:40:42.000Z","msg":"乜事分手，影響咁大"},"citedBy":1,"replyTime":"2018-12-03T11:07:45.000Z","msg":"帽事"},"citedBy":1,"replyTime":"2018-12-03T11:35:13.000Z","msg":"結婚階段？"},{"pid":"f4cf9ce1be4272cba2bbe3047c574e53c19c63d4","tid":926283,"uid":222809,"like":1,"dislike":0,"score":1,"quote":{"pid":"5a81184de941a15608b64aba49da3144705f4d58","tid":926283,"uid":28277,"like":0,"dislike":0,"score":0,"quote":{"pid":"c104e261406c646de146754ac211ed2bca5d8088","tid":926283,"uid":222809,"like":0,"dislike":0,"score":0,"quote":{"pid":"af13eba01794cc99e5a8c48a7e1b8f0e6df77757","tid":926283,"uid":28277,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-03T10:40:42.000Z","msg":"乜事分手，影響咁大"},"citedBy":1,"replyTime":"2018-12-03T11:07:45.000Z","msg":"帽事"},"citedBy":1,"replyTime":"2018-12-03T11:35:13.000Z","msg":"結婚階段？"},"citedBy":1,"replyTime":"2018-12-03T11:48:10.000Z","msg":"不 只是一個普通的初戀 可能我仲細 對呢D野未諗得太通透<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"107ab32fa61382308a7ef6378fc989531f609e79","tid":926283,"uid":28277,"like":2,"dislike":0,"score":2,"quote":{"pid":"f4cf9ce1be4272cba2bbe3047c574e53c19c63d4","tid":926283,"uid":222809,"like":1,"dislike":0,"score":1,"quote":{"pid":"5a81184de941a15608b64aba49da3144705f4d58","tid":926283,"uid":28277,"like":0,"dislike":0,"score":0,"quote":{"pid":"c104e261406c646de146754ac211ed2bca5d8088","tid":926283,"uid":222809,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-03T11:07:45.000Z","msg":"帽事"},"citedBy":1,"replyTime":"2018-12-03T11:35:13.000Z","msg":"結婚階段？"},"citedBy":1,"replyTime":"2018-12-03T11:48:10.000Z","msg":"不 只是一個普通的初戀 可能我仲細 對呢D野未諗得太通透<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-03T12:12:27.000Z","msg":"第一次係痛d，過多倫就冇事"},{"pid":"5e5a38ac90676121f98745b2f01d508