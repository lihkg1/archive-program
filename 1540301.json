gmoji\" />"},{"pid":"d39f66b3c7677c995cb4e2086d53ff89039ec156","tid":1540301,"uid":224916,"like":1,"dislike":0,"score":1,"quote":{"pid":"d8d5aab6a6e04e3f107bd789d2d61730b6b2fd9e","tid":1540301,"uid":141871,"like":9,"dislike":0,"score":9,"citedBy":2,"replyTime":"2019-09-04T11:17:40.000Z","msg":"其實你有啲紅字都唔係重點黎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-04T11:58:57.000Z","msg":"同意<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n當然篇野過半都係紅字，咁紅字就無意義"},{"pid":"f33ee829d7128595be2440b5892f186dbcea4a7b","tid":1540301,"uid":49110,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-09-04T11:59:41.000Z","msg":"唔好開心住，有傳言:<br />\n&quot;根據規程：要撤回就要喺二讀程序中動議撤回，大家要留意，政府出嘅動議係唔使經「分組點票」，即係話，若果復會後，呢條條例嘅撤回動議喺「地區點票」下被否決呢，即係會繼續二讀<br />\n<br />\n香港人，我地冇贏過，唔好比條佢呃到<br />\n<br />\n而家應該係中美貿易戰，中央開始驚，所以要做d野比美國睇，但要留意林鄭只係動議徹回，到時議會上會唔會班建制派又否決動議，互扯貓尾，好難講！&quot;<br />\n<br />\n毒蛾分分鐘彈弓手<br />\n※※※※※※※※※※※※※<br />\n求連仔改版<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n次次入到連登，有好多大量重要訊息沉底，訊息太多，亂到睇唔到。依家打緊仗，重要訊息對任何人都很重要，是時候改版吧？訊息混亂對手足無好處。<br />\n如加&ldquo;克警戰術分析(知己知彼)&rdquo;、&ldquo;向高官致意(高官咁好，要做返D野回敬佢哋)&rdquo;、&ldquo;黨共小動作/陰謀背後&rdquo;、&ldquo;國際文宣/頭版團&rdquo;、&ldquo;發夢戰術&rdquo;、&quot;發夢裝備&quot;、&ldquo;夢後感想&rdquo;、&ldquo;夢後檢討&rdquo;、&ldquo;訓得唔好區<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />&rdquo;、&ldquo;文宣空間&rdquo;、&ldquo;和你飛活動空間&rdquo;、&ldquo;和你衝總部&rdquo;、&ldquo;勇武有野話&rdquo;、&ldquo;官媒/紅媒清算車&rdquo;、&ldquo;狗嘅黑材料&rdquo;、&ldquo;戰場最前線！&rdquo;、&ldquo;對應藍絲/鄉黑部落格&rdquo;、&ldquo;戰區好人好事&rdquo;、&ldquo;識別鬼踪&rdquo;、&ldquo;被捕回憶錄&rdquo;、&ldquo;地鐵巴士遇難記&rdquo;(名就是但改)<br />\n<br />\n每分鐘，有一百幾十任何人放野上嚟(我係狗就放垃圾訊息，而且狗有一群十幾個都夠死)，咁真係唔係辦法！最要訊息分分鐘等下世先睇到！雖然好煩重，可否搵人做管理員必要時轉訊息到適當地方！<br />\n亂對我哋，對前線好不利！<br />\n我一時, 不吐不快,不喜勿插。<br />\n不妨考慮下，幫手推下....或改改內容然後推，推到連仔改版<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"5a138b5193fc1cfc340289c131fb6a8f485face7","tid":1540301,"uid":40226,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T11:59:53.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"3f14fca619a67a24dbc50a6a6613a9f0b45f16ad","tid":1540301,"uid":288231,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:00:21.000Z","msg":"我覺得會搵幾個散仔頂"},{"pid":"a66293c7f41f90644db57b9857fa7c59065c444f","tid":1540301,"uid":307857,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:00:47.000Z","msg":"請不要被毒娥模糊視線<br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: x-large;\"><strong>敵退我打！！</strong></span></span><br />\n<br />\n<span style=\"color: gold;\"><span style=\"font-size: x-large;\">最新目標-美國國會9月9日復會,要求大比數通過香港民主人權法案</span></span>"},{"pid":"be417ab410f044b4af192be44872ba2d7555bf6e","tid":1540301,"uid":40226,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:01:00.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"8a2790b548171825e352410f396ec7dce447ed20","tid":1540301,"uid":89184,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:01:58.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"214793bfcce72fcffc778476e851b51f88a2c630","tid":1540301,"uid":40226,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:02:00.000Z","msg":"幫手推下啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"dc5549365c5cf8590b15ea84d7c1b41898c58508","tid":1540301,"uid":40226,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:03:07.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"301e18d6952dc9eb477c08ac15e540c19d7a544f","tid":1540301,"uid":40226,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:03:18.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f2ad2f4d81e58494344ebd15b77066f1c6bf511a","tid":1540301,"uid":243915,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:11:34.000Z","msg":"掟住一隻狗穩定民心 證明監警會有用<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"229d2d0484922c7c8de93baa804c2c9a59c06717","tid":1540301,"uid":283080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:12:26.000Z","msg":"【請關注831太子站事件】<br />\n<img src=\"https://na.cx/i/Ogv8qjF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOgv8qjF.jpg&h=57f98b62&s={SIZE}\" />"},{"pid":"3e21c91d7bbd60a566e2bd7c1938e35db1b08c55","tid":1540301,"uid":35592,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:13:13.000Z","msg":"push"},{"pid":"4596a8fa99773e51f9a656b93c4bb2ae47f56e70","tid":1540301,"uid":46440,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:16:59.000Z","msg":"focus返春袋<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"a20307e9e816a55b242ce54b25369ccf66e093b0","tid":1540301,"uid":73219,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:28:02.000Z","msg":"國際輿論的確係緊要<br />\n要話俾全球聽我地面對警暴仲輸緊<br />\n我地對呢四大妥協完全唔撚收貨<br />\n民陣快入紙搞遊行啦<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"04938d03c18a9c998e1d32ed958b91e4b2cbd9b4","tid":1540301,"uid":304160,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:30:45.000Z","msg":"真係，等到法案過到先在勇武都未遲"},{"pid":"2e62330218789aa450a4b2f9e7f933cb8402e341","tid":1540301,"uid":205552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:31:23.000Z","msg":"幫推"},{"pid":"97b6290bce4ae40a13c42d3e81a29c87f29b333e","tid":1540301,"uid":182984,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:32:16.000Z","msg":"林鄭諗住以退為進 大家唔好俾佢呃左<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"00b7f20f8fa5cf749819c556833ca89422b8c231","tid":1540301,"uid":183950,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-09-04T12:32:22.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />殺左佢太便宜<br />\n點解唔斬斷佢手/腳等佢地痛苦到死<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" />"},{"pid":"329ce6578c080978143ad4fb81555a11b8762dac","tid":1540301,"uid":51698,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:36:01.000Z","msg":"1。唔好亂用紅字<br />\n2。其實9月9復會唔代表即過人權法，預計最少一個月，但冇可能叫勇武停一個月"},{"pid":"18ec87ab4963fce56c1fe8fdf466a90bdb02e4fd","tid":1540301,"uid":260238,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:36:57.000Z","msg":"柒婆想分散注意力！太子一定死咗人<br />\n<a href=\"https://lih.kg/1540764\" data-auto-link target=\"_blank\">https://lih.kg/1540764</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"85148c2ca115dc65ed6937b2d1f459530df61ee8","tid":1540301,"uid":268656,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:38:16.000Z","msg":"推"},{"pid":"fd5b7a62f342d72335487a647bc46858f1df1a63","tid":1540301,"uid":272202,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:39:22.000Z","msg":"人權法一定要通過！！！<br />\n<br />\n五大訴求 <span style=\"color: red;\"><span style=\"font-size: xx-large;\"><strong>缺一不可</strong></span></span><br />\n咪撚改口號<br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">送中仲未正式撤回 依家只係動議</span></span><br />\n<blockquote>林鄭又想過鳩我地一棟啊<br />\n<a href=\"https://lih.kg/1539720\" data-auto-link target=\"_blank\">https://lih.kg/1539720</a><br />\n<br />\n屌你老母仲要等復會 再提出撤回議案<br />\n而立法會復會係10月9或10月16日<br />\n重點就係呢到：10月1國慶<br />\n今日無啦啦出黎廢up<br />\n擺明就係想側側搏 係10月1日前盡快平息件事<br />\n等佢可以平平安安渡過鄰國國慶</blockquote><br />\n<br />\n求下你地睇埋呢篇文<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n大家點睇脫共？<br />\n<a href=\"https://lih.kg/1536794\" data-auto-link target=\"_blank\">https://lih.kg/1536794</a>"},{"pid":"196431f2e393318fe59694792d158620eb42d7d8","tid":1540301,"uid":22824,"like":0,"dislike":0,"score":0,"quote":{"pid":"703b3432a371793771adc2ccbf66b0feceb9d377","tid":1540301,"uid":40226,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T11:14:11.000Z","msg":"首先林鄭行撤回呢一步<span style=\"color: red;\">最主要目的未必係令淺黃返屋企</span><br />\n我睇完佢呢個行動我係好撚嬲<br />\n嬲到仆街<br />\n<br />\n相信大家到今時今日最撚憎一定係班狗<br />\n但請大家仔細一諗<br />\n林鄭做<span style=\"color: red;\">呢一步一定唔係一時興起</span><br />\n大家睇返<span style=\"color: red;\">呢排發生嘅事</span><br />\n啲狗越黎越亂鳩咁黎<br />\n仲有之前<span style=\"color: red;\">所謂流出</span>嘅林鄭承諾警隊將唔會有獨立調查委員會<br />\n仲有831嘅故意隱瞞<br />\n全部嘢都話緊比我地知一樣嘢<br />\n<span style=\"color: red;\">班狗將唔會受到應有嘅懲罰</span><br />\n我認為依家係有一種請君入甕嘅感覺<br />\n佢<span style=\"color: red;\">將民憤激發到一個極點</span><br />\n仲要喺呢個時候<span style=\"color: red;\">走返大陸</span><br />\n<span style=\"color: red;\">留個張建宗喺到</span><br />\n究竟係想點？<br />\n我認為到時佢會<span style=\"color: red;\">要求狗喺近日嘅示威放軟手腳</span><br />\n營造一個<span style=\"color: red;\">狗係受害者嘅錯覺</span><br />\n必要時<span style=\"color: red;\">派一條友去死</span><br />\n而呢條友亦唔需要係真狗<br />\n可以搵人扮<br />\n<br />\n到時將會<span style=\"color: red;\">扭轉成個國際輿論</span><br />\n<span style=\"color: red;\">美國推人權法案可能會受挫</span><br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">我地最大嘅一張牌將會被無效化</span></span><br />\n<br />\n我認為喺目前呢個<span style=\"color: red;\">勇武行動嚴重受挫嘅局勢</span><br />\n我地需要<span style=\"color: red;\">暫時先重回和理非</span><br />\n黎一次<span style=\"color: red;\">大遊行</span><br />\n企出黎<span style=\"color: red;\">話畀國際聽我地唔撚收貨</span>呀屌你老母<br />\n班黑警有乜理由唔需要受懲罰？<br />\n咁撚樣嘅制度下<br />\n同直接送我地中係冇分別！<br />\n<span style=\"color: red;\">待美國國會再開<br />\n人權法案塵埃落定<br />\n再考慮下一步行動</span><br />\n<br />\n當然<span style=\"color: red;\">我嘅諗法仍有不足</span><br />\n我好希望大家一齊brainstorm諗下點拆"},"citedBy":0,"replyTime":"2019-09-04T12:40:13.000Z","msg":"其實真係有效 好多人一開始都係修例先企出黎 但多得班popo又激咗另一班人出黎"},{"pid":"1c7782d715ffc73fb71821b389807338ffd71832","tid":1540301,"uid":229886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:40:32.000Z","msg":"大你老母遊行<br />\n我宣佈全部都要去機場<br />\n仲遊行<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"14a49001e5164307d5fc6f889015f65bb64d9bc3","tid":1540301,"uid":248290,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:40:33.000Z","msg":"一隻唔夠嫁 <br />\n要推成隊 狗隊 去死先得嫁<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"9d6cf652c82d37c8f0dd3e266b33e25f4b1d0750","tid":1540301,"uid":216178,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:42:14.000Z","msg":"condom係咁用喎<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"}]}