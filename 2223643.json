223643,"uid":93119,"like":0,"dislike":0,"score":0,"quote":{"pid":"8f8a4d68215701198b04c9bedd67f076f13ff265","tid":2223643,"uid":240682,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-30T05:19:21.000Z","msg":"自從帶口罩右邊面成日爆<img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-09-30T05:20:07.000Z","msg":"你呢d好可能係保濕做得唔夠好"},{"pid":"1e8bee35e4f8483b2888711d75d6e5fed1ff62cf","tid":2223643,"uid":165891,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-30T05:22:36.000Z","msg":"我都爆得好犀利<br />\n換左個好嘅須刨. 乾濕分離. 好好多"},{"pid":"5371b9b8df1014508ba160ef7b20b8c60b3b51f8","tid":2223643,"uid":93119,"like":0,"dislike":0,"score":0,"quote":{"pid":"1e8bee35e4f8483b2888711d75d6e5fed1ff62cf","tid":2223643,"uid":165891,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-30T05:22:36.000Z","msg":"我都爆得好犀利<br />\n換左個好嘅須刨. 乾濕分離. 好好多"},"citedBy":0,"replyTime":"2020-09-30T05:32:09.000Z","msg":"有無型號可以參考下<img src=\"/assets/faces/mf/surprise.gif\" class=\"hkgmoji\" />"},{"pid":"a4a50ac28708ccc3caaef59650427dc93f59272c","tid":2223643,"uid":62758,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-09-30T05:36:48.000Z","msg":"講吓啲經歷先<br />\n中學時期爆到成面瘡 （爆到蜂巢果隻）然後採用自然療法<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />唔用洗面膏洗面奶 即係沖涼用水沖 除咗塊面好多死皮 角質好厚之後 已經無再出嚴重暗瘡 淨係圍繞住嗰嘴出啲走米( 即係白色膿頭 但好脆 一用力抹就會穿咗無咗 )<br />\n然後去咗荃灣睇葉醫生 佢叫我用返洗面 同埋食四環素試下 初初兩個月食完好返晒 但兩個月後又係下巴位爆啲石頭瘡出嚟 咁咪再去覆診 今次佢開A酸比我<img src=\"/assets/faces/cat/darkness.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/darkness.gif\" class=\"hkgmoji\" />因為我強烈要求食A酸 想解決埋面油嘅問題<br />\n<br />\nA酸期間 都係常見嘅皮膚超好、乾爽！係成個人好乾身 淚水分泌極少<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><br />\n而家停咗藥三年 油脂分泌比起之前少咗一半 但下巴周不時Keep住生啲走米仔 其實我都有返去覆診問醫生 但佢話問題唔大 無謂為咗啲小問題去食 四環素/食多次A酸 佢叫我做多啲去角質<br />\n<br />\n我老婆就叫我一星期 Peeling一次 但我最後發現 洗完面用毛巾濕水抹一抹面就完全解決咗下巴出走米嘅問題<img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/clown.gif\" class=\"hkgmoji\" />(因為用完洗面膏未必清得晒面上啲污糟嘢 所以用毛巾抹一抹就可以更乾淨 。但唔係叫你用毛巾印乾面上啲水 因為毛巾其實好多菌<img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />你搞店好晒就用紙巾印乾啲水就算啦）"},{"pid":"2523cdd780a90c11d123413dc2ff0c70a5161650","tid":2223643,"uid":268088,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-09-30T05:38:10.000Z","msg":"有冇人係額頭係咁爆"},{"pid":"fde1a3e23ed343eb1058998096b6096ef7c6a812","tid":2223643,"uid":232877,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-30T05:38:33.000Z","msg":"便秘 有毒排唔出下巴就會爆瘡"},{"pid":"ae34336713a4b59cecde0efda4a423e14df707c7","tid":2223643,"uid":62758,"like":0,"dislike":0,"score":0,"quote":{"pid":"2523cdd780a90c11d123413dc2ff0c70a5161650","tid":2223643,"uid":268088,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-09-30T05:38:10.000Z","msg":"有冇人係額頭係咁爆"},"citedBy":0,"replyTime":"2020-09-30T05:38:58.000Z","msg":"太夜瞓？<img src=\"/assets/faces/cat/headache.gif\" class=\"hkgmoji\" />"},{"pid":"9a93bb6ddea74d15200fd477bc494d4140f7a0c6","tid":2223643,"uid":135127,"like":0,"dislike":0,"score":0,"quote":{"pid":"33c69fae57d6d0c34a8e23e539f5fccb50917490","tid":2223643,"uid":243936,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-30T04:38:47.000Z","msg":"Same，已經頂唔順想睇醫生，有無平醫生推介<img src=\"/assets/faces/lm2/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-09-30T05:41:59.000Z","msg":"睇開中環黎醫生<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n去睇佢幾次佢覺得你冇需要覆診就可以淨係攞藥"},{"pid":"383b9f569010e30818a5478863bc7ad26be0f455","tid":2223643,"uid":93119,"like":0,"dislike":0,"score":0,"quote":{"pid":"2523cdd780a90c11d123413dc2ff0c70a5161650","tid":2223643,"uid":268088,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-09-30T05:38:10.000Z","msg":"有冇人係額頭係咁爆"},"citedBy":0,"replyTime":"2020-09-30T05:50:36.000Z","msg":"額頭好似關夜訓同心情事"},{"pid":"05e31768484097f63a777217d20f95b63fbf1231","tid":2223643,"uid":93119,"like":0,"dislike":0,"score":0,"quote":{"pid":"9a93