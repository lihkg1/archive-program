fed009ce7b7a8d5762df7f5c1fe2f4204554a1","tid":2123162,"uid":6329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-24T13:16:02.000Z","msg":"<img src=\"https://na.cx/i/CGLrrGC.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCGLrrGC.gif&h=bd309f6f&s={SIZE}\" />"},{"pid":"3dd0d9f85d2b8fc8cde14b2f2d8973143a7947b6","tid":2123162,"uid":46966,"like":0,"dislike":0,"score":0,"quote":{"pid":"b35162582147f7f6168e363358ef5d60936ae8d9","tid":2123162,"uid":79117,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-24T13:14:26.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-07-24T13:17:24.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />成日撞機姐 鬼叫D飛唔係自己整咩<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"26974ee1ea348f1eb5c2e001b2d76ece271ac1eb","tid":2123162,"uid":46966,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-07-24T13:17:42.000Z","msg":"<blockquote><blockquote>但係台灣軍演好似成日死人<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />成日撞機姐 鬼叫D機唔係自己整咩<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /></blockquote>"},{"pid":"cd6b4049b1d7257d41621b3d6faefef5ca398c74","tid":2123162,"uid":79563,"like":0,"dislike":0,"score":0,"quote":{"pid":"b35162582147f7f6168e363358ef5d60936ae8d9","tid":2123162,"uid":79117,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-07-24T13:14:26.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2020-07-24T13:22:54.000Z","msg":"台軍去到環太平洋軍演, 都係做吓樣"},{"pid":"19af98dcf3d5a5194311bd92e9cf8