/s00001/1580323510633/%E6%9C%89%E5%85%A7%E5%9C%B0%E4%BA%BA%E8%B6%95%E9%AB%98%E9%90%B5%E5%B0%81%E7%AB%99%E5%89%8D%E4%BE%86%E6%B8%AF</a>"},{"pid":"5440bcbab2fababde48f27cebe7bf05953fcb5f1","tid":2369330,"uid":143241,"like":0,"dislike":0,"score":0,"quote":{"pid":"3a9b53424a0b34302ed4d8dc0cb35b7087f9bee2","tid":2369330,"uid":212274,"like":0,"dislike":0,"score":0,"quote":{"pid":"4e5341dc00dad1fd9643b3bac1e1c8f78520f46d","tid":2369330,"uid":143241,"like":4,"dislike":2,"score":2,"citedBy":2,"replyTime":"2021-01-17T05:01:59.000Z","msg":"佢護士嚟o者"},"citedBy":1,"replyTime":"2021-01-17T05:17:56.000Z","msg":"警察都係打份工聽指示姐,我屌你老母<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-17T05:20:45.000Z","msg":"佢局長嚟㗎,唔通柒婆識醫學叫佢咁講啊."},{"pid":"f90048362a3708daf2047e528aba181d62f20180","tid":2369330,"uid":51754,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-17T05:27:07.000Z","msg":"垃圾護士<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />呢條八婆根本就唔識武肺<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}