mg src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e64e81aa527695e999ed5c583aaf85b4b25d1280","tid":2364414,"uid":256246,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-13T04:06:13.000Z","msg":"邊個仆街洩露國家機密<img src=\"/assets/faces/lomoji/26.png\" class=\"hkgmoji\" />"},{"pid":"87db3af0d3d8e62c0975232a9259d65967f98972","tid":2364414,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-13T04:07:15.000Z","msg":"<a href=\"https://youtu.be/YEHnaZL9SWg\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FYEHnaZL9SWg&d=Eu1QSTPz0OFPBNy7%2BevvEfGl%2B26pDsgLotMYn9d4AWI%3D&h=7299e97b\" data-auto-link target=\"_blank\">https://youtu.be/YEHnaZL9SWg</a>"},{"pid":"38f856ece82d89cecdaeee2c42adbc3958a8f675","tid":2364414,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-13T04:08:50.000Z","msg":"<a href=\"https://youtu.be/vxwaOX-nH_w\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FvxwaOX-nH_w&d=Eu1QSTPz0OFPBNy7%2BevvEfGl%2B26pDsgLotMYn9d4AWI%3D&h=d14e2f22\" data-auto-link target=\"_blank\">https://youtu.be/vxwaOX-nH_w</a>"},{"pid":"277a5113890201e099893346d7a4256c1aa6b6a8","tid":2364414,"uid":39200,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-13T04:09:15.000Z","msg":"感冒又扮武肺, 支那明明清左零啦"},{"pid":"4c03d5260dbfaac9e48d0db484d78c2d66f583fe","tid":2364414,"uid":280593,"like":2,"dislike":0,"score":2,"quote":{"pid":"29b5c184d67342dab8d4b64f2794f93ae1f8df0c","tid":2364414,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-13T03:31:57.000Z","msg":"<strong><span class=\"x-large\">疫情擴大！中國爆增107例本土確診 創10個多月以來新高</span></strong><br />\n<br />\n2021/01/13 10:52<br />\n〔即時新聞／綜合報導〕<span class=\"red\">中國武漢肺炎（新型冠狀病毒病，COVID-19）疫情持續蔓延，昨（12日）新增107例本土確診，有90例在河北、16例在黑龍江、1例山西，不但本土病例創逾10個多月以來新高，黑龍江疫情開始升溫，山西也出現新本土病例，中國疫情恐大爆發。</span><br />\n<br />\n根據中國衛健委公告，昨0時至24時，中國31個省（自治區、直轄市）和新疆生產建設兵團報告新增本土確診病例107例（河北90例、黑龍江16例、山西1例）以及8例境外輸入，其中河北石家莊依然是疫情熱點，新增84例確診，另外還有14例本土無症狀感染者，另外邢台市也有6例確診及1例無症狀感染者，當局昨宣布石家莊市、邢台市、廊坊市實施封城。<br />\n<br />\n另外黑龍江省疫情也開始升溫，黑龍江省昨日新增確診病例16例，其中13例為綏化市望奎縣無症狀感染者轉確診，另外3例來自於哈爾濱市香坊區，望奎縣也進入封城狀態。<br />\n<br />\n除此之外疫情有向河北以外地區擴散的趨勢，鄰近的山西省也出現1例本土確診，山東威海也通報有來自黑龍江望奎縣的無症狀感染者。<br />\n<br />\n<a href=\"https://news.ltn.com.tw/news/world/breakingnews/3409386\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F3409386&d=Eu1QSTPz0OFPBNy7%2BevvEfGl%2B26pDsgLotMYn9d4AWI%3D&h=671956f1\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F3409386&h=b2a42cde\" data-auto-link target=\"_blank\">https://news.ltn.com.tw/news/world/breakingnews/3409386</a>"},"citedBy":0,"replyTime":"2021-01-13T04:09:45.000Z","msg":"其實係為左阻WHO入去查<img src=\"/assets/faces/pig/mock.gif\" class=\"hkgmoji\" />"},{"pid":"f445541c48dad36090a54b181edf91c090aa4e73","tid":2364414,"uid":21141,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-13T04:10:31.000Z","msg":"爆到武漢個陣咁又會出現逃難潮<br />\n到時香港又仆多次街<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"17d5967a98a2e4ffc593d6be2ca9f1a250552b8e","tid":2364414,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-13T04:11:36.000Z","msg":"<a href=\"https://youtu.be/xiFR5oz5bvo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FxiFR5oz5bvo&d=Eu1QSTPz0OFPBNy7%2BevvEfGl%2B26pDsgLotMYn9d4AWI%3D&h=fea3d83b\" data-auto-link target=\"_blank\">https://youtu.be/xiFR5oz5bvo</a>"},{"pid":"cbc86b58f9dbe692a69a775f8acc45200bb7f819","tid":2364414,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-13T04:14:55.000Z","msg":"<a href=\"https://youtu.be/zkVygBDcpPc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FzkVygBDcpPc&d=Eu1QSTPz0OFPBNy7%2BevvEfGl%2B26pDsgLotMYn9d4AWI%3D&h=4f7