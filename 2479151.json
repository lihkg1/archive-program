o%2BkVhR8rs%3D&h=eb6d6186\" data-auto-link target=\"_blank\">https://www.swallowlife.org/intro-heartwithmate</a><br />\n<br />\n在囚手足支援手冊<br />\n<a href=\"https://www.swallowlife.org/在囚手足支援手冊\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.swallowlife.org%2F%E5%9C%A8%E5%9B%9A%E6%89%8B%E8%B6%B3%E6%94%AF%E6%8F%B4%E6%89%8B%E5%86%8A&d=kuRIuFMgKSvsW5TefiiiYYeNTHq1rgEicHo%2BkVhR8rs%3D&h=ab6e3bfc\" data-auto-link target=\"_blank\">https://www.swallowlife.org/在囚手足支援手冊</a>"},{"pid":"740b00ebed814dc729b19d02f0f10301ccd7a87a","tid":2479151,"uid":280525,"like":0,"dislike":0,"score":0,"quote":{"pid":"c556a0f23c5ee2c9593149b81fcd502bbe662a19","tid":2479151,"uid":103965,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-07T15:14:31.000Z","msg":"。。。"},"citedBy":0,"replyTime":"2021-04-07T15:16:00.000Z","msg":"。。。"},{"pid":"6063450e0a83e4f8674a5a9c9f4fb2aaa5303652","tid":2479151,"uid":280525,"like":0,"dislike":0,"score":0,"quote":{"pid":"fe4896e359a3170f29026e1dc1f0d7468973acef","tid":2479151,"uid":126919,"like":0,"dislike":0,"score":0,"quote":{"pid":"6ccd36139a6230bb256b13c1d59a84426e67ccf0","tid":2479151,"uid":280525,"like":0,"dislike":0,"score":0,"quote":{"pid":"40ffb6c081866a06876570da4daae048f36cfdec","tid":2479151,"uid":126919,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-07T15:12:53.000Z","msg":"生日安好"},"citedBy":1,"replyTime":"2021-04-07T15:13:23.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-04-07T15:14:28.000Z","msg":"<img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/cat/rain.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-07T15:16:10.000Z","msg":"<img src=\"/assets/faces/mouse/please.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/ple