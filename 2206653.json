"hkgmoji\" />"},{"pid":"dbaa57ced185ee6d94e66cf3b8af257ea32c412b","tid":2206653,"uid":18167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T01:48:26.000Z","msg":"就算而家起, 全個香港都唔可以參與<br />\n班港共官員都會走出黎話好合理<br />\n其他人講會話佢地政治化件事"},{"pid":"898911d64894ced6a7874a7bdc0dc8d3275e69a1","tid":2206653,"uid":28163,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T01:49:19.000Z","msg":"消關未得 搞咁多野"},{"pid":"4e2ed4744df7752c45251c1a417619bcad56d028","tid":2206653,"uid":77196,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T01:49:57.000Z","msg":"地方政府冇權干預中央政策，好合理"},{"pid":"5a881565958d066021841e8a364ed4eb4f55d3c2","tid":2206653,"uid":24080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T01:52:44.000Z","msg":"下一總站:地府<br />\ndo do do do do do do do do <br />\nthe next station is day full <br />\n<img src=\"/assets/faces/pig/fan.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/champagne.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/play.gif\" class=\"hkgmoji\" />"},{"pid":"abe744055c4a5689528e5764505948ed2ce7b717","tid":2206653,"uid":265113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T01:53:58.000Z","msg":"一帶一路, 輸出地方債務<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},{"pid":"826dde5a36815bae4999eb3fd3b91167ec6ce007","tid":2206653,"uid":326580,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T01:54:01.000Z","msg":"同hyperloop比邊個好啲？"},{"pid":"38a5c159c4a0c252651488e9f546582552f41a94","tid":2206653,"uid":257622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T01:54:59.000Z","msg":"啱啱先通完高鐵，又整新嘢 cap 水"},{"pid":"8be82853b8d9136cd4b469da01fc1ff7efa163f8","tid":2206653,"uid":119806,"like":0,"dislike":0,"score":0,"quote":{"pid":"0a51ed642544b2a18f887353060adbce8cce5e2f","tid":2206653,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-09-17T15:11:54.000Z","msg":"<img src=\"https://hk.on.cc/hk/bkn/cnt/news/20200917/photo/bkn-20200917222956827-0917_00822_001_01p.jpg?20200917225143\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Fnews%2F20200917%2Fphoto%2Fbkn-20200917222956827-0917_00822_001_01p.jpg%3F20200917225143&h=1753d496&s={SIZE}\" /><br />\n<br />\n未來香港可能會有磁浮列車直通內地。中國工程院表示，內地時速高達600公里的高速磁浮列車正研究興建走線，其中一個方案是由廣州東站至深圳香蜜湖站，甚至可能伸延至香港九龍站，通關則可能採用一地兩檢模式，令來往穗港的車程縮短至20分鐘以內。<br />\n<br />\n中國工程院副院長何華武，於昨日(16日)在上海舉辦的「創新與新興產業發展國際會議」現代交通工程技術與產業專題會上稱，內地高速磁浮列車正研究2條走線，分別是「滬杭磁浮」和「廣深磁浮」，前者會以明線方式興建，後者則是地下線。<br />\n<br />\n會議上展示一幅「廣深磁浮」規劃線路圖，走線全長110公里，由廣州東站出發，經廣州黃埔及東莞常平鎮，再到深圳香蜜湖一帶，沿途設有廣州東站、東莞蛤地站，以及深圳香蜜湖站，將來更可能延伸至香港九龍站。有指本港運輸及房屋局未有參與相關規劃。<br />\n<br />\n<pre><code data-type=\"\">https://hk.on.cc/hk/bkn/cnt/news/20200917/bkn-20200917222956827-0917_00822_001.html</code></pre>"},"citedBy":0,"replyTime":"2020-09-18T01:59:20.000Z","msg":"呢轆野係磁浮列車？<br />\n<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"fbc4d11fab39cfd94642c76f288915d055b9a859","tid":2206653,"uid":11291,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T02:21:53.000Z","msg":"<img src=\"/assets/faces/dog/photo.gif\" class=\"hkgmoji\" />"},{"pid":"9caaf456bc8fee57511f63c09daa108d16e9aac3","tid":2206653,"uid":33456,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-09-18T02:24:20.000Z","msg":"應該會係個條乜鳩由寶安機場經洪水橋去西九既鐵路<img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" />"},{"pid":"570e7f4e5fb80227f79e5435c4e8ed2562a4dcc8","tid":2206653,"uid":290973,"like":0,"dislike":0,"score":0,"quote":{"pid":"36652b2303015a704c7b0b54cac9b33cc04c463d","tid":2206653,"uid":146030,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-09-17T15:17:50.000Z","msg":"又嚟被規劃"},"citedBy":0,"replyTime":"2020-09-18T02:27:10.000Z","msg":"藍絲：膠鐵2.0<img src=\"/assets/faces/dog/lick.gif\" class=\"hkgmoj