vUobeFZk%2BLn%2Bp4m9s6a9hK%2BPA%3D&h=4b79f8aa\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20171130%2F20230175&h=11b362ed\" target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20171130/20230175</a><br />\n<br />\n<span style=\"color: red;\"><strong><span style=\"font-size: xx-large;\">抗衡中國魔掌<br />\n組建香港既遊說團隊！</span></strong></span><br />\n<br />\n<span style=\"color: orange;\"><strong><span style=\"font-size: x-large;\">誠意推薦：</span></strong></span><br />\n<br />\n<strong><em>香港大專學界國際事務代表團眾籌計劃</em></strong><br />\nHong Kong IAD Crowdfunding Plan<br />\n<a href=\"https://gogetfunding.com/hkiad-crowdfunding/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgogetfunding.com%2Fhkiad-crowdfunding%2F&d=pzn6Hq8jxzH2PmSSbZvUobeFZk%2BLn%2Bp4m9s6a9hK%2BPA%3D&h=848248bd\" target=\"_blank\">https://gogetfunding.com/hkiad-crowdfunding/</a><br />\n<br />\n<strong><em>香港眾志國際眾籌計劃 Demosisto International Campaign Crowdfunding Project</em></strong><br />\n<a href=\"https://gogetfunding.com/%E9%A6%99%E6%B8%AF%E7%9C%BE%E5%BF%97%E5%9C%8B%E9%9A%9B%E7%9C%BE%E7%B1%8C%E8%A8%88%E5%8A%83-demosisto-international-campaign-crowdfunding-project/?show_desktop=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgogetfunding.com%2F%25E9%25A6%2599%25E6%25B8%25AF%25E7%259C%25BE%25E5%25BF%2597%25E5%259C%258B%25E9%259A%259B%25E7%259C%25BE%25E7%25B1%258C%25E8%25A8%2588%25E5%258A%2583-demosisto-international-campaign-crowdfunding-project%2F%3Fshow_desktop%3D1&d=pzn6Hq8jxzH2PmSSbZvUobeFZk%2BLn%2Bp4m9s6a9hK%2BPA%3D&h=106ab4c5\" target=\"_blank\">https://gogetfunding.com/%E9%A6%99%E6%B8%AF%E7%9C%BE%E5%BF%97%E5%9C%8B%E9%9A%9B%E7%9C%BE%E7%B1%8C%E8%A8%88%E5%8A%83-demosisto-international-campaign-crowdfunding-project/?show_desktop=1</a><br />\n<br />\n<strong><span style=\"font-size: small;\"><span style=\"color: orange;\">什麼是遊說集團？</span></span></strong><br />\n<br />\n<span style=\"font-size: x-small;\">遊說集團的工作，<strong><ins>是嘗試影響立法者</ins></strong>或其他持份者決定或行為，在政治角力中為服務對象<strong><ins>爭取利益</ins></strong>。遊說集團的服務對象，可以是國家、企業、社會團體、個人。在美國，政治遊說是極為普遍及重要的一環；幾乎所有政治操作都有遊說集團的參與。</span><br />\n<br />\n<strong><span style=\"font-size: small;\"><span style=\"color: orange;\">為什麼香港需要遊說隊伍？</span></span></strong><br />\n<br />\n<span style=\"font-size: x-small;\">任何國家的政治，背後都擁有複雜的政治脈絡；包括國家政策、政治形勢、民意、錯綜複雜的利益網絡、乃至個別官員或議員的性情喜好。要在國際社會維護和爭取香港的利益，<strong><ins>香港需要一支能具經驗和技巧，能夠有效收風、熟識政治形勢</ins></strong>、具備遊說策略的隊伍。</span>"},{"pid":"464b527f8c4c67bb7a49db08412be58576d32f9b","tid":1672633,"uid":33642,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-10-24T09:04:41.000Z","msg":"cc台咁多核彈<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />驚閪咩"}]}