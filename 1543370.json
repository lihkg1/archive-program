4U.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEUH604U.jpg&h=74590733&s={SIZE}\" />"},{"pid":"ea795cb91ddeb86dd54b2de84c960bc966b0ff60","tid":1543370,"uid":21424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T07:10:10.000Z","msg":"<img src=\"https://s5.ezgif.com/save/ezgif-5-2a08538c8047.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs5.ezgif.com%2Fsave%2Fezgif-5-2a08538c8047.gif&h=0b45625d&s={SIZE}\" />"},{"pid":"dda22c08de306f2b541e213a17cfe104b28f97c1","tid":1543370,"uid":49979,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-05T07:10:14.000Z","msg":"唔一定要跳 我係巴都覺得跳好揚<br />\n<br />\n我夢到暫時慣左做法係<br />\n<br />\n1）紅色閘門<br />\n<br />\n用銀包厚d果邊扮拍卡 有人係前面就貼佢屎忽過（唔使真係好貼）其實都有成2-3秒時間 自己就啦<br />\n<br />\n如果冇得跟前面果個 我會用膝頭哥 用力一下頂落度門到 佢唔係硬膠黎 唔會好痛 女仔都做到 度門唔係兩邊開哂 淨係會開比你頂果邊<br />\n<br />\n2）轉輪<br />\n<br />\n都係扮拍卡出閘 用手渣實一chok就過 其實好鬆 唔使好大力 但我試過唔用手chok用身撞 都係得既 但要大力d 同少痛 女仔未必做到<br />\n<br />\n以上純粹發夢夢到"},{"pid":"f6e9e78b3189f9cc9d0e2d0956406c558e27b645","tid":1543370,"uid":41411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T07:14:20.000Z","msg":"其實真係唔洗咁驚...可能你地係怕尷尬比人望<br />\n但我想講好多人都係望完就算 同埋好多人會支持你<br />\n如果驚比廢老跟就跳完行快2步 佢地點會跟到你<br />\n就算比人捉到 咪最多罰500<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f97f56331cad513a82b1e15229ae79e2c0ca700f","tid":1543370,"uid":144,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T07:14:29.000Z","msg":"咩站 黎陪你練跳<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5f4ba7a8df6d935af24adab952b964e54d1ba1c9","tid":1543370,"uid":76702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T07:17:01.000Z","msg":"此回覆已被刪除"},{"pid":"c9fa4362b54e9a84e15f0027084d617dd404a010","tid":1543370,"uid":76702,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-05T07:17:27.000Z","msg":"此回覆已被刪除"},{"pid":"10223e9039d15