id":"1f75bc7b7fb0ee5f04cd07afe0fdf385ff536c9a","tid":724693,"uid":152387,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-02T15:25:57.000Z","msg":"香港人太鍾意儲錢唔洗錢<br />\n但儲埋儲埋啲錢就拎晒去投資房地產"},{"pid":"6e00a263a82c1be18b070a3896dd1a62d5bfd1d4","tid":724693,"uid":29080,"like":0,"dislike":0,"score":0,"quote":{"pid":"cf82240d23dafdac1a814bf70c4cc1c6f94101b3","tid":724693,"uid":85461,"like":18,"dislike":1,"score":17,"citedBy":1,"replyTime":"2018-07-01T06:45:55.000Z","msg":"吳震宇夠去左墨西哥守龍<br />\n<img src=\"https://media.zenfs.com/en_us/News/Reuters/2014-06-17T203448Z_2090303617_TB3EA6H1NSFVN_RTRMADP_3_SOCCER-WORLD-M17-BRA-MEX.JPG\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.zenfs.com%2Fen_us%2FNews%2FReuters%2F2014-06-17T203448Z_2090303617_TB3EA6H1NSFVN_RTRMADP_3_SOCCER-WORLD-M17-BRA-MEX.JPG&h=60dac23f&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-07-02T15:27:20.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ec94d11e7cc6e9b69c8ad3f4223d5a304bb8cdec","tid":724693,"uid":155818,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-02T15:28:09.000Z","msg":"好去唔去 去墨西哥<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"932d201f8cd5e3c3c129271ea83d36e2037d86e6","tid":724693,"uid":174192,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec94d11e7cc6e9b69c8ad3f4223d5a304bb8cdec","tid":724693,"uid":155818,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-07-02T15:28:09.000Z","msg":"好去唔去 去墨西哥<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-07-02T15:32:15.000Z","msg":"有得走邊到我都去<br />\n利申;窮能一個"},{"pid":"de9515843e1580ad7fbb81ec435cdd99e1d4e993","tid":724693,"uid":77905,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-07-02T16:49:22.000Z","msg":"ON9<br />\n今朝有酒今朝醉係因為聽日唔知有冇命享咋"}]}