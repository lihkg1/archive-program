a3dee9792895c72abe8839b6335696e692ad","tid":932283,"uid":137604,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-08T00:59:30.000Z","msg":"同佢有仇就叫佢入去做啦。"},"citedBy":0,"replyTime":"2018-12-08T02:06:08.000Z","msg":"<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},{"pid":"9999c029b7326d95a7aa6535304a794ac5834702","tid":932283,"uid":51200,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-08T03:07:11.000Z","msg":"萬八都無<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"91ca20d5e6daa3729717deb20766ca4b7385aa04","tid":932283,"uid":838,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-12-08T03:26:04.000Z","msg":"有免費車飛<br />\n加車費=加人工<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"38c22a02f8c66de45fecbe4fa6b7b2f8145a7f4e","tid":932283,"uid":15501,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-12-08T04:04:02.000Z","msg":"一個技工的13850<br />\n一個技術員的18k左右<br />\n今年內部追薪最搞笑係新入職既加勁多<br />\n有年資既追得勁少<br />\n<br />\n變相入職10幾年既人工只係多入職1-2年既少少"},{"pid":"757087e4b5d7be72863631a9285f0c1cd9911f94","tid":932283,"uid":71596,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-08T04:07:25.000Z","msg":"9個月先六千"},{"pid":"095e19f639d2a171cf0b45825584f40d44df560c","tid":932283,"uid":51620,"like":0,"dislike":0,"score":0,"quote":{"pid":"757087e4b5d7be72863631a9285f0c1cd9911f94","tid":932283,"uid":71596,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-12-08T04:07:25.000Z","msg":"9個月先六千"},"citedBy":0,"replyTime":"2018-12-08T08:12:29.000Z","msg":"<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /> 確保做夠狗個月"}]}