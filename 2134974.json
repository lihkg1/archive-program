E6%B0%B4%E4%BA%BA%E7%94%A8crypto.com&d=dD36If%2FKkPZsb%2F00sEqzOUzKa5je2Ql9GrxhcbxOrro%3D&h=ada928ea\" data-auto-link target=\"_blank\">又水人用crypto.com</a>"},{"pid":"254e82fc4c85f0916fa19cc923066e1ccc55426c","tid":2134974,"uid":158735,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-01T09:21:03.000Z","msg":"轉去local exchange賣"},{"pid":"ab3db06172a3837ee4430545cf5424d74708ea8d","tid":2134974,"uid":6581,"like":0,"dislike":0,"score":0,"quote":{"pid":"9ed2068f27992ceeefc29444d8a004300da7ecd8","tid":2134974,"uid":2607,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-01T08:51:39.000Z","msg":"<a href=\"http://又水人用crypto.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2F%E5%8F%88%E6%B0%B4%E4%BA%BA%E7%94%A8crypto.com&d=dD36If%2FKkPZsb%2F00sEqzOUzKa5je2Ql9GrxhcbxOrro%3D&h=ada928ea\" data-auto-link target=\"_blank\">又水人用crypto.com</a>"},"citedBy":0,"replyTime":"2020-08-01T09:26:15.000Z","msg":"邊個水人用？你啊？"},{"pid":"9b1de830603ebfc0559dab5c43330b7463464e14","tid":2134974,"uid":186543,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-01T09:30:03.000Z","msg":"唔該pin呢個<br />\n<br />\n德國支付巨頭 Wirecard 在昨（26）日申請破產，這使得許多和該公司合作發行加密金融卡的公司都受到牽連，如 <a href=\"http://Crypto.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2FCrypto.com&d=dD36If%2FKkPZsb%2F00sEqzOUzKa5je2Ql9GrxhcbxOrro%3D&h=1022dadc\" data-auto-link target=\"_blank\">Crypto.com</a>、TexX、WireX 等公司。其中 MCO 加密金融卡的發行公司 <a href=\"http://Crypto.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2FCrypto.com&d=dD36If%2FKkPZsb%2F00sEqzOUzKa5je2Ql9GrxhcbxOrro%3D&h=1022dadc\" data-auto-link target=\"_blank\">Crypto.com</a> 就收到的 FCA 的通知，將暫停 MCO 加密金融卡在英國和歐洲的交易服務。<br />\n而 <a href=\"http://Crypto.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2FCrypto.com&d=dD36If%2FKkPZsb%2F00sEqzOUzKa5je2Ql9GrxhcbxOrro%3D&h=1022dadc\" data-auto-link target=\"_blank\">Crypto.com</a> 的首席執行長克里斯・馬斯薩勒克（Kris Marszalek）也在今日稍早於推特更新退款進度。<br />\n<br />\n他表示：「英國與歐洲地區卡片持有人的退款進度一切順利。我們正在努力找尋新的發卡商，將原有業務移轉過去。」<br />\n而雖然在歐洲、英國業務受到影響，但由於 MCO 加密金融卡在美國是由大都會商業銀行所發行的，因此業務不受影響；值得注意的是，MCO 卡在新加坡的發卡商同樣是 Wirecard，但該國政府至今並未阻止 <a href=\"http://Crypto.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2FCrypto.com&d=dD36If%2FKkPZsb%2F00sEqzOUzKa5je2Ql9GrxhcbxOrro%3D&h=1022dadc\" data-auto-link target=\"_blank\">Crypto.com</a> 繼續發卡，僅指示 Wirecard 將資金都先存進當地另外一家銀行，保護用戶資金。"},{"pid":"f28cec1348465d931f91789feeaeb99e66088fe4","tid":2134974,"uid":13754,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-08-01T09:33:17.000Z","msg":"用咭可以每個月免手續費咁撳$400波幣等值嘅港幣"},{"pid":"7ce0465ab677f53d4dd96544d99b2d20e1454031","tid":2134974,"uid":114774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-01T09:34:55.000Z","msg":"入左落card wallet就只可以禁返出黎"},{"pid":"307700cc0be19f972fc7ab4ddff79ed39716ea9b","tid":2134974,"uid":310721,"like":0,"dislike":0,"score":0,"quote":{"pid":"9b1de830603ebfc0559dab5c43330b7463464e14","tid":2134974,"uid":186543,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-01T09:30:03.000Z","msg":"唔該pin呢個<br />\n<br />\n德國支付巨頭 Wirecard 在昨（26）日申請破產，這使得許多和該公司合作發行加密金融卡的公司都受到牽連，如 <a href=\"http://Crypto.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2FCrypto.com&d=dD36If%2FKkPZsb%2F00sEqzOUzKa5je2Ql9GrxhcbxOrro%3D&h=1022dadc\" data-auto-link target=\"_blank\">Crypto.com</a>、TexX、WireX 等公司。其中 MCO 加密金融卡的發行公司 <a href=\"http://Crypto.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2FCrypto.com&d=dD36If%2FKkPZsb%2F00sEqzOUzKa5je2Ql9GrxhcbxOrro%3D&h=1022dadc\" data-auto-link target=\"_blank\">Crypto.com</a> 就收到的 FCA 的通知，將暫停 MCO 加密金融卡在英國和歐洲的交易服務。<br />\n而 <a href=\"http://Crypto.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2FCrypto.com&d=dD36If%2FKkPZsb%2F00sEqzOUzKa5je2Ql9GrxhcbxOrro%3D&h=1022dadc\" data-auto-link target=\"_blank\">Crypto.com</a> 的首席執行長克里斯・馬斯薩勒克（Kris Marszalek）也在今日稍早於推特更新退款進度。<br />\n<br />\n他表示：「英國與歐洲地區卡片持有人的退款進度一切順利。我們正在努力找尋新的發卡商，將原有業務移轉過去。」<br />\n而雖然在歐洲、英國業務受到影響，但由於 MCO 加密金融卡在美國是由大都會商業銀行所發行的，因此業務不受影響；值得注意的是，MCO 卡在新加坡的發卡商同樣是 Wirecard，但該國政府至今並未阻止 <a href=\"http://Crypto.com\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2FCrypto.com&d=dD36If%2FKkPZsb%2F00sEqzOUzKa5je2Ql9GrxhcbxOrro%3D&h=1022dadc\" data-auto-link target=\"_blank\">Crypto.com</a> 繼續發卡，僅指示 Wirecard 將資金都先存進當地另外一家銀行，保護用戶資金。"},"citedBy":0,"replyTime":"2020-08-01T13:15:13.000Z","msg":"亞太區MCO卡都無乜受影響"}]}