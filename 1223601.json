b18dc218458","tid":1223601,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"a37ddf33c28eb35bcd9e82532b2e1bb29858365b","tid":1223601,"uid":164307,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-14T17:51:32.000Z","msg":"<div style=\"text-align: center;\"><a href=\"https://youtu.be/BB-qvTKYSpc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FBB-qvTKYSpc&d=YB8lrFeyQ%2BkzHCEHpdql8EzlOXIvf7DEkQzrkg%2FJo1w%3D&h=572aad04\" data-auto-link target=\"_blank\">https://youtu.be/BB-qvTKYSpc</a></div>"},"citedBy":1,"replyTime":"2020-06-11T09:43:30.000Z","msg":"支那人"},"citedBy":2,"replyTime":"2020-06-11T09:45:53.000Z","msg":"唔好咁叫自己啦"},"citedBy":0,"replyTime":"2020-06-11T10:08:42.000Z","msg":"香港人真的是中國人<br />\n支那種"},{"pid":"39bba69d2268742b9aa5925e002e37174a605019","tid":1223601,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"4986ce28a7c818c9d32855357c13f985a04ad60e","tid":1223601,"uid":164307,"like":0,"dislike":0,"score":0,"quote":{"pid":"759807b6b3dc0078e3f05a6e644bbb18dc218458","tid":1223601,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"a37ddf33c28eb35bcd9e82532b2e1bb29858365b","tid":1223601,"uid":164307,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-14T17:51:32.000Z","msg":"<div style=\"text-align: center;\"><a href=\"https://youtu.be/BB-qvTKYSpc\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FBB-qvTKYSpc&d=YB8lrFeyQ%2BkzHCEHpdql8EzlOXIvf7DEkQzrkg%2FJo1w%3D&h=572aad04\" data-auto-link target=\"_blank\">https://youtu.be/BB-qvTKYSpc</a></div>"},"citedBy":1,"replyTime":"2020-06-11T09:43:30.000Z","msg":"支那人"},"citedBy":2,"replyTime":"2020-06-11T09:45:53.000Z","msg":"唔好咁叫自己啦"},"citedBy":1,"replyTime":"2020-06-11T10:15:47.000Z","msg":"港人救援方案何時出爐 陸委會：規劃已大致完成<br />\n最新更新：2020/06/11 17:54<br />\n<br />\n（中央社記者賴言曦台北11日電）外傳香港人道救援行動方案將出爐；陸委會今天下午說明，相關專案規劃已大致完成，但隨著香港情勢的快速變化，及政府對港版國安法立法情形的掌握，需作更完整細緻的規劃。<br />\n<br />\n大陸委員會今天下午舉行例行記者會，陸委會發言人邱垂正說明，有關港人協助服務的事宜，港澳關係條例及其許可辦法已有所規範，相關機關會依據相關法規積極妥適來處理。<br />\n<br />\n邱垂正說，相關專案規劃已大致完成，但隨著香港情勢的快速變化，以及政府對港版國安法立法情形的掌握，香港局勢發展及國際社會對香港的後續反應跟作法，政府還是需要精進完善相關機制，作更完整細緻的規劃，沒有外界所說的難產或延宕的問題。<br />\n<br />\n邱垂正也提到，陸委會會加強與相關機關的溝通和整合，等完成所有程序並核定後，會適時對外說明。<br />\n<br />\n由於中國大陸將在18至20日舉行全國人大常委會議，外界猜測這是否可能影響政府推出方案的時程。邱垂正對此回應，陸委會考慮外部情勢變化，會積極作為，「陸委會是非常有效率的單位」。<br />\n<br />\n中國推動「港版國安法」，為援助港人，總統蔡英文表示，由行政院組成專案，提出香港人道救援行動方案；專案由陸委會主責。<br />\n<br />\n陸委會隨後提出政府主導、陸委會跨部會整合、政府成立法人機構執行整合民間跨部門的公私協力、政府編列預算挹注經費等4原則，作為政府對來台尋求庇護的港人「居留、安置、照顧」3大目標的依據。（編輯：張淑伶）1090611"},{"pid":"3108649172cc1832c8d1a203648a7e7cc301d9fb","tid":1223601,"uid":164307,"like":0,"dislike":0,"score":0,"quote":{"pid":"39bba69d2268742b9aa5925e002e37174a605019","tid":1223601,"uid":337052,"like":0,"dislike":0,"score":0,"quote":{"pid":"4986ce28a7c818c9d32855357c13f985a04ad60e","tid":1223601,"uid":164307,"like":0,"dislike":0,"score":0,"quote":{"pid":"759807b6b3dc0078e3f05a6e644bbb18dc218458","tid":1223601,"uid":337052,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-11T09:43:30.000Z","msg":"支那人"},"citedBy":2,"replyTime":"2020-06-11T09:45:53.000Z","msg":"唔好咁叫自己啦"},"citedBy":1,"replyTime":"2020-06-11T10:15:47.000Z","msg":"港人救援方案何時出爐 陸委會：規劃已大致完成<br />\n最新更新：2020/06/11 17:54<br />\n<br />\n（中央社記者賴言曦台北11日電）外傳香港人道救援行動方案將出爐；陸委會今天下午說明，相關專案規劃已大致完成，但隨著香港情勢的快速變化，及政府對港版國安法立法情形的掌握，需作更完整細緻的規劃。<br />\n<br />\n大陸委員會今天下午舉行例行記者會，陸委會發言人邱垂正說明，有關港人協助服務的事宜，港澳關係條例及其許可辦法已有所規範，相關機關會依據相關法規積極妥適來處理。<br />\n<br />\n邱垂正說，相關專案規劃已大致完成，但隨著香港情勢的快速變化，以及政府對港版國安法立法情形的掌握，香港局勢發展及國際社會對香港的後續反應跟作法，政府還是需要精進完善相關機制，作更完整細緻的規劃，沒有外界所說的難產或延宕的問題。<br />\n<br />\n邱垂正也提到，陸委會會加強與相關機關的溝通和整合，等完成所有程序並核定後，會適時對外說明。<br />\n<br />\n由於中國大陸將在18至20日舉行全國人大常委會議，外界猜測這是否可能影響政府推出方案的時程。邱垂正對此回應，陸委會考慮外部情勢變化，會積極作為，「陸委會是非常有效率的單位」。<br />\n<br />\n中國推動「港版國安法」，為援助港人，總統蔡英文表示，由行政院組成專案，提出香港人道救援行動方案；專案由陸委會主責。<br />\n<br />\n陸委會隨後提出政府主導、陸委會跨部會整合、政府成立法人機構執行整合民間跨部門的公私協力、政府編列預算挹注經費等4原則，作為政府對來台尋求庇護的港人「居留、安置、照顧」3大目標的依據。（編輯：張淑伶）1090611"},"citedBy":1,"replyTime":"2020-06-11T11:26:15.000Z","msg":"講就會移？台灣同中共硬碰硬係遲早嘅事，如果真係要移都移其他地方啦！咪攬住你個鬼島ff"},{"pid":"5