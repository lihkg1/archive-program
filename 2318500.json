其後指出，劉的證供有誇大之嫌，被告在首次照射警員後已遭制服，劉不同意。<br />\n<br />\n<a href=\"https://hk.appledaily.com/local/20201209/4YW7U3YQBBAEPMX2AKWT5ECWYU/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20201209%2F4YW7U3YQBBAEPMX2AKWT5ECWYU%2F&d=zhjqHwqbwmwTWRz%2FWGYaUCq0XD4M5CHb8byFtBYuAsM%3D&h=725b73ab\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.appledaily.com%2Flocal%2F20201209%2F4YW7U3YQBBAEPMX2AKWT5ECWYU%2F&h=ceb7c3ef\" data-auto-link target=\"_blank\">https://hk.appledaily.com/local/20201209/4YW7U3YQBBAEPMX2AKWT5ECWYU/</a>"},{"pid":"af88c1d94820d99a585941bf6629bdce679b1147","tid":2318500,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-09T11:19:07.000Z","msg":"註: 依單唔係雙鄭審"},{"pid":"4ef5022a5baccd522aff511343536922de4bcc8f","tid":2318500,"uid":56115,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-09T11:29:12.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"e1b0b5826bed16fde8a83d139cb8b95b1527c4c7","tid":2318500,"uid":27122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-12-09T11:31:35.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"}]}