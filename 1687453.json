/i/X2396h2.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FX2396h2.gif&h=3a35acf1&s={SIZE}\" /><br />\n<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: red;\">光復香港 時代革命<br />\n寧化飛灰 不作浮塵</span></span></strong></blockquote>"},"citedBy":0,"replyTime":"2019-11-02T00:21:10.000Z","msg":"<img src=\"/assets/faces/big/agree.gif\" class=\"hkgmoji\" />"},{"pid":"5b68d0f2665e4535c7513ca71ea8a6ad3c586ea1","tid":1687453,"uid":8948,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-02T00:22:15.000Z","msg":"推"},{"pid":"2200aecde1ece52aa2ae3050160bb3f763c6d7dd","tid":1687453,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-02T00:22:54.000Z","msg":"<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"42191de79d93c3ce13fd15f29bba2e8ff1fe535a","tid":1687453,"uid":80261,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-02T00:23:34.000Z","msg":"推"},{"pid":"5a36f2f290b8ef3f91510e1181bc43a1d97d3f63","tid":1687453,"uid":291750,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-02T00:24:31.000Z","msg":"收到"},{"pid":"f66287457d0e3348995d99caa4922328c3c3d3a6","tid":1687453,"uid":54940,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-02T00:32:30.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"fe3fa8f6032186a993559eefaccb479515a07915","tid":1687453,"uid":41873,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-02T00:34:14.000Z","msg":"推"},{"pid":"dbd38fd6e1969fb21f5482fc2d199cc456426867","tid":1687453,"uid":8948,"like":0,"dislike":0,"score":0,"quote":{"pid":"f66287457d0e3348995d99caa4922328c3c3d3a6","tid":1687453,"uid":54940,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-02T00:32:30.000Z","msg":"<img src=\"/assets/faces/normal/adore.gif\"