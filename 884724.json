 src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"a9ffa0748bef719543c9a3de48f9763ee1dc6ea2","tid":884724,"uid":294,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-01T02:30:16.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"4cbe39a6c48ec7d5cf1c3a6b5dd7365bbe2d1b7b","tid":884724,"uid":200328,"like":2,"dislike":2,"score":0,"citedBy":1,"replyTime":"2018-11-01T02:52:17.000Z","msg":"child登你估假架?<br />\n都無睇過<br />\n分分鐘唔識邊個金庸添<br />\n人地講兩句就踩埋一份架啦<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n話咁易就帶動到佢地"},{"pid":"40ca67a88aba7e71631ef4b4ff5631f6565ffb6a","tid":884724,"uid":64073,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-11-01T02:54:58.000Z","msg":"講故佬一個<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d948471c558a3a910733f3397e771351155bcfc7","tid":884724,"uid":23400,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-01T02:59:03.000Z","msg":"支那都奶日本仔袋底啦，國仇家恨都冇啦，乜都講以前<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> 奶共金庸既彈出彈入既程度真係冇人能及<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> 等睇支那滅國啦<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"d4be104709e7f98893f756512b2f37cd7682d44b","tid":884724,"uid":163350,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-11-01T02:59:54.000Z","msg":"此回覆已被刪除"},{"pid":"a133b71a94221e29606f9073e22999a706a42887","tid":884724,"uid":38189,"like":0,"dislike":1,"score":-1,"quote":{"pid":"7ade9c813c0e6c3b6f8a0f3b6f42b7d5c26a5341","tid":884724,"uid":37733,"like":4,"dislike":7,"score":-3,"citedBy":2,"replyTime":"2018-10-31T23:53:20.000Z","msg":"唔係點顯得我地與別不同"},"citedBy":0,"replyTime":"2018-11-01T03