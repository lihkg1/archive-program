https://lihkg.com/thread/1479130/page/1\" data-auto-link target=\"_blank\">https://lihkg.com/thread/1479130/page/1</a><br />\nTG CHANNEL :<a href=\"https://t.me/WallPaperENews\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2FWallPaperENews&d=y6uglPlKbSLkZz%2BcPL4okVGN3hMT3pF%2B84p80JiLMiI%3D&h=6ded60b8\" data-auto-link target=\"_blank\">https://t.me/WallPaperENews</a>"},{"pid":"fdada303917fc5ca8e0062f73d0c311523966d47","tid":1561701,"uid":86113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T02:25:17.000Z","msg":"831"},{"pid":"98168d3b985c391bf6fd900a51e58fe8d951bf15","tid":1561701,"uid":86113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T02:25:28.000Z","msg":"721"},{"pid":"557a154f53ebf40c017d89a5a3701912d70078d5","tid":1561701,"uid":86113,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-12T02:25:42.000Z","msg":"新屋嶺"}]}