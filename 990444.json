01aaa9887d531ea7749158&amp;oe=5CC1AEE5\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkg3-1.xx.fbcdn.net%2Fv%2Ft1.0-9%2F50682915_1873485592778060_8735492386576138240_n.jpg%3F_nc_cat%3D101%26_nc_ht%3Dscontent-hkg3-1.xx%26oh%3D33c0b20f9d01aaa9887d531ea7749158%26oe%3D5CC1AEE5&h=4c9bce18&s={SIZE}\" /><br />\n<img src=\"https://scontent-hkg3-1.xx.fbcdn.net/v/t1.0-9/50608268_1873485649444721_1489042806218424320_n.jpg?_nc_cat=106&amp;_nc_ht=scontent-hkg3-1.xx&amp;oh=42b10682377e8ed8335af0613ec74fb2&amp;oe=5CB8FB13\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkg3-1.xx.fbcdn.net%2Fv%2Ft1.0-9%2F50608268_1873485649444721_1489042806218424320_n.jpg%3F_nc_cat%3D106%26_nc_ht%3Dscontent-hkg3-1.xx%26oh%3D42b10682377e8ed8335af0613ec74fb2%26oe%3D5CB8FB13&h=be451f8e&s={SIZE}\" /><br />\n<a href=\"https://www.facebook.com/376443552482279/posts/1873489519444334/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F376443552482279%2Fposts%2F1873489519444334%2F&d=rYg5mx6yknX5c4F1CB4In57TfgnX9jywtYe9GXZmhCU%3D&h=ccb7d191\" target=\"_blank\">https://www.facebook.com/376443552482279/posts/1873489519444334/</a>"},"citedBy":0,"replyTime":"2019-01-21T15:21:06.000Z","msg":"呢張簡介圖本身都唔齊"},{"pid":"f96ef30bfff80ad8325f3748683237e6f700303c","tid":990444,"uid":33868,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-21T15:21:36.000Z","msg":"點解個地圖無富裕樓"},{"pid":"3549d9a00ce653e7d2e2c408abf6885b38ed9a71","tid":990444,"uid":43518,"like":0,"dislike":1,"score":-1,"quote":{"pid":"068a45f0017a415872e0200f71dda7c71fc50b1f","tid":990444,"uid":200317,"like":2,"dislike":0,"score":2,"quote":{"pid":"2db6473befd1dc888443dab3f66d734ed7ca3cc6","tid":990444,"uid":43518,"like":2,"dislike":0,"score":2,"quote":{"pid":"439c51854132845bd63887041064ef3f93bbaadd","tid":990444,"uid":200317,"like":14,"dislike":2,"score":12,"citedBy":2,"replyTime":"2019-01-21T15:12:56.000Z","msg":"真心覺得呢種設計正啊 好過旺角係地面塞死<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-01-21T15:17:11.000Z","msg":"地面太多人 元朗旺角等燈位過馬路勁多人塞住哂"},"citedBy":1,"replyTime":"2019-01-21T15:18:46.000Z","msg":"旺角真心overload<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 係咪得我一個覺得成個城市管理規劃好失敗<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-01-21T15:26:29.000Z","msg":"睇返新聞 前年有話起<br />\n<br />\n建議的行人天橋系統旨在紓緩區內行人路的擠迫情況、改善行人環境、加強旺角中心區行人通道的連接性、減少人車爭路及改善行人安全。<br />\n建議的行人天橋系統主要包括:-<br />\n亞皆老街段行人天橋(長約六百二十米) - 沿亞皆老街由塘尾道行人天橋伸延至黑布街。<br />\n塘尾道段行人天橋(長約一百七十米) - 沿塘尾道由塘尾道行人天橋伸延至福全街。<br />\n<br />\n但最驚又係變左賓賓橋<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"284a4c36950ab80a579cee4202a8226e37b56a5f","tid":990444,"uid":45672,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-21T15:31:23.000Z","msg":"幾時將龍德街工廠改埋做住宅<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" />"},{"pid":"ddf0a0ab460323726e0733d010e44ae65be4198e","tid":990444,"uid":104804,"like":0,"dislike":0,"score":0,"quote":{"pid":"86f248b205f4b471a657aa703098ea65da857aef","tid":990444,"uid":150400,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2019-01-21T15:15:05.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-01-21T15:33:14.000Z","msg":"去楊屋道街市"},{"pid":"a185d2bd4dfccfc672ab193f3dcc25721278f3de","tid":990444,"uid":202278,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-01-21T15:35:14.000Z","msg":"此回覆已被刪除"},{"pid":"0a686df62fca3b32b9e84f11217ff2af3d7480ad","tid":990444,"uid":60529,"like":0,"dislike":0,"score":0,"quote":{"pid":"52049f79b3b845f440e754a6018deca120052e7d","tid":990444,"uid":39608,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-01-21T14:58:22.000Z","msg":"之後再更新，由荃灣站行去荃灣西站，荃灣廣場 &rarr; 祈德尊新邨/灣景廣場 &rarr; 全城滙&rarr;荃灣西站<img src=\"/assets/faces/lm2/support.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n（獨媒特約報導）荃灣天橋陣即將完成最後一塊拼圖。新樓盤「全城滙」的五條行人天橋開通後，行人日後可由荃灣站直接經天橋步行至荃灣西站，不再需在如心廣場或祈德尊新邨返回地面再步行到荃灣西站，全程「堅離地」。<br />\n<br />\n由華懋和港鐵共同發展的荃灣西站新盤「全城滙」，預計將於2019年第一季入伙。根據公契，「全城滙」一樓設有五條行人天橋，分別連接如心廣場、祈德尊新邨及荃灣西站。五條行人天橋由發展商承擔建設費用，並須負責管理及保養。<br />\n<br />\n<img src=\"https://c1.staticflickr.com/5/4452/36878130984_27970b840c_h.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fc1.staticflickr.com%2F5%2F4452%2F36878130984_27970b840c_h.jpg&h=1667c024&s={SIZE}\" /><br />\n<br />\n<a href=\"http://www.inmediahk.net/node/1052731\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1052731&d=rYg5mx6yknX5c4F1CB4In57TfgnX9jywtYe9GXZmhCU%3D&h=11e468c9\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fwww.inmediahk.net%2Fnode%2F1052731&h=6edec65e\" target=\"_blank\">http://www.inmediahk.net/node/1052731</a>"},"citedBy":0,"replyTime":"2019-01-21T15:35:30.000Z","msg":"係愉景新城&gt;荃灣站&gt;荃灣西站<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n或者熊貓&gt;荃灣站&gt;荃灣西站<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"4c78ff75e65cd62f15b0e6b607958df4b1f37226","tid":990444,"uid":29093,"like":2,"dislike":2,"score":0,"citedBy":1,"replyTime":"2019-01-21T15:35:35.000Z","msg":"哇  天橋城呀 <br />\n<br />\n腥港新地標呀  最新打卡位，  上蝗蟈論壇 宣傳下先 <br />\n<br />\n<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> 好快就迫爆全部天橋"},{"pid":"a347ada002dc18e9fdc59e0c6af484e2d1af161a","tid":990444,"uid":810,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-01-21T15:42:28.000Z","msg":"幾時可以行哂18區"},{"pid":"52a6c32057f55c99feed901a4ae2681b6d97a20e","tid":990444,"uid":39608,"like":3,"dislike":1,"score":2,"quote":{"pid":"4c78ff75e65cd62f15b0e6b607958df4b1f37226","tid":990444,"uid":29093,"like":2,"dislike":2,"score":0,"citedBy":1,"replyTime":"2019-01-21T15:35:35.000Z","msg":"哇  天橋城呀 <br />\n<br />\n腥港新地標呀  最新打卡位，  上蝗蟈論壇 宣傳下先 <br />\n<br />\n<br />\n<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />