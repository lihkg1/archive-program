5bdb638cd4f0ea2360070d97cb239e0d4513da38","tid":2178353,"uid":36157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-28T10:40:06.000Z","msg":"唔好通街貼真係<br />\n<br />\n我講緊中囯國"},{"pid":"3df77ed1ebebc68041db7a18faf7994a6ac211d2","tid":2178353,"uid":165200,"like":10,"dislike":1,"score":9,"quote":{"pid":"973a6af1c33f61322939882f1116f10f031c2441","tid":2178353,"uid":35430,"like":41,"dislike":1,"score":40,"citedBy":2,"replyTime":"2020-08-28T10:23:03.000Z","msg":"有人在微博上要求刪除，說是事關國家安全<br />\n<br />\n屌那星墓碑都係<img src=\"/assets/faces/lm2/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-28T10:40:51.000Z","msg":"国家安全的確好重要，刪相呢啲點夠，一定要做得徹底，剷平個墳，然後將死者全家滅口係基本嘢，其他親屬、鄰居、朋友等等，視乎合作態度而定，滅口、軟禁或者發配邊疆都可以考慮 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n利申：愛国 <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"ce96b80ef3563792310dd7b660bddfda9a860841","tid":2178353,"uid":25424,"like":14,"dislike":0,"score":14,"citedBy":0,"replyTime":"2020-08-28T10:41:58.000Z","msg":"學sims咁賣左塊碑賺返$10<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"a47c958d81ae35359090390889410a430543a80a","tid":2178353,"uid":58630,"like":2,"dislike":0,"score":2,"quote":{"pid":"6828736375a0daf7ab138b851c9f682b7a5c1aa9","tid":2178353,"uid":55317,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-08-28T10:32:25.000Z","msg":"點解支那唔公開死亡人數？<br />\n<br />\n人地印度風光大葬 支那唔見得光<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-28T10:42:50.000Z","msg":"驚啲士兵知原來上戰場會死<img src=\"/assets/faces/dog/scare.gif\" class=\"hkgmoji\" />"},{"pid":"1218d80159c705df6d9c80a4642bd41c5ddb6863","tid":2178353,"uid":330227,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-28T10:44:10.000Z","msg":"<im