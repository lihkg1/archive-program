ra.io/ipfs/QmWAbx2ZgRz14yMogspr3PM3DnxF9r4ci55t3oXvR7rqhY?filename=j2tJcd1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fj2tJcd1.jpg&h=0de27ed6&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmTVyQ5etzXZCvAojZiNiRCNcmLYUENsfC5vaKQuZETfsL?filename=MAYhgFG.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FMAYhgFG.jpg&h=35c8c2cc&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmTPNxPZGGJhMEbeBtMFEkM8UFmTHeVTXsFG4g8oMjE4qR?filename=hZETzsm.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhZETzsm.jpg&h=dae345fd&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmbuh9nAUXimz5SW3TcWvQsHiQZhsTJaX8HAkEQWYnq7eW?filename=u8i1JkG.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fu8i1JkG.png&h=337cde0d&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2021/01/11/003309_f8ae17c6bd36ae5f4bd8b10b046cd7b2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2021%2F01%2F11%2F003309_f8ae17c6bd36ae5f4bd8b10b046cd7b2.png&h=2277483e&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qma7Es7KQnKUgLwXZ8MT9zMr4sckmmdZdU8sTMUwXnfG3q?filename=Hyyw5y2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHyyw5y2.jpg&h=61f7bf94&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmZPA4vqdEdRJetTfgWfk7WPXabejJpEY3CUVcwSTDpNQa?filename=JaYUiT2.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJaYUiT2.png&h=0557e84c&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmP7Fd9ZcW7Lj8t3fAHrn1SsLjsNdgUJk2UuLftQELjpew?filename=3yQO7Nn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F3yQO7Nn.jpg&h=0418abcc&s={SIZE}\" /><br />\n<br />\nTSLA是你們的方舟，信者必得救（馬斯克福音1:1）<br />\n<br />\n工作是為了購買更多的TSLA（馬斯克福音1:2）<br />\n<br />\n馬斯克看見這許多的人，就上了山，既已坐下，門徒到他跟前來，<br />\n他就開口教訓他們，說：<br />\nSH的人有福了！因為天國是他們的。<br />\nSH的人有福了！因為他們必得安慰。<br />\nSH的人有福了！因為他們必承受地土。<br />\nSH的人有福了！因為他們必得飽足。<br />\n（馬斯克福音1:3）<br />\n<br />\n保持信念是邁向火星的第一步（馬斯克福音1:4）<br />\n<br />\n日期滿了，神的國近了。你們當悔改，信TSLA！<br />\n（馬斯克福音1:5）<br />\n<br />\n神愛世人，甚至將他的TSLA賜給他們，叫一切信他的，不致滅亡，反得永生。<br />\n（馬斯克福音1:6）<br />\n <br />\n馬斯克回答說：「我實在告訴你們，你們若有信心，不疑惑，不但能行無花果樹上所行的事，就是對這座山說：『你挪開此地，投在海裡！』也必成就。<br />\n你們禱告，無論求什麼，只要信，就必得著。<br />\n（馬斯克福音1:7）<br />\n<br />\n惟有忍耐到底的，必然得救。（馬斯克福音1:8）<br />\n<br />\n淡 淡 看 哪 、 你 們 的 廢 淡 區 成 為 荒 場 留 給 你 們 ． 我 告 訴 你 們 、 從 今 以 後 你 們 不 得 再 見 我 、 直 等 到 你 們 說 、 奉 特 斯 拉 名 來 的 是 應 當 稱 頌 的 。<br />\n（馬斯克福音1:9）<br />\n<br />\nTesla信眾請進，每天讀鋼鐵俠禱文一次就會天天破頂<br />\n<br />\n我們在美國的父，<br />\n願人都尊你的名為鋼鐵俠，願你的space X降臨，願你的tesla，行在地上，如同starlink行在天上。<br />\n我們晚晚炒的美股，今日分拆給我們；接上我們的大腦，如同我們接上電腦的接口。<br />\n不要叫我們遇見熊市，救我們脫離貧窮；<br />\n因為火星，地球，月球，全是你的，直到永遠。阿門。<br />\n<img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},{"pid":"09ee741e2a116bcd43980fdb557d8b93181f8d11","tid":2502793,"uid":336590,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-24T13:23:46.000Z","msg":"傻橙<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"a849eb41ce17b1583c883ad1a6d36bcc44ace4a6","tid":2502793,"uid":299792,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-24T13:24:21.000Z","msg":"LM<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"b607f79ea13e4cb85dd91a60f9fad0ba907a2b0a","tid":2502793,"uid":336590,"like":0,"dislike":0,"score":0,"quote":{"pid":"a849eb41ce17b1583c883ad1a6d36bcc44ace4a6","tid":2502793,"uid":299792,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-24T13:24:21.000Z","msg":"LM<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-04-24T13:24:4