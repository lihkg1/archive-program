ets/faces/lm2/aura.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/aura.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2021-04-26T14:53:34.000Z","msg":"改過個TITLE拉, 死柒頭"},"citedBy":1,"replyTime":"2021-04-26T14:57:54.000Z","msg":"咁惡做咩呢"},{"pid":"9e8ef66d85f2c95096d996d60e10e1d66a532fb6","tid":2502793,"uid":336590,"like":2,"dislike":0,"score":2,"quote":{"pid":"450a14c298a3d294d2f0bec95de7675442ff54eb","tid":2502793,"uid":126452,"like":0,"dislike":4,"score":-4,"quote":{"pid":"7bbdee1c8357b32c6f79d5e2ed604314d1af498b","tid":2502793,"uid":336590,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-04-24T13:23:35.000Z","msg":"<img src=\"https://na.cx/i/SfR2ehn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSfR2ehn.jpg&h=15903752&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/dtjfzhi.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fdtjfzhi.jpg&h=09f2f797&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/uQrJJaA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FuQrJJaA.jpg&h=344f19f9&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/4ghkLoQ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4ghkLoQ.jpg&h=573ff2f8&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/R94G6Y1.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FR94G6Y1.gif&h=60c28ac1&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/vZ8HRtc.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FvZ8HRtc.gif&h=2d704790&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/cSPv0mH.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FcSPv0mH.gif&h=6ddb3bf2&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/j2tJcd1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fj2tJcd1.jpg&h=0de27ed6&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/MAYhgFG.jpg\" data-thumbnail-src=\"ht