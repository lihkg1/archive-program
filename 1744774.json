,"citedBy":0,"replyTime":"2019-11-22T04:42:48.000Z","msg":"所以話人哋真係法治囉"},{"pid":"d7f6b5e155cec7b856721739992475937f4c45cc","tid":1744774,"uid":41608,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-22T05:17:58.000Z","msg":"對比返中国同香港，<br />\n好精彩"},{"pid":"3e6958960c5cbc205ba361a4bd45e5fb92837166","tid":1744774,"uid":241723,"like":0,"dislike":0,"score":0,"quote":{"pid":"48a8563485c79ee3607e8f239e8237998654444b","tid":1744774,"uid":184679,"like":22,"dislike":0,"score":22,"citedBy":1,"replyTime":"2019-11-22T02:01:26.000Z","msg":"<img src=\"https://img.ltn.com.tw/Upload/news/600/2019/07/22/phprsUoNX.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.ltn.com.tw%2FUpload%2Fnews%2F600%2F2019%2F07%2F22%2FphprsUoNX.jpg&h=cddcec5a&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-11-22T05:19:17.000Z","msg":"秒<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}