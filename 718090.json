8B%E6%80%A7%E6%A0%BC-073236878.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.yahoo.com%2F%25E4%25B8%2589%25E5%2580%258B%25E5%25A5%25B3%25E4%25BA%25BA-%25E5%2580%258B%25E5%259B%25A0-%25E7%259C%259F%25E4%25BA%25BA%25E7%2589%2588-%25E7%25B2%25BE%25E7%25A5%259E%25E5%2588%2586%25E8%25A3%2582%25E6%2583%2585%25E4%25BE%25B6%25E6%259C%2589400%25E5%2580%258B%25E6%2580%25A7%25E6%25A0%25BC-073236878.html&d=aSudrojFQ0lCV3FZcZzkFS7PofNJLCAwyGXsi6MH%2FEQ%3D&h=86e9a0f8\" data-auto-link target=\"_blank\">https://hk.news.yahoo.com/%E4%B8%89%E5%80%8B%E5%A5%B3%E4%BA%BA-%E5%80%8B%E5%9B%A0-%E7%9C%9F%E4%BA%BA%E7%89%88-%E7%B2%BE%E7%A5%9E%E5%88%86%E8%A3%82%E6%83%85%E4%BE%B6%E6%9C%89400%E5%80%8B%E6%80%A7%E6%A0%BC-073236878.html</a><br />\n<br />\n普通人好難分呢兩種病<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"132ef7de3c3d180e73f40a1f109ebe01201532be","tid":718090,"uid":47359,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-06-26T14:23:26.000Z","msg":"呢啲叫人格分裂<br />\n精神分裂又叫思覺失調(Schizophrenia)係另一個病嚟"},{"pid":"f3f4e52d8fb7b1b3291d2bf69b54fedc19c90a44","tid":718090,"uid":160807,"like":0,"dislike":0,"score":0,"quote":{"pid":"132ef7de3c3d180e73f40a1f109ebe01201532be","tid":718090,"uid":47359,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2018-06-26T14:23:26.000Z","msg":"呢啲叫人格分裂<br />\n精神分裂又叫思覺失調(Schizophrenia)係另一個病嚟"},"citedBy":0,"replyTime":"2018-06-26T14:31:16.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"89ac923a0113e5ed1166f2e17cd245496c8c1a7f","tid":718090,"uid":160807,"like":0,"dislike":0,"score":0,"quote":{"pid":"54b9f687e015fadcec4ed2f4f5c4d9bccf2fb74b","tid":718090,"uid":136662,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-06-26T14:12:54.000Z","msg":"仲勁過24個比利<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-06-26T14:32:03.000Z","msg":"人地係400個比利<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"6bf5886eefb