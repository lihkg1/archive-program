emergencyresponsecard_29750033.html&d=9l2h7zKZEd5x%2FdYTAZY3whZmCTjK%2FM6Kxb2TK%2FvXQ0I%3D&h=2ada0151\" target=\"_blank\">https://www.cdc.gov/niosh/ershdb/emergencyresponsecard_29750033.html</a>"},"citedBy":0,"replyTime":"2019-07-28T15:27:55.000Z","msg":"8月5日全港齊心大罷工<br />\n<a href=\"https://lih.kg/1378023\" data-auto-link target=\"_blank\">https://lih.kg/1378023</a><br />\n- 分享自 LIHKG 討論區<br />\n <br />\n齊心一齊推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n入黎一齊推<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n<br />\n8月5號一齊罷<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"88ed32a5f59f543ab8f42348467b9c22c46b80cd","tid":1376342,"uid":281467,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T15:28:31.000Z","msg":"推"},{"pid":"7ce01b8a9afe5be3ec888d8ff67b6b98b5f5f864","tid":1376342,"uid":275588,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T15:28:46.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c0d8539b3b6de56d9484fc8dceb1654d35e5746a","tid":1376342,"uid":246118,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T15:28:46.000Z","msg":"推"},{"pid":"5aa7dd1abfabf04c457da8b759dadd1861eaa56d","tid":1376342,"uid":181981,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T15:29:12.000Z","msg":"推"},{"pid":"9e1e5927ca9d1c2bac80b6a3a3fb715a358b0430","tid":1376342,"uid":287822,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T15:30:29.000Z","msg":"推俾d屋企人/老人家睇"},{"pid":"6ecb5a8489606eca465ce50af2f55b92b4234e19","tid":1376342,"uid":193786,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T15:34:33.000Z","msg":"推"},{"pid":"17c0f79acb7393c347d04bc2f1b9886e638a44cd","tid":1376342,"uid":31185,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T15:35:07.000Z","msg":"推"},{"pid":"781b46e6a181899fd57