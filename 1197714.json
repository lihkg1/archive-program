:04.000Z","msg":"<img src=\"https://scontent-hkg3-2.xx.fbcdn.net/v/t1.0-9/62265086_2950891668284425_8436017343661867008_n.jpg?_nc_cat=110&amp;_nc_eui2=AeFUffA5dm9efcMDvldvqI01wIyu1UDGffwve3qPN61lkftgRlffJkjD5I9trxoARoCwnTJHRy6ktlTdqYqR2VdF2ntGoo9x49v75zs2Uv-RYw&amp;_nc_ht=scontent-hkg3-2.xx&amp;oh=5d0d9d2ad748149b0a9b4db25a4f10f2&amp;oe=5D98003D\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent-hkg3-2.xx.fbcdn.net%2Fv%2Ft1.0-9%2F62265086_2950891668284425_8436017343661867008_n.jpg%3F_nc_cat%3D110%26_nc_eui2%3DAeFUffA5dm9efcMDvldvqI01wIyu1UDGffwve3qPN61lkftgRlffJkjD5I9trxoARoCwnTJHRy6ktlTdqYqR2VdF2ntGoo9x49v75zs2Uv-RYw%26_nc_ht%3Dscontent-hkg3-2.xx%26oh%3D5d0d9d2ad748149b0a9b4db25a4f10f2%26oe%3D5D98003D&h=8a0ce878&s={SIZE}\" />"},{"pid":"5ff07252040aab50169674e94b311992ff26bc7f","tid":1197714,"uid":189,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-10T06:41:52.000Z","msg":"罷工唔係叫你返屋企瞓啊，係要大家出去立會！"},{"pid":"d02652721879e81b23d6c164b63ce4fb7ffff8b8","tid":1197714,"uid":26451,"like":0,"dislike":4,"score":-4,"citedBy":0,"replyTime":"2019-06-10T06:42:49.000Z","msg":"此回覆已被刪除"},{"pid":"db28698ab0e8100162c26857f851272fd565582c","tid":1197714,"uid":13724,"like":0,"dislike":0,"score":0,"quote":{"pid":"a9238298b02bf4e060efaaa4bdf8c71357ff6c3b","tid":1197714,"uid":74171,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-06-10T05:06:22.000Z","msg":"衰啲諗，罷工係咪真係有用？可以罷幾耐？<br />\n除非有大型公型公司搞，唔係影響唔大<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-10T06:43:55.000Z","msg":"自己射波啦"},{"pid":"5d81694159b1657d018b5883e8875c38b0bb5fba","tid":1197714,"uid":114781,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-10T06:45:15.000Z","msg":"推，今次真係背水一戰"},{"pid":"c5e5e19a0dde61bff0828b3a57199dda65909cbf","tid":1197714,"uid":143499,"like":0,"dislike":3,"score":-3,"citedBy":0,"replyTime":"2019-06-10T06:53:04.000Z","msg":"星期日又last game有endgame<br />\n<br />\n<br />\n<br />\n星期三又嚟個背水一戰<br />\n<br />\n<br />\n咁下個禮拜日改乜嘢名好？<br />\n<br />\n<br />\n<br />\n前幾日我聽你哋講，為咗大是大非唔好搞咁多嘢出聲， 好啦幫你搵到一百萬人出嚟啦屌你老母又係夠鐘和平散去<br />\n<br />\n<br />\n咁咪證明我之前恥笑endgame呢個名冇錯囉<br />\n<br />\n以前就永續抗爭，今日就永續最後一戰<br />\n<br />\n<br />\n民陣大哪哪有一百萬人都唔佔領立法會<br />\n<br />\n<br />\n我睇你禮拜三做得出啲乜"}]}