plyTime":"2019-03-06T13:46:14.000Z","msg":"."},{"pid":"68cda019252bacddb26e204e3526072e7d52c2c5","tid":718363,"uid":6122,"like":0,"dislike":0,"score":0,"quote":{"pid":"e0ca2e4004cb91f891493ba2c9cb5b8f566446fe","tid":718363,"uid":1567,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-03-06T13:46:14.000Z","msg":"."},"citedBy":0,"replyTime":"2019-04-01T02:35:08.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"138645823008e30d2f8a6371517c48b72b3f77b2","tid":718363,"uid":6122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-04-24T04:02:31.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"7081a3790b10dfa6e17dcc83a054f15fee4637ba","tid":718363,"uid":1567,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-18T07:54:38.000Z","msg":"."},{"pid":"f3096edc29ff156ea0f26e9f5d4af36cca1cbc92","tid":718363,"uid":82717,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-18T08:25:39.000Z","msg":"茶盅 蓋碗茶 三才杯 少咗挓底個碟又有咩咩好玩"},{"pid":"8591d2b9bf065b12132cdf82789ef171d9c4585b","tid":718363,"uid":6122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-08T14:09:57.000Z","msg":"."},{"pid":"5a699dea91ee8d0354a1f19d0248551f332fe3c0","tid":718363,"uid":6122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-03T12:24:09.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"de884d1a9008e0c82d133a30048a7d2293df321b","tid":718363,"uid":6122,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T02:39:19.000Z","msg":"."},{"pid":"5bea04a50f62e7235b9bc62f6833f579ef251e9c","tid":718363,"uid":1567,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T11:55:32.000Z","msg":"."},{"pid":"a192ea2641748072b85fddd3bb7314811acab26a","tid":718363,"uid":1567,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-17T00:31:48.000Z","msg":"."},{"pid":"3899aa8537b745629ace43c0ea2a1e8c5e163914","tid":718363,