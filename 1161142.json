/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n識配埋chord真係好叻<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"b2aa96ed9fef9abd326dc50ffc4cc5abf6041cd9","tid":1161142,"uid":36088,"like":0,"dislike":4,"score":-4,"quote":{"pid":"0783817b9b08d198da98414bccc1949069da9d16","tid":1161142,"uid":228995,"like":0,"dislike":0,"score":0,"quote":{"pid":"d8e048e4dc82f39a89a49d4b5efbd655600aeaf7","tid":1161142,"uid":36088,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-19T03:44:15.000Z","msg":"就咁睇同練習有關<br />\n你點練歌？<br />\n點藝術家皮氣法？"},"citedBy":1,"replyTime":"2019-05-19T04:02:47.000Z","msg":"細個都係拍子機+睇譜吹+練手指啦<br />\n<br />\n藝術家脾氣就常見個類啦<br />\n老師真係有料，寸得起<br />\n又做過大樂團成員<br />\n<br />\n我無天分學到後期自己都覺得唔好意思浪費人地時間<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-19T04:31:10.000Z","msg":"其實我唔識乜係藝術家脾氣<br />\n如果老師講個要求你明但係你做唔到咁係練習問題，一係就自己以為明其實未明<br />\n如果老師唔認講到你明就係老師問題<br />\n學音樂冇天份唔天份，只有努力問題<br />\n如果努力方向錯咗咁就好慘<br />\n神童到貝多芬咁都會練琴練到用水浸手"},{"pid":"aa4a5d81cda5368621dc0b845a785bec09563cd5","tid":1161142,"uid":228995,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ac7f6d5be839bef20e9aa51570886f0302fc197","tid":1161142,"uid":239157,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-19T04:26:07.000Z","msg":"音樂感應該唔止音準，仲有拍子感，係天生嘅，後天練點都差啲<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-19T04:31:22.000Z","msg":"係<br />\n<br />\n當年考樂理<br />\n<br />\n要聽melody拍子係幾拍<br />\n<br />\n亂9做"},{"pid":"208cca81f47966d42bbf21ad7566d32ce2cf846e","tid":1161142,"uid":36088,"like":1,"dislike":0,"score":1,"quote":{"pid":"dc1f5abdc196af7c27aa705958d92f9258905a4a","tid":1161142,"uid":228995,"like":0,"dislike":0,"score":0,"quote":{"pid":"f63210cc7f5d059cff3116ad00b96ad59ff8d059","tid":1161142,"uid":234737,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-19T04:22:53.000Z","msg":"可試試下聽首歌 再一個一個音搵返出嚟<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-19T04:30:29.000Z","msg":"我對住部琴只可以逐個音trial and error 篤<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n識配埋chord真係好叻<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-19T04:33:30.000Z","msg":"配chord係有方法，配得有幾快同經好係經驗問題"},{"pid":"52a395e65d2bc4e61cd1260c708d0076a429d302","tid":1161142,"uid":100016,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-05-19T04:38:24.000Z","msg":"藝術家脾氣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 笑撚左"},{"pid":"9848363743eaaebda125dbbd4a3df6c0b0928438","tid":1161142,"uid":228995,"like":0,"dislike":0,"score":0,"quote":{"pid":"52a395e65d2bc4e61cd1260c708d0076a429d302","tid":1161142,"uid":100016,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-05-19T04:38:24.000Z","msg":"藝術家脾氣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 笑撚左"},"citedBy":1,"replyTime":"2019-05-19T04:41:00.000Z","msg":"大家無遇過/聽過咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n雖然個老師係男人<br />\n<br />\n但一個總會有幾日M到<br />\n一M到就開火<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"e0bf32425f9628dde5bbc01abcdcfdcd5090abe8","tid":1161142,"uid":204537,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-19T04:54:04.000Z","msg":"首先係音感同perfect pitch<br />\n音感就係例如你可以分辨到半個半音音階嘅分別<br />\n聽得出微微#/b左嘅音並且知道係#定係b左<br />\n而且對於音準有一套嚴謹嘅要求<br />\nPerfect pitch例如係一聽就知道係咩音<br />\n大概係咁<br />\n<br />\n而其次就係拍子同節奏感<br />\n除左跟beat/唔會甩beat之外<br />\n好嘅人可以創作/輕易摸索到不同嘅拍子<br />\n普通4/4拍子當然係人都可以摸索到<br />\n但係一個音樂感強嘅人可以摸索埋一啲麻煩拍子<br />\n例如3/4, 5/4呢累冇咁常規嘅拍子"},{"pid":"83e1e22109af8bbd999edaceba4960c7de39c07c","tid":1161142,"uid":128584,"like":0,"dislike":1,"score":-1,"quote":{"pid":"6ff6f23ec6455e04500150475e8cf9ebc202c345","tid":1161142,"uid":214036,"like":0,"dislike":9,"score":-9,"citedBy":2,"replyTime":"2019-05-19T03:45:41.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-05-19T07:03:16.000Z","msg":"咁多負皮，兒登仔唔鍾意聽真話<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"346ba6f9f94e3c6c3182be274b1303700ccbd230","tid":1161142,"uid":46967,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-05-19T11:26:55.000Z","msg":"其實音樂感唔係講緊拍子準唔準 D音岩唔岩 咁表面 (即係一係岩/錯)<br />\n<br />\n而係講緊對首歌個氣氛點去決定/處理<br />\n為達到某個感覺/氣氛， 去決定大細聲/發音法/分句<br />\n<br />\n聽音準唔準係幫到你 一睇到份譜 大概就知首歌大約係點"},{"pid":"d15af832e29e410a649c76f347162fe0d472033e","tid":1161142,"uid":133680,"like":0,"dislike":0,"score":0,"quote":{"pid":"965555069c3757623f2f873d120c05fa1fd6fe9f","tid":1161142,"uid":228995,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-19T03:19:32.000Z","msg":"有無學過音樂都一齊討論下<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n自己讀書時學校逼學樂器（woodwind）<br />\n不過一直玩得唔好 成日比老師話（藝術家脾氣）<br />\n唔係無花時間練<br />\n不過自己對拍子音準都無咩天分<br />\n最後只係勉強考左張7級證書 僅僅合格<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n知道自己無呢方面天分<br />\n有好多人可以聽到首流行曲可以講返係咩音符，然後鋼琴彈返出黎<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n可能呢個技能好多人都識<br />\n但自己只係停留唱返出黎個階段<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<br />\n其實有無學術研究過呢種能力係先天定後天？<br />\n成日話音樂感，音樂感究竟係包括咩能力？"},"citedBy":0,"replyTime":"2019-05-19T11:29:17.000Z","msg":"係咪有樣野叫絕對音感？之前見老母睇個套泡菜劇有講個呢樣野"},{"pid":"03fadf4ddee6214aa483fa4e9bd25bcb39d5c416","tid":1161142,"uid":228143,"like":1,"dislike":3,"score":-2,"quote":{"pid":"346ba6f9f94e3c6c3182be274b1303700ccbd230","tid":1161142,"uid":46967,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-05-19T11:26:55.000Z","msg":"其實音樂感唔係講緊拍子準唔準 D音岩唔岩 咁表面 (即係一係岩/錯)<br />\n<br />\n而係講緊對首歌個氣氛點去決定/處理<br />\n為達到某個感覺/氣氛， 去決定大細聲/發音法/分句<br />\n<br />\n聽音準唔準係幫到你 一睇到份譜 大概就知首歌大約係點"},"citedBy":0,"replyTime":"2019-05-19T11:34:55.000Z","msg":"睇花花就知咩係天生音樂人<br />\n舞台大魔王"},{"pid":"7f382039de3c4e3a717ea7fda0ed423c4702fece","tid":1161142,"uid":228143,"like":0,"dislike":7,"score":-7,"quote":{"pid":"346ba6f9f94e3c6c3182be274b1303700ccbd230","tid":1161142,"uid":46967,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-05-19T11:26:55.000Z","msg":"其實音樂感唔係講緊拍子準唔準 D音岩唔岩 咁表面 (即係一係岩/錯)<br />\n<br />\n而係講緊對首歌個氣氛點去決定/處理<br />\n為達到某個感覺/氣氛， 去決定大細聲/發音法/分句<br />\n<br />\n聽音準唔準係幫到你 一睇到份譜 大概就知首歌大約係點"},"citedBy":0,"replyTime":"2019-05-19T11:39:17.000Z","msg":"<a href=\"https://youtu.be/RLLOqUGfTCA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FRLLOqUGfTCA&d=ywm3zvd%2FSAlFHYQsdiPdPaVJa0bF76%2FliPNifPMhSX0%3D&h=5d4a1d74\" target=\"_blank\">https://youtu.be/RLLOqUGfTCA</a><br />\n短短一首歌已經睇到編曲落左幾多心機<br />\n加埋動作 唱腔 <br />\n拍子音準去到呢d級數基本野啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c8beb420b5b61032d08d09da8ca436124032c6bc","tid":1161142,"uid":155902,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-19T12:26:04.000Z","msg":"無天份, 彈幾耐都係一pat屎<img src=\"/assets/faces/lomoji/21.png\" class=\"hkgmoji\" />"},{"pid":"e83bccd3829f7be460e6c1916431f4b60b91f4f0","tid":1161142,"uid":294,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-05-19T12:29:46.000Z","msg":"有父蔭咪有音樂感<br />\n<br />\n莫札特唔係有老頭照住日日彈邊有天才"},{"pid":"05cd3c0f0188595284c8ab44bc0cabc0cfd756db","tid":1161142,"uid":157407,"like":4,"dislike":0,"score":4,"quote":{"pid":"8c2e8e9801db353f8e05dbc7f343d8a4d65b94f7","tid":1161142,"uid":214036,"like":25,"dislike":3,"score":22,"citedBy":1,"replyTime":"2019-05-19T03:40:46.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-05-19T12:34:00.000Z","msg":"有分天生perfect pitch 同後天perfect pitch <br />\n只後後天好難練到天生果種<br />\n同埋以我所知天生嘅係會跟年齡而越黎越廢甚至冇埋<br />\n但係好多時天生有果啲其實都已經練到爐火純青"},{"pid":"0f8f652a4a95c2e2d86e30fa89d3dab5633f42da","tid":1161142,"uid":55511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-19T22:00:04.000Z","msg":"唔係。<br />\nGoogle視唱練耳  要唱譜 要聽和弦 都要練"},{"pid":"3d37767a21f64db76179631be75ae3e48927e339","tid":1161142,"uid":213945,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-05-19T22:31:40.000Z","msg":"我  更加冇音樂天分,  <br />\n由小一開始學彈琴   彈到中三先考abrsm 五級  <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><br />\n考咗個試之後就即刻無學<br />\n左右手協調好差   彈琴彈到炆 <br />\n唔係考試個個月  咁多年一個禮拜淨係上堂個一個鐘先彈  平時完全唔練 <br />\n小提琴 長笛 都學過  但更垃圾 學左一/兩年冇學 <br />\n<br />\n<br />\n另外我係連唱返出黎 都唔準 <br />\n去唱k 淨係坐底食野 <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />  <br />\n唔明啲人點認返音<br />\n考琴   彈得差 都係得考官<br />\n中學個陣音樂堂要一個人係全班面前 考唱歌 梗直痛苦"},{"pid":"57f1ead15f14042d26bcef91fb8792b163cc1044","tid":1161142,"uid":67553,"like":1,"dislike":0,"score":1,"quote":{"pid":"aa4a5d81cda5368621dc0b845a785bec09563cd5","tid":1161142,"uid":228995,"like":0,"dislike":0,"score":0,"quote":{"pid":"2ac7f6d5be839bef20e9aa51570886f0302fc197","tid":1161142,"uid":239157,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-19T04:26:07.000Z","msg":"音樂感應該唔止音準，仲有拍子感，係天生嘅，後天練點都差啲<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-19T04:31:22.000Z","msg":"係<br />\n<br />\n當年考樂理<br />\n<br />\n要聽melody拍子係幾拍<br />\n<br />\n亂9做"},"citedBy":0,"replyTime":"2019-05-19T22:56:46.000Z","msg":"真係練到出嚟，我試過<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"e9510650ed4a805f19ad679ca3ff146b2eb438b4","tid":1161142,"uid":88663,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-19T22:59:52.000Z","msg":"有時會冇咗拍子感，今日明明練到嘅嘢，就算係好簡單既基本野聽日都會彈晤返<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"415fb98aceec5830f093a0ea5c9344c3a8292ed7","tid":1161142,"uid":254528,"like":0,"dislike":0,"score":0,"quote":{"pid":"346ba6f9f94e3c6c3182be274b1303700ccbd230","tid":1161142,"uid":46967,"like":2,"dislike":0,"score":2,"citedBy":3,"replyTime":"2019-05-19T11:26:55.000Z","msg":"其實音樂感唔係講緊拍子準唔準 D音岩唔岩 咁表面 (即係一係岩/錯)<br />\n<br />\n而係講緊對首歌個氣氛點去決定/處理<br />\n為達到某個感覺/氣氛， 