3,"uid":231886,"like":3,"dislike":0,"score":3,"quote":{"pid":"21c2461d92e2fcf81fbca26f4b315330a4ae5302","tid":1681183,"uid":292497,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-29T09:34:12.000Z","msg":"失蹤左兩個<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-10-29T09:42:48.000Z","msg":"失蹤2個手足，樓主仲掛住溝女..."},"citedBy":2,"replyTime":"2019-10-29T09:45:02.000Z","msg":"<img src=\"/assets/faces/lm2/think.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-10-29T10:20:33.000Z","msg":"a0仔<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"fa9e41896dc1a98ef5073b17284a0875f647eb85","tid":1681183,"uid":117947,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-29T10:28:46.000Z","msg":"應該顧掂自己先<br />\n<img src=\"/assets/faces/normal/chicken.gif\" class=\"hkgmoji\" />"},{"pid":"c8912fa0544bbf9c9d411de159efa36c173891ba","tid":1681183,"uid":316810,"like":0,"dislike":0,"score":0,"quote":{"pid":"eccff96efa5c40f365069955dd716c0b47b550f2","tid":1681183,"uid":330025,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-29T09:04:31.000Z","msg":"有啲內容要登入至睇到<br />\n<br />\n<br />\n背景<br />\nA0 就20歲，學生一個<br />\n<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n有少少摺 仲要本身並唔仲意同人講野<br />\n<br />\n<br />\n對方<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />大我3年<br />\n追星族嚟，成日飛 ( 我唔介意佢追星，亦冇打算干涉)<br />\n<br />\n我本身打機算係超勁，佢亦都鐘意打機<br />\n因為鐘意既game唔同，未一齊打過<br />\n佢亦都表明過鐘意睇人打機<br />\n<br />\n<br />\n大概咁概<br />\n<br />\n2/3月已經開始free到我對佢有少少好感<br />\n6月交換咗ig <br />\n開始叫做不時有ig&amp;wts 傾下計<br />\n有時成幾日都有傾，有時成個禮拜都冇msg過咁濟。。。<br />\n佢本身有時好夜訓，有時會msg到好撚夜<br />\n<br />\n咁都放工之後有出過黎食吓宵夜咁既<br />\n最近食完有一齊行去巴士站<br />\n一邊陪佢等通宵車，一邊傾計<br />\n<br />\n有時傾吓自己屋企，食既野，打機，1啲芝麻小事，<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\nbtw,<br />\n<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" /><br />\n<br />\n一嚟，<br />\n我feel到佢對我唔係討厭<br />\n但佢本身都算係對人熱情既<br />\n又係追星族<br />\n佢對我有冇好感我都唔敢肯定<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n2嚟，<br />\n我真係好撚矛盾<br />\n我怕自己如果有個萬一<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n都唔知仲有冇機會可以講到<br />\n但我亦都好怕只係我自己自作多情，get 錯野<br />\n<br />\nsome for 1999，<br />\n求各位巴絲俾啲意見，etc點做<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n小弟A0仔,真係冇乜經驗<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n同埋如果建議去，就正皮<br />\n唔建議去，就負皮<br />\n<br />\n<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-10-29T10:28:50.000Z","msg":"唔好錯過"},{"pid":"3440ee012e9771e7667da990e5fd64a135fb997d","tid":1681183,"uid":238391,"like":3,"dislike":0,"score":3,"citedBy":2,"replyTime":"2019-10-29T10:29:41.000Z","msg":"此回覆已被刪除"},{"pid":"be6b5746418da5657bb2aae3315c28f39820f0fc","tid":1681183,"uid":48947,"like":1,"dislike":0,"score":1,"quote":{"pid":"2372f05c452251e8116e3854fcbf45dc223bf232","tid":1681183,"uid":175168,"like":23,"dislike":0,"score":23,"citedBy":4,"replyTime":"2019-10-29T09:05:40.000Z","msg":"聽過一句好真實既說話<br />\n<br />\n溝咩女都好...一定唔好溝同事"},"citedBy":0,"replyTime":"2019-10-29T10:32:26.000Z","msg":"係度食<br />\n唔好係度屙呀&hellip;"},{"pid":"31ebfa6f002c1a426f06c546ca7303b03075200d","tid":1681183,"uid":195211,"li