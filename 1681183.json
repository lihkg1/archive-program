hkgmoji\" /><br />\n<br />\n同埋如果建議去，就正皮<br />\n唔建議去，就負皮<br />\n<br />\n<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-10-29T10:28:50.000Z","msg":"唔好錯過"},"citedBy":0,"replyTime":"2019-11-19T16:15:25.000Z","msg":"幾日前一齊咗，多謝各位巴絲<br />\n<br />\n請<span style=\"font-size: large;\"><strong><span style=\"color: red;\">用不推文回覆</span></strong></span>，唔想霸住連登嘅位<br />\n<br />\nthx"},{"pid":"f573388a345fa73eae5d67737895a3fee468d25b","tid":1681183,"uid":330025,"like":0,"dislike":0,"score":0,"quote":{"pid":"3440ee012e9771e7667da990e5fd64a135fb997d","tid":1681183,"uid":238391,"like":3,"dislike":0,"score":3,"quote":{"pid":"2372f05c452251e8116e3854fcbf45dc223bf232","tid":1681183,"uid":175168,"like":23,"dislike":0,"score":23,"citedBy":4,"replyTime":"2019-10-29T09:05:40.000Z","msg":"聽過一句好真實既說話<br />\n<br />\n溝咩女都好...一定唔好溝同事"},"citedBy":2,"replyTime":"2019-10-29T10:29:41.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-11-19T16:15:37.000Z","msg":"幾日前一齊咗，多謝各位巴絲<br />\n<br />\n請<span style=\"font-size: large;\"><strong><span style=\"color: red;\">用不推文回覆</span></strong></span>，唔想霸住連登嘅位<br />\n<br />\nthx"},{"pid":"0a7ac531dddb0f3c07321c0edee0993f00289e71","tid":1681183,"uid":330025,"like":0,"dislike":0,"score":0,"quote":{"pid":"31ebfa6f002c1a426f06c546ca7303b03075200d","tid":1681183,"uid":195211,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-29T10:34:04.000Z","msg":"哇想識你&hellip;<br />\n前線巴就該嫁"},"citedBy":1,"replyTime":"2019-11-19T16:15:50.000Z","msg":"幾日前一齊咗，多謝各位巴絲<br />\n<br />\n請<span style=\"font-size: large;\"><strong><span style=\"color: red;\">用不推文回覆</span></strong></span>，唔想霸住連登嘅位<br />\n<br />\nthx"},{"pid":"8b77f107246c4dbd5b5afeecb50c236e0c182627","tid":1681183,"uid":330025,"like":0,"dislike":0,"score":0,"quote":{"pid":"0058c307b4908099a4994dbe08f20d3cec1c13de","tid":1681183,"uid":251395