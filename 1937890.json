ash;《紅樓夢》<br />\n6. 又如：奶食；奶豆腐；奶腥（乳汁的氣味）；奶食<br />\n7. 奶奶的簡稱"},{"pid":"f7f177d9fdb1aa44476affdc4015de72facfcdb7","tid":1937890,"uid":158372,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-03-22T08:12:35.000Z","msg":"有奶乃女"},{"pid":"409dcc0bda00dd5c5068a9053b4a47d3b39d17a5","tid":1937890,"uid":27416,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-22T08:14:08.000Z","msg":"點解仍要從亻字部"},{"pid":"f3cb60ddb9bd729142fcb4d45fb734b8724c6aa1","tid":1937890,"uid":200638,"like":12,"dislike":0,"score":12,"quote":{"pid":"c4f8f7e731c8144a8f4ee80ed3294cb6165696ca","tid":1937890,"uid":112557,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-22T07:56:24.000Z","msg":"<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />唔係從牛字部 <br />\n利申：唔奶共"},"citedBy":2,"replyTime":"2020-03-22T10:01:23.000Z","msg":"唔係得牛有奶<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n豬都有狗都有<br />\n你老母都有"},{"pid":"2b5a71f53dcec048ce9cfebbed06ccab9dac0c49","tid":1937890,"uid":192409,"like":0,"dislike":2,"score":-2,"quote":{"pid":"f3cb60ddb9bd729142fcb4d45fb734b8724c6aa1","tid":1937890,"uid":200638,"like":12,"dislike":0,"score":12,"quote":{"pid":"c4f8f7e731c8144a8f4ee80ed3294cb6165696ca","tid":1937890,"uid":112557,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-03-22T07:56:24.000Z","msg":"<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />唔係從牛字部 <br />\n利申：唔奶共"},"citedBy":2,"replyTime":"2020-03-22T10:01:23.000Z","msg":"唔係得牛有奶<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n豬都有狗都有<br />\n你老母都有"},"citedBy":0,"replyTime":"2020-03-22T10:02:13.000Z","msg":"朱奶好飲喎"},{"pid":"12b36a8411f7ef90e0bdd69e2a176e40b5c2cb78","tid":1937890,"uid":192409,"like":1,"dislike":7,"score":-6,"quote":{"pid":"f3cb60ddb9bd729142fcb4d45fb734b8724c6aa1","tid":1937890,"uid":200638,"like":12,"dislike":0,"score":12,"quote":{"pid":"c4f8f7e731c8144a8f4ee80ed3294cb6165696ca","tid":1937890,"uid":112557,"like":0,"dislike":0,"score":0,"cited