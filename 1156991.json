class=\"hkgmoji\" />"},{"pid":"48f38ccf033c07576553efadcc47f17aa28683e7","tid":1156991,"uid":134071,"like":3,"dislike":0,"score":3,"quote":{"pid":"fd7cfc465a859acb9822f1677015bd7f2ae48ccc","tid":1156991,"uid":63154,"like":28,"dislike":0,"score":28,"citedBy":2,"replyTime":"2019-05-16T04:22:51.000Z","msg":"又灌輸極權統治思想，整嬲皇上要殺頭，都係你唔好啦，唔識溫婉語氣同皇上講嘢<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n本末倒置，當權者做衰嘢，人民反抗，去怪責反抗者<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-16T04:24:24.000Z","msg":"奴隸思想...."},{"pid":"48b4682fc35cbb5072bfd5727037d9fb44079116","tid":1156991,"uid":134071,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-16T04:28:04.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"5f133c803e366146aac0aa480dd1dad2a3586ec4","tid":1156991,"uid":48083,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-05-16T04:29:27.000Z","msg":"毛e版本<br />\n<br />\n<br />\n立法會民主及建制兩派今早就《逃犯條例》法案委員會的情況洽商，但雙方僅會面 15 分鐘即告結束，建制派指民主派開出兩大條件，包括要求建制派協助游說特區政府撤回條例，以及承認涂謹申為法案委員會主席，建制派指難以接受。民主派會議召集人毛孟靜反駁，民主派是「百分百誠意」，她原期望建制派提出新想法，「但結果係零」，她對此表示出奇。<br />\n<br />\n毛孟靜指政治是妥協的藝術，雙方的交流仍是有價值，「知道對方緊守原則及底線」不過她承認兩派現時結果是「既無共識、遑論協議」而民主派的主軸是以涂謹申為法案委員會主席，繼續審議法例。<br />\n<br />\n她指以為建制派會提出把法案提出直上大會、專責委員會，甚至是特別內委會來審議法例，但結果建制派沒有提出任何建議，亦承認建制派內未有共識。<br />\n<br />\n她重申，事件因林鄭月娥政府提出修訂《逃犯條例》在先， 在於處理管治危機，她仍促請政府先撤回修訂，「如果『撤回』兩個字太重，我唔介意佢用擱置，束之高閣。」<br />\n<br />\n民主派派出四名代表，除毛孟靜外，還有民主黨主席胡志偉、公民黨黨魁楊岳橋，以及專業議政的會計界議員梁繼昌。<br />\n<br />\n<a href=\"https://thestandnews.com/politics/%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B-%E6%9C%83%E9%9D%A2%E5%83%85-15-%E5%88%86%E9%90%98-%E6%AF%9B%E5%AD%9F%E9%9D%9C-%E5%8E%9F%E6%9C%9F%E6%9C%9B%E5%BB%BA%E5%88%B6%E6%B4%BE%E6%8F%90%E6%96%B0%E6%83%B3%E6%B3%95-%E7%B5%90%E6%9E%9C%E4%BF%82%E9%9B%B6/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%25E9%2580%2583%25E7%258A%25AF%25E6%25A2%259D%25E4%25BE%258B-%25E6%259C%2583%25E9%259D%25A2%25E5%2583%2585-15-%25E5%2588%2586%25E9%2590%2598-%25E6%25AF%259B%25E5%25AD%259F%25E9%259D%259C-%25E5%258E%259F%25E6%259C%259F%25E6%259C%259B%25E5%25BB%25BA%25E5%2588%25B6%25E6%25B4%25BE%25E6%258F%2590%25E6%2596%25B0%25E6%2583%25B3%25E6%25B3%2595-%25E7%25B5%2590%25E6%259E%259C%25E4%25BF%2582%25E9%259B%25B6%2F&d=ljHbDMTA27iaUnmVhJlU2OzNZxTp5Qnzjcs1Ew7Eoms%3D&h=bfc25c3d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fthestandnews.com%2Fpolitics%2F%25E9%2580%2583%25E7%258A%25AF%25E6%25A2%259D%25E4%25BE%258B-%25E6%259C%2583%25E9%259D%25A2%25E5%2583%2585-15-%25E5%2588%2586%25E9%2590%2598-%25E6%25AF%259B%25E5%25AD%259F%25E9%259D%259C-%25E5%258E%259F%25E6%259C%259F%25E6%259C%259B%25E5%25BB%25BA%25E5%2588%25B6%25E6%25B4%25BE%25E6%258F%2590%25E6%2596%25B0%25E6%2583%25B3%25E6%25B3%2595-%25E7%25B5%2590%25E6%259E%259C%25E4%25BF%2582%25E9%259B%25B6%2F&h=e66c743f\" data-auto-link target=\"_blank\">https://thestandnews.com/politics/%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B-%E6%9C%83%E9%9D%A2%E5%83%85-15-%E5%88%86%E9%90%98-%E6%AF%9B%E5%AD%9F%E9%9D%9C-%E5%8E%9F%E6%9C%9F%E6%9C%9B%E5%BB%BA%E5%88%B6%E6%B4%BE%E6%8F%90%E6%96%B0%E6%83%B3%E6%B3%95-%E7%B5%90%E6%9E%9C%E4%BF%82%E9%9B%B6/</a><br />\n1<br />\n0"},{"pid":"be92010569ac605393bf72c98490a8a9407394ea","tid":1156991,"uid":55597,"like":1,"dislike":8,"score":-7,"quote":{"pid":"a8498fd7d0187768b5851d04335ede68252c8c8b","tid":1156991,"uid":49216,"like":354,"dislike":2,"score":352,"citedBy":1,"replyTime":"2019-05-16T03:21:49.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n傀儡屌有自由意識既人"},"citedBy":1,"replyTime":"2019-05-16T04:31:36.000Z","msg":"唔出奇<br />\nwindows, mac os 傀儡都鍾意屌用 linux 既人"},{"pid":"e14936dc0b2a07aa9aca4012c89cb01d9fada799","tid":1156991,"uid":189489,"like":4,"dislike":1,"score":3,"citedBy":0,"replyTime":"2019-05-16T04:34:37.000Z","msg":"真係好笑<br