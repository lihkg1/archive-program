66450334ffccc5753ba1e70","tid":1634772,"uid":17289,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-07T14:52:07.000Z","msg":"<img src=\"https://na.cx/i/OLbTzM0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOLbTzM0.jpg&h=22d121c2&s={SIZE}\" /><br />\n冇set日期 將罷工個idea普及"},"citedBy":1,"replyTime":"2019-10-07T14:56:39.000Z","msg":"多謝，可否借圖來用？"},"citedBy":0,"replyTime":"2019-10-07T14:59:13.000Z","msg":"當然<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"154f2e92780a9325d616bef9733d8c284835f012","tid":1634772,"uid":312125,"like":0,"dislike":0,"score":0,"quote":{"pid":"69a8a0dbb927460f166450334ffccc5753ba1e70","tid":1634772,"uid":17289,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-07T14:52:07.000Z","msg":"<img src=\"https://na.cx/i/OLbTzM0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FOLbTzM0.jpg&h=22d121c2&s={SIZE}\" /><br />\n冇set日期 將罷工個idea普及"},"citedBy":0,"replyTime":"2019-10-07T14:59:25.000Z","msg":"之前有人提及嘅罷工罷課自救呢個idea都應該用在對內文宣上<br />\n<br />\n<strong><span style=\"color: red;\">破解緊急法！</span><span style=\"color: gold;\">只有全民<span style=\"font-size: x-large;\">無&middot;限&middot;期</span>罷工罷課先可以救自己、救香港！</span></strong><br />\n<a href=\"https://lih.kg/1610341\" data-auto-link target=\"_blank\">https://lih.kg/1610341</a><br />\n<br />\n<span style=\"color: red;\">早前政府宣布，香港各區發生暴動！今日宣布立緊急法</span><span style=\"color: gold;\">亦即係話，當日只要出過街嘅非警察人士，都有機會告你參與暴動</span>！<span style=\"color: red;\">要去狗屋坐48個鐘，而且定罪嘅話一坐就幾年</span>！<br />\n<br />\n打工反學嘅你，為你自己將來，呼籲大家，<span style=\"color: red;\">盡快組織無限期罷工、罷課</span>！<span style=\"color: gold;\">只有咁，先可以癱瘓社會運作，直到政府宣布徹底妥協為止！</span>"},{"pid":"9a1a5d5161c29f2adb11548929c8e7c1c480c4ca","tid":1634772,"uid":169141,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-07T15:04:14.000Z","msg":"推！！！罷工！！！！"},{"pid":"df0af9a9df2ca2d76316578a881cfac830f7f77a","tid":1634772,"uid":312125,"like":0,"dislike":0,"score":0,"quote":{"pid":"9a1a5d5161c29f2adb11548929c8e7c1c480c4ca","tid":1634772,"uid":169141,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-07T15:04:14.000Z","msg":"推！！！罷工！！！！"},"citedBy":0,"replyTime":"2019-10-07T15:06:37.000Z","msg":"罷工之餘，幫手做文宣"},{"pid":"6c22fedf12dd03f548c7282dd0a391e0aa30d5bb","tid":1634772,"uid":258566,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-07T15:41:58.000Z","msg":"此回覆已被刪除"},{"pid":"2f19c6d53855abe009178e4a9f6243dc62e16c09","tid":1634772,"uid":258566,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T16:51:19.000Z","msg":"此回覆已被刪除"},{"pid":"7c6a96196da9a557e29c9c40741a709989371a32","tid":1634772,"uid":47659,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T19:25:20.000Z","msg":"推三罷難過香港獨立<br />\n無論自發定被罷工 我都推到灰 睇你表演"},{"pid":"bd7d345bb278620ac29b237b103dad15bdaf30e9","tid":1634772,"uid":186874,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T19:27:09.000Z","msg":"推 行動post<br />\n（幫推上熱門）可唔可以推返啲正經野<br />\n<a href=\"https://lih.kg/1636594\" data-auto-link target=\"_blank\">https://lih.kg/1636594</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"9c02db3f2f44aacbe9ebacba5f1e9c1c802b62cb","tid":1634772,"uid":63117,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T22:43:52.000Z","msg":"推"},{"pid":"df6a2aab80574cb07672981fea115de49a683c89","tid":1634772,"uid":312125,"like":0,"dislike":0,"score":0,"quote":{"pid":"6c22fedf12dd03f548c7282dd0a391e0aa30d5bb","tid":1634772,"uid":258566,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-10-07T15:41:58.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-10-08T02:25:27.000Z","msg":"請問你係咪讀緊中學？得閒幫手一齊做文宣"}]}