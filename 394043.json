s=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"309196be4dccce6e5e2685f32ae0aee892d3bb62","tid":394043,"uid":54373,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-12T17:12:50.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"72d8aed43bd79dedac7cb18bf5c247f3a148a041","tid":394043,"uid":22251,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-12T19:10:27.000Z","msg":"<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"4467c5d206cf5263384f24b16c984ae21d003c69","tid":394043,"uid":29270,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-09-12T20:57:16.000Z","msg":"多謝呀廢"}]}