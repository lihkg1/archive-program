:"3de8335390f7726c738703ad436c6f6350bfcf98","tid":537222,"uid":12404,"like":0,"dislike":0,"score":0,"quote":{"pid":"2369ee0339d2e9d4314cd510d68ff37c8164134e","tid":537222,"uid":23707,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-01-22T15:10:18.000Z","msg":"印象中就算支那話講轉車 係用換車 幾時變左叫倒車<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-01-22T15:24:22.000Z","msg":"垃圾語言是撚但啦<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-01-22T15:26:27.000Z","msg":"我記得係轉乘喎<br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-01-23T01:53:48.000Z","msg":"百度百科解答<br />\n<a href=\"https://baike.baidu.com/item/%E5%80%92%E8%BD%A6/5006695\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fbaike.baidu.com%2Fitem%2F%25E5%2580%2592%25E8%25BD%25A6%2F5006695&d=k3FtystjW27N0V0sEM17sozZXVCnaYNE8CBFJ%2F%2FgXXY%3D&h=3666d055\" target=\"_blank\">https://baike.baidu.com/item/%E5%80%92%E8%BD%A6/5006695</a><br />\n倒車是指機動車向後運動的行為。也指人們在出行時中途「倒車」，即由一輛車換乘另一輛車。<br />\n<br />\n真係痴撚線<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"88d6bd80ca82a3914719f59a51bf56ccd4035f10","tid":537222,"uid":35430,"like":0,"dislike":0,"score":0,"quote":{"pid":"0b82f6b6f1d8a48a2aed0f3fd5c848fc027f77f6","tid":537222,"uid":34409,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-01-22T14:38:17.000Z","msg":"其實慰安婦也有妓女意思"},"citedBy":0,"replyTime":"2018-01-23T01:57:20.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"d4a9b6078e97bde4004e86fd687b12c0e37b9029","tid":537222,"uid":62226,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-01-23T01:58:15.000Z","msg":"十幾年前呢本課本好似已經係咁教"},{"pid":"ff560fbaf3f2944ed18b7aa687da7c8bfe88a24e","tid":537222,"uid":21028,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-01-23T01:59:19.000Z","msg":"r波 <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji