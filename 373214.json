}\" /><br />\n<img src=\"https://i.imag.cx/vHoXA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imag.cx%2FvHoXA.jpg&h=1fb87b30&s={SIZE}\" /><br />\n下面呢個係隨便台Official LINE群,有咩突發消息,開台通知,我都會係呢度公布<br />\n<img src=\"http://qr-official.line.me/L/aqio2VXZLo.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fqr-official.line.me%2FL%2Faqio2VXZLo.png&h=03fd5638&s={SIZE}\" />"},{"pid":"75a6754d99e59f5957cd2620e908769020dbd302","tid":373214,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-25T01:03:11.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"00f32fe9658b86e26bfe09112a94c4b9619b13a9","tid":373214,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-25T01:40:15.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"44c1991f63a736daac65d010b1425356abb06aa6","tid":373214,"uid":89382,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-08-25T02:15:03.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"}]}