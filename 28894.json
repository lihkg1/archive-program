kgmoji\" />"},{"pid":"bdce1bbe5711b4b2e880d1db2f1434f054e1f469","tid":28894,"uid":60259,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-09T08:43:44.000Z","msg":"公司交換禮物<br />\n<br />\n仆街老細拎其他partner送比我地既膠水杯出嚟抽 上面大大個麥頭印撚住人地公司名<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"aa2d3fa2fe3a57dbdf7fdb757a1e707eba8d366e","tid":28894,"uid":22633,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2016-12-09T10:07:04.000Z","msg":"仲未有人講念佛機<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}