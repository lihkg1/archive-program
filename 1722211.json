000Z","msg":"拉"},{"pid":"acc81d4f5b254e444dc2eebc0fd9acabdb333ce1","tid":1722211,"uid":287032,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T00:26:25.000Z","msg":"拉"},{"pid":"4bfdd0a860fd598cc8398bafaae7db91e5fb1913","tid":1722211,"uid":225774,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T00:26:41.000Z","msg":"拉"},{"pid":"13ca6d7705a52d2e2934f425831f9701a236ae08","tid":1722211,"uid":141789,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T00:26:46.000Z","msg":"無涉及任何傷害人命嘅事，恐你老母分子"},{"pid":"b224ea0e62dc729e0a4be44899e5eb68be9900af","tid":1722211,"uid":24722,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T00:27:06.000Z","msg":"拉"},{"pid":"151d55cdf457c96f2d827fb8194f2602c5e1fcd3","tid":1722211,"uid":238919,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-11-15T00:27:45.000Z","msg":"回應三個幪面人偽冒中大學生<br />\n<br />\n凌晨有三個蒙面人，冒充中大前線學生，騎劫學生意願，濫開記者會。本公海admim就此回應：<br />\n<br />\n1. 三個蒙面人聲稱中大係百年校園，但事實上中大成立根本未有一百年。 明顯，三個幪面人係冒充中大前線學生。<br />\n<br />\n2. 三個蒙面人以區議會選舉如常舉行作為主要訴求。<br />\n<br />\n不過，本公海admin必須強調，五大訴求（ 包括制裁黑警、實行民主）明顯比區議會選舉重要，因為區議員並無實權，區議會選舉惟一得益者只係得到兩萬蚊人工嘅勝選者，而非前線手足。 <br />\n<br />\n五大訴求，缺一不可。<br />\n<br />\n3. 三個蒙面人聲稱自己代表中大前線手足。不過，本公海admin必須強調， 中大前線手足全民會議今朝先會舉行，凌晨嗰陣仲未舉行。明顯，三個蒙面人並不代表中大前線手足。<br />\n<br />\n三個蒙面人並不代表我。<br />\n<br />\n4. 中大學生會幹事會經過選舉產生，比起三個蒙面人，更可代表中大學生。<br />\n<br />\n5. 呼籲中大學生會，以及真正中大學生今晚前，盡快召開記者會， 重申爭取民主，制裁黑警，釋放義士，方為主要訴求，而非區議會。<br />\n<br />\n中大抗爭者公海Admin G. Shan<br />\n2019/11/15 7:49am"},{"pid":"f2f830204b16a9d8031cee48b9cd9fa4fcaeed6d","tid":1722211,"uid":109811,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-15T00:27:54.000Z","msg":"拉"},{"pid":"c755308ce443e2e3b6ad71ba7100d11c8664e86e","tid":1722211,"uid":238919,"like":0,"dislike":0,"score":0,"quote":{"pid":"8307885241c2ff9dee32f5a60333d7989af6e27f","tid":1722211,"uid":8532,"like":19,"dislike":10,"score":9,"citedBy":2,"replyTime":"2019-11-15T00:01:46.000Z","msg":"<span style=\"font-size: xx-large;\"><