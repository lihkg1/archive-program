%2588%25BE%25E9%2586%25AB%25E5%25AD%25B8%25E7%258D%258E%25E5%25BE%2597%25E4%25B8%25BB%25E8%2581%25B2%25E7%25A8%25B1%25E6%2596%25B0%25E5%2586%25A0%25E7%2597%2585%25E6%25AF%2592%25E7%2582%25BA%25E4%25BA%25BA%25E9%2580%25A0&d=0xR7vGHOl893LUq1yoppepktsUQkmpJZziL8xq2DbDY%3D&h=75ee481c\" data-auto-link target=\"_blank\">http://www.rfi.fr/tw/%E6%B3%95%E5%9C%8B/20200417-%E6%B3%95%E5%9C%8B%E8%AB%BE%E8%B2%9D%E7%88%BE%E9%86%AB%E5%AD%B8%E7%8D%8E%E5%BE%97%E4%B8%BB%E8%81%B2%E7%A8%B1%E6%96%B0%E5%86%A0%E7%97%85%E6%AF%92%E7%82%BA%E4%BA%BA%E9%80%A0</a>"},{"pid":"f1d9be8ce3e8bc9933945a59211a344bb81bacba","tid":1977384,"uid":193217,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-18T03:02:06.000Z","msg":"push"},{"pid":"33479d8bf8970d42ea0ac56cbd55dacd39b94721","tid":1977384,"uid":15880,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-18T03:02:51.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />TVB 冇講,一定唔係真"},{"pid":"008900f6674180ee725af6ce30eaa194a8f9408f","tid":1977384,"uid":75300,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-04-18T03:07:14.000Z","msg":"武漢肺炎"}],"pinned":{"pid":"cb39bdf31872363b9c6fe436a10a74040925f154","tid":1977384,"uid":193217,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-04-18T02:58:07.000Z","msg":"全文起呢度<br />\n<a href=\"http://www.rfi.fr/tw/%E6%B3%95%E5%9C%8B/20200417-%E6%B3%95%E5%9C%8B%E8%AB%BE%E8%B2%9D%E7%88%BE%E9%86%AB%E5%AD%B8%E7%8D%8E%E5%BE%97%E4%B8%BB%E8%81%B2%E7%A8%B1%E6%96%B0%E5%86%A0%E7%97%85%E6%AF%92%E7%82%BA%E4%BA%BA%E9%80%A0\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fwww.rfi.fr%2Ftw%2F%25E6%25B3%2595%25E5%259C%258B%2F20200417-%25E6%25B3%2595%25E5%259C%258B%25E8%25AB%25BE%25E8%25B2%259D%25E7%2588%25BE%25E9%2586%25AB%25E5%25AD%25B8%25E7%258D%258E%25E5%25BE%2597%25E4%25B8%25BB%25E8%2581%25B2%25E7%25A8%25B1%25E6%2596%25B0%25E5%2586%25A0%25E7%2597%2585%25E6%25AF%2592%25E7%2582%25BA%25E4%25BA%25BA%25E9%2580%25A0&d=0xR7vGHOl893LUq1yoppepktsUQkmpJZziL8xq2DbDY%3D&h=75ee481c\" data-auto-link target=\"_blank\">http://www.rfi.fr/tw/%E6%B3%95%E5%9C%8B/20200417-%E6%B3%95%E5%9C%8B%E8%AB%BE%E8%B2%9D%E7%88%BE%E9%86%AB%E5%AD%B8%E7%8D%8E%E5%BE%97%E4%B8%BB%E8%81%B2%E7%A8%B1%E6%96%B0%E5%86%A0%E7%97%85%E6%AF%92%E7%82%BA%E4%BA%BA%E9%80%A0</a>"}}