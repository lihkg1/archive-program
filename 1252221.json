\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"4cfe6ee558574abe7cd6cf77ba825db0d522b4c2","tid":1252221,"uid":178876,"like":0,"dislike":0,"score":0,"quote":{"pid":"8eeba367ac43d795881bc891c7ea6ec736e36eb9","tid":1252221,"uid":103230,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-23T01:51:49.000Z","msg":"明報食錯藥？"},"citedBy":0,"replyTime":"2019-06-23T04:04:26.000Z","msg":"明報記者好似畀警察打過定不禮貌對待"}]}