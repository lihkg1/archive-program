4ee0e2a4d792ec4","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T10:55:12.000Z","msg":"十六推"},{"pid":"8afdef05cd6d51161c993ae29c4616b4a35e5c6e","tid":1655994,"uid":198800,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T10:55:14.000Z","msg":"tui"},{"pid":"e6aaa12cec3cd06138032e59871ddb6702297dad","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T10:55:26.000Z","msg":"十七推"},{"pid":"68650ccb00eb00492d98b7aacb89e678fd55b2ba","tid":1655994,"uid":198800,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T10:55:31.000Z","msg":"pisg"},{"pid":"57361ab0b8af5e71a5ee2cef4295486b1b175200","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T10:55:49.000Z","msg":"十八推"},{"pid":"cbded10a161bba16c4f15b442412cc135ae014ec","tid":1655994,"uid":81996,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T10:56:00.000Z","msg":"tui"},{"pid":"5b882d5dc6d288bb10e22f3295a4cb98799a97bc","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T10:56:03.000Z","msg":"十九推"},{"pid":"02f4c24468e161b6bb25e43db989721e5b2a10f2","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T10:56:15.000Z","msg":"二十推"},{"pid":"58ca558a245bb8b3cc4d9f9ceed8f5ef35d15b74","tid":1655994,"uid":138790,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T10:56:29.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"781505afcc02d18cbd6ae71c0f26ce72cd760e88","tid":1655994,"uid":15259,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-15T10:56:40.000Z","msg":"<strong><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">1.打電話、EMAIL、無限FAX</span></span></strong><br />\n想同職員談心又得，講咩都得，幫阿SIR叫下外賣又得<img src=\"/assets/faces/dog/999.gif\" class=\"hkgmoji\" />總知JAM到佢線就得。有EMAIL既就SEND EMAIL查詢下，有FAX機既可以用下無限FAX大法<img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">2.MEMO紙</span></span></strong><br />\n有開門就入去叫杯水慢慢坐<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n無開門既咪留張紙起度寫低自己有咩問或者有咩訴求囉<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">3.善用1823</span></span></strong><br />\n食完野集體食物中毒呀，消防設備唔合符規格呢D無理由唔投訴呀？<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" /><br />\n留意返打完1823之後，佢係要起限期內比返回覆你架<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n呢招長玩長有，大家打之前要謹慎少少呀<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><br />\n<br />\n<strong><span style=\"font-size: xx-large;\"><span style=\"color: gold;\">4.蟲系魔法師</span></span></strong><br />\n知道好多巴絲打鐘意養蟲蟲，但係入店一定要小心唔好倒瀉D寶貝呀(特別起食肆)<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n幫推"},{"pid":"cfa6bdc73835cb4a992db2b125523684a9fad47f","tid":1655994,"uid":223678,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-15T10:56:56.000Z","msg":"推"},{"pid":"6d158faf7b005f88ba1346ee6ebad865ce45f632","tid":1655994,"uid":267600,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-15T10:57:01.000Z","msg":"所以現在應考慮改變抗爭模式，減少襠被捕和流血。"},{"pid":"1a54a9cbe941ff5695622b4caba9eca06ae59e0d","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T10:57:13.000Z","msg":"有抗爭方法可以係度討論呀"},{"pid":"fcd360d92abd807a8fb5817747deb1cfe7f0e585","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"quote":{"pid":"6d158faf7b005f88ba1346ee6ebad865ce45f632","tid":1655994,"uid":267600,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-15T10:57:01.000Z","msg":"所以現在應考慮改變抗爭模式，減少襠被捕和流血。"},"citedBy":0,"replyTime":"2019-10-15T10:57:57.000Z","msg":"就算book場打籃球，大家去睇波，已經係個集會la<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"70fd0d5f1bcbb949ea97f5cad962c25e4de37399","tid":1655994,"uid":55974,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-15T11:00:07.000Z","msg":"49、偽裝下的抗議集會(搞個願榮光歸香港音樂會）<br />\n<br />\n係商場搞個大型音樂會，搵歌手唱，畫面已經好靚嫁啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"47cdedd0dc46098c1dd2aa5948fb8a0494b2ea07","tid":1655994,"uid":17838,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-15T11:01:56.000Z","msg":"Push"},{"pid":"701ae37013d619a7b8e1cfaf1222a06444f958a3","tid":1655994,"uid":44415,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-15T11:02:30.000Z","msg":"Tui"},{"pid":"1b5850e62f4f58c0dc7a5d1575e6e31480dde77b","tid":1655994,"uid":266503,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-15T11:02:33.000Z","msg":"和理非努力"},{"pid":"3b771ef4a4026b79d0817978190238b9d51a575e","tid":1655994,"uid":209468,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T11:02:46.000Z","msg":"Push"},{"pid":"8a6fde5483f9055e3e74cc48af3f017fddbefbc8","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T11:03:07.000Z","msg":"51、退場（個人或集體離場退席以示反對和抗議）<br />\n<br />\n下次柒婆有公眾會開，表達意見，同一個時間離場就係最好既表達方法<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},{"pid":"f9749d1626cf36313afda8f54ac2974b776b296a","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T11:06:33.000Z","msg":"31、如影隨形地跟蹤官員（對不義的官員造成心理壓力) (<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />唔好做）<br />\n<br />\n呢個緊係唔好做啦，咁劏房波去到酒店食德國豬手個陣比群眾屌，有人通知去到百佳買野又比人屌<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"c2afbba3d99f7187d42a769e3155824793aa0c5a","tid":1655994,"uid":249464,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T11:07:43.000Z","msg":"推"},{"pid":"aca39d8f10292b230dd9be753232991d19114afe","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-15T11:15:38.000Z","msg":"公務員既朋友就要睇下下面呢d方法啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n142、選擇性地拒絕執行或協助公務（個人或集體公然拒絕執行上級指派的公務）<br />\n143、阻塞命令及信息管道（不動聲色地阻止命令的下達或擱置下級呈送的報告）<br />\n144、推拖阻礙（表面服從但實際上卻拖延或妨礙政令的推行，如納粹德國的科學家拖延原子彈研製）<br />\n145、全面行政不合作<br />\n146、司法人員不合作 (律政署既朋友有幫到手)<br />\n147、執法人員故意執行不力和選擇性的不合作"},{"pid":"5bd1fef5dbd0da0e4646d9934b6114cd58e298e6","tid":1655994,"uid":322179,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-15T11:26:10.000Z","msg":"以後話維園裸嘅改做帶小熊維尼面具做22<br />\n<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},{"pid":"433ae72652cab8afe01099a17cff2366c6e870b5","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"quote":{"pid":"5bd1fef5dbd0da0e4646d9934b6114cd58e298e6","tid":1655994,"uid":322179,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-10-15T11:26:10.000Z","msg":"以後話維園裸嘅改做帶小熊維尼面具做22<br />\n<img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/touch.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-10-15T11:30:21.000Z","msg":"絕對得，帶維尼面具開音樂會，音樂會帶面具緊係正常la<img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" />"},{"pid":"629624178d7925ef55cfd96ed8f70337d64b5bef","tid":1655994,"uid":88773,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-15T11:31:40.000Z","msg":"Push"},{"pid":"9d63f2cc071f50b4a29b506ebc30e23f37a8d62e","tid":1655994,"uid":78392,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-15T11:32:17.000Z","msg":"推？！！？"},{"pid":"82fb5b5e8147fcf992a6e248b8ddf48e4faafdb2","tid":1655994,"uid":55974,"like":0,"dislike":0,"score":0,"quote":{"pid":"781505afcc02d18cbd6ae71c0f26ce72cd760e88","tid":165