ike":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T02:21:19.000Z","msg":"台灣叫FoodPanda/香港用UPS寄過去"},{"pid":"425428b7bd0e5b9ede57d91bf66c56d676eb8995","tid":2245024,"uid":345051,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T02:21:23.000Z","msg":"佳仔冇錯洗乜自首 管牧師對得住天地良心<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"9d26330228ee8c9b5576d887a3d8b6b517e33109","tid":2245024,"uid":364850,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T02:50:28.000Z","msg":"下一世。。。&hellip;。<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"73c5adcafae101b5446af3ceadcd816cdfd17b5c","tid":2245024,"uid":364850,"like":0,"dislike":0,"score":0,"quote":{"pid":"8f55d6686e34882480e55f27216fee4ac58f8727","tid":2245024,"uid":313546,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2020-10-16T02:02:52.000Z","msg":"去廈門游水過金門"},"citedBy":0,"replyTime":"2020-10-16T02:51:10.000Z","msg":"投胎會唔會快啲<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}