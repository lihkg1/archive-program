dBy":1,"replyTime":"2021-02-14T23:32:47.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"653b27d9aa4fdee8ee2372ebe76a6edaaed50fc3","tid":2408194,"uid":79589,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-15T00:03:16.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n睇相"},{"pid":"ac69cc80cd405e68b155ebbb7a85c9a1989d7858","tid":2408194,"uid":373442,"like":0,"dislike":0,"score":0,"quote":{"pid":"6699a5f3082d8e0f4040e925787ea56f8c0d5998","tid":2408194,"uid":104804,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-14T17:01:13.000Z","msg":"勇者王好正<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-15T00:41:25.000Z","msg":"咁你係咪收留<img src=\"/assets/faces/lny/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"9084bc0619095b63892b028f45307acd73778486","tid":2408194,"uid":373442,"like":0,"dislike":0,"score":0,"quote":{"pid":"caa992817d3db29373b35a9d5dd46ffed84f123b","tid":2408194,"uid":335883,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2021-02-14T18:55:49.000Z","msg":"可以幫你keep部份<br />\n等你解決土地問題原封不動比番你"},"citedBy":0,"replyTime":"2021-02-15T00:43:44.000Z","msg":"多謝巴打，不過佢既土地問題應該解決唔到<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />呢度只係佢一小部份，日後可能有更多要棄置<img src=\"/assets/faces/pig/dying.gif\" class=\"hkgmoji\" />"},{"pid":"df195630364cd07d574a2c2f3ffa5994fdbb9134","tid":2408194,"uid":373442,"like":0,"dislike":0,"score":0,"quote":{"pid":"5035abfaf65f95505d6780a693533d5b7ebf3ee2","tid":2408194,"uid":373119,"like":9,"dislike":0,"score":9,"citedBy":2,"replyTime":"2021-02-14T19:19:52.000Z","msg":"勸你小心啲<br />\n舊登送過比人轉手被人賣左<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-15T00:48:13.000Z","msg":"多謝巴打，我唔放相係度同咁多要求，都係想盡量避免啲人亂排，不過有時都避唔到咁多<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" />"},{"pid":"09654588928e28a2dadf6d239f1d97398e4b7ec4","tid":2408194,"uid":373442,"like":0,"dislike":9,"score":-9,"citedBy":0,"replyTime":"2021-02-15T01:25:35.000Z","msg":"咁多負皮係咪因為我唔擺相<img src=\"/assets/faces/fs/angel.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n我朋友之前係FB啲高達group放過呢張相，好多人都未睇內容就話成箱收，我諗果啲人都係拎去賣，或者亂收，漁翁撒網，最後太混亂del po收場<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n之後揀係呢度放係諗住可以篩走果班人<br />\n我知唔可以完全避免有人拎去賣<br />\n但放得出去真係冇辦法，我又唔認識你地任何一個人，如果咁多要求佢都照做，真係抵比佢既<br />\n<br />\n有心就自然肯做多步<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" /><br />\n反正我唔怕麻煩<br />\n結論係，我都係唔會擺相係度<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"a6368bfe60a3bdf1b8136cb68059a59de6497c34","tid":2408194,"uid":373442,"like":0,"dislike":0,"score":0,"quote":{"pid":"da9baf724f1facc91d8e1f2befbae1593c603a5b","tid":2408194,"uid":124,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-14T18:22:39.000Z","msg":"<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-15T01:41:45.000Z","msg":"Tg ed"},{"pid":"20c7ca9e323f250d371185307e4c652eb7b42b68","tid":2408194,"uid":373442,"like":0,"dislike":0,"score":0,"quote":{"pid":"60f702874c4e2ba3eb91a475fa28f475c9baa018","tid":2408194,"uid":35711,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-14T19:10:34.000Z","msg":"<blockquote><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /></blockquote>"},"citedBy":0,"replyTime":"2021-02-15T01:41:58.000Z","msg":"Tg ed"},{"pid":"b0717097957ed3a1afd1e934ab746e9e4df6e3d5","tid":2408194,"uid":373442,"like":0,"dislike":0,"score":0,"quote":{"pid":"4b307770b87d48015f2ee4049836082772df5a44","tid":2408194,"uid":183601,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-14T23:32:47.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-02-15T01:42:11.000Z","msg":"T