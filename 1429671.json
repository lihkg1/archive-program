id":"8556709a679c02cce5888cfa113286fccaf7b201","tid":1429671,"uid":60527,"like":5,"dislike":0,"score":5,"quote":{"pid":"ad1cbb33a6f8e7523320ff68bc3e615a50b5669a","tid":1429671,"uid":11147,"like":3,"dislike":2,"score":1,"citedBy":1,"replyTime":"2019-08-07T14:47:46.000Z","msg":"各有各做啦 唔好咁快屌住<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-07T15:27:06.000Z","msg":"燒山一定要屌，呢件負資產黎"},{"pid":"b3514c55535d60ee0e47cd7684e2aa44a2ad1c44","tid":1429671,"uid":210140,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-08-07T15:32:41.000Z","msg":"俾正評係因為樓主開帖警世<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"143d9d568b627aaf2545aff4624d93b7c01b1935","tid":1429671,"uid":251582,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-07T15:37:57.000Z","msg":"仆街 邊撚個話起大台姐係出賣我地！同我地割席就等俾港共政府收皮啦！"},{"pid":"29105007ab318d582fb5b903b952a451eba99280","tid":1429671,"uid":269285,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-07T17:01:39.000Z","msg":"推，唔好比佢起得成大台"},{"pid":"b50844b791288d73523376f4df34c8c92421ac43","tid":1429671,"uid":187950,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-08-07T17:07:29.000Z","msg":"on9冇勇武手足 全部送晒中<br />\n你憑乜野限制勇武 <br />\n你成班失敗專家 30年爭取左d咩"},{"pid":"04559a07a1002c8b4cf046dde25b0b24eb2a53c2","tid":1429671,"uid":28759,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-07T17:49:28.000Z","msg":"是但啦<br />\n冇人迫你聽佢支笛 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}