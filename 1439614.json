ss=\"hkgmoji\" />"},{"pid":"44b1b77a2575179800e740cc6b3f4ecef0db4b7a","tid":1439614,"uid":290973,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:22:04.000Z","msg":"推"},{"pid":"75741c09e5f008e928b25b400075133a62f7026c","tid":1439614,"uid":20126,"like":1,"dislike":0,"score":1,"quote":{"pid":"875149660be52da0a93a729d80684b8323163b72","tid":1439614,"uid":191790,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-08-10T07:20:58.000Z","msg":"其實九月份嘅學生會準備換屆<br />\n都唔知上年話事定下年話事<br />\n有啲難度"},"citedBy":0,"replyTime":"2019-08-10T07:24:43.000Z","msg":"一黎應該無咁快換？<br />\n二黎罷課在學生<br />\n我相信學生會並唔係唯一組織發起罷課<br />\n只係一個較有聲出嘅組織<br />\n<br />\n但任何學生都可以發起罷課！ 只要有同學和應！"},{"pid":"c5b6967f57d0357553c3275111bc3bb58a8877d7","tid":1439614,"uid":20126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:27:20.000Z","msg":"push"},{"pid":"a3eda70fb53f683db4377bd5b36e49bdac5ae012","tid":1439614,"uid":20126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:32:51.000Z","msg":"push"},{"pid":"d54365faca0f94eba80a4d5b6acf2a9b6b7939d4","tid":1439614,"uid":76577,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:34:53.000Z","msg":"幫推<img src=\"/assets/faces/pig/dance.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/dance2.gif\" class=\"hkgmoji\" /><br />\n<br />\n唔好意思阻阻你<br />\n<br />\n食人血饅頭既奶共地產商，就係我地黎緊既目標！<br />\n<a href=\"https://lih.kg/1435521\" target=\"_blank\">https://lih.kg/1435521</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"1ffdbffa434936990cc233041e72c3162323fcaa","tid":1439614,"uid":270111,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-10T07:36:26.000Z","msg":"各位畢左業既<br />\n都可以用校友既身份send返去學校/校友會<br />\n詢問罷課安排<br />\n問既人夠多就易成事架啦"},{"pid":"4192cf9636261df5b1dfde70d03eacd3577b43c8","tid":1439614,"uid":97603,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:40:07.000Z","msg":"Push"},{"pid":"4dd7517d35acc6231c39ef890a38e9deb775b08b","tid":1439614,"uid":20126,"like":1,"dislike":0,"score":1,"quote":{"pid":"1ffdbffa434936990cc233041e72c3162323fcaa","tid":1439614,"uid":270111,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-10T07:36:26.000Z","msg":"各位畢左業既<br />\n都可以用校友既身份send返去學校/校友會<br />\n詢問罷課安排<br />\n問既人夠多就易成事架啦"},"citedBy":0,"replyTime":"2019-08-10T07:41:06.000Z","msg":"<a href=\"https://www.facebook.com/495193710689456/posts/1170343586507795/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F495193710689456%2Fposts%2F1170343586507795%2F&d=sJhP54gyZlpQHD%2BOhJ68s4kJ8G0wCzjK2GZdEgWvKr0%3D&h=2417e69e\" target=\"_blank\">https://www.facebook.com/495193710689456/posts/1170343586507795/</a><br />\n<br />\n眾志搞緊<br />\n可share埋"},{"pid":"b2959555a47c9ef2a4650b4bfdf027b52a654e52","tid":1439614,"uid":92188,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:41:50.000Z","msg":"要大專返學先"},{"pid":"a075a53da214816b7f395a915abdb90cf28a8f58","tid":1439614,"uid":44149,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:42:12.000Z","msg":"推"},{"pid":"26a7289ebe252aae960441153b62547d5b9e36f5","tid":1439614,"uid":20126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:46:27.000Z","msg":"push"},{"pid":"962368a6f1bac67a2d53d3be135da666672c87f1","tid":1439614,"uid":199613,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:48:06.000Z","msg":"全港中學生永久罷課18區集會<br />\n如何<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"f18a7736e387f7a5d080711f54df670d4c4c955e","tid":1439614,"uid":2662,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:49:29.000Z","msg":"推<br />\n9月再三罷"},{"pid":"be47dee0f3a625211cc7223cfa0b4b4737cfe71c","tid":1439614,"uid":20126,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:50:11.000Z","msg":"push"},{"pid":"614f8f932d7ebf8f47f0e4b08b08550d37c025f4","tid":1439614,"uid":69741,"like":6,"dislike":3,"score":3,"citedBy":3,"replyTime":"2019-08-10T07:58:59.000Z","msg":"叫中學生罷課係好無恥<br />\n<br />\n大學生罷一d問題都無<br />\n中學生喺未有足夠自學能力，同真係會不罷學pick up翻miss咗既野既自制力之前，應該keep翻上學<br />\n尤其是中五，甚至中六係全年搏殺<br />\n呢場你幾唔同意唔想都好，一定係長期戰爭，罷到幾時?罷到12月，到時係咪你同班中六考dse?<br />\n<br />\n我再講多次，所有上咗岸，讀緊大學翻緊工既人叫中學生放棄人生咁幫你發夢係好無恥<br />\n<br />\n你話罷課方便發夢?6月佢地咪一樣有參與過，唔一定要罷課，而且佢地中學生嚟架，車錢飯錢防具錢係咪你比?<br />\n<br />\n當全場大部分都係大中學生年輕人，廿中型中年人相對減少，仲邊夠戰鬥力<br />\n<br />\n而且最緊要，係呢8月剩翻呢半個月，最重要要做既，係扭轉成個運動係年輕人既形象<br />\n<br />\n事實亦唔少中老年人，專業人士去過嚟一齊發夢<br />\n<br />\n我地1唔可以再比人有口實，成場運動只係一班年輕人唔識野搞搞震，而且要清楚比佢地察覺，承認，呢場戰爭係上上下下各行各業各年齡層包括眾多專業人空都反對，要出現到呢個信息<br />\n<br />\n咁樣佔社會大多數既愚民先會識驚，先知到自己先係比煽動既1一群，先可以清楚自己係應該企係我地呢邊，先識分乜野係對錯，先會聽得入耳我地既訴求，因為呢d訴求係由成年既專業人士都係咁講<br />\n<br />\n我再講多次，要中學生罷課，都唔好話10%學生真係罷得到都好保守，無了期咁罷係傷唔到對方，而且更加令人有口實，年輕人係真係比煽動，腦旬都未生埋就出嚟搞事，書都未讀完，於是佢一定唔會支持黑衫既人，更加確立深藍位置<br />\n<br />\n唔好再咁無恥要中學生同你罷課"},{"pid":"7a6b62bb9b7f8924260e4d52c45ca8ded30b4aac","tid":1439614,"uid":67553,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:59:14.000Z","msg":"光復香港 時代革命"},{"pid":"db9eba3b90f115a16ac8a18105b241f6ecdd3d76","tid":1439614,"uid":260695,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:59:15.000Z","msg":"推"},{"pid":"9954c8cbb609b2144939cd36033e75dd8bf1e9fb","tid":1439614,"uid":267172,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:59:37.000Z","msg":"光復香港 時代革命"},{"pid":"de6621fc4bbc4dde8c10e4d3796b5e7d6e411156","tid":1439614,"uid":27675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:59:40.000Z","msg":"如果諗住開學罷課，而家大家要開始籌備了"},{"pid":"8d3ad1ab070f5ba40a3bf1668386ce5ef6bf4c2b","tid":1439614,"uid":164031,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T07:59:42.000Z","msg":"Push"},{"pid":"4df07cfabcaa28224121f898d6a0550fc0311ff9","tid":1439614,"uid":67491,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T08:00:41.000Z","msg":"罷課都make到noise！推！"},{"pid":"32bd485a92ec8270ea8156dfc975e74f54448ba4","tid":1439614,"uid":36592,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-10T08:03:14.000Z",