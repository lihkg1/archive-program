BA%2594-%25E5%2582%25B3%25E6%2588%2596%25E6%2592%25A4%25E5%259B%259E%25E5%2591%258A%25E7%25A5%25A8-%25E9%25A3%259F%25E7%2592%25B0%25E7%25BD%25B2-%25E6%259C%2583%25E4%25BA%2586%25E8%25A7%25A3%25E4%25BA%258B%25E4%25BB%25B6%25E5%25A7%258B%25E6%259C%25AB-%25E5%2586%258D%25E6%25B1%25BA%25E5%25AE%259A%25E8%25B7%259F%25E9%2580%25B2%25E8%25A1%258C%25E5%258B%2595%2F&d=rocWq0H159RMtn9QCTPVbPaDgzkAO6tKN2FhpyhCcE0%3D&h=a9cc583e\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fsociety%2F%25E5%25A9%2586%25E5%25A9%2586%25E5%2580%2592%25E6%25B0%25B4%25E8%25A2%25AB%25E7%25BD%25B0%25E5%258D%2583%25E4%25BA%2594-%25E5%2582%25B3%25E6%2588%2596%25E6%2592%25A4%25E5%259B%259E%25E5%2591%258A%25E7%25A5%25A8-%25E9%25A3%259F%25E7%2592%25B0%25E7%25BD%25B2-%25E6%259C%2583%25E4%25BA%2586%25E8%25A7%25A3%25E4%25BA%258B%25E4%25BB%25B6%25E5%25A7%258B%25E6%259C%25AB-%25E5%2586%258D%25E6%25B1%25BA%25E5%25AE%259A%25E8%25B7%259F%25E9%2580%25B2%25E8%25A1%258C%25E5%258B%2595%2F&h=195be734\" target=\"_blank\">https://www.thestandnews.com/society/%E5%A9%86%E5%A9%86%E5%80%92%E6%B0%B4%E8%A2%AB%E7%BD%B0%E5%8D%83%E4%BA%94-%E5%82%B3%E6%88%96%E6%92%A4%E5%9B%9E%E5%91%8A%E7%A5%A8-%E9%A3%9F%E7%92%B0%E7%BD%B2-%E6%9C%83%E4%BA%86%E8%A7%A3%E4%BA%8B%E4%BB%B6%E5%A7%8B%E6%9C%AB-%E5%86%8D%E6%B1%BA%E5%AE%9A%E8%B7%9F%E9%80%B2%E8%A1%8C%E5%8B%95/</a>"}}