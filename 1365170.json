macros%2Fs%2FAKfycbx3iXYrOgGQhE1ESqUjWtdNXXVJk6L6gVVaaY-qF8xwdGtPbYTZ%2Fexec&d=VlhNwxbPYDbrmmiZclZ9hMg1Od0Dt6CGL4wHSLmh2%2Bg%3D&h=65a4f70a\" data-auto-link target=\"_blank\">https://script.google.com/macros/s/AKfycbx3iXYrOgGQhE1ESqUjWtdNXXVJk6L6gVVaaY-qF8xwdGtPbYTZ/exec</a><br />\n<br />\nFacebook msg: @civilservantsflowers<br />\n<br />\nTelegram: <a href=\"https://t.me/civilservantsflowers\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ft.me%2Fcivilservantsflowers&d=VlhNwxbPYDbrmmiZclZ9hMg1Od0Dt6CGL4wHSLmh2%2Bg%3D&h=8526feb8\" data-auto-link target=\"_blank\">https://t.me/civilservantsflowers</a><br />\n<br />\n<br />\n人手勁唔夠，如果有錯有漏麻煩屌得細力啲<br />\n<br />\n感激各位冇TLDR<br />\n兄弟爬山，各有各做"}]}