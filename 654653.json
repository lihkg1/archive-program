hkgmoji\" />"},{"pid":"8951ef8704e67e7741f31630fbc799d66c0c39f6","tid":654653,"uid":180035,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-05-06T05:09:47.000Z","msg":"講完睇下先又要企係度等 通常我都慢慢睇 睇好撚耐 等佢地頂唔順走<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"}]}