sga.org.hk/C-080615.files/image001.jpg?ver=1562553772\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.fsdsga.org.hk%2FC-080615.files%2Fimage001.jpg%3Fver%3D1562553772&h=baa131d7&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-11-04T03:33:10.000Z","msg":"就篤呢d 局俾popo<br />\n話入面有黄絲暴徒<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"2ab7dc0cf2406146576cfe4f1cdc3f12877f5f0c","tid":1692030,"uid":48315,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-04T03:33:59.000Z","msg":"消防好慘 人地popo公會全部都係撐自己友<br />\n消防公會就係撐popo唔撐自由人"},{"pid":"8149da3423950d36e1b1fe58ae75544640e33e54","tid":1692030,"uid":292204,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-04T03:35:00.000Z","msg":"咪又係D毅進黑警把口唔收。其實一開始有個阿sir已經講咗𠗐好意恩，個消防都無乜嘢<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" />"},{"pid":"366d41d7407bd17542e50f332f6039095fc34c9d","tid":1692030,"uid":96648,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-04T03:38:30.000Z","msg":"警察消防部"},{"pid":"357e3e01ad1e41f5c2f8dd1e52d7eca7acd61c72","tid":1692030,"uid":27411,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-04T03:40:01.000Z","msg":"屌你老母咁撚樣都跪得低你仲學人講尊嚴? <br />\n做警甴隻狗罷啦<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"4bb5ece9d8b1ba26e6680dfb493ef35e0704a232","tid":1692030,"uid":195187,"like":0,"dislike":0,"score":0,"quote":{"pid":"440ef7f3c537847b9d96eaccfe5946e873a23c33","tid":1692030,"uid":184679,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-04T01:58:54.000Z","msg":"警方星期六港島驅散行動中，一輛消防車懷疑被催淚彈擊中，車內一名消防員不滿，下車與警員理論。消防處職工總會主席謝學忠澄清，當時有警員想分隔該名消防員及防暴警員，所以在片段上看似雙方發生推撞。<br />\n<br />\n謝學忠在本台節目《千禧年代》表示，該名消防員下車與警員理論時，有警員已即場表達不好意思，另外有警員及消防員均出現不禮貌的言辭，有警員擔心雙方發生口角，所以分隔兩人，澄清片段看到的「推撞」，其實是分隔兩人的行為。他表示，已聯絡相關同事，對方同意相關細節，又希望不要再將事情放大。<br />\n<br />\n被問到片段看到該名消防懷疑被警員圍著，謝學忠認為是人數上的問題，因為當時有10多名防暴警員，但只有一名消防員，所以看似被圍。 <br />\n<br />\n<a href=\"https://news.rthk.h