,"uid":127511,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-12T11:44:00.000Z","msg":"有冇人報告下晚市點"},{"pid":"2e003e41496e37d667652862ade7a4e8565f8941","tid":1309651,"uid":171313,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-07-12T11:45:23.000Z","msg":"吉野家好難食<br />\n期待松屋入港"},{"pid":"b24e8dc5e97c2c835523f3e177e5fbc8e4312135","tid":1309651,"uid":219146,"like":1,"dislike":0,"score":1,"quote":{"pid":"0412078431cbc8d86f3b98e551a0c12033a0389a","tid":1309651,"uid":127511,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-12T11:44:00.000Z","msg":"有冇人報告下晚市點"},"citedBy":1,"replyTime":"2019-07-12T11:45:55.000Z","msg":"好撚多人"},{"pid":"b4ec36696b5c2e83b68ffab3b6e788f520e0d250","tid":1309651,"uid":263251,"like":0,"dislike":0,"score":0,"quote":{"pid":"b24e8dc5e97c2c835523f3e177e5fbc8e4312135","tid":1309651,"uid":219146,"like":1,"dislike":0,"score":1,"quote":{"pid":"0412078431cbc8d86f3b98e551a0c12033a0389a","tid":1309651,"uid":127511,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-12T11:44:00.000Z","msg":"有冇人報告下晚市點"},"citedBy":1,"replyTime":"2019-07-12T11:45:55.000Z","msg":"好撚多人"},"citedBy":0,"replyTime":"2019-07-12T11:46:36.000Z","msg":"屌"},{"pid":"543e3a7a48a0f0ee2d4d798360f3cf7985463230","tid":1309651,"uid":65530,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-12T11:51:47.000Z","msg":"此回覆已被刪除"},{"pid":"a3998c5de7ba24aa78d7a6d7e21b3e7e8515150a","tid":1309651,"uid":90697,"like":0,"dislike":0,"score":0,"quote":{"pid":"ff278b876733ed90bca1424893f7811d673c20b4","tid":1309651,"uid":107216,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-07-12T10:13:49.000Z","msg":"真心食唔落<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-07-12T12:23:05.000Z","msg":"狗先食得落<br />\n你係人"},{"pid":"bc841f4cc4d276fbb6763cd58e1ccb60680a9dd9","tid":1309651,"ui