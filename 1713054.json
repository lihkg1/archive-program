設銀行股份有限公司<br />\n11. 中國建築股份有限公司<br />\n12. 中國農業銀行股份有限公司<br />\n13. 中國平安保險（集團）股份有限公司<br />\n14. 中國人壽保險（集團）公司"},{"pid":"4c7b6563f72b4ce04f21a940847bb2a5152d369e","tid":1713054,"uid":91397,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T20:25:21.000Z","msg":"推"},{"pid":"8b9576bf9757268af23527080319a3fd9ee49907","tid":1713054,"uid":91397,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-12T20:25:31.000Z","msg":"推"},{"pid":"04964fce53854504ec53531837f91083acee2292","tid":1713054,"uid":10540,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T23:03:54.000Z","msg":"Push"},{"pid":"eb065b78e9a9b1fe74b44cefe9e2ec340b33bc51","tid":1713054,"uid":223609,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-17T23:06:16.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"}]}