g/smile.gif\" class=\"hkgmoji\" /> <br />\n<br />\n一年七萬人到啦<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"20ea363bacfc7cab6c7b5e2d58786c1bb59c22d5","tid":658990,"uid":53060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-10T05:29:49.000Z","msg":"<img src=\"https://s.yimg.com/ny/api/res/1.2/1Bf25ehApkPiZ_3jNpYmCA--/YXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9ODAw/http://media.zenfs.com/en/homerun/feed_manager_auto_publish_494/5e6455c8d4f04fc1b7706b82a8aad33e\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs.yimg.com%2Fny%2Fapi%2Fres%2F1.2%2F1Bf25ehApkPiZ_3jNpYmCA--%2FYXBwaWQ9aGlnaGxhbmRlcjtzbT0xO3c9ODAw%2Fhttp%3A%2F%2Fmedia.zenfs.com%2Fen%2Fhomerun%2Ffeed_manager_auto_publish_494%2F5e6455c8d4f04fc1b7706b82a8aad33e&h=8bedea24&s={SIZE}\" />"},{"pid":"e45fe3f5a8cbb327e58e0cdb4d4808f585d28f00","tid":658990,"uid":49359,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-10T11:52:06.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"d2fd6445ea66303302bd54db0c2de6a55377a58e","tid":658990,"uid":48083,"like":0,"dislike":0,"score":0,"quote":{"pid":"aaeb76141d5ddb6a3294bcb71df2bcf52ffc21c8","tid":658990,"uid":83582,"like":14,"dislike":0,"score":14,"citedBy":2,"replyTime":"2018-05-09T12:47:13.000Z","msg":"都話左唔止150, 開發幾多土地都唔夠用"},"citedBy":1,"replyTime":"2018-05-10T11:54:16.000Z","msg":"專才計劃仲係唔包係150<br />\n即係上年哩兩樣加埋已經6萬人"},{"pid":"822ba39ef41a221363d3995c5c4cbc7e9c9b70a6","tid":658990,"uid":99205,"like":0,"dislike":0,"score":0,"quote":{"pid":"fce6e0961f4121164e4a494137be48831cdbaefb","tid":658990,"uid":63154,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-05-10T03:33:45.000Z","msg":"在座各位都係垃圾.jpg"},"citedBy":0,"replyTime":"2018-05-10T11:56:45.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/08/22/110302_3d1a882572933513d7b8613967a0a682.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F