3%2F20%2F232428_4d98ee2cca504de8274c563812596f99.png&h=e7ec4590&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/20/232433_6667e4ce62157fd66ec69f28474ca3d3.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F20%2F232433_6667e4ce62157fd66ec69f28474ca3d3.png&h=006e58da&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/20/232435_1f7df71d560f01dba7733b0439dcaf5f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F20%2F232435_1f7df71d560f01dba7733b0439dcaf5f.png&h=06f39eef&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/20/232439_d2fc8635a2c1f8f970b5ffbaa04c7b7a.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F20%2F232439_d2fc8635a2c1f8f970b5ffbaa04c7b7a.png&h=56f72f92&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/20/232443_90242b9342167ada2619da8f0c24b0f9.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F20%2F232443_90242b9342167ada2619da8f0c24b0f9.png&h=92501c2b&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/20/232446_3a89914139b2d5ed8f7084ad3f5151c1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F20%2F232446_3a89914139b2d5ed8f7084ad3f5151c1.png&h=62ca9027&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/20/232448_a43e79e31fa9481f37f37f3ff6ffef62.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F20%2F232448_a43e79e31fa9481f37f37f3ff6ffef62.png&h=4b754a6f&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/20/232452_25002439a7fc1df04f939ae41ae45d55.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F20%2F232452_25002439a7fc1df04f939ae41ae45d55.png&h=9732c305&s={SIZE}\" /><br />\n終於去到傳說既小丑漢堡<br />\nhost誇張到話有人專誠為左佢而黎函館<br />\n我就20:45到鋪頭 <br />\n收九點前面對台灣情侶竟然嗌野食嗌成五分鐘<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fuck.gif\" class=\"hkgmoji\" /> <br />\n<br />\n食完我既感想係平夾大食 即係抵<br />\n味道我比7.5 我會話黎函館係必食"},{"pid":"4590bd86668ad50f9108a501b4458829fe56432e","tid":597661,"uid":8203,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-20T15:36:06.000Z","msg":"而我去既十字街銀座站食聖誕主題<br />\n而間間分店都有唔同主題 <br />\n我認為小丑漢堡賣點唔在於食物<br />\n而係佢既鋪頭比到人既感覺係舊時美式快餐店既歡樂<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <br />\n佢永遠停留係聖誕節 比到人一種節日氣氛<br />\n心入面好溫暖<br />\n順帶一提全部店員都起碼五十路<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"075159971ea36adab74d759ebfcc2aeba6d53ce5","tid":597661,"uid":8203,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-21T02:02:58.000Z","msg":"毒撚開po無人理<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"7839f81a165ad4f5631e8d34d069827388a74647","tid":597661,"uid":11688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-03-21T02:07:03.000Z","msg":"好鐘意函館 夠靜"},{"pid":"1addcfb6fa9379a3f276210a1f0a0aa9773c0472","tid":597661,"uid":100131,"like":3,"dislike":0,"score":3,"quote":{"pid":"075159971ea36adab74d759ebfcc2aeba6d53ce5","tid":597661,"uid":8203,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-21T02:02:58.000Z","msg":"毒撚開po無人理<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-03-21T02:21:20.000Z","msg":"你