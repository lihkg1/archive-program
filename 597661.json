a8d48d350dff74017dc3fbf2b43.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F22%2F162342_6e29fa8d48d350dff74017dc3fbf2b43.png&h=d2a38acb&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/22/162344_a2da084175dcaa0ff402f93902fad3f8.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F22%2F162344_a2da084175dcaa0ff402f93902fad3f8.png&h=15d815a6&s={SIZE}\" /><img src=\"https://img.eservice-hk.net/upload/2018/03/22/162346_7ea621655d9c6e39369d4fbc6038344a.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F22%2F162346_7ea621655d9c6e39369d4fbc6038344a.png&h=fc8ff82e&s={SIZE}\" /><br />\n然後就行左去紅色倉庫<br />\n大多都係賣手信 精品 小品<br />\n總之目不暇給 你中意shopping既呢個area夠你行三四個鐘<br />\n有個teddy bear館裡面有勁多熊仔 D熊仔會「cosplay」日本既大人物<img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" /> <br />\n行過一間叫北の灯既鋪頭 比個店員囉唆左勁耐<br />\n又話函館獨有既雪玉云云<br />\n結果我又比佢氹到買成萬円<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/want_die.gif\" class=\"hkgmoji\" /> <br />\n因為之後繼續行見到d更靚更平既<img src=\"/assets/faces/fs/fuck.gif\" class=\"hkgmoji\" />"}]}