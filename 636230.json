gur.com%2FofBNKQi.png&h=0e577f1c&s={SIZE}\" />  <img src=\"http://i.imgur.com/3t6dl40.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi.imgur.com%2F3t6dl40.png&h=65916f4a&s={SIZE}\" /></div><br />\n<div style=\"text-align: center;\">(3)苟芸慧vs張曦雯(7)</div><br />\n<br />\n<div style=\"text-align: center;\">聯賽賽時為22小時，會員可於本回覆發起後22小時內於以回覆評分功能(前者上箭咀;後者下箭咀)投選心水賽事女神。<br />\n在<span style=\"color: red;\">指定時段外</span>的回覆評分功能投票<span style=\"color: red;\">將不作計算</span>在內，請會員密切留意比賽時間。</div><br />\n<br />\n<div style=\"text-align: center;\">主場女神票數達到15者會按得票相關情況獲得指定額外分數，會員請踴躍投票支持參賽者。</div>"},{"pid":"2fb70b8ae4f5c1d9e86573c4957e2c877c781cc0","tid":636230,"uid":92376,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-20T16:18:53.000Z","msg":"每場賽事每收到10票,將會捐出$0.1到慈善機構,就算唔夠10票,都會將總票數合併,多出既仙不論多少一律會作新既一毫計算<br />\n<br />\n善款會喺結算後於歇冬期及賽季結束後各捐出一次,希望大家參與同時,仲可以做埋善事,一舉兩得<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n上半季籌到既296元已經捐出,多謝大家支持<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n<br />\n<a href=\"https://lihkg.com/thread/518316/page/1\" target=\"_blank\">https://lihkg.com/thread/518316/page/1</a><br />\nclick入上址即可參閱下半季詳盡賽程<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <br />\n<br />\nLIHKG香港女神總會盃決賽會係4月29日舉行<br />\n文詠珊VS李佳芯<br />\n<br />\n<a href=\"https://lihkg.com/thread/636206/page/1\" target=\"_blank\">https://lihkg.com/thread/636206/page/1</a><br />\nLIHKG環球女神冠軍盃4強已經誕生<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><br />\n新垣結衣(日本)<br />\nvs<br />\n周子瑜@TWICE(台灣)<br />\n<br />\nIU(韓國)<br />\nvs<br />\n謝安琪(香港)<br />\n<br />\n<br />\n抽籤將於下星期舉行,有結果會再另行公佈<br />\n<br />\n希望巴打絲打們到時踴躍參與<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"2813cd7f6f9443681bcbf0560ebfb3d6caebb806","tid":636230,"uid":92376,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-20T16:28:33.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"30ac4a0edfdcc27b3f806dac6bc1d8ca4e89efc0","tid":636230,"uid":92376,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-20T16:36:59.000Z","msg":"<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},{"pid":"df2da38d2e7464969ca560dd6630c8662c3083b5","tid":636230,"uid":92376,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-20T16:47:08.000Z","msg":"<img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" />"},{"pid":"68642500b75a1da0afabe321dcce8f83f392edf7","tid":636230,"uid":92376,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-04-20T17:04:31.000Z","msg":"<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"deabae88432a9c8ed0d7d46d50e9fd7d7e631b18","tid":636230,"uid":10876,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-20T17:38:46.000Z","msg":"<img src=\"/assets/faces/big/lomore_agree.gif\" class=\"hkgmoji\" />"},{"pid":"e7a83dd559d3ea128ae7164d3f39ce0541d04945","tid":636230,"uid":92376,"like":0,"dislike":0,"score":0,"quote":{"pid":"deabae88432a9c8ed0d7d46d50e9fd7d7e631b18","tid":636230,"uid":10876,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-04-20T17:38:46.000Z","msg":"<img src=\"/assets/faces/big/lomore_agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-04-20T17:55:30.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"749a96a3e3152902c6