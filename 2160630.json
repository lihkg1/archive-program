.gif\" class=\"hkgmoji\" /><br />\n講講下我都想按腳 差唔多一年未按<br />\n利申 非gay 但一定要搵男技師<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"8baf4af2921efce48e04d257db01fe01f8a1b614","tid":2160630,"uid":214502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-17T06:35:03.000Z","msg":"<img src=\"/assets/faces/lm2/point1.gif\" class=\"hkgmoji\" />"},{"pid":"6852de1d08aa37a0ed37dca87765f23705bc1456","tid":2160630,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-17T07:18:54.000Z","msg":"正喎<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},{"pid":"31b9034abb1206f7e49da31d1cb52600e9907ed5","tid":2160630,"uid":272819,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-17T09:46:59.000Z","msg":"撈檬好味<img src=\"/assets/faces/lm2/eating.gif\" class=\"hkgmoji\" />"},{"pid":"319e9c9d45d6bb058cba36343869a6fdc5f45d12","tid":2160630,"uid":310853,"like":0,"dislike":0,"score":0,"quote":{"pid":"6852de1d08aa37a0ed37dca87765f23705bc1456","tid":2160630,"uid":60545,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-17T07:18:54.000Z","msg":"正喎<img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/wet.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-08-17T10:12:06.000Z","msg":"佢個價錢夠平<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"d2a6344005ad76a9de794179c69de4fe3c24c335","tid":2160630,"uid":310853,"like":0,"dislike":0,"score":0,"quote":{"pid":"31b9034abb1206f7e49da31d1cb52600e9907ed5","tid":2160630,"uid":272819,"like":0,"dislike":0,"score