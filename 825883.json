/big/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ab4eb86066afb78bcea850c69e4654f28f4e98ad","tid":825883,"uid":21028,"like":0,"dislike":2,"score":-2,"quote":{"pid":"2638ed7d394e31ff0f70a5831c2a0ce79e4ec43f","tid":825883,"uid":141151,"like":0,"dislike":1,"score":-1,"quote":{"pid":"cc08cbac4a9a3e4781d7e4c0bcdfa07c47960006","tid":825883,"uid":7632,"like":9,"dislike":1,"score":8,"citedBy":1,"replyTime":"2018-09-18T03:11:25.000Z","msg":"日本仔最近發現大量稀土，夠用幾百年<br />\n<br />\n<a href=\"https://udn.com/news/story/6811/3079822\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fudn.com%2Fnews%2Fstory%2F6811%2F3079822&d=in88Pmjn3G1wA9FuzEv35J4f2li5K%2Fs6EGgmwhpeblA%3D&h=bd927ac6\" data-auto-link target=\"_blank\">https://udn.com/news/story/6811/3079822</a>"},"citedBy":2,"replyTime":"2018-09-18T03:56:13.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-09-19T00:56:32.000Z","msg":"畀我係中共就出兵打鳩佢據為己有 除非唔夠打<br />\n贏国軍事咁強 真係畀個on9領軍都贏到開巷啦<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"69880ae45055d0dd911be127828aec6c9e608b7d","tid":825883,"uid":9964,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-19T01:01:29.000Z","msg":"<blockquote><blockquote>中國反擊<br />\n美國還擊<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /></blockquote>無限loop 輸家只會係 係贏國廠商<br />\n<br />\n贏家係美帝同贏國官員</blockquote><br />\n<br />\n中國唔賣材料就無其他國家賣咩<br />\n中國反擊 最大贏家一家係其他可以生產重金既國家 例如日本仔<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"252e08094fb719bc64053d671f426ecd175e6124","tid":825883,"uid":28654,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-19T01:03:27.000Z","msg":"中國制造2025"}]}