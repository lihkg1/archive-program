{"tid":505453,"cid":5,"subCid":0,"title":"【國際突發】墨爾本汽車衝向繁忙路口 造成至少19傷","createTime":"2017-12-21T06:48:28.000Z","updateTime":"2017-12-21T06:59:52.000Z","uid":65346,"like":0,"dislike":0,"uniUserReply":4,"replies":[{"pid":"453956c7c287f3c56c5fbeaa85dc74b3a2394588","tid":505453,"uid":65346,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-21T06:48:28.000Z","msg":"<a href=\"https://hk.news.appledaily.com/international/realtime/article/20171221/57609432\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Finternational%2Frealtime%2Farticle%2F20171221%2F57609432&d=pDKrl1Vp8gUPhiduO97o%2FywN645TRhVPBLeqKBQ2Igw%3D&h=0da1f90d\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Finternational%2Frealtime%2Farticle%2F20171221%2F57609432&h=999ff273\" data-auto-link target=\"_blank\">https://hk.news.appledaily.com/international/realtime/article/20171221/57609432</a><br />\n<br />\n澳洲墨爾本有車撞入人群，造成至少19人受傷。<br />\n<br />\n事發現場消息指，撞人的白色汽車當時完全無減速跡象駛入一個繁忙的路口，結果造成多人受傷，包括一名學前兒童。一名到場處理的警員質疑屬恐襲。"},{"pid":"7ef4c1dd2426b6cce875afee31df8d74885aa666","tid":505453,"uid":37005,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-21T06:51:29.000Z","msg":"<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"88a45420192f86021d0729f63d151c6de3eab4cd","tid":505453,"uid":511,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-21T06:53:10.000Z","msg":"<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f99b7cdbdc68887f1ff0318eff20846f383f45f5","tid":505453,"uid":102096,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-12-21T06:59:52.000Z","msg":"此回覆已被刪除"}]}