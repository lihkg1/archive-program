b473c8","tid":1300821,"uid":78907,"like":0,"dislike":0,"score":0,"quote":{"pid":"dae190dc8c44a8225de0c2b37be71e4efa5f14f0","tid":1300821,"uid":267204,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-09T13:35:15.000Z","msg":"好緊張<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-09T13:37:53.000Z","msg":"冇事嘅 可能攞條5**full hse呢<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-09T14:29:12.000Z","msg":"機會好微呀 今晚都未必訓得着"},{"pid":"c07a46af5367ed43d7bed7cbfb76773ec13bb8ce","tid":1300821,"uid":57793,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2019-07-09T14:37:47.000Z","msg":"dse之後仲有好多路揀，得2條唔係：<br />\n1. 尋死<br />\n2. 毅進警察科<br />\n<br />\n搵d你鍾意或者你覺得讀到既科／職業，俾心機做，好多出路嫁<br />\n<br />\n我係ce al年代既屋邨妹，上中學之後成績差左呀媽都唔認得，al得4D，jupus都得俾HD我。degree無我份，只可以入asso／HD，結果揀左一科我鍾意既，讀得唔錯，上到大學。宜家做教育界，唔敢講有幾叻，都叫搵到2餐。黎緊去外國工作假期添。<br />\n<br />\n有朋友讀書差我更多，家境差唔多，去左讀廚，宜家係澳洲；有d搵到自己長處，搵錢多過我<br />\n<br />\n你再睇下我地今次運動既手足。點解做到咁多野？就係因為各行各業各種技能既人都有。<br />\n<br />\n問下自己叻d乜、想做乜，係可能有d遲，但係都有一晚諗同搵資料，未遲架<br />\n<br />\n總之有命，就仲有機會<br />\n呢度大把手足撐住你"},{"pid":"b61b4d8d297ddfb1fb4788be893c5dbb1cbb7bf1","tid":1300821,"uid":78907,"like":0,"dislike":0,"score":0,"quote":{"pid":"95e4a072cf06427b2bd5765fb346280a47b8e7e3","tid":1300821,"uid":267204,"like":0,"dislike":0,"score":0,"quote":{"pid":"2c9b02fecdb9d62671d97d224bc980c5afb473c8","tid":1300821,"uid":78907,"like":0,"dislike":0,"score":0,"quote":{"pid":"dae190dc8c44a8225de0c2b37be71e4efa5f14f0","tid":1300821,"uid":267204,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-09T13:35:15.000Z","msg":"好緊張<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-07-09T13:37:53.000Z","msg":"冇事嘅 可能攞條5**full hse呢<img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"