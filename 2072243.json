mg src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"996cab0b49c9e3e56dcd05d261ea88926454d97c","tid":2072243,"uid":36162,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-20T18:28:17.000Z","msg":"如果有幾億人受災，都應該唔少人死<br />\n到時除時又有温疫"},{"pid":"d0f76844964f20c4c0ffda6ec2c407cee1c2e949","tid":2072243,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-26T04:52:37.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"06dfc43a4f07380eff31d8117635e526154227a9","tid":2072243,"uid":237562,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-26T04:56:39.000Z","msg":"因為水利學家去曬做官"},{"pid":"bd4d6331655c895ba2dde559459808ecf2d5dc7a","tid":2072243,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-26T06:59:18.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"}]}