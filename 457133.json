tps%3A%2F%2Fcdn.unwire.hk%2Fwp-content%2Fuploads%2F2016%2F09%2FMarco.png?dpr=2.0&amp;fit=crop&amp;h=320&amp;w=\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fswiftype2.imgix.net%2Fhttps%253A%252F%252Fcdn.unwire.hk%252Fwp-content%252Fuploads%252F2016%252F09%252FMarco.png%3Fdpr%3D2.0%26fit%3Dcrop%26h%3D320%26w%3D&h=7f1df7dc&s={SIZE}\" /><br />\nIt=缺人<br />\n大把錢搵"},{"pid":"b38938a8c7ae29419aa5e8a416b06ab6ed3a0b5d","tid":457133,"uid":17738,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-03T14:50:52.000Z","msg":"<blockquote>老貓點睇<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20171103/large/1509705181_b2ee.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20171103%2Flarge%2F1509705181_b2ee.jpg&h=f4735620&s={SIZE}\" /></blockquote><br />\n<br />\n<img src=\"/assets/faces/big/lomore_shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/lomore_shocking.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/lomore_shocking.gif\" class=\"hkgmoji\" /> 老貓嚟嘅"},{"pid":"ba8b55224b63e0fc1c4b1714f524f47f0265d937","tid":457133,"uid":90,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-03T14:50:54.000Z","msg":"<img src=\"https://swiftype2.imgix.net/https%3A%2F%2Fcdn.unwire.hk%2Fwp-content%2Fuploads%2F2016%2F09%2FMarco.png?dpr=2.0&amp;fit=crop&amp;h=320&amp;w=.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fswiftype2.imgix.net%2Fhttps%253A%252F%252Fcdn.unwire.hk%252Fwp-content%252Fuploads%252F2016%252F09%252FMarco.png%3Fdpr%3D2.0%26fit%3Dcrop%26h%3D320%26w%3D.jpg&h=20ecb2dd&s={SIZE}\" />"},{"pid":"668b8e52db74960ff2c441111c2a9319354d0d5a","tid":457133,"uid":90,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-11-03T14:51:12.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/11/03/225111_f7a555f9c91ff20e833b9f569042cb12.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F11%2F03%2F225111_f7a555f9c91ff20e833b9f569042cb12.jpg&h=a5a10f6a&s={SIZE}\" />"},{"pid":"b01c92ad88235a580373b073d232254fbe9ff2c9","tid":457133,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-03T14:51:42.000Z","msg":"<blockquote>老貓點睇<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20171103/large/1509705181_b2ee.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20171103%2Flarge%2F1509705181_b2ee.jpg&h=f4735620&s={SIZE}\" /></blockquote><br />\n<br />\n<br />\nifandog=jail<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"89e8a9851d951471ee6b98761a411555f5bf20b6","tid":457133,"uid":90,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-03T14:53:13.000Z","msg":"香港資訊及通訊科技業的先進程度躋身世界前列。2015年11月，國際電信聯盟發表每年一度的「全球ICT發展指數」，香港在亞洲排名第二，僅次於韓國，全球排名第九。<br />\n香港擁有先進的電訊基建，是本港資訊科技業發達的主要原因。以國際電話通話時間，以及電話線、流動電話和傳真機的普及率而言，香港在亞洲名列前茅。香港亦設有亞洲最大的商用衛星地面收發站。<br />\n香港職業訓練局於2014年4月進行的一項調查顯示，全港有82,973人在資訊科技業擔任主要職務，當中33.2%受僱於資訊科技產品及服務供應商，其餘66.8%受僱於資訊科技用戶機構。<br />\n香港不少資訊科技服務供應商都擁有技術實力，善於靈活變通，並且經常接觸國際市場。他們向本地客戶提供有效的解決方案之餘，亦有能力在全球市場競爭。"},{"pid":"cd87123a8503b5b14608661c5cfd8a680c808280","tid":457133,"uid":17738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-03T14:53:50.000Z","msg":"<blockquote><blockquote>老貓點睇<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20171103/large/1509705181_b2ee.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20171103%2Flarge%2F1509705181_b2ee.jpg&h=f4735620&s={SIZE}\" /></blockquote><br />\n<br />\n<br />\nifandog=jail<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /></blockquote><br />\n<br />\n<img src=\"http://img.ziines.com/ziines-user-upload/upload/2016/03/08/1592_20160308142149_56de6f7dd7e50.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.ziines.com%2Fziines-user-upload%2Fupload%2F2016%2F03%2F08%2F1592_20160308142149_56de6f7dd7e50.gif&h=0c696957&s={SIZE}\" />"},{"pid":"4242f8957d28ef1a1bbbd1fd7e47ae2176dc6e9f","tid":457133,"uid":90,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-03T14:54:41.000Z","msg":"香港是國際商業中心，資訊科技業的發展對鞏固本港的地位非常重要，也為多個行業提供創新成果。例子包括公共交通方面的八達通卡、機場管理系統、貨櫃碼頭採用的現代港口管理系統、金融界的網上及無線理財系統，以及政府部門使用的智能身份系統等。另一方面，香港對優質金融及商業服務需求殷切，為本地資訊科技企業造就有利的發展環境。<br />\n<br />\n基建方面，香港的數碼港是一個由政府及私營機構共同發展的高科技多媒體中心，造價130億港元。數碼港亦向資訊科技業提供多方面支援，包括培訓、籌辦商業配對活動及提供財政支援，以培育資訊及通訊科技界的企業和企業家。截至2015年3月，進駐數碼港的公司已籌集了逾3億港元。截至2015年底，數碼港透過培育計劃扶植了295家科技公司。<br />\n<br />\n金融方面，於1999年成立的創業板市場，為香港的資訊科技公司提供了集資場所。截至2016年4月，在創業板掛牌的公司有231家，總市值超過2,670億港元。創業板也是個便利的套現離場平台，有助吸引創業投資者考慮注資本地初創軟件公司。<br />\n<br />\n香港政府成立的創新科技基金，為資訊科技業提供另一個資金來源。截至2016年3月底，基金審批了5,088個項目的資助申請，涉及金額合共110億港元。"},{"pid":"328fc7e7dafb3a02ca5414488d32ec632f628638","tid":457133,"uid":46527,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-03T14:55:09.000Z","msg":"政府一直吹捧IT"},{"pid":"cef58450822229353aa58b42d687e76a421f85fa","tid":457133,"uid":19454,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-04T04:15:52.000Z","msg":"<img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" /> <img src=\"/assets/faces/lomoji/31.png\" class=\"hkgmoji\" />"}]}