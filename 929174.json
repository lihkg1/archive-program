ad.wikimedia.org%2Fwikipedia%2Fen%2F2%2F27%2FMimic.jpg&h=608d9489&s={SIZE}\" />"},"citedBy":0,"replyTime":"2018-12-05T11:45:03.000Z","msg":"賀建奎單野"},{"pid":"3a2c8ae7f03319d997f65c2e8a2f207c46a16de4","tid":929174,"uid":389,"like":0,"dislike":0,"score":0,"quote":{"pid":"714dff624b53cddcc2e8c39dc8c8975c36f46d5e","tid":929174,"uid":117602,"like":1,"dislike":0,"score":1,"quote":{"pid":"8c2741608518a27e10a9f0074126d4d8f98efc79","tid":929174,"uid":22566,"like":9,"dislike":0,"score":9,"citedBy":2,"replyTime":"2018-12-05T11:42:08.000Z","msg":"<img src=\"https://na.cx/i/cxc7zvr.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fcxc7zvr.png&h=ea526059&s={SIZE}\" /><br />\n佢匿草叢做乜嘢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 伏老鼠？"},"citedBy":1,"replyTime":"2018-12-05T11:44:00.000Z","msg":"人有三急"},"citedBy":0,"replyTime":"2018-12-05T11:46:13.000Z","msg":"[url]食環出動科學忍者隊捉人<br />\n<a href=\"https://lih.kg/489945\" data-auto-link target=\"_blank\">https://lih.kg/489945</a><br />\n- 分享自 LIHKG 討論區[/url]"}]}