s/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-03T06:03:37.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-03T06:03:48.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-03T06:05:04.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"7e6e2b8f8682f47ebe97bacae8895d1db9929078","tid":1534711,"uid":5549,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2019-09-03T06:05:54.000Z","msg":"文尼確實值得入top 10喎"},{"pid":"59fa6cf12a3660b26ebf332a4c16ff0d0c69cd52","tid":1534711,"uid":61271,"like":9,"dislike":1,"score":8,"citedBy":1,"replyTime":"2019-09-03T06:07:26.000Z","msg":"沙夏呢條撚樣都叫名宿<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"aa1dcf469098083146685b95553f811774863d29","tid":1534711,"uid":2429,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T06:09:39.000Z","msg":"力架就認命啦！<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />"},{"pid":"a753f485b32c25947924889eaa51fafb6700f08d","tid":1534711,"uid":289649,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T06:11:48.000Z","msg":"明白大家呢排嘅士氣經過<span style=\"font-size: xx-large;\"><span style=\"color: red;\">831恐襲</span></span>同<span style=\"font-size: xx-large;\"><span style=\"color: blue;\">901大撤退</span></span>之後好低落<img src=\"/assets/faces/dog/upset.gif\" class=\"hkgmoji\" /><br />\n我同大家一樣都係<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n但越係呢啲時候<br />\n<span style=\"font-size: x-large;\">我地就越要堅持下去，<span style=\"color: limegreen;\">團結一致</span></span><br />\n唔好比林鄭見我地冇士氣而去捉多啲人<br />\n<br />\n以下兩篇文章<span style=\"font-size: x-large;\">無論<span style=\"color: gold;