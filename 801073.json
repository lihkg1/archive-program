lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F184622_c739c4cc8b694c74bfd518e20a00dd44.jpg&h=e48d4152&s={SIZE}\" /><br />\n型仔皮嬲,好似天若有情咁加多架電單車實cow死女<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/184621_ebdf08dc81e749e054c8c0fb6c9ace1c.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F184621_ebdf08dc81e749e054c8c0fb6c9ace1c.jpg&h=a65014b4&s={SIZE}\" /><br />\n條褲最好有啲釘<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/184621_69014334172055de3935617a75418195.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F184621_69014334172055de3935617a75418195.jpg&h=bfba4713&s={SIZE}\" />"},{"pid":"7f6b2b327d9ad0403cf01d6665d25ce87a53874d","tid":801073,"uid":8307,"like":1,"dislike":1,"score":0,"quote":{"pid":"1c1f8a111f4539ced94ddf426028371b9ea4395c","tid":801073,"uid":109983,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-31T10:43:43.000Z","msg":"抄post狗<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<a href=\"https://m.hkgolden.com/view.aspx?message=5584229&amp;page=1\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.hkgolden.com%2Fview.aspx%3Fmessage%3D5584229%26page%3D1&d=ZLoo38Xlgln5pGjbkuEY%2BLIOlR6kLHi1VdsYCD5DrTY%3D&h=bfcd9b4d\" target=\"_blank\">https://m.hkgolden.com/view.aspx?message=5584229&amp;page=1</a>"},"citedBy":0,"replyTime":"2018-08-31T10:48:46.000Z","msg":"全世界得1個人可以教人襯衫?<br />\n久唔久就有人開教襯衫post架啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"2a2011b2a10df1b1ff39c0acc86948b105b5fb0a","tid":801073,"uid":8307,"like":0,"dislike":0,"score":0,"quote":{"pid":"02d19a50b7a416d42a3c252f73802d4a439a2677","tid":801073,"uid":129660,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-31T10:43:26.000Z","msg":"個煙斗使唔使裝d野？"},"citedBy":0,"replyTime":"2018-08-31T10:49:42.000Z","msg":"裝飾黎既姐,唔食煙既話戴住都冇壞<br />\n不過識出煙有氣勢啲"},{"pid":"16bd5304c030b5833cd52b7c63cfc8855fb583b6","tid":801073,"uid":146340,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-31T10:57:15.000Z","msg":"日日都淨係着痛T加短褲拖鞋<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"68c4d4e5c6fc11de81e64a215eede1f62c1676c5","tid":801073,"uid":8307,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-31T10:57:17.000Z","msg":"我黎sir知道各位動物台手足都好鍾意睇日劇<br />\n所以教大家著到好似伊藤淳史或者星野源咁樣<br />\n<br />\n戴眼鏡可以突顯到自己對眼,同人溝通最緊要眼神接觸<br />\n同遮住自己部份樣衰既位置<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/185259_98c2de5b050e28a26e66b02c5c3cee79.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F185259_98c2de5b050e28a26e66b02c5c3cee79.jpg&h=bca47788&s={SIZE}\" /><br />\n<br />\n格仔衫睇落好似好毒咁,其實係日本係好流行既衣著黎<br />\n各位都應該有唔少格仔衫係屋企,可以慳返啲錢唔洗買<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/185357_e8a694453fbf0e248b31a3311e84810d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F185357_e8a694453fbf0e248b31a3311e84810d.jpg&h=2c0d74f3&s={SIZE}\" /><br />\n<br />\n鮮色短褲<br />\n扯旗冇咁明顯<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/185508_a5e0397aa20c2e048fe64d4b69108df3.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F185508_a5e0397aa20c2e048fe64d4b69108df3.jpg&h=7d826181&s={SIZE}\" /><br />\n<br />\n白色長襪<br />\n小學著到中學,睇落young啲<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/185628_628d2ebade09652fce75521d3aca7730.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F185628_628d2ebade09652fce75521d3aca7730.jpg&h=ad21ca85&s={SIZE}\" /><br />\n<br />\n皮鞋夠斯文<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/08/31/185709_cbca4f03a7d8b20a5e7f8b3ab876390a.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F08%2F31%2F185709_cbca4f03a7d8b20a5e7f8b3ab876390a.jpg&h=8108b95e&s={SIZE}\" />"},{"pid":"0de5d65203516e875c830cd68db20f09bf74d32b","tid":801073,"uid":8307,"like":0,"dislike":0,"score":0,"quote":{"pid":"16bd5304c030b5833cd52b7c63cfc8855fb583b6","tid":801073,"uid":146340,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-31T10:57:15.000Z","msg":"日日都淨係着痛T加短褲拖鞋<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-31T11:04:20.000Z","msg":"學下呢個post咁著,立即型仔"},{"pid":"cc0a49991f3a8ef2f6cd32f058413f89bf333c26","tid":801073,"uid":35667,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-08-31T11:05:16.000Z","msg":"樓主點睇呢套<br />\n我動漫節戰衣黎<br />\n<img src=\"http://puu.sh/BnmJr/47e58d6bab.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fpuu.sh%2FBnmJr%2F47e58d6bab.jpg&h=119e7898&s={SIZE}\" />"},{"pid":"468c8737d2f1d53602e599314824587e2eda1dd1","tid":801073,"uid":8307,"like":0,"dislike":0,"score":0,"quote":{"pid":"cc0a49991f3a8ef2f6cd32f058413f89bf333c26","tid":801073,"uid":35667,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2018-08-31T11:05:16.000Z","msg":"樓主點睇呢套<br />\n我動漫節戰衣黎<br />\n<img src=\"http://puu.sh/BnmJr/47e58d6bab.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fpuu.sh%2FBnmJr%2F47e58d6bab.jpg&h=119e7898&s={SIZE}\" />"},"citedBy":1,"replyTime":"2018-08-31T11:07:21.000Z","msg":"全身黑色有啲dry加埋中間啲白色線都叫可以拎到個平衡<br />\n長袍唔夠高著會好柒<br />\n如果高過160cm著應該都幾好睇"},{"pid":"dc312f50ba1378d81bcf23fd9a8a4ae0e8b1fbf3","tid":801073,"uid":46389,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-08-31T11:07:51.000Z","msg":"呢排打p5 2周目#1條褲好有親切感"},{"pid":"96a430db8dc5fdbdb6c9a7a8b20379b6e60bb155","tid":801073,"uid":35667,"like":0,"dislike":0,"score":0,"quote":{"pid":"468