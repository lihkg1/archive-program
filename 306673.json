\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"f80275f23168dd78c0da54923ee233cd58dcc054","tid":306673,"uid":48157,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-07-02T18:30:05.000Z","msg":"此回覆已被刪除"}]}