moji\" />"},{"pid":"6c37ab3e4a8ff0493f8a595cb17287186ee1cc05","tid":939154,"uid":176728,"like":0,"dislike":0,"score":0,"quote":{"pid":"bc78da51f4e4fdcb18901211f4f29e654160119a","tid":939154,"uid":22959,"like":0,"dislike":0,"score":0,"quote":{"pid":"2518216d1a00c3b51615096bd940d9c39420bb78","tid":939154,"uid":176728,"like":0,"dislike":1,"score":-1,"citedBy":2,"replyTime":"2018-12-13T05:13:09.000Z","msg":"14度要著大褸<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <br />\n呢幾晚我仲著緊t shirt短褲加件薄褸"},"citedBy":1,"replyTime":"2018-12-13T05:16:18.000Z","msg":"定係開左暖氣都係得14 度<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-12-13T05:18:49.000Z","msg":"唔出奇, 北方好L凍<br />\n門口有塊簾隔溫<br />\n加上個新供暖系統應該好弱雞"}]}