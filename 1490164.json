l?u=https%3A%2F%2Fna.cx%2Fi%2FXaY0sMh.jpg&h=2a9c28ec&s={SIZE}\" />"},{"pid":"79a59b2a1afa44f3eed2018af84549db69297b0b","tid":1490164,"uid":76310,"like":1,"dislike":0,"score":1,"quote":{"pid":"e193f1e1f1b361319c6e6921201cd96fb5f3fe2e","tid":1490164,"uid":16034,"like":1,"dislike":7,"score":-6,"citedBy":3,"replyTime":"2019-08-20T04:53:06.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />無計啦印尼本身就生番國家 邊有港豬咁多包袱可言<br />\n下次捉到黑警/藍絲打人根本就要私刑 咁撚有道德係無用架"},"citedBy":0,"replyTime":"2019-08-20T06:27:53.000Z","msg":"重點係黑警唔會對你手軟<br />\n斬人<br />\n打到骨折<br />\n射爆眼<br />\n打到甩門牙<br />\n男黑警搜全祼女示威者<br />\n<br />\n<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" />"},{"pid":"5a15c2cdf7725e7cf4b1f55c3a3f8090ac8b8e88","tid":1490164,"uid":76310,"like":0,"dislike":0,"score":0,"quote":{"pid":"f8a23686f218cb47f10966d51993cc7a3cabc069","tid":1490164,"uid":188176,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-20T05:03:45.000Z","msg":"印尼香港人好快d走<br />\n第二次排華黎緊<br />\n你仲有機會走<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-20T06:28:36.000Z","msg":"回強国<br />\n共享中国人榮譽啦"},{"pid":"a1bfc3b7bdf81f085ec1fcc83b576bb54ed0f2f6","tid":1490164,"uid":266289,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-20T06:34:29.000Z","msg":"有種"},{"pid":"40c1a433859d9d51e303a0edc5649ef1871369d1","tid":1490164,"uid":40287,"like":10,"dislike":0,"score":10,"quote":{"pid":"8c605c4fa7956ea7b24dc5e21c67cf81d53f9d0e","tid":1490164,"uid":149978,"like":1,"dislike":0,"score":1,"quote":{"pid":"7b679765f319fcb55133c80ab070e9b0bd1f8e93","tid":1490164,"uid":108337,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2019-08-20T04:50:37.000Z","msg":"好好學習"},"citedBy":1,"replyTime":"2019-08-20T06:20:01.000Z","msg":"其實係印尼學香港，定香港學印尼，定大家互相彼此學習？"},"citedBy":1,"replyTime":"2019-08-21T21:57:10.000Z","msg":"其實香港人係學唔到印尼人，今次印尼發生騷亂嘅，係東部西巴布亞同巴布亞兩省，發動嘅全部係當地土著巴布亞人，同主導印尼政治及印尼最大族群爪哇族有極大文化差異，本身兩個省係印尼武力吞返嚟，加上長期歧視及冷落，好多巴布亞人都不滿印尼政府，獨立呼聲持續多年，佢哋有自組游擊隊同印尼軍警對戰，有槍有炸彈，實行武裝革命。<br />\n<br />\n而最近西巴布亞騷亂，某城市已經嚴重癱瘓，嗰啲示威者唔會同你講文明， 首先堵塞市內主要道路，然後四圍放火，將所有重要建築物燒晒，包括政府大樓，令市內大部分嘢停止運作，再衝入監獄放走囚犯，最後燒埋機場，由於示威者放火破壞係左一忽右一忽，市內警察都無符，全民皆兵，佢哋一早預咗攬炒，唔會主動同警察對碰，目標係破壞。<br />\n<br />\n香港人點學？"},{"pid":"7037174a505d4e3bf9c9c56f303b2c33f63047d4","tid":1490164,"uid":40287,"like":6,"dislike":0,"score":6,"quote":{"pid":"e193f1e1f1b361319c6e6921201cd96fb5f3fe2e","tid":1490164,"uid":16034,"like":1,"dislike":7,"score":-6,"citedBy":3,"replyTime":"2019-08-20T04:53:06.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />無計啦印尼本身就生番國家 邊有港豬咁多包袱可言<br />\n下次捉到黑警/藍絲打人根本就要私刑 咁撚有道德係無用架"},"citedBy":0,"replyTime":"2019-08-21T22:15:28.000Z","msg":"5月份雅加達騷亂，有示威者只係帶毛巾包口，著拖鞋就出去同防暴隻揪，嗰啲示威者大部分窮到濃，反正乜都冇，就同你死過，好多人寫哂遺書準備死亡，郁起手癲過香港示威者好多，佢哋大部分人已經預咗冇命，所以最後死咗8個人。<br />\n<br />\n有印尼朋友睇啲香港啲示威者同犬隻嘅衝突，直頭覺得香港啲示威者太淋，佢哋最鍾意四圍放火燒舖燒車，等啲警察心理上畏懼，汽油彈呢啲對佢哋嚟講好濕碎，但佢哋更鍾意用煙花同炮丈對付警察。但印尼警察都一樣係癲嘅， 射咗幾百粒催淚彈嗰啲示威者都唔肯走，就開真槍掃射，再出軍隊包夾。<br />\n<br />\n印尼朋友讚香港示威者好文明，同時又話香港示威者因為太規限於文明，所以永遠勇唔起。"},{"pid":"dbc62e5cd36fadc1092cb4e214020e992c15de73","tid":1490164,"uid":293036,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T22:20:00.000Z","msg":"香港人太多包袱啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"b469f6a1ca6ee24019008b845e42e454805121c6","tid":1490164,"uid":40287,"like":4,"dislike":0,"score":4,"quote":{"pid":"dbc62e5cd36fadc1092cb4e214020e992c15de73","tid":1490164,"uid":293036,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-21T22:20:00.000Z","msg":"香港人太多包袱啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-21T22:50:31.000Z","msg":"香港人差唔多每個都有包袱，唔同印尼佬，好多一窮就窮到濃，反正一無所有，就同你死過，係咁嘅心態，同埋佢哋全民有信仰，信仰有時都會畀到佢哋好多信心。上面有人講印尼人好多都係生蕃，講得冇錯，好多時就係生蕃先做到呢啲嘢。<br />\n<br />\n香港有心人好多，但因為生活上差極有譜，比起世界各地我哋尚算幸福， 一般嚟講都好難破嗰個枷鎖，上到戰嗰腦充滿矛盾及恐懼，所以好多人最後會為首畏尾。<br />\n<br />\n反而好多藍絲其實有生蕃特質， 如果佢哋集體發癲其實幾得人驚，我哋呢批實在太淋善，裝備係好永齊全，望落好有準備，但嗰心其實收藏咗好多嘢，相信好多人都係咁。"},{"pid":"5ccef100550fc3c25159c02dcce48ad57259f620","tid":1490164,"uid":290176,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-21T22:51:28.000Z","msg":"<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" />"}]}