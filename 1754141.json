B8%AF%E6%9B%B4%E5%A5%BD%E6%9C%AA%E4%BE%86\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftopick.hket.com%2Farticle%2F2504766%2F%25E8%2591%25A3%25E5%25BB%25BA%25E8%258F%25AF%25E7%25B1%25B2%25E9%2581%25B8%25E6%25B0%2591%25E4%25BB%25A5%25E6%2589%258B%25E4%25B8%25AD%25E4%25B8%2580%25E7%25A5%25A8%25E3%2580%2580%25E6%258F%259B%25E5%258F%2596%25E9%25A6%2599%25E6%25B8%25AF%25E6%259B%25B4%25E5%25A5%25BD%25E6%259C%25AA%25E4%25BE%2586&d=S%2FsiG%2FBE2bBILTWTz3VeJnqjnVJZrvj6qhhAu%2BA3ahw%3D&h=225c8085\" target=\"_blank\">https://topick.hket.com/article/2504766/%E8%91%A3%E5%BB%BA%E8%8F%AF%E7%B1%B2%E9%81%B8%E6%B0%91%E4%BB%A5%E6%89%8B%E4%B8%AD%E4%B8%80%E7%A5%A8%E3%80%80%E6%8F%9B%E5%8F%96%E9%A6%99%E6%B8%AF%E6%9B%B4%E5%A5%BD%E6%9C%AA%E4%BE%86</a><br />\n<br />\n2019年區議會選舉今日（24日）舉行，全國政協副主席董建華表示，<span style=\"color: red;\">知道部分市民對暴力亂港是「敢怒不敢言」，大家都感痛心</span>。但他認為，今日是最好機會以手中一票，選出真心為香港做事的地區代表，希望選舉後社會各界能共同努力，使香港社會回復平靜、重新出發。<br />\n<br />\n董建華早上投票後表示，香港亂局持續了5個多月，好不容易才看到有勇敢市民採取行動，站出來清走垃圾，也藉著行動向暴徒「say no」說不。<br />\n<br />\n他認為區議會是重要平台，處理社會民生事務，<span style=\"color: red;\">質疑暴徒有何理由要這樣破壞香港，強調市民要多說「不不不」。</span><br />\n<br />\n今屆區議會選舉由早上7時30分至晚上10時30分舉行，全港共有約600多個票站；由1090名候選人競逐全港452個議席。"},"citedBy":0,"replyTime":"2019-11-25T08:35:38.000Z","msg":"向警甴暴徒破壞香港說「不不不」<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"4fdfe87794cad5b51e97e453c6dfd4a44a4c0254","tid":1754141,"uid":276971,"like":0,"dislike":0,"score":0,"quote":{"pid":"884da94b106461f1495ca6597a0929e9818c1a60","tid":1754141,"uid":20870,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-11-25T06:22:16.000Z","msg":"其實要多謝返佢推行通識"},"citedBy":0,"replyTime":"2019-11-25T08:41:09.000Z","msg":"想知 當年佢死都要推通識科目的係嘜？"},{"pid":"37f8c937db9b74ce23531a102189a261698e8ef5","tid":1754141,"uid":17008,"like":0,"dislike":0,"score":0,"quote":{"pid":"e77530dfbe4d5cf007ec1c73407b01e2964001d6","tid":17