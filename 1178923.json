g src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/jable.gif\" class=\"hkgmoji\" />"},{"pid":"3021cc48144491863a56047a0e5b1004585f6137","tid":1178923,"uid":52477,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2019-05-31T23:27:42.000Z","msg":"體育<br />\n<br />\n【有片】挪威小將世青盃入9球　佢踢硬曼聯<br />\n香港時間<br />\n05月31日(五) 05:04   <br />\n更多新聞短片<br />\n<br />\n挪威U20喺今屆世青盃表現唔算好，小組頭兩場都落敗，但周五(31日)凌晨喺小組最後一場對洪都拉斯U20突然發威，大炒對手12比0攞個尾彩，陣中小將夏蘭特Erling Braut H&aring;land個人獨取9球，即係帽子戲法嘅帽子戲法，打破世青盃紀錄，而佢同蘇斯克查好有淵源，將來踢硬曼聯。 <br />\n<br />\n挪威U20能否出線，仲要睇小組賽結束後各組第3名得分，但夏蘭特喺今場波就一鳴驚人，轟動挪威球壇不在話下，仲開始喺各大足球社交網站被洗版，睇吓佢係咩來歷。 <br />\n<br />\n18歲嘅夏蘭特喺英格蘭出世，但就代表挪威青年軍，佢出身於挪超白蘭恩，上季效力莫迪期間跟過蘇斯克查，今季去咗奧地利薩爾斯堡磨鍊，但網上消息指佢一早畀曼聯球探吼實，加上蘇斯克查係現任曼聯領隊，所以佢去曼聯只係遲早問題。 <br />\n<br />\n有評論指夏蘭特踢法似盧卡古，不過睇今場佢對洪都拉斯U20表現，夏蘭特似乎仲好過盧卡古。"},{"pid":"1df9d48f7a228e5e252fa8d620bd1c64dab4d492","tid":1178923,"uid":99700,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-05-31T23:52:24.000Z","msg":"咪又係出局"},{"pid":"9d7f8310eb00ade07cc0a58f71685e0fc893b88e","tid":1178923,"uid":120070,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-01T02:51:52.000Z","msg":"可惜出唔到線"},{"pid":"c20539dcf617404f767a56e875683363620ff9a7","tid":1178923,"uid":74281,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-01T02:55:57.000Z","msg":"歐國盃新星<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"801ad4f4ba875203a0714ac7864800155b89281e","tid":1178923,"uid":191762,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-01T03:03:29.000Z","msg":"不過都係出局"},{"pid":"1554d5ab47071095189f3f746f7670ed5a555789","tid":1178923,"uid":18692,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-01T07:19:06.000Z","msg":"另一隊第3名出局<br />\n喺熱門葡萄牙 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"}]}