om/link?u=https%3A%2F%2Fwww.facebook.com%2F901362236584137%2Fposts%2F2812263218827353%2F&d=7FLALsszV4LuAMmN05fc6r7WCVQ3d6ncBxZnFa%2FO6Ec%3D&h=0cb1332d\" data-auto-link target=\"_blank\">https://www.facebook.com/901362236584137/posts/2812263218827353/</a><br />\n<br />\n參與黄店：<br />\n<a href=\"https://docs.google.com/spreadsheets/d/14eZg3bM89oCGYFfmjArmHEmknCyCvlLKkDmxwlUf9Os/htmlview\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdocs.google.com%2Fspreadsheets%2Fd%2F14eZg3bM89oCGYFfmjArmHEmknCyCvlLKkDmxwlUf9Os%2Fhtmlview&d=7FLALsszV4LuAMmN05fc6r7WCVQ3d6ncBxZnFa%2FO6Ec%3D&h=fdcc2aeb\" data-auto-link target=\"_blank\">https://docs.google.com/spreadsheets/d/14eZg3bM89oCGYFfmjArmHEmknCyCvlLKkDmxwlUf9Os/htmlview</a>"},"citedBy":0,"replyTime":"2020-04-26T02:18:43.000Z","msg":"返嚟推post啊<img src=\"/assets/faces/normal/kill2.gif\" class=\"hkgmoji\" />"},{"pid":"dd81c32bc8c4fb7bdd855a27f3bdb3fc77da5d75","tid":1985553,"uid":66798,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-26T02:18:51.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c5add04b1b90404b875f6eb392cc1e9d61cc2f20","tid":1985553,"uid":5005,"like":0,"dislike":0,"score":0,"quote":{"pid":"dd81c32bc8c4fb7bdd855a27f3bdb3fc77da5d75","tid":1985553,"uid":66798,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-04-26T02:18:51.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-04-26T02:19:20.000Z","msg":"<img src=\"/assets/faces/mouse/solution.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/mouse/solution.gif\" class=\"hkgmoji\" />"},{"pid":"748ae7abb202ae3fa8bfad347ca4002f95c12007","tid":1985553,"uid":5005,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-26T02:26:05.000Z","msg":"黃金週啊<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid