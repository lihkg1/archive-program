95,"like":0,"dislike":0,"score":0,"quote":{"pid":"60ca1c978eb56df3de431cd03cc8eb55a1b056b4","tid":906593,"uid":5489,"like":0,"dislike":3,"score":-3,"citedBy":3,"replyTime":"2018-11-18T09:53:37.000Z","msg":"憑乜撚野<br />\n做咁多年演員得一套黃金甲見得下人<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-18T10:10:55.000Z","msg":"有套邁阿密<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"44849d79b2d40ee5573e08857345f6688e19b922","tid":906593,"uid":218559,"like":0,"dislike":0,"score":0,"quote":{"pid":"34aeff74dfd567b15a9d0f2ac89caa597d933245","tid":906593,"uid":130626,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-18T06:20:32.000Z","msg":"昨晚台灣金馬獎引爆中台大戰，憑《我們的青春，在台灣》奪最佳紀錄片的導演傅榆歷，在台上發表台獨言論，疑觸動了大陸人神經，上屆影帝凃們上台頒最佳女主角時，就以一句「中國台灣金馬獎」還擊，去到頒獎禮尾聲，大會原定安排李安和鞏俐齊齊頒發最佳劇情長片獎，但...鞏俐竟然拒絕上台！<br />\n當大會宣布頒發壓軸大獎最佳劇情長片，結果只有李安單拖出場，鞏俐坐在台下冇反應，不知是否台獨風波拒上台，還是想避開以《影》入圍的舊愛張藝謀！當台上播完入圍影片後，李安對台下嘅鞏俐講：「鞏俐，妳不上來跟我頒嗎？」鞏俐依然拒上台，令李安十分尷尬！<br />\n除了臨場拒上台頒獎外，鞏俐更創下評審團主席冇向傳媒解說評審過程嘅首例，結果又要勞煩李安出頭，代表鞏俐到媒體區跟媒體致意，改由有份參與評審會議嘅執行長聞天祥講解評審過程。李安只簡單表示鞏俐「不方便下來」，問到點解鞏俐冇按程序上台頒獎？李安尷尬表示：「她想跟他們評審同事坐在一起，就決定不上來了。」<br />\n據台灣傳媒報道，鞏俐拒上台可能跟台獨、中國台灣金馬獎等言論有關，另亦有工作人員估鞏俐臨時拒絕頒獎同台獨言論冇關，因噚日評審決選投票後，就傳出鞏俐黑面，似乎對金馬決賽評審投票結果唔滿意。<br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20181118/large/1542510240_7515.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20181118%2Flarge%2F1542510240_7515.jpg&h=ed2d1b4a&s={SIZE}\" /><br />\n<img src=\"https://static.appledaily.hk/images/e-paper/20181118/large/1542510240_f340.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatic.appledaily.hk%2Fimages%2Fe-paper%2F20181118%2Flarge%2F1542510240_f340.jpg&h=5b7422c2&s={SIZE}\" /><br />\n<a href=\"https://hk.entertainment.appledaily.com/enews/realtime/article/20181118/58927433\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.entertainment.appledaily.com%2Fenews%2Frealtime%2Farticle%2F20181118%2F58927433&d=tg3Dda7iVq8UyaQIpyYsBGi1w7%2FDyS2Kz%2BsYtkalU0Y%3D&h=64a25277\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.entertainment.appledaily.com%2Fenews%2Frealtime%2Farticle%2F20181118%2F58927433&h=31262c87\" target=\"_blank\">https://hk.entertainment.appledaily.com/enews/realtime/article/20181118/58927433</a>"},"citedBy":0,"replyTime":"2018-11-18T10:42:21.000Z","msg":"臭G"},{"pid":"b2a9791d127bf8df8819d1dc4fb7b1394bafe06f","tid":906593,"uid":28435,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-18T10:53:52.000Z","msg":"狗改不了吃屎"},{"pid":"927bcc10025448676e3a127bc00ec6160007a279","tid":906593,"uid":130626,"like":2,"dislike":0,"score":2,"quote":{"pid":"9014f2ccfc5ff4c63f84791618ed29122d800ca9","tid":906593,"uid":42128,"like":0,"dislike":0,"score":0,"quote":{"pid":"3ecd6d05f0c53394717252bc3ca0036f5adaa1ee","tid":906593,"uid":127988,"like":0,"dislike":0,"score":0,"quote":{"pid":"9bb90aa8dab0450437ac59e673c78827199e01ba","tid":906593,"uid":42128,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-11-18T09:45:59.000Z","msg":"李安好慘<img src=\"/assets/faces/lomoji/23.png\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-18T10:01:54.000Z","msg":"李安怕支那有牙咩<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-11-18T10:09:35.000Z","msg":"唔係依個問題,<br />\n係佢要臨時做埋個西女人嗰份,<br />\n又要幫佢諗藉口<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-11-18T12:25:07.000Z","msg":"我都覺<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"1372b99b0ae44383e8a6c10482d22cf30fe60233","tid":906593,"uid":55960,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-11-18T12:40:11.000Z","msg":"一啲尊業精神都無<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n怕瀨屎上身就一早唔好掂台灣啲野啦<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> 兩岸問題一直都存在"},{"pid":"5dda645c338e321a6a5f9a0802373821cf0c