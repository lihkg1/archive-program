的最大動物，命名為 Cryptops speleorex 的有毒蜈蚣長達 52 毫米，名字的意思則為「洞穴之王」。<br />\n<br />\n全文請前往立場<br />\n<br />\n<a href=\"https://www.thestandnews.com/cosmos/%E6%AD%90%E6%B4%B2%E5%AF%86%E5%B0%81-550-%E8%90%AC%E5%B9%B4%E6%B4%9E%E7%A9%B4%E7%99%BC%E7%8F%BE%E5%85%A8%E6%96%B0%E7%84%A1%E8%89%B2%E8%9C%88%E8%9A%A3-%E8%A2%AB%E5%91%BD%E5%90%8D%E7%82%BA-%E6%B4%9E%E7%A9%B4%E4%B9%8B%E7%8E%8B/?fbclid=IwAR09RtZfUfE5GpLFNHiLuSOT73vIlBINvF_exJBi4fm-jyKUnRwN-gvjJI4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thestandnews.com%2Fcosmos%2F%25E6%25AD%2590%25E6%25B4%25B2%25E5%25AF%2586%25E5%25B0%2581-550-%25E8%2590%25AC%25E5%25B9%25B4%25E6%25B4%259E%25E7%25A9%25B4%25E7%2599%25BC%25E7%258F%25BE%25E5%2585%25A8%25E6%2596%25B0%25E7%2584%25A1%25E8%2589%25B2%25E8%259C%2588%25E8%259A%25A3-%25E8%25A2%25AB%25E5%2591%25BD%25E5%2590%258D%25E7%2582%25BA-%25E6%25B4%259E%25E7%25A9%25B4%25E4%25B9%258B%25E7%258E%258B%2F%3Ffbclid%3DIwAR09RtZfUfE5GpLFNHiLuSOT73vIlBINvF_exJBi4fm-jyKUnRwN-gvjJI4&d=YgirQyY3AADlg18%2F%2B2KZ%2FftobIAPz7vP9zHpdy2ENqg%3D&h=bf69c4a6\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fwww.thestandnews.com%2Fcosmos%2F%25E6%25AD%2590%25E6%25B4%25B2%25E5%25AF%2586%25E5%25B0%2581-550-%25E8%2590%25AC%25E5%25B9%25B4%25E6%25B4%259E%25E7%25A9%25B4%25E7%2599%25BC%25E7%258F%25BE%25E5%2585%25A8%25E6%2596%25B0%25E7%2584%25A1%25E8%2589%25B2%25E8%259C%2588%25E8%259A%25A3-%25E8%25A2%25AB%25E5%2591%25BD%25E5%2590%258D%25E7%2582%25BA-%25E6%25B4%259E%25E7%25A9%25B4%25E4%25B9%258B%25E7%258E%258B%2F%3Ffbclid%3DIwAR09RtZfUfE5GpLFNHiLuSOT73vIlBINvF_exJBi4fm-jyKUnRwN-gvjJI4&h=c5b74325\" data-auto-link target=\"_blank\">https://www.thestandnews.com/cosmos/%E6%AD%90%E6%B4%B2%E5%AF%86%E5%B0%81-550-%E8%90%AC%E5%B9%B4%E6%B4%9E%E7%A9%B4%E7%99%BC%E7%8F%BE%E5%85%A8%E6%96%B0%E7%84%A1%E8%89%B2%E8%9C%88%E8%9A%A3-%E8%A2%AB%E5%91%BD%E5%90%8D%E7%82%BA-%E6%B4%9E%E7%A9%B4%E4%B9%8B%E7%8E%8B/?fbclid=IwAR09RtZfUfE5GpLFNHiLuSOT73vIlBINvF_exJBi4fm-jyKUnRwN-gvjJI4</a>"},"citedBy":1,"replyTime":"2020-12-22T06:10:54.000