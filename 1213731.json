9ad9dc8d7516047256c2e761c8","tid":1213731,"uid":17352,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T03:40:19.000Z","msg":"推"},{"pid":"1c9b398286d0e69e1cbef0b62b5b09c510db8161","tid":1213731,"uid":216662,"like":2,"dislike":0,"score":2,"quote":{"pid":"341a585d1239c3f996159949bd5e37c5301214a2","tid":1213731,"uid":216662,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-13T03:37:14.000Z","msg":"送中～習帝為著獵取港島金庫竟不理港殤"},"citedBy":1,"replyTime":"2019-06-13T03:41:15.000Z","msg":"為了杜絕異己得到保障　用血肉結賬"},{"pid":"d6606395ce0c55ee10273ccb1ff8795645ec305c","tid":1213731,"uid":216662,"like":2,"dislike":0,"score":2,"quote":{"pid":"1c9b398286d0e69e1cbef0b62b5b09c510db8161","tid":1213731,"uid":216662,"like":2,"dislike":0,"score":2,"quote":{"pid":"341a585d1239c3f996159949bd5e37c5301214a2","tid":1213731,"uid":216662,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-06-13T03:37:14.000Z","msg":"送中～習帝為著獵取港島金庫竟不理港殤"},"citedBy":1,"replyTime":"2019-06-13T03:41:15.000Z","msg":"為了杜絕異己得到保障　用血肉結賬"},"citedBy":0,"replyTime":"2019-06-13T03:45:36.000Z","msg":"三個7　販賣血汗變棟樑"},{"pid":"66dfaa7972d380f09052b2d3c767ac053b41e98e","tid":1213731,"uid":216662,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-13T03:50:30.000Z","msg":"當　未慣靜默靜得聽到心跳竟加倍緊張<br />\n未信自在在於天生天養　難以弱勝強　殺入戰場<br />\n<br />\n　<span style=\"color: red;\">送中～習帝為著獵取港島金庫竟不理港殤<br />\n為了杜絕異己得到保障　用血肉結賬<br />\n三個7　販賣血汗變棟樑</span>[誰被誰越抬越上]<br />\n烏托邦　那獵物也是獵人　踏破了樹林<br />\n浮在半空寄生貨櫃箱<br />\n<br />\n誰明白這異象<br />\n<span style=\"color: red;\">六月悲傷 惡法踢翻中央 誰又會説極權正常 狗官替哪個著想？<br />\n自由未滿 謝絶中央 快上街分享<br />\n人人英姿堅決立場　誰有膽説想試送中下場</span><br />\n<br />\n當　習慣附和大家講的真理都得到獎賞<br />\n未慣十字路口挑選方向　離隊要膽量　拒絕跳牆<br />\n一輩子　血汗注入拍賣場　[誰被誰越抬越上]<br />\n一輩子　價值像泡沫上揚　誓與天較量<br />\n埋下理想栽種幻想<br />\n<br />\n<br />\n誰明白這異象<br />\n<span style=\"color: red;\">六月悲傷 惡法踢翻中央 誰又會説極權正常 狗官替哪個著想？<br />\n自由未滿 謝絶中央 快上街分享<br />\n人人英姿堅決立場　誰有膽説想試送中下場</span><br />\n<br />\n<br />\n即使你跟我比鬥已極平常<br />\n囂張得敢與天格鬥　才是榜樣<br />\n開天闢地之歌　轟轟烈烈　大合唱<br />\n如何憑人力綑綁一剎夕陽<br />\n如何憑財力去扭轉天亮　請拍掌<br />\n<br />\n習慣了這異象　誰又在叫嚷<br />\n六月飛霜　世界怪得誇張<br />\n誰又去決定誰正常　不知哪個有異想<br />\n未曾盡興　剩下砒霜　當配方分享<br />\n誰來斗膽講仙丹會斷腸　誰有膽去相信過激立場<br />\n人人一把口一百種真相　誰說得漂亮<br />\n<br />\n最可笑的　喊亦正常<br />\n最悲壯的　笑亦正常<br />\n哪一個可　發育正常"},{"pid":"9301124ca00b23e1f31a4be5769067a2169364f1","tid":1213731,"uid":225846,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-13T03:52:35.000Z","msg":"push<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"b3ac64a765e42868f3ec6ef59140ac9a4b021b0f","tid":1213731,"uid":55420,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T03:54:53.000Z","msg":"其實首歌唔駛改都好有意思 <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"0ba17374496729397cb502230cd655af630510e6","tid":1213731,"uid":216662,"like":0,"dislike":0,"score":0,"quote":{"pid":"9301124ca00b23e1f31a4be5769067a2169364f1","tid":1213731,"uid":225846,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-13T03:52:35.000Z","msg":"push<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-13T08:32:25.000Z","msg":"鼻毛仔<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"808437d6d27cb661817fd8515f7d499e3b1ceab9","tid":1213731,"uid":78253,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T15:31:46.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"1498f178f59b25a77d26abeddc2b8dd8d8dca893","tid":1213731,"uid":3571,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T15:35:13.000Z","msg":"此回覆已被刪除"},{"pid":"7fb6e4dacf7