ote":{"pid":"7709204b418b78a7ae4c4a32d57006f7870e5047","tid":1540554,"uid":146535,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T11:57:43.000Z","msg":"樓主手足個名唔係咁健康<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-04T12:10:25.000Z","msg":"半年前個香港就係咁，所以就改左個咁既名"},{"pid":"2b8d5dc8ae35517125ef3542a4cf8d715c6a68f9","tid":1540554,"uid":35104,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:11:27.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"028c34624d4b900450480ce79df3a18e39d9dc76","tid":1540554,"uid":35104,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:11:38.000Z","msg":"<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"02f6787d880034662f7be661d6cce79960ac447d","tid":1540554,"uid":146535,"like":0,"dislike":0,"score":0,"quote":{"pid":"d1e7aa07cf0a0cf332e20f85a9fe844032f57c49","tid":1540554,"uid":35104,"like":0,"dislike":0,"score":0,"quote":{"pid":"7709204b418b78a7ae4c4a32d57006f7870e5047","tid":1540554,"uid":146535,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T11:57:43.000Z","msg":"樓主手足個名唔係咁健康<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-04T12:10:25.000Z","msg":"半年前個香港就係咁，所以就改左個咁既名"},"citedBy":0,"replyTime":"2019-09-04T12:12:28.000Z","msg":"希望香港改變到之後你會換到個新名"},{"pid":"3b7a3bf1159144f9c1de9e5c2dc44bbecf9b789d","tid":1540554,"uid":209679,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T12:13:35.0