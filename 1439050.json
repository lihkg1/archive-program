22e2ccbf8e402bbb897767a3ea7bdc2","tid":1439050,"uid":36494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T03:46:55.000Z","msg":"Push"},{"pid":"633594a89111f003c433adb02246d2ee9dce551e","tid":1439050,"uid":102214,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T03:49:04.000Z","msg":"推"},{"pid":"41b708adadcb5c2dbf908c77206b587dc31724e7","tid":1439050,"uid":61882,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-11T03:52:33.000Z","msg":"呢份變相係醫護界既投名狀<br />\n尤其係做街客生意既<br />\n就睇吓無簽嗰堆之後會點<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"31ddd3ddbbcf09c708a98992937c976cbf342c53","tid":1439050,"uid":36494,"like":0,"dislike":0,"score":0,"quote":{"pid":"41b708adadcb5c2dbf908c77206b587dc31724e7","tid":1439050,"uid":61882,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-11T03:52:33.000Z","msg":"呢份變相係醫護界既投名狀<br />\n尤其係做街客生意既<br />\n就睇吓無簽嗰堆之後會點<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-11T04:00:37.000Z","msg":"係驚簽咗嗰班俾藍絲騷擾"},{"pid":"e5d6b72e400ac06552fd560ba9b466c457dcf1d5","tid":1439050,"uid":258758,"like":0,"dislike":0,"score":0,"quote":{"pid":"b719f607ee848ff82a16ce75505e2a2e67ebf963","tid":1439050,"uid":36494,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-10T03:40:42.000Z","msg":"<a href=\"https://www.facebook.com/110325316976046/posts/111060530235858?s=100000528866832&amp;sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F110325316976046%2Fposts%2F111060530235858%3Fs%3D100000528866832%26sfns%3Dmo&d=sJhP54gyZlpQHD%2BOhJ68swmnwACYIcySctyK7icvN2A%3D&h=d859972d\" data-auto-link target=\"_blank\">https://www.facebook.com/110325316976046/posts/111060530235858?s=100000528866832&amp;sfns=mo</a><br />\n<br />\n我們是一眾醫療界專職人員，時刻以守護市民身心健康為己任，竭盡所能服務市民大眾。<br />\n<br />\n近兩個月來一次又一次因反送中而發生的大型遊行示威及集會，市民聲嘶力竭，甚至以死作諫，政府依然故我，充耳不聞。更以警隊作為棋子，一次次以濫暴及無理鎮壓回應市民。<br />\n<br />\n我們痛心疾首。<br />\n<br />\n我們現懇請醫療界各專業界別參與「醫療界登報實名聯署」，再一次以更具公信力之手法促請政府立即正面回應香港人之五大訴求，以及撤銷註冊護士陳永琪日前參與人道救援時遭受的一切政治檢控。<br />\n<br />\n有意參與登報實名聯署之人士，請填妥表格，我們會先核對相關專業之名冊內的姓名及註冊編號。待人數足夠後便會公布眾籌事宜以支持登報之費用。執業會計師將會跟進一切相關帳目。如眾籌數目超過預期，扣除登報所需款項後，餘額將會捐至「立場新聞」及 「星火同盟抗爭支援」。<br />\n<br />\n我們 無畏站在公義的一方；<br />\n我們 無懼把真實姓名展露於人前。<br />\n<br />\n聯署表格：<a href=\"https://forms.gle/VG15gzxeRcrJAjMUA\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fforms.gle%2FVG15gzxeRcrJAjMUA&d=sJhP54gyZlpQHD%2BOhJ68swmnwACYIcySctyK7icvN2A%3D&h=929cc910\" data-auto-link target=\"_blank\">https://forms.gle/VG15gzxeRcrJAjMUA</a><br />\n各專業界別之名冊：<a href=\"https://tiny.cc/reglist\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftiny.cc%2Freglist&d=sJhP54gyZlpQHD%2BOhJ68swmnwACYIcySctyK7icvN2A%3D&h=6245154e\" data-auto-link target=\"_blank\">https://tiny.cc/reglist</a><br />\n<br />\n請讚好/追蹤此專頁，日後聯署人數更新以及眾籌詳情將在此發佈。<br />\n<br />\n聯署發起人<br />\n歐耀佳 醫生 Dr AU Yiu Kai<br />\n陳偉雄 註冊護士 RN CHAN Bernard Wai Hung<br />\n范子信 註冊護士 RN FAN Tsz Shun<br />\n劉凱文 註冊護士 RN LAU Hoi Man Michael Felix<br />\n梁婷欣 註冊護士 RN LEUNG Ting Yan <br />\n梁子恆 醫生 Dr LEUNG Tsz Hang"},"citedBy":0,"replyTime":"2019-08-11T04:02:17.000Z","msg":"推"},{"pid":"978d39e61f8c9a0f23f132bb964a6285fdd2c67b","tid":1439050,"uid":61882,"like":0,"dislike":0,"score":0,"quote":{"pid":"31ddd3ddbbcf09c708a98992937c976cbf342c53","tid":1439050,"uid":36494,"like":0,"dislike":0,"score":0,"quote":{"pid":"41b708adadcb5c2dbf908c77206b587dc31724e7","tid":1439050,"uid":61882,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-11T03:52:33.000Z","msg":"呢份變相係醫護界既投名狀<br />\n尤其係做街客生意既<br />\n就睇吓無簽嗰堆之後會點<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-11T04:00:37.000Z","msg":"係驚簽咗嗰班俾藍絲騷擾"},"citedBy":0,"replyTime":"2019-08-11T04:02:50.000Z","msg":"傻豬黎既<br />\n越多人簽<br />\n就越安全"},{"pid":"b4839f96dce969e841788d131bde70dfbb06fdaa","tid":1439050,"uid":293691,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:06:27.000Z","msg":"721查成點？<br />\n721黑警去晒邊？<br />\n最近多區有示威又處理到？<br />\n幾時提堂？"},{"pid":"d5eb5feace34a0be068b00d0e7d661131de24b14","tid":1439050,"uid":134508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:06:40.000Z","msg":"push"},{"pid":"62c7d587cbe3fe2253806372b648c26bdbc89dd1","tid":1439050,"uid":134508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:07:14.000Z","msg":"push"},{"pid":"7448e3954d921cda211d1af31aa648540dd35dd9","tid":1439050,"uid":134508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:08:21.000Z","msg":"<img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"f0f1e874f3a0778f68b6752ac7c833f952abca6f","tid":1439050,"uid":174541,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:08:55.000Z","msg":"想搞<span style=\"font-size: xx-large;\"><span style=\"color: red;\"><strong>快閃連儂牆</strong></span></span>，有興趣可以入黎一齊傾<br />\n<br />\n連儂場!進!化!<br />\n<a href=\"https://lih.kg/1433384\" target=\"_blank\">https://lih.kg/1433384</a>"},{"pid":"02d3f82a0052198320fdddddd3cfd3c0613dffe8","tid":1439050,"uid":41245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:09:39.000Z","msg":"<span style=\"font-size: large;\">針對警方無差別襲擊，標籤為<span style=\"color: red;\">國家恐怖主義武裝組織</span></span><br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">文宣核彈 - 為恐怖主義正名</span></span><br />\n<img src=\"https://na.cx/i/qMJqUur.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqMJqUur.jpg&h=36fb98e7&s={SIZE}\" /><br />\n恐怖主義標籤係諸國用嚟打壓異己嘅手法，「國家當局可用以將政敵或其他對手非法化，從而使國家武裝部隊可理直氣壯地打擊敵人」，包括支那對新疆嘅打壓，都係以打擊恐怖主義為名，效果顯著。若果我地為警隊嘅恐怖主義正名，絕對係致命打擊警隊嘅合法性同認受性嘅方法。<br />\n<span style=\"color: orange;\">佢標籤我地做港獨，我地標籤返佢做「國家恐怖主義份子」 正名標籤警方為非法嘅武裝組織</span><br />\n<a href=\"https://lih.kg/1426058\" target=\"_blank\">https://lih.kg/1426058</a><br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">無差別襲擊製造恐怖氣氛絕對已經係恐怖主義！我地係嘅係要為警隊嘅行為正名！</span></span><br />\n<span style=\"color: orange;\">警隊失控無差別襲擊，係屬於國家恐怖主義嘅行為，已經超越「過度暴力」、「濫捕」同「濫用暴力」，依啲字眼淡化佢嘅「拐帶」、「恐怖襲擊」等非法行為，警隊嘅行為喺好多國家已經係可以定義為失去合法性啲武裝組織。<br />\n而且加上721恐襲同打後嘅黑警合作，有理由相信依個恐怖主義組織係跨越明同暗。現時警察喺民間嘅認受性極低，執法行動已變質，失去合法地執行職務嘅能力，街坊見到警察嘅武裝會產生恐懼感。恐怖主義管治已引起社會及國際極度不安。</span><br />\n<img src=\"https://scontent.fool1-1.fna.fbcdn.net/v/t1.0-9/fr/cp0/e15/q65/67630995_110432746967840_2331413204384612352_o.jpg?_nc_cat=107&amp;efg=eyJpIjoidCJ9&amp;_nc_oc=AQl4L1bx4RYkXXmGjLvLvV0mieI9WjtsALdVP9McHQyfw-djgsY6ZSsf-1vl88RayEY&amp;_nc_ht=scontent.fool1-1.fna&amp;oh=58b06b4db0bdb4fb6b665e75af38d026&amp;oe=5DD55B02\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fscontent.fool1-1.fna.fbcdn.net%2Fv%2Ft1.0-9%2Ffr%2Fcp0%2Fe15%2Fq65%2F67630995_110432746967840_2331413204384612352_o.jpg%3F_nc_cat%3D107%26efg%3DeyJpIjoidCJ9%26_nc_oc%3DAQl4L1bx4RYkXXmGjLvLvV0mieI9WjtsALdVP9McHQyfw-djgsY6ZSsf-1vl88RayEY%26_nc_ht%3Dscontent.fool1-1.fna%26oh%3D58b06b4db0bdb4fb6b665e75af38d026%26oe%3D5DD55B02&h=2d15fa1a&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">無差別化武襲擊！！</span></span><br />\n<span style=\"color: orange;\">[過期催淚彈][有圖] 毒到連眼都起水泡！！！！！麻煩全世界前線中線後線街坊啊婆啊伯！！戴靚少少既Gear唔該！！！！！</span><br />\n<a href=\"https://lih.kg/1436725\" data-auto-link target=\"_blank\">https://lih.kg/1436725</a><br />\n<br />\n<span style=\"font-size: x-large;\">認同請聯署請分享</span><br />\n<a href=\"https://petitions.whitehouse.gov/petition/officially-recognize-hong-kong-police-force-hkpf-led-commissioner-stephen-lo-wai-chung-terrorist-organization\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fofficially-recognize-hong-kong-police-force-hkpf-led-commissioner-stephen-lo-wai-chung-terrorist-organization&d=sJhP54gyZlpQHD%2BOhJ68swmnwACYIcySctyK7icvN2A%3D&h=3cde3ecb\" data-auto-link target=\"_blank\">https://petitions.whitehouse.gov/petition/officially-recognize-hong-kong-police-force-hkpf-led-commissioner-stephen-lo-wai-chung-terrorist-organization</a><br />\n已有<span style=\"color: orange;\">45,505</span>/100,000個簽名（11 Aug 2019 at 12:09）<br />\n［白宮聯署］香港警察為恐怖組織<br />\n<a href=\"https://lih.kg/1427701\" target=\"_blank\">https://lih.kg/1427701</a><br />\n<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">警黑合作 恐怖治國<br />\n警察本色 恐怖組織</span></span><br />\n<span style=\"font-size: large;\"><span style=\"color: orange;\">槍炮化武 無差別襲擊<br />\n警黑勾結 武裝巴結<br />\nHKPF IS STATE TERRORIST!<br />\nNO STATE TERRORISM!<br />\nNO INDISCRIMINATE ATTACK!</span></span><br />\n<br />\n821守衛香港 反警黑恐怖治國 反恐大遊行/集會（未定）<br />\n821 - 元朗恐襲紀念日<br />\n<a href=\"https://lih.kg/1442294\" data-auto-link target=\"_blank\">https://lih.kg/1442294</a>"},{"pid":"200b3725988cb9623d3a43a2a746814fed2eabf7","tid":1439050,"uid":65074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:11:47.000Z","msg":"推"},{"pid":"acd893ce7bf1363f88b5501ee1279734d71113c9","tid":1439050,"uid":162910,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:16:28.000Z","msg":"推"},{"pid":"ce81cbc53cc47dd8c2444aeeb91051e077ddc3f4","tid":1439050,"uid":36494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:19:09.000Z","msg":"Push"},{"pid":"5a6a064b6a99c540e278506e1b654263d3c020b5","tid":1439050,"uid":134508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:29:35.000Z","msg":"push"},{"pid":"490edee18974a909db8b7f4f2bb47af258859ea6","tid":1439050,"uid":134508,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T04:30:23.000Z","msg":"push"},{"pid":"bc518d7a63313ad34f58a89f407b19aee48f183f","tid":1439050,"uid":36494,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:05:01.000Z","msg":"Push"},{"pid":"40d67415bfbb218a1a97c0283d0f28a2914e29f6","tid":1439050,"uid":70685,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-11T05:09:01.000Z","msg":"push"},{"pid":"2894ce15ef9aff6d5baa82c5df588013bdfee7f4","tid":1439050,"uid":36088,"like":0,"dislike":0,"scor