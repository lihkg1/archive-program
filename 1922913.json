A%2F%2Fna.cx%2Fi%2FNuHVJus.png&h=b2cd80c9&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/69CFGrn.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F69CFGrn.png&h=e589a7ac&s={SIZE}\" /><br />\n<br />\n老鳳一開po，所有食花生的人便都看著他笑，有的叫道，「老鳳，你今日又殺咗幾多隻狗？」他不回答，自言自語，「大家睇住啦，分化狗永遠唔撚敢入以下嘅post反駁老鳳，佢地真係支共主力」，便開多個po屈班人做分化狗當駁咗。他們又故意的高聲嚷道，「你一定又係度推人去死啦！」老鳳睜大眼睛說，「我係提倡緊全民勇武&hellip;&hellip;」「全民勇武？日日見你係啲po度叫人打狗殺狗，但係有行動就唔見你岀手，全民勇武唔包你自己？」老鳳便漲紅了臉，額上的青筋條條綻出，爭辯道，「提倡全民勇武，不算是推人去死&hellip;&hellip;只係我無資格帶頭，無話過唔喺後面玩狙&hellip;&hellip;抗爭者的事，能算是推人去死麼」接連便是難懂的話，甚麼「有我係度隻狗死硬」，甚麼「捷克嘅係scorpion非常好用嘅槍」之類，引得眾人都哄笑起來，連登内外充滿了快活的空氣。<br />\n<br />\n淫書豪滾出美國<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/fgCcnS\" data-auto-link target=\"_blank\">https://lih.kg/fgCcnS</a>"},{"pid":"8b9be0f04d5d35d12fa4318054799698b6b77b24","tid":1922913,"uid":48234,"like":0,"dislike":0,"score":0,"quote":{"pid":"1e648fe3b7879fd044f9df1b5d2e6970cbdd0448","tid":1922913,"uid":333283,"like":1,"dislike":0,"score":1,"quote":{"pid":"c04a72860cabd35a15427d5b1cc0a07ccaccc42f","tid":1922913,"uid":48234,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-03-12T23:32:37.000Z","msg":"政府啱啱好全面復工兩星期<br />\n如果政府都爆嘅，賤務處最大機會爆<br />\n因為蚑那冠狀病毒最鍾意殺蚑那狗/藍屍<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-03-18T13:03:46.000Z","msg":"<img src=\"https://na.cx/i/YYTeeA5.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FYYTeeA5.png&h=02956be2&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/NuHVJus.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNuHVJus.png&h=b2cd80c9&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/69CFGrn.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F69CFGrn.png&h=e589a7ac&s={SIZE}\" /><br />\n<br />\n老鳳一開po，所有食花生的人便都看著他笑，有的叫道，「老鳳，你今日又殺咗幾多隻狗？」他不回答，自言自語，「大家睇住啦，分化狗永遠唔撚敢入以下嘅post反駁老鳳，佢地真係支共主力」，便開多個po屈班人做分化狗當駁咗。他們又故意的高聲嚷道，「你一定又係度推人去死啦！」老鳳睜大眼睛說，「我係提倡緊全民勇武&hellip;&he