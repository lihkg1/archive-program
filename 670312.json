"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3382afaba1984c19c2daa5d703ad9a68577e4b6a","tid":670312,"uid":28007,"like":1,"dislike":5,"score":-4,"quote":{"pid":"39d0a09a58d5da99528e621b0bf5b7263d91ac2f","tid":670312,"uid":88862,"like":0,"dislike":1,"score":-1,"quote":{"pid":"e8fc3eed2ede817c7fed9799a8888cd5f1abda27","tid":670312,"uid":28007,"like":1,"dislike":9,"score":-8,"quote":{"pid":"31547ad49b156fae117aacf87310cec9f45fd824","tid":670312,"uid":88862,"like":8,"dislike":0,"score":8,"citedBy":1,"replyTime":"2018-05-19T13:56:39.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2018-05-19T14:07:20.000Z","msg":"咁係你唔掂 唔好拉埋其他人黎講 出面好多好勁既老細<br />\n三樣做曬既都仲有 <br />\n唔好睇少一間鋪仔 <br />\n佢地既潛力大到你唔信<br />\n可以將一間鋪仔既威力發揮到最大 <br />\n先叫自己做老細啦<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-19T14:26:29.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-05-19T14:48:28.000Z","msg":"我都有錯 講講下起曬鋼<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n唔好意思"},{"pid":"b644867a2982dc35cd0cda78b297b5cb117eef0c","tid":670312,"uid":19496,"like":6,"dislike":1,"score":5,"citedBy":1,"replyTime":"2018-05-19T14:49:11.000Z","msg":"茶記一定係水吧最大，你見有奶茶王，鴛鴦王比賽，但就冇炒飯王，炒麵王，炒河王就知，因為炒鑊唔得，賣茶水都仲賣埋三文治、餐蛋麵就可以做得住"},{"pid":"f479cccece7a325234becf6fc7734327b076f591","tid":670312,"uid":9082,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-19T14:56:06.000Z","msg":"此回覆已被刪除"},{"pid":"a5c4ce64a22f81a50e0e3bdb12e3933af5422d7d","tid":670312,"uid":9082,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-19T14:58:34.000Z","msg":"此回覆已被刪除"},{"pid":"aed78e843575e925ad46ba0228842c6e8b3ea530","tid":670312,"uid":18167,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-05-19T14:59:33.000Z","msg":"我去到邊度做都好，個個都怕左我<br />\n<br />\n利申，做過樂融雅敍<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"889f75a2ec2b4a0bf6d6eda5f91e2d7b9e029983","tid":670312,"uid":20625,"like":1,"dislike":0,"score":1,"quote":{"pid":"2972286b8f7713f2b7ee88214ba0c151f85843f0","tid":670312,"uid":53673,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2018-05-19T11:27:16.000Z","msg":"<blockquote>梗係<div style=\"text-align: center;\"><span style=\"font-size: xx-large;\"><span style=\"color: red;\">洗碗碟呀姐</span></span></div>最大啦...上至老大廚,下至樓面收銀都唔敢得罪佢...佢唔返工...你死入去頂佢位洗晒佢呀!<br />\n<br />\n利申:接觸過飲食行業</blockquote><br />\n而家有得outsource<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-19T15:05:57.000Z","msg":"佢臨時唔番你outsource補唔補得切<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"2fba9e5dbf3ee5ba8da82dc9ce3a0aed0baaa1c9","tid":670312,"uid":99124,"like":4,"dislike":2,"score":2,"citedBy":0,"replyTime":"2018-05-19T15:23:14.000Z","msg":"最大洗碗 - 冇人願做，洗碗射波就最麻煩<br />\n第二水位 - 因為人手唔多，唔係特別大間都係得一條友，但正常老闆都會識小小水位野<br />\n第三火位 - 成間鋪既出品，3 - 5個既班底有時一個半個射波都頂得住<br />\n第四收銀 - 通常同老闆有d關係<br />\n第五老闆 - 以上既人老闆都唔敢得罪<br />\n袋底泥樓面 - 唔岩就換，駁嘴就換，係成間鋪既發洩工具"},{"pid":"3118ec6ddb1de0c5221e20db60bca2377311e215","tid":670312,"uid":2950,"like":1,"dislike":0,"score":1,"quote":{"pid":"aed78e843575e925ad46ba0228842c6e8b3ea530","tid":670312,"uid":18167,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2018-05-19T14:59:33.000Z","msg":"我去到邊度做都好，個個都怕左我<br />\n<br />\n利申，做過樂融雅敍<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-19T15:30:58.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" />"},{"pid":"00c0b1dc76aae95ff98a0a097bf6e045e5562043","tid":670312,"uid":40336,"like":0,"dislike":0,"score":0,"quote":{"pid":"8b40773ab5459b5666de455ddb263ae2f4c9f928","tid":670312,"uid":103339,"like":19,"dislike":1,"score":18,"citedBy":2,"replyTime":"2018-05-19T13:25:40.000Z","msg":"如果拍到條片講茶記勾心鬥角都幾過癮<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-19T15:53:11.000Z","msg":"18樓C座<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e1734ffaaf64212e81be61f1d5092cab5a769cfa","tid":670312,"uid":136252,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-19T15:56:57.000Z","msg":"水吧位先好做"},{"pid":"7989272c9476901cade60ea70a3f0cea830bd2e1","tid":670312,"uid":40965,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-19T16:06:44.000Z","msg":"茶記唔知<br />\n但大餐廳一定係洗碗<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"f95381def67862e905b05e2662da91491b7ca1e2","tid":670312,"uid":1654,"like":0,"dislike":0,"score":0,"quote":{"pid":"282a818a6a811934d35418cf109e6587d7dda994","tid":670312,"uid":69597,"like":694,"dislike":13,"score":681,"citedBy":4,"replyTime":"2018-05-19T09:25:49.000Z","msg":"茶水位通常係老闆心腹，好多時廚房有幾個雜工加個廚，但水吧永遠只係得一個水吧佬，冇人會監住佢做嘢，反而好多時老闆出咗外面，都會叫水吧佬同佢匯報<br />\n<br />\n再睇下大部份茶記嘅水吧都係位於廚房同舖面之間，假如廚房失火，水吧佬可以跑出樓面逃生，如果有黑社會入茶記搵人追數/劈友，水吧佬又可以入廚房經後門著草，地理完全係有絕對優勢<br />\n<br />\n唔單止咁，你再睇下待遇，廚房個個對住個火爐熱撚到仆街，收銀對住門口位冬冷夏熱，樓面做到隻狗咁，連坐嘅機會都冇，但水吧佬偏偏就可以偏飲嘢邊做<br />\n<br />\n總結：唔計老闆，水吧佬就係權力嘅頂峰"},"citedBy":0,"replyTime":"2018-05-19T16:31:07.000Z","msg":"新潮文<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"e9fe1e42fa480633e537432359b9dec5325d6bc6","tid":670312,"uid":134474,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-05-19T16:49:47.000Z","msg":"樓面賤過地底泥"},{"pid":"c399a52546c8c067a9a49c94c30c20ae49112644","tid":670312,"uid":2020,"like":0,"dislike":0,"score":0,"quote":{"pid":"17a0f58d0af2690f50124c9799a6dd768219e22a","tid":670312,"uid":28007,"like":14,"dislike":1,"score":13,"quote":{"pid":"c7964ec983bce467c86c090751d761148950a528","tid":670312,"uid":88862,"like":17,"dislike":1,"score":16,"quote":{"pid":"266a7f69083cac73e2b2ab5c22f00ae35d0d8b99","tid":670312,"uid":28007,"like":9,"dislike":2,"score":7,"citedBy":1,"replyTime":"2018-05-19T13:04:40.000Z","msg":"你係老闆？咁你都幾&hellip;<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n開餐飲第一條首則 老閪都唔可以比廚房話曬事<br />\n簡單啲講句 唔識廚房真係搵黎死<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-05-19T13:09:34.000Z","msg":"此回覆已被刪除"},"citedBy":2,"replyTime":"2018-05-19T13:44:57.000Z","msg":"你唔應該問我開過茶記未 你應該問自己識唔識做老細<br />\n邊有老細會比員工揸住個春袋撚<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-05-19T17:02:54.000Z","msg":"師兄 講就易 你估而家廚房佬易請咩 重要係炒得出好食既<br />\n<br />\n廚房已經少人入行 基本上黎黎去去果區都係同一班師傅黎<br />\n<br />\n除非你自己手握秘方 否則你一間茶記有無生意個廚房佬係重點"},{"pid":"e0337857c760f281e5ba7fb5866f25e0f3766130","tid":670312,"uid":38041,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-05-20T06:07:02.000Z","msg":"屌咁多篇潮文 有春用咩<br />\n等小妹講下五德終始說啦<br />\n即係相生相剋 冇話咩權力核心<br />\n<br />\n金 老闆剋收銀 屌尻佢收少錢<br />\n木 收銀剋樓面 屌尻佢落錯單<br />\n水 樓面剋水吧 屌尻佢冇得飲<br />\n火 水吧剋廚房 屌尻佢做唔嚟<br />\n土 廚房剋老闆 屌尻佢你嚟做"}]}