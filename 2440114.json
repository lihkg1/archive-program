ormal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"252650fbf9d7423e42adf92ac87dfc60f45807b9","tid":2440114,"uid":254196,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-09T17:24:37.000Z","msg":"殘體拉"},{"pid":"fa646e7f55df1a9312debd084ca2f725e30b06b2","tid":2440114,"uid":168169,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2021-03-09T17:29:34.000Z","msg":"同異性相處嗰陣<br />\n開始著重相處嗰陣講完嘢對方嘅反應（對方識唔識笑）<br />\n有無共同嘅興趣話題<br />\n而唔再睇樣睇身材<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"553d692852bbf6f2b7d5ba93a7f994c02aeeaa39","tid":2440114,"uid":370016,"like":0,"dislike":1,"score":-1,"quote":{"pid":"428741f7231d2ceeae9951ffb9e0746ffe4b96c8","tid":2440114,"uid":85659,"like":2,"dislike":2,"score":0,"citedBy":2,"replyTime":"2021-03-09T17:22:49.000Z","msg":"男女都想屌既時候"},"citedBy":0,"replyTime":"2021-03-09T17:30:15.000Z","msg":"<img src=\"/assets/faces/dog/touch.gif\" class=\"hkgmoji\" />"},{"pid":"d38db199148dfb279c536f90bd1189219b8d8132","tid":2440114,"uid":34607,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2021-03-09T18:06:07.000Z","msg":"當你發現自己玩Online Game既時候玩一陣就覺得無耐性無時間去升Lv，寧願用啲時間去訓多陣覺<br />\n<br />\n當你認識到真正長大社會係咩一回事既時候，你唔再覺得自己可以改變世界、心想事成，寧願留返啖氣暖肚默默生存<br />\n<br />\n當你買嘢食嘢唔再需要睇價錢牌直接去馬，唔再係食$4撈麵死慳死抵過活為咗一件想買好耐既嘢的時候；不過，呢一刻既你，永遠都重拾當初的快樂<br />\n<br />\n當你醒覺生命健康可貴既時候，身邊既人可能已經離開得七七八八、頭髮亦是一樣<br />\n<br />\n<br />\n成長？<br />\n早啲訓啦，聽日又要準時起身返工返學啦<br />\n（無串既意思）"},{"pid":"47ba6ba3578d17f1d3981db6726b028032fab7a8","tid":2440114,"uid":393890,"like":0,"dislike":1,"score":-1,"quote":{"pid":"428741f7231d2ceeae9951ffb9e0746ffe4b96c8","tid":2440114,"uid":85659,"like":2,"dislike":2,"score":0,"citedBy":2,"replyTime":"2021-03-09T17:22:49.000Z","msg":"男女都想屌既時候"},"citedBy":0,"replyTime":"2021-03-10T00:14:11.000Z","msg":"真"},{"pid":"4dcfe3418ff643983a3a34aeb1f19840ce9a2642","tid":2440114,"uid":393890,"like":0,"dislike":1,"score":-1,"quote":{"pid":"a2e4b0066a27c076cd563a5c72f024296559f01f","tid":2440114,"uid":123282,"like":3,"dislike":1,"score"