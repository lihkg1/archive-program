ke":0,"dislike":0,"score":0,"quote":{"pid":"f34e5bed2beedffccc9212fe8b96a6ff69a3d6bf","tid":573541,"uid":7550,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-26T14:50:51.000Z","msg":"我好撚驚死<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n唔敢諗"},"citedBy":1,"replyTime":"2018-02-26T14:54:15.000Z","msg":"我自己就一時時<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n身排身體唔係咁好，有時諗又覺得無乜嘢，有時又會不安"},"citedBy":0,"replyTime":"2018-02-26T14:55:29.000Z","msg":"近*"},{"pid":"247897bd5b86f70d4a3115f2842c5ffdf1e59817","tid":573541,"uid":149978,"like":0,"dislike":0,"score":0,"quote":{"pid":"1dd5b9be2c943d00095dff79faa0abb38b12de06","tid":573541,"uid":33885,"like":0,"dislike":0,"score":0,"quote":{"pid":"e8e2c13d0251aa0e15763cbec032ff2cd473a726","tid":573541,"uid":172948,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-02-26T14:52:07.000Z","msg":"當你年紀越大<br />\n你就有時候會諗 離死亡又近一步<br />\n越諗你就越怕  簡單D黎講係怕痛同辛苦"},"citedBy":2,"replyTime":"2018-02-26T14:55:18.000Z","msg":"主要係 <br />\n但死後乜都無哂都幾得人驚"},"citedBy":1,"replyTime":"2018-02-26T15:03:30.000Z","msg":"死後的你 等於 母親體內懷孕前的你，<br />\n有咩好驚？<br />\n<br />\n仲有，死後的野，係無證據和未知。無證據證明，死後乜都冇，亦無證據證明靈魂不死。不過，有證據證明物質和能量是守恒不滅。"},{"pid":"aff82a53e5797c8f28708729da3b30b8ddebdf71","tid":573541,"uid":94465,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-02-26T15:08:06.000Z","msg":"好驚睇住身邊既人一個又一個死<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n反而自己冇乜所謂<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 只係唔想屋企人因為自己而唔開心"}]}