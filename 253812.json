db2941&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/27/011526_46b465bab0a3b3381d880343f57ff660.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F011526_46b465bab0a3b3381d880343f57ff660.jpg&h=fa8cc963&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/27/011528_24a11a79fe413bdd91f83bb869498075.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F011528_24a11a79fe413bdd91f83bb869498075.jpg&h=44ec8826&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/27/011546_b07b14abfcf415c2a701207cffe05235.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F011546_b07b14abfcf415c2a701207cffe05235.jpg&h=15ab312d&s={SIZE}\" />"},{"pid":"9b5a705b154179fde065f9856d3424e83e30c0a6","tid":253812,"uid":113045,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2017-05-26T17:40:50.000Z","msg":"<blockquote><img src=\"http://img.eservice-hk.net/upload/2017/05/27/011521_4fe9ca76242f5e742eb0845aaffff801.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F011521_4fe9ca76242f5e742eb0845aaffff801.jpg&h=0c7bf3fa&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/27/011523_1f480c3e9fd0d26f31476a1e2e765891.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F011523_1f480c3e9fd0d26f31476a1e2e765891.jpg&h=f16b8ed7&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/27/011524_f3653f662f6c9e9cf515439f370608f8.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F011524_f3653f662f6c9e9cf515439f370608f8.jpg&h=a1db2941&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/27/011526_46b465bab0a3b3381d880343f57ff660.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F011526_46b465bab0a3b3381d880343f57ff660.jpg&h=fa8cc963&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/27/011528_24a11a79fe413bdd91f83bb869498075.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F011528_24a11a79fe413bdd91f83bb869498075.jpg&h=44ec8826&s={SIZE}\" /><img src=\"http://img.eservice-hk.net/upload/2017/05/27/011546_b07b14abfcf415c2a701207cffe05235.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F011546_b07b14abfcf415c2a701207cffe05235.jpg&h=15ab312d&s={SIZE}\" /></blockquote><br />\nPlabo<br />\n心齋橋好似有3間，食咗半熟芝士蛋糕（蘋果味同香蕉朱古力）<br />\n<br />\nHiro Kiyamachi<br />\n京都一間幾出名既燒肉，個人勁推覺得有必要試一次，不過偏貴同好多人，推佢個醃肉（唔記得咩名）<br />\n<br />\nじねん<br />\n牛油饅魚壽司，鍾意食饅魚同菠蘿油應該好岩食<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <br />\n基於禮貌有叫其他壽司，還好冇特別<br />\n另外，一開始去錯咗隔離一間食shabu shabu, 因為招牌好似，但意外發現臨尾個手打烏冬不得了<br />\n<br />\n河童拉麵<br />\n見到d叉燒都知咩事，肥叉燒同豚角不解釋了<br />\n<br />\nSteakland<br />\n神戶一間幾出名食牛扒，開11點就到左唔洗點排，一開門坐滿晒，師傅即場表演咁煎牛扒，有個特價午餐好抵屌，當然貴野質素會更好（利申：試左一個特價餐一個貴餐）<br />\n<br />\n元喜神拉麵（冇圖）<br />\n奈良，重點係個雞白湯，唔好叫錯，骨膠原充足<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n<br />\n利申：我專食肥野，肥左唔好怪我<br />\n<br />\n來緊會再去關西，有新發現再分享<br />\n<br />\nBetween, 鍾意靚景可以花時間去白濱<br />\n<img src=\"http://img.eservice-hk.net/upload/2017/05/27/014048_261b72ef5e34699d70fe21f6bf58e27f.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F05%2F27%2F014048_261b72ef5e34699d70fe21f6bf58e27f.jpg&h=597bd241&s={SIZE}\" />"},{"pid":"51b1322cf3b6bd272a653cc243562b1875f27530","tid":253812,"uid":60531,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T08:02:51.000Z","msg":"<blockquote><blockquote><img src=\"http://img.eservice-hk.net/upload/2017/05/27/011521_4fe9ca76242f5