assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"0c5fd2a716f1e17a9a100c1977caa56ddb1606d4","tid":1525833,"uid":273854,"like":0,"dislike":0,"score":0,"quote":{"pid":"e427a224d0d6aa2ddecf8ec3e11c89816a21dcd3","tid":1525833,"uid":183060,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-01T03:12:18.000Z","msg":"如果一個示威者，見到另一個示威者有疑似槍既物體係身，然後做一D非常暴力行為例如丟汽油彈，係咪應該搶左佢身上懷疑危險品（例如槍枝）先呢？<br />\n<br />\n以防黑警查贓嫁禍比和平既示威者！"},"citedBy":1,"replyTime":"2019-09-01T03:56:54.000Z","msg":"小小意見<br />\n如果一個良好市民<br />\n見到有暴徒縱火或其他極危險行為<br />\n用合適武力去阻止佢<br />\n係英勇行為<br />\n<br />\n如果暴徒突然示槍<br />\n係保護市民情況下<br />\n搶去暴徒攻擊武器雖然危險<br />\n但係更為英勇<br />\n<br />\n如果暴徒打算使用槍械傷害市民<br />\n而市民制止時, 錯手, 或別無打法<br />\n迫於無奈要使用槍械即時制止暴徒反抗<br />\n亦係合理的<br />\n<br />\n<span style=\"color: red;\">如果事後發現暴徒係休班警員<br />\n我相信警方一定會高度讚揚制止罪行嘅市民<br />\n並為警隊剷除害群之馬</span><br />\n<br />\nBTW(<span style=\"color: red;\">未完全fact check)</span><br />\n好似警察同市民權力分別<br />\n係: 警察合法擁有槍械武器<br />\n同埋: 執法時使用合理武力<br />\n但對於因為要保障市民生命財產而使用武力方面<br />\n市民使用合理武力嘅權力, 應該係等同警察的。<br />\n<span style=\"color: red;\">即係, 警察使用槍械制止暴徒, 係同一般市民使用槍械制止暴徒, 法律責任應該是相同</span>"},{"pid":"aaad4251173c231c0fb7aec6039cd7765c09f927","tid":1525833,"uid":273854,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c5fd2a716f1e17a9a100c1977caa56ddb1606d4","tid":1525833,"uid":273854,"like":0,"dislike":0,"score":0,"quote":{"pid":"e427a224d0d6aa2ddecf8ec3e11c89816a21dcd3","tid":1525833,"uid":183060,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-01T03:12:18.000Z","msg":"如果一個示威者，見到另一個示威者有疑似槍既物體係身，然後做一D非常暴力行為例如丟汽油彈，係咪應該搶左佢身上懷疑危險品（例如槍枝）先呢？<br />\n<br />\n以防黑警查贓嫁禍比和平既示威者！"},"citedBy":1,"replyTime":"2019-09-01T03:56:54.000Z","msg":"小小意見<br />\n如果一個良好市民<br />\n見到有暴徒縱火或其他極危險行為<br />\n用合適武力去阻止佢<br />\n係英勇行為<br />\n<br />\n如果暴徒突然示槍<br />\n係保護市民情況下<br />\n搶去暴徒攻擊武器雖然危險<br />\n但係更為英勇<br />\n<br />\n如果暴徒打算使用槍械傷害市民<br />\n而市民制止時, 錯手, 或別無打法<br />\n迫於無奈要使用槍械即時制止暴徒反抗<br />\n亦係合理的<br />\n<br />\n<span style=\"color: red;\">如果事後發現暴徒係休班警員<br />\n我相信警方一定會高度讚揚制止罪行嘅市民<br />\n並為警隊剷除害群之馬</span><br />\n<br />\nBTW(<span style=\"color: red;\">未完全fact check)</span><br />\n好似警察同市民權力分別<br />\n係: 警察合法擁有槍械武器<br />\n同埋: 執法時使用合理武力<br />\n但對於因為要保障市民生命財產而使用武力方面<br />\n市民使用合理武力嘅權力, 應該係等同警察的。<br />\n<span style=\"color: red;\">即係, 警察使用槍械制止暴徒, 係同一般市民使用槍械制止暴徒, 法律責任應該是相同</span>"},"citedBy":0,"replyTime":"2019-09-01T04:01:20.000Z","msg":"BTW 最好要有人錄影住<br />\n暴徒當時有冇表身份<br />\n同埋<br />\n即使暴徒表白身份<br />\n亦不等同佢可以做明顯犯法行為<br />\n(例如縱火)"},{"pid":"323d35cf472649f6729a91ce1db833d306aa4418","tid":1525833,"uid":86674,"like":0,"dislike":0,"score":0,"quote":{"pid":"008f4bdba27a6a2a46bb719d71f0282f901423f4","tid":1525833,"uid":217275,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7fd2a2e33043aa5f99034f6dd82e84bc051d3dd","tid":1525833,"uid":86674,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-01T03:21:10.000Z","msg":"係，下次見到<br />\n要包抄佢地"},"citedBy":1,"replyTime":"2019-09-01T03:28:10.000Z","msg":"要求check槍"},"citedBy":1,"replyTime":"2019-09-01T04:53:19.000Z","msg":"唔洗check啦<br />\n圍到之後大家識做<br />\n<br />\n去就去到盡<br />\n9月1啦，呢個月好撚關鍵"},{"pid":"ab93ebf24d8dc5517cb5c1961d86257f8febb67c","tid":1525833,"uid":46933,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-01T05:01:46.000Z","msg":"佢如果掟緊汽油彈<br />\n應該即場射殺都ok<br />\n因為佢都殺緊人"},{"pid":"5b98df9fcea10d2c8a619ebf1f4ee99e01120018","tid":1525833,"uid":183060,"like":0,"dislike":0,"score":0,"quote":{"pid":"323d35cf472649f6729a91ce1db833d306aa4418","tid":1525833,"uid":86674,"like":0,"dislike":0,"score":0,"quote":{"pid":"008f4bdba27a6a2a46bb719d71f0282f901423f4","tid":1525833,"uid":217275,"like":0,"dislike":0,"score":0,"quote":{"pid":"a7fd2a2e33043aa5f99034f6dd82e84bc051d3dd","tid":1525833,"uid":86674,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-01T03:21:10.000Z","msg":"係，下次見到<br />\n要包抄佢地"},"citedBy":1,"replyTime":"2019-09-01T03:28:10.000Z","msg":"要求check槍"},"citedBy":1,"replyTime":"2019-09-01T04:53:19.000Z","msg":"唔洗check啦<br />\n圍到之後大家識做<br />\n<br />\n去就去到盡<br />\n9月1啦，呢個月好撚關鍵"