ssets/faces/pig/dance.gif\" class=\"hkgmoji\" />"},{"pid":"351a1cb7831f52c32a1b2ecedf6bbda0f8a1fdfa","tid":1538844,"uid":200532,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T08:04:27.000Z","msg":"9月8<br />\n捏春袋"},{"pid":"07ca33dfc34f18d1396eea6f9d3718b1ad94d4a8","tid":1538844,"uid":212182,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T08:04:39.000Z","msg":"你地係咪仲以為呢個政府值得我地信任？仲信政府既承諾？<br />\n<a href=\"https://lih.kg/1538706\" data-auto-link target=\"_blank\">https://lih.kg/1538706</a><br />\n要記住，香港唔係一個地方，係住呢度既人！我地先係香港既核心，香港既主人！無左我地，政府根本唔係一回事！點解要比依個草菅人命既政府拖住鼻子走！"},{"pid":"2b928b5610861fd69e3c506136ba28cfde2672ac","tid":1538844,"uid":200532,"like":0,"dislike":0,"score":0,"quote":{"pid":"07ca33dfc34f18d1396eea6f9d3718b1ad94d4a8","tid":1538844,"uid":212182,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T08:04:39.000Z","msg":"你地係咪仲以為呢個政府值得我地信任？仲信政府既承諾？<br />\n<a href=\"https://lih.kg/1538706\" data-auto-link target=\"_blank\">https://lih.kg/1538706</a><br />\n要記住，香港唔係一個地方，係住呢度既人！我地先係香港既核心，香港既主人！無左我地，政府根本唔係一回事！點解要比依個草菅人命既政府拖住鼻子走！"},"citedBy":0,"replyTime":"2019-09-04T08:05:08.000Z","msg":"exac7ly"},{"pid":"c9079fa37dcaa7929d6e2861882130a06bbbfe84","tid":1538844,"uid":200532,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T08:05:32.000Z","msg":"捏春袋呀捏春袋"},{"pid":"db2240cb5e46d7ad22c55f79d20a5e15cee57451","tid":1538844,"uid":72800,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-04T08:05:35.000Z","msg":"<img src=\"https://na.cx/i/xcgb58P.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fxcgb58P.gif&h=4c045c7d&s={SIZE}\" /><img src=\"https://na.cx/i/Ep8qq8P.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEp8qq8P.gif&h=b74f62eb&s={SIZE}\" /><br />\n<br />\n<span style=\"font-size: large;\"><span style=\"color: brown;\"><strong><em><div style=\"text-align: center;\">毋忘七烈 千一義 四眼 三十骨折 手腳筋<br />\n721元朗 811警暴 831車廂 雙肺 一裙<br />\n無數屈辱私刑 重傷昏迷<br />\n<br />\n撤回 定性 釋士 究警 普選</div></em></strong></span></span><br />\n<br />\n<div style=\"text-align: center;\"><span style=\"color: red;\">港共殺人政權企圖以<strong>錄音、撤回、學季開始</strong><br />\n轉移<strong><span style=\"font-size: x-large;\">太子地鐵傷亡、<br />\n六警壓脊椎休克 至今嚴重昏迷、<br />\n新屋嶺、民主人權法案</span></strong>事件焦點<br />\n醒呀大家 <img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /> <span style=\"font-size: xx-large;\">政府帶緊風向</span><br />\n背後繼續大清算 入獄 利刑 一年後被失蹤</span></div><br />\n<br />\n<pre><code data-type=\"\">暗黑兵法劇本 出沒注意：\n\n沒收gear 未來兩星期大量武警喬裝示威者 嫁禍衝擊\n內部分化示威者、\n酷刑凌虐威嚇被捕人士、\n邊緣打壓香港 渲染港獨 阻抗爭之風蔓延內陸、\n假新聞、擺拍、編輯、洗腦文宣製造風向 污名化運動、\n暴力鎮壓 拘捕 扣留 私刑 企圖瓦解前線、\n文宣 抹黑 嫁禍 插贜 示威者、\n暗殺 第一滴血 企圖逆轉民意 國際譴責、\n市民絕望噤聲 憤怒冷卻、\n中立派 賺錢派 政治疲勞、\n鼓吹經濟下滑風向 富豪商家屈服 加速瓦解、\n學季始開，拖延 分散 擊破、\n白色恐怖、清除異己、染紅香港\n\n拖字訣 雨傘結局 ⋯</code></pre><br />\n<br />\n袋住先 放風降溫<br />\n大追捕 清算 正式開始<br />\n<br />\n<div style=\"text-align: center;\"><span style=\"color: blue;\"><strong>這不只是反修例活動<br />\n這是屬於香港人的<span style=\"font-size: xx-large;\">時代革命</span></strong></span></div>"},{"pid":"22e7b5c270288a62692bac59a1c8397e71eece8a","tid":1538844,"uid":296848,"like":0,"dislike":0,"score":0,"quote":{"pid":"5ca1645bd37ed79148ad6994bd2a4f6683cd8bfe","tid":1538844,"uid":19353,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T08:03:52.000Z","msg":"如果美國收貨 我地就仆街了"},"citedBy":1,"replyTime":"2019-09-04T08:05:39.000Z","msg":"要同美國果邊文宣"},{"pid":"f0711c4f7f16a85bafc9d489d516abf97695afb1","tid":1538844,"uid":200532,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9079fa37dcaa7929d6e2861882130a06bbbfe84","tid":1538844,"uid":200532,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-04T08:05:32.000Z","msg":"捏春袋呀捏春袋"},"citedBy":0,"replyTime":"2019-09-04T08:05:48.000Z","msg":"9月8呀9月8"},{"pid":"f98e6dd4199afa4ea3e7244b0b922e2900a2ec6e","tid":1538844,"uid":200532,"like":0,"dislike":0,"score":0,"quote":{"pid":"22e7b5c270288a62692bac59a1c8397e71eece8a","tid":1538844,"uid":296848,"like":0,"dislike":0,"score":0,"quote":{"p