/>"},{"pid":"1c8b181b3758c59553dfd3a5ddc0793c4dc5dfd2","tid":1159881,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-18T06:49:43.000Z","msg":"應該好多人<img src=\"/assets/faces/lm2/dead.gif\" class=\"hkgmoji\" />"},{"pid":"16d61d66aad12b407e446950acec4c22431cc1f3","tid":1159881,"uid":28195,"like":28,"dislike":4,"score":24,"quote":{"pid":"9d61ef8dca086fc84d1a91fcc36d61864942f97a","tid":1159881,"uid":177219,"like":5,"dislike":4,"score":1,"citedBy":4,"replyTime":"2019-05-18T06:24:50.000Z","msg":"其實呢d算唔算賊贓"},"citedBy":2,"replyTime":"2019-05-18T07:40:40.000Z","msg":"支那人小學雞同廢老最中意咁講"},{"pid":"21893106999a8fd174545427e36b9c3d284836f3","tid":1159881,"uid":13343,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-05-18T07:53:47.000Z","msg":"條例好在未過<br />\n如果唔係成團人加展品直運強國<br />\n話你販運文物"},{"pid":"ea8fedbf17b6694b57f9da59b444ef8958dbd0f1","tid":1159881,"uid":219244,"like":39,"dislike":2,"score":37,"quote":{"pid":"16d61d66aad12b407e446950acec4c22431cc1f3","tid":1159881,"uid":28195,"like":28,"dislike":4,"score":24,"quote":{"pid":"9d61ef8dca086fc84d1a91fcc36d61864942f97a","tid":1159881,"uid":177219,"like":5,"dislike":4,"score":1,"citedBy":4,"replyTime":"2019-05-18T06:24:50.000Z","msg":"其實呢d算唔算賊贓"},"citedBy":2,"replyTime":"2019-05-18T07:40:40.000Z","msg":"支那人小學雞同廢老最中意咁講"},"citedBy":1,"replyTime":"2019-05-18T09:01:08.000Z","msg":"博物館攞到藏品嘅方法有好多<br />\n有好多係佢哋收購返嚟或者人哋捐贈所得<br />\n仲有係資助考古活動時發掘所得<br />\n<br />\n無可否認有啲文物嘅取得途徑唔係咁正當<br />\n其實唔止強國追討文物，希臘、埃及嗰啲都有追<br />\n但係歷史恩怨呢啲嘢唔係三言兩語可以講得清<br />\n<br />\n於公營博物館嚟講<br />\n呢個更加多係政府與政府之間嘅關係<br />\n佢哋做嘅嘢只係守住呢啲文物<br />\n有風險嘅就唔好借出去"},{"pid":"8fffaac6560c87b92ddd0503810e2066fc6878c0","tid":1159881,"uid":249885,"like":1,"dislike":14,"score":-13,"citedBy":0,"replyTime":"2019-05-18T09:08:20.000Z","msg":"點解會喺沙田呢啲cheap 地方show 出嚟"},{"pid":"878f89c2d870550e8e3158237fae4c8c6f4a4bb3","tid":1159881,"uid":28765,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-18T09:15:16.000Z","msg":"正 得閒去睇"},{"pid":"d744bc8291329c11a