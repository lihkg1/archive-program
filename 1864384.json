ji\" />"},{"pid":"c27c60f09c33acc9960b5d63b2b4e31b3dae35ed","tid":1864384,"uid":34872,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T05:44:39.000Z","msg":"閪佢面就有"},{"pid":"f674ca5f8c2dc9dd30970ed3e606b1b38fc5302a","tid":1864384,"uid":85180,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-06T11:04:47.000Z","msg":"個個生而平等，點解唔屌得"},{"pid":"83139674ac0a2b68672dd9f8378441f1845dfc71","tid":1864384,"uid":347977,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T11:14:50.000Z","msg":"[銀行撚入] 台資銀行係黃？<br />\n<a href=\"https://lih.kg/1862282\" data-auto-link target=\"_blank\">https://lih.kg/1862282</a><br />\n<br />\n幫推"},{"pid":"b468801dc4e091dc50c589c16180bc1417df8ebd","tid":1864384,"uid":120093,"like":0,"dislike":0,"score":0,"quote":{"pid":"f674ca5f8c2dc9dd30970ed3e606b1b38fc5302a","tid":1864384,"uid":85180,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-06T11:04:47.000Z","msg":"個個生而平等，點解唔屌得"},"citedBy":0,"replyTime":"2020-02-06T11:27:50.000Z","msg":"你講得岩"},{"pid":"5105336c8cf94e463175f170689cf30b724599cb","tid":1864384,"uid":120093,"like":0,"dislike":0,"score":0,"quote":{"pid":"17e8a1728763578fe89d45f005a133e43eb91c0e","tid":1864384,"uid":128863,"like":1,"dislike":0,"score":1,"quote":{"pid":"e5bdcc678ca0ceba8a7936c9b2e2c84e1064429b","tid":1864384,"uid":120093,"like":0,"dislike":0,"score":0,"quote":{"pid":"879bd09d7213c91fe97f85984d9c7c0c0aa36de4","tid":1864384,"uid":165377,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-06T01:00:21.000Z","msg":"發脾氣又冇<br />\n有試真心同佢講工作量唔合理同以我經驗一定做唔黎，果陣岩岩fg比左單做左幾年野都未必做到既野我跟<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n最後d job正常返"},"citedBy":2,"replyTime":"2020-02-06T01:09:56.000Z","msg":"我控制唔到自己情緒 好地地想講樣野都變到好激動好似嘈交咁"},"citedBy":1,"replyTime":"2020-02-06T05:10:53.000Z","msg":"有冇睇醫生"},"citedBy":0,"replyTime":"2020-02-06T11:33:31.000Z","msg":"無呀 驚貴"},{"pid":"3c7ef634ded5b5dfaae63a9d5a7f3972d827680a","tid":1864384,"uid":143321,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-02-06T11:49:58.000Z","msg":"上一份工試過有閪面個經理，但冇屌到出面<br />\n<br />\n個經理好多野都係又屌，唔係又屌，就算做完份job冇鑊氣，佢都會屌9 你做得唔好。平時交文件，佢又會屌9 你d 釘書釘個位置釘得唔好，吹毛求疵。傾野時諗多一陣佢講咩，就會屌9 你咁蠢唔L明。<br />\n<br />\n成條team 唔計佢有3 個人，3 個都係咁俾佢屌，所以我唔覺係自己問題。其他team head 有時都叫佢唔好咁屌9 d 細。<br />\n<br />\n有一次有個年中大job，佢又發癲。我開始頂唔順，開始閪佢面，見到面唔打招呼，交完文件就走唔解釋。當時心諗再頂唔住就陪錢走。慢慢佢覺得我好怪，叫左我入房，我就屌9 佢做人冇禮貌，d 野唔識又係度屌。攪到成team 冇晒mood，佢可能見到我d 語氣係預咗唔撈，佢居然同我道歉。之後佢就開始對我好有禮貌，唔再乜都屌。<br />\n<br />\n但之後半年，另一個 team member 俾佢屌到辭職，佢講晒對唔住咁留人，但當然梗係採佢都傻啦。"},{"pid":"90bb9963382649a22417726edd23e388236a3d58","tid":1864384,"uid":89801,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T11:58:32.000Z","msg":"當年返第一份工<br />\n兜口兜面拍枱再屌佢老母 然後我返埋位坐<br />\n事後上司向我道歉"},{"pid":"a9a70c8467b66da244aba8e260cc138879e01088","tid":1864384,"uid":29093,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T12:00:36.000Z","msg":"經常 <img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5a53fda2589f3a7052b34b78665bfee28e84b8ab","tid":1864384,"uid":12618,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-02-06T12:02:19.000Z","msg":"我成日都想 但最後都無<br />\n因為知道佢會扮唔知  扮唔明  扮無<br />\n因為佢係一個無賴<img src=\"/assets/faces/lny/smile.gif\" class=\"hkgmoji\" />"},{"pid":"1d788e21ad38ee4b338e266133e0674883809d8b","tid":1864384,"uid":132446,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T12:04:18.000Z","msg":"嘈黎無用， 最緊要自己有氣場"},{"pid":"910125f935b9570b0bf4aa1d47f6b330260d6410","tid":1864384,"uid":247184,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T12:08:41.000Z","msg":"經常性，最後和好如初<img src=\"/assets/faces/lny/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"92c324b209bf2e72f8cc8697e67b50d9bab79611","tid":1864384,"uid":293,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-06T12:10:07.000Z","msg":"琴日先屌完高層班仆街黎"},{"pid":"a95c41cff0cfc3d34b2a5234eacd2a7bdc4041f8","tid":1864384,"uid":1