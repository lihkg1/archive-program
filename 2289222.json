aces/normal/fire.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},{"pid":"7cf672fdce3f1e1d6ddd983e138c2b4d2000f6ac","tid":2289222,"uid":188515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-17T06:27:17.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"32fa87baa05239bd458c7dcbfa24ffefd446523f","tid":2289222,"uid":188515,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-17T06:27:45.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"d030b8eb7a12c4193a11ea6badbcaab9c6eaf065","tid":2289222,"uid":33263,"like":0,"dislike":0,"score":0,"quote":{"pid":"7ee01f206c8b928b7033293c06d5053d88f94692","tid":2289222,"uid":100638,"like":7,"dislike":0,"score":7,"citedBy":1,"replyTime":"2020-11-17T06:06:56.000Z","msg":"因有示威者在停車場大概 2 樓位置，投擲雪糕筒等雜物，所以我地決定殺左佢<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" /><br />\n仆街死一死唔該"},"citedBy":0,"replyTime":"2020-11-17T06:41:17.000Z","msg":"應該係穿黑杉既警察打死左周梓樂 再掟佢落樓<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"8a21e462f34e811c01805858ab3a730254dac3dd","tid":2289222,"uid":6981,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-17T06:56:41.000Z","msg":"<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"cda95071a0028f38a89a86b96a0ecf9d98926955","tid":2289222,"uid":320078,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-17T07:03:19.000Z","msg":"因為有人, 所以要殺"},{"pid":"9f20e439c186462b1f2bffbac4699d622ff904b6","tid":2289222,"uid":42250,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-11-17T07:06:25.000Z","msg":"唔係話老閉影到停車場一個人都冇咩<br />\n咁邊有人可以從停車場擲物"},{"pid":"9c1e26e809e7ba8896788802565d6d75e62d621a","tid":2289222,"uid":81113,"like"