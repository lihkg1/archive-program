":835484,"uid":25858,"like":0,"dislike":0,"score":0,"quote":{"pid":"e17b2e29f65c31ac960c97e6df67bf91ebefdf90","tid":835484,"uid":136216,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2018-09-25T03:17:26.000Z","msg":"鎖國算吧！"},"citedBy":0,"replyTime":"2018-09-25T03:49:28.000Z","msg":"<img src=\"/assets/faces/mf/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"677f21f64c1893a658584835764d2801c70d67ee","tid":835484,"uid":8410,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-25T04:00:36.000Z","msg":"漏左講香港呢個atm"},{"pid":"98129398bcabf30b83927a861eb2975945c84457","tid":835484,"uid":53705,"like":15,"dislike":0,"score":15,"citedBy":4,"replyTime":"2018-09-25T04:17:57.000Z","msg":"條柒頭搞到今時今日咁, 都仲未有人發動政變推翻佢<br />\n<br />\n應該成班中共官員都係離哂地"},{"pid":"726ddae951bf9db5badaafc92763744a3509c582","tid":835484,"uid":163350,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-25T04:31:45.000Z","msg":"此回覆已被刪除"},{"pid":"1d4a788ddadb8a42a7b19d2b6875564fac8fd3f4","tid":835484,"uid":127569,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-25T04:32:49.000Z","msg":"係味有得抄家批鬥人<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"829b5dccd44088bbb72db1ceb7547633513a5b8c","tid":835484,"uid":27206,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-25T05:05:45.000Z","msg":"人民公社指日可待<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"0129f09df524a90f5dc869cd9c4acdcb25fc106b","tid":835484,"uid":76310,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-09-25T08:35:45.000Z","msg":"「大不了恢復計劃經濟」。<br />\n<br />\n<img src=\"/assets/faces/mf/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/mf/agree.gif\" class=\"hkgmoji\" />"},{"pid":"ac190b0cf9b4b6776f2c266f78ef82630d240f8f","tid":835484,"uid":76310,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-25T08:36:56.000Z","msg":"目的是引蛇出洞，<br />\n<br />\n成日用呢招, 睇下邊個有異意, 之後打瓜佢"},{"pid":"083e00192a4d5e9493fed152960524f315373074","tid":835484,"uid":76310,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-09-25T08:41:08.000Z","msg":"從別的國家進口的貨物價錢可能更貴、品質可能更低，但這些蟻民的顧慮習總當然不管！<br />\n<br />\n岩呀, 洗鬼理班畜牲, 最緊要中共秋萬世, 佢地食草都愛国愛黨, 質佢地食草咪得"},{"pid":"c89576a8b14cdc55e52eb61094c5dd261f71c9c3","tid":835484,"uid":76310,"like":2,"dislike":0,"score":2,"quote":{"pid":"98129398bcabf30b83927a861eb2975945c84457","tid":835484,"uid":53705,"like":15,"dislike":0,"score":15,"citedBy":4,"replyTime":"2018-09-25T04:17:57.000Z","msg":"條柒頭搞到今時今日咁, 都仲未有人發動政變推翻佢<br />\n<br />\n應該成班中共官員都係離哂地"},"citedBy":0,"replyTime":"2018-09-25T08:43:10.000Z","msg":"邊個出頭邊個死<br />\n<br />\n你唔明習總玩法<br />\n佢抄家, 加稅有咩所謂, 都係班蝗民仆街, 至緊要保護利益階層, 利益階層自然會擁入習帝"},{"pid":"c852d26cda1cb227ed460ecf69a4a3d1dfdb8df2","tid":835484,"uid":11148,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-09-25T08:58:07.000Z","msg":"便命令黨政部門把「信得過的幹部」安插進一系列利潤豐厚的私營企業<br />\n<br />\n<br />\nok,我就等支那變到同委內瑞拉一撚樣 <img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"pid":"8e19abba401e55e3d07a4a80ba67668b55773a02","tid":835484,"uid":11148,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-09-25T09:00:11.000Z","msg":"美國抵制中國高科技產業，國務院與解放軍可以加倍遞增開發科研的經費<br />\n<br />\n<img src=\"/assets/faces/big/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"c0b3b41908860a1c0eda2457fd2e5d3ba3a98295","tid":835484,"uid":123738,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-09-25T09:03:14.000Z","msg":"支那一亮劍即刻世界第一啦<img src=\"/assets/faces/dog/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"c3f8330953dd58a6da99e4fa696527f50808cb42","tid":835484,"uid":103513,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-09-25T10:02:16.000Z","msg":"之前賺落咁多<br />\n搞計劃經濟係可以捱到一排<br />\n但之後賺錢能力越來越弱<br />\n好快會步蘇聯後塵<img src=\"/assets/faces/mf/angel.png\" class=\"hkgmoji\" />"},{"pid":"2ee72914596e9afe5ddc6234123da2e825883418","tid":835484,"uid":52006,"like":0,"dislike":0,"score":0,"quote":{"pid":"726ddae951bf9db5badaafc92763744a3509c582","tid":835484,"uid":163350,"like":1,"dislike":0,"score":1,"quote":{"pid":"98129398bcabf30b83927a861eb2975945c84457","tid":835484,"uid":53705,"like":15,"dislike":0,"score":15,"citedBy":4,"replyTime":"2018-09-25T04:17:57.000Z","msg":"條柒頭搞到今時今日咁, 都仲未有人發動政變推翻佢<br />\n<br />\n應該成班中共官員都係離哂地"},"citedBy":1,"replyTime":"2018-09-25T04:31:45.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2018-09-25T10:24:39.000Z","msg":"反佢既都被鬥死哂，得番班痴痴呆呆坐埋一枱<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"cacf069b3c4af53a78162cf0384609ae2c2587ce","tid":835484,"uid":149494,"like":0,"dislike":0,"score":0,"quote":{"pid":"98129398bcabf30b83927a861eb2975945c84457","tid":835484,"uid":53705,"like":15,"dislike":0,"score":15,"citedBy":4,"replyTime":"2018-09-25T04:17:57.000Z","msg":"條柒頭搞到今時今日咁, 都仲未有人發動政變推翻佢<br />\n<br />\n應該成班中共官員都係離哂地"},"citedBy":2,"replyTime":"2018-09-25T10:25:57.000Z","msg":"唔好傻啦<br />\n既得利益者好地地點解要出聲"},{"pid":"3f07134318106fb5c4498d046f4f3ee967b7cf3f","tid":835484,"uid":53705,"like":0,"dislike":0,"score":0,"quote":{"pid":"cacf069b3c4af53a78162cf0384609ae2c2587ce","tid":835484,"uid":149494,"like":0,"dislike":0,"score":0,"quote":{"pid":"98129398bcabf30b83927a861eb2975945c84457","tid":835484,"uid":53705,"like":15,"dislike":0,"score":15,"citedBy":4,"replyTime":"2018-09-25T04:17:57.000Z","msg":"條柒頭搞到今時今日咁, 都仲未有人發動政變推翻佢<br />\n<br />\n應該成班中共官員都係離哂地"},"citedBy":2,"replyTime":"2018-09-25T10:25:57.000Z","msg":"唔好傻啦<br />\n既得利益者好地地點解要出聲"},"citedBy":1,"replyTime":"2018-09-25T10:29:16.000Z","msg":"重點係<br />\n<br />\n習總 向美國挑機, 令美國打柒中共<br />\n導致中共經濟損失傷重, 完全燒到中共官員利益<br />\n<br />\n中共官員燒到自己利益, 仲會忠於習總咩??"}]}