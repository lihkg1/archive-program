ile.gif\" class=\"hkgmoji\" />"},{"pid":"62101f4d926902376236d50cf214f4e397190d47","tid":2026811,"uid":49151,"like":0,"dislike":0,"score":0,"quote":{"pid":"79db1143dbe337c2dfff9e138eb056962b6b87c5","tid":2026811,"uid":48234,"like":1,"dislike":0,"score":1,"quote":{"pid":"8e989520c19d580cd6bfc4d5d22356f23c15c57c","tid":2026811,"uid":49151,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-05-21T08:02:45.000Z","msg":"其實食黃店係光復唔到香港 操fit啲勇武啦各位<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-21T08:12:29.000Z","msg":"Why not both?"},"citedBy":1,"replyTime":"2020-05-21T08:18:09.000Z","msg":"問心有幾多個真係落場抗爭過 每日返工收工食黃店當抗爭咗 黃店冇錯係需要 一定唔係首選必要做"},{"pid":"7fdf4ff1d58b58a12f5a1bc2b793c9f353645297","tid":2026811,"uid":48234,"like":0,"dislike":0,"score":0,"quote":{"pid":"62101f4d926902376236d50cf214f4e397190d47","tid":2026811,"uid":49151,"like":0,"dislike":0,"score":0,"quote":{"pid":"79db1143dbe337c2dfff9e138eb056962b6b87c5","tid":2026811,"uid":48234,"like":1,"dislike":0,"score":1,"quote":{"pid":"8e989520c19d580cd6bfc4d5d22356f23c15c57c","tid":2026811,"uid":49151,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-05-21T08:02:45.000Z","msg":"其實食黃店係光復唔到香港 操fit啲勇武啦各位<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-05-21T08:12:29.000Z","msg":"Why not both?"},"citedBy":1,"replyTime":"2020-05-21T08:18:09.000Z","msg":"問心有幾多個真係落場抗爭過 每日返工收工食黃店當抗爭咗 黃店冇錯係需要 一定唔係首選必要做"},"citedBy":1,"replyTime":"2020-05-21T08:32:54.000Z","msg":"和理非都係手足<br />\n各有各做<br />\n人人可以承擔得起嘅後果都唔同"},{"pid":"500c7bd6d1f1bae465b5f12090c3456b968cf654","tid":2026811,"uid":95138,"like":0,"dislike":0,"score":0,"quote":{"pid":"78fa4a792146cf46a0753715bd381e4805a54709","tid":2026811,"uid":202464,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2020-05-21T07:50:44.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">全力支持「35+」<br />\n<br />\n<br />\n張超雄、楊岳橋、黃碧雲、梁耀忠，<br />\n<br />\n<br />\n一票都不能少！