"pid":"244974d3595cf7a5e6dce805fb43cba065433add","tid":1842012,"uid":209657,"like":50,"dislike":7,"score":43,"citedBy":2,"replyTime":"2020-01-25T13:11:37.000Z","msg":"<img src=\"https://appledaily-hk-appledaily-prod.cdn.arcpublishing.com/resizer/QiJX5BQcLA3Em-nnQtrv9qRwGBs=/802x534/arc-photo-appledaily.s3.amazonaws.com/ap-ne-1-prod/public/EUAQPYN5N6LJJP66RNDDYRYKXE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fappledaily-hk-appledaily-prod.cdn.arcpublishing.com%2Fresizer%2FQiJX5BQcLA3Em-nnQtrv9qRwGBs%3D%2F802x534%2Farc-photo-appledaily.s3.amazonaws.com%2Fap-ne-1-prod%2Fpublic%2FEUAQPYN5N6LJJP66RNDDYRYKXE.jpg&h=1d9815b4&s={SIZE}\" /><br />\n<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-25T13:33:41.000Z","msg":"除褲放屁<img src=\"/assets/faces/lny/ass.gif\" class=\"hkgmoji\" /><br />\n除口罩打喊露🥱"},{"pid":"e4f2dd5dc89bc79be8167b7a333c3a51b54116af","tid":1842012,"uid":235025,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T13:35:46.000Z","msg":"此回覆已被刪除"},{"pid":"1c468aec0507752e2252b9c157eb6cba1cbb3990","tid":1842012,"uid":332877,"like":0,"dislike":1,"score":-1,"quote":{"pid":"075744c2fa57fc8e1f8b00d77297999f4fe6f91b","tid":1842012,"uid":198023,"like":66,"dislike":2,"score":64,"citedBy":1,"replyTime":"2020-01-25T13:10:48.000Z","msg":"On9"},"citedBy":0,"replyTime":"2020-01-25T13:35:53.000Z","msg":"唔好意思<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />借一借個位嚟<br />\n<br />\n［要人簽聯署］！！！立即推動香港普選計劃！！！仲有幾日咋！<br />\n<a href=\"https://lih.kg/1842015\" data-auto-link target=\"_blank\">https://lih.kg/1842015</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"84560120a68a6e5294d21a6599419f654e3332b4","tid":1842012,"uid":60860,"like":0,"dislike":0,"score":0,"quote":{"pid":"4399df0064d80e81088ddedabf07fac56a299e25","tid":1842012,"uid":209657,"like":4,"dislike":16,"score":-12,"citedBy":1,"replyTime":"2020-01-25T13:10:51.000Z","msg":"被問到香港已有多宗確診個案，到人多擠逼的地方遊玩會唔擔心有患病風險，莊小姐亦未有佩戴口罩，直言「其實每個地方都會有確診的，過年的話，開心就好。」來自廣東茂名的何先生亦指，特意乘搭高鐵來港感受一下過年的氣氛，原本未有佩戴口罩，經記者提醒後立即補載，解釋只是照相時除了下來。被問到會否擔心疫情擴散，他指內地政府的預防措施做得還可以，「還是放心的」，他所居住的農村內亦沒有村民患病。<br />\n<br />\n陷入財困的海洋公園在武漢肺炎陰霾下，入場人數持續下跌。大年初一園區人流疏落，除了間中有小型內地旅行團到訪，購票區幾乎不用排隊。海洋公園大部份迎賓員工已佩戴口罩，園區設有健康服務站，派發口罩和提供酒精搓手液供遊人使用。"},"citedBy":0,"replyTime":"2020-01-25T13:36:11.000Z","msg":"過年的話，開心就好<br />\n鬼唔望你過唔撚到<img src=\"/assets/faces/lny/dead.gif\" class=\"hkgmoji\" />死大陸閪"},{"pid":"d015d38d960f1e3f800675ebddc9d0e583805d68","tid":1842012,"uid":2404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T13:37:50.000Z","msg":"國家政策咪就係叫你戴口罩囉<img src=\"/assets/faces/lny/clown4.gif\" class=\"hkgmoji\" />"},{"pid":"d1f68990533464cadfef2532b0abf4eb7b06e865","tid":1842012,"uid":191762,"like":0,"dislike":0,"score":0,"quote":{"pid":"48d98ed5bf38e0b87128e0369303eff0998604e9","tid":1842012,"uid":181655,"like":2,"dislike":32,"score":-30,"citedBy":5,"replyTime":"2020-01-25T13:17:38.000Z","msg":"條女好正<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-25T13:38:02.000Z","msg":"肚餓得滯？"},{"pid":"a22c3815937ba32a3ba533d3f7f5e30a411fd1e2","tid":1842012,"uid":3549,"like":0,"dislike":0,"score":0,"quote":{"pid":"2427b97abfb32678c9b8f9b91c60276f3d455f87","tid":1842012,"uid":191762,"like":12,"dislike":0,"score":12,"quote":{"pid":"244974d3595cf7a5e6dce805fb43cba065433add","tid":1842012,"uid":209657,"like":50,"dislike":7,"score":43,"citedBy":2,"replyTime":"2020-01-25T13:11:37.000Z","msg":"<img src=\"https://appledaily-hk-appledaily-prod.cdn.arcpublishing.com/resizer/QiJX5BQcLA3Em-nnQtrv9qRwGBs=/802x534/arc-photo-appledaily.s3.amazonaws.com/ap-ne-1-prod/public/EUAQPYN5N6LJJP66RNDDYRYKXE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fappledaily-hk-appledaily-prod.cdn.arcpublishing.com%2Fresizer%2FQiJX5BQcLA3Em-nnQtrv9qRwGBs%3D%2F802x534%2Farc-photo-appledaily.s3.amazonaws.com%2Fap-ne-1-prod%2Fpublic%2FEUAQPYN5N6LJJP66RNDDYRYKXE.jpg&h=1d9815b4&s={SIZE}\" /><br />\n<img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-01-25T13:22:24.000Z","msg":"佢個口罩當口水肩用定係用嚟裝飾"},"citedBy":0,"replyTime":"2020-01-25T13:39:35.000Z","msg":"遮口臭"},{"pid":"d4f24e04516226c2950ca50b15a5b70f66d19756","tid":1842012,"uid":414,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T13:40:38.000Z","msg":"究竟佢地諗緊咩 我睇唔透"},{"pid":"92d3affce7ac687599c0a95e0884ee2611281dbf","tid":1842012,"uid":144766,"like":0,"dislike":0,"score":0,"quote":{"pid":"48d98ed5bf38e0b87128e0369303eff0998604e9","tid":1842012,"uid":181655,"like":2,"dislike":32,"score":-30,"citedBy":5,"replyTime":"2020-01-25T13:17:38.000Z","msg":"條女好正<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-25T13:44:50.000Z","msg":"食開屎?"},{"pid":"4c7ebae0ae3bb9ba1f00784d238461821f611ee8","tid":1842012,"uid":264788,"like":0,"dislike":0,"score":0,"quote":{"pid":"6515d4e6af1daa905737e9d57abcce1957c90e6f","tid":1842012,"uid":209657,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-25T13:10:07.000Z","msg":"<img src=\"https://appledaily-hk-appledaily-prod.cdn.arcpublishing.com/resizer/O0UT4Fg-wj6NWwyanzU0xeO0fB0=/802x451/arc-photo-appledaily.s3.amazonaws.com/ap-ne-1-prod/public/YH7IIY4CX2GL5KPVHGIGKTKXDE.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fappledaily-hk-appledaily-prod.cdn.arcpublishing.com%2Fresizer%2FO0UT4Fg-wj6NWwyanzU0xeO0fB0%3D%2F802x451%2Farc-photo-appledaily.s3.amazonaws.com%2Fap-ne-1-prod%2Fpublic%2FYH7IIY4CX2GL5KPVHGIGKTKXDE.jpg&h=87837ca6&s={SIZE}\" /><br />\n<br />\n大年初一傳統上與家人拜年聚天倫，亦有市民和遊客趁假日去主題公園消閒，惟人流未算多，大部份員工亦佩戴口罩，園區設有健康服務站。武漢肺炎持續於內地多個省市爆發，廣東省今公佈新增25宗病例，東莞更首次報告確診病例。有來自東莞的內地旅客莊小姐今早來港，一到埗即與友人到海洋公園遊玩，她表示東莞市況平靜，「感覺這種東西應該不會弄到自己身上吧」，又笑言「國家已經有政策了，有甚麼好擔心呢？過關的時候也有測體溫，所以沒事的。」"},"citedBy":0,"replyTime":"2020-01-25T13:45:34.000Z","msg":"咁似兩星期前架武漢人既<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},{"pid":"f0e2a95b29f42e9b7f63587bc2cd00f2f806bf35","tid":1842012,"uid":173191,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T13:45:45.000Z","msg":"<span style=\"font-size: xx-large;\"><strong><span style=\"color: red;\">我屌你老母臭閪</span></strong></span>"},{"pid":"e2f7615a51b3a2eb598b71814dacfb4bf1851f82","tid":1842012,"uid":255600,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T14:08:17.000Z","msg":"此回覆已被刪除"},{"pid":"8b43aeeb306368a1f85b372214452b10dcf1d234","tid":1842012,"uid":72334,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T14:10:53.000Z","msg":"有政府唔驚 唔戴.jpg"},{"pid":"abb508f05e0fd3a4578af4b594adbc6cba509a06","tid":1842012,"uid":272394,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-25T14:24:51.000Z","msg":"南港島線rip<img src=\"/assets/faces/lny/smile3.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"1c468aec0507752e2252b9c157eb6cba1cbb3990","tid":1842012,"uid":332877,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-01-25T13:35:53.000Z","msg":"唔好意思<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />借一借個位嚟<br />\n<br />\n［要人簽聯署］！！！立即推動香港普選計劃！！！仲有幾日咋！<br />\n<a href=\"https://lih.kg/1842015\" data-auto-link target=\"_blank\">https://lih.kg/1842015</a><br />\n- 分享自 LIHKG 討論區"}}