en.bitcoin.it/w/images/en/a/a1/SupplyFormula.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fen.bitcoin.it%2Fw%2Fimages%2Fen%2Fa%2Fa1%2FSupplyFormula.gif&h=ef32117f&s={SIZE}\" /><br />\n<img src=\"https://www.bitcoinblockhalf.com/images/bitcoin-inflation-chart.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.bitcoinblockhalf.com%2Fimages%2Fbitcoin-inflation-chart.png&h=c3903102&s={SIZE}\" />"},"citedBy":2,"replyTime":"2020-06-27T02:12:43.000Z","msg":"cryto 唔只一隻 姐係=印錢"},"citedBy":1,"replyTime":"2020-06-27T03:24:25.000Z","msg":"正如你喺屋企印大富翁錢唔代表美元供應多咗<br />\n任何人都可以fork Bitcoin protocol，但無群眾共識喺背後唔會有價值"},"citedBy":0,"replyTime":"2020-06-27T03:28:59.000Z","msg":"bitcoin 唯一共識= 可以增值換美金 <br />\n而其他coin一樣 <br />\n同美股一樣"},{"pid":"bae053d10e1a6ba81a2038f4c18724a25e05f0ba","tid":2080933,"uid":2590,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-27T03:30:34.000Z","msg":"其實只要整bitcoin同掘bitcoin果班人個社群肯制<br />\nbitcoin最高發行量同出產方式係可以改 <br />\n個比喻係 cryptocurrency 本身雖然好安全 <br />\n不過你只要揾到持有bitcoin果條友打鳩佢迫到佢交條key出嚟就可以暴力破解<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"0f43f4edc2d21cfda4a8a82727e113c2addc35cd","tid":2080933,"uid":130797,"like":0,"dislike":0,"score":0,"quote":{"pid":"c7dc8c79a2d271c3337ec0ee66b245668aaab04b","tid":2080933,"uid":71237,"like":1,"dislike":0,"score":1,"quote":{"pid":"2213daa455b568cb42b7cf06acc0432d1234bd65","tid":2080933,"uid":130797,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2020-06-27T02:48:31.000Z","msg":"我都唔識經濟<br />\n不過我相信係 錢 呢種量化工具<br />\n之後先有 窮 呢種概念<br />\n<br />\n想像人類之初<br />\n你有你養牛揸下牛奶<br />\n我有我種田種菜<br />\n大家得閒就交換下生活所需<br />\n何來你窮定我窮既觀念？<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-06-27T03:16:44.000Z","msg":"我擁有好多牛，啲牛奶多到可以賣出去換其他物品(例如雞蛋)。<br />\n你種菜就淨係夠自己食，拎咗嚟換其他物品你就唔夠菜食。"},"citedBy":2,"replyTime":"2020-06-27T03:52:07.000Z","msg":"如果我需要牛奶<br />\n我就用菜同你換牛奶<br />\n如果我發現換完牛奶之後就無菜食<br />\n咁我一係開始養多隻牛 一係我就開始種多d菜<br />\n<br />\n當中又的確好似係含有「不滿足」呢個概念<img src=\"/assets/faces/lm2/think.gif\" class=\"hkgmoji\" /><br />\n但我又認為無金錢呢種統一量化既工具<br />\n就好難用「窮」黎評估你同我<br />\n<br />\n就因為財產無統一量化<br />\n根本唔會清楚你既牛係值錢d 定我既菜值錢d<br />\n只會盡量去滿足同交換自己想要既野<br />\n話唔定你需求蔬菜個陣 會拎隻牛黎同我交換"},{"pid":"9b14928b38b160f666e92c033aea5a473c06fb9d","tid":2080933,"uid":60648,"like":1,"dislike":0,"score":1,"quote":{"pid":"c7dc8c79a2d271c3337ec0ee66b245668aaab04b","tid":2080933,"uid":71237,"like":1,"dislike":0,"score":1,"quote":{"pid":"2213daa455b568cb42b7cf06acc0432d1234bd65","tid":2080933,"uid":130797,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2020-06-27T02:48:31.000Z","msg":"我都唔識經濟<br />\n不過我相信係 錢 呢種量化工具<br />\n之後先有 窮 呢種概念<br />\n<br />\n想像人類之初<br />\n你有你養牛揸下牛奶<br />\n我有我種田種菜<br />\n大家得閒就交換下生活所需<br />\n何來你窮定我窮既觀念？<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-06-27T03:16:44.000Z","msg":"我擁有好多牛，啲牛奶多到可以賣出去換其他物品(例如雞蛋)。<br />\n你種菜就淨係夠自己食，拎咗嚟換其他物品你就唔夠菜食。"},"citedBy":0,"replyTime":"2020-06-27T03:55:23.000Z","msg":"錢其中一個功能都係量化左一個人既資源財產姐<br />\n<br />\n個窮字本身咪係古人既概念<br />\n<br />\n窮 = 穴身弓<br />\n<br />\n窮到要縮係個山洞到住<br />\n<br />\n富 = 屋 一 口 田<br />\n<br />\n有屋有糧有地"},{"pid":"f5d3fa64904217cf83ce314b355644cf6c0f0cd6","tid":2080933,"uid":71237,"like":0,"dislike":0,"score":0,"quote":{"pid":"0f43f4edc2d21cfda4a8a82727e113c2addc35cd","tid":2080933,"uid":130797,"like":0,"dislike":0,"score":0,"quote":{"pid":"c7dc8c79a2d271c3337ec0ee66b245668aaab04b","tid":2080933,"uid":71237,"like":1,"dislike":0,"score":1,"quote":{"pid":"2213daa455b568cb42b7cf06acc0432d1234bd65","tid":2080933,"uid":130797,"like":0,"dislike":4,"score":-4,"citedBy":1,"replyTime":"2020-06-27T02:48:31.000Z","msg":"我都唔識經濟<br />\n不過我相信係 錢 呢種量化工具<br />\n之後先有 窮 呢種概念<br />\n<br />\n想像人類之初<br />\n你有你養牛揸下牛奶<br />\n我有我種田種菜<br />\n大家得閒就交換下生活所需<br />\n何來你窮定我窮既觀念？<br />\n<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-06-27T03:16:44.000Z","msg":"我擁有好多牛，啲牛奶多到可以賣出去換其他物品(例如雞蛋)。<br />\n你種菜就淨係夠自己食，拎咗嚟換其他物品你就唔夠菜食。"},"citedBy":2,"replyTime":"2020-06-27T03:52:07.000Z","msg":"如果我需要牛奶<br />\n我就用菜同你換牛奶<br />\n如果我發現換完牛奶之後就無菜食<br />\n咁我一係開始養多隻牛 一係我就開始種多d菜<br />\n<br />\n當中又的確好似係含有「不滿足」呢個概念<img src=\"/assets/faces/lm2/think.gif\" class=\"hkgmoji\" /><br />\n但我又認為無金錢呢種統一量化既工具<br />\n就好難用「窮」黎評估你同我<br />\n<br />\n就因為財產無統一量化<br />\n根本唔會清楚你既牛係值錢d 定我既菜值錢d<br />\n只會盡量去滿足同交換自己想要既野<br />\n話唔定你需求蔬菜個陣 會拎隻牛黎同我交換"},"citedBy":0,"replyTime":"2020-06-27T03:56:20.000Z","msg":"你太睇少人類嘅妒忌心。<br />\n就算無統一單位，但邊個人生活過得好啲、物資多啲都係好明顯嘅。"},{"pid":"fa28d8a55b71ed0bcc616c78d1f44652c9041ed9","tid":2080933,"uid":351009,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d9b0e22d03bd2c2ea152d5470236e71567d2d74","tid":2080933,"uid":71237,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-27T02:20:00.000Z","msg":"如果貨幣數量永遠不變，但係經濟就不斷擴張，到時就會出現通縮。<br />\n通縮即係同等數量嘅金錢可以換到嘅物品愈嚟愈多。<br />\n例如以前一個bitcoin可以換到一個pizza，今日一個bitcoin可以換到無數個pizza。<br />\n<br />\n不過到時連登仔又會唔開心，覺得自己每個月返工賺嘅bitcoin愈嚟愈少。"},"citedBy":0,"replyTime":"2020-06-27T03:58:15.000Z","msg":"通縮雖然係Keynesian economics嘅大忌，但喺Austrian economics原則上唔係完全壞事<br />\nBitcoin理念上接近Austrian economics<br />\n<br />\n<a href=\"https://youtu.be/9-uo-KfnkhI\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2F9-uo-KfnkhI&d=jQldmXM9xAXOA%2BwUl6G2h6b0OKgTvMyjK8k7SjVk7cc%3D&h=0494a22a\" data-auto-link target=\"_blank\">https://youtu.be/9-uo-KfnkhI</a>"},{"pid":"d7a4049ed68d870352df1c326a26e76a4d39ecfa","tid":2080933,"uid":135137,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-27T04:29:08.000Z","msg":"諗清楚你講緊money定currency先啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f448af7abe7cfdfb7de7bdac7aefb4c2c576e17d","tid":2080933,"uid":67280,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-27T05:08:16.000Z","msg":"印錢目的係應付增長需求，錢係必定靠貸款先會流出。<br />\n<br />\n個生態玩玩下變左得資產得天下，做生意同買樓都要5m，做生意回報可能高10%，但做生意風險大又煩好多野(鋪，請人，交表等)，買樓唔好<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n個10%唔賺好過啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"0149df14987a25ac58cfb18f967b0967f719bf02","tid":2080933,"uid":83654,"like":0,"dislike":0,"score":0,"quote":{"pid":"4b7c7cee2d4b58d150274116bd2d615fd17c4816","tid":2080933,"uid":22675,"like":0,"dislike":0,"score":0,"citedBy":4,"replyTime":"2020-06-26T21:12:45.000Z","msg":"錢只係印出嚟，所以根本係想要幾多就有幾多，所以先有通漲呢回事，如果有一樣野好似bitcoin咁數量永遠不變嘅貨幣，咁就唔會有通漲呢回事，咁有錢人就無辦法利用通漲剝削窮人<br />\n<br />\n不過我都講過我唔識經濟，以上嘅野都只係我猜測，好可能係錯，更何況，我唔知道點解bitcoin貨幣好似每隔一段時間就多咗，好似唔係我想像咁永恆不變"},"citedBy":1,"replyTime":"2020-06-27T05:11:10.000Z","msg":"想得太美好<br />\n金本位時代窮人都係剝削， 關鍵根本唔係咩載體為貨幣， 根本在於制度同思維。"},{"pid":"5df7090d2d2a208f08ddeb261a0beeef3d89b2c7","tid":2080933,"uid":34530,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-27T05:13:06.000Z","msg":"窮爸爸"},{"pid":"67d9a2603df7897554ef437601da5458c50b0471","tid":2080933,"uid":83654,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-27T05:14:20.000Z","msg":"俾多張圖你， 記住任何制度下， 人類社會都有貧富， 係純粹機率問題， 關鍵只係個形狀點劃。<br />\n<img src=\"https://na.cx/i/Mqp7Y7w.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FMqp7Y7w.png&h=35ddd916&s={SIZE}\" />"},{"pid":"040ab9ef0f5a5cf70b6a6de7a8c5aec4ce577dcc","tid":2080933,"uid":161374,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-27T05:17:32.000Z","msg":"咩情況之下都會有窮人同富人<br />\nbitcoin 係有限，但類似 bitcoin嘅貨幣係無限"},{"pid":"925474ea156bcede7bbff241bde17ca2d81974a2","tid":2080933,"uid":34804,"like":0,"dislike":0,"score":0,"quote":{"pid":"67d9a2603df7897554ef437601da5458c50b0471","tid":2080933,"uid":83654,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-06-27T05:14:20.000Z","msg":"俾多張圖你， 記住任何制度下， 人類社會都有貧富， 係純粹機率問題， 關鍵只係個形狀點劃。<br />\n<img src=\"https://na.cx/i/Mqp7Y7w.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A