bea59ca1ed0848639675788f83c66eda37","tid":2152871,"uid":73972,"like":0,"dislike":0,"score":0,"quote":{"pid":"ea374493be139d65d7f9bd474f0f7ed639fd45f1","tid":2152871,"uid":59518,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2020-08-12T08:30:39.000Z","msg":"駁回訟費申請<br />\n<br />\n食屎啦"},"citedBy":0,"replyTime":"2020-08-12T08:35:14.000Z","msg":"食屎啦，以本傷人"},{"pid":"f5eba8c96cfec2103da7d1a6fefdba97e18b35f0","tid":2152871,"uid":43062,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-12T08:35:34.000Z","msg":"求當日報道新聞<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"bd62729187adf3db92ecaefb19ddf6f82edf592b","tid":2152871,"uid":321059,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-08-12T08:35:36.000Z","msg":"梁嘉琪咪判區諾軒大聲公襲狗罪成個紅官<br />\n<br />\n制裁近了<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"38be2561495583f22ab0c6aa3f9cbb3e1b93097f","tid":2152871,"uid":88663,"like":0,"dislike":0,"score":0,"quote":{"pid":"bff3e1130a028b6adcc843eaf3ced5239c801f8d","tid":2152871,"uid":46906,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-08-12T08:33:52.000Z","msg":"控罪不成立竟然會駁回訟費申請，好似好少見？"},"citedBy":0,"replyTime":"2020-08-12T08:35:37.000Z","msg":"可能話佢自招嫌疑掛"},{"pid":"286af6dfbe77a99c9372d84007d6c47ebb6c6825","tid":2152871,"uid":186152,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2020-08-12T08:47:43.000Z","msg":"垃圾臭閪官"},{"pid":"4b7ff6a508d8bc92655592b2982953f96d4403b6","tid":2152871,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-12T09:18:48.000Z","msg":"有市民去年8月3日晚上在旺角警署外聚集，其間身處警方防線前的廚師涉嫌拒絕按指示離開，拖慢警方推進被起訴。案件經審訊後今午在九龍城法院裁決，梁嘉琪裁判官指警員供詞與現場片段不符、出現矛盾，加上被告案發時身穿「街坊裝」，沒有證供顯示他與在場示威者有聯繫，終裁定阻礙公職人員及在公眾地方管有攻擊性武器兩罪罪名不成立，惟駁回辯方訟費申請。被告聞判後眼泛淚光，形容自己如釋重負。<br />\n<br />\n梁官表示，雖然被告拒絕按指示離開的行為可疑，但在盤問下涉案警員證供與現場片段出現矛盾、不一致之處，故裁決阻礙公職人員罪罪脫。梁官續指，被告遭要求出示身分證時沒有迴避，過程中沒有激烈反抗。被告當時僅身穿T恤、短褲及拖鞋，而其住所亦與案發地相距不遠，未能證明被告與現場示威者有聯繫，終裁定控方舉證未能達致唯一且不可抗拒的推論。"},{"pid":"76b85ad71e09952875a20426bf0148c4043c6862","tid":2152871,"uid":230662,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-08-12T09:19:30.000Z","msg":"又唔批DKLM<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"df95f23f57c4a252ba55ef93dded00d1c7df9905","tid":2152871,"uid":6211,"like":0,"dislike":0,"score":0,"quote":{"pid":"bff3e1130a028b6adcc843eaf3ced5239c801f8d","tid":2152871,"uid":46906,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2020-08-12T08:33:52.000Z","msg":"控罪不成立竟然會駁回訟費申請，好似好少見？"},"citedBy":0,"replyTime":"2020-08-12T09:19:44.000Z","msg":"唔係"},{"pid":"2712bd4071859fda3bb45c55a74b6fc05fbc336c","tid":2152871,"uid":171107,"like":1,"dislike":0,"score":1,"quote":{"pid":"4c48dd983c2771c84c3d5b2b6f517bd581652c87","tid":2152871,"uid":48060,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2020-08-12T08:34:10.000Z","msg":"連呢個紅底官都判無罪就知班狗同doj幾離譜<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-08-12T09:20:47.000Z","msg":"狗官怕制裁姐，唔敢入手足罪頂住條氣，所以做埋啲小學雞野唔俾手足攞返訟費"},{"pid":"22b08fe8279b28f544ad6ce80f660fa9022b6f39","tid":2152871,"uid":48060,"like":0,"dislike":0,"score":0,"quote":{"pid":"4b7ff6a508d8bc92655592b2982953f96d4403b6","tid":2152871,"uid":240362,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-08-12T09:18:48.000Z","msg":"有市民去年8月3日晚上在旺角警署外聚集，其間身處警方防線前的廚師涉嫌拒絕按指示離開，拖慢警方推進被起訴。案件經審訊後今午在九龍城法院裁決，梁嘉琪裁判官指警員供詞與現場片段不符、出現矛盾，加上被告案發時身穿「街坊裝」，沒有證供顯示他與在場示威者有聯繫，終裁定阻礙公職人員及在公眾地方管有攻擊性武器兩罪罪名不成立，惟駁回辯方訟費申請。被告聞判後眼泛淚光，形容自己如釋重負。<br />\n<br />\n梁官表示，雖然被告拒絕按指示離開的行為可疑，但在盤問下涉案警員證供與現場片段出現矛盾、不一致之處，故裁決阻礙公職人員罪罪脫。梁官續指，被告遭要求出示身分證時沒有迴避，過程中沒有激烈反抗。被告當時僅身穿T恤、短褲及拖鞋，而其住所亦與案發地相距不遠，未能證明被告與現場示威者有聯繫，終裁定控方舉證未能達致唯一且不可抗拒的推論。"},"citedBy":0,"replyTime":"2020-08-12T09:20:57.000Z","msg":"食屎啦 即係同示威有關就可以判？"}]}