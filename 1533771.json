/na.cx/i/TxutcQb.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FTxutcQb.png&h=c956cdbc&s={SIZE}\" /><img src=\"https://na.cx/i/n5syoWR.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fn5syoWR.png&h=825480d8&s={SIZE}\" />"},{"pid":"efa89ba30444834438482e3b65ff5f69cd6ade47","tid":1533771,"uid":276715,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T22:23:31.000Z","msg":"推"},{"pid":"b22ef8b6e18975d5a13630a1e6fb73dd0df99d20","tid":1533771,"uid":261852,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-02T22:34:46.000Z","msg":"連登嘅最大功能就係集中本地討論然後對外輸出, 開個英文台當然可以, 但功用係乜? 吸引外藉冷氣軍師加入參與討論? 點樣防止五毛借外國A/C滲入連登?.....問題一大堆, 開台容易, 管理難, 後門一打開, 清兵即入關, 後果真係自負, 三思!!!"},{"pid":"ea5a955177f196ff31624b2ed253ec27c6e915a8","tid":1533771,"uid":204075,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T22:49:20.000Z","msg":"推啊"},{"pid":"b0d177879b66790c916934984b450d35a757f09e","tid":1533771,"uid":124410,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T23:31:33.000Z","msg":"好諗頭"},{"pid":"63ef77ae254cb1f223e66f7198f4822b868ef574","tid":1533771,"uid":288912,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T23:40:29.000Z","msg":"一定要開！唔只已經好多po話外國人想睇英文抗爭資訊，而家直頭有外國人想參戰！廣傳<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><br />\n<br />\n［和理升級］Reddit出現外國手足！出圖上咗熱門！盡快相認！<br />\n<a href=\"https://lih.kg/1533804\" data-auto-link target=\"_blank\">https://lih.kg/1533804</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"2cdfe94c9c5faac56cbe66fb00f05d0a0325364c","tid":1533771,"uid":38793,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T23:41:12.000Z","msg":"Yes!"},{"pid":"be6115d2f0d50948ac4746b7fc8b522e21d6eb57","tid":1533771,"uid":259335,"like":0,"dislike":0,"score":0,"quote":{"pid":"b22ef8b6e18975d5a13630a1e6fb73dd0df99d20","tid":1533771,"uid":261852,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-02T22:34:46.000Z","msg":"連登嘅最大功能就係集中本地討論然後對外輸出, 開個英文台當然可以, 但功用係乜? 吸引外藉冷氣軍師加入參與討論? 點樣防止五毛借外國A/C滲入連登?.....問題一大堆, 開台容易, 管理難, 後門一打開, 清兵即入關, 後果真係自負, 三思!!!"},"citedBy":0,"replyTime":"2019-09-02T23:49:48.000Z","msg":"咁不如 開放申請做 非正式會員<br />\n非正式會員只可以係英文台<br />\n1.留言(有每日限制 例如：每日12個)<br />\n2.開Post(有每日限制 例如：每日1個)<br />\n3.評分(分開正式會員同非正式會員嘅正負評數目)<br />\n<br />\n英文台就只可以用英文留言/開post<br />\n其他語言就自動刪除/出唔到個留言/post<br />\n<br />\n咁work唔work先？"},{"pid":"3301a64f19dc9aeb8831943782d9da406210731c","tid":1533771,"uid":297997,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-02T23:52:50.000Z","msg":"Support"},{"pid":"536527802b0fa1c8397b402624deab7eed08d7b3","tid":1533771,"uid":201889,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T03:01:28.000Z","msg":"開3個新台 <br />\n<br />\n<span style=\"color: limegreen;\">- 徵求翻譯台<br />\n- English Channel [英文台]<br />\n- Other Languages Channel [外文台]</span><br />\n<br />\n<span style=\"color: gold;\">&quot;徵求翻譯台&quot;</span><br />\n內 Post 需要找人翻譯的文章, 最好指明想要的語言<br />\n甚至 &quot;文宣&quot; 內容也可以<br />\n在回覆內 Post 各種話言的文字翻譯<br />\n<br />\n<span style=\"color: gold;\">&quot;英文台&quot; &quot;外文台&quot;</span><br />\nPost 已翻譯的文章<br />\n可能要在標題加 Tag, 分話言 e.g. [Francais] [Deutsch]"},{"pid":"dfe4b68818ec27533a5a7114a1f4db7dea09c9d7","tid":1533771,"uid":300554,"like":0,"dislike":0,"score":0,"quote":{"pid":"3b82cfbc9ce3e62305986617ed6dea4a5cebb73c","tid":1533771,"uid":137279,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-09-02T21:40:30.000Z","msg":"唔好焗限香港討論，放眼世界，集思廣益<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-03T03:08:26.000Z","msg":"<span style=\"color: red;\">3隻眼 8條命 1117被捕 無數斷手斷腳</span><br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">831黨鐵恐襲傷者消息全無</span></span><br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: green;\"><br />\n九二九三大三罷！<br />\n設死線 升級持續罷工<br />\n日日罷工 日日入機場<br />\n</span></strong></span><br />\n<strong><span style=\"color: red;\">【升級罷工】EndGame＝全面開啟升級抗爭</span></strong><br />\n<span style=\"color: gold;\">網民問卷調查報告 我們在這沉痛的晚上公佈</span><br />\n<a href=\"https://lih.kg/1525035\" data-auto-link target=\"_blank\">https://lih.kg/1525035</a><br />\n- 分享自 LIHKG 討論區<br />\n<img src=\"https://na.cx/i/bVP4X9g.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FbVP4X9g.jpg&h=c7d56cf5&s={SIZE}\" /><img src=\"https://na.cx/i/Y5iA4Pi.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FY5iA4Pi.jpg&h=b866962b&s={SIZE}\" /><img src=\"https://na.cx/i/1hL7VVY.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1hL7VVY.jpg&h=fc849ad9&s={SIZE}\" />"},{"pid":"f68cb4e4d8bd77aa9540f37af0c3aa6933ab4a67","tid":1533771,"uid":280163,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-03T07:52:13.000Z","msg":"[集思廣益] 連登必須出英文版 ！！！！！<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1534989\" data-auto-link target=\"_blank\">https://lih.kg/1534989</a><br />\n<br />\n<span style=\"font-size: x-large;\">1. 連登要有<span style=\"color: gold;\">翻譯台</span>+<span style=\"color: blue;\">外語台</span></span><br />\n-<span style=\"color: gold;\">翻譯台</span>：大概係一個<ins>熱門台嘅翻版</ins>，不過可以俾會員click 入去揀語言作出翻譯，<br />\n-每個翻譯都可以report，<ins>太多report唔出得街</ins><br />\n<br />\n-<span style=\"color: blue;\">外語台</span>：一個比<ins>外國人嘅介面</ins>，翻譯好嘅post會係果邊出現。<ins>以語言做大分類，以熱門程度排序。</ins><br />\n<br />\n<br />\n<span style=\"font-size: x-large;\">2.開Reddit／Twitter </span><br />\n連登唔係個個外國人都識，但reddit同twitter就好多外國人用。<br />\n除咗用本土平台，<br />\n可以將<ins>今日熱門嘅post逐個總結</ins>，放上外國平台，<br />\n<span style=\"font-size: x-large;\">再係reddit／twitter link返去原本個post到。<br />\n咁樣外國人可以係佢哋平台comment俾我哋睇。</span>"}]}