faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"3e940bda47cd0bd706e12a553332499d7f1575f1","tid":1211140,"uid":180462,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-12T16:32:25.000Z","msg":"我應份既手足"},{"pid":"7b3c805adcec79e792d77bf1453fd42ed594de88","tid":1211140,"uid":180462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T16:53:36.000Z","msg":"你個樣好後生 中學生？"},{"pid":"e64480dec46e96e676ee07d785e44cdebd779ac8","tid":1211140,"uid":13009,"like":0,"dislike":0,"score":0,"quote":{"pid":"3e940bda47cd0bd706e12a553332499d7f1575f1","tid":1211140,"uid":180462,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-12T16:32:25.000Z","msg":"我應份既手足"},"citedBy":0,"replyTime":"2019-06-12T17:07:44.000Z","msg":"係唔係你調頭救咗我<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />?好多謝你<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n之後喺唔知邊度撞到你你仲問我仲有冇唔舒服<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n我廿歲啦<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"585428f52859f90fb3f0d421552495ed00bbaf80","tid":1211140,"uid":80072,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-12T17:10:08.000Z","msg":"首先我哋必須解決催淚彈嘅問題<br />\n手術口罩係冇撚用"},{"pid":"61debfc8d63277b66d1c9c6e3207a512bb1bcb57","tid":1211140,"uid":56368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-12T17:14:22.000Z","msg":"3M眼罩+口罩其實已經好頂得 但當時係咁走好似透唔到氣咁"},{"pid":"b9050a034a51eba051d6261f6b4255478837e9cd","tid":1211140,"uid":9938,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-12T22:54:40.000Z","msg":"<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},{"pid":"39ab572deba581f3f5e77c252edd708705a9c43a","tid":1211140,"uid":13009,"like":0,"dislike":0,"score":0,"quote":{"pid":"b9050a034a51eba051d6261f6b4255478837e9cd","tid":1211140,"uid":9938,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-12T22:54:40.000Z","msg":"<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-13T01:29:53.000Z","msg":"多謝你<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />唔知今日有啲咩可以做到，依加金鐘又唔夠人<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"db37e3e36b1c9f680906c27f3cf163ee4a95237b","tid":1211140,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T01:31:09.000Z","msg":"<a href=\"https://www.facebook.com/450867315005279/posts/2299277576830901/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F450867315005279%2Fposts%2F2299277576830901%2F&d=o1jNmZJj5m3DpFdm5BDgvzyMEfxyOVmMxalVp7jK43I%3D&h=51fd4a90\" data-auto-link target=\"_blank\">https://www.facebook.com/450867315005279/posts/2299277576830901/</a><br />\n<br />\n612嗰日一位16歲女學生嘅心聲<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> 聽完之後我好嬲，亦都好想喊，香港今時今日嘅景況，除咗班高官之外，班蓄生警犬亦都有份一手一腳造成"},{"pid":"6e5fd03c89ad622d3cb937ab4ab9ff89a385a531","tid":1211140,"uid":226955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-13T01:33:32.000Z","msg":"和理非可以用一切合法手段助攻反送中，例如教會可以申請不反對通知書組織一大班人祈禱唱下聖詩，渣車安全起見渣慢啲，罷工罷課，撘下火車地鐵參觀下香港，周街燈柱貼宣傳反送中單張等等，一方面喚起社會更多人關注，一方面爭取國際支持向政府施加壓力（eg取消美國香港關係法）去迫政府撤回逃犯條例。"}]}