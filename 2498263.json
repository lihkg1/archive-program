h.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2FcttWDoFhUiiWqL6d7f%2Fgiphy.gif&h=2d3ff6a0&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmRYj4zK3umzX9HhasjJHsMdCLA8RQCYBDN5jK3EBEMuMv?filename=CsAtFb6.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCsAtFb6.gif&h=4124a921&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmUbPxrprfwnmYp27MzMdrrzs9rfvqBrc2fpUMqN6oGGPL?filename=mxKutLO.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmxKutLO.gif&h=1e818df4&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmTWq4KSytndPUST7xNWnYKFZwXATGTVFd2N5EDitChgya?filename=dkjm7dT.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fdkjm7dT.gif&h=43cebbdc&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmcSRgZPBpPhiW7hMCbPf5UwrSDnutPB8dhKW3fmzLaXJC?filename=Eat1qYW.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FEat1qYW.gif&h=7c2262d4&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmSH3xpt2dQRQn9vMPBKTTUKxsafEy4KX7SEo9Hiy43g1G?filename=gAp5L0N.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgAp5L0N.gif&h=5eb0c9de&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmeWrbwPq9w2KZq568pNh99EDQjsf5tgBPKmneuKstQkxa?filename=XNfK5T5.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FXNfK5T5.gif&h=311a2e7c&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qma6pPgrA7Cdb9VuEKjNovY43mJGXVTPYf41t4rLC6kEbd?filename=SPOHCpn.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSPOHCpn.gif&h=00bff173&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmXvmoqWJdmv1uTa7vyjhoCYnfxCJwgFkYR5wB6KF3fcST?filename=MyNfGd8.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FMyNfGd8.gif&h=bdbc787a&s={SIZE}\" /><br />\n<br />\n</p><br />\n<br />\n櫻坂46（Sakurazaka46）(原名為欅坂46)是日本大型女子偶像團體，製作人為秋元康。組合名字中的「46」讀作「Forty-six／フォーティシックス」，而不是讀作「四十六／よんじゅうろく」。2016年4月6日，欅坂46出道單曲《サイレントマジョリティー》販售，首週銷量達261,580枚，除了登上Oricon週榜首位，還同時刷新當時歷代女性藝人銷量最高的出道單曲。2016年12月31日，出道不足一年即登場NHK紅白歌合戰。2020年10月14日起更名為櫻坂46，以新的團體名義進行活動。<br />\n<br />\n<p class=\"center\"><img src=\"http://www.keyakizaka46.com/img/14/diar/88/mem/member/sub-member-6897_jpg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fwww.keyakizaka46.com%2Fimg%2F14%2Fdiar%2F88%2Fmem%2Fmember%2Fsub-member-6897_jpg.jpg&h=c3ef22e5&s={SIZE}\" /></p><br />\n<br />\n<br />\n日向坂46（Hinatazaka46）是日本大型女子偶像團體，與乃木坂46、欅坂46、吉本坂46同為坂道系列團體之一。團體名稱的「46」與坂道系列其他團體同樣採用英文讀作「Forty-six／フォーティシックス」，而非讀作「四十六／よんじゅうろく」。成立於2015年11月29日，原名為平假名欅坂46（けやき坂46）。起源是由於營運為了給予以特例加入欅坂46的長濱ねる在團內適當的名份而創立，當時定位為欅坂46旗下的分團。2019年2月11日自欅坂46獨立，並改為現名，成為坂道系列第4個系列團體。<br />\n<br />\n<p class=\"center\"><img src=\"http://cdn.keyakizaka46.com/files/14/diary/k46/member/moblog/201807/mob4wEGI2.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fcdn.keyakizaka46.com%2Ffiles%2F14%2Fdiary%2Fk46%2Fmember%2Fmoblog%2F201807%2Fmob4wEGI2.jpg&h=801bf1a6&s={SIZE}\" /></p><br />\n<br />\n<p class=\"center\"><span class=\"red\"><span class=\"xx-large\">成員名單</span></span><br />\n<br />\n櫻坂46<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmRquYkXG1SF9Yq5Ndv6YQT4qyFh3QsWFmeHSDD8DksWR5?filename=0v6tBFx.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F0v6tBFx.png&h=6479ce8b&s={SIZE}\" /><br />\n櫻坂46 2期生<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmXLFKiy78aWfdCwyvh35gD5PkAqWbosjUjxas6ncam8yg?filename=iPir7Nd.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FiPir7Nd.png&h=d849a9e0&s={SIZE}\" /><br />\n<br />\n<br />\n日向坂46<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmRqqoovXkvCdi326KVcC5bdsPQpA1eRGihLmK2zPmL778?filename=hVVReUR.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FhVVReUR.png&h=d55461ca&s={SIZE}\" /><br />\n日向坂46 2期生<br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmcz771hiwcgJxrEy496pc9fEMBJPBLsvTqH5ax9kF1idJ?filename=HD4251x.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHD4251x.png&h=88fb4652&s={SIZE}\" /><br />\n日向坂46 3期生<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmWbc4HzFi26DTDj22jEz91TqT6a71MQSK8y1hTZyUm9Bi?filename=vyon51w.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fvyon51w.png&h=4e8e797a&s={SIZE}\" /><br />\n</p><br />\n<br />\n<br />\n<p class=\"center\"><br />\n<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmSZ9AHMev3HroDVgwNRDc5xYkryQhbppbUn6vHzBQNkhM?filename=zAhHF42.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzAhHF42.jpg&h=68b9c54d&s={SIZE}\" /><br />\n<span class=\"xx-large\">櫻坂46 2ndシングル <span class=\"red\"><strong>「BAN」</strong></span> 好評発売中!!!</span><br />\n<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmPraHkuEoK2gRWb5BiP8n17E6pqoj4G5FQNXCV9Qe11HW?filename=sb8czX0.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fsb8czX0.jpg&h=db2058d2&s={SIZE}\" /><br />\n<span class=\"red\"><span class=\"xx-large\">日向坂46 5thシングル「君しか勝たん」5月26日 予定発売!!!</span></span><br />\n<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmWaquXuG3XAJfkv5ykr4QVkRTjNhPayTJw6dcHG21bSGv?filename=yZVKfpU.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyZVKfpU.jpg&h=35e1828d&s={SIZE}\" /><br />\n<span class=\"red\"><span class=\"xx-large\">「ひらがな推し」Blu-ray 好評発売中!!!</span></span><br />\n<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmW3B1RYW7z4wYExbEQVJDRvKbZZrWDCNK7mdfpMEAb8JQ?filename=mkxsXDg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmkxsXDg.jpg&h=31b6d0ba&s={SIZE}\" /><br />\n<span class=\"red\"><span class=\"xx-large\">欅坂46「THE LAST LIVE」DVD &amp; Blu-ray 好評発売中!!!</span></span><br />\n<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmPvdLFAGhptG3f67QpxrvE4YEKLEhmSbQy5JUsY8myjJQ?filename=ojmkhdE.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FojmkhdE.png&h=a10c1f5e&s={SIZE}\" /><br />\n<span class=\"red\"><span class=\"xx-large\">欅坂46、初ドキュメンタリー映画「僕たちの嘘と真実」好評発売中!!!<br />\n</span></span><br />\n<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmdXasXQL4h3PmBfLGBSh1e6Pz6Bb1gBrqSr2sygZiWtcU?filename=Uc0tq6A.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUc0tq6A.png&h=c3f72d5e&s={SIZE}\" /><br />\n<span class=\"red\"><span class=\"xx-large\">日向坂46、初ドキュメンタリー映画「３年目のデビュー」好評発売中!!!</span></span><br />\n<br />\n<br />\n</p><br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<br />\n<p class=\"center\"><br />\n【成員有幾靚女？】我直接用例子答你。<br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmcpsc8zxSLubqaqgTMvEBLXovfMkRE3ox5j4jsspS8uUD?filename=j1zVRVf.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fj1zVRVf.jpg&h=25e06c87&s={SIZE}\" /><br />\n<br />\n<br />\n<br />\n</p><br />\n<br />\n<p class=\"center\"><span class=\"x-large\"><span class=\"red\">歡迎新人加入</span></span><br />\n<br />\n<a href=\"http://keyakizaka46style.com/sort/keyakizaka46sort.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fkeyakizaka46style.com%2Fsort%2Fkeyakizaka46sort.html&d=Hmcjt6vcQR8GyvD5m8y4dC%2B6%2F41ZtH0%2FHUJlQhqDsdc%3D&h=3008eedc\" target=\"_blank\">http://keyakizaka46style.com/sort/keyakizaka46sort.html</a><br />\n<span class=\"x-large\"><span class=\"red\">請新/舊手足定期體檢，以便加入DD黨</span></span></p><br />\n<br />\n<br />\n<p class=\"center\"><span class=\"red\"><span class=\"x-large\">成員生日時間表</span></span><br />\n<a href=\"https://cutt.ly/PlSnti6\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fcutt.ly%2FPlSnti6&d=Hmcjt6vcQR8GyvD5m8y4dC%2B6%2F41ZtH0%2FHUJlQhqDsdc%3D&h=521d15d1\" target=\"_blank\">https://cutt.ly/PlSnti6</a><br />\n注意! 畢業mb請勿推新po<br />\n</p>"},{"pid":"d5f6064b8da2ed888ba5c9043800b6fe19b27d7b","tid":2498263,"uid":49532,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-04-21T05:00:33.000Z","msg":"<span class=\"xx-large\"><span class=\"red\"><p class=\"center\">Q&amp;A</p></span></span><br />\n<br />\n1）櫻坂46/日向坂46乃何許人也？<br />\n簡單來說，櫻坂46/日向坂46是來自日本的偶像組合，演戲唱歌跳舞等全部都會參與，是正統全能型偶像。 <br />\n<br />\n2）那裡可以購買櫻坂46/日向坂46既有關產品（生寫、CD、海報、寫真集、演唱會等）？ <br />\n一般來說，信和地庫會有存貨，不過價錢就...另外有不少商品需於官方WEBSHOP/會場購入，不過這裡有機會提供代購，要看看手足們的心情。<br />\n<br />\n3）這裡可否討論櫻坂46/日向坂46以外的組合？<br />\n可以。但皆因這裡主要討論櫻坂46/日向坂46，你可以理性討論、攻擊、黑其他成員(禾ru除外)，但講之前請先作好世界大戰的準備。所以勸喻各位尊重member，尊重手足。<br />\n<br />\n4）那麼我要如何見到櫻坂46/日向坂46成員？<br />\n握手會，演唱會...etc，詳細請問手足<br />\n<br />\n5）呢度大佬係？<br />\n連登會員平手友梨奈<br />\n<br />\n6）高登會然橋本奈奈未/連登會然舞木香純是咪HIHI？<br />\n是。因為三槍為人臭串、極度無恥，自然會引起其他手足責罵他。雖然佢犯禁逼走不少手足，但因他臉皮極厚，罵極不走真是無可奈何。<br />\n<br />\n7）點睇響呢套戲？<br />\n必睇指數10粒星<br />\n<br />\n8）有人黎搞事挑戰咁點算？<br />\n對付戇鳩仔既最好方法就係無視佢。眼不見為淨既野，相信大家都明架喇。你有興趣同佢嘈既話你可以繼續，但相信大家都唔會想浪費時間係啲戇鳩仔身上。<br />\n<br />\n9）音驚抽唔抽卡好? (特別鳴謝會然楠木ともり)<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmcwaayAMGgzKG5D4xmbg5oiR4z6rS7kXm8fXHhNRu1JCZ?filename=1Ms5jrg.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1Ms5jrg.jpg&h=519182dd&s={SIZE}\" /><br />\n順手睇埋個警世po佢 <a href=\"https://lih.kg/2483920\" target=\"_blank\">https://lih.kg/2483920</a><br />\n<br />\n<br />\n<span class=\"red\"><span class=\"xx-large\">TEMPLATE:</span></span><br />\n<a href=\"https://docs.google.com/document/d/19V-y30QwjZk9OvSJRqjCUrxM8B92iOq75fUhlIWO3Cg/edit?usp=sharing\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fdocs.google.com%2Fdocument%2Fd%2F19V-y30QwjZk9OvSJRqjCUrxM8B92iOq75fUhlIWO3Cg%2Fedit%3Fusp%3Dsharing&d=Hmcjt6vcQR8GyvD5m8y4dC%2B6%2F41ZtH0%2FHUJlQhqDsdc%3D&h=60b21b53\" target=\"_blank\">https://docs.google.com/document/d/19V-y30QwjZk9OvSJRqjCUrxM8B92iOq75fUhlIWO3Cg/edit?usp=sharing</a><br />\n<span class=\"red\"><span class=\"xx-large\">出PO前請Check下資料有冇update 有既出完po講聲 唔係下下記得改</span></span><br />\n<br />\n<p class=\"center\"><span class=\"red\"> 五大訴求 缺一不可 死黑警同我死撚開 你無資格睇櫻同日向 </span></p>"},{"pid":"f6433113b16764767323b