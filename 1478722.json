e56c31536995f1","tid":1478722,"uid":221192,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-08-17T03:33:43.000Z","msg":"其實個建議唔錯<br />\n提名做下noise，又唔一定選到 <img src=\"/assets/faces/pig/clap.gif\" class=\"hkgmoji\" />"},{"pid":"079299e1c88d1cd2197b9b9c07413f49619db606","tid":1478722,"uid":10778,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T03:37:19.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"d24c3f2b40cb3d3ab3c647cb1f4400eadd9b0cdd","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T03:38:32.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"16c8ba08cc8b31ff5d647789453b54e648f67fed","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T03:57:17.000Z","msg":"<img src=\"/assets/faces/normal/devil.gif\" class=\"hkgmoji\" />"},{"pid":"de8723d3d19d78048f5c2c127554192d2941334c","tid":1478722,"uid":247840,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T04:39:36.000Z","msg":"幫推"},{"pid":"acaaff5843696b0d4e4e5e38147a488ae363bd75","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T05:12:27.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"3900138bbf1c53db98acd97e8bdf17f7d3b56c48","tid":1478722,"uid":33263,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-08-17T05:15:34.000Z","msg":"陳雲：決戰前夕，班農講話，大家要聽（有中文字幕翻譯）。中共準備屠殺香港，為了某些原因而要動殺機，故此大家在今日和明日必須克制，不要出動，不要被忽然叫大家full gear上前線衝鋒的泛民害死！泛民這麼多日潛伏，今日忽然叫大家勇武衝鋒，港共忽然放了戴耀庭出來，高舉港獨和民主中國，唯恐共產黨沒有藉口鎮壓，他們是要害死香港。泛民不想香港有民主的，泛民現在坐穩議席，終身當選，左右通吃，他們要民主普選來幹什麼？<br />\n班農說，這次的香港民權運動，不見舉起米字旗，而是勇敢地舉起了象徵自由的美國國旗，班農認為香港人珍惜美國國旗、愛護美國開國者的自由精神，更甚於某些侮辱美國國旗的美國國民。<br />\n陳雲認為，美國元老的心弦被香港人高舉美國國旗的奮鬥精神撥動了，the chord of their hearts resonates with us, 美國與香港心連心，因為香港重新舉起了美國丟失的自由精神，香港就是新的美國（America re-born in Hong Kong.）"},{"pid":"110070decd06149c72794173cb0908ac2514ce04","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T05:19:50.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"480d7f4e8fdf036b5d51aff075b084f86ec942e9","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T06:09:52.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"e8764c2eea68f81aae6e3eb086858eb445a6bf83","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T06:40:04.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"7da2b35a89c5aafd533f613ecd47d203d4411838","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T06:43:58.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a19873182b6312a3d99b9e3abef210bdd0f62081","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T07:00:30.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5f4b8f8099056f193ccf723558eb60e57e67ec38","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T09:59:35.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"9137563a77e5ece17bc94b0af61027e4ef71ae7d","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T10:38:40.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"e9c4d5f59d39c3ff651dde0eaca54f23d1be99bc","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T10:57:58.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"a62fb9ef754ba302e3905c0188b9a827ef29deb3","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T12:10:40.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"98bdcafe11468171200b734af33d5f1aaafba159","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T13:04:00.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"f06701a0156fe58cc594409da8b0f828fa009291","tid":1478722,"uid":33263,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T10:02:33.000Z","msg":"<a href=\"https://petitions.whitehouse.gov/petition/please-nominate-hong-kong-freedom-fighters-nobel-peace-prize-2020?sfns=mo\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fplease-nominate-hong-kong-freedom-fighters-nobel-peace-prize-2020%3Fsfns%3Dmo&d=GZKRZRfhFQ75XgsIw24e0ajD3B6m7wr0JF9t5bmmazk%3D&h=48eef5ea\" target=\"_blank\">https://petitions.whitehouse.gov/petition/please-nominate-hong-kong-freedom-fighters-nobel-peace-prize-2020?sfns=mo</a><br />\n<br />\n<br />\n【白宮聯署 - 諾貝爾和平獎提名篇】<br />\n<br />\n好我歸隊了。我見好多留言都質疑一樣嘢：「做乜要拎呢個獎？」「咁樣拎呢個獎我寧願唔要」「拎獎會畀中共殺，好似劉曉波咁」bla bla bla，所以我知我又要再講多一次了，唔緊要，來吧。<br />\n<br />\n呢個白宮聯署，請求美國國會幫忙提名香港人競逐諾貝爾和平獎，唔係為個獎，而係為咗保護義士。<br />\n<br />\n香港人爭取民主自由一役，就咁擺上國際係唔夠的，我哋要協助佢「定性」，要令佢變成「和平、自由」嘅象徵。咁樣，中共投鼠忌器，先有機會救到義士。<br />\n<br />\n我知我即使出咗呢個post，都係會有人來潑我冷水，唔緊要，我慣㗎嘞，我只替義士焦急，其他嘢我唔會理，照管來潑冷水吧，我會睇心情去揀人block。<br />\n<br />\n我真係希望呢個聯署，最終可以上到去一個可觀嘅人數，令白宮都震驚嘅人數呀。但孤掌難鳴，我可以負責不停推同埋跟進進度，間中解答疑問，但我傳播力堅有限，大家廣傳的力量，係比我的力量強大好多的<br />\n<br />\n<a href=\"https://petitions.whitehouse.gov/petition/please-nominate-hong-kong-freedom-fighters-nobel-peace-prize-2020\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetitions.whitehouse.gov%2Fpetition%2Fplease-nominate-hong-kong-freedom-fighters-nobel-peace-prize-2020&d=GZKRZRfhFQ75XgsIw24e0ajD3B6m7wr0JF9t5bmmazk%3D&h=ac356d3a\" data-auto-link target=\"_blank\">https://petitions.whitehouse.gov/petition/please-nominate-hong-kong-freedom-fighters-nobel-peace-prize-2020</a><br />\n<br />\n簽完記得 Check email 並 verify。<br />\n<br />\n拜託大家了。"},{"pid":"a03dfae48b789dec8167178560367c9b7c6aadee","tid":1478722,"uid":33263,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T10:02:43.000Z","msg":"Push push <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"33099b6fa265d295bfbfa251022d6e087e26f99f","tid":1478722,"uid":10778,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T10:03:53.000Z","msg":"<img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" />"},{"pid":"c18dbf5a1892f2be4310348f4fae4f64adf2a6bf","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T10:23:41.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"7749a3edd60eeda1b5718bb141e1f3d6135b4666","tid":1478722,"uid":33263,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-19T10:25:30.000Z","msg":"只有咁 先可以幫到義士"},{"pid":"cd3f91e6e265ebe1f7fa0d096a1c13bb60588833","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T10:29:49.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"d4d268642bb77df73f421618f7833fc69a43bea6","tid":1478722,"uid":41901,"like":2,"dislike":0,"score":2,"citedBy":2,"replyTime":"2019-08-19T10:35:56.000Z","msg":"如果律政司照告和平獎得獎者非法集結/縱火/暴動罪就好笑囉..."},{"pid":"6227cb59259b6174a8701c8dfbac5e1102e2cbe0","tid":1478722,"uid":107060,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T15:37:33.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"e131857d38cd006e573d16da35789d484bcc7d4b","tid":1478722,"uid":157994,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-19T20:04:41.000Z","msg":"陳雲大總統<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"f02122edb5e86150d4d