/pig/wine.gif\" class=\"hkgmoji\" />"},{"pid":"b7abdb955f84a7424a8febe2672a2a715ae846dc","tid":2245650,"uid":33995,"like":0,"dislike":0,"score":0,"quote":{"pid":"1a59900884447d0404e8c5376f4ef5409d695372","tid":2245650,"uid":120123,"like":2,"dislike":0,"score":2,"quote":{"pid":"0e72ced246682d4cc34d3e907a895ed563f3d270","tid":2245650,"uid":34189,"like":5,"dislike":0,"score":5,"quote":{"pid":"2e31b05014af88f96766b1a16924ca9bd7fa6e94","tid":2245650,"uid":65638,"like":12,"dislike":2,"score":10,"citedBy":5,"replyTime":"2020-10-16T11:34:30.000Z","msg":"感覺個配方錯左/煲得唔岩姐，中醫咁勁點會醫唔好"},"citedBy":1,"replyTime":"2020-10-16T11:39:59.000Z","msg":"中醫講調理，係要D時間，俾多一年應該好返<img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-16T12:15:04.000Z","msg":"咁我覺得咁樣賴落中醫度又唔公平。因為佢根本都冇睇醫生.....<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-16T12:22:21.000Z","msg":"根本就係<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n而家係阿嫲自把自為自己醫<br />\n如果個情況係阿嫲亂比西藥出事<br />\n咁就係西醫問題？<img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" />"},{"pid":"686122444625826611821f1bca5696202f7ba38e","tid":2245650,"uid":120123,"like":0,"dislike":0,"score":0,"quote":{"pid":"b7abdb955f84a7424a8febe2672a2a715ae846dc","tid":2245650,"uid":33995,"like":0,"dislike":0,"score":0,"quote":{"pid":"1a59900884447d0404e8c5376f4ef5409d695372","tid":2245650,"uid":120123,"like":2,"dislike":0,"score":2,"quote":{"pid":"0e72ced246682d4cc34d3e907a895ed563f3d270","tid":2245650,"uid":34189,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-10-16T11:39:59.000Z","msg":"中醫講調理，係要D時間，俾多一年應該好返<img src=\"/assets/faces/lm2/abomb.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-16T12:15:04.000Z","msg":"咁我覺得咁樣賴落中醫度又唔公平。因為佢根本都冇睇醫生.....<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-16T12:22:21.000Z","msg":"根本就係<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n而家係阿嫲自把自為自己醫<br />\n如果個情況係阿嫲亂比西藥出事<br />\n咁就係西醫問題？<img src=\"/assets/faces/cat/pussy1.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-16T12:23:42.000Z","msg":"雖然我都唔信中醫。<br />\n但係一件事還一件事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />。<br />\n你自己亂尻煲藥，純粹係個人低能。<br />\n講真，成藥我自己都唔會亂食，就算西藥。我寧願睇醫生<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"e1f1c951536deac4d3d04bf99b2b25c56827f83f","tid":2245650,"uid":210669,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T12:24:03.000Z","msg":"on9<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}