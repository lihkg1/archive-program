=\"https://i.ibb.co/Qb0CjnJ/20190320-WTC-600x600.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.ibb.co%2FQb0CjnJ%2F20190320-WTC-600x600.jpg&h=e56885f0&s={SIZE}\" /><br />\n依個app就要客人upload購物收據先儲到分，咁所以個商場每日做到幾多生意，邊間鋪頭生意額最多可以盡在掌握<br />\n但係聽人講尋日個場靜到爆炸，4樓儲分櫃位完全唔使排隊，就連大陸客換coupon個counter都仲有大把劵可以換，講緊以前中午就已經比大陸客換哂。星期日最旺既日子都比平日靜，甚至之前八號風球個場關左大半日都冇咁靜。依家有一日係咁已經大地震，真係想像唔到如果每個星期都有一次係咁會點<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"},{"pid":"9e31e6f70b658861eea06aa89ca2a9b81c9aaf1d","tid":1317400,"uid":264192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T04:54:29.000Z","msg":"推"},{"pid":"0cc959d48848d234c115042158e8c159ee62d722","tid":1317400,"uid":206021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T05:01:17.000Z","msg":"Push"},{"pid":"e6a6df87277255b885858d52ebc6a789e15301fa","tid":1317400,"uid":264192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T05:57:00.000Z","msg":"推"},{"pid":"6b5471b98c8285c24441e1ea60a45db145c4acc1","tid":1317400,"uid":28302,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T06:05:14.000Z","msg":"推到上熱門"},{"pid":"9b858e53b4e947cc08aa349f7784fffb544115da","tid":1317400,"uid":24007,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T06:08:42.000Z","msg":"PUSH"},{"pid":"04883ed9e5235b915146a893a6b9ec53e4a681aa","tid":1317400,"uid":264192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T06:21:38.000Z","msg":"推"},{"pid":"e75bd7440d11374f14ec14ce2cb14fc150bb7b74","tid":1317400,"uid":237372,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T06:51:34.000Z","msg":"推"},{"pid":"a7d388736a09a1c2d68759c524254433268208e3","tid":1317400,"uid":12662,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-15T06:52:09.000Z","msg":"<img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lm2/dust.gif\" class=\"hkgmoji