>\n同健身狗叫你幫手填問卷,填填下變左碌卡既心理變化一樣"},"citedBy":0,"replyTime":"2019-11-29T16:57:06.000Z","msg":"有必要搞藍絲版"},{"pid":"a1e90cca3d607493b07689f6c63f6c2566ae6617","tid":1762482,"uid":334806,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-29T16:57:39.000Z","msg":"藍絲都不滿777啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n愈搞愈亂"},{"pid":"3351c4bad3891796b9c4dfb110e3804faf9eb92a","tid":1762482,"uid":78546,"like":0,"dislike":0,"score":0,"quote":{"pid":"2f820b73657595ad2c7863fa042eddfcae2507db","tid":1762482,"uid":262674,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9ffaabf76cd1385b2f140ad4ba1c9c5a3da2784","tid":1762482,"uid":212626,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2019-11-29T15:28:25.000Z","msg":"<img src=\"https://na.cx/i/R7KNiYJ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FR7KNiYJ.jpg&h=6740773a&s={SIZE}\" /><br />\n香港民研一條調查問題"},"citedBy":2,"replyTime":"2019-11-29T15:41:30.000Z","msg":"老實講<br />\n<br />\n啲賤警狗使乜怕呀  <img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-11-29T16:58:52.000Z","msg":"拉去新疆嶺比黑警姦<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"14b36537a46a8bcbe72ef642ecc16bc00ad98b87","tid":1762482,"uid":238920,"like":0,"dislike":0,"score":0,"quote":{"pid":"3351c4bad3891796b9c4dfb110e3804faf9eb92a","tid":1762482,"uid":78546,"like":0,"dislike":0,"score":0,"quote":{"pid":"2f820b73657595ad2c7863fa042eddfcae2507db","tid":1762482,"uid":262674,"like":0,"dislike":0,"score":0,"quote":{"pid":"c9ffaabf76cd1385b2f140ad4ba1c9c5a3da2784","tid":1762482,"uid":212626,"like":9,"dislike":0,"score":9,"citedBy":1,"replyTime":"2019-11-29T15:28:25.000Z","msg":"<img src=\"https://na.cx/i/R7KNiYJ.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FR7KNiYJ.jpg&h=6740773a&s={SIZE}\" /><br />\n香港民研一條調查問題"},"citedBy":2,"replyTime":"2019-11-29T15:41:30.000Z","msg":"老實講<br />\n<br />\n啲賤警狗使乜怕呀  <img src=\"/assets/f