eplyTime":"2021-01-19T11:51:37.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"0ab237a0e4c31f8d04ad9a04ef587344ab45a101","tid":2372110,"uid":49329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-19T15:03:03.000Z","msg":"<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"21c38f2e3b024bb4b76dcc58abb9b4f88bef5b2c","tid":2372110,"uid":92448,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-19T15:31:31.000Z","msg":"所有敢係支那報導真相都真心佩服, 包括當地人<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"a9dd751aa0614b23b484529398a5c268efabcd8c","tid":2372110,"uid":267167,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-19T17:16:20.000Z","msg":"Pish strong post"},{"pid":"fab3bc08dbeb88822df804d7c58d106956e13f47","tid":2372110,"uid":48080,"like":0,"dislike":0,"score":0,"quote":{"pid":"15496d00af1703a795cecf915be917b116341ef4","tid":2372110,"uid":31215,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-19T11:30:13.000Z","msg":"You racist racist racist!<br />\n好嬲好嬲<img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/angry.gif\" class=\"hkgmoji\" /><br />\n病毒冇國籍<img src=\"/assets/faces/pig/knife.gif\" class=\"