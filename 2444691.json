normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"a11d795b0af43717ccaa89c1e5912ccf16d9f203","tid":2444691,"uid":143783,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-13T15:08:14.000Z","msg":"冇，過唔到咪兜多個圈，通常出唔到外圈都係因為啲陰陽線<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7e5234fa120ba7dc5033cdeee9784f86dabde03e","tid":2444691,"uid":5574,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-13T15:10:20.000Z","msg":"出內圈先安全, 睇右邊最清楚<br />\n當然架車起圍慢就唔好啦"},{"pid":"c35fb9afee9d1067677f61dd984b571e546f7ce0","tid":2444691,"uid":7008,"like":0,"dislike":0,"score":0,"quote":{"pid":"a11d795b0af43717ccaa89c1e5912ccf16d9f203","tid":2444691,"uid":143783,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-13T15:08:14.000Z","msg":"冇，過唔到咪兜多個圈，通常出唔到外圈都係因為啲陰陽線<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-13T15:14:45.000Z","msg":"官塘<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n偉業街迴旋處同開源道都係內圈唔俾出<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n仲有入藍田<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<br />\n每個星期六日都有人踩單白出<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"ece55b6d547ee2fb7751acd570e71345dbd25c33","tid":2444691,"uid":271857,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-03-13T15:16:46.000Z","msg":"內圈緊係打住燈跟外圈車尾碌位<br />\n再眼尾望L住司機位有無想扭軚出動作<br />\n如果一齊出睇下係咪兩條線<br />\n如果雙線就二線比油出再爬佢頭威威<br />\n如果單線就局跟佢車尾出<br />\n如果佢唔係出都係跟佢車尾出<br />\n車尾都有車就兜多個圈<br />\n<br />\n除非你架車好L快<br />\n佢又唔係快車種<br />\n咁就可以包9佢頭再盞兩下死火燈威威。"},{"pid":"95efb37493fe7a37040a3052cf7f0a9fcf0cbacd","tid":2444691,"uid":143783,"like":0,"dislike":0,"score":0,"quote":{"pid":"c35fb9afee9d1067677f61dd984b571e546f7ce0","tid":2444691,"uid":7008,"like":0,"dislike":0,"score":0,"quote":{"pid":"a11d795b0af43717ccaa89c1e5912ccf16d9f203","tid":2444691,"uid":143783,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-13T15:08:14.000Z","msg":"冇，過唔到咪兜多個圈，通常出唔到外圈都係因為啲陰陽線<img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/fs/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-03-13T15:14:45.000Z","msg":"官塘<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n偉業街迴旋處同開源道都係內圈唔俾出<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n仲有入藍田<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n<br />\n每個星期六日都有人踩單白出<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-03-13T15:20:15.000Z","msg":"斧山道落山入鳳德道，有次入圈，過咗橋個出口諗住cut出去，點知單白<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n周圍一架車都冇，不過都係乖乖地開行油行多個圈<img src=\"/assets/faces/fs/bye.gif\" class=\"hkgmoji\" />"},{"pid":"b158e40f1574e8ccea438788c447ab8c138a7f47","tid":2444691,"uid":67116,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-03-13T16:01:17.000Z","msg":"其實內圈要決就係唔可以急<br />\n一急就危<br />\ncut唔到外圈出圈就收慢 最多行多個圈"},{"pid":"a5503128fc8358854c6737ea7bd7be26b45c0ab0","tid":2444691,"uid":161621,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-03-13T16:16:09.000Z","msg":"新式係行內圈優先架，識唔識架"}]}