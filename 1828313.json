assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a09ae2eab8198c1efaad18c385430aa76322a087","tid":1828313,"uid":10612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T05:36:24.000Z","msg":"1.初見泉（不會讓你受身哦，星落）"},{"pid":"8dcb3e37485de6ed4b83d03264877daaa9660c22","tid":1828313,"uid":25169,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-18T05:40:49.000Z","msg":"<img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"a97d5a19ebc10bdd805264a09cf396ebda5f5c5f","tid":1828313,"uid":28792,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-18T05:43:50.000Z","msg":"二虎武力封咗頂啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n著哂甲打到王馬仆街+教完王馬狀態唔好<br />\n都可以用二虎流再打到預借王馬仆街<br />\n再同白二虎打到同歸於盡<br />\n你睇返練完奧義嘅王馬已經好勁，都仲可以唔知情嘅情況比白二虎埋身打中+開預借"},{"pid":"3a75a6a412ef8223cf74cfb566b75ffcc9bbe325","tid":1828313,"uid":100772,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-18T05:47:21.000Z","msg":"冇睇奧米迦 套野有冇王馬?"},{"pid":"b9eb1c835dd8a21a5e5eb59b5130a6857a52f638","tid":1828313,"uid":40862,"like":0,"dislike":0,"score":0,"quote":{"pid":"3a75a6a412ef8223cf74cfb566b75ffcc9bbe325","tid":1828313,"uid":100772,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-18T05:47:21.000Z","msg":"冇睇奧米迦 套野有冇王馬?"},"citedBy":1,"replyTime":"2020-01-18T05:50:31.000Z","msg":"死撚左，出左個懷疑複製人"},{"pid":"bfa2910d3ec5e1c80e1fe4226dced952150290a9","tid":1828313,"uid":180975,"like":0,"dislike":3,"score":-3,"quote":{"pid":"b9eb1c835dd8a21a5e5eb59b5130a6857a52f638","tid":1828313,"uid":40862,"like":0,"dislike":0,"score":0,"quote":{"pid":"3a75a6a412ef8223cf74cfb566b75ffcc9bbe325","tid":1828313,"uid":100772,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-18T05:47:21.000Z","msg":"冇睇奧米迦 套野有冇王馬?"},"citedBy":1,"replyTime":"2020-01-18T05:50:31.000Z","msg":"死撚左，出左個懷疑複製人"},"citedBy":0,"replyTime":"2020-01-18T07:34:00.000Z","msg":"查實我思疑王馬同龍鬼可能係同一個家族嘅人，甚至兩兄<br />\n<br />\n弟嚟。王馬當年唔知咩原因流落咗去十鬼蛇區。漫畫講到<br />\n<br />\n龍鬼嘅臥王流係佢阿爺教，而臥王流係二虎流前身。所以<br />\n<br />\n我諗會唔會係二虎本身就係龍鬼阿爺嘅徒弟，之後改良臥<br />\n<br />\n王流，用自己個名嚟命名自己改良後嘅流派。跟住喺十鬼<br />\n<br />\n蛇區見到王馬就打算傳返佢哋家傳嘅武術畀佢。甚至可能<br />\n<br />\n二虎係一早知道臥王家有個棄嬰流落咗去十鬼蛇區先特登<br />\n<br />\n去撞佢。"},{"pid":"82b759bb7d2f9a49b9799633b5b74010da6126a7","tid":1828313,"uid":243849,"like":0,"dislike":0,"score":0,"quote":{"pid":"9f26fd625169a3127b83946b45a0bb9368292192","tid":1828313,"uid":159183,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-18T04:04:27.000Z","msg":"都幾認同樓主個頭十<br />\n但我會加埋佐助"},"citedBy":0,"replyTime":"2020-01-18T10:21:50.000Z","msg":"佐助有諗過 不過最後都係揀咗剎那 好想睇奧米迦佐助勁咗幾多"},{"pid":"47514b957f9002f8ecaa1b794fad933cf81c8f65","tid":1828313,"uid":243849,"like":0,"dislike":0,"score":0,"quote":{"pid":"48ff0cc659be5d1757615b1c99017c7ca262cae3","tid":1828313,"uid":22481,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-18T03:49:40.000Z","msg":"鬥神武士無傷狀態勁過王馬啦"},"citedBy":0,"replyTime":"2020-01-18T10:23:41.000Z","msg":"鬥神唔敢講 但武士對王馬都係重傷狀態打 王馬贏自然擺佢先 仲要鬼鏖剋制爆芯"},{"pid":"90ff1460e501b23094a0e7711e5eb8bbc18b11de","tid":1828313,"uid":9938,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2020-01-18T10:30:50.000Z","msg":"而家Omega 講到春男同關林都可以算係代表選手級數<br />\n就覺得而家拳願會好似冇哂勁人咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"eed020a395fb17ff16d5e3e4ce7441650656dffe","tid":1828313,"uid":16384,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-21T02:28:53.000Z","msg":"唔好玩啦鬥神點會咁低<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n個德國佬又係咩事<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"722bd3f5b774ebccf68a12c1c0ee98bd93ecf2b9","tid":1828313,"uid":150544,"like":0,"dislike":0,"score":0,"quote":{"pid":"a97d5a19ebc10bdd805264a09cf396ebda5f5c5f","tid":1828313,"uid":28792,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-18T05:43:50.000Z","msg":"二虎武力封咗頂啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n著哂甲打到王馬仆街+教完王馬狀態唔好<br />\n都可以用二虎流再打到預借王馬仆街<br />\n再同白二虎打到同歸於盡<br />\n你睇返練完奧義嘅王馬已經好勁，都仲可以唔知情嘅情況比白二虎埋身打中+開預借"},"citedBy":0,"replyTime":"2020-01-21T02:32:58.000Z","msg":"永遠死人都係最強"},{"pid":"39bae3d666c1551d9cbef4184f4f99e74237c9a8","tid":1828313,"uid":48791,"like":0,"dislike":0,"score":0,"quote":{"pid":"eed020a395fb17ff16d5e3e4ce7441650656dffe","tid":1828313,"uid":16384,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-01-21T02:28:53.000Z","msg":"唔好玩啦鬥神點會咁低<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n個德國佬又係咩事<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-21T03:44:01.000Z","msg":"鬥神可以贏到1~5邊個先<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5f7417cf18e62f3d8f280d646b69a09e853c6dd3","tid":1828313,"uid":47288,"like":0,"dislike":0,"score":0,"quote":{"pid":"90ff1460e501b23094a0e7711e5eb8bbc18b11de","tid":1828313,"uid":9938,"like":0,"dislike":2,"score":-2,"citedBy":1,"replyTime":"2020-01-18T10:30:50.000Z","msg":"而家Omega 講到春男同關林都可以算係代表選手級數<br />\n就覺得而家拳願會好似冇哂勁人咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-22T05:07:27.000Z","msg":"但係關林同春男未打絕命個陣已經響哂朵喇喎<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n佢地個陣都係不敗之身黎<br />\n仲未計春男之後練摔角會勁咗幾多<br />\n你話派仁王的驅田就話啫<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1d5cff841aa35cb90bb2185f8905b691bbfa4781","tid":1828313,"uid":20244,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-22T05:18:40.000Z","msg":"個人認為王馬係因應有招外掛鬼鏖先入到頭3，無招鬼鏖無可能贏到武士同德國佬(唔夠攻擊力)<br />\n仲有雷神又係超勁，無先之先嘅人都好難贏"},{"pid":"e0bbd167dc5fd6c4a481f1d6056bf1a940d12a28","tid":1828313,"uid":13808,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-01-22T05:34:05.000Z","msg":"如果出到星落一定係初見最強<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}