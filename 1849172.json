:33.000Z","msg":"睇rainbow條臭雞講到武漢好輕鬆咁"},{"pid":"5eb1dc06d696fc31a98f30ab77feed44d1099aca","tid":1849172,"uid":122275,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T02:22:24.000Z","msg":"一個禮拜就謝左咪撚玩啦<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n潛伏期都未過啦"},{"pid":"24398d74a8da69e2c1ddce6b7f35a4d96427897f","tid":1849172,"uid":254729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T07:04:44.000Z","msg":"<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" />"},{"pid":"542e22e351c576ef84b785ba162dc0c66358b06f","tid":1849172,"uid":254729,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T07:18:45.000Z","msg":"【預測準確】肺炎繼續幾何級數上升 38日後可感染13億人<br />\n<a href=\"https://lih.kg/1849380\" data-auto-link target=\"_blank\">https://lih.kg/1849380</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<img src=\"/assets/faces/lny/censored.gif\" class=\"hkgmoji\" />"},{"pid":"e5ff55cebf11b9c67e71c79516e384d8e906baa8","tid":1849172,"uid":344033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T07:36:53.000Z","msg":"<span style=\"color: green;\"><span style=\"font-size: x-large;\">請幫手正評！請廣傳！</span></span><br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: red;\">手足護目鏡抗沙士<br />\n<a href=\"https://lih.kg/1845419\" data-auto-link target=\"_blank\">https://lih.kg/1845419</a></span></span><br />\n<br />\n<br />\n<a href=\"https://www.facebook.com/112357283631796/posts/117867026414155/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F117867026414155%2F%3Fd%3Dn&d=5FuYkWQ3QtYmval6ncx7JoZnnstt8OVeiO3WagLZNiI%3D&h=0073021a\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/117867026414155/?d=n</a><br />\n<br />\n手足裝備抗沙士：護目鏡<br />\n整體分析：<a href=\"https://www.facebook.com/112357283631796/posts/116690396531818/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F116690396531818%2F%3Fd%3Dn&d=5FuYkWQ3QtYmval6ncx7JoZnnstt8OVeiO3WagLZNiI%3D&h=da927e4f\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/116690396531818/?d=n</a><br />\n<br />\n個別分析：<br />\n護目鏡：<a href=\"https://lih.kg/1845419\" data-auto-link target=\"_blank\">https://lih.kg/1845419</a><br />\n防毒面具/濾罐：<a href=\"https://lih.kg/1848447\" data-auto-link target=\"_blank\">https://lih.kg/1848447</a><br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n首選：Sellstrom S80225/S80226 Wildland Fire Goggles （戴眼鏡都用得）<br />\n<a href=\"https://www.amazon.com/Sellstrom-Wildland-Goggles-Non-Vented-Anti-Fog/dp/B07DJVPL9Q\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.amazon.com%2FSellstrom-Wildland-Goggles-Non-Vented-Anti-Fog%2Fdp%2FB07DJVPL9Q&d=5FuYkWQ3QtYmval6ncx7JoZnnstt8OVeiO3WagLZNiI%3D&h=28d9113b\" data-auto-link target=\"_blank\">https://www.amazon.com/Sellstrom-Wildland-Goggles-Non-Vented-Anti-Fog/dp/B07DJVPL9Q</a><br />\n<br />\nSellstrom 依款眼罩，上年九月果陣，已經係前線手足標準裝備，有手足認證，包保放心！其中，依款眼罩有兩大特點。<br />\n<br />\n第一，依款眼罩寫明係 non-vented，即係氣密。戴左之後，基本上就阻隔左外面嘅空氣進入眼罩，所以擋到TG，亦都擋到帶病毒嘅飛沫同空氣，乜春都入唔到眼。依個亦都係佢可以俾美國消防員救山火果陣用嘅原因。氣密係眼罩第一重要條件，如果唔係氣密，病毒同TG都可以經眼罩邊位入眼，大陸衛健委都講明病毒傳染性不斷上升，美國有教授都講左武漢沙士嘅reproductive rate 高過曬佢見過佢嘅病毒，證明今次係非常嚴重，必須要用高規格嘅產品保護自己！<br />\n<br />\n第二，依款眼罩經過 ANSI Z87+ 嘅驗證，保護性極高！<br />\nANSI Z87+嘅定義如下：<br />\n&lsquo;Each product must go through rigorous third-party testing which simulates hazards such as impact by flying objects and debris, high mass impact, and sharp object penetration.&rsquo;<br />\n根據網上一個對ANSI Z87+ 眼罩嘅測試，散彈槍都射佢唔穿，所以依個standard非常高，亦都只有依種眼罩嘅保護性先可以保護前線免受橡膠子彈同布袋彈威脅。<br />\n<br />\n但係有巴打指出部份面型有機會有gap, 建議如果屋企多人買多幾種唔同牌子試下<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n次選：<br />\nPyramex CAPSTONE (G504DT或其他型號）<br />\n<a href=\"https://www.amazon.com/Pyramex-Capstone-Direct-Indirect-Anti-Fog/dp/B003UUEW88\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.amazon.com%2FPyramex-Capstone-Direct-Indirect-Anti-Fog%2Fdp%2FB003UUEW88&d=5FuYkWQ3QtYmval6ncx7JoZnnstt8OVeiO3WagLZNiI%3D&h=33224e85\" data-auto-link target=\"_blank\">https://www.amazon.com/Pyramex-Capstone-Direct-Indirect-Anti-Fog/dp/B003UUEW88</a><br />\n<br />\n第一，依款眼罩有氣密帽，應該同樣做到氣密效果，但係因為佢嘅氣密帽可以拆卸，多左個連接位，所以氣密保護性會低小小（始終多個連接位就多個出錯機<br />\n會）。（巴打指出Pyramex Capstone 只係indirect vent唔係non-vented，如果有心改，可以買熱熔膠封透氣孔）<br />\n第二，依款眼罩經過D3 測試，證實可以防水滴同化學劑嘅飛淺，理論上有足夠防水性能。<br />\n第三，依款眼罩經過MIL-PRF 32432 美軍標準測試，對子彈衝有一定防禦力<br />\n<br />\nUber Ultravision Gas Goggle <br />\n<a href=\"https://www.uvex-safety.com/en/products/safety-glasses/6712/uvex-ultravision-wide-vision-goggle/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.uvex-safety.com%2Fen%2Fproducts%2Fsafety-glasses%2F6712%2Fuvex-ultravision-wide-vision-goggle%2F&d=5FuYkWQ3QtYmval6ncx7JoZnnstt8OVeiO3WagLZNiI%3D&h=5ee4dd6a\" data-auto-link target=\"_blank\">https://www.uvex-safety.com/en/products/safety-glasses/6712/uvex-ultravision-wide-vision-goggle/</a><br />\n<br />\n第一，佢寫明係gas-tight， 同埋 no ventilation, 所以同樣做到non-vented 效果。<br />\n第二，佢過左歐盟嘅EN166, EN170 測試，寫明可以防fine dust particle （smaller than 5 micron), 可防超細粒子，令人用得比較放心，同埋EN166 嘅test，對防衝擊力一定有一定要求，所以亦適合發夢<br />\n第三，官網寫話戴眼鏡都用得<br />\n<br />\n3M 1621 護目鏡<br />\n<br />\n雖然唔係完全氣密，但係過左D3 test 同 ANSI Z87.1 （冇過plus 果個），對飛沫有一定預防能力，依幾日試過，除左大霧啲之外其他都ok, 包得幾好，重點係好便，五金舖$20-30 就有，性價比最高！<br />\n巴打指出大霧，唔適合返工<br />\n<br />\n泳鏡（仲易買過平光鏡）<br />\n<br />\n泳鏡顧名思義，就係for 遊水，氣密效果有一定嘅保證，同埋求其一間運動鋪都可以買到，買近視鏡嘅話眼睛都唔洗戴，幾十蚊就有，保護性一定好過平光鏡，不過如果係講嘢都要除口罩，放屁要除褲，戴左帽可能腦都用唔到嘅人，可能佢戴左就會睇唔野。<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n8.5 最新護目鏡實測 條帶戴高D 鼻位GAP就會消失!!! &amp; 前線超過400位豬嘴實測<br />\n<a href=\"https://lih.kg/1411916\" data-auto-link target=\"_blank\">https://lih.kg/1411916</a><br />\n<br />\n大家幫幫手，like &amp; share 等多啲人睇到！<br />\n<br />\n<a href=\"https://youtu.be/dE5IweYn3T4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FdE5IweYn3T4&d=5FuYkWQ3QtYmval6ncx7JoZnnstt8OVeiO3WagLZNiI%3D&h=d89c9de7\" data-auto-link target=\"_blank\">https://youtu.be/dE5IweYn3T4</a><br />\n清洗參考<br />\n<br />\n建議清潔步驟<br />\n番到屋企，洗手<br />\n唔好除眼罩住，用火酒紙清潔眼罩外部<br />\n除眼罩口罩，再用酒精/消毒清潔劑/稀釋漂白水清潔成個眼罩<br />\n<br />\n<a href=\"https://www.facebook.com/112044766987392/posts/119490526242816/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112044766987392%2Fposts%2F119490526242816%2F%3Fd%3Dn&d=5FuYkWQ3QtYmval6ncx7JoZnnstt8OVeiO3WagLZNiI%3D&h=9d046744\" data-auto-link target=\"_blank\">https://www.facebook.com/112044766987392/posts/119490526242816/?d=n</a><br />\n酒精搓手液 vs 洗手梘液"},{"pid":"166de8651590bc18e33964e1a95a4f3411d1eb07","tid":1849172,"uid":162477,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-29T07:39:11.000Z","msg":"因為世衛條黑九教路，叫習包孑唔好再放咁多料，再放就變疫區！"},{"pid":"13dc0972217b605d955c4d7fdb042bb0d2bbf287","tid":1849172,"uid":33099,"like":0,"dislike":0,"score":0,"quote":{"pid":"166de8651590bc18e33964e1a95a4f3411d1eb07","tid":1849172,"uid":162477,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-29T07:39:11.000Z","msg":"因為世衛條黑九教路，叫習包孑唔好再放咁多料，再放就變疫區！"},"citedBy":0,"replyTime":"2020-01-29T11:43:37.000Z","msg":"條黑柴如無意外之後會有個政協位做"},{"pid":"59e394de1a750711bef14ba38fa2e033a880d44a","tid":1849172,"uid":194298,"like":0,"dislike":0,"score":0,"quote":{"pid":"6a0c0782d35a737274895f5f604f78f37e33572f","tid":1849172,"uid":254729,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-29T01:56:02.000Z","msg":"<a href=\"https://twitter.com/faith8964/status/1220347471588548608?s=21\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Ffaith8964%2Fstatus%2F1220347471588548608%3Fs%3D21&d=5FuYkWQ3QtYmval6ncx7JoZnnstt8OVeiO3WagLZNiI%3D&h=2c0bb532\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Ftwitter.com%2Ffaith8964%2Fstatus%2F1220347471588548608%3Fs%3D21&h=61d5ec04\" data-auto-link target=\"_blank\">https://twitter.com/faith8964/status/1220347471588548608?s=21</a><br />\n<br />\n武漢醫院內情況"},"citedBy":1,"replyT