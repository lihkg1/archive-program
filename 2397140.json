"851efcb7e1c57f67d23ce2bc82b765af33bb7361","tid":2397140,"uid":6788,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2021-02-06T19:14:23.000Z","msg":"呢排睇左片學煎<br />\n<br />\n要攤廿分鐘等扒心都接近室溫<br />\n如果唔係煎完冇機會入面係凍嘅<br />\n<br />\n煎前5分鐘落鹽 黑胡椒醃<br />\n可以重手啲鋪到密質質<br />\n<br />\n個鑊要夠熱燒到到出白煙<br />\n<br />\n煎幾耐睇塊扒幾厚 1cm每邊30秒都夠<br />\n<br />\n夠鍾就熄火 用個鑊餘溫融牛油 將牛油淋塊扒<br />\n<br />\n離鑊等5分鐘先切<br />\n<br />\n極簡單又好食 唔撚會再出街食<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"80704b22254ad887a0f0944f677179726ab81ee3","tid":2397140,"uid":350233,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-06T19:19:02.000Z","msg":"依個幾多成？<br />\n3成？"},{"pid":"8ff525a325013ed8fe61c3ba34c85f8530611f56","tid":2397140,"uid":63119,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-06T19:23:33.000Z","msg":"底面太熟，中間就太生<br />\n係咪未解好凍就煎？"},{"pid":"fea975875bbbe5c850493b488df04e942c4379eb","tid":2397140,"uid":133525,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-06T20:52:25.000Z","msg":"衰撚過狗飯"},{"pid":"6a2bb4de4a1d15b552d28a2ece41d97e9c77c044","tid":2397140,"uid":384590,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-06T20:56:59.000Z","msg":"煎得ok"}]}