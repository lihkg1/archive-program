d7c4adb4a9616068e1ee","tid":2003301,"uid":1886,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-05-06T00:45:08.000Z","msg":"郭文貴：中共過埋2020年仲未收皮我就跳樓死！<br />\n<a href=\"http://news.ltn.com.tw/news/world/breakingnews/2661924\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F2661924&d=h%2B9cq0gO3qQVjfypIz7KRF8MSy0xNzs2bKpftArA8vk%3D&h=e133b5c4\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F2661924&h=4b21dc27\" target=\"_blank\">http://news.ltn.com.tw/news/world/breakingnews/2661924</a><br />\n<br />\n<span style=\"font-size: small;\"><span style=\"color: red;\">2019-01-04 16:32:40</span></span><br />\n<br />\n<div style=\"text-align: center;\"><img src=\"https://upload.cc/i1/2019/12/06/4kDjBt.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2019%2F12%2F06%2F4kDjBt.png&h=2d3a0463&s={SIZE}\" /><br />\n</div><br />\n<br />\n一直預告西方世界將與中國全面對抗的郭文貴還強調：「<span style=\"color: red;\"><strong>2020年是結束共產黨在中國的最後一年，否則文貴就從那18樓跳下去，大家要記住我的承諾。</strong></span>」<br />\n<br />\n<br />\n郭文貴又爆料：中共將於今年6/4滅亡<br />\n<a href=\"https://news.ltn.com.tw/news/politics/breakingnews/3071249\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fpolitics%2Fbreakingnews%2F3071249&d=h%2B9cq0gO3qQVjfypIz7KRF8MSy0xNzs2bKpftArA8vk%3D&h=cd43a933\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fpolitics%2Fbreakingnews%2F3071249&h=2b44cc57\" target=\"_blank\">https://news.ltn.com.tw/news/politics/breakingnews/3071249</a><br />\n<br />\n<span style=\"color: red;\"><span style=\"font-size: small;\">2020-02-18 01:35:08</span></span><br />\n<br />\n<div style=\"text-align: center;\"><img src=\"https://img.ltn.com.tw/Upload/news/600/2020/02/18/phpkwmUEi.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.ltn.com.tw%2FUpload%2Fnews%2F600%2F2020%2F02%2F18%2FphpkwmUEi.jpg&h=81372548&s={SIZE}\" /></div><br />\n<br />\n流亡美國的中國富商郭文貴不定時暴露中國高層黑幕，2月15日在直播中又爆料，共產黨推行的中國夢已經完全不可能實現，<strong><span style=\"color: red;\">今年6月4日「沒有共產黨的新中國一定會成立」，屆時會由世界上許多國家共同宣布。</span></strong>"},{"pid":"97f9de2214a9a215086599281796856559dc3d7d","tid":2003301,"uid":110832,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-05-06T00:45:41.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"f5cbae7b1f06b9b3005a4b4b420efac607a6dc90","tid":2003301,"uid":110832,"like":0,"dislike":0,"score":0,"quote":{"pid":"051a278aa293fbb4c5a6d7c4adb4a9616068e1ee","tid":2003301,"uid":1886,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2020-05-06T00:45:08.000Z","msg":"郭文貴：中共過埋2020年仲未收皮我就跳樓死！<br />\n<a href=\"http://news.ltn.com.tw/news/world/breakingnews/2661924\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F2661924&d=h%2B9cq0gO3qQVjfypIz7KRF8MSy0xNzs2bKpftArA8vk%3D&h=e133b5c4\" data-ef-url=\"https://embed.lih.kg/frame?u=http%3A%2F%2Fnews.ltn.com.tw%2Fnews%2Fworld%2Fbreakingnews%2F2661924&h=4b21dc27\" target=\"_blank\">http://news.ltn.com.tw/news/world/breakingnews/2661924</a><br />\n<br />\n<span style=\"font-size: small;\"><span style=\"color: red;\">2019-01-04 16:32:40</span></span><br />\n<br />\n<div style=\"text-align: center;\"><img src=\"https://upload.cc/i1/2019/12/06/4kDjBt.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fupload.cc%2Fi1%2F2019%2F12%2F06%2F4kDjBt.png&h=2d3a0463&s={SIZE}\" /><br />\n</div><br />\n<br />\n一直預告西方世界將與中國全面對抗的郭文貴還強調：「<span style=\"color: red;\"><strong>2020年是結束共產黨在中國的最後一年，否則文貴就從那18樓跳下去，大家要記住我的承諾。</strong></span>」<br />\n<br />\n<br />\n郭文貴又爆料：中共將於今年6/4滅亡<br />\n<a href=\"https://news.ltn.com.tw/news/politics/breakingnews/3071249\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fnews.ltn.com.tw%2F