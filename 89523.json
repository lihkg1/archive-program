f5cae4ae4b3e94f822fc6bf0eb15b22f","tid":89523,"uid":9163,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-21T20:33:58.000Z","msg":"垃圾 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"45c03323d1d0a7c6333bcef5354f7694ba837340","tid":89523,"uid":2404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-22T04:56:18.000Z","msg":"成日收唔到，又慢，你用得到佢12GB先算啦"},{"pid":"790b71596f98814e24c21759ad3e0aab5aac4648","tid":89523,"uid":266,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-22T05:04:18.000Z","msg":"狗也不屌"},{"pid":"6e65d836d861078b78dbcd80c1b920ad2dfbea6d","tid":89523,"uid":68094,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-22T05:45:20.000Z","msg":"此回覆已被刪除"},{"pid":"1422480a49159eaeda687d95ac32f56f13f6b582","tid":89523,"uid":2638,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-22T06:25:27.000Z","msg":"幾好用👍👍👍"},{"pid":"01b5318f27ff1a4ca8dabd630eb4dc986cbc196f","tid":89523,"uid":1082,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-22T06:28:09.000Z","msg":"<blockquote>地鐵綠色／藍色／紅色線<br />\n<br />\n基本用唔到 4G<br />\n<br />\n室內商場大部分位置無 4G<br />\n<br />\n<br />\n簡單來講，只有望到天空的地方，先用到 4G</blockquote><br />\nagree , 我屋企得一格， 要開埋wifi call 先叫做用到下<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"d019f73410ad552944456bd8130ef0c738059162","tid":89523,"uid":2638,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-22T06:30:21.000Z","msg":"<blockquote>幾好用👍👍👍</blockquote><br />\n<img src=\"https://img.eservice-hk.net/upload/2017/01/22/143019_a534383d73ad15236a36d1d0bccdd719.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F01%2F22%2F143019_a534383d73ad15236a36d1d0bccdd719.jpg&h=626e1f30&s={SIZE}\" />"},{"pid":"370ff5e9328fbf15f03b45b28d394c4af6e5333b","tid":89523,"uid":1886,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-22T16:35:26.000Z","msg":"<a href=\"https://zh.wikipedia.org/wiki/%E9%A6%99%E6%B8%AF%E9%80%9A%E8%A8%8A\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fzh.wikipedia.org%2Fwiki%2F%25E9%25A6%2599%25E6%25B8%25AF%25E9%2580%259A%25E8%25A8%258A&d=DUsE54zVauZF%2B575uuwaA2N6obqfy%2FNc7jg2IsrTbnE%3D&h=0646e479\" target=\"_blank\">https://zh.wikipedia.org/wiki/%E9%A6%99%E6%B8%AF%E9%80%9A%E8%A8%8A</a><br />\n於2012年12月，中國移動通訊與<span style=\"color: red;\">ZTE（中興）</span>及愛立信（Ericsson）一同推出FDD-LTE及TD-LTE雙制式網路（TD-LTE制式由中國自行研發）。<br />\n<br />\n<a href=\"http://hk.on.cc/hk/bkn/cnt/finance/20161108/bkn-20161108194031475-1108_00842_001.html\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fhk.on.cc%2Fhk%2Fbkn%2Fcnt%2Ffinance%2F20161108%2Fbkn-20161108194031475-1108_00842_001.html&d=DUsE54zVauZF%2B575uuwaA2N6obqfy%2FNc7jg2IsrTbnE%3D&h=bf250fb8\" target=\"_blank\">http://hk.on.cc/hk/bkn/cnt/finance/20161108/bkn-20161108194031475-1108_00842_001.html</a><br />\n香港電訊(06823)旗下csl.、和電香港(00215)旗下3香港及中國移動(00941)旗下中移香港，目前均分別與<span style=\"color: red;\">華為</span>合作，將本身的4G服務提升至4.5G標準。<br />\n<br />\n<a href=\"https://g.co/kgs/khPHZH\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fg.co%2Fkgs%2FkhPHZH&d=DUsE54zVauZF%2B575uuwaA2N6obqfy%2FNc7jg2IsrTbnE%3D&h=d4b4daf2\" target=\"_blank\">https://g.co/kgs/khPHZH</a><br />\n中興通訊是一家<span style=\"color: red;\">中國大陸跨國科技公司</span>，於1985年成立。<span style=\"color: red;\">總部在廣東深圳</span>。 中興通訊運營三大業務：運營商網絡、終端、電信。中興通訊的核心產品是無線通訊、電信交換、接入、光傳輸和數據電信設備、行動電話和電信軟體。它還提供增值服務產品，如點播和流媒體視頻。<br />\n總部： <span style=\"color: red;\">中國深圳市</span><br />\n創立於： 1985 年，<span style=\"color: red;\">中國深圳市</span><br />\n<br />\n<a href=\"https://g.co/kgs/alATaU\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fg.co%2Fkgs%2FalATaU&d=DUsE54zVauZF%2B575uuwaA2N6obqfy%2FNc7jg2IsrTbnE%3D&h=ecd2685f\" target=\"_blank\">https://g.co/kgs/alATaU</a><br />\n華為技術公司是<span style=\"color: red;\">中華人民共和國一家從事資訊與通訊解決方案的供應商</span>，<span style=\"color: red;\">總部位於廣東省深圳市</span>。華為於1987年註冊成立，業務範圍涉及電信網路、企業網路、消費者和雲端運算。其電信網路產品主要包括通訊網路中的交換網路、傳輸網路、無線及有線固定接入網路和資料通訊網路及無線終端產品。<br />\n總部： <span style=\"color: red;\">中國深圳市</span><br />\n創立於： 1987 年，<span style=\"color: red;\">中國深圳市</span><br />\n<br />\n<img src=\"/assets/faces/big/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/biggrin.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/big/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"2adda89e9639dff58c22e133cdad49761f8c16d5","tid":89523,"uid":60052,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-23T03:05:13.000Z","msg":"如果D DATA可以帶上大陸用果種就真係堅抵喇"},{"pid":"a9ab131322b56278a20b862fb512a85baf89561d","tid":89523,"uid":54845,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-01-23T04:12:02.000Z","msg":"此回覆已被刪除"}]}