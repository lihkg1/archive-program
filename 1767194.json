F600x0%2Ffilters%3Aquality%28100%29%2Farc-anglerfish-arc2-prod-mco.s3.amazonaws.com%2Fpublic%2FNGBMXW6HGBDM5IB5RYUAYOVYYM.jpg&h=91febc60&s={SIZE}\" />"},{"pid":"ea1465308f752299b493094c7712a08be4ca5d2a","tid":1767194,"uid":286792,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-12-03T06:40:42.000Z","msg":"<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"8fa99b4afc8ff12fc89f069f31a6c896185dd8f4","tid":1767194,"uid":42188,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-03T06:42:15.000Z","msg":"口交部：台灣是中國的台灣，未得中國批准，不得強行停泊高雄，否則只會被世人唾棄<img src=\"/assets/faces/pig/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"087150c0f27a29f1905e9237d194b12d083648f1","tid":1767194,"uid":335434,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-12-03T06:42:48.000Z","msg":"全盛時期嘅中共同柒婆 每日幫蔡英文拉幾多次票?<img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"368c3d5b4d639f73b6cb187254b0eadc049a1585","tid":1767194,"uid":48670,"like":4,"dislike":0,"score":4,"citedBy":3,"replyTime":"2019-12-03T06:44:39.000Z","msg":"<ins>2017-12-09</ins><br />\n中國駐美公使：<span style=\"color: red;\">美艦抵高雄之日，是解放軍武力統台之時</span><br />\n<br />\n李克新當地時間8日在中國駐美大使館舉行了中共十九大與美國總統特朗普訪華之行的說明會，並邀請200多名大陸留美學生、台僑及媒體參加。他在會上指出，台灣問題仍是中美關係的挑戰，美國國會日前通過的國防授權法，其中一條是美國軍艦和台灣軍艦要實現互訪，這違背了中美建交的基本精神。<br />\n<br />\n他表示自己早前曾向美國國會議員表示，要「感謝」他們提出這項要求（通過國防授權法），因為中國從制定《反分裂國家法》以來，從來不曾實行過。他又憶述當時自己的說話指：<span style=\"color: red;\">「如果你把（美國）軍艦派過去就啟動了我這個《反分裂國家法》。我告訴你，美國軍艦抵達高雄之日，就是我解放軍武力統一台灣之時」</span>。他又表示<span style=\"color: red;\">這不是開玩笑</span>，因為美國軍艦若訪上海，是徵得中方同意，但去台灣中方肯定不同意，<span style=\"color: red;\">美國強行要去，就啟動《反分裂國家法》，中方得採取行動。</span><br />\n<br />\n(支那01:<br />\n<a href=\"https://www.hk01.com/%E4%B8%AD%E5%9C%8B/140090/%E4%B8%AD%E5%9C%8B%E9%A7%90%E7%BE%8E%E5%85%AC%E4%BD%BF%E8%81%B2%E8%A8%80-%E7%BE%8E%E8%BB%8D%E8%89%A6%E6%8A%B5%E9%AB%98%E9%9B%84%E4%B9%8B%E6%97%A5-%E6%AD%A3%E6%98%AF%E8%A7%A3%E6%94%BE%E8%BB%8D%E6%AD%A6%E7%B5%B1%E5%8F%B0%E7%81%A3%E4%B9%8B%E6%99%82\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E4%25B8%25AD%25E5%259C%258B%2F140090%2F%25E4%25B8%25AD%25E5%259C%258B%25E9%25A7%2590%25E7%25BE%258E%25E5%2585%25AC%25E4%25BD%25BF%25E8%2581%25B2%25E8%25A8%2580-%25E7%25BE%258E%25E8%25BB%258D%25E8%2589%25A6%25E6%258A%25B5%25E9%25AB%2598%25E9%259B%2584%25E4%25B9%258B%25E6%2597%25A5-%25E6%25AD%25A3%25E6%2598%25AF%25E8%25A7%25A3%25E6%2594%25BE%25E8%25BB%258D%25E6%25AD%25A6%25E7%25B5%25B1%25E5%258F%25B0%25E7%2581%25A3%25E4%25B9%258B%25E6%2599%2582&d=QAb612WS2prazXX2mE0Ksc4e4tfxBia5339duguOAPM%3D&h=f60f6f7a\" data-auto-link target=\"_blank\">https://www.hk01.com/%E4%B8%AD%E5%9C%8B/140090/%E4%B8%AD%E5%9C%8B%E9%A7%90%E7%BE%8E%E5%85%AC%E4%BD%BF%E8%81%B2%E8%A8%80-%E7%BE%8E%E8%BB%8D%E8%89%A6%E6%8A%B5%E9%AB%98%E9%9B%84%E4%B9%8B%E6%97%A5-%E6%AD%A3%E6%98%AF%E8%A7%A3%E6%94%BE%E8%BB%8D%E6%AD%A6%E7%B5%B1%E5%8F%B0%E7%81%A3%E4%B9%8B%E6%99%82</a>)"},{"pid":"a0ed90f19fd4fdcf850d4bca626bee569a429f38","tid":1767194,"uid":83557,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-12-03T06:45:05.000Z","msg":"old news is so exciting<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"3f36a7a19f1936fa3efe141d4d0a17546799ce35","tid":1767194,"uid":291465,"like":4,"dislike":0,"score":4,"quote":{"pid":"368c3d5b4d639f73b6cb187254b0eadc049a1585","tid":1767194,"uid":48670,"like":4,"dislike":0,"score":4,"citedBy":3,"replyTime":"2019-12-03T06:44:39.000Z","msg":"<ins>2017-12-09</ins><br />\n中國駐美公使：<span style=\"color: red;\">美艦抵高雄之日，是解放軍武力統台之時</span><br />\n<br />\n李克新當地時間8日在中國駐美大使館舉行了中共十九大與美國總統特朗普訪華之行的說明會，並邀請200多名大陸留美學生、台僑及媒體參加。他在會上指出，台灣問題仍是中美關係的挑戰，美國國會日前通過的國防授權法，其中一條是美國軍艦和台灣軍艦要實現互訪，這違背了中美建交的基本精神。<br />\n<br />\n他表示自己早前曾向美國國會議員表示，要「感謝」他們提出這項要求（通過國防授權法），因為中國從制定《反分裂國家法》以來，從來不曾實行過。他又憶述當時自己的說話指：<span style=\"color: red;\">「如果你把（美國）軍艦派過去就啟動了我這個《反分裂國家法》。我告訴你，美國軍艦抵達高雄之日，就是我解放軍武力統一台灣之時」</span>。他又表示<span style=\"color: red;\">這不是開玩笑</span>，因為美國軍艦若訪上海，是徵得中方同意，但去台灣中方肯定不同意，<span style=\"color: red;\">美國強行要去，就啟動《反分裂國家法》，中方得採取行動。</span><br />\n<br />\n(支那01:<br />\n<a href=\"https://www.hk01.com/%E4%B8%AD%E5%9C%8B/140090/%E4%B8%AD%E5%9C%8B%E9%A7%90%E7%BE%8E%E5%85%AC%E4%BD%BF%E8%81%B2%E8%A8%80-%E7%BE%8E%E8%BB%8D%E8%89%A6%E6%8A%B5%E9%AB%98%E9%9B%84%E4%B9%8B%E6%97%A5-%E6%AD%A3%E6%98%AF%E8%A7%A3%E6%94%BE%E8%BB%8D%E6%AD%A6%E7%B5%B1%E5%8F%B0%E7%81%A3%E4%B9%8B%E6%99%82\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E4%25B8%25AD%25E5%259C%258B%2F140090%2F%25E4%25B8%25AD%25E5%259C%258B%25E9%25A7%2590%25E7%25BE%258E%25E5%2585%25AC%25E4%25BD%25BF%25E8%2581%25B2%25E8%25A8%2580-%25E7%25BE%258E%25E8%25BB%258D%25E8%2589%25A6%25E6%258A%25B5%25E9%25AB%2598%25E9%259B%2584%25E4%25B9%258B%25E6%2597%25A5-%25E6%25AD%25A3%25E6%2598%25AF%25E8%25A7%25A3%25E6%2594%25BE%25E8%25BB%258D%25E6%25AD%25A6%25E7%25B5%25B1%25E5%258F%25B0%25E7%2581%25A3%25E4%25B9%258B%25E6%2599%2582&d=QAb612WS2prazXX2mE0Ksc4e4tfxBia5339duguOAPM%3D&h=f60f6f7a\" data-auto-link target=\"_blank\">https://www.hk01.com/%E4%B8%AD%E5%9C%8B/140090/%E4%B8%AD%E5%9C%8B%E9%A7%90%E7%BE%8E%E5%85%AC%E4%BD%BF%E8%81%B2%E8%A8%80-%E7%BE%8E%E8%BB%8D%E8%89%A6%E6%8A%B5%E9%AB%98%E9%9B%84%E4%B9%8B%E6%97%A5-%E6%AD%A3%E6%98%AF%E8%A7%A3%E6%94%BE%E8%BB%8D%E6%AD%A6%E7%B5%B1%E5%8F%B0%E7%81%A3%E4%B9%8B%E6%99%82</a>)"},"citedBy":1,"replyTime":"2019-12-03T06:53:40.000Z","msg":"<img src=\"https://na.cx/i/zxrTJFQ.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FzxrTJFQ.gif&h=59495cd6&s={SIZE}\" />"},{"pid":"e926e1c28e11df47f551414ff309b33779007686","tid":1767194,"uid":113902,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-12-03T07:05:41.000Z","msg":"泡菜魚俾唔俾入港都死<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"1f8ce736089ae35e4822e0ef62b099bcb4117b7b","tid":1767194,"uid":29858,"like":0,"dislike":0,"score":0,"quote":{"pid":"3f36a7a19f1936fa3efe141d4d0a17546799ce35","tid":1767194,"uid":291465,"like":4,"dislike":0,"score":4,"quote":{"pid":"368c3d5b4d639f73b6cb187254b0eadc049a1585","tid":1767194,"u