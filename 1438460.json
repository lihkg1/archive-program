{"tid":1438460,"cid":31,"subCid":9,"title":"文宣請進： 林鄭話叫大家返屋企，唔好搞亂香港經濟實在惡毒","createTime":"2019-08-09T18:36:48.000Z","updateTime":"2019-08-10T14:51:05.000Z","uid":59996,"like":4,"dislike":0,"uniUserReply":5,"replies":[{"pid":"d9f285a91df783aff19491e15ab042dc88888692","tid":1438460,"uid":59996,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T18:36:49.000Z","msg":"你班友搞文宣話自已本身無產，所以驚條毛，只係可以圍爐，根本係同班撐你既中產間接割籍。反而林鄭上台咁耐，樓價日日升，教育無搞好醫療無搞好民生無搞好，仲搞到大家反哂面大家應該聚焦呢樣野，畀你繼續坐咪盞衰落去！唔好畀人分化！"},{"pid":"085ef1bb26fb4c79f88f7dd5a6166622ff94ca9a","tid":1438460,"uid":59996,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-09T18:37:33.000Z","msg":"自推"},{"pid":"25e98cadbb518de2905cafb903bc66cd34b68982","tid":1438460,"uid":59996,"like":0,"dislike":0,"score":0,"quote":{"pid":"085ef1bb26fb4c79f88f7dd5a6166622ff94ca9a","tid":1438460,"uid":59996,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-09T18:37:33.000Z","msg":"自推"},"citedBy":0,"replyTime":"2019-08-09T18:37:46.000Z","msg":"自推"},{"pid":"89c96714469ed5119f974c806ece013558670e45","tid":1438460,"uid":59996,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-09T18:37:58.000Z","msg":"自推"},{"pid":"60facd089c01d896ec8592c8408b8cf8eadf8be2","tid":1438460,"uid":197005,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-08-09T18:39:01.000Z","msg":"<img src=\"https://na.cx/i/aHwS8ui.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaHwS8ui.png&h=6145bcc7&s={SIZE}\" />"},{"pid":"a6315500299769919a4e55c2da7fd87fe7273327","tid":1438460,"uid":59996,"like":0,"dislike":0,"score":0,"quote":{"pid":"89c96714469ed5119f974c806ece013558670e45","tid":1438460,"uid":59996,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-09T18:37:58.000Z","msg":"自推"},"citedBy":0,"replyTime":"2019-08-09T18:39:44.000Z","msg":"自推"},{"pid":"80028045fd8f139a156dc9a248885e3de56fb9a1","tid":1438460,"uid":272942,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-09T18:42: