8b5ea0?width=750&amp;format=jpeg&amp;auto=webp\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.insider.com%2F57ab768fce38f234008b5ea0%3Fwidth%3D750%26format%3Djpeg%26auto%3Dwebp&h=25b156b9&s={SIZE}\" />"},{"pid":"7d347f8f7213968c31bd777c3bff64d75ca4841c","tid":2369422,"uid":20867,"like":0,"dislike":0,"score":0,"quote":{"pid":"744651550a01982ecafb02ab7894cb098c80db6e","tid":2369422,"uid":291557,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-17T08:51:35.000Z","msg":"民進黨出賣侵侵，好唔到邊係行狗屎運！"},"citedBy":0,"replyTime":"2021-01-17T09:59:44.000Z","msg":"呢個見解好獨到<img src=\"/assets/faces/normal/oh.gif\" class=\"hkgmoji\" /><br />\n<br />\n<pre><code data-type=\"\">這份解密文件，是對國民黨和馬英九沉重的打臉。馬英九之前鼓吹「始戰即終戰」，便是寄希望於美國在兩岸戰事間袖手旁觀，美國不介入，中共佔壓倒性優勢，台灣無險可守，一開戰即全線崩潰，不可收拾。這是馬英九與國民黨離間台灣朝野關係，替中共的武嚇作宣傳，以幫助實現中共的統一大業。至此，國民黨與馬英九出賣台灣本土利益，助紂為虐的真面目，便暴露無遺了。</code></pre>"}]}