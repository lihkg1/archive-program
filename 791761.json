pid":"279010dc79c9727cf50ea4263b7522968afb89dc","tid":791761,"uid":162406,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-24T05:28:00.000Z","msg":"有時間就拎個波對住牆 實淨啲咁則啲掃把腳 不斷重複 如果你則得夠實淨 個波唔會彈下彈下 ，咁嗰波彈返轉頭嘅時候 就用腳內側控返個波落嚟 ，淨係練腳內側 練咗最基本最簡單嘅嘢先<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"4a8c7e675895762d53d74724182c001473b68d30","tid":791761,"uid":139830,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-24T05:29:59.000Z","msg":"唔好怕個波，成日控就控到了，練下dick波"},{"pid":"4259e17e7e92fa5d05c0e1b071b225f7cf42a15d","tid":791761,"uid":121233,"like":0,"dislike":0,"score":0,"quote":{"pid":"41fa9b159a4cd3ec49be0a1ca1432011dd87f71a","tid":791761,"uid":186301,"like":1,"dislike":0,"score":1,"quote":{"pid":"2c592f310e7f018a94298c4c6e755d466f21583e","tid":791761,"uid":123787,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-08-24T05:21:36.000Z","msg":"<blockquote>高波先會控甩, 定係彈彈下地波都甩?</blockquote><br />\n兩者"},"citedBy":1,"replyTime":"2018-08-24T05:24:14.000Z","msg":"腳腕要用力鎖實，但大腿小腿要放鬆卸力，咁就可以控波，當然，輕輕側一側個人，會同時控波兼修正角度"},"citedBy":1,"replyTime":"2018-08-24T05:30:50.000Z","msg":"講得幾好 同埋接波時腳腕要向後少少卸力<br />\n如果唔係好易彈前<br />\n加油 踢多d練多d就會進步<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"d6cb1d9c0e834e57d365a85cb3b0c667e9ef2602","tid":791761,"uid":118827,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-24T05:32:23.000Z","msg":"加油<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /> <br />\n唔好驚1個人練波"},{"pid":"c19657789bc5cc3481c7d391d99040d9965ba1f8","tid":791761,"uid":174403,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-24T05:55:40.000Z","msg":"問完你未覆我就先講少少<br />\n<br />\n你話得緊張 應該係鬥緊波啦？<br />\n你應該唔會得自己一個練波就緊張掛<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n<br />\n先當你講緊停波<br />\n有人迫同無人迫嘅情況係好唔同嫁<br />\n亦都係踢得勁定廢最大嘅分別<br />\n好多人練習果陣踢到識飛<br />\n但一落場就會好似唔識踢波咁<br />\n<br />\n你鬥緊波 一拎波就會有人拍埋嚟<br />\n你個腦要諗住 第一下掂個波 係彈個波去邊度<br />\n而唔係完全整停佢，「完全整停佢」以你實力起碼要一兩秒<br />\n下半秒就已經俾人迫走咗<br />\n<br />\n你要有畫面彈個波去防守球員嘅邊度<br />\n雖然係用個彈字，但唔一定係彈遠，一個腳掌位都得<br />\n總之要令對方嘅需要反應時間》自己嘅反應時間"},{"pid":"a4d62b946c80f8b935ee917794c04e94965a635f","tid":791761,"uid":186301,"like":0,"dislike":0,"score":0,"quote":{"pid":"4259e17e7e92fa5d05c0e1b071b225f7cf42a15d","tid":791761,"uid":121233,"like":0,"dislike":0,"score":0,"quote":{"pid":"41fa9b159a4cd3ec49be0a1ca1432011dd87f71a","tid":791761,"uid":186301,"like":1,"dislike":0,"score":1,"quote":{"pid":"2c592f310e7f018a94298c4c6e755d466f21583e","tid":791761,"uid":123787,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2018-08-24T05:21:36.000Z","msg":"<blockquote>高波先會控甩, 定係彈彈下地波都甩?</blockquote><br />\n兩者"},"citedBy":1,"replyTime":"2018-08-24T05:24:14.000Z","msg":"腳腕要用力鎖實，但大腿小腿要放鬆卸力，咁就可以控波，當然，輕輕側一側個人，會同時控波兼修正角度"},"citedBy":1,"replyTime":"2018-08-24T05:30:50.000Z","msg":"講得幾好 同埋接波時腳腕要向後少少卸力<br />\n如果唔係好易彈前<br />\n加油 踢多d練多d就會進步<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-08-24T05:56:21.000Z","msg":"當年練波，比教練罰我對住牆傳500球，足足一星期，梗係有啲心得既<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"3e1f905ae9a3c224704bc8ff322dd7f2ab7e9df9","tid":791761,"uid":186301,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-24T05:57:39.000Z","msg":"點都好，你要練多啲力量，特別係下肢同腰腹，幫到你去保持動作既完整性及穩定性"},{"pid":"bc8a34a1e20807314464a17640a4ca6dff092190","tid":791761,"uid":99642,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-24T05:58:41.000Z","msg":"肯屋企多d控波"},{"pid":"262972ac341253d8a1ae30c8ef13503a37dd973b","tid":791761,"uid":199893,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-24T06:11:33.000Z","msg":"控波唔好鎖實隻腳<br />\n唔好用太大力<br />\n同埋諗定控去邊"},{"pid":"846afb4a51782bd8df3712a3a04a3ea8411463e3","tid":791761,"uid":73340,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-24T06:14:34.000Z","msg":"有時控甩係關個波事<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <br />\n輕既波 同 實既波 好唔同"}]}