f610829d890430dbbbc14d6a52ed76cdf9","tid":1847461,"uid":269372,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T05:27:29.000Z","msg":"不割 <img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"48ae2317c245310a427492ee2d9c615e15db8e64","tid":1847461,"uid":177955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T05:28:14.000Z","msg":"支爆近了"},{"pid":"5375f1fc352f574422916f1a0b9ebd29a04e8cc2","tid":1847461,"uid":171786,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T05:28:26.000Z","msg":"多謝手足"},{"pid":"808e2d25efc97214125a5e829b93965504c6c8b1","tid":1847461,"uid":106673,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T05:29:09.000Z","msg":"封關就岩啦屌.. 支持"},{"pid":"6b5d3bcdc25ab1d88c62bcd7199450d70e2cc725","tid":1847461,"uid":65074,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-01-28T05:30:18.000Z","msg":"Source: 基本上已可斷言武漢肺炎係來自武漢P4實驗室<br />\n<a href=\"https://lih.kg/1846058\" data-auto-link target=\"_blank\">https://lih.kg/1846058</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<a href=\"https://s3-ap-northeast-1.amazonaws.com/news.guo.offload.media/wp-content/uploads/2020/01/25133703/Brief-summary-of-evidence-of-lab-finish.pdf\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fs3-ap-northeast-1.amazonaws.com%2Fnews.guo.offload.media%2Fwp-content%2Fuploads%2F2020%2F01%2F25133703%2FBrief-summary-of-evidence-of-lab-finish.pdf&d=ib6ZiIlk8HgX3sh0XBbtb8IAfqyfHgkV2drMeooGLQQ%3D&h=790998ba\" data-auto-link target=\"_blank\">https://s3-ap-northeast-1.amazonaws.com/news.guo.offload.media/wp-content/uploads/2020/01/25133703/Brief-summary-of-evidence-of-lab-finish.pdf</a><br />\n<br />\n懶人包：<br />\n1. 武漢沙士病毒好可能係人工<br />\n<br />\n-佢同2017年浙江蝙蝠身上發現嘅冠狀病毒嘅E protein 100% 一樣 (相應嘅DNA 相似度都有225/228)，下一隻最接近嘅病毒已經只有低於95%一樣。<br />\n<br />\n病毒嘅基因複制同人類唔同；佢哋冇糾錯機制，發生變異機率相當大。即使E protein為保守序列，病毒品種相對不易產生變異，自然界中仍然非常唔可能有兩種冠狀病毒嘅E protein 完全一樣。SARS唔同亞種嘅E protein都有少量差別。<br />\n<br />\n-ORF8 基因通常病毒品種之間分別好大，2017浙江嗰隻嘅ORF8 同其他冠狀病毒最多只有60%似，但係同武漢沙士就有94.21%一樣<br />\n<br />\n2. 電腦推算武漢沙士病毒入侵人體嘅方式與SARS異常接近<br />\n<br />\nSARS入侵人體第一步，係病毒嘅S protein 痴落人體嘅ACE2 受體. 武漢沙士嘅S protein 整體上同SARS或者2017浙江嗰隻都唔似，但係真正痴落人體嗰部分就同沙士好似。最重要嗰五個氨基酸雖然同沙士有四個唔一樣，但係物理特性相似。電腦分析亦估算武漢沙士同人體ACE2 receptor 親和度非常高，只比SARS略低<br />\n<br />\n所以文章推斷為：有可能係有人參考沙士入侵呼吸道細胞ACE2 受體嘅方法，去改造2017年浙江蝙蝠身上發現嘅冠狀病毒，再放出自然環境（如武漢市場）繁殖一段短時間"},{"pid":"dc914a48aea6d5d0610a774389db854fd21e288e","tid":1847461,"uid":222970,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T05:33:07.000Z","msg":"<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" /><br />\n<br />\n壓力煲炸彈成本776元 「基地」製作教學<br />\n<a href=\"https://lih.kg/1846914\" data-auto-link target=\"_blank\">https://lih.kg/1846914</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"ce9e36366658d24d006d42d4899f5e7b0517c3d4","tid":1847461,"uid":112581,"like":12,"dislike":0,"score":12,"citedBy":2,"replyTime":"2020-01-28T05:35:04.000Z","msg":"炸彈唔一定要喺真<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /> 個關就封左"},{"pid":"c105b21ff47cd368c5a24be083e1cf9e1e74051c","tid":1847461,"uid":147376,"like":0,"dislike":0,"score":0,"quote":{"pid":"ce9e36366658d24d006d42d4899f5e7b0517c3d4","tid":1847461,"uid":112581,"like":12,"dislike":0,"score":12,"citedBy":2,"replyTime":"2020-01-28T05:35:04.000Z","msg":"炸彈唔一定要喺真<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" /> 個關就封左"},"citedBy":0,"replyTime":"2020-01-28T05:35:46.000Z","msg":"<img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/angel.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/lny/an