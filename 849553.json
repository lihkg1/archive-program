:24.000Z","msg":"好似發咗一場夢咁<br />\n一直愛住一個無出現過嘅人咁"},"citedBy":1,"replyTime":"2018-10-06T09:13:25.000Z","msg":"係...正正係依種感覺 好令人難堪  但如果自己都唔去相信 去肯定依件事<br />\n依件事就會愈黎愈模糊 慢慢連自己都失去埋<br />\n我真係好憎依種感覺<br />\n<br />\n多謝上面覆我既人<br />\n令我知道自己唔係一個人<br />\n原本我仲覺得自己好奇怪"},{"pid":"85afca193498c9b73ed04a09f21e9f0d135e4f0c","tid":849553,"uid":39735,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-06T09:13:25.000Z","msg":"心突然的隱隱痛"},{"pid":"6c53e6b6b6886e3f1da35df0fac9d2f6bad5c161","tid":849553,"uid":191633,"like":3,"dislike":0,"score":3,"quote":{"pid":"7695c6bd65fcdd9f6e1b1d6d04e3bac944f1e6ec","tid":849553,"uid":105665,"like":3,"dislike":0,"score":3,"quote":{"pid":"2e52c0549dc9046fcd8cbaf17819010e830b369a","tid":849553,"uid":191633,"like":7,"dislike":0,"score":7,"citedBy":2,"replyTime":"2018-10-06T09:07:24.000Z","msg":"好似發咗一場夢咁<br />\n一直愛住一個無出現過嘅人咁"},"citedBy":1,"replyTime":"2018-10-06T09:13:25.000Z","msg":"係...正正係依種感覺 好令人難堪  但如果自己都唔去相信 去肯定依件事<br />\n依件事就會愈黎愈模糊 慢慢連自己都失去埋<br />\n我真係好憎依種感覺<br />\n<br />\n多謝上面覆我既人<br />\n令我知道自己唔係一個人<br />\n原本我仲覺得自己好奇怪"},"citedBy":0,"replyTime":"2018-10-06T09:16:11.000Z","msg":"樓主我愛你<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /> <br />\n我都覺得自己好奇怪<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <br />\n成日懷疑自己嘅記憶<br />\n可能因為曾經太想積極生活而太想忘記<br />\n<br />\n<br />\n<br />\n但原來有你同一個諗法<br />\n你完全講出我心聲<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"faa11c6a8979dee20de888284143b9c586e8b90b","tid":849553,"uid":57069,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2018-10-06T11:28:13.000Z","msg":"我岩岩分手一個月，係分手前個ex已經同人曖昧緊，到左9月頭分手，呢幾日見到佢現任原來係三十幾歲既阿叔，睇佢fb相原來之前已經結過婚生左兩件。我知道我理唔到佢，我想問樓主如果佢未來會搵返你，你仲同唔同呢個背叛你既女仔一齊<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"9848c171074d36fcdac1c8e77392661b8dc0fae6","tid":849553,"uid":207274,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-06T11:33:12.000Z","msg":