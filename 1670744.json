"score":0,"citedBy":0,"replyTime":"2019-10-23T06:59:32.000Z","msg":"推到有人睇為止"},{"pid":"1c923a83e316ba126be6de4961201282e738da2a","tid":1670744,"uid":53610,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-10-23T08:27:55.000Z","msg":"唔好講咁多廢話，想割蓆咪照直講囉"},{"pid":"a1b7fe0551b77a29373df834ad9247c9962989dd","tid":1670744,"uid":223296,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-23T08:51:48.000Z","msg":"自推"},{"pid":"86a692bd50319e834418e3391c56be0411eeba51","tid":1670744,"uid":223296,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-23T08:52:07.000Z","msg":"自推"},{"pid":"bbc51e1bb76e5a4b509c27749b3b93e6cdf9cdd7","tid":1670744,"uid":223296,"like":0,"dislike":0,"score":0,"quote":{"pid":"1c923a83e316ba126be6de4961201282e738da2a","tid":1670744,"uid":53610,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2019-10-23T08:27:55.000Z","msg":"唔好講咁多廢話，想割蓆咪照直講囉"},"citedBy":0,"replyTime":"2019-10-23T08:55:12.000Z","msg":"想去就想去<br />\n唔想去就唔去<br />\n邊撚到割席??"}]}