aces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"545c894c7880e122593bca6fed5788534f0d7662","tid":1549814,"uid":21002,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T12:56:59.000Z","msg":"星期六 唔好諗會有太多私家車幫手 個個番工<br />\n仲有之前咁多次比d狗試陣<br />\n由內一層一層封到外<br />\n巴士狗鐵一早停 係早過出發停<br />\n比太多機會d狗<br />\n行25km我唔覺得有人介意"},{"pid":"9158f6eb53dba6e05bdac63a91332e34e0cd2317","tid":1549814,"uid":31974,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-07T12:59:10.000Z","msg":"上次圍捕同今朝搜巴士既白色恐怖"}]}