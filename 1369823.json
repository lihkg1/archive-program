:"0e15ce92604ab2ea1a56de5e9ca448147f9048dc","tid":1369823,"uid":14939,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-26T19:56:28.000Z","msg":"push"},{"pid":"90ecda969017fa199cd591b8e8e009effa8b2b93","tid":1369823,"uid":15758,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2019-07-26T19:56:46.000Z","msg":"唔發音就咁讀希"},{"pid":"5c58815f647fb44cf3968d8a57c7af0ba05e2b52","tid":1369823,"uid":14939,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-26T19:57:31.000Z","msg":"push"},{"pid":"dcde14d519244066e6f6d4a887ed7b6a871c4ba5","tid":1369823,"uid":222362,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T19:58:07.000Z","msg":"why not both<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"42c28b33ec4994ab805fc9cab4606c93be8e0148","tid":1369823,"uid":14939,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-26T19:58:29.000Z","msg":"push"},{"pid":"7ecdda6f3e70ccfc7f617d9fecb24083526c846e","tid":1369823,"uid":8500,"like":6,"dislike":0,"score":6,"citedBy":0,"replyTime":"2019-07-26T20:00:34.000Z","msg":"很多人不會自覺將「臘」讀成字形相似的「獵」，但其實「臘」和「獵」的讀音和意思都不一樣。根據字庫，「臘」的發音應是「立（laap6）」，而「獵」則應讀成「lip6」。翻查辭典，「臘」可解作一種祭祀的名稱，而「獵」就有追捕禽獸的意思。於希臘這個充滿神話色彩的國家而言，當然是「臘」而不是「獵」了。"},{"pid":"1bec5c9278b01850dc48423d2623fce49ac9c324","tid":1369823,"uid":165817,"like":4,"dislike":0,"score":4,"citedBy":0,"replyTime":"2019-07-26T20:10:02.000Z","msg":"#4咪有人答咗你囉<br />\n係咁push push push push push做乜鳩<br />\n<br />\n仲有你本身個例子已經錯<br />\n係臘腸 唔係獵腸<br />\n根本係兩個字嚟<br />\n希臘讀laap6根本冇異議"},{"pid":"2de14ee670ad38c963b511e48961e4ef8a368c0c","tid":1369823,"uid":149844,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T20:17:23.000Z","msg":"希立"},{"pid":"2e4b5a81c113aaaf46c9d0fa7116221f17156f03","tid":1369823,"uid":3852,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-26T20:23:29.000Z","msg":"laap人<br />\nlip腸"}]}