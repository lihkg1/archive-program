ssets/faces/normal/oh.gif\" class=\"hkgmoji\" />"},{"pid":"4995dede78c840250a3e92f3e9a1d46160fc1142","tid":1746353,"uid":82640,"like":0,"dislike":0,"score":0,"quote":{"pid":"05879fd03d56b66c9fcea8c44bd9913f7173d476","tid":1746353,"uid":73293,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-11-22T20:38:40.000Z","msg":"好人一生平安 快广传!!<br />\n<br />\n24号选举唔使理D黄丝，总之投建制嘅英雄记得盖章后在选票上写加油或支持，为建制派打打气! 还要多选几个建制！ 确保全部入闸！"},"citedBy":0,"replyTime":"2019-11-23T01:09:20.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"53c4b180f609da3da11c1ee131fbbc0b6916a297","tid":1746353,"uid":403,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-11-23T01:09:32.000Z","msg":"屯門<img src=\"/assets/faces/normal/@.gif\" class=\"hkgmoji\" />"}]}