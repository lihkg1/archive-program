ss=\"hkgmoji\" />"},{"pid":"dcbc82aee4f8e5ad22ad78a6d5ab57b0cf790639","tid":1908641,"uid":281401,"like":1,"dislike":1,"score":0,"quote":{"pid":"3623255a3d272b502fb551c512a4ff37eaef039b","tid":1908641,"uid":71133,"like":1,"dislike":4,"score":-3,"citedBy":5,"replyTime":"2020-03-03T12:39:17.000Z","msg":"其實trump內政好唔掂，唔係上次希拉莉搶左bernie個位trump都未必選到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-03T12:42:24.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"a35b83476bc6f7f6ee2a82da695249c2631e67c6","tid":1908641,"uid":281401,"like":2,"dislike":1,"score":1,"quote":{"pid":"3623255a3d272b502fb551c512a4ff37eaef039b","tid":1908641,"uid":71133,"like":1,"dislike":4,"score":-3,"citedBy":5,"replyTime":"2020-03-03T12:39:17.000Z","msg":"其實trump內政好唔掂，唔係上次希拉莉搶左bernie個位trump都未必選到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-03T12:42:34.000Z","msg":"Funny"},{"pid":"b798ce3d198ab6e563ca80d73b83bcd8272526b7","tid":1908641,"uid":78492,"like":2,"dislike":1,"score":1,"citedBy":0,"replyTime":"2020-03-03T12:47:08.000Z","msg":"桑德斯政綱<br />\n<br />\n對內政策方面，桑德斯主張<span style=\"color: red;\">全民福利</span>。桑德斯稱自己為「民主社會主義者」，其國內政策是民主黨強調福利傳統的強化版：<br />\n<br />\n一系列「全民」福利政策，<span style=\"color: red;\">全民醫保、全民大學、全民住房等；</span><br />\n<br />\n希望<span style=\"color: red;\">削減國防預算，擴大基建規模</span>；<br />\n<br />\n<span style=\"color: red;\">對高收入人羣大幅加税，為前述福利政策融資，包括提高個税高收入部分的邊際税率，對最富有的前 0.1%家庭徵財富税等</span>。桑德斯預計，財富税將為政府融資 4.35 萬億美元；<br />\n<br />\n主張加強金融行業監管，<span style=\"color: red;\">規範科技巨頭的壟斷行為，拆分大型銀行和科技企業。</span><br />\n<br />\n對外政策方面，桑德斯外交政策基本符合美國外交傳統：<br />\n<br />\n重視與盟友合作；<br />\n<br />\n支持重返伊朗核協議，支持解決巴以衝突的兩國方案。<br />\n<br />\n貿易方面，其持保護主義立場，與特朗普接近：<br />\n<br />\n<span style=\"color: red;\">贊成以關税為解決貿易爭端手段，反對加入各種自貿協定如 CPTPP、USMCA 等，甚至反對特朗普達成的新北美貿易協議，較特朗普更強硬；</span><br />\n<br />\n主張全面修訂與中國貿易關係。<br />\n<br />\n<span style=\"color: red;\">整體來看，桑德斯勝率的增長，會降低美國經濟增速的預期。</span>桑德斯強調社會公平，不僅對過去 20 年全球化產生的「金融精英」和「科技新貴」加徵「富人税」，也對金融行業和科技行業加強監管。強調公平的同時大概率帶來效率的降低，針對金融和科技行業的嚴監管大概率造成以第三產業為主的美國經濟下行壓力加大"},{"pid":"6ebba8eec80d34cd51465eeeaa0e99f3e0066fb0","tid":1908641,"uid":78304,"like":1,"dislike":1,"score":0,"quote":{"pid":"3623255a3d272b502fb551c512a4ff37eaef039b","tid":1908641,"uid":71133,"like":1,"dislike":4,"score":-3,"citedBy":5,"replyTime":"2020-03-03T12:39:17.000Z","msg":"其實trump內政好唔掂，唔係上次希拉莉搶左bernie個位trump都未必選到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-03T13:09:05.000Z","msg":"但經濟好，股市gogogo"},{"pid":"349d99d0a07c95e63aa7a218c9658b940e354c8b","tid":1908641,"uid":117754,"like":1,"dislike":3,"score":-2,"quote":{"pid":"3623255a3d272b502fb551c512a4ff37eaef039b","tid":1908641,"uid":71133,"like":1,"dislike":4,"score":-3,"citedBy":5,"replyTime":"2020-03-03T12:39:17.000Z","msg":"其實trump內政好唔掂，唔係上次希拉莉搶左bernie個位trump都未必選到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-03T13:23:04.000Z","msg":"破頂，加關稅，破低失業率....ching係平行時空？"},{"pid":"2f0e7cd9c32e3a7221737fb482838e27bd02ad78","tid":1908641,"uid":60529,"like":2,"dislike":3,"score":-1,"quote":{"pid":"3623255a3d272b502fb551c512a4ff37eaef039b","tid":1908641,"uid":71133,"like":1,"dislike":4,"score":-3,"citedBy":5,"replyTime":"2020-03-03T12:39:17.000Z","msg":"其實trump內政好唔掂，唔係上次希拉莉搶左bernie個位trump都未必選到<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-03-03T14:48:32.000Z","msg":"睇太多fake news"},{"pid":"edcd94135658caa2d1dee3df00482b51d1fc03b8","tid":1908641,"uid":71133,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-03-03T17:24:48.000Z","msg":"同連登仔講國際新聞真係多鳩餘<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}],"pinned":{"pid":"b798ce3d198ab6e563ca80d73b83bcd8272526b7","tid":1908641,"uid":78492,"like":2,"dislike":1