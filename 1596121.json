ig/cook.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-09-27T02:17:18.000Z","msg":"<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-09-28T01:35:56.000Z","msg":"<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" />"},{"pid":"a1cb1b0f6e7c2020aa6ccd0ca879034f0b2e39b9","tid":1596121,"uid":182835,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-09-28T01:47:43.000Z","msg":"哩間燒肉質素極垃圾，試過一次冇回頭"},{"pid":"fd014e0663cc47b9506ef505cced9dee7d546a97","tid":1596121,"uid":37204,"like":3,"dislike":1,"score":2,"citedBy":0,"replyTime":"2019-09-28T01:58:08.000Z","msg":"燒肉食平昌啦<br />\n性價比高, 以呢個價錢黎講幾好<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n黃店黎架"},{"pid":"d45082c46455706fc72ef53bf60a5c7cdd422635","tid":1596121,"uid":53062,"like":0,"dislike":6,"score":-6,"citedBy":1,"replyTime":"2019-09-28T07:44:32.000Z","msg":"丸十あぶり牧場 從各種和牛的源頭著手，直接與不同地方的牧場將原隻和牛直送到港，以Farm To Table 的理念，提供高品質、多樣性而且價錢親民的和牛燒肉料理給香港食客。<br />\n除了燒肉料理外，丸十あぶり牧場 多款食材也是由產地直送：牧場直送的日本南部雞、從豊洲水產市場直送的海鮮等，讓食客可享受到選擇豐富而優質日本料理。<br />\n<br />\n樓主唔識食🐂<img src=\"/assets/faces/normal/donno.gif\" class=\"hkgmoji\" />"},{"pid":"8217479a1f2a54e61955df258ed4849a10e861fe","tid":1596121,"uid":90839,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-28T11:50:15.000Z","msg":"貴到 咁嘅質素200蚊一餐都嫌多<img src=\"/assets/faces/pig/shocked.gif\" class=\"hkgmoji\" />"},{"pid":"c190db393162757bd16db7318d6cce6230077b14","tid":1596121,"uid":247833,"like":0,"dislike":0,"score":0,"quote":{"pid":"a1cb1b0f6e7c2020aa6ccd0ca879034f0b2e39b9","tid":1596121,"uid":182835,"like":2,"dislike":0,"score":2,"citedBy":1,"replyTime":"2019-09-28T01:47:43.000Z","msg":"哩間燒肉質素極垃圾，試過一次冇回頭"},"citedBy":0,"replyTime":"2019-09-28T13:46:24.000Z","msg":"岩呀<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />比咁貴食垃圾"},{"pid":"9e00fc419681e63de3627d0d49502f87b2a9a3a8","tid":1596121,"uid":247833,"like":2,"dislike":0,"score":2,"quote":{"pid":"d45082c46455706fc72ef53bf60a5c7cd