s/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />幫推 <br />\n我就係嘔左4件果個<br />\n伏到<br />\n以為食緊香口膠"},{"pid":"9c652ddadb68164312a6dfcdcd6dfaa842ab4490","tid":1596121,"uid":247833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T11:33:25.000Z","msg":"推"},{"pid":"e2800e397f86526d687f26f2a75123b61491e5fd","tid":1596121,"uid":247833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T11:33:36.000Z","msg":"推"},{"pid":"a92c1bbd559e1af7899987792d74bae514084bfd","tid":1596121,"uid":315851,"like":3,"dislike":0,"score":3,"citedBy":1,"replyTime":"2019-09-26T11:51:54.000Z","msg":"moko 差唔多間間都係伏黎<img src=\"/assets/faces/dog/no.gif\" class=\"hkgmoji\" />"},{"pid":"423721f45338a9e896973cc566ca98d3919190f9","tid":1596121,"uid":247833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T14:33:14.000Z","msg":"垃圾<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"4bcbf109b17c9c3c562863f5910ce5f9a6d1fa9d","tid":1596121,"uid":143564,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T14:34:53.000Z","msg":"呢間藍店？"},{"pid":"d5aae9b783399661750cf67d46688de637c1d38e","tid":1596121,"uid":13361,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-09-26T14:36:39.000Z","msg":"堅韓牛"},{"pid":"5bdfe89601ed6ad33bef7a736eb4ad95c0c5e9c7","tid":1596121,"uid":65556,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-09-26T14:37:48.000Z","msg":"求日式燒肉黃店<br />\n每月至少要食5次<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"09b8657044b8ef097b0ece5a7e3ccfb4377688d1","tid":1596121,"uid":63675,"lik