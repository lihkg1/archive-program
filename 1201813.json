res.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Feuromaidanpress.com%2Fwp-content%2Fuploads%2F2018%2F03%2Feuromaidan_tires.jpg&h=1ad91401&s={SIZE}\" /><br />\n人地亦都有和理非非<br />\n<img src=\"https://gdb.rferl.org/0BC1A4DA-5EB0-4106-9548-107E82BA99DC_w1023_r0_s.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fgdb.rferl.org%2F0BC1A4DA-5EB0-4106-9548-107E82BA99DC_w1023_r0_s.jpg&h=ef675bce&s={SIZE}\" /><br />\n<img src=\"https://www.kyivpost.com/wp-content/uploads/2017/06/06_AC8I1389.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fwww.kyivpost.com%2Fwp-content%2Fuploads%2F2017%2F06%2F06_AC8I1389.jpg&h=e6da4b40&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-06-11T16:59:41.000Z","msg":"<img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" />"},{"pid":"af1d5bc5a84170599cca4103bfc134414620e7f9","tid":1201813,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T18:15:42.000Z","msg":"推"},{"pid":"f491c3f7a076630215dd4fff3e92d0a5f01645f4","tid":1201813,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T18:18:26.000Z","msg":"推"},{"pid":"0c0d8739be808efc735ce6ba4b5d23cdab2f237b","tid":1201813,"uid":60764,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-11T18:22:12.000Z","msg":"此回覆已被刪除"},{"pid":"3f6336dc07c48b14a9228c3f424048715bee6e1c","tid":1201813,"uid":163350,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-11T18:23:41.000Z","msg":"此回覆已被刪除"},{"pid":"96c3434f214ebaa3f0c033f526d3b4e51de6dc08","tid":1201813,"uid":154486,"like":0,"dislike":0,"score":0,"quote":{"pid":"0c0d8739be808efc735ce6ba4b5d23cdab2f237b","tid":1201813,"uid":60764,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-11T18:22:12.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-06-11T18:24:05.000Z","msg":"facebook會del"},{"pid":"3689e115ec8682bfb069966d762b0c81d5720316","tid":1201813,"uid":154486,"like":2,"dislike":0,"score":2,"quote":{"pid":"3f6336dc07c48b14a9228c3f424048715bee6e1c","tid":1201813,"uid":163350,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-11T18:23:41.000Z","msg":"此回覆已被刪除"},"citedBy":0,"replyTime":"2019-06-11T18:24:25.000Z","msg":"基本上係俄羅斯食住"},{"pid":"a6b819ca1308e5bf20ab50f5d5408dab1d561def","tid":1201813,"uid":4739,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-11T18:31:48.000Z","msg":"有人用棍拍野deam beat 既時候唔好劣<br />\n一齊叫同一句口號加士氣避免士氣此消彼長<br />\n有心理學背後原理<br />\n對陣口號可參考港隊打氣口號<br />\n拍拍~拍拍拍~DIE FOR HONG KONG<br />\n<br />\n引用 雞肉大師 巴打:<br />\n要佢哋一齊嘶哮， 進入同一個呼吸節奏 同一個心跳步伐 <br />\n配合戰鼓(你搵個大水樽好撚大嗰啲 求其搵嘢敲佢有節奏嘅)打拍子 就會將一堆散兵游勇聚合成一個群體<br />\n以往慣例邊個大聲公喇叭就死邊個， 二來呢啲設備貴<br />\n但係水樽就可以有好多個 水樽買得起<br />\n<br />\n<br />\n另外大家小心雙眼，戴眼罩被人噴油漆就喪失視力，唔戴又會比人插眼<br />\n<br />\n大家亦小心近距離突然由下巴向上大力推有機會導致頸椎受傷 請各位注意安全免生危險<br />\n<br />\n請廣傳<br />\n<br />\n希望無論大家去邊，甚至返工，不了<br />\n都想大家連日常生活都黑衫黑褲口罩笠帽加黑鞋<br />\n令到平時條街見到全黑既人唔再係特徵反而係大多數<br />\n最好個個用現金，咁買飛個個就唔係做突出個一個<br />\n<br />\n全民 BLACK BLOCK<br />\n<a href=\"https://lih.kg/1203119\" data-auto-link target=\"_blank\">https://lih.kg/1203119</a><br />\n- 分享自 LIHKG 討論區<br />\n<br />\n<img src=\"https://na.cx/i/qwOd9MT.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FqwOd9MT.png&h=5069e98c&s={SIZE}\" />"},{"pid":"9aacf0322e3b84ad656f77e7b850a9ab21eeaca9","tid":1201813,"uid":60764,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T19:07:43.000Z","msg":"此回覆已被刪除"},{"pid":"4722c7574ae6c2014770a90cf43c7e9acb505ab1","tid":1201813,"uid":11809,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T20:33:18.000Z","msg":"Push"},{"pid":"4f30b3b3b8482f2373a26bb5afa9b85813786243","tid":1201813,"uid":15428,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-11T20:34:18.000Z","msg":"推"},{"pid":"51485e0ac4dcca5fcb6b0a04c733878eeb877e38","tid":1201813,"uid":100986,"like":1,"dislike":0,"score":1,"quote":{"pid":"e21305ef0e2434d4f301c344af2723f523e03cc1","tid":1201813,"uid":154486,"like":0,"dislike":0,"score":0,"citedBy":3,"replyTime":"2019-06-11T06:33:29.000Z","msg":"<a href=\"https://www.thisav.com/playvideo.php?videoid=425425&amp;page=%E5%87%9C%E5%86%AC%E7%83%88%E7%81%AB%EF%BC%9A%E7%83%8F%E5%85%8B%E8%98%AD%E8%87%AA%E7%94%B1%E4%B9%8B%E6%88%B0.html\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.thisav.com%2Fplayvideo.php%3Fvideoid%3D425425%26page%3D%25E5%2587%259C%25E5%2586%25AC%25E7%2583%2588%25E7%2581%25AB%25EF%25BC%259A%25E7%2583%258F%25E5%2585%258B%25E8%2598%25AD%25E8%2587%25AA%25E7%2594%25B1%25E4%25B9%258B%25E6%2588%25B0.html&d=0xAgwAOhMzbM3o1MPcLVD0PclXdXKQfB%2FlJdEd6ZkMI%3D&h=80ca874b\" target=\"_blank\">https://www.thisav.com/playvideo.php?videoid=425425&amp;page=%E5%87%9C%E5%86%AC%E7%83%88%E7%81%AB%EF%BC%9A%E7%83%8F%E5%85%8B%E8%98%AD%E8%87%AA%E7%94%B1%E4%B9%8B%E6%88%B0.html</a><br />\n<br />\n第一：烏克蘭開頭都係和理非非，有唱歌有玩膠，直到清場(10:00) <br />\n<br />\n第二：勇武派示威者開頭輸到貼地，開頭就算有部推土機(20:37) <br />\n夜左好多人冇防護比人打到仆街(22:00) <br />\n<br />\n第三：歐盟發言人講左兩句(33:00) ，之後就冇出過場<br />\n<br />\n第四：烏克蘭既差佬佈陣、裝備同香港冇大分別，唔係話特別勁或者廢<br />\n<br />\n第五：Slava Ukranini - Heroyem Slava係人所共知既口號，打招呼果陣、對峙果陣、衝果陣、葬禮果陣，都會大大聲講出黎，增強士氣<br />\n<br />\n第六：中段示威者已經有人係背後指揮，對峙時會不斷敲擊物件震懾(46:43) <br />\n<br />\n第七：<br />\n示威者組隊並且有自己既隊名(34:40) <br />\n學排陣 (34:55) <br />\n有人整左一批木盾(35:15) <br />\n中段左右好多人成功搶警察長鐵盾(45:50) <br />\n經訓練後由以前既散兵遊勇變成方陣<br />\n<br />\n第八：示威法過左之後，開始使用汽油彈同投擲硬物 (44:35)  <br />\n之前成功用滅火筒噴退攔路左膠 (44:12) <br />\n<br />\n第九：烏克蘭勇武派早中期冇特定形象領袖<br />\n<br />\n第十：第一位犧牲者年僅20（唔好死）<br />\n<br />\n第十一：烏克蘭廣場既地形係平地，但係後段警察已經有Sniper係大廈<br />\n<br />\n第十二：一位唔衝既小朋友參與調酒(47:10) <br />\n<br />\n第十三：黑社會藍屍(1:04:05) <br />\n<br />\n第十四：差佬已經癡左線，射醫護人士(51:30)，自己擲燃燒彈(1:08:55)<br />\n<br />\n重點係你以為戰鬥民族好威威，其實同你我經歷過既都冇大分別，點解咁快放棄<br />\n人地本身已有民主，都係打生打死先得到自由！！<br />\n人地有比人迫出黎既勇武<br />\n<img src=\"http://euromaidanpress.com/wp-content/uploads/2018/03/euromaidan_tires.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Feuromaidanpress.com%2Fwp-content%2Fuploads%2F2018%2F03%2Feuromaidan_tires.jpg&h=1ad91401&