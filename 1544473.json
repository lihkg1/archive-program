7e1433535f8db3ba96c00337d94189cacc","tid":1544473,"uid":102453,"like":0,"dislike":0,"score":0,"quote":{"pid":"f3907f64ad9d1c30e4ff922ef335c078223fd35c","tid":1544473,"uid":175602,"like":0,"dislike":0,"score":0,"quote":{"pid":"6e476e35c798c1adc4422172803046eb44425492","tid":1544473,"uid":102453,"like":0,"dislike":0,"score":0,"quote":{"pid":"a0118d4ff18dc8adc455f3e36d7f067724ebdede","tid":1544473,"uid":175602,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-09-05T15:17:30.000Z","msg":"<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-05T15:18:20.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-05T15:19:22.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-09-05T15:20:02.000Z","msg":"<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" />"},{"pid":"d495e3eac70ce81e374a62403a74b939f90fe3d2","tid":1544473,"uid":34780,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-09-05T15:20:04.000Z","msg":"----------------------------------------------------------------------------<br />\n太子CCTV最快星期6會被刪除<br />\n我地要有一次大集氣出太子 制造輿論壓力<br />\n將831死人嘅概念植入市民心中<br />\n令全港市民聚焦落黨鐵 迫佢交831嘅CCTV<br />\n絕對唔係要依兩日咁得幾十人圍太子警署咁<br />\n一定要上千人<br />\n實行將太子站鋪滿白色鮮花<br />\n<br />\n若然屬實 <span style=\"font-size: x-large;\"><span style=\"color: red;\">聽日就係手足頭七</span></span><br />\n依家號召各位巴打<br />\n<span style=\"font-size: x-large;\"><span style=\"color: red;\">聽日9月6號1930集氣千人太子站獻花</span></span><br />\n見字嘅<span style=\"font-size: x-large;\"><span style=\"color: red;\">巴打幫手spread出去</span></span> 一個人真係推唔起<br />\n----------------------------------------------------------------------------<br />\n【831】9月6號1930集氣千人太子站獻花行動post<br />\n- 分享自 LIHKG 討論區<br />\n<a href=\"https://lih.kg/1544326\" data-auto-link target=\"_blank\">https://lih.kg/1544326</a>"},{"pid":"9853582affa1f2e1bee8350af924308e9dd447f1","tid":1544473,"uid":27