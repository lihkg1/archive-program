52:33.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2019-07-12T02:16:12.000Z","msg":"有冇屋？族譜有冇屋企人名？"},{"pid":"0e1242d6e7c43848fc8753e4ec88a5109c0575f3","tid":1308414,"uid":196924,"like":0,"dislike":0,"score":0,"quote":{"pid":"ea49bdc3788848e946027cfaf26085ee52689b9b","tid":1308414,"uid":182820,"like":0,"dislike":3,"score":-3,"quote":{"pid":"c78b307ec20844776fc428703003706e0fa8be7f","tid":1308414,"uid":53026,"like":8,"dislike":1,"score":7,"quote":{"pid":"fa89a84c9f8436e747cd67f360da20421b234d2d","tid":1308414,"uid":77314,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-12T01:30:26.000Z","msg":"唔計香港原居民"},"citedBy":2,"replyTime":"2019-07-12T01:37:04.000Z","msg":"所謂「原居民」都係宋、明移居香港。無真正原居民，有都海禁令搬咗返大陸。「原居民」聲稱自己有丁權要起丁屋好可笑，應該驗DNA證明自己係「原住」。<br />\n<br />\n丁權與抗日戰爭有否立下戰功無關。抗日成功全靠愛因斯坦叫羅斯福研究原子彈，炸完先投降。"},"citedBy":2,"replyTime":"2019-07-12T01:42:36.000Z","msg":"丁權同抗英有關，英軍登陸時原居民同過英軍搏命，英軍打死咗人。後尾用丁權呢個特權黎收買番班原居民，等佢哋唔好攪事。"},"citedBy":1,"replyTime":"2019-07-12T02:18:39.000Z","msg":"錯晒<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n<br />\n<span style=\"color: red;\">展拓香港界址專條訂明保障新界原有居民嘅土地產權</span><br />\n<br />\n但係英國獲得新界之後強制新界原居民由佢地持有土地變成租地, 即係由freehold變成leasehold, 甚至想強逼佢地要補地價先可以起屋<br />\n由於違反展拓香港界址專條條文, 原居民拎住專條同英國佬講數, 最後英國跪低唔洗佢地補地價。<br />\n<br />\n但係去到50~60年代, 政府又想向包括新界在內所有混凝土建築收補地價, 咁啲原居民又覺得唔公平, 加上政府想發展新界, 最後喺70年代搞出「丁權」呢個折衷辦法, 「補償」原居民損失。<br />\n<br />\n<br />\n「展拓香港界址專條」都係1898年生效, <br />\n同咩對抗完全無關...<br />\n點樣隔咗<span style=\"color: red;\">七十幾年</span>先喺1972年訂出「丁權」政策去收買?"},{"pid":"1bf45eb167b665d5806c190f0454fa73f64589a7","tid":1308414,"uid":182820,"like":0,"dislike":0,"score":0,"quote":{"pid":"0e1242d6e7c43848fc8753e4ec88a5109c0575f3","tid":1308414,"uid":196924,"like":0,"dislike":0,"score":0,"quote":{"pid":"ea49bdc3788848e946027cfaf26085ee52689b9b","tid":1308414,"uid":182820,"like":0,"dislike":3,"score":-3,"quote":{"pid":"c78b307ec20844776fc428703003706e0fa8be7f","tid":1308414,"uid":53026,"like":8,"dislike":1,"score":7,"citedBy":2,"replyTime":"2019