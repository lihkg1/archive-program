2f39e7fb29cfcdee6952d388c8","tid":2245390,"uid":48485,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T08:40:05.000Z","msg":"拉登仔竟然打斧頭 <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"7b4ea20f2d6bb5b1fcb97740e76bbfc61d99f002","tid":2245390,"uid":174654,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T08:41:49.000Z","msg":"印狗打斧頭啲錢俾印媽買餸？<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"e57a647cd4b0732d20042fe7d9e308d030ff1c98","tid":2245390,"uid":43119,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T08:42:15.000Z","msg":"自師<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"64e4a1bf0e0dfea0e74d0a4d975c9a0fb8387513","tid":2245390,"uid":17265,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T08:45:24.000Z","msg":"你條仆街 <img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n唔係因為你話想幫我哋揀d好野食 <br />\n我都唔想比你買<img src=\"/assets/faces/pig/pointing.gif\" class=\"hkgmoji\" /><br />\n好啦 見你成日食神上身比你買囉 <br />\n點知你原來係度打斧頭<br />\n搞到我為咗慳錢日日飲熱飲<img src=\"/assets/faces/pig/wail2.gif\" class=\"hkgmoji\" /><br />\n點知原來你打斧頭嘅<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"829681a34a3ae95417948b28866591c217269fd8","tid":2245390,"uid":245576,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-16T08:46:48.000Z","msg":"打斧頭師<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},{"pid":"d5e21cb03e095348a2e3ba2269ef6eb00989e4b0","tid":2245390,"uid":15371,"like":11,"dislike":0,"score":11,"citedBy":0,"replyTime":"2020-10-16T08:47:13.000Z","msg":"我<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /><br />\n同事<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n<br />\n屌<br />\n好嬲<br />\n我今日同班同事一齊食外賣<br />\n又唔記得自己叫咗咩飯<br />\n咪拎起張單睇<br />\n點知俾我發現咗一件事<br />\n就係買飯個同事原來打斧頭<br />\n張單上面就寫住優惠減十幾蚊<br />\n個同事就無講過<br />\n我果吓即刻把幾火，就特登問同事<br />\n「喂&quot;同事英文名&quot;，點解張單有寫優惠減十幾蚊既？」<br />\n佢好似啞咗咁，我就知佢一定係特登<br />\n又追問佢<br />\n「個十幾蚊去咗邊？」<br />\n佢就支吾以對<br />\n「er......我都唔知喎，可能個外賣佬找漏咗&hellip;&hellip;我宜家打過去問吓先&hellip;&hellip;」<br />\n之後我都廢事理佢<br />\n睇佢平時講野成個毒撚咁都頂佢唔順<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n上次見佢用公司電腦睇野，本身以為咸濕相<br />\n點知原來睇TB<br />\n毒撚真係無得救"},{"pid":"20ce5a577f682907ec3fb549e0010c789657be40","tid":2245390,"uid":128741,"like":0,"dislike":0,"score":0,"quote":{"pid":"99f7b08e0e5642f166bc5173e41aff9058792b6c","tid":2245390,"uid":99700,"like":237,"dislike":1,"score":236,"citedBy":10,"replyTime":"2020-10-16T07:47:21.000Z","msg":"請定律師<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-10-16T08:48:39.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"f7fb2b304547fe52f40f6a9154bb1b76eaef28e6","tid":2245390,"uid":128741,"like":2,"dislike":0,"score":2,"quote":{"pid":"98b8b2f11f3ebae1cf5b54877221a19e3813c7d4","tid":2245390,"uid":33359,"like":35,"dislike":2,"score":33,"quote":{"pid":"625838a2e032904aa3ae4d028712d2742df15c5e","tid":2245390,"uid":16503,"like":6,"dislike":0,"score":6,"citedBy":1,"replyTime":"2020-10-16T07:51:23.000Z","msg":"叫人買飯唔使俾貼士？<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><br />\n<br />\n大聲夾惡師<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/wail.gif\" class=\"hkg