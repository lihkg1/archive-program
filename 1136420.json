十分香口澴滑，+4蚊抵飲！"},{"pid":"b90e95c1baf51705e85c6fa209461ee8f6eb885a","tid":1136420,"uid":145418,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-05-03T03:56:06.000Z","msg":"一定係p過張相，實物永遠都係差d"},{"pid":"24ac537c606fc9d9a216d002664bf70f787ea93d","tid":1136420,"uid":239451,"like":0,"dislike":0,"score":0,"quote":{"pid":"d81873743447cca9bcae88d891b52b376dfd084c","tid":1136420,"uid":33359,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-03T03:53:38.000Z","msg":"SAVE低呢張圖可以重複用?"},"citedBy":0,"replyTime":"2019-05-03T05:20:16.000Z","msg":"應該可以"},{"pid":"3350ceaddc66acf9ad3a799289910f427c8724cc","tid":1136420,"uid":76854,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-03T05:31:44.000Z","msg":"乜撚野叫早鳥?<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"76f7d5e80ed560d35e94a4c1b0d9dc5e6e1fb8de","tid":1136420,"uid":239451,"like":0,"dislike":0,"score":0,"quote":{"pid":"3350ceaddc66acf9ad3a799289910f427c8724cc","tid":1136420,"uid":76854,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-03T05:31:44.000Z","msg":"乜撚野叫早鳥?<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-03T06:34:48.000Z","msg":"早D食有得平D law"},{"pid":"f432a610862fc64c8268d2fff0da1295e8858e9e","tid":1136420,"uid":156795,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-05-03T07:34:23.000Z","msg":"很大唷 <br />\n<br />\n聽到都覺得尷尬<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"35d0c427e48e92b986dc8e2fd0d85699085d2236","tid":1136420,"uid":239451,"like":0,"dislike":0,"score":0,"quote":{"pid":"f432a610862fc64c8268d2fff0da1295e8858e9e","tid":1136420,"uid":156795,"like":0,"dislike":1,"score":-1,"citedBy":1,"replyTime":"2019-05-03T07:34:23.000Z","msg":"很大唷 <br />\n<br />\n聽到都覺得尷尬<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-05-03T08:21:17.000Z","msg":"我真係試過全個名讀出來....^^&quot;&quot;"},{"pid":"c3665e97879ae733af8a257d959a65c