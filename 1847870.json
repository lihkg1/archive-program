" class=\"hkgmoji\" />"},{"pid":"fade77edcaa4c3fbd4c00167993ce973ece9e0f9","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T09:31:35.000Z","msg":"Push"},{"pid":"7fa883f42016842fbfd822b5eab3d7d324d5b123","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T10:03:27.000Z","msg":"Push"},{"pid":"51fdbe0362c18061e8c91c7203c83aabda35bd5b","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T11:05:21.000Z","msg":"Push"},{"pid":"f346e72af1ec6970dfa175e58d3ea38807fe1149","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T13:09:54.000Z","msg":"Push"},{"pid":"f22269c8aa3baccafa92ebef593b2dcbeb1e88b5","tid":1847870,"uid":212897,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T13:11:11.000Z","msg":"推"},{"pid":"641c3ab6b3c6d0437b8d6c2acec191fa776dd1e3","tid":1847870,"uid":344033,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T13:13:50.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">請廣傳</span></span><br />\n<br />\n手足裝備抗沙士：防毒面具/濾罐 (型號/分析/用法/清潔全齊）<br />\n<br />\n<a href=\"https://lih.kg/1848447\" data-auto-link target=\"_blank\">https://lih.kg/1848447</a><br />\n<br />\n<br />\n整體分析圖：<a href=\"https://www.facebook.com/112357283631796/posts/116690396531818/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112357283631796%2Fposts%2F116690396531818%2F%3Fd%3Dn&d=ib6ZiIlk8HgX3sh0XBbtb5MONXnVHdpXbsFGehQCOpI%3D&h=c219c559\" data-auto-link target=\"_blank\">https://www.facebook.com/112357283631796/posts/116690396531818/?d=n</a><br />\n個別仔細分析：<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\"><span style=\"font-size: xx-large;\">護目鏡</span>：<a href=\"https://lih.kg/1845419\" data-auto-link target=\"_blank\">https://lih.kg/1845419</a></span></span> / <a href=\"https://m.facebook.com/112357283631796/posts/117867026414155/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2F112357283631796%2Fposts%2F117867026414155%2F%3Fd%3Dn&d=ib6ZiIlk8HgX3sh0XBbtb5MONXnVHdpXbsFGehQCOpI%3D&h=f8816feb\" data-auto-link target=\"_blank\">https://m.facebook.com/112357283631796/posts/117867026414155/?d=n</a><br />\n<br />\nVPN 大踢爆：<a href=\"https://m.facebook.com/story.php?story_fbid=112386483628876&amp;id=112357283631796&amp;__tn__=%2As-R\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.facebook.com%2Fstory.php%3Fstory_fbid%3D112386483628876%26id%3D112357283631796%26__tn__%3D%252As-R&d=ib6ZiIlk8HgX3sh0XBbtb5MONXnVHdpXbsFGehQCOpI%3D&h=0066de54\" data-auto-link target=\"_blank\">https://m.facebook.com/story.php?story_fbid=112386483628876&amp;id=112357283631796&amp;__tn__=%2As-R</a><br />\n<br />\n請大家廣傳，避免沉底<br />\n<br />\n最近口罩同N95 都賣曬，部分手足屋企口罩已經就黎用盡，今日同大家介紹下可以防沙士+TG嘅濾罐同濾棉。第一，係for 用曬/買唔到口罩嘅手足，第二係希望方便大家一次過買齊發夢+出街嘅裝備，就算沙士完左，自用送禮都可以繼續名貴大方。<br />\n<br />\nN95/R95/P95 口罩基本上係particulate respirator, 外科口罩防嘅係飛沫粒子，即係我地用防毒面具代替，就要裝particulate filter，換言之，就係濾棉！<br />\n<br />\n濾棉最高級別就係P100，防油性+非油性粒子，即係TG（油性）同埋病毒都可以防，型號包括2091, 2097, 2297, 6035（只有英國製）,7093 等等，而60926等等嘅6092X 系列濾罐，因為內置P100 濾棉，所以一樣ok <br />\n其中，6053 同 7093 棉係防水的，清潔消毒會較方便，而60926表面亦有膠盒。<br />\n<br />\n有強國人做過測試，係北京霧霾毒氣之下，3M 2091 用左十一日過濾能力都係跌左1%，手足請自行考慮幾耐換一次。<br />\n<br />\nAmazon 大log買亦有便，大家可以組團買。<br />\n<br />\n<a href=\"https://www.3m.com.au/3M/en_AU/company-au/all-3m-products/~/3M-Particulate-Filter-6035-P2-P3/?N=5002385+8711017+3294471754&amp;rt=rud\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.3m.com.au%2F3M%2Fen_AU%2Fcompany-au%2Fall-3m-products%2F~%2F3M-Particulate-Filter-6035-P2-P3%2F%3FN%3D5002385%2B8711017%2B3294471754%26rt%3Drud&d=ib6ZiIlk8HgX3sh0XBbtb5MONXnVHdpXbsFGehQCOpI%3D&h=5dfd18b7\" data-auto-link target=\"_blank\">https://www.3m.com.au/3M/en_AU/company-au/all-3m-products/~/3M-Particulate-Filter-6035-P2-P3/?N=5002385+8711017+3294471754&amp;rt=rud</a><br />\n<a href=\"https://www.3m.com/3M/en_US/company-us/all-3m-products/~/3M-Particulate-Filter-7093-P100-60-EA-Case/?N=5002385+3294776429&amp;rt=rud\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.3m.com%2F3M%2Fen_US%2Fcompany-us%2Fall-3m-products%2F~%2F3M-Particulate-Filter-7093-P100-60-EA-Case%2F%3FN%3D5002385%2B3294776429%26rt%3Drud&d=ib6ZiIlk8HgX3sh0XBbtb5MONXnVHdpXbsFGehQCOpI%3D&h=42ca803e\" data-auto-link target=\"_blank\">https://www.3m.com/3M/en_US/company-us/all-3m-products/~/3M-Particulate-Filter-7093-P100-60-EA-Case/?N=5002385+3294776429&amp;rt=rud</a><br />\n<br />\n2003 年沙士，淘大嘅清理人員就係用2091棉+600X 罐（罐理論上唔洗，應該係防佢地嘅清潔同消毒藥水）。<br />\n<br />\n<span style=\"font-size: xx-large;\"><span style=\"color: green;\">如何清潔防毒面具可參考依段片，有教disinfection，主要都係漂白水同消毒劑<br />\n<a href=\"https://youtu.be/dE5IweYn3T4\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fyoutu.be%2FdE5IweYn3T4&d=ib6ZiIlk8HgX3sh0XBbtb5MONXnVHdpXbsFGehQCOpI%3D&h=c01726f1\" data-auto-link target=\"_blank\">https://youtu.be/dE5IweYn3T4</a></span></span><br />\n<br />\n清潔步驟：<br />\n入到屋企唔好除裝備住，用酒精紙巾抹左面具同濾棉/罐表面先，跟住抹埋手再洗手（點解又要酒精又要洗手係有原因的），跟住就除面罩，再跟番片入面嘅教學清潔<br />\n<br />\n&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;&mdash;<br />\n防毒面具方面，建議大家買/用6800 或者其他包曬成塊面嘅款式，咁樣就唔洗帶眼罩，一舊野保護曬成塊面，最安全。因為你戴半面+眼罩，咁就多舊野清潔，同埋部分眼罩封唔曬，冇咁安全。<br />\n<br />\n型號方面，全面嘅建議大家買6800，順便擋埋橡膠子彈，半面嘅就買7502/ 6500，兩款手足都表示舒適度幾高。<br />\n<br />\n<span style=\"color: red;\"><a href=\"https://www.facebook.com/112044766987392/posts/119490526242816/?d=n\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2F112044766987392%2Fposts%2F119490526242816%2F%3Fd%3Dn&d=ib6ZiIlk8HgX3sh0XBbtb5MONXnVHdpXbsFGehQCOpI%3D&h=858fdc52\" data-auto-link target=\"_blank\">https://www.facebook.com/112044766987392/posts/119490526242816/?d=n</a><br />\n酒精搓手液 vs 洗手梘液</span>"},{"pid":"1dc200f8783818ddb357a06d7cf5f23d1d522ce1","tid":1847870,"uid":1292,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-28T14:01:59.000Z","msg":"係咪LV <img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" />"},{"pid":"50f99e8171793a8339214a66e4db593644650cf9","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"quote":{"pid":"1dc200f8783818ddb357a06d7cf5f23d1d522ce1","tid":1847870,"uid":1292,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-01-28T14:01:59.000Z","msg":"係咪LV <img src=\"/assets/faces/lny/frown.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2020-01-28T14:31:43.000Z","msg":"唔係"},{"pid":"6150287d0b61b97f55282e8ff1b4faefa88d2224","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T15:33:28.000Z","msg":"Push"},{"pid":"9db2d808ac3f154cee6454d4d38308e10feccd9a","tid":1847870,"uid":41818,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T15:52:28.000Z","msg":"推"},{"pid":"f2dfb2cd0a8d6b9a7330dd95c1958ee7c8c3802e","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-28T15:58:20.000Z","msg":"推"},{"pid":"08f1aea33510823a695dbeedfb88c93c82cea915","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T07:04:42.000Z","msg":"推"},{"pid":"0779e7162380778f810ce04fc59ba02e07f69e1a","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T12:29:13.000Z","msg":"推"},{"pid":"6d2e51c2ac00222ceb9564271c37526aced1d5d3","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T13:40:02.000Z","msg":"推"},{"pid":"7a6ca5f5cadf8d66a9e57967b2e04931e7184649","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T14:59:16.000Z","msg":"push"},{"pid":"6d2575802e1bd518262e9c1e41f046d4b35071ad","tid":1847870,"uid":144942,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01-29T14:59:44.000Z","msg":"<img src=\"/assets/faces/lny/angry.gif\" class=\"hkgmoji\" />"},{"pid":"5c43cca9cd8aea735536d26c3981c43ac10bc4a5","tid":1847870,"uid":21483,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-01