ac0fc","tid":801302,"uid":47359,"like":41,"dislike":1,"score":40,"citedBy":1,"replyTime":"2018-08-31T14:09:13.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">百年一遇</span></span>"},"citedBy":1,"replyTime":"2018-08-31T14:23:02.000Z","msg":"用啱顏色，係百年一遇嘅黃雨"},{"pid":"9255f7e0d4c8f28a2ec916c0325ad041607aeadc","tid":801302,"uid":51701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-31T14:24:35.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"110cae9076f70781f7f2d971f478123aef0c9b07","tid":801302,"uid":622,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-31T14:24:53.000Z","msg":"快 d 通車啦 <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"5a0cfedc2f7dded9b9a86d1f01a96ad0e31703ee","tid":801302,"uid":51701,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-31T14:25:06.000Z","msg":"太早<br />\n<br />\n應該通車先落雨"},{"pid":"e690f46f3dd0b6c01c22ea900eee4521e98b4bd8","tid":801302,"uid":36551,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-31T14:26:48.000Z","msg":"又批幾百萬復修，工程公司Fat Fat<img src=\"/assets/faces/dog/wet.gif\" class=\"hkgmoji\" />"},{"pid":"386497e0567465d4c2be0008a58d356191931ea3","tid":801302,"uid":79563,"like":124,"dislike":4,"score":120,"quote":{"pid":"79570268b64e6b0e166126962ba52f6e5cac9cb7","tid":801302,"uid":80395,"like":47,"dislike":0,"score":47,"quote":{"pid":"50d54decae9e03c9194c32552edac9f918bac0fc","tid":801302,"uid":47359,"like":41,"dislike":1,"score":40,"citedBy":1,"replyTime":"2018-08-31T14:09:13.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: gold;\">百年一遇</span></span>"},"citedBy":1,"replyTime":"2018-08-31T14:23:02.000Z","msg":"用啱顏色，係百年一遇嘅黃雨"},"citedBy":0,"replyTime":"2018-08-31T14:27:36.000Z","msg":"嗒嗒嗒，英國人擔起雨遮、著上雨褸；香港人正在趕緊上班上學。<br />\n微微細雨，法國人捧著長麵包回家享用；香港人在巴士站打開預報到站應用程式看廣告，等待一百次一分鐘的下一班車。<br />\n雨開始稠密，日本人在便利店等雨勢暫緩；香港人在地鐵中觀看鐘乳石洞。<br />\n雨量達到五十毫米，韓國人開始被雨滴化了妝容；香港人開始拿起雨遮。<br />\n雨量達到一百毫米，巴西人開始做好防水設備；香港人打開天文台應用程式查看天氣狀況。<br />\n雨量達五百毫米，南非開始水浸，動物相繼移往高處；香港人在划船上班。<br />\n雨量已達八百毫米，中國大部分地方開始淹沒；香港人爭先恐後搶搭潛艇上班，司機說要徵收附加費。<br />\n雨勢達一千毫米以上，埃及變成海灘；香港人在慶幸可以親眼目睹尼亞加拉大瀑布。<br />\n雨勢未有停止，地球廣泛地區已沉沒；千億高鐵全線浸沒；馬浚偉開始游泳，香港人於下班時仿效。<br />\n天文台台長：「啊，是時候黃雨了！」"},{"pid":"e1f0cc054e37cf3de459fcb57fe4625e0ff6335f","tid":801302,"uid":31568,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2018-08-31T14:27:48.000Z","msg":"777眾高官快d 去搭<br />\n以表愛國愛港之心"},{"pid":"4e20f6fe38b364735936f5a85f43f4a0d04a6864","tid":801302,"uid":53498,"like":9,"dislike":0,"score":9,"citedBy":0,"replyTime":"2018-08-31T14:28:11.000Z","msg":"又cap多兩千億做維修"},{"pid":"291acda29ea6e6ed3223a3f78d0340dff20902aa","tid":801302,"uid":19454,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-08-31T14:30:21.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"a44e1986f12458731f1f1f1fee941e957203476b","tid":801302,"uid":100136,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2018-08-31T14:30:49.000Z","msg":"水浸純屬意外，唔評論個別事件<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"fe1a13b4c1e1cc1024df4a1791405a07be3eac48","tid":801302,"uid":26385,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-08-31T14:31:15.000Z","msg":"好似個天都要玩死佢咁<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"1cea781b213ca4d1fd745bf3079257c8925ce674","tid":801302,"uid":16676,"like":12,"dislike":0,"score":12,"citedBy":1,"replyTime":"2018-08-31T14:31:31.000Z","msg":"海洋列車<img src=\"/assets/faces/lomoji/10.png\" class=\"hkgmoji\" />"},{"