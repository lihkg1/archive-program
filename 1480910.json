s=\"hkgmoji\" />"},{"pid":"97b3e3aba00f23cb0e86d9f4800bc9fe86a7e606","tid":1480910,"uid":194553,"like":0,"dislike":0,"score":0,"quote":{"pid":"778e8b237bd8880121bfea99a92413fcb786df26","tid":1480910,"uid":294050,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-17T14:13:40.000Z","msg":"😂 sing hallelujah 係我強項 ！ loop 到popo 暈"},"citedBy":0,"replyTime":"2019-08-18T01:35:04.000Z","msg":"popo表示聽到生活不能自理<img src=\"/assets/faces/dog/lihkg.gif\" class=\"hkgmoji\" />"},{"pid":"dd6e07f144a54c80919aa9edefabfacde144d902","tid":1480910,"uid":69636,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T01:36:38.000Z","msg":"<img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/fight1.gif\" class=\"hkgmoji\" />"},{"pid":"e14c0d933e3517311e941f3662f53ff8056db9fe","tid":1480910,"uid":180019,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T02:00:47.000Z","msg":"推"},{"pid":"1557d24ab3a650597a2e7fdff52c60dc913bf2f7","tid":1480910,"uid":20420,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T02:04:35.000Z","msg":"GFHD SDGM<br />\n<br />\n<img src=\"/assets/faces/normal/shocking.gif\" class=\"hkgmoji\" />"},{"pid":"c8c839ad6b0213216b0826422b79ee63d736fb87","tid":1480910,"uid":268251,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-18T02:06:21.000Z","msg":"唔好意思借個位.<br />\n<br />\n<img src=\"https://na.cx/i/FNrEn9y.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFNrEn9y.jpg&h=3a63f7b3&s={SIZE}\" /> <br />\n(麻煩貼上Twitter, FB, IG)<br />\n<a href=\"https://lihkg.com/thread/1481244/page/1\" target=\"_blank\">https://lihkg.com/thread/1481244/page/1</a><br />\n<br />\n原圖既少女, 係孤星淚入面既Cosette. 孤星淚係咩故事, 大家應該都知, 唔知自己google.<br />\n留意左好多文日, 我地既文宣其實可以利用唔同地方既文化,<br />\n加以更改, 達成更大效果. 要同全世界We Connect, 要活用唔同地方既文化.<br />\n孤星淚, 係歐美社會一定知道既title, 亦容易勾起佢地既共鳴.<br />\n大家不妨諗諗之後既文宣, 要更加creative.<br />\n勾起其他國家本身既文化共鳴, 先係最佳方法.<br />\n<br />\n麻煩大家幫手forward去外國網站或者FB,<br />\n澳洲同法國既香港支持者受到大陸人攻擊之下,<br />\n呢張圖就係我地對外文宣既最佳利器.<br />\n當年南斯拉夫內戰, 打左幾年, 國際社會關注但唔出手,<br />\n最後係一張『薩拉熱窩的羅密歐與茱麗葉』既照片成為轉變關鍵.<br />\n羅密歐與茱麗葉既標題, 引起左歐美社會共鳴.<br />\n<br />\n(文宣太多字, 人地會唔睇飛左)<br />\n<br />\n<br />\n接下來係<span style=\"color: red;\"><span style=\"font-size: xx-large;\">理念輸出, 比上圖更重要</span></span><br />\n[文宣] 發夢之歌: 自由之旗?自由之民, 一首代表我地理念既歌.<br />\n<a href=\"https://lihkg.com/thread/1476260/page/1\" target=\"_blank\">https://lihkg.com/thread/1476260/page/1</a><br />\n<br />\n<a href=\"https://www.youtube.com/watch?v=Il7Tp2r9qL8\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3DIl7Tp2r9qL8&d=9fV5YN%2BdLeg0vJDpI0pnmpq%2FK6ZSh20SQa5bazxoXL8%3D&h=17dd35d0\" target=\"_blank\">https://www.youtube.com/watch?v=Il7Tp2r9qL8</a><br />\n<br />\n我地唔單止要宣傳, 仲要有理念. 藉由歌聲追求自由係最好既理念文宣,<br />\n唔會嚇親老一派既香港人, 亦可以觸動到歐美社會既支持.<br />\n我選呢首歌既理由, 同上面講既『薩拉熱窩的羅密歐與茱麗葉』一樣,<br />\n都係能觸動歐美普世價值既issue. 對我地黎講, 一首好歌,<br />\n可以鼓舞士氣, 提醒我地不要放棄.<br />\n<br />\n上面條LINK係我搵既一首歌, 好適合我地用. 大家可以襟上去聽下首歌,<br />\n如果認同既話, 我希望可以搞個萬人齊唱版, 大家可以聽住音樂清唱,<br />\n唱完之後UPLOAD上上面條連登LINK, 我整合之後放出黎.<br />\n<br />\n文宣也好, 歌曲也好, 最重要係做得到be Symbol.<br />\nBatman曾有一段對話:<br />\n&ldquo;People need dramatic examples to shake them out of apathy,<br />\nand I can&rsquo;t do that as Bruce Wayne. As a man I&rsquo;m flesh and blood,<br />\nI can be ignored, I can be destroyed, but as a symbol,<br />\nas a symbol I can be incorruptible. I can be everlasting.&rdquo;<br />\n&mdash; Bruce Wayne (Batman Begins)<br />\n<br />\n我地既文宣同理念, 一定要做到be Symbol, 一聽到某D文宣圖就諗起成個運動,<br />\n一聽到某首歌就能夠代表我地. 查不公, 查真相, 都係文宣應該做. <span style=\"color: gold;\"><span style=\"font-size: xx-large;\">但我地要再進化,</span></span><br />\n<span style=\"color: red;\"><span style=\"font-size: xx-large;\">be Symbol, be Symbol, be Symbol</span></span>. 重要事情講三次.<br />\n<br />\n唯有有左Symbol, 有左令我地寄托夢想既Symbol, 先可以長期落去.<br />\n我地無大台, 唔似印度人有甘地去寄托夢想, 寄托夢想於歌曲就係最好選擇.<br />\n<br />\n<br />\n818，維園見"},{"pid":"497b9baaa6b4d1845faac3aebcde6701eaf44ff4","tid":1480910,"uid":271199,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T02:10:44.000Z","msg":"推"},{"pid":"0a5f28629dffa42a407bf60065de77550971c096","tid":1480910,"uid":231368,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T02:20:19.000Z","msg":"推"},{"pid":"32da38287cbb676cb9c4d6daf9e46d4f1ce69e48","tid":1480910,"uid":264983,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-18T02:39:53.000Z","msg":"3點維園，不見不散"},{"pid":"c402f3e988de4d5b5deeadff8c37f98dbeda7f0d","tid":1480910,"uid":264124,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T02:50:33.000Z","msg":"721 811"},{"pid":"fd6db413953ff9fd520f82a74ef2df8ba0f569bf","tid":1480910,"uid":264124,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T02:50:43.000Z","msg":"721 811"},{"pid":"cc5aff614a9646663db3232e1c361b653424987e","tid":1480910,"uid":264124,"like":0,"dislike":0,"score":0,"quote":{"pid":"32da38287cbb676cb9c4d6daf9e46d4f1ce69e48","tid":1480910,"uid":264983,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-18T02:39:53.000Z","msg":"3點維園，不見不散"},"citedBy":0,"replyTime":"2019-08-18T02:50:53.000Z","msg":"2點 <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"598b4a05f1028fe60bfe6b074eea8a264541903e","tid":1480910,"uid":288370,"like":0,"dislike":0,"score":0,"quote":{"pid":"c8c839ad6b0213216b0826422b79ee63d736fb87","tid":1480910,"uid":268251,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2019-08-18T02:06:21.000Z","msg":"唔好意思借個位.<br />\n<br />\n<img src=\"https://na.cx/i/FNrEn9y.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FFNrEn9y.jpg&h=3a63f7b3&s={SIZE}\" /> <br />\n(麻煩貼上Twitter, FB, IG)<br />\n<a href=\"https://lihkg.com/thread/1481244/page/1\" target=\"_blank\">https://lihkg.com/thread/1481244/page/1</a><br />\n<br />\n原圖既少女, 係孤星淚入面既Cosette. 孤星淚係咩