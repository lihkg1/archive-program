55.000Z","msg":"佢鳩下鳩下咁，抵啦"},{"pid":"1806b9be9fa1f883992665f3dbd0053d000680d9","tid":855382,"uid":199211,"like":0,"dislike":2,"score":-2,"citedBy":0,"replyTime":"2018-10-10T04:34:13.000Z","msg":"唔識啊屌你家母"},{"pid":"f5b973f7b97a360a4363f4cf1a5dbc711e7dc093","tid":855382,"uid":54025,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-10T04:48:06.000Z","msg":"有無人哭左"},{"pid":"f370d29ad05aed8a81c49dbef0a47c0afc631167","tid":855382,"uid":61357,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-10T05:01:48.000Z","msg":"唔撚係掛"},{"pid":"2708e83b58dc36d3def07551a58f3bc064c21c29","tid":855382,"uid":195627,"like":9,"dislike":1,"score":8,"citedBy":0,"replyTime":"2018-10-10T05:03:06.000Z","msg":"&ldquo;&hellip;&hellip;你結婚了嗎？&rdquo;<br />\n雪音用毫不顧慮的聲音問道。<br />\n&ldquo;誒？&rdquo;<br />\n突然的疑問讓來夏一瞬間眨巴起眼睛看著雪音的臉。<br />\n&ldquo;沒有哦。&rdquo;<br />\n&ldquo;要結婚了嗎？&rdquo;<br />\n紗羽有些吃驚似地問。<br />\n&ldquo;不結哦。&rdquo;<br />\n&ldquo;啊&mdash;&mdash;，果然。&rdquo;<br />\n紗羽恩恩點頭道。<br />\n和奏變得有些嚴肅起來，<br />\n&ldquo;&hellip;&hellip;難道說，因此分手了？&rdquo;<br />\n&ldquo;嘛，要這麼說的話也行。&rdquo;<br />\n&ldquo;詳細說說。&rdquo;<br />\n紗羽猛探出身子後，來夏苦笑起來，<br />\n&ldquo;等一下。雪音完全跟不上話題了對吧。&rdquo;<br />\n從剛才開始雪音就一副不明所以地樣子望著三人。<br />\n&ldquo;那個&hellip;&hellip;我之前有個交往了一段時間的男友，我和他在之前分手了。這件事和奏和紗羽<br />\n都知道，所以儘管知道了我懷孕這件事，也沒覺得我已經結婚了。因為沒有結婚的對象。<br />\n&rdquo;<br />\n&ldquo;但是&hellip;&hellip;那麼，他就是孩子的父親嗎？&rdquo;<br />\n雪音板著長臉問了後，紗羽和和奏也朝來夏投去了饒有興趣的目光。<br />\n&ldquo;是哦。&rdquo;<br />\n來夏爽快地說。<br />\n&ldquo;果然如此啊。&rdquo;<br />\n和奏嘀咕道。<br />\n&ldquo;這樣太不負責任了&hellip;&hellip;&rdquo;<br />\n雪音哀傷似地低下了頭。<br />\n&ldquo;先說好，我不是懷孕了然後被甩掉的哦。&rdquo;<br />\n&ldquo;誒？&rdquo;<br />\n雪音有些吃驚地看著來夏。<br />\n&ldquo;信息裡是說來夏提出的分手對吧？&rdquo;<br />\n紗羽說完，&ldquo;沒錯沒錯&rdquo;，和奏也點頭道。<br />\n&ldquo;恩。雖然他是個好人。做人很認真，也有責任感，所以我告訴他我懷孕了的時候，當場<br />\n就被求婚了。&rdquo;<br />\n&ldquo;求婚！？&rdquo;<br />\n和奏吃了一驚。<br />\n&ldquo;這還是第一次聽說。&rdquo;<br />\n紗羽也吃驚地看著來夏。<br />\n&ldquo;&hellip;&hellip;那，你拒絕了？&rdquo;，和奏問。<br />\n&ldquo;恩，就是這樣。&rdquo;<br />\n來夏輕快點頭後，<br />\n&ldquo;誒&hellip;&hellip;為什麼？&rdquo;<br />\n和奏疑惑地盯著來夏的臉。<br />\n&ldquo;因為&hellip;&hellip;我不想由於責任奉子成婚又在將來後悔。被求婚的時候，我也對他說了希望他<br />\n稍微等一下，結果就大吵了一架。然後我們就那麼分手了。如果我跟他道歉估計是能和好<br />\n的&hellip;&hellip;不過我考慮了許多之後，果然還是覺得結婚和孩子是兩件事。&rdquo;<br />\n緊繃這張臉聽完的和奏說，<br />\n&ldquo;&hellip;&hellip;那，如果他說願意等的話呢？&rdquo;<br />\n&ldquo;那樣的話，我們現在大概還在交往吧。可能之後會有一天我覺得和他結婚也挺好。&rdquo;<br />\n&ldquo;是嗎&hellip;&hellip;雖然對我來說是沒經歷過的事情&hellip;&hellip;不過，很有來夏的風格。&rdquo;<br />\n說完，和奏露出微笑。<br />\n紗羽也點頭微笑。<br />\n&ldquo;恩，很像來夏的風格。&rdquo;<br />\n雪音一言不發，呆呆地凝視著來夏。<br />\n&ldquo;但是，辛苦的是這之後哦&hellip;&hellip;&rdquo;<br />\n來夏靠到椅背上，抬頭望向天空，然後&ldquo;哈&mdash;&mdash;&rdquo;的大大嘆了口氣。<br />\n&ldquo;是呢。來夏要做媽媽了。&rdquo;<br />\n和奏感慨地看著來夏。<br />\n<br />\n<br />\n<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" />"},{"pid":"39d00e8f6608ed513a92ae9c084e3d10a6450c55","tid":855382,"uid":54025,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-10-10T05:15:44.000Z","msg":"條女真係癲架"},{"pid":"e505e59f6e332de98189588decf05198ed04b0a3","tid":855382,"uid":46389,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-10-10T05:16:45.000Z","msg":"樓豬幾多歲"},{"pid":"638d09e49150a1f1223f90a8d57e4fc91cf678f1","tid":855382,"uid":6327,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-10T05:36:11.000Z","msg":"奶水play了可以"},{"pid":"3139bbea9e75cafd85781a92d0094d6a8ab5da1f","tid":855382,"uid":54025,"like":1,"dislike":0,"score":1,"quote":{"pid":"e505e59f6e332de98189588decf05198ed04b0a3","tid":855382,"uid":46389,"like":1,"dislike":0,"score":1,"citedBy":1,"replyTime":"2018-10-10T05:16:45.000Z","msg":"樓豬幾多歲"},"citedBy":0,"replyTime":"2018-10-10T05:36:20.000Z","msg":"17"},{"pid":"b182780a8c444c4b98064128eca7c0017f30703f","tid":855382,"uid":34622,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-10T05:42:01.000Z","msg":"痴撚線<img src=\"/assets/faces/dog/give.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/angry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" /> <img src=\