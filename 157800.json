， 2017 年都投到一票。"},{"pid":"2978934c0026424374d4a62ebd2cbcb3e22221bf","tid":157800,"uid":43308,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-15T18:56:17.000Z","msg":"此回覆已被刪除"},{"pid":"b784559580dadfe367864fcff08b4ee37e01f28a","tid":157800,"uid":55597,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-15T19:10:27.000Z","msg":"有著數咪主流意見"},{"pid":"b152d308e1c88a91dd25e2302418aebd0cd88d02","tid":157800,"uid":41245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-15T19:11:14.000Z","msg":"林鄭釋詞<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"f8cdea79e5a1529e906bfae41f03a612f3cc105e","tid":157800,"uid":4158,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-15T23:00:09.000Z","msg":"過半支那人<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"}]}