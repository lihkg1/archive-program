if\" class=\"hkgmoji\" />"},{"pid":"4b286cb8bfcc5a58c4db085831132881e766b073","tid":1506104,"uid":106302,"like":2,"dislike":0,"score":2,"quote":{"pid":"936392979dc269948b90312d722a377003884c5d","tid":1506104,"uid":45523,"like":3,"dislike":0,"score":3,"quote":{"pid":"5751f935698d884d38c6e98519529f29d1f6d82b","tid":1506104,"uid":106302,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-25T17:11:55.000Z","msg":"唔供之後 換咗大陸野咪仲撚衰<img src=\"/assets/faces/pig/arrested.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-08-25T17:13:36.000Z","msg":"你唔係咁天真真係信係本地企業下話？"},"citedBy":0,"replyTime":"2019-08-25T17:14:50.000Z","msg":"是鳩但啦乜柒企業都唔可以監控<br />\n老母都唔可以監控我啦 何況係正苦"},{"pid":"527c884d7873099d3f755336758056b2600aed61","tid":1506104,"uid":522,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:17:24.000Z","msg":"<span style=\"font-size: large;\">傳統手法係換過另一間公司做 ，但背底裡又係同一班人就當咩事都無發生</span><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/smile.gif\" class=\"hkgmoji\" />"},{"pid":"0c15c4ae918a7b8d8cef7832068c1506e648c3a2","tid":1506104,"uid":14433,"like":0,"dislike":0,"score":0,"quote":{"pid":"deccb22dc373d6ba51a094c716fbbb9b29af6d5a","tid":1506104,"uid":136387,"like":3,"dislike":0,"score":3,"citedBy":3,"replyTime":"2019-08-25T17:09:43.000Z","msg":"講就咁講<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />實際仲供唔供就<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-08-25T17:17:31.000Z","msg":"冇錯，要check住"},{"pid":"d34d7e60b0af1d91c10961455da5b219b4b10a35","tid":1506104,"uid":254371,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-25T17:18:45.000Z","msg":"又屈示威者<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"956eb0c18f3940962300b6f859d333d49856f442","tid":1506104,"uid":73972,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-25T17:21:17.000Z","msg":"有古怪，驚人查落去？"},{"pid":"2b67287c32934163f7b4a7f52710b368294ba19e