{"tid":693942,"cid":15,"subCid":0,"title":"中興達成和解，港股好消息散貨，跌幅擴至２２３點報３１２８９","createTime":"2018-06-08T02:02:36.000Z","updateTime":"2018-06-08T03:50:53.000Z","uid":147097,"like":0,"dislike":1,"uniUserReply":1,"replies":[{"pid":"9b8f064bbf2b0e9e9f76812265512a82544a2f4c","tid":693942,"uid":147097,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-08T02:02:37.000Z","msg":"《經濟通通訊社８日專訊》中興（００７６３）與美國達成和解，惟港股六連升後，趁好消息散貨，跌幅擴至２２３點或跌０﹒７１％，報３１２８９，主板成交８５﹒５８億元。今早則低開７７點。　　上證綜合指數報３０９０﹒１６，跌１９﹒３４點或跌０﹒６２％，成交１５６﹒２４億元人民幣。國指則跌７０點報１２３３６。　　美國議員調查谷歌與騰訊（００７００）等中國合作夥伴的關係，騰訊現價跌１﹒６３％，報４２２﹒２元；成交約３２９萬股，涉資１３﹒９８億元。　　表列同板塊或相關股份表現："},{"pid":"c509e078544e57605ba6dde65c3e86a2c9fa08b5","tid":693942,"uid":147097,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-08T02:03:51.000Z","msg":"港估好消息=跌<br />\n<br />\n壞消息=升<br />\n<br />\n原來要咁睇<img src=\"/assets/faces/lomoji/33.png\" class=\"hkgmoji\" />"},{"pid":"411fef88137580f07f0ce310d1962e45a82fa62c","tid":693942,"uid":147097,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-06-08T03:50:53.000Z","msg":"<img src=\"/assets/faces/lomoji/40.png\" class=\"hkgmoji\" />"}]}