nt.uk/petitions/244402</a>"},{"pid":"aa8011c69f34476ec01916ff7273d1e5ae961b2f","tid":1471361,"uid":308875,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T07:17:00.000Z","msg":"【英重量級議員 促給港人完整英國國籍】<br />\n<br />\n英國下議院外交委員會主席圖根達特（Tom Tugendhat）呼籲，政府應給予香港人完整的英國國籍，作為與北京對峙的一種保障。（法新社）<br />\n<br />\n1分鐘時間幫幫手簽<br />\n夠10萬個就有機會喺英國國會討論<br />\n<br />\nPostal code 就打000000<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=SW1PDOKa3sbtYTDDPfmX3fSletu%2BpyBbwtETYsduqsw%3D&h=fb51eb30\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"c05f7c1a4abf346f519f2353df9624e7ad9793a1","tid":1471361,"uid":308875,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T11:51:42.000Z","msg":"求求00後都幫手簽, 對你地都有好處<br />\n<br />\n英重量級議員 促給港人完整英國國籍<br />\n<br />\n英國下議院外交委員會主席圖根達特（Tom Tugendhat）呼籲，政府應給予香港人完整的英國國籍，作為與北京對峙的一種保障。（法新社）<br />\n<br />\n1分鐘時間幫幫手簽<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n夠10萬個就有機會喺英國國會討論<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n點解要支持?<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n1.成功爭取父母啲BNO變BC後, 因關係可以用家庭團聚形式入籍<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n2.增加香港有外國國籍啲人數, 提升外國政府啲話語權<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n3.因中共反對, 所以我地更加要支持<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n4.中共話香港人都是中國公民, 唔通你地想一世都係中國公民?<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\nPostal code 就打000000<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=SW1PDOKa3sbtYTDDPfmX3fSletu%2BpyBbwtETYsduqsw%3D&h=fb51eb30\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"3e715595e4de0eac2052fbb57ab4e130e5272d31","tid":1471361,"uid":228955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-17T12:06:47.000Z","msg":"Share and up"},{"pid":"1b59ed36d3859a79b403c37151de52ab9de0974c","tid":1471361,"uid":308875,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-08-17T13:10:08.000Z","msg":"求求00後都幫手簽, 對你地都有好處<br />\n<br />\n英重量級議員 促給港人完整英國國籍<br />\n<br />\n英國下議院外交委員會主席圖根達特（Tom Tugendhat）呼籲，政府應給予香港人完整的英國國籍，作為與北京對峙的一種保障。（法新社）<br />\n<br />\n1分鐘時間幫幫手簽<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n夠10萬個就有機會喺英國國會討論<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n點解要支持?<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><br />\n1.成功爭取父母啲BNO變BC後, 因關係可以用家庭團聚形式入籍<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n2.增加香港有外國國籍啲人數, 提升外國政府啲話語權<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n3.因中共反對, 所以我地更加要支持<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n4.中共話香港人都是中國公民, 唔通你地想一世都係中國公民?<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n<br />\nPostal code 就打000000<br />\nBritish National (Overseas) Citizens should be given full British Citizenship.<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=SW1PDOKa3sbtYTDDPfmX3fSletu%2BpyBbwtETYsduqsw%3D&h=fb51eb30\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a>"},{"pid":"2137bba3c3be5a6f1cf000b8a72daad81d26d175","tid":1471361,"uid":228955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T07:04:48.000Z","msg":"Up and share"},{"pid":"7d7dbe9d902d78b9bb75bde0760caa5b3b54758a","tid":1471361,"uid":228955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T07:04:59.000Z","msg":"Share please"},{"pid":"122425cdac3b656a244819fd39ea2fa345942f7b","tid":1471361,"uid":290508,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-18T07:08:06.000Z","msg":"signed"},{"pid":"158df153de894c3f9640b471693171b8033c6b04","tid":1471361,"uid":228955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T07:17:53.000Z","msg":"<img src=\"https://na.cx/i/axLt5AA.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FaxLt5AA.jpg&h=7d0d3225&s={SIZE}\" />"},{"pid":"744341b21921d5aeb59ea68c1baee4e983a1ef7a","tid":1471361,"uid":154530,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T07:21:38.000Z","msg":"推"},{"pid":"a8cbb8a243d9198d29c90bc376c58c47eb51ad43","tid":1471361,"uid":19037,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-18T08:42:11.000Z","msg":"開始有大量疑似三毛質疑平權成效<br />\n<br />\n證明平權係啱嘅<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"9d5f94231e85c35e1d4b01c81099e27af2000632","tid":1471361,"uid":19037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T09:51:38.000Z","msg":"此誠危急存亡之秋也<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"29821a8ee298c8a8773cf9ea70b45a97214f101a","tid":1471361,"uid":55775,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-08-18T09:52:19.000Z","msg":"此回覆已被刪除"},{"pid":"61f3316a08e7535cb055ec2e92ba04c537043d3d","tid":1471361,"uid":308875,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T12:57:29.000Z","msg":"搵人比下意見<br />\nDear British Citizens,<br />\n<br />\nMost people who were born in Hong Kong before 1997 hold British National (Overseas) passport (BNO), which means they can only stay in the UK for up to 6 months. British National Overseas citizens are the only few nationalities with no right of abode in their own country.<br />\n<br />\nAs you may see on the news, China has breached the Sino-British Joint Declaration repeatedly, putting the lives of Hong Kong people at risk. We have no choice but to suffer under the Chinese rule.<br />\n<br />\nWe (British National Overseas citizens) are quality British. We can make Britain great again with the following facts:<br />\n1. Hong Kong people are highly educated. The majority of the young people received tertiary education. <br />\n2. GDP per capital of Hong Kong is comparable to that of UK, which ranks rank 15th in the world according to the International Monetary Fund (2018).<br />\n3. The average Hongkonger owns USD$245,000, which ranks 14th in the world according to the Global Wealth Report 2018 published by the Credit Suisse Research Institute.<br />\n4. Hong Kong people share common value with British.<br />\n5. Hong Kong people are pragmatic, industrious. We want to contribute to society.<br />\n6. We respect the rule of law because this is taught by the British before 1997.<br />\n<br />\nAs Tom Tugendhat (MP) put forward: &ldquo;The UK had obligations to Hong Kong citizens before 1997, and the extension of overseas citizenship, which is in many ways a second-tier citizenship, was a mistake, and I think it&rsquo;s one that should be corrected. At a time when there are clearly tensions in Hong Kong, the UK could reassure many Hong Kong citizens that their existing rights are recognised by the UK, and they are valued.&rdquo;<br />\n<br />\nPlease help Hong Kong by signing this petition:<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=SW1PDOKa3sbtYTDDPfmX3fSletu%2BpyBbwtETYsduqsw%3D&h=fb51eb30\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a><br />\n<br />\nYou help is much appreciated.<br />\n<br />\nMany thanks,<br />\nBritish National Overseas citizens<br />\n<img src=\"https://na.cx/i/jtvxPGP.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FjtvxPGP.jpg&h=a84e7b9a&s={SIZE}\" />"},{"pid":"e0d09b72799391813dbf5bfdad701a3239741bed","tid":1471361,"uid":228955,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T13:09:48.000Z","msg":"Up and share"},{"pid":"951667f55070bbf47884054f57a36ea006a1a77a","tid":1471361,"uid":31710,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T13:18:44.000Z","msg":"Push"},{"pid":"3e2cbc6b80332acc9eadeb8b8d5366cb8232ad36","tid":1471361,"uid":19037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T13:53:57.000Z","msg":"<img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/itdog2.gif\" class=\"hkgmoji\" />"},{"pid":"2b87f31c9b7f305caab0bbd447891e8af52a0fe3","tid":1471361,"uid":308875,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T14:21:57.000Z","msg":"幫幫手去reddit, twitter, facebook share, 等多D人簽<br />\nDear British Citizens,<br />\n<br />\nMost people who were born in Hong Kong before 1997 hold British National (Overseas) passport (BNO), which means they can only stay in the UK for up to 6 months. British National Overseas citizens are the only few nationalities with no right of abode in their own country.<br />\n<br />\nAs you may see on the news, China has breached the Sino-British Joint Declaration repeatedly, putting the lives of Hong Kong people at risk. We have no choice but to suffer under the Chinese rule.<br />\n<br />\nWe (British National Overseas citizens) are quality British. We can make Britain great again with the following facts:<br />\n1. Hong Kong people are highly educated. The majority of the young people received tertiary education. <br />\n2. GDP per capital of Hong Kong is comparable to that of UK, which ranks 15th in the world according to the International Monetary Fund (2018).<br />\n3. The average Hongkonger owns USD$245,000, which ranks 14th in the world according to the Global Wealth Report 2018 published by the Credit Suisse Research Institute.<br />\n4. Hong Kong people share common value with British.<br />\n5. Hong Kong people are pragmatic and industrious. We want to contribute to the British society, and we are willing to assimilate.<br />\n6. We respect the rule of law because this is the intrinsic value taught by the British before 1997.<br />\n<br />\nAs Tom Tugendhat (MP) put forward: &ldquo;The UK had obligations to Hong Kong citizens before 1997, and the extension of overseas citizenship, which is in many ways a second-tier citizenship, was a mistake, and I think it&rsquo;s one that should be corrected. At a time when there are clearly tensions in Hong Kong, the UK could reassure many Hong Kong citizens that their existing rights are recognised by the UK, and they are valued.&rdquo;<br />\n<br />\nPlease help Hong Kong by signing this petition:<br />\n<a href=\"https://petition.parliament.uk/petitions/244402\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fpetition.parliament.uk%2Fpetitions%2F244402&d=SW1PDOKa3sbtYTDDPfmX3fSletu%2BpyBbwtETYsduqsw%3D&h=fb51eb30\" data-auto-link target=\"_blank\">https://petition.parliament.uk/petitions/244402</a><br />\n<br />\nYou help is much appreciated.<br />\n<br />\nMany thanks,<br />\nBritish National Overseas citizens"},{"pid":"ffa48efafdb4fe13ebb6e79a2ae80964b9929757","tid":1471361,"uid":19037,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T14:47:40.000Z","msg":"已超過40000<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"5305981b41f22ce07a561148cdfa2abf0a827b1b","tid":1471361,"uid":308875,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-18T14:50:17.000Z","msg":"過四萬了<br />\n<