ih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F24%2F102611_1d31acb35f0410036419768c0f3734e8.png&h=a15aeeea&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/03/24/102612_00cb997cc109639500e2cdca9d4c5ade.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F24%2F102612_00cb997cc109639500e2cdca9d4c5ade.png&h=f51c873f&s={SIZE}\" /><br />\n<br />\n重有 converge 系列好多都可以攞嚟改可動<br />\n睇你肯唔肯試 <img src=\"/assets/faces/normal/wink.gif\" class=\"hkgmoji\" /><br />\n<br />\n台灣都有幾條友改過好多隻<br />\n呢個係其中一個<br />\n<a href=\"http://xpiritlee.blogspot.hk/?m=1\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fxpiritlee.blogspot.hk%2F%3Fm%3D1&d=PGvktPFvO8uhCwWWOTiXtcRCHeky4xD%2FQbA%2BfbsvJuc%3D&h=1283a31e\" target=\"_blank\">http://xpiritlee.blogspot.hk/?m=1</a><br />\n<br />\n改造教學<br />\n<a href=\"http://xpiritlee.blogspot.hk/2014/03/converge_23.html?m=1\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fxpiritlee.blogspot.hk%2F2014%2F03%2Fconverge_23.html%3Fm%3D1&d=PGvktPFvO8uhCwWWOTiXtcRCHeky4xD%2FQbA%2BfbsvJuc%3D&h=4293bbfd\" target=\"_blank\">http://xpiritlee.blogspot.hk/2014/03/converge_23.html?m=1</a><br />\n<br />\n<a href=\"http://xpiritlee.blogspot.hk/2016/01/converge-gp04.html?m=1\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fxpiritlee.blogspot.hk%2F2016%2F01%2Fconverge-gp04.html%3Fm%3D1&d=PGvktPFvO8uhCwWWOTiXtcRCHeky4xD%2FQbA%2BfbsvJuc%3D&h=7bdca9bd\" target=\"_blank\">http://xpiritlee.blogspot.hk/2016/01/converge-gp04.html?m=1</a><br />\n<br />\n如果各位有興趣改嘅可以淘寶搵呢種索帶做關節<br />\n㗎仔都推薦用<br />\n建議搵 3mm 粗嘅珠條<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/03/25/173932_6b9361d1ee756734e0813c497467a513.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F25%2F173932_6b9361d1ee756734e0813c497467a513.png&h=55a5e5b2&s={SIZE}\" /><br />\n<br />\n或者呢啲關節補品<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/03/25/174209_7eed12e84c95c2becbd3e4229a0e98c8.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F25%2F174209_7eed12e84c95c2becbd3e4229a0e98c8.png&h=ae55ee07&s={SIZE}\" /><br />\n<br />\n<img src=\"https://img.eservice-hk.net/upload/2018/03/25/174535_01f24117481b96f130fe20f63cea8f5f.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F25%2F174535_01f24117481b96f130fe20f63cea8f5f.png&h=552a0435&s={SIZE}\" /><br />\n<br />\n以上淘寶都搵得到<br />\n<br />\n改完貼水貼噴吓色就會正過 MSE 㗎喇 <img src=\"/assets/faces/normal/biggrin.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/03/25/175648_20a93d6cee318615a7b3523ee4a076e0.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F25%2F175648_20a93d6cee318615a7b3523ee4a076e0.png&h=6c480c3f&s={SIZE}\" /><br />\n<img src=\"https://img.eservice-hk.net/upload/2018/03/25/175649_ce893890aecd0bc5820217d191fb8ef4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2018%2F03%2F25%2F175649_ce893890aecd0bc5820217d191fb8ef4.png&h=51398773&s={SIZE}\" /><br />\n<br />\nby焦土新香港 巴打<br />\n改裝左隻z可以變形<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qmev1tHoWHcFKB9HT5iNxJCtXautnMhHjWEGCaYAQNwHfy?filename=Sxbrp7S.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FSxbrp7S.png&h=9629386a&s={SIZE}\" /><img src=\"https://ipfs.infura.io/ipfs/QmbZGfahw6Xx53MrbPMnVpSznYJuGmGKR5BynnrnjMoB4U?filename=ch5LFGr.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fch5LFGr.png&h=1b955aff&s={SIZE}\" /><br />\n<br />\n再改z <img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><br />\n今次加埋z plus<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmcKKdNBvk1ZCWBqWZnw4qMqQ3Cggd6RG72q42sm6bbtKZ?filename=6wiEY8a.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6wiEY8a.png&h=62fd4541&s={SIZE}\" /><br />\nMS組裝+ 加工<br />\n<img src=\"https://na.cx/i/m5N63qh.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fm5N63qh.png&h=77cdad9a&s={SIZE}\" /><img src=\"https://ipfs.infura.io/ipfs/Qma2BZchjFFikfPNX4i8EtHBJVrrBFdkFhwbaDSrBQFwqq?filename=ACExexL.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FACExexL.png&h=1a745d29&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmXFaGdMxzoDryRKcXzGZWeeEcYJiH21hyHunqJEKoDom1?filename=vzp5zxe.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fvzp5zxe.png&h=f549e27e&s={SIZE}\" /><img src=\"https://ipfs.infura.io/ipfs/QmTJ3esWK5DVXFfEzTYcSG2tWh8rMzXdHQf4ZRy5tFe3pP?filename=Dw2u1cr.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FDw2u1cr.png&h=cc7c2a50&s={SIZE}\" /><br />\nMA組裝<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmSYpTE5fGge6fcs1hTmTSv24kt43Jg7K9xGAEMJsD3g64?filename=ioQcYZ1.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FioQcYZ1.png&h=a6d91017&s={SIZE}\" /><br />\n再改z <img src=\"/assets/faces/lm2/bye.gif\" class=\"hkgmoji\" /><br />\n今次加埋z plus<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmcKKdNBvk1ZCWBqWZnw4qMqQ3Cggd6RG72q42sm6bbtKZ?filename=6wiEY8a.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F6wiEY8a.png&h=62fd4541&s={SIZE}\" /><br />\n<br />\nby潮吹小雛菊、餓聾先生、黑崎一心巴打<br />\n<blockquote>用左個連接件扮變形<img src=\"https://ipfs.infura.io/ipfs/QmUEN5RQnsjQqEVtdEtfSyoHTcA1nxo6izbQCTr9im6MAG?filename=kfQ9BVo.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FkfQ9BVo.png&h=23e5330d&s={SIZE}\" /></blockquote><img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /><br />\n<br />\n<blockquote><img src=\"https://ipfs.infura.io/ipfs/QmUUm95RzhFR3EyQszEsnjNtBkCRNuVcA2TeQjEL4EtWud?filename=yHGEwsu.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FyHGEwsu.png&h=517ba7d2&s={SIZE}\" /><img src=\"https://ipfs.infura.io/ipfs/QmUWn5oczM2vXmErj9Vih7NuLP8wRJMFC57RyPg7dUY9ji?filename=NhvxRsw.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FNhvxRsw.png&h=ab3db1ca&s={SIZE}\" /><img src=\"https://ipfs.infura.io/ipfs/QmUksFM5Q4MSoBtZbCXMi1cb9ubD12CjhL6rK83KNEWWfV?filename=HmAU4Nx.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHmAU4Nx.png&h=b9ce152a&s={SIZE}\" /><br />\n<br />\n同埋有冇巴打可以一齊分享下點變形<br />\n好難先整到流線形<br />\n咁樣已經用哂成pack連接件<img src=\"/assets/faces/fs/smile.gif\" class=\"hkgmoji\" /></blockquote>我前邊po冇頭嗰張 你點睇?<br />\n我用左兩粒parts<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmPJHUeV85y3oz21Rbheg43idNRe3HK4Jeciaq7EAbEp1V?filename=mY69eC4.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FmY69eC4.png&h=e47e3521&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmYDzvNdPq8q2ixQ1WKaJYH84jqmnPcjP4Sw1dPwn2rQRA?filename=Mt1AUC6.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FMt1AUC6.png&h=c7e7b90e&s={SIZE}\" /><br />\n<br />\nby黑色騎士團巴打<br />\n開心share出渕 裕配色<br />\n<img src=\"https://ipfs.infura.io/ipfs/QmVgVZWPwDR4KAM2sxaFKimkSwCPXQSdjx4UgxrVe5y4BY?filename=5i2HyYV.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F5i2HyYV.png&h=5d4db5a6&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/QmQkV8D7k9PMMaVnMk5Z8r8xnNN2H7hxvtUE6nxZ7byXxf?filename=UFpOuxj.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FUFpOuxj.png&h=ed29a8ff&s={SIZE}\" /><br />\n<img src=\"https://ipfs.infura.io/ipfs/Qma3c83LshzDCpv7SKiLAJnAyRB2idxFPT9fuY9o8pG6az?filename=ub7gDqF.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2Fub7gDqF.jpg&h=d3f8e1f3&s={SIZE}\" /><br />\n<br />\n其他收藏品/作品/教學各位自己再追返舊Post<i