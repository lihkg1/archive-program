3a9acc44aed125eff6038d394","tid":560930,"uid":48479,"like":5,"dislike":3,"score":2,"citedBy":0,"replyTime":"2018-02-16T15:38:45.000Z","msg":"人生第一次自己一條友去戲院睇戲就on99咁入錯院<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n本來買咗飛睇福爾摩斯，入錯場睇大魔術師<img src=\"/assets/faces/lny/clown.png\" class=\"hkgmoji\" />"},{"pid":"940e00c2706798bbe125b00901e78e7804cea328","tid":560930,"uid":36049,"like":5,"dislike":13,"score":-8,"citedBy":0,"replyTime":"2018-02-16T15:58:41.000Z","msg":"睇春嬌與志明<br />\n唔記得左1,2集劇情以為入錯劇院😂😂😂😂"},{"pid":"fa6cacfc5a9fcb1c8f95dd8c29f410dd5e672572","tid":560930,"uid":142748,"like":48,"dislike":0,"score":48,"citedBy":0,"replyTime":"2018-02-16T16:03:59.000Z","msg":"<blockquote>睇玩轉極樂園<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 無啦啦播冰雪奇緣 以為入錯院</blockquote><br />\n我本身唔知玩轉極樂園喺講咩<br />\n但條女想睇就買咗飛入場<br />\n開頭播心諗做咩播冰雪奇緣<br />\n但播咁到咁上下<br />\n我就肯定喺播緊冰雪第二集<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <br />\n仲同條女講 喔 原來喺冰雪第二集<br />\n<br />\n屌你老味播咁撚長<img src=\"/assets/faces/lomoji/05.png\" class=\"hkgmoji\" />"},{"pid":"6b547305cdf55f62c0f493e4a874147f3ca5388e","tid":560930,"uid":136790,"like":0,"dislike":0,"score":0,"quote":{"pid":"e0c5b11685ba24ebf2287b41a64bee2f05b7bf84","tid":560930,"uid":4402,"like":584,"dislike":12,"score":572,"citedBy":3,"replyTime":"2018-02-15T02:49:17.000Z","msg":"睇玩轉極樂園<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> 無啦啦播冰雪奇緣 以為入錯院"},"citedBy":1,"replyTime":"2018-02-16T16:04:54.000Z","msg":"<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"ae50d008386e57c07a16b9e673d05b0242dcf4ff","tid":560930,"uid":15935,"like":6,"dislike":0,"score":6,"quote":{"pid":"6b547305cdf55f62c0f493e4a874147f3ca5388e","tid":560930,"uid":136790,"like":0,"dislike":0,"score":0,"quote":{"pid":"e0c5b11685ba24ebf2287b41a64bee2f05b7bf84","tid":560930,"uid":4402,"like":584,"dislike":12,"score":572,"citedBy":3,"replyTime":"201