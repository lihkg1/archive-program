=\"hkgmoji\" />"},{"pid":"9cac6199e3816ac05bbb9a55c3c10c63f29e0fb3","tid":1633850,"uid":225192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T07:39:38.000Z","msg":"又係支那或成最大嬴家D朋友<br />\n<br />\n五大訴求缺一不可<br />\n核爆都唔割"},{"pid":"46005803a4c31d68d3cc9d4a589d0b0ac58b73bb","tid":1633850,"uid":93986,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-07T07:42:21.000Z","msg":"中共期望香港獨立的三大理由"},{"pid":"a1ccecae295da3ab803f516f38f29d8ad1f77b6b","tid":1633850,"uid":3080,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-10-07T07:49:26.000Z","msg":"雖然知01係黨媒,但平時都會扮下中立<br />\n呢篇嘢啲文風直頭同大公文匯真係一撚樣<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"424e76783b91383c48e4c990b7b79ed8247a9fea","tid":1633850,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T07:51:46.000Z","msg":"香港人反共<br />\n所以將計就計詭儍仔<br />\n配合民主黨<br />\n<br />\n要記住，香港事務，兩黨既幫忙都多謝<br />\n但講反共決心，侵侵》〉》〉》民主黨"},{"pid":"de30a8fb96e2c13a884cfade0a9311defe782021","tid":1633850,"uid":265192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T07:57:12.000Z","msg":"<img src=\"https://na.cx/i/JG49P0v.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FJG49P0v.jpg&h=bfdca82e&s={SIZE}\" /><br />\n<br />\n行動Post : <a href=\"https://lih.kg/1634329\" data-auto-link target=\"_blank\">https://lih.kg/1634329</a><br />\n<br />\n<span style=\"font-size: x-large;\"><strong><span style=\"color: orange;\">目標一、哂馬</span></strong></span><br />\n由於警狗唔再批不反，即使批左亦會製造衝突。<br />\n為左令和理非可以舒舒服服地出返黎，展示人數同民意，<br />\n所以就利用黃店門外既人龍，製造畫面同話題吸引媒體注意。<br />\n<br />\n<strong><span style=\"font-size: x-large;\"><span style=\"color: orange;\">目標二、支持黃色經濟</span></span></strong><br />\n依幾個月生意難免受影響，加上可能被藍絲杯葛，<br />\n良心黃店係好需要大家支持。<br />\n最實際既支持當然就係拎銀包出黎，入錢入錢入錢！<br />\n另外參考連登既食評，由於良心經營既關係，黃店食物質素一般都偏高，<br />\n絕對係win win雙贏！<br />\n<br />\n------------國際文宣------------<br />\n請將買返黎既貨物/食物/單據同排隊盛況<br />\n一齊用<strong><span style=\"font-size: xx-large;\"><span style=\"color: red;\">#Buy4HK</span></span></strong><br />\n放上IG, Twitter, reddit"},{"pid":"8fdc1dfca1a9b15b3cf4af547e67f227ba87da9b","tid":1633850,"uid":265192,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-07T07:57:59.000Z","msg":"連登仔唔好燈呀 <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 燒山快d毒啞自已"},{"pid":"36bb1aae6e36355803b20988932c1228d37a6c59","tid":1633850,"uid":155095,"like":0,"dislike":0,"score":0,"quote":{"pid":"46005803a4c31d68d3cc9d4a589d0b0ac58b73bb","tid":1633850,"uid":93986,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-07T07:42:21.000Z","msg":"中共期望香港獨立的三大理由"},"citedBy":0,"replyTime":"2019-10-08T09:17:39.000Z","msg":"最多變新疆，唔會俾香港獨立"},{"pid":"6a54d797f5bc3bb91297da478e02129772576658","tid":1633850,"uid":155095,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-09T14:22:04.000Z","msg":"push"}]}