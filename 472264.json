faces/normal/clown.gif\" class=\"hkgmoji\" />"},{"pid":"b86d4a360f1b6b99e7ea0384e97d34b1549cfe27","tid":472264,"uid":45914,"like":1,"dislike":2,"score":-1,"citedBy":0,"replyTime":"2017-11-18T05:43:53.000Z","msg":"此回覆已被刪除"},{"pid":"f34d9e119e8da5199261c869a660e1b4d902d0f2","tid":472264,"uid":53223,"like":2,"dislike":12,"score":-10,"citedBy":0,"replyTime":"2017-11-18T05:44:04.000Z","msg":"咁咪要離開香港？"},{"pid":"44821f89277cf4d974b5b8b26ce4338c0997a078","tid":472264,"uid":132,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-18T05:45:17.000Z","msg":"屌呃正評<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cd83d427e8d9ac5ad622934ee164413f273fd74f","tid":472264,"uid":63845,"like":48,"dislike":10,"score":38,"citedBy":0,"replyTime":"2017-11-18T05:46:24.000Z","msg":"一個二個開埋晒啲<br />\n認同A觀點就<img src=\"/assets/faces/normal/like.gif\" class=\"hkgmoji\" /><br />\n認同B觀點就<img src=\"/assets/faces/normal/dislike.gif\" class=\"hkgmoji\" /> <br />\n既膠post<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n如果你問我，呢班人係咪真心熱愛投選運動而做呢種事，以我觀察黎睇，好明顯唔係<img src=\"/assets/faces/normal/z.gif\" class=\"hkgmoji\" /> <br />\n<br />\n就等我抽樣搵少少例子<br />\n<br />\n[二選一] 靜靜雞 定 靜雞雞<br />\n<a href=\"https://lihkg.com/thread/445235\" target=\"_blank\">https://lihkg.com/thread/445235</a><br />\n呢類就最為垃圾既，乜柒都無直接彈兩行野叫人投，不過呢個post就天有眼，無人理佢，抵死<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n揸車嘅你地 會唔會讓斑馬線<br />\n<a href=\"https://lihkg.com/thread/439945\" target=\"_blank\">https://lihkg.com/thread/439945</a><br />\n同上，都係果啲引人望完個正負就會輕易有答案既垃圾post，而呢個更加有幾百人投添，無眼睇<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n[有圖]係火車無啦啦有條女係我張床<br />\n<a href=\"https://lihkg.com/thread/445123\" target=\"_blank\">https://lihkg.com/thread/445123</a><br />\n呢個相對黎講已經算好啲，本來一路都有圖有字，但好可惜條友最後都係屎忽痕要整返個投票調查，而好明顯個風向都實係吹向佢set做正評果個option架啦，結果又成為一個make到noise上熱門既廢post<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\n<br />\n不過有好就當然會有更加廢既，而最令人覺得肉酸既係呢類post誇起上黎往往係可以比人煲到上千even數千正評，咁我一開頭就話係心理唔平衡既人為呃正評先會開呢類post<br />\n<br />\n不過由我一路打呢篇野一路搵資料啦<br />\n我發現如果話晒佢地係心理唔平衡而咁做，的確係太過主觀有欠公允，所以我又得出左另一個原因<br />\n就係呢類人表達能力極度有問題，佢地唔開呢類正負評post就無辦法進行正常既討論，如果你講野mean啲，直頭可以稱呢類人係智障都完全無問題<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /><br />\n<br />\n咁當然無論以上人士係心理唔平衡又好定表達能力有缺撼都好，我都會建議佢地立即就醫，唔好再沉溺連登損人不利己啦<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /><br />\n<br />\n其實搞公投，舉行投選活動就無罪既，但如果係濫用左就當然唔可取，呢啲人開埋晒呢啲問東問西或者係邊條女正啲既post，好啦問完之後又有咩用呢，任何投選投票都一定有佢自身既出發點，如果投完之後根本無下文無用處既，唔單止浪費資源，仲對真心熱愛投票活動既朋友仔都好唔公平，因為真係令投票既本質改變晒，搞到低質晒<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /> <br />\n<br />\n咁成日開無聊投票既低質會員睇到呢度，以後仲會唔會咁做？希望你呢啲垃圾識諗喇快啲收手喇<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"47c5894d584e0271d28e6de5d566b63a611c77ad","tid":472264,"uid":139224,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-18T05:48:13.000Z","msg":"你話俾一億我但成世住支那就要諗姐"},{"pid":"92ed0ec13e0643e1cd6023e171451ec234a4e9c6","tid":472264,"uid":71373,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-18T05:49:26.000Z","msg":"已經五年冇返<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"b0564e4adc4cb9733acc1d4fdb9953f752dc1688","tid":472264,"uid":88182,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-11-18T05:49:40.000Z","msg":"唔肯<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"0b665f4ca4f72b6b7de28e1455b8d8f1445e9d98","tid":472264,"uid":85659,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-11-18T05:55:29.000Z","msg":"樓主係咪問錯左?查實係俾一億一世唔可以離開支那<img src=\"/assets/faces/normal/angel.gif