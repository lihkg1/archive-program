32e7","tid":1171530,"uid":57461,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-25T23:36:06.000Z","msg":"我最近第二次斷acl同傷半月板<br />\n上次手術都係兩年前 <br />\n上次私家做 十幾皮<br />\n今次寫左信政府 唔知係咪嚴重<br />\nD期排得超快 上星期已經照左xray <br />\n下兩星期就CT 跟住7月頭覆診<br />\n應該一兩個月可以手術"},{"pid":"f882a24f994313363c119248d7953721df2353f8","tid":1171530,"uid":23197,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-26T00:44:50.000Z","msg":"你點整親"},{"pid":"14c77b48405e8aae3456563e1e24684ebafdb383","tid":1171530,"uid":143598,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-05-26T02:30:58.000Z","msg":"照左mri先算"},{"pid":"ded495b99e9ee41c742dcf53afd69decef4d1f1a","tid":1171530,"uid":204205,"like":0,"dislike":0,"score":0,"quote":{"pid":"7f72c30c1203f91dc537432ba1a3e95ebdc100ac","tid":1171530,"uid":39216,"like":0,"dislike":0,"score":0,"quote":{"pid":"602a5d01da2083ddba017cc6df141abcdad603d3","tid":1171530,"uid":204205,"like":0,"dislike":0,"score":0,"quote":{"pid":"71a3c42640789c9928b32727ca0cb3d1e451757d","tid":1171530,"uid":39216,"like":1,"dislike":0,"score":1,"citedBy":2,"replyTime":"2019-05-25T19:49:10.000Z","msg":"要睇下你有無內出血，如果個膝頭仲腫緊就要等。<br />\n我就隔咗成10年先做。"},"citedBy":1,"replyTime":"2019-05-25T20:22:28.000Z","msg":"隔十年都做得<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />咁個問題解決左一大半！！！<br />\n我主要係暫時冇錢！怕唔即刻搞會有大問題<img src=\"/assets/faces/fs/dead.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-05-25T21:37:02.000Z","msg":"你唔踢波唔打籃球其實對身體無大礙"},"citedBy":1,"replyTime":"2019-05-27T15:13:55.000Z","msg":"我有睇網上話，如果唔做劇烈運動，根本斷左都唔影響日常生活！<br />\n其實暫時先都行到，係怕日後想駁番唔知會唔會太遲依下有啲擔心！"},{"pid":"02b889c67ff2fba7afb605c119fb19b5cd254a25","tid":1171530,"uid":204205,"like":0,"dislike":0,"score":0,"quote":{"pid":"44689035635d55952a0fd6bfe5325935fd2332e7","tid":1171530,"uid":57461,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-25T23:36:06.000Z","msg":"我最近第二次斷acl同傷半月板<br />\n上次手術都係兩年前 <br />\n上次私家做 十幾皮<br />\n今次寫左信政府 唔知係咪嚴重<br />\nD期排得超快 上星期已經照左xray <br />\n下兩星期就CT 跟住7月頭覆診<br />\n應該一兩個月可以手術"},"citedBy":1,"replyTime":"2019-05-27T15:16:33.000Z","msg":"十幾皮<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n我見好多人都傷acl多我就內側副韌帶，唔知兩者症狀同治療係咪相近呢！？<br />\n<br />\nBTW，Ching你係私家做完效果點？係咪有傷前8～9成？"},{"pid":"f2043dec2f023ac8be08a201d4c9e7634902ec4f","tid":1171530,"uid":197437,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-27T15:26:11.000Z","msg":"要確診係咪韌帶斷裂，一定係照MRI<br />\n唔好諗住睇急症室會有得安排照，因為MRI唔係urgent嘢，急症室最多照到xray黎睇骨頭有冇事，同埋可以試下問急症室拎轉介信去私家做MRI<br />\n排政府MRI唔係唔得，但你要預幾年時間，同埋只有骨科專科先安排到政府既MRI，所以多數醫生都建議病人去私家照MRI<br />\n所以，唔好話慳錢，點都俾錢去照，起碼知清楚咩傷勢<br />\n希望你快d好番"},{"pid":"839f380ca611e2503c0723494ccfac38c86b5d57","tid":1171530,"uid":204205,"like":1,"dislike":0,"score":1,"quote":{"pid":"f882a24f994313363c119248d7953721df2353f8","tid":1171530,"uid":23197,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-26T00:44:50.000Z","msg":"你點整親"},"citedBy":1,"replyTime":"2019-05-27T15:28:40.000Z","msg":"我係溜冰<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n果時失平衡，隻腳向外曲咁跌落地但未跌得哂，跟住我就想格硬整番自己起身，但唔夠力，結果成個人既身體重量壓左落去個關節度，啪左一聲後，隻腳軟哂同無力！但當下就唔係好痛，重行到，係feel到個關節唔穩定同隻腳無乜力！<img src=\"https://na.cx/i/AuxoZRU.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FAuxoZRU.jpg&h=20ed7aef&s={SIZE}\" /><br />\n就好似張相做深蹲，但隻左腳同左膝關節再向外轉多啲，咁個重量一壓落去，個膝關節食哂啲力，向外扭左一下咁！"},{"pid":"14cf59d4127f731fa14d5f5012cbfc76b3793d6e","tid":1171530,"uid":204205,"like":1,"dislike":0,"score":1,"quote":{"pid":"839f380ca611e2503c0723494ccfac38c86b5d57","tid":1171530,"uid":204205,"like":1,"dislike":0,"score":1,"quote":{"pid":"f882a24f994313363c119248d7953721df2353f8","tid":1171530,"uid":23197,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-05-26T00:44:50.000Z