c=\"/assets/faces/lomoji/16.png\" class=\"hkgmoji\" />"},{"pid":"4c20d46fb027c26dcbce7a3244024ad0639d1121","tid":263892,"uid":80724,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T15:51:41.000Z","msg":"中西湯<br />\n老火、滾湯定罐頭湯，一律通殺<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"b52244b461e3877e170b65cc3078b9443dda312b","tid":263892,"uid":43096,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T16:00:11.000Z","msg":"<img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bouncer.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" />"},{"pid":"da25d1b40607299d451bf5acd26a20e0ffbb9d1a","tid":263892,"uid":104917,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T16:20:44.000Z","msg":"正呀<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <br />\n想學下自己煲湯 但係覺得買材料已經好麻煩同埋唔識揀<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"443247809bb27c5669d344979f74793b214808a9","tid":263892,"uid":71428,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T16:27:25.000Z","msg":"由細到大係屋企食都係咁<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n又唔覺腸胃差"},{"pid":"956b2f9320b33a9b75f8c9c09ab44e085a849017","tid":263892,"uid":75485,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-05-30T16:41:07.000Z","msg":"花膠雞湯撈飯<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"5581164c34b4afd66e950fc5e45720f96635b283","tid":263892,"uid":55533,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T16:59:45.000Z","msg":"淨白飯好難食<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><br />\n一定要有汁/湯撈飯先食得落"},{"pid":"5482781781d0d3845ea5a7b28f402f9c971c9310","tid":263892,"uid":3233,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T17:05:40.000Z","msg":"鴨腿湯飯<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"b110010df797fb5a9ae7a55258dcc5b302ab7c74","tid":263892,"uid":28806,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-05-30T17:27:47.000Z","msg":"湯撈飯拎到飯既澱粉質被口水既amylase 消化減弱，所以係小腸到會用更多時候消化。而湯撈飯又會加快我地進食速度，咪變相加重小腸既消化負擔，所以咪有機會唔舒服咯。<br />\n另外，胃係用嚟消化protein ，飯係starch ，所以飯唔是係胃消化。"},{"pid":"8a04fc9a2f6511c2c4b4ae80f9676dc7bc3cba72","tid":263892,"uid":85805,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T17:31:38.000Z","msg":"蕃薯魚湯<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" />"},{"pid":"8efb533121b54c05ecfff9c8d27832ebd8f0817d","tid":263892,"uid":85805,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T17:32:08.000Z","msg":"<blockquote>蕃茄魚湯<img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/love.gif\" class=\"hkgmoji\" /></blockquote><br />\n<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"2dbe5a0baf521d194345a15edc673633d1f0bb9d","tid":263892,"uid":57785,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-30T17:33:16.000Z","msg":"番茄湯撈飯<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"}]}