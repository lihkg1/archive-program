ad5283f9","tid":1278341,"uid":6152,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:07:15.000Z","msg":"Push<br />\n前線手足<br />\n一個都不能少"},{"pid":"798007f82433dd362531c249058f461509864e48","tid":1278341,"uid":12864,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:09:27.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"3e284bd0b4fbd7f95f961877b6363ec23c609007","tid":1278341,"uid":138966,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-02T17:10:26.000Z","msg":"多謝你地嘅付出"},{"pid":"fc42908cd44661df95dfa242877576251d6f672c","tid":1278341,"uid":118791,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-07-02T17:11:36.000Z","msg":"屌 今日要喊幾多次<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"030688b10dd2a0d5b49a152c08bf4f27a022f921","tid":1278341,"uid":4619,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:17:55.000Z","msg":"堅守訴求"},{"pid":"dd757d60b90fbdd4f93ef7cb642f9996f096fdea","tid":1278341,"uid":89882,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:22:15.000Z","msg":"Push!"},{"pid":"c97f4568205b2073de37bb21b4b7db32df3f0be6","tid":1278341,"uid":225869,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:22:37.000Z","msg":"push"},{"pid":"c4bfc0899a0f11ec677c8d625e458e22e33709a5","tid":1278341,"uid":12176,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-07-02T17:26:10.000Z","msg":"<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />睇到好心痛..."},{"pid":"76a10b6895d5da0c1c7fd9d8193160d077703eb9","tid":1278341,"uid":195485,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:29:36.000Z","msg":"不如大家都落街幫手做文宣 減輕下佢哋負擔<br />\n<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"dc738adabd94d91d2f34a9e031f149e080a670ae","tid":1278341,"uid":207702,"like":0,"dislike":0,"score":0,"quote":{"pid":"1d98195ba2216631fa580d89edf0cb41011da45e","tid":1278341,"uid":248449,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2019-07-02T12:10:07.000Z","msg":"請容許我講啲冇人知道嘅我發過嘅夢。<br />\n<br />\n係。我係發緊夢。<br />\n我係一個19dse嘅中學生。<br />\n<br />\n6月6日，我開始幫街站手派傳單，而係嗰個禮拜之間都有幫手過幾次。係當中我認識咗一位前線嘅朋友，我對佢嘅第一印象，就係好冷漠好冷漠。佢並唔多嘢講，唔出聲。不過邊度街站需要幫手，佢都會仆出去幫，無論有幾夜、無論天氣有幾熱、無論有幾攰。而遊行當日，佢要走到最前，成個氣場就係，勇武派。到咗6月12，夢裡面佢亦係夏愨道前線第一線嘅其中一員，但係講緊嘅第一線其實只有6至7個。所以可以話係最前最前嗰一批。我好佩服前線，真心好敬佩。我之前係覺得佢地犧牲自己嘅時間同精神，去為香港嘅所有人去爭取我地應有嘅權利。但係原來佢地所付出嘅，往往比我想像中嘅多更多更多。<br />\n<br />\n佢同我講，佢地唔係因為有希望先企最前，而係憤怒、絕望到一個唔想再絕望落去嘅地步。佢地出嚟，老老實實，係以一種冇嘢可以輸嘅心態，只係爭在條命。但以我所知，佢地如果有機會贏，即使要死，佢哋都在所不惜。身為前線，佢地同自己講唔可以頹。佢地企係人群最前，如果連帶頭嘅都頹，後面嘅人點？ 6月12，啲人驚就開始撇，而佢地係前面食曬啲催淚彈、胡椒噴霧、布袋彈、橡膠彈⋯話個身好似比火燒咁，但係仲要撐住啲遮，死守防線後面，用自己嘅生命去嗌人唔好走。佢地一開始都好驚，但後尾開始麻木，已經唔怕催淚彈，攞住把遮，想退都唔可以退。因為佢地知道，呢個時候，更加唔可以亂咗陣腳，因為後面嘅人，都係靠佢地嚟保護。企係前線嘅全部都係95後，甚至乎有00後嘅喊曬口話好驚、好想走，但係依然企係度死守。前線嘅情況可以話係極度辛苦同絕望，去到後尾換嚟嘅，係政苦嘅漠視、和理非嘅批評、身邊屋企人朋友嘅指責。咁請問，佢地有乜理由要為我地香港人做咁多嘢，為唔理解唔支持佢地嘅人犧牲咁多？每一位前線嘅人員，其實好攰好想放棄，但係因為佢地愛港，唔希望見到自己居住嘅地方變成一個法治淪陷，再都無自由嘅地方。因為佢地知道，佢地唔出嚟就無人會出，所以危險嘅勇武嘅就靠佢地嚟做。<br />\n<br />\n佢地一班前線，自從6月11晚就一直留守到依家。呢一個月一個禮拜加埋都訓唔到一日，我有時過去煲底搵佢，都會埋一埋堆同成班前線吹下水。而琴日 7月1 我又發夢自己融入咗佢地嘅一份子，佢地前線同物資站因為多日嘅留守變咗同一堆人，所以我去咗幫物資方面。煲底係一個充滿咗人情味嘅地方。明明我只係搭上搭，佢地都好關照我，當曬自己人咁，好多重要情報會同我講，亦承諾一定會安全送我地每一位backup嘅離開。前線嘅人，佢地明知道身邊有唔係勇武派嘅同伴，依然會尊重、會關顧。咁點解我地呢一班所謂嘅和理非，要去指責、阻止佢地嘅行動？我好中意佢地每一位，不論為香港、為佢地、我好想衝出去同佢地共同進退。但係我自己有包袱係身，亦清楚自己未有足夠嘅能力可以幫到手，甚至可能成為負累。我好自責，好唔甘心，但係佢地仲要安慰我，同我講「唔緊要」，「幫backup都幫到好多」，「好叻女」；呢一批咁衝動嘅人，其實係咪只有衝動？我可以講，佢地好清楚發生緊咩事，好清楚自己做緊啲乜，同身邊嘅人做緊啲乜。佢地嘅崗位背負住全港人嘅希望，為我地抗爭、戰鬥，仲要睇住後面所有嚟支援嘅抗爭者。我真係覺得佢地好偉大，更加顯得自己無用。<br />\n<br />\n而琴日我發夢夢到正正係呢一批，我所認識嘅前線人員，係6月30通宵至7月1呢一晚，投咗票決定出嚟做死士。我無諗過會有報導報出呢件事，咁我亦唔怕講。我唔知係邊幾位，佢地係自己圍內傾好咗，都係唔方便透露。其實聽到真係好沉重。好沉重。佢地每一個為咗呢一個地方，連死都願意。究竟係我地掙扎緊好攰，唔知出定唔出嘅時候，出嚟危唔危險，甚至係被捕風險嘅時候，佢地已經決定咗去犧牲自己嘅生命。佢地係為咗自己？點會係。就算就算，呢一場仗即使勝利，佢地個人唔係度，又可以享有啲咩回報？佢地出嚟即使無事，企得前線一定比人搭，坐翻十年八年，佢地又係為咗啲咩？就係為咗捍衛香港嘅自由、法治、良知。仲有守護我地呢一班土生土長嘅香港人。為咗我地，佢地負上咗一切一切。面對佢地，我覺得自己實在係太過渺小，太過無能為力。"},"citedBy":0,"replyTime":"2019-07-02T17:31:02.000Z","msg":"唔該咁多位巴絲打檢舉埋呢條撚樣 將義士放上網<br />\n<a href=\"https://lih.kg/1279363\" data-auto-link target=\"_blank\">https://lih.kg/1279363</a><br />\n- 分享自 LIHKG 討論區<br />\n呢個都要幫手推同檢舉"},{"pid":"b1ce2ad396358dbdab396234bc5e20f4a09ca1ed","tid":1278341,"uid":159791,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-07-02T17:37:18.000Z","msg":"感動感動<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"3d8653211179e3720a0a742b7d1a28220bce395a","tid":1278341,"uid":42194,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:42:14.000Z","msg":"push<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"0532b27ea22ab7aebf18a304a343ce0a99ce7870","tid":1278341,"uid":27578,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:43:56.000Z","msg":"推"},{"pid":"5203c96d2c5fa91bc40637efad4b16658128d21e","tid":1278341,"uid":25164,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:45:43.000Z","msg":"<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/run.gif\" class=\"hkgmoji\" />"},{"pid":"a16293f1c759782b3c6b3bd59f8769d7a4b180f7","tid":1278341,"uid":40902,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:47:13.000Z","msg":"<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"cc48cc09079421725b0fd5ab18a23bb7b3c193fb","tid":1278341,"uid":230290,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:55:54.000Z","msg":"推"},{"pid":"685a805bf8f472322dc03a3a40220b013c897957","tid":1278341,"uid":263395,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:57:27.000Z","msg":"推<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"b77584577fa2839a687cda0054be3e718300b3c2","tid":1278341,"uid":206021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:58:26.000Z","msg":"Push"},{"pid":"0e2692f8ba48f14db6c01434f30753aa56721b3c","tid":1278341,"uid":185048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:58:38.000Z","msg":"推"},{"pid":"e743ac30021f1bbf25c337769c7f2899b6eff725","tid":1278341,"uid":206021,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:58:43.000Z","msg":"屌<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"1b198d74a4af329a955cd4f84b1ab55a7ff51ce8","tid":1278341,"uid":185048,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T17:58:51.000Z","msg":"推"},{"pid":"81ef5cc87d8bd6f6ba61e8fa454ec0bad7fe7c0e","tid":1278341,"uid":266879,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T18:01:50.000Z","msg":"推  多謝<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"49ecd850621becc3bc97e58ca1bbc962b2db4f3e","tid":1278341,"uid":188104,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T18:02:52.000Z","msg":"push"},{"pid":"b9d1c1081aee8f05d039295b9a8a2ab94278ae4a","tid":1278341,"uid":8175,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-02T18:04:46.000Z","msg":"話之你勇武定和理非！只要有相同目標嘅就係同路人！<br />\n一齊加油！"},{"pid":"5e48da06d48ab51c853291c16f31bc65a499b74f","tid":1278341,"uid":110