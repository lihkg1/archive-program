chk%2Fimages%2Ff%2Ffa%2FIbvexqKQrPKgRe.jpg%2Frevision%2Flatest%3Fcb%3D20121104181929&h=fb3865d3&s={SIZE}\" />"},{"pid":"6dbee59c823d60914df4b0fd85c0fe5ee6b52f1f","tid":1993503,"uid":66987,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-29T06:25:24.000Z","msg":"<a href=\"https://www.facebook.com/pingshansouthleungtakming/videos/vb.108599527186604/1587924664697664/?type=2&amp;theater\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.facebook.com%2Fpingshansouthleungtakming%2Fvideos%2Fvb.108599527186604%2F1587924664697664%2F%3Ftype%3D2%26theater&d=C0QxMr2ftqWfBh1dRblImGWYsxP5Z0Wle18NOkmjjC4%3D&h=1668375d\" target=\"_blank\">https://www.facebook.com/pingshansouthleungtakming/videos/vb.108599527186604/1587924664697664/?type=2&amp;theater</a>"},{"pid":"dfd9acc7cc13cdb8858bf9b4876c6198d99a9fac","tid":1993503,"uid":66987,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-04-29T06:40:36.000Z","msg":"是咁的<br />\n<br />\n平時一大早起身見到梁德明<br />\n<br />\n我已經&quot;動L&quot;左既小弟弟就想向佢發炮<img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><br />\n<br />\n但為求對小明既尊重<br />\n<br />\n於是我特登谷左五日唔打飛機<br />\n<br />\n諗住一炮過射俾小明俾佢做facial<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n今日已經谷左五日如箭在弦既小弟弟再忍唔住啦<br />\n<br />\n一開電視，小明已經係到ready 緊我d面部護理&quot;精&quot;華&quot;液&quot;<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /><br />\n<br />\n我用手將小弟弟好似shotgun咁狂chok<img src=\"/assets/faces/normal/bomb.gif\" class=\"hkgmoji\" /><br />\n<br />\n就黎顏射佢既時候...你老母<br />\n<br />\n電視突然轉左做林鄭<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/fire.gif\" class=\"hkgmoji\" /><br />\n<br />\n我幾億精兵又忍唔住出左一半，收唔撚番<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n<br />\n於是一路嗌：哎呀，仆街啦，你老母，呀...呀...呀...呀...呀...<br />\n<br />\n就咁我幾億子彈射左落林鄭塊面到<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<br />\n仆街，而家仲好撚興<img src=\"/assets/faces/normal/angry.gif\" class=\"hkgmoji\" /> ，早知下次定住個畫面先射<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n還番我谷左五個禮拜既精兵俾我呀<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"33313f873367dcdc8ecf29a2a05f1c8804d7f638","tid":1993503,"uid":66987,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-29T06:55:20.000Z","msg":"推<img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/whip.gif\" class=\"hkgmoji\" />"},{"pid":"4bfed1427e4ae8fc81807fb5c000ec3143fe1405","tid":1993503,"uid":244808,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-29T07:35:35.000Z","msg":"好大隻下！"},{"pid":"7a9fc938217fdfd4686d06c8eb91d3744c1a2cfb","tid":1993503,"uid":93986,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-04-29T07:38:41.000Z","msg":"<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/norma