 src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"d71c9d92592f68b6972e092a08a05c5208295e37","tid":353220,"uid":35070,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-08-09T12:13:55.000Z","msg":"有冇加密都成問題<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"33c036d5dad48061d9fca0dd1aafb92327690fb7","tid":353220,"uid":52459,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-08-09T12:20:57.000Z","msg":"有得用信用卡增值，再withdraw 錢走嗎？<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"f641f66b2b5e4b32e04235d23ef63df0ae54cfc2","tid":353220,"uid":57705,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-08-09T12:37:19.000Z","msg":"此回覆已被刪除"}]}