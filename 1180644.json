=54573835</a>"},{"pid":"443fca7343fe2a6dea8c8fbe3edae3d4accd1800","tid":1180644,"uid":68509,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-06-01T04:33:49.000Z","msg":"根本就on撚99 愛乜撚柒國吖"},{"pid":"fe7e60277490f298eb112d984ffacbb0df3ad750","tid":1180644,"uid":20867,"like":3,"dislike":0,"score":3,"quote":{"pid":"443fca7343fe2a6dea8c8fbe3edae3d4accd1800","tid":1180644,"uid":68509,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-06-01T04:33:49.000Z","msg":"根本就on撚99 愛乜撚柒國吖"},"citedBy":0,"replyTime":"2019-06-01T04:35:43.000Z","msg":"<blockquote>「學了個新詞：離岸愛國主義」</blockquote><br />\n<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"1f4c490f4cb7111135d024743b0381f8fe7164bb","tid":1180644,"uid":118120,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-06-01T04:36:34.000Z","msg":"愛國既錢最好賺"},{"pid":"f3c98d9254720293058dfceb2e43f7fab225ab56","tid":1180644,"uid":19557,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-01T04:37:51.000Z","msg":"笑撚死<img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"7d4b878f9da3378b0f9dec498ca71f921607bbcc","tid":1180644,"uid":53122,"like":22,"dislike":0,"score":22,"citedBy":1,"replyTime":"2019-06-01T04:37:52.000Z","msg":"愛國只係一份工作"},{"pid":"b5adc45b6ea7709a7aeb01f9fdb54066eb5d0b15","tid":1180644,"uid":59898,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-01T04:38:06.000Z","msg":"<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"ef6d8476d1945836b9a06633e79899eb90cc4ba6","tid":1180644,"uid":19557,"like":11,"dislike":0,"score":11,"quote":{"pid":"68cf4367594b2953d0cabb7e7093c73b06aa2de9","tid":1180644,"uid":149494,"like":131,"dislike":4,"score":127,"citedBy":2,"replyTime":"2019-06-01T04:21:51.000Z","msg":"呢d人先最醒, 有美國藉可以享受自由既空氣<br />\n又可以接大陸job做打手<