2edad025b94","tid":2372941,"uid":160638,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-20T06:31:32.000Z","msg":"樓上全部調返轉，大個反而細膽咗<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-20T11:26:37.000Z","msg":"你個標題 「反而」已經有問題 <img src=\"/assets/faces/mousexm/medicine.gif\" class=\"hkgmoji\" />"},{"pid":"c0445aa83c1b88b189b7ceec1b2c9983a66ce0f5","tid":2372941,"uid":152867,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-01-22T03:28:32.000Z","msg":"其實因為驚係人對未來嘅未知事物產生嘅情緒<br />\n<br />\n你細個細膽 大個夠膽做係因為你已長大 知道個expected outcome 從而衡量自己去唔去做<br />\n<br />\n如果掉返轉果啲 係因為你細個唔識死 大個諗返知道個outcome係有大機會係死 所以咪唔做<br />\n<br />\n情緒係好正常嘅事 係你身體嘅一部分 <br />\n而呢個世界好多都係由呢啲化學反應去運作"},{"pid":"9b67de4e56dee30057fe7a13deb1a0e6e6302eb6","tid":2372941,"uid":129658,"like":1,"dislike":0,"score":1,"quote":{"pid":"58f46c81e53249794740321412b9b3928fb2c941","tid":2372941,"uid":46979,"like":4,"dislike":0,"score":4,"citedBy":2,"replyTime":"2021-01-20T11:15:56.000Z","msg":"細個好撚怕事，俾人屌都唔敢出聲<br />\n依家人屌我一句屌番人十句"},"citedBy":0,"replyTime":"2021-01-22T03:41:18.000Z","msg":"我都係，會即刻駁咀<img src=\"/assets/faces/normal/slick.gif\" class=\"hkgmoji\" />"},{"pid":"cfb0d117bac5d156cd4d6a56387eb0d88de801e3","tid":2372941,"uid":171615,"like":0,"dislike":0,"score":0,"quote":{"pid":"7914aa83267bc17facd167a48b6b8ed09fc65490","tid":2372941,"uid":192078,"like":0,"dislike":0,"score":0,"quote":{"pid":"b260197d940b83f348ca17f9486682edad025b94","tid":2372941,"uid":160638,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-01-20T06:31:32.000Z","msg":"樓上全部調返轉，大個反而細膽咗<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2021-01-20T11:26:37.000Z","msg":"你個標題 「反而」已經有問題 <img src=\"/assets/faces/mousexm/medicine.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2021-01-22T03:45:46.000Z","msg":"因為細個無諗