fa9","tid":1251321,"uid":264676,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:11:52.000Z","msg":"唔好意思，借個位黎擺下，希望更多人見到<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n<a href=\"https://lihkg.com/thread/1251015/page/1\" target=\"_blank\">https://lihkg.com/thread/1251015/page/1</a><br />\n<br />\n<img src=\"https://na.cx/i/Cu2oJOS.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FCu2oJOS.jpg&h=a799cc9a&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/ASGkL2d.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FASGkL2d.jpg&h=daa617d8&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/HoeZg8U.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FHoeZg8U.jpg&h=9f294cad&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/wF8LcRB.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FwF8LcRB.jpg&h=04cf3bea&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/gJ9ixLx.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FgJ9ixLx.jpg&h=3be87dce&s={SIZE}\" />"},{"pid":"97505fa4ed6f210c26dddee89e0568bc34c15a2a","tid":1251321,"uid":514,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:21:32.000Z","msg":"推"},{"pid":"f8dbee1e5c5dbe5855addb9ab9f0a4bf0ad38228","tid":1251321,"uid":55130,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T03:22:13.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"8f5295f340ca84cd9e6b252840fb00d22497e8dd","tid":1251321,"uid":6833,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T04:44:55.000Z","msg":"幫手推"},{"pid":"896d47e80133999b2b520d61c678a8611100acff","tid":1251321,"uid":55130,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-23T04:47:08.000Z","msg":"<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},{"pid":"b7086642aac0e4f0e9400367896012b5af85a325","tid":12513