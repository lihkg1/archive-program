ts/faces/dog/haha.gif\" class=\"hkgmoji\" />"},{"pid":"4a502e63909684f974ceb2e99bc8ea5c6ebd33be","tid":1477072,"uid":3405,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-16T05:07:04.000Z","msg":"大公報都唔使人買<br />\n佢地成日周圍派"}]}