://i.imgur.com/mhdDm8B.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fi.imgur.com%2FmhdDm8B.gif&h=0b8f8d01&s={SIZE}\" />"},{"pid":"1e359ba173a4ce5759b2d40f2af53d57a01e3ccf","tid":159342,"uid":82921,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-17T02:05:10.000Z","msg":"lm？"},{"pid":"2de9c4e883316aec1e0886c654f4d08e39659e28","tid":159342,"uid":80481,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-17T02:05:31.000Z","msg":"<img src=\"https://img.eservice-hk.net/upload/2017/03/17/100530_d0b3244693f743a542dc6a84b8f5ae22.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F03%2F17%2F100530_d0b3244693f743a542dc6a84b8f5ae22.jpg&h=dac43214&s={SIZE}\" />"},{"pid":"e460664f9afa98d67bf65048df6bd881ea87bf9a","tid":159342,"uid":25345,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-17T02:05:34.000Z","msg":"<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"3a6d33a714fd2ce16e68757a16f752b65bbaaae2","tid":159342,"uid":20943,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-17T02:05:37.000Z","msg":"喂阿哥 少咗一層嘅"},{"pid":"28f0191b296bb563e29616bc3d0383b4ecf74d8b","tid":159342,"uid":62635,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-17T02:06:19.000Z","msg":"<strong><span style=\"font-size: xx-large;\"><span style=\"color: green;\">新垣結衣x瑛太W主演映畫《ミックス。》(混合雙打)<br />\n挑戰乒乓球題材的浪漫喜劇！ </strong></span></span><br />\n<br />\n<br />\n<img src=\"https://na.cx/i/97B91eP.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F97B91eP.jpg&h=61a86686&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/4TB523R.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4TB523R.jpg&h=c72bb608&s={SIZE}\" /><br />\n<br />\n腳本：古沢良太（Legal High 腳本） <br />\n監督：石川淳一（Legal High 監督） <br />\n<br />\n共演卡司：広末涼子、遠藤憲一、田中美佐子、佐野勇斗、瀬戸康史、永野芽郁、蒼井優、森崎博之、吉田鋼太郎、生瀬勝久、山口紗彌加、斎藤司、久間田琳加、鈴木福、谷花音、真木よう子、小日向文世等。 <br />\n<br />\n　　2月中旬開始攝影，2017年秋全國東寶系公開！ 新垣結衣飾演戀愛和工作都很失敗的原天才乒乓球少女、快30歲的單身OL富田多滿子，與瑛太飾演的原日本職業拳擊手組合成乒乓球混雙，向全國大賽挑戰的故事。<br />\n<br />\n<span style=\"color: green;\"><span style=\"font-size: xx-large;\"><strong>《Code Blue 3》製作決定!!</strong></span></span><br />\n<img src=\"https://img.eservice-hk.net/upload/2017/03/10/100302_53bdee902bf86890010775dc3176e6ed.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fimg.eservice-hk.net%2Fupload%2F2017%2F03%2F10%2F100302_53bdee902bf86890010775dc3176e6ed.jpg&h=039dc2f5&s={SIZE}\" /><br />\n5月開拍，時間設定於第2季的七年後，播放時間：7月份 月九<br />\n<br />\n十年過去，各人都走上自己的人生道路。<br />\n藍沢耕作（山下智久）離開咗翔陽大學附屬醫院嘅急症室之後，喺腦外科深造研究，目標係成為最強嘅腦外科醫生。<br />\n白石恵（新垣結衣）就繼續喺人手不足嘅翔北急症室工作，成為咗飛行救護團隊嘅領導醫生奮鬥中！<br />\n緋山美帆子（戸田恵梨香）就去咗備產醫療中心，喺婦產科果度深造。<br />\n冴島はるか（比嘉愛未）依家繼續做緊飛行團隊嘅護士。<br />\n藤川一男（浅利洋介）同白石一齊留咗喺翔北急症室，只係自己向着成為整形外科嘅急症室醫生之路進發。<br />\n面臨新挑戰，失去家人，開始戀愛，在新嘅階段有邊個對手等緊佢哋？<br />\n<br />\n來自 Gakki 的訊息：<br />\n　　「在最初的《Code Blue》拍攝中收到的20歲生日祝福，好像已經過了很久，又像是最近的事。在這20代的最後一年再次扮演白石惠，以及劇組時隔7年的集結，感受到極大的緣分和使命感。全新的《Code Blue》故事中，狀況、立場、所有的事物都有很大的改變，當時一起努力著的5人會有什麼發展我非常期待。希望能讓觀眾看得開心，也希望能夠有所收穫，我會全力以赴的！」<br />\n<a href=\"http://ricgrady.pixnet.net/blog/post/117081740\" data-sr-url=\"https://r.lihkg.com/link?u=http%3A%2F%2Fricgrady.pixnet.net%2Fblog%2Fpost%2F117081740&d=ZBayvnjX3omFcj6xyood9I9%2BoveFa0K0Z8Wn6wXPu4k%3D&h=78773843\" target=\"_blank\">http://ricgrady.pixnet.net/blog/post/117081740</a><br />\n<br />\n~~~~~~~~~~~~~~~~~~~~~~~~~~~~<br />\n<br />\n<span style=\"color: green;\"><strong><span style=\"font-size: xx-large;\">相集</span></strong></span><br />\n<br />\n擺圖用google drive：<a href=\"https://goo.gl/qXk2TG\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgoo.gl%2FqXk2TG&d=ZBayvnjX3omFcj6xyood9I9%2BoveFa0K0Z8Wn6wXPu4k%3D&h=66b0394a\" target=\"_blank\">https://goo.gl/qXk2TG</a><br />\n<br />\nios用Whatsapp save gif 教學：<a href=\"https://goo.gl/EpWsmP\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgoo.gl%2FEpWsmP&d=ZBayvnjX3omFcj6xyood9I9%2BoveFa0K0Z8Wn6wXPu4k%3D&h=3c980610\" target=\"_blank\">https://goo.gl/EpWsmP</a><br />\n<br />\n華田PS去底小心得：<a href=\"https://goo.gl/YFByBR\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fgoo.gl%2FYFByBR&d=ZBayvnjX3omFcj6xyood9I9%2BoveFa0K0Z8Wn6wXPu4k%3D&h=7582e073\" target=\"_blank\">https://goo.gl/YFByBR</a><br />\n<br />\n<img src=\"http://i.imgur.com/BQxA8i5.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=http%3A%2F%2Fi.imgur.com%2FBQxA8i5.gif&h=fd7485c5&s={SIZE}\" /><br />\nCredit：華田"},{"pid":"19115231789263e3f92d11e5953db431dd357d0b","tid":159342,"uid":82921,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-17T02:08:59.000Z","msg":"<span style=\"color: red;\"><span style=\"font-size: xx-large;\">此po已完</span></span>"},{"pid":"cb208f3e378126a8bdeef90a3b5397d1d1006543","tid":159342,"uid":79089,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-17T02:18:21.000Z","msg":"兩邊都留名<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" />"},{"pid":"3d2a6a34d698896d3a9cbebff13ca6ade11cc76d","tid":159342,"uid":70800,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-17T02:20:37.000Z","msg":"<img src=\"/assets/faces/normal/wonder.gif\" class=\"hkgmoji\" />"},{"pid":"ac822c7491fa2842530a7758ae12d58ea9a2148d","tid":159342,"uid":34156,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-17T02:29:33.000Z","msg":"第一頁<img src=\"/assets/faces/normal/hoho.gif\" class=\"hkgmoji\" />"},{"pid":"e30f8a33f6900a733ed6e0f8752211bb3d0c55aa","tid":159342,"uid":894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-03-17T02:49:20.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"aa36a1df54b9b3a2af5a382fb10f8cd2814f551e","tid":159342,"uid":894,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017