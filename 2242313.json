e02cc00c112e84cbe80a81dfc","tid":2242313,"uid":346701,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2020-10-14T09:23:21.000Z","msg":"唔死都無用"},{"pid":"f2c21179e356abce2dcc358ff5393b824d659cf8","tid":2242313,"uid":201604,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-14T09:24:54.000Z","msg":"200蚊同你收左佢"},{"pid":"5b2a36b37bf595562519975eee3a06390f7549a8","tid":2242313,"uid":155371,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2020-10-14T09:37:34.000Z","msg":"香港人兇宅都無得住<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"96c47cf98fddb984a9921684f3d4e136f0418288","tid":2242313,"uid":25213,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2020-10-14T09:46:56.000Z","msg":"香港人幾撚折墮"},{"pid":"2627013c399d6439c1a56afea1c9391931716a63","tid":2242313,"uid":299263,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-14T09:48:29.000Z","msg":"政府<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"9ebae0dbc891b8dc8a6fe537f6a86d397a36bb2d","tid":2242313,"uid":195136,"like":7,"dislike":0,"score":7,"quote":{"pid":"90f9e4a46a15d8e33490e71d869e2d9ab7c5d360","tid":2242313,"uid":66271,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-14T02:51:04.000Z","msg":"香港樓價高企令不少人「上車」無望，就連公屋亦因長期短缺而「一房難求」，凶宅或近垃圾房的單位成上樓捷徑。有網民近日在內地社交平台「小紅書」發現一篇帖文，只見一名女子表示剛拿到火炭駿洋邨的鎖匙，上門收樓目睹「實物」後，卻大嘆公屋不如私人樓，更直言與丈夫「超級無語」。<br />\n<br />\n有網民今日（13日）在網上討論區「連登」發帖，指在「小紅書」發現一篇帖文，只見有一名女子成功上樓後，卻大嘆公屋不如私人樓。對此，網民大為憤怒：「有朋友send畀我睇到燥咗&hellip;&hellip;可以點樣舉報？」<br />\n<br />\n從該則帖文可見，該名女子上月21日在其「小紅書」個人頁面上，分享多張駿洋邨單位的內部照片，只見應是未開始裝修的清水樓，但她對此表示：<br />\n<br />\n<span class=\"red\">「駿洋村（邨），昨天拿了鑰匙，差一點沒要。以前聽人說住公屋挺好，但是住慣私人住宅去到公屋的地方就知道滋味了，和我老公這2天超級無語。」</span><br />\n<br />\n<img src=\"https://resource01-proxy.ulifestyle.com.hk/res/v3/image/content/2775000/2775705/red131020204_600.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fresource01-proxy.ulifestyle.com.hk%2Fres%2Fv3%2Fimage%2Fcontent%2F2775000%2F2775705%2Fred131020204_600.jpeg&h=3ae4e3b5&s={SIZE}\" /><br />\n<br />\n帖文一出，隨即引來不少網民留言怒斥：「覺得無語就把公屋交回房屋署，多少人恨都恨唔到！」、「對，很多香港人排了八年也還沒排到。」、「那就拒絕，然後繼續住私樓，把資源留給更有需要的人。」、「那就繼續住私人住宅呀，環境肯定不一樣的。」<br />\n<br />\n而查看該名女子過往在「小紅書」上的帖文可見，有4篇是與國際名牌Louis Vuitton（LV）有關；其中有3篇是「開箱文」，另一篇則是題為「氣死我了」的「抱怨文」。<br />\n<br />\n在該篇「抱怨文」中，她指自己背上「我的新LV」去朋友家聚會，「香港地方太小，人又多，想找地方放我的包也沒合適的地方，我就放我坐的凳（櫈）子上了，趕緊去瞅一眼兒子」；當她10多分鐘後從房間出來時，卻看到「驚人」一幕，<br />\n<br />\n「有一個朋友就把我的包掛在窗上的鐵鉤上，天啊！把我氣死了，五金磨破了幾處地方，我好心疼呀！又不是她拿錢出來買的包，當然不心疼啦！我都不知道怎麼說了，另外一次也是這樣，朋友居然把我香香（應意指「香奈兒（Chanel）」）仍（扔）地上OMG（Oh My God）都是些甚麼人呀？」<br />\n<br />\n女子抱怨自己的「新LV」被友人掛在窗上鐵鉤。<br />\n對此，有網民在該則「抱怨文」下留言詢問：「住公屋的人為甚麼購買能力這麼高？」而在另一則「開箱文」中，亦有網民詢問：「住公屋為甚麼買得起奢侈品？」<br />\n<br />\n房屋署：濫用公屋可遭檢控<br />\n<br />\n據房屋署資料指，公共房屋是社會寶貴資源，必須善用及合理編配給真正有需要人士；如租戶被證實濫用公屋，除會被終止租約外，更可能會遭檢控。除屋邨辦事處執行日常租約管制工作外，房屋署亦成立了「善用公屋資源分組」，打擊濫用公屋。<br />\n<br />\n以下為舉報濫用公屋途徑：<br />\n<br />\n致電房屋委員會熱線 2712 2712<br />\n填交「舉報濫用公屋郵柬」 或 「舉報濫用公屋表格」<br />\n在網上填寫和遞交「舉報濫用公屋網上表格」<br />\n舉報濫用公屋網上表格<br />\n通知屋邨辦事處<br />\n房屋署表示，舉報者所提供的一切資料，署方會絕對保密。"},"citedBy":1,"replyTime":"2020-10-14T09:51:04.000Z","msg":"舉報肯做先得架<br />\n其實點解佢地咁快上樓<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n香港人排成十幾二十年<br />\n佢地應該7年都未夠"},{"pid":"f62f39334273c6c50b2b86f937e662d2108afa1e","tid":2242313,"uid":6297,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2020-10-14T09:56:23.000Z","msg":"其實check 吓大陸戶口資產，check 大陸房產證有幾難"},{"pid":"5e068fe89bc2857b21e2e06f286e0c6d2093dccc","tid":2242313,"uid":60307,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-14T09:57:44.000Z","msg":"大陸應該有幾層樓<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"44c0f98599b4115bbeb6834b977d4bd2b8f1fb97","tid":2242313,"uid":195136,"like":12,"dislike":0,"score":12,"quote":{"pid":"d228191b422c2a5872245619d9c797d81b5ea190","tid":2242313,"uid":122134,"like":483,"dislike":2,"score":481,"citedBy":1,"replyTime":"2020-10-14T03:00:28.000Z","msg":"<span class=\"red\">房屋署：濫用公屋可遭檢控</span><br />\n<br />\n最後check到係大陸人<br />\n表示無濫用<br />\n<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-14T09:59:02.000Z","msg":"香港房屋署依家有誠信可言？<br />\n仲衰過黑警<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n將香港福利送俾亞南同大陸人香港人要捱貴租<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" /><br />\n你睇下新加坡佢地點處理外來人同本地人分別<br />\n仲有張超雄我屌你老母含家富貴<img src=\"/assets/faces/pig/knife.gif\" class=\"hkgmoji\" />"},{"pid":"8926ee35b3aa1c6853a294a17ee3a5afccdc88df","tid":2242313,"uid":29080,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-10-14T09:59:39.000Z","msg":"😓"},{"pid":"6d0596d4af112eb1822289d62c841fe1f9f47a71","tid":2242313,"uid":227628,"like":7,"dislike":2,"score":5,"quote":{"pid":"b2a1a19a43596044335c85cc2b0ab9fa0e946642","tid":2242313,"uid":374024,"like":3,"dislike":35,"score":-32,"citedBy":2,"replyTime":"2020-10-14T03:51:01.000Z","msg":"支那新移民黃 邊忽黃<br />\n條底褲黃定屙果督尿黃<br />\n連登仔一齊批鬥支那新移民<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2020-10-14T10:08:24.000Z","msg":"又一支竹竿<img src=\"/assets/faces/dog/zzz.gif\" class=\"hkgmoji\" />"},{"pid":"e6a80ec25e8b2caa2ec150789ec566247e8fe036","tid":2242313,"uid":367177,"like":16,"dislike":2,"score":14,"quote":{"pid":"b2a1a19a43596044335c85cc2b0ab9fa0e946642","tid":2242313,"uid":374024,"like":3,"dislike":35,"score":-32,"citedBy":2,"replyTime":"2020-10-14T03:51:01.000Z","msg":"支那新移民黃 邊忽黃<br />\n條底褲黃定屙果督尿黃<br />\n連登仔一齊批鬥支那新移民<img src=\"/assets/faces/pig/cook.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2020-10-14T10:08:51.000Z","msg":"我識有個新移民同學係勇武<br />\n上佢屋企玩<br />\n佢老豆連廣東話都講唔正<br />\n但係屌鳩黑警同港共<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"cd4136477f96a5d11a116b1ad16cadeb0e1e213c","tid":2242313,"uid":46933,"like":2,"dislike":0,"score":2,"quote":{"pid":"9ebae0dbc891b8dc8a6fe537f6a86d397a36bb2d","tid":2242313,"uid":195136,"like":7,"dislike":0,"score":7,"quote":{"pid":"90f9e4a46a15d8e33490e71d869e2d9ab7c5d360","tid":2242313,"uid":66271,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-14T02:51:04.000Z","msg":"香港樓價高企令不少人「上車」無望，就連公屋亦因長期短缺而「一房難求」，凶宅或近垃圾房的單位成上樓捷徑。有網民近日在內地社交平台「小紅書」發現一篇帖文，只見一名女子表示剛拿到火炭駿洋邨的鎖匙，上門收樓目睹「實物」後，卻大嘆公屋不如私人樓，更直言與丈夫「超級無語」。<br />\n<br />\n有網民今日（13日）在網上討論區「連登」發帖，指在「小紅書」發現一篇帖文，只見有一名女子成功上樓後，卻大嘆公屋不如私人樓。對此，網民大為憤怒：「有朋友send畀我睇到燥咗&hellip;&hellip;可以點樣舉報？」<br />\n<br />\n從該則帖文可見，該名女子上月21日在其「小紅書」個人頁面上，分享多張駿洋邨單位的內部照片，只見應是未開始裝修的清水樓，但她對此表示：<br />\n<br />\n<span class=\"red\">「駿洋村（邨），昨天拿了鑰匙，差一點沒要。以前聽人說住公屋挺好，但是住慣私人住宅去到公屋的地方就知道滋味了，和我老公這2天超級無語。」</span><br />\n<br />\n<img src=\"https://resource01-proxy.ulifestyle.com.hk/res/v3/image/content/2775000/2775705/red131020204_600.jpeg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fresource01-proxy.ulifestyle.com.hk%2Fres%2Fv3%2Fimage%2Fcontent%2F2775000%2F2775705%2Fred131020204_600.jpeg&h=3ae4e3b5&s={SIZE}\" /><br />\n<br />\n帖文一出，隨即引來不少網民留言怒斥：「覺得無語就把公屋交回房屋署，多少人恨都恨唔到！」、「對，很多香港人排了八年也還沒排到。」、「那就拒絕，然後繼續住私樓，把資源留給更有需要的人。」、「那就繼續住私人住宅呀，環境肯定不一樣的。」<br />\n<br />\n而查看該名女子過往在「小紅書」上的帖文可見，有4篇是與國際名牌Louis Vuitton（LV）有關；其中有3篇是「開箱文」，另一篇則是題為「氣死我了」的「抱怨文」。<br />\n<br />\n在該篇「抱怨文」中，她指自己背上「我的新LV」去朋友家聚會，「香港地方太小，人又多，想找地方放我的包也沒合適的地方，我就放我坐的凳（櫈）子上了，趕緊去瞅一眼兒子」；當她10多分鐘後從房間出來時，卻看到「驚人」一幕，<br />\n<br />\n「有一個朋友就把我的包掛在窗上的鐵鉤上，天啊！把我氣死了，五金磨破了幾處地方，我好心疼呀！又不是她拿錢出來買的包，當然不心疼啦！我都不知道怎麼說了，另外一次也是這樣，朋友居然把我香香（應意指「香奈兒（Chanel）」）仍（扔）地上OMG（Oh My God）都是些甚麼人呀？」<br />\n<br />\n女子抱怨自己的「新LV」被友人掛在窗上鐵鉤。<br />\n對此，有網民在該則「抱怨文」下留言詢問：「住公屋的人為甚麼購買能力這麼高？」而在另一則「開箱文」中，亦有網民詢問：「住公屋為甚麼買得起奢侈品？」<br />\n<br />\n房屋署：濫用公屋可遭檢控<br />\n<br />\n據房屋署資料指，公共房屋是社會寶貴資源，必須善用及合理編配給真正有需要人士；如租戶被證實濫用公屋，除會被終止租約外，更可能會遭檢控。除屋邨辦事處執行日常租約管制工作外，房屋署亦成立了「善用公屋資源分組」，打擊濫用公屋。<br />\n<br />\n以下為舉報濫用公屋途徑：<br />\n<br />\n致電房屋委員會熱線 2712 2712<br />\n填交「舉報濫用公屋郵柬」 或 「舉報濫用公屋表格」<br />\n在網上填寫和遞交「舉報濫用公屋網上表格」<br />\n舉報濫用公屋網上表格<br />\n通知屋邨辦事處<br />\n房屋署表示，舉報者所提供的一切資料，署方會絕對保密。"},"citedBy":1,"replyTime":"2020-10-14T09:51:04.000Z","msg":"舉報肯做先得架<br />\n其實點解佢地咁快上樓<img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><br />\n香港人排成十幾二十年<br />\n佢地應該7年都未夠"},"citedBy":1,"replyTime":"2020-10-14T10:14:05.000Z","msg":"佢地一路住大陸一路排"},{"pid":"5f69ea7689b7c474de781e181f2dad65de72d68d","tid":2242313,"uid":105890,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-14T10:18:32.000Z","msg":"點會差過私樓呀 <br />\n<br />\n睇連登 個個成功人士都係住公屋喺工廈返工 <br />\n<br />\n住半山潮撚濕 住寶馬山一落山就俾福建幫斬 火炭好住好多"},{"pid":"21dbb120990e72981f45cbe6bbf4dcea6136c462","tid":2242313,"uid":34929,"like":0,"dislike":0,"score":0,"quote":{"pid":"5f69ea7689b7c474de781e181f2dad65de72d68d","tid":2242313,"uid":105890,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-10-14T10:18:32.000Z","msg":"點會差過私樓呀 <br />\n<br />\n睇連登 個個成功人士都係住公屋喺工廈返工 <br />\n<br />\n住半山潮撚濕 住寶馬山一落山就俾福建幫斬 火炭好住好多"},"citedBy":0,"replyTime":"2020-10-14T10:20:53.000Z","msg":"返觀塘夠熱鬧"},{"pid":"a3c581f45daf56d8de21ef9cd235dc177ab6bd91","tid":2242313,"uid":139506,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-14T10:22:42.000Z","msg":"大陸人黎，好撚嬲，房署有冇真係查入息架"},{"pid":"293bf99d6b73e2b8b1772b8d312d3e28064fc50b","tid":2242313,"uid":68598,"like":2,"dislike":0,"score":2,"quote":{"pid":"a3c581f45daf56d8de21ef9cd235dc177ab6bd91","tid":2242313,"uid":139506,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-14T10:22:42.000Z","msg":"大陸人黎，好撚嬲，房署有冇真係查入息架"},"citedBy":1,"replyTime":"2020-10-14T10:24:32.000Z","msg":"剩查香港 <br />\n有撚用咩<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"5366131038375486b2126c12822ea7477f351813","tid":2242313,"uid":16164,"like":1,"dislike":0,"score":1,"quote":{"pid":"293bf99d6b73e2b8b1772b8d312d3e28064fc50b","tid":2242313,"uid":68598,"like":2,"dislike":0,"score":2,"quote":{"pid":"a3c581f45daf56d8de21ef9cd235dc177ab6bd91","tid":2242313,"uid":139506,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-10-14T10:22:42.000