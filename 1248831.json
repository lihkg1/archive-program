78d374fd198f9ec25fbe87ebbe2654","tid":1248831,"uid":126099,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:39:38.000Z","msg":"一定要走 入夜危險"},{"pid":"f5b1dbb861d27f19e2ed5c16661a8d72b3ed99cc","tid":1248831,"uid":45983,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:39:46.000Z","msg":"走"},{"pid":"cbef84fe14e6f4217de07389a0e63514543a3a23","tid":1248831,"uid":196829,"like":3,"dislike":0,"score":3,"citedBy":0,"replyTime":"2019-06-21T14:40:08.000Z","msg":"巴打我明呀<br />\n<br />\n但好多人好早出左嚟已經累<br />\n夜晚無光線少記者 對我地好唔著數<br />\n<br />\n而家民意係我地果邊<br />\n<span style=\"font-size: large;\"><span style=\"color: red;\">搵日再出黎慢慢撚佢地 先為上策</span></span>"},{"pid":"dcfa0077dbdc17b9dbe8ddd209c82c87ed9ee849","tid":1248831,"uid":98431,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-21T14:40:27.000Z","msg":"新新地AC<br />\n<br />\n要走要留 自己睇路"},{"pid":"c883846043a0aa5c0e3a1c6f016c45c8cfc2d5dd","tid":1248831,"uid":168960,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:41:27.000Z","msg":"唔推"},{"pid":"704f76fda69193c97b4336c6e1abc32e2b48b0a6","tid":1248831,"uid":260887,"like":0,"dislike":0,"score":0,"quote":{"pid":"4eaeff99adeec7e85dca3aa05e815c5f8f30628e","tid":1248831,"uid":30408,"like":5,"dislike":0,"score":5,"citedBy":1,"replyTime":"2019-06-21T14:37:34.000Z","msg":"都係果句唔走唔好留係警總<br />\n政總大把地方<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2019-06-21T14:41:28.000Z","msg":"Push<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"86f07f644cdf1bf6145357af7d7bdbe60597339c","tid":1248831,"uid":147367,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-21T14:42:53.000Z","msg":"凌晨散仲有一個好處<br />\n等於製造一個地獄更比班狗，等佢哋自己內部都分化"},{"pid":"abe4b74ead21480cd3f7a465bdd13bef389d0a77","tid":1248831,"uid":231206,"like":2,"dislike":0,"score":2,"quote":{"pid":"dcfa0077dbdc17b9dbe8ddd209c82c87ed9ee849","tid":1248831,"uid":98431,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-06-21T14:40:27.000Z","msg":"新新地AC<br />\n<br />\n要走要留 自己睇路"},"citedBy":0,"replyTime":"2019-06-21T14:44:59.000Z","msg":"舊登唔係叫呢個名 少上連登<br />\n要走要留 真係自己決定<br />\n<br />\n但人走左既話 一人少就好易比人做野<br />\n話就話宜家唔走 夜晚無機會走 又無支援<br />\n但其實人多唔走既話 根本不需支援<br />\n宜家一走 留低果班就真係無人支援佢地啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /><br />\n<br />\n6月9果陣 就係咁樣 D人走哂又無車黎到支援<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><br />\n果時睇住D狗衝埋黎 局住捱左好多棍<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"}]}