if\" class=\"hkgmoji\" />"},{"pid":"a341ee1d785dc0602f82dee954520c7f6420e613","tid":1254191,"uid":79145,"like":5,"dislike":1,"score":4,"citedBy":0,"replyTime":"2019-06-24T04:04:40.000Z","msg":"<blockquote><img src=\"https://cdn.hk01.com/di/media/images/2947642/org/51b9dec34dce3dda522a44d99072d234.jpg/95dRWbibQ2te7bIQbeabIlR5OZ61hq005sbReObG0Xg?v=w1600\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F2947642%2Forg%2F51b9dec34dce3dda522a44d99072d234.jpg%2F95dRWbibQ2te7bIQbeabIlR5OZ61hq005sbReObG0Xg%3Fv%3Dw1600&h=e8f67aae&s={SIZE}\" /><br />\n<br />\n政府雖暫緩《逃犯條例》修訂，但事件餘波未了，反修例人士要求調查警方在6.12鎮壓中濫權，並要求釋放示威者及完全撤回修例。<br />\n<br />\n立法會保安事務委員會主席陳克勤接受港台節目《千禧年代》電話訪問時就指，不贊成成立任何獨立調查委員會，因所有調查最後都會將焦點放在警方身上。而對於民間要求釋放示威者，他就表示訴求不合理，因有關被捕人士一定是犯罪才會被捕，應相信香港司法制度有公平審訊。<br />\n<br />\n民建聯主席李慧琼早前曾指，政府若宣布撤回修例，民建聯支持者會理解。陳克勤則認為，<span style=\"font-size: x-large;\"><span style=\"color: red;\">暫緩和撤回，只是文字上不同寫法。</span></span><br />\n<br />\n而6月21日示威者包圍警總部，陳則表示，雖然看不到當日有嚴重肢體衝突，示威者包圍警車、塗鴉外牆是挑戰警方，又阻礙警方正常服務，絕對不能接受，警方不應該受脅迫就範。<br />\n<br />\n他又不認同「釋放示威者」的訴求，指港人一直相信香港司法制度，<span style=\"color: red;\">示威者被捕一定因為有犯法行為，因此必須起訴，又相信被告會有公平審訊機會，強調看不到釋放示威者的理據。</span><br />\n<br />\n6.12包圍立法會時，警方曾使用布袋彈、橡膠子彈鎮壓，有包括記者等的在場人士頭部中彈，民間要成立獨立調查委員會徹查。陳克勤就表示，<span style=\"color: red;\">所有針對警方的獨立調查委員會都不贊成，認為調查會影響警方士氣，亦不會公正。</span><br />\n<br />\n<a href=\"https://www.hk01.com/%E6%94%BF%E6%83%85/343906/%E9%80%83%E7%8A%AF%E6%A2%9D%E4%BE%8B-%E9%99%B3%E5%85%8B%E5%8B%A4-%E9%87%8B%E6%94%BE%E7%A4%BA%E5%A8%81%E8%80%85%E4%B8%8D%E5%90%88%E7%90%86-%E8%AA%BF%E6%9F%A5%E8%AD%A6%E6%96%B9%E4%B8%8D%E6%9C%83%E5%85%AC%E6%AD%A3\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fwww.hk01.com%2F%25E6%2594%25BF%25E6%2583%2585%2F343906%2F%25E9%2580%2583%25E7%258A%25AF%25E6%25A2%259D%25E4%25BE%258B-%25E9%2599%25B3%25E5%2585%258B%25E5%258B%25A4-%25E9%2587%258B%25E6%2594%25BE%25E7%25A4%25BA%25E5%25A8%2581%25E8%2580%2585%25E4%25B8%258D%25E5%2590%2588%25E7%2590%2586-%25E8%25AA%25BF%25E6%259F%25A5%25E8