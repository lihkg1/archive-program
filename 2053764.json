害人害物&hellip;&hellip;"},{"pid":"240b76fb7cebeb137ca1d8c051b7b08829212f4c","tid":2053764,"uid":14087,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T14:34:59.000Z","msg":"滅口"},{"pid":"8fa0a0baf83a92e9b16989def52cdffc6e019275","tid":2053764,"uid":54502,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T14:35:32.000Z","msg":"幾時到香港"},{"pid":"7ab9af7d8876856752d8fb09c55c17363d39870b","tid":2053764,"uid":101110,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T14:35:34.000Z","msg":"賭盤輸死人？<img src=\"/assets/faces/lm2/wonder2.gif\" class=\"hkgmoji\" />"},{"pid":"c07cc1d2e0f8b5649f61e6c31de9661cecd9e83c","tid":2053764,"uid":131696,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T14:36:16.000Z","msg":"中共做野？<img src=\"/assets/faces/pig/smile.gif\" class=\"hkgmoji\" />"},{"pid":"121ea8085eaec776bd5a22203fd184b89b50755d","tid":2053764,"uid":155095,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T14:36:26.000Z","msg":"<img src=\"https://cdn.hk01.com/di/media/images/1995355/org/3da3998b4f7310ceac56cfbee982af7a.jpg/7aET0n22aVryr8Q6nUfis3af3IQPKPO62ZoMx9maDMc?v=w1920r16_9\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fcdn.hk01.com%2Fdi%2Fmedia%2Fimages%2F1995355%2Forg%2F3da3998b4f7310ceac56cfbee982af7a.jpg%2F7aET0n22aVryr8Q6nUfis3af3IQPKPO62ZoMx9maDMc%3Fv%3Dw1920r16_9&h=4aadcf0d&s={SIZE}\" /><br />\n<br />\n<img src=\"https://statics.exmoo.com/uploads/2018-10-21/yTp8mTsRdVJutbXAe1ca.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fstatics.exmoo.com%2Fuploads%2F2018-10-21%2FyTp8mTsRdVJutbXAe1ca.jpg&h=c508da58&s={SIZE}\" />"},{"pid":"560efc61473d42c1b44adb1d94b1ff2cf00aff32","tid":2053764,"uid":186074,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-06-06T14:44:24.000Z","msg":"老闆燒幾十億搵你call呢隻雞黎    <br />\n<br />\n你連隻雞電話number都整唔見<br />\n<br />\n你估班老細係水魚？江湖規矩  你懂的"},{"pid":"88fa328f60c02ec31fa42d0ac5740d5f5e096bfd","tid":2053764,"uid":67186,"like":0,