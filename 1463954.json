係你而家去搵嘢塞機場做乜鳩？"},{"pid":"bb56ca70ba6ab76ae3ac09e475e34e815e17f6ec","tid":1463954,"uid":216800,"like":0,"dislike":0,"score":0,"quote":{"pid":"08eb9ba7e7ace8e585700ad3f63b9fe64176c2fb","tid":1463954,"uid":7630,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-08-13T14:31:58.000Z","msg":"幫推"},"citedBy":0,"replyTime":"2019-08-13T14:36:14.000Z","msg":"多謝你<img src=\"/assets/faces/pig/wail.gif\" class=\"hkgmoji\" />"}]}