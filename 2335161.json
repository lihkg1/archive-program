姐係換言之對一般人嚟講都係需要畀錢買啦<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n由覺得唔需要畀錢去到願意攞幾舊水支持思想上算好大進步<br />\n但仍需努力<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"a632c20a8b77b206f9caadeccd544814443afa5b","tid":2335161,"uid":284432,"like":1,"dislike":1,"score":0,"citedBy":1,"replyTime":"2020-12-23T11:35:04.000Z","msg":"此回覆已被刪除"},{"pid":"97cae620474d3e7749e46bd3c2ffa08db71d4878","tid":2335161,"uid":284432,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2020-12-23T11:36:15.000Z","msg":"此回覆已被刪除"},{"pid":"6bfbca8290a9f2d6bea8097146978815240c447b","tid":2335161,"uid":370583,"like":0,"dislike":0,"score":0,"quote":{"pid":"fbcd374ed0b3c6558c373bff7b86f04d1de47589","tid":2335161,"uid":284432,"like":15,"dislike":0,"score":15,"citedBy":2,"replyTime":"2020-12-21T16:39:43.000Z","msg":"此回覆已被刪除"},"citedBy":1,"replyTime":"2020-12-23T16:33:25.000Z","msg":"好多都冇，得番啲炒到過九千幾嗰D☠️"},{"pid":"6dc99ce418447e3f2d77a9abd406b39f31c2b8ea","tid":2335161,"uid":370583,"like":0,"dislike":0,"score":0,"quote":{"pid":"cad952bb617290bd0d0b1b616e50ac66413ce6d9","tid":2335161,"uid":130278,"like":17,"dislike":1,"score":16,"citedBy":4,"replyTime":"2020-12-21T17:32:23.000Z","msg":"還掂都係，等2月3080ti"},"citedBy":0,"replyTime":"2020-12-23T16:33:52.000Z","msg":"都唔同價位"},{"pid":"7e5609903c847d99b8dd213007d7c9dc1a5661c5","tid":2335161,"uid":284432,"like":0,"dislike":0,"score":0,"citedBy":2,"replyTime":"2020-12-23T17:21:12.000Z","msg":"此回覆已被刪除"},{"pid":"4339438836b1336f4641d04e9fac673c843e2e61","tid":2335161,"uid":130278,"like":0,"dislike":0,"score":0,"quote":{"pid":"7e5609903c847d99b8dd213007d7c9dc1a5661c5","tid":2335161,"uid":284432,"like":0,"dislike":0,"score":0,"quote":{"pid":"6bfbca8290a9f2d6bea8097146978815240c447b","tid":2335161,"uid":370583,"like":0,"dislike":0,"score":0,"quote":{"pid":"fbcd374ed0b3c6558c373bff7b86f04d1de47589","tid":2335161,"uid":284432,"like":15,"dislike":0,"score":15,"citedBy":2,"replyTime":"2020-12-21T16:39:43.000Z","msg":"此回覆已被刪除"},"citedBy"