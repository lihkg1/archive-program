ces/normal/good.gif\" class=\"hkgmoji\" />"},{"pid":"baebfb09ab8d34b9c5ccdcae8f8f768080e87895","tid":260160,"uid":49197,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2017-05-27T14:29:31.000Z","msg":"<blockquote><blockquote>炒哂車？柒咗？</blockquote><br />\n炒車<img src=\"/assets/faces/normal/good.gif\" class=\"hkgmoji\" /></blockquote><br />\n炒車好似係集體,個人要唸過另一個"},{"pid":"0b43ce1c25d338fb7b5e42cc249774b1178d3394","tid":260160,"uid":58552,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:31:06.000Z","msg":"匪語"},{"pid":"6a735f8105835dec8e9dbe78abd3dd9c2e8b2354","tid":260160,"uid":25468,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:32:53.000Z","msg":"被打臉<br />\n被落面"},{"pid":"055fd3d374bb85391b2cac60eda6fa629141e5f4","tid":260160,"uid":74442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:35:22.000Z","msg":"蝗語討厭嘅地方主要係因為蝗文化水平低<br />\n用字好唔嚴謹，你作潮字無問題<br />\n但個定義要清晰，落人面又話打臉，自打咀巴又係打臉，極低質"},{"pid":"a19dfe391705d3dbf3587a05026f2e3bf05a323b","tid":260160,"uid":54183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:44:41.000Z","msg":"此回覆已被刪除"},{"pid":"60216bc4330e86f410aa58e3d96dbde8e8171f71","tid":260160,"uid":29804,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:47:52.000Z","msg":"<blockquote><blockquote>落你面</blockquote><br />\n錯晒意思<br />\n落你面=唔俾面你<br />\n<br />\n完全唔係&quot;打臉&quot;既意思</blockquote><br />\n完全唔知乜鳩野叫打臉"},{"pid":"3cb4fbbb76f1175dddba61849d9148164133d2ab","tid":260160,"uid":54183,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-05-27T14:50:12.000Z","msg":"此回覆已被刪除"},{"pid":"4c2f94a0ce11aad27fc6410396acaa462cc4b9cf","tid":260160,"uid":25424,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:51:10.000Z","msg":"<blockquote><blockquote><blockquote>落你面</blockquote><br />\n錯晒意思<br />\n落你面=唔俾面你<br />\n<br />\n完全唔係&quot;打臉&quot;既意思</blockquote><br />\n完全唔知乜鳩野叫打臉</blockquote><br />\n就係打塊面<br />\n打還打，唔好打塊面<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"0fd8b6efc3b5ba9e386b007980d2e4e6df537d11","tid":260160,"uid":54183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:53:08.000Z","msg":"此回覆已被刪除"},{"pid":"4830ea0b4c2519bdd54856b978809632ba35ce29","tid":260160,"uid":74442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:56:14.000Z","msg":"<blockquote><blockquote><blockquote><blockquote>落你面</blockquote><br />\n錯晒意思<br />\n落你面=唔俾面你<br />\n<br />\n完全唔係&quot;打臉&quot;既意思</blockquote><br />\n完全唔知乜鳩野叫打臉</blockquote><br />\n類似燈既意思<br />\n<br />\n但打臉既受詞範圍更廣，比燈既涵義更大，更通俗易明</blockquote><br />\n涵義更大只會引起更多誤會同亂用"},{"pid":"8bc9110f1a307022bb6adb6f8feb2024d03a534f","tid":260160,"uid":54183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:57:23.000Z","msg":"此回覆已被刪除"},{"pid":"8e640835e841405843e09fef3b8d088fa891e4af","tid":260160,"uid":98526,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:58:30.000Z","msg":"呀me"},{"pid":"11eb7bed588ad4510f60694e3590434777f9416a","tid":260160,"uid":54183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:58:40.000Z","msg":"此回覆已被刪除"},{"pid":"fee081541a497886ae9777676405e686d8170afe","tid":260160,"uid":74442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:59:06.000Z","msg":"<blockquote>打臉＝　集合左　＂燈+ 炒車 + 柒左＋自打嘴巴＂ 既意思<br />\n但更強調＂一耳光重重的打在臉上一樣＂既動態動詞<br />\n<br />\n<br />\n基本上搵唔到替代詞，正如＂吐槽＂一詞一樣</blockquote><br />\n吐嘈應該係窒頭窒勢嘅意思"},{"pid":"e78b77da28f4a252bb6ef685b9c79bbfa9ecf45a","tid":260160,"uid":84355,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T14:59:27.000Z","msg":"自膠"},{"pid":"ef8919acc62ae6759b64814fb3cfdc7101f6ee3b","tid":260160,"uid":41245,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:00:12.000Z","msg":"<blockquote>蝗語討厭嘅地方主要係因為蝗文化水平低<br />\n用字好唔嚴謹，你作潮字無問題<br />\n但個定義要清晰，落人面又話打臉，自打咀巴又係打臉，極低質</blockquote><br />\nAgger<br />\n佢地流行嘅原因係因為用字唔嚴謹，以至濫用，成日出現<br />\n啲 打造 呀，優化 呀，小鮮肉<br />\n我地香港點叫？<br />\n打造：製造、建造、塑造⋯<br />\n優化：維修、改善、升級<br />\n小鮮肉：型仔、靚仔、青靚白淨、陽光型靚仔、運動型靚仔、大隻仔<br />\n支那用嘅字一嚟唔準確、而且誇大不實，好容易做content farm嘅字眼，所以根本成個文化就係建基係依啲文化之上。內容準唔準確唔重要，重要係呃你睇以為好勁"},{"pid":"290a27c985e456a72747e8c12fdeddad50565622","tid":260160,"uid":74442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:00:18.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><blockquote>落你面</blockquote><br />\n錯晒意思<br />\n落你面=唔俾面你<br />\n<br />\n完全唔係&quot;打臉&quot;既意思</blockquote><br />\n完全唔知乜鳩野叫打臉</blockquote><br />\n類似燈既意思<br />\n<br />\n但打臉既受詞範圍更廣，比燈既涵義更大，更通俗易明</blockquote><br />\n涵義更大只會引起更多誤會同亂用</blockquote><br />\n涵義大不等於有歧義／多詞意　<br />\n好好琢磨一下我講咩吧<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n咁唔琢磨，你係講就講清楚唔講就算"},{"pid":"d05d6e491bf058f9934abba1e577f03e375f6f38","tid":260160,"uid":55614,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:01:30.000Z","msg":"車毀人亡"},{"pid":"f32a7adc4301d0fc5a49d83af412471dd683288a","tid":260160,"uid":44358,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:01:34.000Z","msg":"顏射<img src=\"/assets/faces/normal/angel.gif\" class=\"hkgmoji\" />"},{"pid":"fed781b44a8498cfa89d20630907747bf0a57f82","tid":260160,"uid":54183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:01:36.000Z","msg":"此回覆已被刪除"},{"pid":"c41a807d11881d82d7167fd44eba0c25a81c035d","tid":260160,"uid":54183,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:02:32.000Z","msg":"此回覆已被刪除"},{"pid":"16e16f5303485b89fab9f6735bd39fe8c0a95502","tid":260160,"uid":74442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:03:34.000Z","msg":"<blockquote><blockquote>蝗語討厭嘅地方主要係因為蝗文化水平低<br />\n用字好唔嚴謹，你作潮字無問題<br />\n但個定義要清晰，落人面又話打臉，自打咀巴又係打臉，極低質</blockquote><br />\nAgger<br />\n佢地流行嘅原因係因為用字唔嚴謹，以至濫用，成日出現<br />\n啲 打造 呀，優化 呀，小鮮肉<br />\n我地香港點叫？<br />\n打造：製造、建造、塑造⋯<br />\n優化：維修、改善、升級<br />\n小鮮肉：型仔、靚仔、青靚白淨、陽光型靚仔、運動型靚仔、大隻仔<br />\n支那用嘅字一嚟唔準確、而且誇大不實，好容易做content farm嘅字眼，所以根本成個文化就係建基係依啲文化之上。內容準唔準確唔重要，重要係呃你睇以為好勁</blockquote><br />\n打臉＝　集合左　＂燈+ 炒車 + 柒左＋自打嘴巴＂ 既意思<br />\n<br />\n如果橋本環奈講得啱，咁聽果個點知幾時係燈幾時係炒車幾時係自打咀巴？<br />\n<br />\n最極端就係果個乜撚嘢牛字，都戇尻，根本任佢講係咩意思。咁我駛撚用個牛字呀？咩字都得啦"},{"pid":"35806e0634de1cbdcc27dd62809ad1fd1878b199","tid":260160,"uid":74442,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:04:42.000Z","msg":"<blockquote><blockquote><blockquote>打臉＝　集合左　＂燈+ 炒車 + 柒左＋自打嘴巴＂ 既意思<br />\n但更強調＂一耳光重重的打在臉上一樣＂既動態動詞<br />\n<br />\n<br />\n基本上搵唔到替代詞，正如＂吐槽＂一詞一樣</blockquote><br />\n吐嘈應該係<span style=\"color: red;\">窒頭窒勢</span>嘅意思</blockquote><br />\n<img src=\"/assets/faces/normal/no.gif\" class=\"hkgmoji\" /> 　唔識就唔好亂講</blockquote><br />\n挑，胸無半點墨扮哂嘢"},{"pid":"648b57f9355275d586bbb2edb16bafb71005b02f","tid":260160,"uid":73547,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:04:53.000Z","msg":"被反駁？ 算唔算？"},{"pid":"861abb0bc41173dc06e7b291014929e5d61b4783","tid":260160,"uid":41245,"like":1,"dislike":1,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:04:55.000Z","msg":"<blockquote><blockquote><blockquote><blockquote><blockquote><blockquote><blockquote>落你面</blockquote><br />\n錯晒意思<br />\n落你面=唔俾面你<br />\n<br />\n完全唔係&quot;打臉&quot;既意思</blockquote><br />\n完全唔知乜鳩野叫打臉</blockquote><br />\n類似燈既意思<br />\n<br />\n但打臉既受詞範圍更廣，比燈既涵義更大，更通俗易明</blockquote><br />\n涵義更大只會引起更多誤會同亂用</blockquote><br />\n涵義大不等於有歧義／多詞意　<br />\n好好琢磨一下我講咩吧<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" /></blockquote><br />\n咁唔琢磨，你係講就講清楚唔講就算</blockquote><br />\n支那人文化，自己表達含糊不清，有利自己搬龍門<br />\n但大部分唔係有目的嘅人只係純屬詞貧，表達不清<br />\n用漢語嘅人用幾千年時間去為啲歧義嘅字配詞、造字，企圖令文字意思準確。支那人用幾廿年時間去造啲含糊不清嘅字要讀者自己去琢磨你嘅說話"},{"pid":"ac651748fd1f82dda869646d08b3df641761f7d2","tid":260160,"uid":33481,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2017-05-27T15:05:34.000Z","msg":"大巴車落去"},{"pid":"39e1f01689a672a5ad8dfba90d819c68a65840e8","tid":260160,"uid":48083,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-05-27T15:06:12.000Z","msg":"奶閪"},{"pid":"40558267e7045