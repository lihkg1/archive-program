mal/love.gif\" class=\"hkgmoji\" />"},{"pid":"f496e45c13c1b0010adba2ee6cf85327ca0fe4c2","tid":102983,"uid":35319,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T12:18:56.000Z","msg":"<blockquote>星期六就整呢個食<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /></blockquote><br />\n我尋晚醃咗，等陣又整<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><br />\n要用埋樽醬佢<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"63c947181005bcc0a6b356236c18e52e2cd16a3c","tid":102983,"uid":62532,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T12:40:15.000Z","msg":"<img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" />"},{"pid":"88b1f57dbfc6352faf28e9fdf16b1b716e57fe22","tid":102983,"uid":42009,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T13:21:08.000Z","msg":"<blockquote><blockquote><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/tongue.gif\" class=\"hkgmoji\" /></blockquote><br />\nhello 生鐵鑊<img src=\"/assets/faces/normal/bye.gif\" class=\"hkgmoji\" /></blockquote><br />\n生鐵鑊<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"6a9166feb4e6b1dc9d115bc6dfd42b97e4e94f5a","tid":102983,"uid":828,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T13:21:39.000Z","msg":"波波<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"b07095d4dee06312328782975063c01f1424eece","tid":102983,"uid":60858,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2017-02-01T13:34:45.000Z","msg":"波絲<img src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" /> 又話新年要hea唔整嘢嘅！<img src=\"/assets/faces/normal/hehe.gif\" class=\"hkgmoji\" /> 但我好鍾意食雞