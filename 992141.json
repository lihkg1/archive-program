"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" />"},{"pid":"279999ef1f96ec5b5afafdbd12c90bd72d90e152","tid":992141,"uid":52595,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-23T17:24:21.000Z","msg":"此回覆已被刪除"},{"pid":"ef19d3b2939142d550cdee5646ec34d71212a0d2","tid":992141,"uid":550,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-23T18:51:45.000Z","msg":"金田一個速水玲香"},{"pid":"c1545fc310197e214d53e0258b2d3f4acac26d62","tid":992141,"uid":60651,"like":0,"dislike":0,"score":0,"quote":{"pid":"7099a3bede27e52433f19cb6d2abc4d6d94107c6","tid":992141,"uid":25345,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-01-23T03:38:38.000Z","msg":"好似有套武俠小說係咁"},"citedBy":0,"replyTime":"2019-01-23T19:05:22.000Z","msg":"蓋世豪俠"},{"pid":"2437ff5955d6f20cef3dea255744e228667f9f94","tid":992141,"uid":123264,"like":2,"dislike":0,"score":2,"citedBy":0,"replyTime":"2019-01-23T19:10:54.000Z","msg":"小峰也表示，他和養育他的奶奶感情很深，現在他只想好好讀書，考上好大學，找到好工作，報答奶奶的養育之恩，並照顧長年不放棄找他的叔叔一家人。<br />\n<br />\n成件事如果唔係奶奶既話就會唔同哂<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" /> <br />\n小峰會比人賣走 可能好細個就死左 叔叔都浪費一世時間搵唔到個侄<img src=\"/assets/faces/normal/adore.gif\" class=\"hkgmoji\" />"},{"pid":"7ad3b995fc674367a12c7b7154446c6bb64f5172","tid":992141,"uid":191462,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-01-23T20:25:28.000Z","msg":"好似Netflix套陽關道咁<img src=\"/assets/faces/normal/surprise.gif\" class=\"hkgmoji\" />"}]}