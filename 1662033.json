a0e","tid":1662033,"uid":144000,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T13:44:33.000Z","msg":"唔好咁喇大家"},{"pid":"9e9111a971c045471615c488de20ce728fdb7964","tid":1662033,"uid":95181,"like":0,"dislike":0,"score":0,"quote":{"pid":"e0bb34c48cc341b9dec63fbd710870826a9e9f41","tid":1662033,"uid":144000,"like":0,"dislike":0,"score":0,"quote":{"pid":"76cd62afcb3ffca8f40b8a266b7a4b2d89d3b3ea","tid":1662033,"uid":100406,"like":0,"dislike":0,"score":0,"quote":{"pid":"28f39fcb115b035747b14aaf7e0a8bad821c0256","tid":1662033,"uid":144000,"like":0,"dislike":3,"score":-3,"citedBy":1,"replyTime":"2019-10-18T13:35:51.000Z","msg":"你老母臭閪<br />\n咁你推唔撚推啊"},"citedBy":1,"replyTime":"2019-10-18T13:36:24.000Z","msg":"吾推<img src=\"/assets/faces/pig/heard.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2019-10-18T13:37:30.000Z","msg":"吾你老母<br />\n字都唔識打<br />\n<img src=\"/assets/faces/normal/smile.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2019-10-18T13:45:02.000Z","msg":"吾推<img src=\"/assets/faces/lm2/kill.gif\" class=\"hkgmoji\" />"},{"pid":"c01a1bda10da45434c3314b206c997048db62862","tid":1662033,"uid":144000,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-10-18T13:45:14.000Z","msg":"<img src=\"https://na.cx/i/1gSdywn.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F1gSdywn.jpg&h=e0f0129d&s={SIZE}\" />"},{"pid":"7c7ca2adba2754969dbc64ef586429f944b8efd9","tid":1662033,"uid":108418,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-10-18T13:45:38.000Z","msg":"你係唔係啱啱沙田個絲打<br />\n<br />\n如果係嘅話，建議你唔好咁燥底，會嚇壞人，真心。我都明情況有幾嚴峻，我星期日一定會出，我會叫多幾個人出，一個叫一個，唔好屌走佢地。"}]}