6年的口號：「光復香港，時代革命」！事情的變質是由元朗事件引起的。<br />\n<a href=\"https://hk.news.appledaily.com/local/daily/article/20190806/20743857\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20190806%2F20743857&d=qWTZpUodHfCf2bB0mbfn0y3IRifvRw8PV%2BxDOhj55DY%3D&h=b7480a06\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fhk.news.appledaily.com%2Flocal%2Fdaily%2Farticle%2F20190806%2F20743857&h=d2757a6b\" target=\"_blank\">https://hk.news.appledaily.com/local/daily/article/20190806/20743857</a>"},"citedBy":0,"replyTime":"2019-08-21T23:52:04.000Z","msg":"好文，推"},{"pid":"99f7b14c98c898f426447dd7b67ac8e115dede10","tid":1494712,"uid":107611,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-08-22T01:42:13.000Z","msg":"10"}]}