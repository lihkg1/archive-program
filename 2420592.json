=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"53d58bee1f01fa2258a39fcbb234598bba291e6f","tid":2420592,"uid":13745,"like":0,"dislike":0,"score":0,"quote":{"pid":"ec8d9305e284751aa769554a0440ddc7f3e92dd1","tid":2420592,"uid":37413,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2021-02-24T05:09:37.000Z","msg":"Who cares 🤷🏻&zwj;♂️<br />\n而家議會真係唔想理，因為毫無作用"},"citedBy":1,"replyTime":"2021-02-24T05:14:44.000Z","msg":"區諾軒同民主黨都話唔放棄議會路線喎<img src=\"/assets/faces/normal/369.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/clown.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/ass.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/banghead.gif\" class=\"hkgmoji\" />"},{"pid":"bbaf45e480eaa8d0debabcd52d0bb0d761017b9f","tid":2420592,"uid":21279,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-24T05:15:57.000Z","msg":"泰博又贏<img src=\"/assets/faces/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"49e34a51b501ccdf6ea88445c5d38af21d7ff109","tid":2420592,"uid":305358,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-24T05:18:43.000Z","msg":"呢條友真係好撚狗<img src=\"/assets/faces/lny/censored.gif\" class=\"hkgmoji\" />"},{"pid":"6e4828472c713f9acdb46642524fb62315e116d8","tid":2420592,"uid":163801,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2021-02-24T05:19:06.000Z","msg":"投反對票都列入清單<img src=\"/assets/faces/dog/treat.gif\" class=\"hkgmoji\" />"},{"pid":"03f56e43798850fe90d80f02e876633c3218523a","tid":2420592,"uid":179775,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2021-02-24T05:19:42.000Z","msg":"太矮都應該入負面清單"}]}