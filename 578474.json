 src=\"/assets/faces/normal/kiss.gif\" class=\"hkgmoji\" />"},{"pid":"dd887b127a144063fb2065f2067549d3e9e6dcfb","tid":578474,"uid":69985,"like":0,"dislike":0,"score":0,"quote":{"pid":"9d2f6296d73223a7d104ef6b8e9f8924442115be","tid":578474,"uid":164527,"like":0,"dislike":0,"score":0,"quote":{"pid":"df78fafc9c43ed03f2a7292b476b210ecece829c","tid":578474,"uid":69985,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-03-02T15:57:41.000Z","msg":"<blockquote>你本身咩 cup</blockquote>"},"citedBy":2,"replyTime":"2018-03-02T16:10:28.000Z","msg":"本身係34A<img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> 而家係大B"},"citedBy":0,"replyTime":"2018-03-02T16:18:00.000Z","msg":"咁都 ok 啦<br />\n其實儲肥個人對波自然會大左"},{"pid":"5cb867a20f743cfe7b0ffacd05eec7dee70392d7","tid":578474,"uid":164527,"like":2,"dislike":0,"score":2,"quote":{"pid":"c353e12d5b49cb47eae129f16e6b00baf45e12d7","tid":578474,"uid":156197,"like":4,"dislike":0,"score":4,"citedBy":1,"replyTime":"2018-03-02T16:16:11.000Z","msg":"tried all of these stuff but turns out it just goes back to the normal size when you stop taking these supplements <br />\n<br />\ndefinitely not sustainable <img src=\"/assets/faces/normal/flowerface.gif\" class=\"hkgmoji\" />"},"citedBy":0,"replyTime":"2018-03-02T16:21:14.000Z","msg":"um it has labelled that for breast enlargements need take 2 tabs and 1 tab for sustainability <img src=\"/assets/faces/normal/dead.gif\" class=\"hkgmoji\" /> <br />\nso just looking for other alternative &gt;_&gt; taking supplement is just an safer method other than surgery <img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" />"},{"pid":"cc7d7901a98d32e10bdb92a6168d9a15ab1eeb4f","tid":578474,"uid":149357,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2018-03-02T16:41:25.000Z","msg":"係得就唔會有隆胸手術呢樣野出現啦<img src=\"/assets/faces/normal/frown.gif\" class=\"hkgmoji\" /> <br />\n同埋你一次試咁多樣野<br />\n唔知邊樣得邊樣唔得喎<br />\n應該一次用一樣啊嘛"},{"pid":"0e7b2248eb9218ea7fb2db0d9820015559d56ef2","tid":578474,"uid":144