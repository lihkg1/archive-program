/normal/cry.gif\" class=\"hkgmoji\" />"},{"pid":"55f9c7aa36fd86c71ec12f017cf1721980e33432","tid":855821,"uid":28195,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-10T09:57:55.000Z","msg":"私煙係梁振英系統既人，777真係好想689死"},{"pid":"69c6a8f1430ec3426e0d64a40d11b654d5c4f3fd","tid":855821,"uid":37902,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-10T09:59:09.000Z","msg":"私煙bb<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},{"pid":"90d5ed40d2761ebcd56170d166678d43767c62ba","tid":855821,"uid":22506,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-10T09:59:21.000Z","msg":"樓主個名<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"84a78ff62284db81d57c6aa4a8bc6515eb462048","tid":855821,"uid":207087,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-10T10:14:23.000Z","msg":"<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /> <img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" />"},{"pid":"c88cbd2cbc054a59bd587f90a698d656c0f4b831","tid":855821,"uid":96894,"like":0,"dislike":0,"score":0,"quote":{"pid":"69c6a8f1430ec3426e0d64a40d11b654d5c4f3fd","tid":855821,"uid":37902,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-10T09:59:09.000Z","msg":"私煙bb<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-10T11:18:42.000Z","msg":"<strong>曾任鄺美雲經理人　破產後屢被追債</strong><br />\n<br />\n<img src=\"https://na.cx/i/pOjE6t1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpOjE6t1.jpg&h=c1934182&s={SIZE}\" /><br />\n<br />\n原名李艷青（Lettie）的李偲嫣，可謂「一生傳奇」；年輕時在無綫做過臨時演員，1990 年代更曾擔任藝人鄺美雲和林志美的經理人 ，但疑因錢銀問題，與鄺解約收場，更一度破產；25 年間至少 20 次被人入稟追債或索償，包括地產商新世界和無綫電視。她近年亦涉虧空公款和欠債，與不少藍絲黨友決裂。<br />\n<br />\n2年前，「梁粉」彭春娥大呻被私煙騙財 20 萬 ，「佢周圍呃人錢呀，爭咗成過百萬呀&hellip;&hellip;唔係女神呀，係女神棍」；另一藍絲史先生更稱，私煙利用其愛國心色誘他 ，3年借他逾80萬，但一直不歸還，鬧爆偲嫣「殘花敗柳」、「一個仙都唔值」。<br />\n<br />\n<strong>藍絲叔轟殘花敗柳　梁粉嘲女神棍</strong><br />\n<br />\n不過李偲嫣近年的出位言行，仍叫一眾支持者「津津樂道」；不但高調撐國教、反同志，更率領藍絲批鬥，成為撐警界「女神」。曾批評學民 3 子絕食反國教是博同情的李偲嫣，4 年前竟絕食反佔中，3 年前更 Cosplay 學生妹 ，以一身水手校服在記者面前，大玩「跳飛機」撐警，相當出位。<br />\n<br />\n現年 50 有 4 的她，亦以「P 圖功力深厚」 ，廣為網民認知，更曾推出「寫真集」 。李偲嫣育有一子，前夫姓劉，二人很早離異。獨守空幃多年的她，去年宣佈找到第二春，今年 5 月與有港專「鋮浚哥」之稱的謝鋮浚（Gary）再婚 ，正式再被「私有化」。李的好友兼前上司梁美芬，也有出席其婚宴。"},{"pid":"0fdaf7adab71183d6cd150138923cb1480c41d5f","tid":855821,"uid":43173,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2018-10-10T11:49:33.000Z","msg":"呢個post會唔會爆正評<img src=\"/assets/faces/normal/sosad.gif\" class=\"hkgmoji\" />"},{"pid":"fd7062047ff86fb9f40112fdea9d935d4ad23d7b","tid":855821,"uid":19278,"like":0,"dislike":0,"score":0,"quote":{"pid":"c88cbd2cbc054a59bd587f90a698d656c0f4b831","tid":855821,"uid":96894,"like":0,"dislike":0,"score":0,"quote":{"pid":"69c6a8f1430ec3426e0d64a40d11b654d5c4f3fd","tid":855821,"uid":37902,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2018-10-10T09:59:09.000Z","msg":"私煙bb<img src=\"/assets/faces/dog/cry.gif\" class=\"hkgmoji\" />"},"citedBy":1,"replyTime":"2018-10-10T11:18:42.000Z","msg":"<strong>曾任鄺美雲經理人　破產後屢被追債</strong><br />\n<br />\n<img src=\"https://na.cx/i/pOjE6t1.jpg\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2FpOjE6t1.jpg&h=c1934182&s={SIZE}\" /><br />\n<br />\n原名李艷青（Lettie）的李偲嫣，可謂「一生傳奇」；年輕時在無綫做過臨時演員，1990 年代更曾擔任藝人鄺美雲和林志美的經理人 ，但疑因錢銀問題，與鄺解約收場，更一度破產；25 年間至少 20 次被人入稟追債或索償，包括地產商新世界和無綫電視。她近年亦涉虧空公款和欠債，與不少藍絲黨友決裂。<br />\n<br />\n2年前，「梁粉」彭春娥大呻被私煙騙財 20 萬 ，「佢周圍呃人錢呀，爭咗成過百萬呀&hellip;&hellip;唔係女神呀，係女神棍」；另一藍絲史先生更稱，私煙利用其愛國心色誘他 ，3年借他逾80萬，但一直不歸還，鬧爆偲嫣「殘花敗柳」、「一個仙都唔值」。<br />\n<br />\n<strong>藍絲叔轟殘花敗柳　梁粉嘲女神棍</strong><br />\n<br />\n不過李偲嫣近年的出位言行，仍叫一眾支持者「津津樂道」；不但高調撐國教、反同志，更率領藍絲批鬥，成為撐警界「女神」。曾批評學民 3 子絕食反國教是博同情的李偲嫣，4 年前竟絕食反佔中，3 年前更 Cosplay 學生妹 ，以一身水手校服在記者面前，大玩「跳飛機」撐警，相當出位。<br 