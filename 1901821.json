aces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"2a45fbe8fbc8ae07aaa40252751896204878c0b3","tid":1901821,"uid":146973,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T05:26:12.000Z","msg":"推呀<br />\nRIP藍絲港共中共"},{"pid":"33d42815e2632e7d9a7cd2b88bb1e3d030281a27","tid":1901821,"uid":49329,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T05:28:56.000Z","msg":"啱！<br />\n<br />\n一<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"3e6c0d3ba7f17f6ccf8f8da3e36b14c87b5c4389","tid":1901821,"uid":108757,"like":0,"dislike":0,"score":0,"quote":{"pid":"6148eca28c91fd98e56f83ff6f4ac037c1ea68cd","tid":1901821,"uid":184144,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2020-02-28T05:16:54.000Z","msg":"如果根據呢個原則，咁去廣告商fb洗版嘅行動，係咪應該要有改變？"},"citedBy":0,"replyTime":"2020-02-28T05:33:51.000Z","msg":"睇下對象係咩啦，如果係出晒名藍嘅，美心吉野家m記，洗佢版都無用，就唔好幫人推啦。<br />\n但有啲叫做中立或者唔出名嘅，佢會驚形象唔好，洗版就有啲用，因為佢無固定支持者，幫佢宣傳都無人care<br />\n呢點有啲保留嘅，或者有其他更好辦法<img src=\"/assets/faces/pig/sowhat.gif\" class=\"hkgmoji\" />"},{"pid":"74d231a40306eb93c907a44f7223169ebb19d572","tid":1901821,"uid":108757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T05:37:11.000Z","msg":"其實支持自己人比起唔幫對方宣傳更重要，大家要多啲留意例如傳真社，眾新聞，獨媒，呢啲page<img src=\"/assets/faces/pig/drum.gif\" class=\"hkgmoji\" />"},{"pid":"99cb7986ec412865035414017bec7a2a9741f786","tid":1901821,"uid":11643,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T05:37:14.000Z","msg":"推"},{"pid":"ed1c2ecf839998ba200ed70cbcd073f7f3e060de","tid":1901821,"uid":158404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T05:39:34.000Z","msg":"推"},{"pid":"adf7b4959b5058062cac82b5fade5d4721adbaf8","tid":1901821,"uid":108757,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2020-02-28T05:57:00.000Z","m