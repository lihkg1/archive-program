https%3A%2F%2Fna.cx%2Fi%2FMwXT0nt.gif&h=2bf00dd6&s={SIZE}\" />"},{"pid":"de104ece16bc781464a36fadabd4f0aa4eac4bac","tid":1360410,"uid":89006,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T01:00:35.000Z","msg":"push"},{"pid":"d2339cd89f7647237532efb459bcdf2c443fdc60","tid":1360410,"uid":50457,"like":0,"dislike":0,"score":0,"quote":{"pid":"a9ba1ef7d61a6be145bf6797c6abbe796fb0686f","tid":1360410,"uid":71447,"like":0,"dislike":0,"score":0,"citedBy":1,"replyTime":"2019-07-24T10:44:54.000Z","msg":"<span style=\"font-size: x-large;\">攬炒巴登報呢場仗未完<br />\n 攬炒巴登報呢場仗未完<br />\n 攬炒巴登報呢場仗未完</span><br />\n<br />\n我地要繼續上次G20登報經驗<br />\n今次繼續上Twitter宣傳 將香港變做全球的焦點!!<br />\n<br />\n方法依然好簡單<br />\n1. 上Twitter 用Hashtag #StandwithHK #FightforFreedom<br />\n同時配合番攬炒巴主題 加埋@BorisJohnson開一個Post<br />\n要求Boris Johnson回應我地<br />\n<br />\n2. 然後再入去 #StandwithHK #FightforFreedom 揀幾個Post<br />\nLink: <a href=\"https://twitter.com/hashtag/StandWithHK?src=hash\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Ftwitter.com%2Fhashtag%2FStandWithHK%3Fsrc%3Dhash&d=ye2s6s2DGg0XurdvegCh9UYD92OErucUe%2F0sHRi%2FZkY%3D&h=76f6d49e\" data-auto-link target=\"_blank\">https://twitter.com/hashtag/StandWithHK?src=hash</a><br />\nReweet一下<br />\nLike一下<br />\nComment一下<br />\n搞掂 得閒的話 做多幾下<br />\n可以做到一個Trend最好<br />\n但最唔到亦都唔緊要<br />\n<br />\n<strong>請大家謹記 一定一定一定要 脫離同溫層<br />\n連登有用 TG有用 蘋果有用 立場有用 連儂牆有用 和理非有用 勇武有用<br />\n但係國際關注亦都係非常有用!!<br />\n多一個外國人發聲<br />\n就多一分壓力比到中共<br />\n就多一分希望革命成功<br />\n所以請大家千萬千萬唔好放棄國際關注呢個支線任務</strong><br />\n<br />\nTwitter同埋Reddit係兩條非常重要國際戰線<br />\n大家千萬千萬千萬唔好忽略<br />\n希望大家可以養成一個習慣<br />\n用你每日上連登1/100的時間<br />\n盡量利多更多的Twitter<br />\n<br />\n<span style=\"font-size: small;\"><strong><span style=\"color: red;\">最後大吉利是講句<br />\n如果解放軍出坦克車 屠城<br />\n你第一時間反應會係嘜?<br />\n調頭走? 做烈士頂坦克車? 衝去外國大使館? 抑或係上連登宣傳? 定係打電話同屋企人講拜拜?<br />\n我的答案會係<br />\n拍片放上Twitter 然後@realDonaldTrump <br />\n然後就係等住帶美軍入城 成功攬炒</span></strong><br />\n</span><br />\n<strong><span style=\"font-size: xx-large;\">光復香港<br />\n時代革命</span></strong><br />\n#FightforFreedom<br />\n#StandwithHK<br />\n<br />\n<img src=\"https://media.giphy.com/media/RhkvtuUcntXSuoVzay/giphy.gif\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fmedia.giphy.com%2Fmedia%2FRhkvtuUcntXSuoVzay%2Fgiphy.gif&h=254e8117&s={SIZE}\" /><br />\n<img src=\"https://na.cx/i/4yert0A.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fna.cx%2Fi%2F4yert0A.png&h=8523d66c&s={SIZE}\" />"},"citedBy":0,"replyTime":"2019-07-25T01:03:06.000Z","msg":"幫手<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"6473bd449988c87f8d905e12cd56b9d15481a341","tid":1360410,"uid":227610,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T01:05:19.000Z","msg":"已幫like"},{"pid":"d4c5176d262864280a7c78297ebdd9304a6b4871","tid":1360410,"uid":71447,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T01:08:35.000Z","msg":"我地今日推爆Ｔｗｉｔｔｅｒ！！！"},{"pid":"12c0dd04f8fa1fe65b8bc34f38e9dca60ba304ed","tid":1360410,"uid":197086,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T01:10:43.000Z","msg":"push"},{"pid":"93e1d70f375a6a89b6ec4cba71f3ae2eadfeb8d5","tid":1360410,"uid":71447,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T01:13:42.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"18e4d69f1697c8dd82b764ad02d8209cd12f5c3b","tid":1360410,"uid":10402,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T01:16:43.000Z","msg":"push"},{"pid":"0991fea5931cba184d59a99417d8ade2ab40366d","tid":1360410,"uid":219444,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-25T01:17:54.000Z","msg":"Pish"},{"pid":"dfc2251dcc0a5378e26c24d63c94a5119be9ed33","tid":1360410,"uid":71447,"like":0,"dislike":0,"score":0,"