lih.kg/thumbnail?u=https%3A%2F%2Fs14.postimg.org%2F4ichm3wg1%2F1516171151944.png&h=02ab2e62&s={SIZE}\" /><br />\n<br />\n<img src=\"https://s14.postimg.org/jr2ezyq5d/1516171268632.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs14.postimg.org%2Fjr2ezyq5d%2F1516171268632.png&h=0a9a6f66&s={SIZE}\" /><br />\n<br />\n<img src=\"https://s14.postimg.org/5xe2b2pw1/1516171326975.png\" data-thumbnail-src=\"https://i.lih.kg/thumbnail?u=https%3A%2F%2Fs14.postimg.org%2F5xe2b2pw1%2F1516171326975.png&h=ed2675fe&s={SIZE}\" /><br />\n<br />\n<span style=\"color: teal;\"><span style=\"font-size: xx-large;\"><strong>溫馨提示: 肥絲大隻其實你咁撚柒，不如開post或者留comment之前，咨詢一下你老母既意見先，咁會減少好多被人恥笑既機會<img src=\"/assets/faces/big/smile.gif\" class=\"hkgmoji\" /> </strong></span></span>"},{"pid":"3b739ab0b8986dd992f7b4c2ba3b05e4502b178d","tid":531833,"uid":48796,"like":2,"dislike":3,"score":-1,"citedBy":4,"replyTime":"2018-01-17T08:41:38.000Z","msg":"留意到佢轉咗名叫「大隻肥絲」又轉咗藍色字 <img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /> 柒到唔敢面對自己 <img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},{"pid":"ca08d78f05efa70cd5eee90fb410c42c6e904fe2","tid":531833,"uid":21423,"like":10,"dislike":22,"score":-12,"citedBy":0,"replyTime":"2018-01-17T08:46:41.000Z","msg":"此回覆已被刪除"},{"pid":"9c93eeac305aab40c73817804df8b824df6ffa67","tid":531833,"uid":39800,"like":0,"dislike":0,"score":0,"quote":{"pid":"3b739ab0b8986dd992f7b4c2ba3b05e4502b178d","tid":531833,"uid":48796,"like":2,"dislike":3,"score":-1,"citedBy":4,"replyTime":"2018-01-17T08:41:38.000Z","msg":"留意到佢轉咗名叫「大隻肥絲」又轉咗藍色字 <img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /> 柒到唔敢面對自己 <img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},"citedBy":2,"replyTime":"2018-01-17T08:47:11.000Z","msg":"第個ac黎<br />\n係咪funson就唔知"},{"pid":"e93e21c94bc1d1c7f25de84facec4d51edab23e3","tid":531833,"uid":21423,"like":4,"dislike":1,"score":3,"citedBy":1,"replyTime":"2018-01-17T08:47:30.000Z","msg":"此回覆已被刪除"},{"pid":"b5e8ade9