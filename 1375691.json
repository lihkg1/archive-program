{"tid":1375691,"cid":1,"subCid":0,"title":"7月27-28日晚上11:59-0010銅鑼灣連儂場尋片+證人","createTime":"2019-07-28T06:27:10.000Z","updateTime":"2019-07-30T00:44:12.000Z","uid":32612,"like":40,"dislike":0,"uniUserReply":37,"replies":[{"pid":"05f7505da2155df5a131b572c391013fc61a78ce","tid":1375691,"uid":32612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T06:27:10.000Z","msg":"<span style=\"font-size: xx-large;\"><span style=\"color: red;\">銅鑼灣波斯富街天橋</span></span><br />\n我係樓梯比藍絲打果個男仔  <br />\n希望搵到片證明我冇還手<br />\n 事發經過係見到幾個藍絲係連儂牆撕紙<br />\n我上前拍片 被追打到樓梯我冇還過手<br />\n事後藍絲再與另一男子打鬥  <br />\n警察到場 藍絲話我有份打佢<br />\n我希望有巴絲有當時既片<br />\n我唔想比人老屈比人告 <br />\n因為我真係冇還手"},{"pid":"a67967db2bf3145090d0286b42ac1575fd7a509f","tid":1375691,"uid":32612,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-07-28T06:27:17.000Z","msg":"推"},{"pid":"fc97bde0d4453708d8ef5a19f107105596f5040c","tid":1375691,"uid":32612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T06:27:38.000Z","msg":"推"},{"pid":"fc15dfd8442881dc3b29b1017522bbea0297ae4d","tid":1375691,"uid":32612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T06:28:41.000Z","msg":"推"},{"pid":"a1ad7b4cb90dc40e84848fd2485cf1fec72b7658","tid":1375691,"uid":32612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T06:28:59.000Z","msg":"有冇人幫到我"},{"pid":"7deb09b7bc96b5eb1292b23ac23ff2b3373c5b89","tid":1375691,"uid":32612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T06:29:21.000Z","msg":"。"},{"pid":"da5566e11cd24bd0d04745301f2b3128603d04c7","tid":1375691,"uid":1247,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T06:30:22.000Z","msg":"推"},{"pid":"a54cca532ae94022620f963c22eac564f007a4b7","tid":1375691,"uid":32612,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-07-28T06:31:37.000Z","msg":"<a href=\"https://m.facebook.com/story.php?story_fbid=10156727117709737&amp;id=2228262587450481&amp;sfnsn=xwwa&amp;funlid=gLRDLKwDYU03yXBw\" data-sr-url