3741,"uid":130140,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T23:41:46.000Z","msg":"推"},{"pid":"992ba59d7f2d4a6a7663b9981df5143017690296","tid":1233741,"uid":94958,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T23:42:19.000Z","msg":"走"},{"pid":"5575b6892318ceddc9761d7e593dd0ef716c940e","tid":1233741,"uid":112404,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T23:42:50.000Z","msg":"p"},{"pid":"1963f76705874c3da227e2d5e8f65b44bae461d1","tid":1233741,"uid":145730,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T23:44:00.000Z","msg":"推"},{"pid":"adee798b89a78bc3202bc62c59a5e300b5bb9e90","tid":1233741,"uid":147880,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T23:49:05.000Z","msg":"Push"},{"pid":"37e5948dd71d236f150ede3cf835ce402f3a4292","tid":1233741,"uid":46688,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T23:49:38.000Z","msg":"<img src=\"/assets/faces/normal/kill.gif\" class=\"hkgmoji\" />"},{"pid":"23f7fb305794fc30158e4949566222ba2e55a5fe","tid":1233741,"uid":64953,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T23:50:07.000Z","msg":"推"},{"pid":"85d9c0fcf0f5bdeb2e901f03b575acc84aede93c","tid":1233741,"uid":198386,"like":5,"dislike":0,"score":5,"citedBy":0,"replyTime":"2019-06-16T23:53:09.000Z","msg":"講真唔開會你留喺夏愨道都無用<br />\n狙擊林鄭，佢去邊就圍邊就最岩<img src=\"/assets/faces/normal/agree.gif\" class=\"hkgmoji\" /><br />\n佢真係玩野二讀大不了即時返金鐘"},{"pid":"91df0ef7b799fed7e6ece26ea1bf55c0ffae3b7f","tid":1233741,"uid":151248,"like":1,"dislike":0,"score":1,"citedBy":0,"replyTime":"2019-06-16T23:54:28.000Z","msg":"【逃犯條例】路透社引述資深警務人員︰警隊內不滿特首處理危機「瘋狂」　感成磨心 (10:54)<br />\n2019/6/15<br />\n<br />\n反對修訂《逃犯條例》示威周三（12日）釀成嚴重衝突，多人受傷，警方被批評使用過度武力，引起爭議。路透社周五（14日）引述多名資深警員稱，在今次暴力衝突中感到左右為難。<br />\n<br />\n報道引述「一名在指揮位置的資深警務人員」（a senior law enforcement officer in a command position）說，基於港人長久以來對內地法律制度的不信任，示威者反對修例並非不合理。他表示，警隊內「很多人」（a significant number）感到成為磨心，將這歸咎特首林鄭月娥處理今次危機的手法，形容是「瘋狂」的（&quot;It's madness.&quot;）。他又說，要解決事件，警員及示威者都無能為力，只有林鄭月娥才能解決此事。<br />\n<br />\n另一名資深執法人員稱，示威者今次更加堅決，如果政府不退讓，暴力勢必會升級。<br />\n<br />\n（明報）<a href=\"https://m.mingpao.com/ins/港聞/article/20190615/s00001/1560566718349/\" data-sr-url=\"https://r.lihkg.com/link?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%E6%B8%AF%E8%81%9E%2Farticle%2F20190615%2Fs00001%2F1560566718349%2F&d=sdtaPhne9yHE0zuhYC4X4VKtFW5C59xXAvdsbQ2qrIE%3D&h=2f42bc23\" data-ef-url=\"https://embed.lih.kg/frame?u=https%3A%2F%2Fm.mingpao.com%2Fins%2F%E6%B8%AF%E8%81%9E%2Farticle%2F20190615%2Fs00001%2F1560566718349%2F&h=0c8e788b\" data-auto-link target=\"_blank\">https://m.mingpao.com/ins/港聞/article/20190615/s00001/1560566718349/</a><br />\n【逃犯條例】路透社引述資深警務人員-警隊內不滿特首處理危機「瘋狂」-感成磨心<br />\n<br />\n自己諗<img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" /><img src=\"/assets/faces/normal/photo.gif\" class=\"hkgmoji\" />"},{"pid":"1105db4f6a6ad165007021f64055e360985fe08a","tid":1233741,"uid":167394,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T23:57:40.000Z","msg":"推"},{"pid":"683edfdc82e2101ce971d798cae2c369a1d819e5","tid":1233741,"uid":31330,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T23:58:28.000Z","msg":"推"},{"pid":"16b035c8278f8e792de94dd414796ceaae531b81","tid":1233741,"uid":195211,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-16T23:59:22.000Z","msg":"先撤<br />\n戰略性撤退！！"},{"pid":"bfc013570334f8d9235928e4a48d1accc56d0671","tid":1233741,"uid":62929,"like":0,"dislike":1,"score":-1,"citedBy":0,"replyTime":"2019-06-17T00:00:15.000Z","msg":"唔該你班傻鳩咪撚再叫人去禮賓府<br />\n<a href=\"https://lih.kg/1233958\" data-auto-link target=\"_blank\">https://lih.kg/1233958</a><br />\n- 分享自 LIHKG 討論區"},{"pid":"ee21a4e0bd51df9d996f15f9f0fd11c86865df64","tid":1233741,"uid":151248,"like":0,"dislike":0,"score":0,"citedBy":0,"replyTime":"2019-06-17T00:01:09.000Z","msg":"請比機會佢地推返個波比林奠<img src=\"/assets/faces/dog/sm